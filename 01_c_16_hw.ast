			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“什么意思啊！？唔……橘君老是把人家当小孩子。我可是前辈哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「什麼意思啊！？唔……橘君老是把人家當小孩子。我可是前輩哦？」",
