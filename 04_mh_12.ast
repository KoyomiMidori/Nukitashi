				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're not going to take the same direct approach that we did yesterday. Now that I've had time to prepare, we can outsmart them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我已经不会再犯同样的错误了。现在的我，有能够超越那些家伙的对策和力量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我已經不會再犯同樣的錯誤了。現在的我，有能夠超越那些傢伙的對策和力量。",
