					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You think I'd be joking about this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你觉得我会在这种情况下开玩笑吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你覺得我會在這種情況下開玩笑嗎？」",
					{"rt2"},
