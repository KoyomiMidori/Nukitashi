					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“因为这个岛的缘故，我们的风俗产业生意可惨淡了……虽然我另外经营了副业……不过完全回不了本啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「因為這個島的緣故，我們的風俗產業生意可慘淡了……雖然我另外經營了副業……不過完全回不了本啊。」",
					{"rt2"},
				},
			},
		},
