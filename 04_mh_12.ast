	["0089_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yesterday we were so close to our objective, yet suffered a humiliating defeat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"昨天我在接近目的的时候，品尝到了悲惨败北的屈辱。",
