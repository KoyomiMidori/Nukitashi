			cn = {
				{
					"铃、真弓、圆……虽然和你们一起度过的日子并不长——但请助我一臂之力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"鈴、真弓、圓……雖然和你們一起度過的日子並不長——但請助我一臂之力。",
					{"rt2"},
