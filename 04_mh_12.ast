			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Four bandits heading into the killzone. Aikaze heading to summit on autopilot. Point D suppressed. Only point E remains. You're up, Hotori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“敌性器4人全部冲进杀敌区。爱风用",
					{"ruby", text="・・・・"},
					"自动驾驶",
					{"/ruby"},
					"向山顶前进中……D点压制完成。剩下的只有E点……畔同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「敵性器4人全部衝進殺敵區。愛風用",
					{"ruby", text="・・・・"},
					"自動駕駛",
					{"/ruby"},
					"向山頂前進中……D點壓制完成。剩下的只有E點……畔同學。」",
					{"rt2"},
				},
			},
		},
