			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ugh, they sped up again!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“又加速了……！？唔——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「又加速了……！？唔——！」",
					{"rt2"},
				},
