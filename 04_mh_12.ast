			},
		},
		linkback = "0089_00216",
		linknext = "0089_00218",
		line = 3232,
	},
	["0089_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We'll never be able to take the SS head-on. There's way too many of them. There's only one solution.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果无法在数量上与FS匹敌，那怎么办？答案很简单。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果無法在數量上與FS匹敵，那怎麼辦？答案很簡單。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00217",
		linknext = "0089_00219",
		line = 3242,
	},
	["0089_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wreak as much havoc as possible with their chain of command, so they can't fight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要最大限度地打乱他们的纪律，使之达到不能战斗的状态就可以了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要最大限度地打亂他們的紀律，使之達到不能戰鬥的狀態就可以了。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00218",
		linknext = "0089_00220",
		line = 3252,
	},
	["0089_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The easiest way to do that on this island is with wild sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛扰乱人的最好办法——那就是变态做爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島擾亂人的最好辦法——那就是變態做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00219",
