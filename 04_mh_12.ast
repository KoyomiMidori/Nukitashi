				{
					name = {"蘭", "Ran"},
					"“One of you? What the hell? She was flying!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“同伴……？怎么可能有那种愚蠢的事情……她不是飞在天上吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「同伴……？怎麼可能有那種愚蠢的事情……她不是飛在天上嗎！」",
