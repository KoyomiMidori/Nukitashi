					"Since it's still morning, the beach is already swarming with sex seekers in a fucking frenzy, but they're so engrossed in it that they don't pay any attention to us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一大清早的海滩上就有性触者们在肆无忌惮地性交，但他们似乎不在意我们的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一大清早的海灘上就有性觸者們在肆無忌憚地性交，但他們似乎不在意我們的事情。",
					{"rt2"},
				},
			},
		},
