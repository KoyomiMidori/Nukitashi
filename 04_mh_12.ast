	["0089_00833"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like that, they've gone back to normal and dispelled the gloomy atmosphere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才那沉重的空气不知跑到哪里去了——回过神时，已经是平常的氛围了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才那沉重的空氣不知跑到哪裡去了——回過神時，已經是平常的氛圍了。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00832",
		linknext = "0089_00834",
		line = 12599,
	},
	["0089_00834"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sudden failure of our mission was heartbreaking, but they're helping me cheer back up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因作战失败而挫败的心，也渐渐振作了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因作戰失敗而挫敗的心，也漸漸振作了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00833",
		linknext = "0089_00835",
		line = 12609,
	},
	["0089_00835"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure that as long as I'm with Hotori — and everyone else — that no matter how many times we get put on our ass, we'll always be able to get back up again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和畔——和这些同伴们在一起的话，即使失败了，也一定每次都能站起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和畔——和這些同伴們在一起的話，即使失敗了，也一定每次都能站起來。",
					{"rt2"},
				},
			},
		},
