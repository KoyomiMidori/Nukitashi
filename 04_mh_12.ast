		linkback = "0089_00525",
		linknext = "0089_00527",
		line = 8142,
	},
	["0089_00527"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The narrow gap separating us from Onabuta gradually starts to widen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与逼近的女部田的距离又瞬间拉开了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與逼近的女部田的距離又瞬間拉開了。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00526",
		linknext = "0089_00528",
		line = 8152,
	},
	["0089_00528"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori and I love each other.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——我和畔两情相悦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——我和畔兩情相悅。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00527",
		linknext = "0089_00529",
		line = 8162,
	},
	["0089_00529"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since that's finally sunk in, the bliss from my virginity-fueled fantasies coming true makes me tremble.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在我才终于知道了这一事实，并对处男的妄想成为现实一事感到兴奋不已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在我才終於知道了這一事實，並對處男的妄想成為現實一事感到興奮不已。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00528",
		linknext = "0089_00530",
		line = 8172,
	},
	["0089_00530"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's different from shaking in fear from the SS. It's the wild, irrepressible rushing of blood.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于震动的胸膛里高涨的不是面对FS的恐惧，而是令血液沸腾奔走的狂热情绪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"於震動的胸膛裡高漲的不是面對FS的恐懼，而是令血液沸騰奔走的狂熱情緒。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00529",
		linknext = "0089_00531",
		line = 8182,
	},
	["0089_00531"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Every time she says she loves me, my heart races even more. My pulse would put the SS' assault rifles to shame.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每当听到她说喜欢的时候，我的心脏就会加速跳动。鼓动以无法言喻的速度拍打着脉搏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每當聽到她說喜歡的時候，我的心臟就會加速跳動。鼓動以無法言喻的速度拍打著脈搏。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00530",
		linknext = "0089_00532",
		line = 8192,
	},
	["0089_00532"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel like I could do anything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在的我一定什么都能办到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在的我一定什麼都能辦到。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00531",
		linknext = "0089_00533",
		line = 8202,
	},
	["0089_00533"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could win an F1 race on a bicycle. I could run a marathon in under a minute.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不仅可以骑自行车在F1方程式比赛中获胜，还可以在1分钟内跑完全马。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不僅可以騎自行車在F1方程式比賽中獲勝，還可以在1分鐘內跑完全馬。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00532",
		linknext = "0089_00534",
		line = 8212,
	},
	["0089_00534"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could win gold medals in every olympic event and be home in time for breakfast, then go knock out an Indian elephant with a single punch.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奥运会的全部项目都能轻松摘下金牌，2秒内就能一拳KO印度象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奧運會的全部項目都能輕鬆摘下金牌，2秒內就能一拳KO印度象。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00533",
