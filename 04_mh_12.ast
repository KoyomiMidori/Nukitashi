				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“That again? You really think you can deceive me with that again? You really need a good punishment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“又是那个……你以为我会被这样的假东西骗好几次？看来要让你吃点苦头比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「又是那個……你以為我會被這樣的假東西騙好幾次？看來要讓你吃點苦頭比較好。」",
					{"rt2"},
				},
			},
		},
