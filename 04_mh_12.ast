		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks up at me, but her eyes seem to look far into the distance. I can't read her emotions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"抬头望过来的目光非常迷茫，无法读取感情。",
