		linkback = "0089_00792",
		linknext = "0089_00794",
		line = 12088,
	},
	["0089_00794"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1451", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“About that... What if they're actually trying to abolish the perverted sex law?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以我才猜想……或许，那些家伙的目的该不会是破坏条例……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以我才猜想……或許，那些傢伙的目的該不會是破壞條例……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00793",
		linknext = "0089_00795",
		line = 12100,
	},
	["0089_00795"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——你说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——你說什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00794",
		linknext = "0089_00796",
		line = 12112,
	},
	["0089_00796"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1452", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Of course, maybe it's just wishful thinking on my part, but it's a logical conclusion to make.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“当然，这也许只是对我们有利的解释……但也说得通……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「當然，這也許只是對我們有利的解釋……但也說得通……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00795",
		linknext = "0089_00797",
		line = 12124,
	},
	["0089_00797"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1453", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It's thanks to this island's unlimited sexual privileges that prostitution's dried up on the mainland. That's a good enough justification for them wanting to bring down the law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为能免费打炮的青蓝岛使本岛的风俗产业衰退是事实……破坏变态条例的动机很明确……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為能免費打炮的青藍島使本島的風俗產業衰退是事實……破壞變態條例的動機很明確……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00796",
		linknext = "0089_00798",
		line = 12136,
	},
	["0089_00798"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So that's the silver lining she meant...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明白她刚才说“不幸中的大幸”的理由了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明白她剛才說「不幸中的大幸」的理由了。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00797",
		linknext = "0089_00799",
		line = 12146,
	},
	["0089_00799"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Do they have the same objective as us?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过——他们的目的居然和我们一样？",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過——他們的目的居然和我們一樣？",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00798",
		linknext = "0089_00800",
		line = 12156,
	},
	["0089_00800"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If so, we wouldn't even have to do anything. We can just let the law be abolished.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果真是那样，就算放着不管，条例也将被破坏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果真是那樣，就算放著不管，條例也將被破壞。",
