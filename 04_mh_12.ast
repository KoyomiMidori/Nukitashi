		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With her engine roaring, Aikaze heads into the hills.",
					{"rt2"},
				},
			},
			cn = {
				{
					"爱风吼叫着，在山中奔驰。",
					{"rt2"},
				},
			},
			tw = {
				{
					"愛風吼叫著，在山中奔馳。",
					{"rt2"},
				},
