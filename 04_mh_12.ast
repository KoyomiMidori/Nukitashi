	["0089_00713"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once we get Fumino safely to our base, we can contact the old man, and our primary goal will be achieved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要将文乃平安送到基地，并与那位老人取得联系——我们的夙愿就要实现了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要將文乃平安送到基地，並與那位老人取得聯繫——我們的夙願就要實現了。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00712",
		linknext = "0089_00714",
		line = 11026,
	},
	["0089_00714"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was a precarious road, and we crossed numerous difficult bridges, but now I've managed to become a couple with Hotori, and protect Fumino from the evil clutches of the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"漫长而险峻的道路上，虽然碰过很多次危机……但最终还是与畔成为了恋人，并成功保护文乃不受FS的侵害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"漫長而險峻的道路上，雖然碰過很多次危機……但最終還是與畔成為了戀人，並成功保護文乃不受FS的侵害。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00713",
		linknext = "0089_00715",
		line = 11036,
	},
	["0089_00715"] = {
		{"text"},
		text = {
