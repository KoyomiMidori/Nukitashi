	["0089_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yuiko was the one who was there for Hotori during the olympiad and abandoned. I secretly retrieved her, since I couldn't just leave my first girlfriend behind like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"唯子——体欲节那天，为了帮助畔而抛了出去，然后我又偷偷回收了的，我的第一个女朋友。",
					{"rt2"},
				},
			},
			tw = {
				{
					"唯子——體欲節那天，為了幫助畔而拋了出去，然後我又偷偷回收了的，我的第一個女朋友。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00199",
		linknext = "0089_00201",
		line = 3007,
	},
	["0089_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe I'm being unreasonable to ask more of her after she did so much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明做了那样的事，却还要再次拜托它做这样的事，这可能不怎么合情理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明做了那樣的事，卻還要再次拜託它做這樣的事，這可能不怎麼合情理。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00200",
		linknext = "0089_00202",
		line = 3017,
	},
	["0089_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I need her help again.",
