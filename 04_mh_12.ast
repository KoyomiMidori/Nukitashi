			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That's what I do best! Leave it to me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我很擅长！交给我吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我很擅長！交給我吧！」",
