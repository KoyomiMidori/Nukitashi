		},
		linkback = "0089_00063",
		linknext = "0089_00065",
		line = 936,
	},
	["0089_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From this point on, it's a race against time. Every second counts, and my heart is pounding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"接下来就是速度赛。在争分夺秒的状态下，我的心跳开始加速。",
					{"rt2"},
				},
			},
			tw = {
				{
					"接下來就是速度賽。在爭分奪秒的狀態下，我的心跳開始加速。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00064",
		linknext = "0089_00066",
		line = 946,
	},
	["0089_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hopefully we'll get there before they capture Fumino, but we've got contingencies for if things go south.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在文乃被抓捕之前——不，最坏的情况是文乃被捕也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在文乃被抓捕之前——不，最壞的情況是文乃被捕也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00065",
		linknext = "0089_00067",
		line = 956,
	},
	["0089_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As long as they don't escape with her, we've still got a chance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果能在他们还在这里的这段期间内完成，就有胜算。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果能在他們還在這裡的這段期間內完成，就有勝算。",
					{"rt2"},
				},
			},
		},
