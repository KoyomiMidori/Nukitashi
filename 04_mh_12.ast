	["0089_00641"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I evade her sword she strikes with her legs, and then goes back to her sword. Her style is ever-changing, forged by combat with those trained in classical martial arts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"斩击被躲开就用扫腿，扫腿被躲开就用斩击，利用体术长时间玩弄猎物的变幻自如的战斗术。",
					{"rt2"},
				},
			},
			tw = {
				{
					"斬擊被躲開就用掃腿，掃腿被躲開就用斬擊，利用體術長時間玩弄獵物的變幻自如的戰鬥術。",
					{"rt2"},
				},
			},
		},
