		linkback = "0089_00522",
		linknext = "0089_00524",
		line = 8106,
	},
	["0089_00524"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never seen them as anything more than an annoyance, but right now they sound like a huge crowd giving us a standing ovation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前只觉得吵杂的鸣叫声，现在听起来却像观众毫不吝惜的赞叹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前只覺得吵雜的鳴叫聲，現在聽起來卻像觀眾毫不吝惜的讚嘆。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00523",
		linknext = "0089_00525",
		line = 8116,
	},
	["0089_00525"] = {
		{"fg", file="misaki_02f_00001", file1="misaki_02f_00124", file2="misaki_02f_00203", path=":fg/misaki_02f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1341", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I've wanted to tell you for so long! I love you, I love you! I love you, I love you, I love you I love you I love you!! I love you so, so much, Tachibana!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我一直一直都很想告诉你！我喜欢你……我喜欢你！喜欢你喜欢你喜欢你！！我最喜欢橘同学了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我一直一直都很想告訴你！我喜歡你……我喜歡你！喜歡你喜歡你喜歡你！！我最喜歡橘同學了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00524",
		linknext = "0089_00526",
		line = 8129,
	},
	["0089_00526"] = {
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00117", file2="ikuko_01f_00202", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
