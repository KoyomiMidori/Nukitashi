				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're falling even faster than we were traveling before, and the sandy beach below us is rapidly approaching.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们以超过自行车速度的趋势朝大地坠落，眼看着沙滩正向我们越靠越近。",
