	["0089_00864"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00205", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1377", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So, anyway... if it's wrong to have sex with someone you don't love, then if you love them... sex should be okay, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“所、所以说……橘同学虽然说过没有爱的做爱是不行的，不过如果有爱情……就可以了吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「所、所以說……橘同學雖然說過沒有愛的做愛是不行的，不過如果有愛情……就可以了吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00863",
		linknext = "0089_00865",
		line = 12998,
	},
	["0089_00865"] = {
