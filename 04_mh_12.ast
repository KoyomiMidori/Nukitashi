		line = 98,
	},
	["0089_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, thinking back, retreating was what we needed to secure victory today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——现在回想起来，逃回来一定是为了能在今天得到胜利。",
