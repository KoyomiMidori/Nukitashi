			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This won't work! There's a cliff up ahead, and if we don't stop we'll go over it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……不行。再往前就是断崖了……！如果不赶快停车，这样下去会掉下……！”",
