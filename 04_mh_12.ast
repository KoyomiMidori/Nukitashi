			en = {
				{
					"The saddle sprouts wings, and Tanizaki gracefully soars through the sky.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那瞬间，坐垫生出了翅膀——谷崎开始优雅地在空中飞翔。",
