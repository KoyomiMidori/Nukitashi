	},
	["0089_00825"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our transmitter got wasted when we went over that cliff, but this must mean they heard everything up to that point clear as day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从悬崖上跳下来的时候通讯器好像撞坏了，但是在那之前他们都一直在听。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從懸崖上跳下來的時候通訊器好像撞壞了，但是在那之前他們都一直在聽。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00824",
		linknext = "0089_00826",
		line = 12477,
	},
	["0089_00826"] = {
