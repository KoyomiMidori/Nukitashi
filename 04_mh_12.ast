					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在开始进入移送作业！大队长，反交尾势力的事情就拜托了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在開始進入移送作業！大隊長，反交尾勢力的事情就拜託了！」",
