			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“What was that? Answer me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“刚才的人影是……？那、那是什么？回答我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「剛才的人影是……？那、那是什麼？回答我！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00144",
		linknext = "0089_00146",
		line = 2235,
	},
	["0089_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Can't you guess? She's one of us. She's gonna go pick up the girl for us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不明白吗？是我们的同伴。她要去抢那个女孩。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你不明白嗎？是我們的同伴。她要去搶那個女孩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00145",
		linknext = "0089_00147",
