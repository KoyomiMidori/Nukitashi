				},
			},
		},
		linkback = "0089_00781",
		linknext = "0089_00783",
		line = 11963,
	},
	["0089_00783"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The boiling blood rushing to my head cools down in what feels like an instant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"涌上心头的血一下子冷静了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"湧上心頭的血一下子冷靜了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00782",
		linknext = "0089_00784",
		line = 11973,
	},
	["0089_00784"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry... Just tell me what you meant by a silver lining.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……对不起，你能继续说下去吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……對不起，你能繼續說下去嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00783",
		linknext = "0089_00785",
		line = 11987,
	},
	["0089_00785"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00116", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1449", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“All right. So there's a reason we've got yakuza running around the island. Basically, they're here to do 'business'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……首先，有关黑社会在青蓝岛理由……他们好像在做一些副业……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……首先，有關黑社會在青藍島理由……他們好像在做一些副業……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00784",
		linknext = "0089_00786",
		line = 12000,
	},
	["0089_00786"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Business... I remember Teshima mentioning something along those lines as he left.",
					{"rt2"},
				},
			},
			cn = {
				{
					"副业——手嶋在离开时也说过同样的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"副業——手嶋在離開時也說過同樣的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00785",
		linknext = "0089_00787",
		line = 12010,
	},
	["0089_00787"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1450", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Underground sex videos filmed here, that kinda thing. Technically illegal, but they had a system.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“例如私下贩卖在青蓝岛拍摄的色情视频……虽然这是被条例禁止的，但他们好像有组织地在做这些事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「例如私下販賣在青藍島拍攝的色情影片……雖然這是被條例禁止的，但他們好像有組織地在做這些事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00786",
		linknext = "0089_00788",
		line = 12022,
	},
	["0089_00788"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suddenly recall that time when I rescued Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我突然想起以前帮助畔时的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我突然想起以前幫助畔時的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00787",
		linknext = "0089_00789",
		line = 12032,
	},
	["0089_00789"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They were coercing Hotori into sex against her will, and they said they'd sell the video.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个时候的家伙们也是无视正在抵抗的畔，打算强迫发生性行为，并说要把拍的视频卖出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個時候的傢伙們也是無視正在抵抗的畔，打算強迫發生性行為，並說要把拍的影片賣出去。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00788",
		linknext = "0089_00790",
		line = 12042,
	},
	["0089_00790"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Were they Yakuza, too? Were they connected to Teshima, and the ones who took Fumino away?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那同样也是黑社会——也是手嶋一伙人干的好事吗？是那样的人，带走了文乃吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那同樣也是黑社會——也是手嶋一夥人幹的好事嗎？是那樣的人，帶走了文乃嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00789",
		linknext = "0089_00791",
		line = 12052,
	},
	["0089_00791"] = {
		{"se", id=0, loop=0, file="se_a127"},
		{"fg", file="misaki_02l_00001", file1="misaki_02l_00106", file2="misaki_02l_00204", path=":fg/misaki_02l/", id=6, lv=5, head="misaki_02l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
