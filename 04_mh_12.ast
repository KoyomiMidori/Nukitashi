	["0089_00822"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“W-Wait a minute... I thought the jamming would've screwed up our comms?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等、等一下……因为有电波干扰，不是应该不能通讯了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等、等一下……因為有電波干擾，不是應該不能通訊了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00821",
		linknext = "0089_00823",
		line = 12442,
	},
	["0089_00823"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1455", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hey, that's nothing I can't jury-rig some kind of way around.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那种程度我随便调整一下就解决了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那種程度我隨便調整一下就解決了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00822",
		linknext = "0089_00824",
		line = 12456,
	},
	["0089_00824"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, shit...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00823",
