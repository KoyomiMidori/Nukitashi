	["0089_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With an unusual sound, a shadow comes out from behind me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"伴随着一声怪声，从我背后跳出一个人影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"伴隨著一聲怪聲，從我背後跳出一個人影。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00142",
