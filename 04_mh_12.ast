			tw = {
				{
					"這樣就可以了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00801",
		linknext = "0089_00803",
		line = 12194,
	},
	["0089_00803"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if they achieve the end I want, am I able to condone their means?",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为最后能破坏条例，所以就要默许那些人的做法吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為最後能破壞條例，所以就要默許那些人的做法嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00802",
		linknext = "0089_00804",
		line = 12204,
	},
	["0089_00804"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No fucking way... Or maybe that's just what my feelings are trying to tell me in the face of the facts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么可能可以——这样的想法，难道是我幼稚的感情论吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼可能可以——這樣的想法，難道是我幼稚的感情論嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00803",
		linknext = "0089_00805",
		line = 12214,
	},
	["0089_00805"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't come to terms with the emotional whirlwind within me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无法消化的感情，在脑海中卷起了漩涡。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無法消化的感情，在腦海中捲起了漩渦。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00804",
		linknext = "0089_00806",
		line = 12224,
	},
	["0089_00806"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00805",
		linknext = "0089_00807",
		line = 12236,
	},
	["0089_00807"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Right now, though, there's one conclusion I can come to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎样——有件事是显而易见的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎樣——有件事是顯而易見的。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00806",
		linknext = "0089_00808",
		line = 12246,
	},
	["0089_00808"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Whether I condone their methods or not, we can't do jack shit about it right now. We're all thoroughly drained.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管承不承认他们的行为——在大家都累了的现在，我们什么都做不到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管承不承認他們的行為——在大家都累了的現在，我們什麼都做不到。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00807",
		linknext = "0089_00809",
		line = 12256,
	},
	["0089_00809"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A silence hangs in the air, further dimming the gloomy mood.",
					{"rt2"},
				},
			},
			cn = {
				{
					"沉默，沉重的空气充满了房间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沉默，沉重的空氣充滿了房間。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00808",
		linknext = "0089_00810",
		line = 12266,
	},
	["0089_00810"] = {
		{"bgm", stop=1},
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00202", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1365", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“W-Well, not much sense stewing in it, right? At the very least, we're all together, safe and sound, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好、好了……这样消沉也没有用……难得大家在一起……不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好、好了……這樣消沉也沒有用……難得大家在一起……不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00809",
		linknext = "0089_00811",
		line = 12280,
	},
	["0089_00811"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2039", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yup-yup! Misaki gets it! Since we're all here, this calls for a celebration!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯，美岬酱说得对！机会难得，大家一起庆祝吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯，美岬醬說得對！機會難得，大家一起慶祝吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00810",
		linknext = "0089_00812",
		line = 12294,
	},
	["0089_00812"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
