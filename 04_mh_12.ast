	},
	["0089_00056"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1426", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Roger that. Should I jam their comms?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“明白了……电波干扰呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「明白了……電波干擾呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00055",
		linknext = "0089_00057",
		line = 767,
	},
	["0089_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not yet. Once we do that, we're giving away our presence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还不用，一妨碍说不定就会被发现我们的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還不用，一妨礙說不定就會被發現我們的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00056",
		linknext = "0089_00058",
		line = 778,
	},
	["0089_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The rest of you, let Aikaze take you to your positions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“剩下的成员——就这样乘着爱风前往各自的地点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剩下的成員——就這樣乘著愛風前往各自的地點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00057",
		linknext = "0089_00059",
		line = 789,
	},
	["0089_00059"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You ready, Hotori? We'll need you to do some 'likely driving' to get us out of here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——畔，准备好了吗？接下来的路程就拜托你危险驾驶了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——畔，準備好了嗎？接下來的路程就拜託你危險駕駛了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00058",
		linknext = "0089_00060",
		line = 801,
	},
	["0089_00060"] = {
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
