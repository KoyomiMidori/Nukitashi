	["0089_00207"] = {
		{"se", id=0, loop=0, file="se_b056"},
		{"fg", file="ran_01m_00001", file1="ran_01m_00103", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
