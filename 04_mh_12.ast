	["0089_00014"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2029", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, no, but... Did you get any sleep last night?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不……但你昨天有睡吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不……但你昨天有睡嗎？」",
					{"rt2"},
