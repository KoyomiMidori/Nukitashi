	["0089_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If it hit my head, I'd immediately be down for the count. If it hit my leg, I wouldn't be able to walk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"打到头会马上昏倒，打到脚会马上走不动——那样的一击。",
					{"rt2"},
				},
			},
			tw = {
				{
					"打到頭會馬上昏倒，打到腳會馬上走不動——那樣的一擊。",
					{"rt2"},
				},
			},
		},
