	["0089_00223"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Blow-up dolls ain't nothin' to fuck with. I was at the olympiad. I saw how large-scale usage of hoelighters can produce incredible aphrodisiacal effects.",
					{"rt2"},
				},
			},
			cn = {
				{
					"别小看充气娃娃。通过体欲节的事件，已经证实了如果与催淫笔结合，将产生惊人的催淫效果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"別小看充氣娃娃。通過體欲節的事件，已經證實瞭如果與催淫筆結合，將產生驚人的催淫效果。",
					{"rt2"},
