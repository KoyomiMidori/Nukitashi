	["0089_00114"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1438", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Maybe the guard is changing. Alternative route would take approximately nine extra minutes. What do you want to do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“也许是为了换班刚好在一起……如果使用迂回线路估计会产生约9分钟的延迟，怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「也許是為了換班剛好在一起……如果使用迂迴線路估計會產生約9分鐘的延遲，怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00113",
		linknext = "0089_00115",
		line = 1744,
	},
	["0089_00115"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That could be nine minutes too long. I'll take them all on at once!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么能给他们9分钟的时间——也就4个人，我会打倒他们的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼能給他們9分鐘的時間——也就4個人，我會打倒他們的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00114",
		linknext = "0089_00116",
		line = 1756,
	},
