		{"fg", file="misaki_01f_00001", file1="misaki_01f_00123", file2="misaki_01f_00205", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1338", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Th-That's not fair! So not fair! How can you say that now!? I was gonna at least wait until this was all over to tell you!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“太……太狡猾了！太狡猾了！你竟然在这种时候说出来！我本来想等一切都结束了再说的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「太……太狡猾了！太狡猾了！你竟然在這種時候說出來！我本來想等一切都結束了再說的！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00518",
		linknext = "0089_00520",
		line = 8048,
	},
	["0089_00520"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00303", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bwahahaha! I said it, so I win! I love you so damn much that I don't fucking care how I tell you!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈哈！说了就赢了！告白和时间地点有关系吗！我就是这么喜欢你！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈哈！說了就贏了！告白和時間地點有關係嗎！我就是這麼喜歡你！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00519",
		linknext = "0089_00521",
		line = 8060,
	},
	["0089_00521"] = {
		{"se", id=0, loop=0, file="se_a192"},
		{"cgact", file="cgact", id=16, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", lv=5, x=-100, y=0},
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00124", file2="misaki_01f_00205", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1339", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Whaaa!? I-Is that the only thing you know how to talk about!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“什么……！？我、我什么都还没说，你就像个笨蛋一样一直说喜欢我……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「什麼……！？我、我什麼都還沒說，你就像個笨蛋一樣一直說喜歡我……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00520",
		linknext = "0089_00522",
		line = 8075,
	},
	["0089_00522"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00122", file2="misaki_01f_00203", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1340", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“At least let me get a word in!! I love you too! I'm in love with you, too! Actually, I think I love you way more!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我……我也！我也喜欢橘同学！我爱你！应该说，我喜欢你更多！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我……我也！我也喜歡橘同學！我愛你！應該說，我喜歡你更多！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00521",
		linknext = "0089_00523",
		line = 8088,
	},
	["0089_00523"] = {
