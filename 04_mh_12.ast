		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The incredible impact makes us grunt weirdly, but we're alive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然由于受到了不得了的冲击，而发出了奇怪的声音——但是没有死。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然由於受到了不得了的衝擊，而發出了奇怪的聲音——但是沒有死。",
					{"rt2"},
				},
			},
		},
