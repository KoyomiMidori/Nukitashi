		{"text"},
		text = {
			vo = {
				{"vo", file="asane1437", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Enemy spotted, dead ahead. One team of four, likely point D's SS guards.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“敌影捕捉。前进方向D点，好像是警备队的FS。人数是1队——4人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「敵影捕捉。前進方向D點，好像是警備隊的FS。人數是1隊——4人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00111",
		linknext = "0089_00113",
		line = 1719,
	},
	["0089_00113"] = {
