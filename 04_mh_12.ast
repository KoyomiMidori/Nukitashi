		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"se", id=1, loop=1, file="se_d030", vol=60},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're back here again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回来了——这个地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回來了——這個地方。",
					{"rt2"},
