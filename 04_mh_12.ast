			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Thanks a million, Junnosuke. Ya truly was a huge help, gettin' Fumino outta the hands o' them fuckin' SS. Couldn't'a dun it without ya.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“谢了，淳之介君。多亏你把文乃从那些难缠的FS那里带了出来，真是帮了我大忙。那些家伙可让我头疼了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「謝了，淳之介君。多虧你把文乃從那些難纏的FS那裡帶了出來，真是幫了我大忙。那些傢伙可讓我頭痛了。」",
					{"rt2"},
				},
			},
		},
