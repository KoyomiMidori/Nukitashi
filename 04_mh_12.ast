	["0089_00213"] = {
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asane? How are things looking?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙音，情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙音，情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00212",
		linknext = "0089_00214",
		line = 3180,
	},
	["0089_00214"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1444", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“All the SS from points A to E are transitioning to 'thoroughly drenched' or 'diamond' state. No change to main group at summit... wait, hold on...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“A〜E点附近的FS全部进入淫乱状态。山顶附近的主队没有变化——啊……等一下，情况不太对……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「A〜E點附近的FS全部進入淫亂狀態。山頂附近的主隊沒有變化——啊……等一下，情況不太對……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00213",
		linknext = "0089_00215",
		line = 3193,
	},
	["0089_00215"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00112", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1445", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I'm tracking their movements. Main force is moving en masse, looks like males and females are engaging in sex on a large scale. Bro, we're looking at a mass orgy at the summit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这个动作……！本队有巨大的动作，推断是FS的男女间开始了大规模的做爱，现在山顶附近大概是大乱交状态……大成功哟，哥哥！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這個動作……！本隊有巨大的動作，推斷是FS的男女間開始了大規模的做愛，現在山頂附近大概是大亂交狀態……大成功喲，哥哥！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00214",
		linknext = "0089_00216",
		line = 3206,
	},
	["0089_00216"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
