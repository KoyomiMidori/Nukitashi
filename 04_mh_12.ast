		linkback = "0089_00013",
		linknext = "0089_00015",
		line = 205,
	},
	["0089_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hell no. All-nighter. If I were in my right mind, I wouldn't say that, would I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然是通宵了。你认为我脑袋正常时会说这种话吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然是通宵了。你認為我腦袋正常時會說這種話嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00014",
		linknext = "0089_00016",
		line = 216,
	},
	["0089_00016"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
