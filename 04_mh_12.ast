		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori desperately clasps my clenched fist in her hands.",
					{"rt2"},
				},
			},
			cn = {
				{
					"紧握的拳头被畔的双手紧紧地包裹住。",
					{"rt2"},
				},
			},
			tw = {
				{
					"緊握的拳頭被畔的雙手緊緊地包裹住。",
