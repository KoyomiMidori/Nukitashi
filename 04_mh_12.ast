	},
	["0089_00499"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those were just excuses, things I told myself. But, because of that, my romantic feelings got out of control, and they're close to bursting out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我找了各种各样的理由一再推迟，在这样的过程中，内心的恋慕之情早已疯狂膨胀，此时此刻，膨胀的思绪已经快要爆发了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我找了各種各樣的理由一再推遲，在這樣的過程中，內心的戀慕之情早已瘋狂膨脹，此時此刻，膨脹的思緒已經快要爆發了。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00498",
		linknext = "0089_00500",
		line = 7736,
	},
	["0089_00500"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We have Fumino, and there's a light at the end of the tunnel.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在，文乃就在我们手中，胜利的时刻已经近在眼前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在，文乃就在我們手中，勝利的時刻已經近在眼前。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00499",
		linknext = "0089_00501",
		line = 7746,
	},
	["0089_00501"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't see any reason to keep lying to myself. More than that, though, my blood feels like it's boiling in my veins, and my nerves are screaming at me to get it out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么也找不到继续欺骗自己的理由了，而且浑身的血液都在沸腾呐喊着要我现在就说出口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼也找不到繼續欺騙自己的理由了，而且渾身的血液都在沸騰吶喊著要我現在就說出口。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00500",
		linknext = "0089_00502",
		line = 7756,
	},
	["0089_00502"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't drag it out and tell myself that I'll tell her once all this is over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"等这场战斗结束之后——我不会说出这么悠闲的话语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"等這場戰鬥結束之後——我不會說出這麼悠閒的話語。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00501",
		linknext = "0089_00503",
		line = 7766,
	},
