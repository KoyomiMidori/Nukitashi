		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The cicadas in the forest are roaring loudly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"林中的蝉们大声喝彩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"林中的蟬們大聲喝彩。",
