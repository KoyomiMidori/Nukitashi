			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“You little... You think you can just stand there and make a fool of me!? You think I won't!? I'll do it, all right! I'll make you regret provoking me!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“你这个……居然这么小看我！你以为我不会开枪吗！？我会开枪的……我要让你后悔……挑衅我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「你這個……居然這麼小看我！你以為我不會開槍嗎！？我會開槍的……我要讓你後悔……挑釁我！」",
					{"rt2"},
				},
