		linkback = "0089_00790",
		linknext = "0089_00792",
		line = 12064,
	},
	["0089_00792"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00106", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2037", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But he said that 'business' stuff wasn't making them anything, didn't he?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是，那副业并没有回本……对方是那样说的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是，那副業並沒有回本……對方是那樣說的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00791",
		linknext = "0089_00793",
		line = 12077,
	},
	["0089_00793"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... He did say that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……嗯，我确实有听到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……嗯，我確實有聽到。」",
					{"rt2"},
				},
