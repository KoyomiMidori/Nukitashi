	["0089_00842"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1372", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Umm, uh... As you know, despite my age, I'm still a virgin, so this is all kinda new to me... What does the girlfriend usually do when she's being escorted home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……就像你知道的那样，我都这个年纪了还是个处女，所以这种事还是第一次……作为被你送回家的女朋友，我有什么该做的事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……就像你知道的那樣，我都這個年紀了還是個處女，所以這種事還是第一次……作為被你送回家的女朋友，我有什麼該做的事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00841",
		linknext = "0089_00843",
		line = 12734,
	},
	["0089_00843"] = {
