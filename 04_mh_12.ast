			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, props on the self-awareness, at least... What a shitshow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你居然有自知之明……有点棘手了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你居然有自知之明……有點棘手了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00015",
		linknext = "0089_00017",
		line = 230,
	},
	["0089_00017"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like, yeah, I feel like I could take on the world after that all-nighter. But that's not the end of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我现在确实有种通宵之后特有的全能感——但是，我并不光是因为这样就说了这些。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我現在確實有種通宵之後特有的全能感——但是，我並不光是因為這樣就說了這些。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00016",
		linknext = "0089_00018",
		line = 242,
	},
	["0089_00018"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We've got a ridiculous numerical disadvantage. Plus, we don't have the strength to take on their numbers. We try facing them head-on, and it's just gonna be a repeat of yesterday.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们在数量上非常不利。也没有一骑当千的力量。正面作战只会重蹈昨天的覆辙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們在數量上非常不利。也沒有一騎當千的力量。正面作戰只會重蹈昨天的覆轍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00017",
		linknext = "0089_00019",
		line = 254,
	},
	["0089_00019"] = {
