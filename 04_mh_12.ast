		{"extrans", sync=0, time=300},
		{"cgact", file="cgact", id=13, act="汎用アクション", rotate=360, time=3000, loop=-1, ease="none", lv=5},
		{"cgact", file="cgact", id=14, act="アルファフェード点滅", loop=-1, alpha="90,256", time=750, alphadel=0, lv=5, x=0, y=0},
		{"fgact", ch="dw", id=16, act="移動", x=100, y=0, time=20000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The flying girl was a new dutch wife I bought from the Mutable Membrane a few days ago. I call her Jet Girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"飞过去的是前几天在一时的皮膜买的新型充气娃娃——喷射女郎。",
					{"rt2"},
				},
			},
			tw = {
				{
					"飛過去的是前幾天在一時的皮膜買的新型充氣娃娃——噴射女郎。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00151",
		linknext = "0089_00153",
		line = 2331,
	},
	["0089_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normally, my inflatable girlfriends are just made of plastic.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通常被称为空气老婆的充气娃娃是用塑料做的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通常被稱為空氣老婆的充氣娃娃是用塑膠做的。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00152",
		linknext = "0089_00154",
		line = 2341,
	},
	["0089_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, Jet Girl is made from the same kind of rubber that's used in the rubber balloons they bounce around baseball stadiums.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，喷射女郎是使用特殊技术的橡胶制充气娃娃——是用和棒球场上放飞的橡胶气球同样的材料制作而成的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，噴射女郎是使用特殊技術的橡膠製充氣娃娃——是用和棒球場上放飛的橡膠氣球同樣的材料製作而成的。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00153",
		linknext = "0089_00155",
		line = 2351,
	},
	["0089_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So they're not really 'flying'. They're bouncing with style.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说——会飞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說——會飛。",
					{"rt2"},
				},
