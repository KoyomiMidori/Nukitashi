	["0089_00498"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to secure Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为我还没找到文乃————",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為我還沒找到文乃————",
