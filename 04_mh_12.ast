		{"cgact", file="cgact", id=2, act="移動", x=395, y=-5, time=30000, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0266", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "FS女学生A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female SS Student A"},
					"“Magical Mirror, halt! What division do you belong to?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "FS女学生A"},
					"“停下来！那里的魔镜号，所属是哪里——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "FS女學生A"},
					"「停下來！那裡的魔鏡號，所屬是哪裡——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00072",
		linknext = "0089_00074",
		line = 1055,
	},
	["0089_00074"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00103", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1305", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The Anti-Copulation Front have appeared, and they're after the girl! We're in pursuit! Please inform the main squad immediately!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“反交尾势力出现了！现在本车正在追踪反交尾势力！他们的目标就是那个少女！请马上告诉本队！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「反交尾勢力出現了！現在本車正在追踪反交尾勢力！他們的目標就是那個少女！請馬上告訴本隊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00073",
		linknext = "0089_00075",
		line = 1068,
	},
	["0089_00075"] = {
		{"text"},
		delay = {
			[2500] = {
				{"se", id=0, loop=0, file="se_b032", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="gmoba0267", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "FS女学生A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female SS Student A"},
					"“The Anti-Copulation Front!? Roger that! This B-7, an emergency situation has... guh!? What's this noise!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "FS女学生A"},
					"“你说什么！？……我明白了！这里是B-7，发生紧急事态——唔！？这噪音怎么回事……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "FS女學生A"},
					"「你說什麼！？……我明白了！這裡是B-7，發生緊急事態——唔！？這噪音怎麼回事……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00074",
		linknext = "0089_00076",
		line = 1081,
	},
	["0089_00076"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00103", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1306", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“They've got a jamming beacon! We'll stay in pursuit, and request that you inform the main squad directly!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那是他们的电波干扰攻击！我们将继续追踪，拜托你直接前往本部通报！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那是他們的電波干擾攻擊！我們將繼續追踪，拜託你直接前往本部通報！」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00075",
		linknext = "0089_00077",
		line = 1095,
	},
	["0089_00077"] = {
		{"text"},
		text = {
