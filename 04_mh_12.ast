	},
	["0089_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It goes hurtling over the rep's head and disappears into the trees.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人影悠然越过委员长的头顶，随即消失在森林深处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人影悠然越過委員長的頭頂，隨即消失在森林深處。",
