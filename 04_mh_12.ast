		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sun has gone down, and after constantly being egged on by Nanase and Wata, I'm walking Hotori home.",
					{"rt2"},
				},
			},
			cn = {
