					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ha, glad ya understand. Guess it's time to blow this joint... Oh, right. Guess I gotta thank my pawn 'ere properly first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啊，理解得那么快真是帮大忙了。那么，走吧……哦对了，忘记说谢谢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啊，理解得那麼快真是幫大忙了。那麼，走吧……哦對了，忘記說謝謝了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00731",
		linknext = "0089_00733",
		line = 11277,
	},
	["0089_00733"] = {
		{"text"},
		text = {
