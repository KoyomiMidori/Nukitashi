			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Enemy presence detected. Two virginity status unknowns in your path, presumably SS guards. Engaging in under 20 seconds.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“敌影捕捉。前进方向有处女躯不明器2。推测是警备中的FS。20秒以内接触。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「敵影捕捉。前進方向有處女軀不明器2。推測是警備中的FS。20秒以內接觸。」",
					{"rt2"},
				},
			},
