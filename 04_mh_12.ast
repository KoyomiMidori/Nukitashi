				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know Nanase's usually the one in charge of strategy, but this is something that only I could've come up with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然作战方案原本是奈奈濑负责的……但这是只有我才能想到的作战对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然作戰方案原本是奈奈瀨負責的……但這是只有我才能想到的作戰對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00018",
		linknext = "0089_00020",
		line = 266,
	},
	["0089_00020"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1420", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You really think this'll work?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……你认为会顺利吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……你認為會順利嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00019",
		linknext = "0089_00021",
		line = 280,
	},
	["0089_00021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You think I'd be doing this if I didn't?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不认为就不会想要实行了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不認為就不會想要實行了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00020",
		linknext = "0089_00022",
		line = 292,
	},
	["0089_00022"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What I can tell you for certain is that yesterday, we had a 0% chance of success. But that's not the case today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有一点我可以明确地说——昨天还只有0%的胜率，但现在已经不是0了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有一點我可以明確地說——昨天還只有0%的勝率，但現在已經不是0了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00021",
		linknext = "0089_00023",
		line = 304,
	},
	["0089_00023"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=4, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2028", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooh, so how many percent is it now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“噢……那现在是多少%？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「噢……那現在是多少%？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00022",
		linknext = "0089_00024",
		line = 318,
	},
	["0089_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Can't say for sure. But it's not zero, and that's good enough for us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“具体的数字我不知道，但不是0——只要知道这个就足够了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「具體的數字我不知道，但不是0——只要知道這個就足夠了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00023",
		linknext = "0089_00025",
		line = 330,
	},
	["0089_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if it's like threading a needle, we'll make it work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使是如同针孔般微小的可能性——我们也一定要抓住这种可能性。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使是如同針孔般微小的可能性——我們也一定要抓住這種可能性。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00024",
		linknext = "0089_00026",
		line = 342,
	},
	["0089_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As Nanase and Asane said, the plan is a reckless one. Still, I want to shoot our shot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“正如奈奈濑和麻沙音所说的，这也许是个有勇无谋的作战。但尽管如此，我也想赌这一把。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「正如奈奈瀨和麻沙音所說的，這也許是個有勇無謀的作戰。但儘管如此，我也想賭這一把。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00025",
		linknext = "0089_00027",
		line = 354,
	},
	["0089_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, guys... Do you trust me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——能相信我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——能相信我嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00026",
		linknext = "0089_00028",
		line = 366,
	},
	["0089_00028"] = {
