	},
	["0089_00037"] = {
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1301", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's a lot quieter than it was yesterday...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“比昨天要安静许多啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「比昨天要安靜許多啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00036",
		linknext = "0089_00038",
		line = 547,
	},
	["0089_00038"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, sitrep!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，情况怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，情況怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00037",
		linknext = "0089_00039",
		line = 559,
	},
	["0089_00039"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1422", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“More than half of the SS are gathered at the summit. I'm guessing that's where Fumino is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“大部分FS都集中在山顶附近……文乃恐怕就在那里……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「大部分FS都集中在山頂附近……文乃恐怕就在那裡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00038",
		linknext = "0089_00040",
		line = 572,
	},
	["0089_00040"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1302", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The summit? Oh, I think I remember the old folks around here talking about some big mansion up there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“山顶……那里好像有间很大的宅邸，我听附近的爷爷们说起过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「山頂……那裡好像有間很大的宅邸，我聽附近的爺爺們說起過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00039",
		linknext = "0089_00041",
		line = 584,
	},
	["0089_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So she's probably hiding in there, then. Can you tell what the OSS and Yakuza are doing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“藏在宅邸中吗……？可以知道SHO和黑社会的动向吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「藏在宅邸中嗎……？可以知道SHO和黑社會的動向嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00040",
		linknext = "0089_00042",
		line = 596,
	},
	["0089_00042"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1423", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I still can't get GPS data on them, but if the SS are closing in on Fumino, they've probably pulled out. Looks like it from the cameras at the base of the hill, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“仍不能获取位置信息……只是，根据FS紧逼文乃的情况，很有可能已经撤离。山麓下的摄像头也确认到了类似的身影。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「仍不能獲取位置資訊……只是，根據FS緊逼文乃的情況，很有可能已經撤離。山麓下的攝影機也確認到了類似的身影。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00041",
		linknext = "0089_00043",
		line = 608,
	},
	["0089_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they're on the move, then the deadlock must be over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"情况不是胶着状态，而是静观其变。",
					{"rt2"},
				},
			},
			tw = {
				{
					"情況不是膠著狀態，而是靜觀其變。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00042",
		linknext = "0089_00044",
		line = 618,
	},
	["0089_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if the SS are closing on Fumino, then...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，FS离文乃比较接近，也就是说——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，FS離文乃比較接近，也就是說——",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00043",
		linknext = "0089_00045",
		line = 628,
	},
	["0089_00045"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did the adults lose to the students?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……大人输给了学生？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……大人輸給了學生？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00044",
		linknext = "0089_00046",
		line = 640,
	},
	["0089_00046"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1424", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I can't know for sure, but based on what we saw and heard yesterday, I'm guessing the SS mounted a surprise attack.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我无法断言，但恐怕……从位置信息数据来看，日出的同时，FS似乎进行了突袭……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我無法斷言，但恐怕……從位置資訊數據來看，日出的同時，FS似乎進行了突襲……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00045",
		linknext = "0089_00047",
		line = 652,
	},
	["0089_00047"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2030", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooh... Rei's team is incredible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶——礼酱们好厉害啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸——禮醬們好厲害啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00046",
		linknext = "0089_00048",
		line = 665,
	},
	["0089_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The OSS were clearly acting abnormally yesterday.",
					{"rt2"},
				},
			},
			cn = {
				{
					"昨天看到的时候，SHO有些不正常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"昨天看到的時候，SHO有些不正常。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00047",
		linknext = "0089_00049",
		line = 675,
	},
	["0089_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While Onabuta can probably be considered an exception, my experience with the SS tells me that they've got excellent leadership, and may outnumber the OSS and Yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"倒是FS——虽然有女部田这样的例外——基本有着统率，数量上也压过了SHO和黑社会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"倒是FS——雖然有女部田這樣的例外——基本有著統率，數量上也壓過了SHO和黑社會。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00048",
		linknext = "0089_00050",
		line = 685,
	},
	["0089_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if they're just students, they're still an armed, heavily trained combat force.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说是学生，但也是训练过的武装集团。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說是學生，但也是訓練過的武裝集團。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00049",
		linknext = "0089_00051",
		line = 695,
	},
	["0089_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they were able to put their advantage in numbers to good use in a surprise attack, then they could've easily made up any disadvantage from the age difference.",
					{"rt2"},
				},
			},
			cn = {
				{
					"数量上有利的突袭成功的话，就可以轻易推翻大人和孩子的差距——是这回事吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"數量上有利的突襲成功的話，就可以輕易推翻大人和孩子的差距——是這回事嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00050",
		linknext = "0089_00052",
		line = 705,
	},
	["0089_00052"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, if that means the guys with real guns aren't around, that's great. Still, we have to move fast so the SS don't get her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有真枪实弹的人在的话就好了……不赶紧的话，文乃会落到FS手中——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有真槍實彈的人在的話就好了……不趕緊的話，文乃會落到FS手中——」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00051",
		linknext = "0089_00053",
		line = 717,
	},
	["0089_00053"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1425", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What do we do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00052",
		linknext = "0089_00054",
		line = 731,
	},
	["0089_00054"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Stick to the plan. We have to overturn this situation before we can do anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——按照作战进行。首先，不逆转这个情况就无法开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——按照作戰進行。首先，不逆轉這個情況就無法開始。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00053",
		linknext = "0089_00055",
		line = 743,
	},
	["0089_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, you'll be here on standby until I give you the signal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱按照计划在这里待命，一边引导一边等指示。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬按照計劃在這裡待命，一邊引導一邊等指示。」",
