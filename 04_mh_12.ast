	},
	["0089_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After Onabuta charged the students into a lustful frenzy at the school that one time, I stole that plan and put it to work for us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前，女部田曾将学校的学生变成淫乱状态————正是因为偷了她的策略，才有了这个无耳作战。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前，女部田曾將學校的學生變成淫亂狀態————正是因為偷了她的策略，才有了這個無耳作戰。",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00220",
		linknext = "0089_00222",
		line = 3272,
	},
	["0089_00222"] = {
