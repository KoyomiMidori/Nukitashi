					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's a lot...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真多啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
