					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah, it's my job. Anyone who still has their senses, assemble! We'll regroup and take on the Anti-Copulation Front right here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，那是我的工作……所有有意识的人都集合起来！重新组成部队，在这里打击反交尾势力！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，那是我的工作……所有有意識的人都集合起來！重新組成部隊，在這裡打擊反交尾勢力！」",
					{"rt2"},
				},
			},
		},
