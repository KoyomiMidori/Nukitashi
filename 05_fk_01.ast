				{"vo", file="gmobc0072", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "FS女学生C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Female SS Student C"},
					"“Strike 4, 6, and 7 down! They're resisting from a distance of 10 meters away! How can they shoot so accurately in this darkness!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "FS女学生C"},
					"“强袭4、6、7倒下！敌人于距离10米的地方应战中！为什么能在这样的黑暗中正确判断我们的位置……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "FS女學生C"},
					"「強襲4、6、7倒下！敵人於距離10米的地方應戰中！為什麼能在這樣的黑暗中正確判斷我們的位置……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00072",
		linknext = "0101_00074",
		line = 1129,
	},
	["0101_00074"] = {
