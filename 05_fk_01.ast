				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“So I implore you, please forget what happened this evening. I bid you farewell.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“所以，请忘记今晚的事情吧……那么，再见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「所以，請忘記今晚的事情吧……那麼，再見。」",
					{"rt2"},
