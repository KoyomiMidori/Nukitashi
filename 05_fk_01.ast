	["0101_00105"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00120", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0359", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“I do not know who you are... But I want to thank you for saving me from that situation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“……虽然我不知道您是谁……不过非常感谢您救了我一命……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「……雖然我不知道您是誰……不過非常感謝您救了我一命……」",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00104",
		linknext = "0101_00106",
		line = 1610,
	},
	["0101_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't get the words out, as her eyes stare into mine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直到她移开视线为止，我都发不出声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直到她移開視線為止，我都發不出聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00105",
		linknext = "0101_00107",
		line = 1620,
	},
	["0101_00107"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0360", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“However, I am a woman who does not exist in reality. I am but an apparition from the world of dreams.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“可是——我是不存在于现世的女人……是梦中的假像……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「可是——我是不存在於現世的女人……是夢中的假像……」",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00106",
		linknext = "0101_00108",
		line = 1634,
	},
	["0101_00108"] = {
