			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You there! No running in the halls! We can't have obstructions to perverted sex going on during events, that's what the SS is here for!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你们也是！不要在走廊上奔跑！妨碍做爱的行为，在活动期间也归SS管！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你們也是！不要在走廊上奔跑！妨礙做愛的行為，在活動期間也歸SS管！」",
					{"rt2"},
				},
			},
