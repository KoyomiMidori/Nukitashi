	["0021_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A mis espaldas, Asa-chan está recopilando información, mientras que Hotori, Wata-chan y Nanase forman la retaguardia.",
					{"rt2"},
				},
			},
			cn = {
				{
