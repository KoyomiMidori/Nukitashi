	["0021_00430"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00107", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0015", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Heh heh, pleasure to make your acquaintance. I am Onabuta Ikuko, commander of the SS's first squad, and commanding officer of the special advance forces.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵，初次见面。我的名字是女部田郁子。SS一队队长，也是特别尖兵的中队长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵，初次見面。我的名字是女部田郁子。SS一隊隊長，也是特別尖兵的中隊長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00429",
		linknext = "0021_00431",
		line = 6128,
	},
	["0021_00431"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0016", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Normally I'd be screwing myself silly, but today I was assigned this task as a special duty... Rei-chan asked me, since we're kinda short on numbers and stuff ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“除了做色色的事外，平常只会执行一些特别任务……但因为人手不够就被礼酱拜托了〜♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「除了做色色的事外，平常只會執行一些特別任務……但因為人手不夠就被禮醬拜託了〜♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00430",
		linknext = "0021_00432",
		line = 6142,
	},
