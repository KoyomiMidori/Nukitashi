		{"fgact", ch="美岬", id=7, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0192", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, Tachibana-san! The sex seekers behind us have finished having sex! There's a chance they might come this way!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，橘同学！后面的性触者的性行为结束了……！有靠近这里的可能性！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，橘同學！後面的性觸者的性行為結束了……！有靠近這裡的可能性！」",
					{"rt2"},
				},
