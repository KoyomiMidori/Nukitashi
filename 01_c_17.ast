				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“要是有换鞋的时间就好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「要是有換鞋的時間就好了……」",
