	["0021_00199"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", path=":fg/hinami_02m/", id=6, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0421", path=":vo/", ch="hinami"},
			},
			ja = {
				{
