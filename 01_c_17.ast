					name = {"奈々瀬", "Nanase"},
					"“Yeah... Sorry, Misaki, can you pass this to Jun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……对不起，美岬，能帮我把这个给淳吗？”",
