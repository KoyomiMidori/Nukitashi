	["0021_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Considering where the SS has been stationed to date, it's not workable to get out at the second or third floors.",
