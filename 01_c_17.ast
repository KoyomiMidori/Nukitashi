		linkback = "0021_00137",
		linknext = "0021_00139",
		line = 2023,
	},
	["0021_00139"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00110", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0635", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah... By the way, Wata-chan, shouldn't you leave your chair behind today to make your way home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……对了渡酱，今天把钢管椅子放着回去不好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……對了渡醬，今天把鋼管椅放著回去不好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00138",
		linknext = "0021_00140",
		line = 2036,
	},
	["0021_00140"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00102", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0419", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I need it to reach high places. Like my locker and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那样的话高处的东西就拿不到了，鞋箱什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那樣的話高處的東西就拿不到了，鞋箱什麼的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00139",
		linknext = "0021_00141",
		line = 2049,
	},
	["0021_00141"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00105", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
