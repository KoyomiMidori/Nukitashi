					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“除了做色色的事外，平常只会执行一些特别任务……但因为人手不够就被礼酱拜托了〜♪”",
					{"rt2"},
				},
			},
			tw = {
