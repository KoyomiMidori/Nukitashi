		linkback = "0021_00201",
		linknext = "0021_00203",
		line = 2836,
	},
	["0021_00203"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Nanase, do you have any smoke screen items on you? Anything?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦？奈奈濑，有没有什么遮掩用的道具——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦？奈奈瀨，有沒有什麼遮掩用的道具——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00202",
		linknext = "0021_00204",
		line = 2848,
	},
	["0021_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn't plan for this many people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人数远远比想象的多。",
