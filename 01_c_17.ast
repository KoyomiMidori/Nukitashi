	["0021_00259"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mantuve toda mi atención en nuestra retaguardia, pero descuidé por completo el frente... ¡Soy un idiota!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被后面的人吸引而没注意到前方，我真是笨蛋啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被後面的人吸引而沒注意到前方，我真是笨蛋啊——！」",
					{"rt2"},
				},
