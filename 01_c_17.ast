					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si queremos salir de esto, necesitamos una buena estrategia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了平安生还，必须制定作战计划。”",
