				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Oye! ¡No corras en los pasillos! No podemos permitir que se interfiera en el sexo pervertido que se practica durante los eventos. ¡Para eso vino la SS!”",
