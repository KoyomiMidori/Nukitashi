			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That's assuming you'll even have time to get your outdoor shoes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“要是有换鞋的时间就好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「要是有換鞋的時間就好了……」",
					{"rt2"},
				},
			},
		},
