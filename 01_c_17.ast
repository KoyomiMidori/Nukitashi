	},
	["0021_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca imaginé que el evento dificultaría tanto el movimiento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到活动会进行到如此火热，让人无法动弹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到活動會進行到如此火熱，讓人無法動彈。",
