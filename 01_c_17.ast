		{"bgm", file="bgm01", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La manera más segura de ir a la escuela es cuando no hay nadie por allí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要说最安全的上学方法是什么，那就是在谁都不在的时间去学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要說最安全的上學方法是什麼，那就是在誰都不在的時間去學校。",
					{"rt2"},
				},
			},
		},
		linknext = "0021_00002",
		line = 18,
	},
	["0021_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En pocas palabras, si nos vamos temprano por la mañana, no nos verán ni los guardias de la SHO ni la SS, así que podremos llegar sin problemas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，只要一大早去学校，就可以不被SHO警卫和SS发现，平安到达学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，只要一大早去學校，就可以不被SHO警衛和SS發現，平安到達學校。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00001",
		linknext = "0021_00003",
		line = 28,
	},
	["0021_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero estamos más tiempo en la escuela. Lo que significa más peligro por todo este asunto del Rey Tiroteador.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是那也意味着待在学校的时间变长了，在“击落王”的活动期间反而危险。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是那也意味著待在學校的時間變長了，在「擊落王」的活動期間反而危險。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00002",
		linknext = "0021_00004",
		line = 38,
	},
	["0021_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por lo tanto, encontrar un escondite y no ser descubiertos mientras estamos en la escuela se ha convertido en la mejor opción.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么应该怎么办呢？只要藏在学校里谁都找不到的地方就可以了。",
