			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Espera, hermanito. Hay dos miembros de la SS apostados al otro extremo de donde nos dirigimos. Por ahora estamos ocultos entre la multitud, pero si seguimos adelante, nos verán.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“等一下，哥哥，前进方向的另一侧有2名普通SS在待机。现在虽然被人潮遮掩，但这样下去会被发现的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「等一下，哥哥，前進方向的另一側有2名普通SS在待機。現在雖然被人潮遮掩，但這樣下去會被發現的。」",
					{"rt2"},
				},
			},
