		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=5, ch="奈々瀬", lv=5, time=100},
		{"fg", mode=-1, id=6, ch="ヒナミ", lv=5, time=100},
		{"fg", mode=-1, id=7, ch="美岬", lv=5, time=100},
		{"bg", id=1, file="bg12_1l_00000", x=0, y=0, path=":bg/", sync=0, ax=1280, ay=730, bx=-480, by=-280},
		{"extrans", sync=0, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nos reunimos alrededor de la mesa de estrategia, Nanase está en el centro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们以奈奈濑为中心，在基地中央的作战板前集合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們以奈奈瀨為中心，在基地中央的作戰板前集合。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00100",
		linknext = "0021_00102",
		line = 1505,
	},
	["0021_00102"] = {
		{"bgm", file="bgm11", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"extrans", sync=0, time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Antes que nada, repasemos lo sucedido. ¿Asane?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先，整理情况——麻沙音。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先，整理情況——麻沙音。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00101",
		linknext = "0021_00103",
		line = 1521,
	},
	["0021_00103"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0572", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hoy es el último día del evento del Rey Tiroteador de la Academia Minotsuki. Se espera una gran afluencia de público y un alto riesgo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“今天是水乃月学园定期活动‘击坠王’的最后一天，预计会出现最混乱和最危险的局面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「今天是水乃月學園定期活動『擊墜王』的最後一天，預計會出現最混亂和最危險的局面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00102",
		linknext = "0021_00104",
		line = 1534,
	},
	["0021_00104"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0573", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“En cuanto a las vías de escape, la puerta trasera presenta algunas complicaciones. Hay más de diez miembros de la SS apostados en la parte trasera del edificio, y la falta de cobertura hace que escapar por allí sea inviable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“关于逃跑路线，被堵住出口的后门路线无法使用。现阶段教学楼后面有10多名SS，由于没有遮挡物，所以视为不可能突破。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「關於逃跑路線，被堵住出口的後門路線無法使用。現階段校舍後面有10多名SS，由於沒有遮擋物，所以視為不可能突破。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00103",
		linknext = "0021_00105",
		line = 1546,
	},
	["0021_00105"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0574", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Además, se prevé la imposibilidad de utilizar la ruta de la cueva de piedra caliza debido a la falta de mareas bajas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“同时钟乳洞路线也不在退潮时期，预计从今天开始将无法使用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「同時鐘乳洞路線也不在退潮時期，預計從今天開始將無法使用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00104",
		linknext = "0021_00106",
		line = 1558,
	},
	["0021_00106"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0183", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um... Disculpa. Si solo tenemos que pasar hoy, ¿por qué no podemos quedarnos aquí a pasar la noche?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……不好意思，如果只需要挺过今天的话，就住在这里不行吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……不好意思，如果只需要挺過今天的話，就住在這裡不行嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00105",
		linknext = "0021_00107",
		line = 1572,
	},
	["0021_00107"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0184", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“La base tiene un almacén con todos los productos de primera necesidad, así que deberíamos poder pasar el día aquí, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“基地里的日用品也很齐全，你有说过一天的话应该没有问题的对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「基地裡的日用品也很齊全，你有說過一天的話應該沒有問題的對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00106",
		linknext = "0021_00108",
		line = 1584,
	},
	["0021_00108"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, los fines de semana cierran con llave ambas puertas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个学校的大门，每逢周末都会锁上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個學校的大門，每逢週末都會鎖上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00107",
		linknext = "0021_00109",
		line = 1596,
	},
	["0021_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si nos quedaramos toda la noche, no podríamos salir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，过了今天晚上将不能出入学校。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，過了今天晚上將不能出入學校。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00108",
		linknext = "0021_00110",
		line = 1608,
	},
	["0021_00110"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0629", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Después de todo, la mayoría de nosotros vive con nuestros padres en esta isla. Les costaría aceptarlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对我们这些父母在岛上的人来说，这提案应该有点困难的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對我們這些父母在島上的人來說，這提案應該有點困難的吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00109",
		linknext = "0021_00111",
		line = 1621,
	},
	["0021_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El día que rescatamos a Wata-chan, entramos en la base por el ascensor, pero la escuela estaba abierta porque era el Día de la Orgía de la Isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然帮助渡酱的时候是乘坐学校里的电梯来到基地的，但那是因为学校当时正在纪念姦港纪念日才对外开放的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然幫助渡醬的時候是乘坐學校裡的電梯來到基地的，但那是因為學校當時正在紀念姦港紀念日才對外開放的。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00110",
		linknext = "0021_00112",
		line = 1631,
	},
	["0021_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al tratarse de un fin de semana normal, es casi seguro que las puertas estarán cerradas esta vez.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是这个周末，门应该会跟往常一样被锁住吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是這個週末，門應該會跟往常一樣被鎖住吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00111",
		linknext = "0021_00113",
		line = 1641,
	},
	["0021_00113"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0630", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Además, la SHO aparece con su pequeño servicio de entrega especial los fines de semana, ¿verdad? Eso también sirve como inspección de la estructura familiar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“而且SHO在休息日也会上门服务，那还包括家庭成员的调查呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「而且SHO在休息日也會上門服務，那還包括家庭成員的調查呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00112",
		linknext = "0021_00114",
		line = 1653,
	},
	["0021_00114"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0185", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡¿Eh?! ¡¿En serio?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶，是这样啊……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸，是這樣啊……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00113",
		linknext = "0021_00115",
		line = 1668,
	},
	["0021_00115"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0631", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“La SS está básicamente conectada a la SHO, así que... si no estamos allí, le causaremos problemas a nuestras familias. Tenemos que volver a casa sí o sí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“SS基本上和SHO是联系在一起的……如果我们不在，会给家人带来麻烦的。无论如何都必须回家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「SS基本上和SHO是聯繫在一起的……如果我們不在，會給家人帶來麻煩的。無論如何都必須回家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00114",
		linknext = "0021_00116",
		line = 1680,
	},
	["0021_00116"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0575", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mi hermanito y yo somos los únicos en nuestra familia, así que sería muy sospechoso que los dos desapareciéramos...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我和哥哥是二人家庭，不在的话会很奇怪的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我和哥哥是二人家庭，不在的話會很奇怪的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00115",
		linknext = "0021_00117",
		line = 1692,
	},
	["0021_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Teniendo eso en cuenta...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，也就是说今天——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，也就是說今天——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00116",
		linknext = "0021_00118",
		line = 1704,
	},
	["0021_00118"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tendremos que pensar en una forma de atravesar la puerta principal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无论如何都只能从正门突破。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無論如何都只能從正門突破。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00117",
		linknext = "0021_00119",
		line = 1716,
	},
	["0021_00119"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0632", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Es algo arriesgado, pero no tenemos más opciones.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然风险很高，但除此之外别无他法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然風險很高，但除此之外別無他法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00118",
		linknext = "0021_00120",
		line = 1728,
	},
	["0021_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La ruta más directa es salir del ascensor en el piso bajo y dirigirse a la salida este, pero...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最近的路线是在一楼下电梯，然后马上前往东侧的出入口……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最近的路線是在一樓下電梯，然後馬上前往東側的出入口……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00119",
		linknext = "0021_00121",
		line = 1739,
	},
	["0021_00121"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=6, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="ヒナミ", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0417", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿No podemos hacerlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那不行吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那不行嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00120",
		linknext = "0021_00122",
		line = 1753,
	},
	["0021_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A esta hora del día no hay ningún problema, pero por la noche, las persianas de la puerta que hay cerca del ascensor están cerradas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个时间段没问题，但一到傍晚，一楼电梯附近的门就会被拉下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個時間段沒問題，但一到傍晚，一樓電梯附近的門就會被拉下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00121",
		linknext = "0021_00123",
		line = 1765,
	},
	["0021_00123"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0186", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Y si nos vamos ahora? Ah, aunque todavía habrá mucha gente por aquí. Olvídenlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那么现在就……啊，不，这个时间段还有很多人。也就是说不可能，是吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那麼現在就……啊，不，這個時間段還有很多人。也就是說不可能，是吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00122",
		linknext = "0021_00124",
		line = 1781,
	},
	["0021_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, tenemos que esperar hasta la última hora de la tarde, para que haya el menor número posible de personas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，我们要等到人最少的傍晚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，我們要等到人最少的傍晚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00123",
		linknext = "0021_00125",
		line = 1793,
	},
	["0021_00125"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00103", path=":fg/nanase_02m/", id=5, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0633", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“En ese caso... ¿qué les parece esto? Subiremos al cuarto piso, luego bajaremos hasta el primer piso y nos dirigiremos a la salida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那就——上到4楼，然后穿过缝隙下到1楼，再前往出入口吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那就——上到4樓，然後穿過縫隙下到1樓，再前往出入口吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00124",
		linknext = "0021_00126",
		line = 1807,
	},
	["0021_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase señala la mesa de estrategías.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑指着作战板。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨指著作戰板。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00125",
		linknext = "0021_00127",
		line = 1817,
	},
	["0021_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Teniendo en cuenta dónde se ha ubicado la SS hasta la fecha, no es viable salir en el segundo o tercer piso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从以往SS的分布情况来看，在23楼下来不是上策。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從以往SS的分佈情況來看，在23樓下來不是上策。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00126",
		linknext = "0021_00128",
		line = 1827,
	},
	["0021_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El único lugar frente a los ascensores sin SS y con vigilancia ligera es el cuarto piso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"电梯前没有SS，那些人最不警戒的只有四楼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"電梯前沒有SS，那些人最不警戒的只有四樓。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00127",
		linknext = "0021_00129",
		line = 1837,
	},
	["0021_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hay que recorrer más distancia, y eso conlleva más riesgos. Pero es nuestra mejor opción.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然移动距离增加有点危险，但这是最好的办法了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然移動距離增加有點危險，但這是最好的辦法了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00128",
		linknext = "0021_00130",
		line = 1849,
	},
	["0021_00130"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0634", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Básicamente, los cinco nos moveremos como un grupo, utilizaremos objetos y escaparemos de forma sigilosa. ¿Les parece?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“基本上由5个人组成一组，一边使用道具一边隐秘逃脱——可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「基本上由5個人組成一組，一邊使用道具一邊隱密逃脫——可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00129",
		linknext = "0021_00131",
		line = 1863,
	},
	["0021_00131"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=6, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=7, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="ヒナミ", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ex0003", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"淳之介＆美岬＆ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介＆美岬＆ヒナミ", "Junnosuke & Misaki & Hinami"},
					"“¡Sí!” “¡Sí!” “¡Okey!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介＆美岬＆ヒナミ", "淳之介＆美岬＆雏见"},
					"“哦”“是”“嗯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介＆美岬＆ヒナミ", "淳之介＆美岬＆雛見"},
					"「哦」「是」「嗯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00130",
		linknext = "0021_00132",
		line = 1883,
	},
	["0021_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si logramos superar el día de hoy, mañana tendremos el fin de semana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要过了今天，明天就是休息日了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要過了今天，明天就是休息日了。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00131",
