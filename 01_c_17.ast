				{"vo", file="misaki0192", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Ah, Tachibana-san! ¡Los buscadores de sexo que están detrás de nosotros han terminado de tener sexo! ¡Es posible que vengan hacia aquí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，橘同学！后面的性触者的性行为结束了……！有靠近这里的可能性！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，橘同學！後面的性觸者的性行為結束了……！有靠近這裡的可能性！」",
					{"rt2"},
				},
