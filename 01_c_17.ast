	["0021_00328"] = {
		{"se", id=0, loop=0, file="se_b056"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0083", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SS二番隊隊長"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Comandante del segundo escuadrón SS"},
					"“Ups... No se muevan, a menos que quieran acabar como un queso suizo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SS第二中队队长"},
					"“哎呀……你们只要稍微动一下，就会变成蜂窝哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SS第二中隊隊長"},
					"「哎呀……你們只要稍微動一下，就會變成蜂窩哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00327",
