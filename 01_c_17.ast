		{"fgact", ch="奈々瀬", id=5, act="移動", x=-200, y=0, time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0636", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
