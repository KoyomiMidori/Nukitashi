	["0021_00150"] = {
		{"se", id=1, loop=1, file="se_d012", vol=50},
		{"bg", id=1, file="bg15_2_1l_00000", x=-400, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's our primary battle formation, designed to protect the two with the least firepower and evasive ability.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是第一次使用这个把缺乏战斗力和回避能力的两个人夹在中间的阵形。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是第一次使用這個把缺乏戰鬥力和迴避能力的兩個人夾在中間的陣形。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00149",
		linknext = "0021_00151",
		line = 2189,
	},
	["0021_00151"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0578", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Approaching virginity status unknowns from the classrooms. Two in number. They appear to be in the midst of the nasty, in a standing position. Genital status is 'drenched. Penetration immediately upon approach possible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“教室方向有处女躯不明器接近中，数量是2，车站便当体位，推测正在交尾。湿润度‘一塌胡涂’状态，可以在接近后马上插入。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「教室方向有處女軀不明器接近中，數量是2，車站便當體位，推測正在交尾。濕潤度為『一塌糊塗』狀態，可以在接近後馬上插入。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00150",
		linknext = "0021_00152",
		line = 2201,
	},
	["0021_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We have to slip past them... Nanase, get out that screen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无论如何都要突破——奈奈濑，把那个屏幕拿出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無論如何都要突破——奈奈瀨，把那個螢幕拿出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00151",
		linknext = "0021_00153",
		line = 2212,
	},
	["0021_00153"] = {
