	["0021_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tener varios para diferentes circunstancias significa que no hay muchos de un mismo estilo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"由于为了应付各种情况而带着不同种类，所以每种的数量都不多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"由於為了應付各種情況而帶著不同種類，所以每種的數量都不多。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00195",
		linknext = "0021_00197",
		line = 2764,
	},
	["0021_00197"] = {
		{"text"},
		text = {
