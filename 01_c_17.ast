			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Búsqueda completa. No hay señales del enemigo delante del ascensor. Pueden avanzar. Estén listos.”",
