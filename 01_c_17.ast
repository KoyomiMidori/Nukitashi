		linkback = "0021_00203",
		linknext = "0021_00205",
		line = 2858,
	},
	["0021_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never imagined the event would make it this hard to move around.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到活动会进行到如此火热，让人无法动弹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到活動會進行到如此火熱，讓人無法動彈。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00204",
		linknext = "0021_00206",
		line = 2868,
	},
	["0021_00206"] = {
		{"cgact", file="cgact", id=2, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=5, x=0, y=-200},
		{"cgact", file="cgact", id=4, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=5, x=0, y=-200},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As my expectations continuously get exceeded, I can sense any further actions we take becoming a day late and a dollar short.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随着意想不到的事情不断发生，我发现情况渐渐超过了自己的负荷能力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨著意想不到的事情不斷發生，我發現情況漸漸超過了自己的負荷能力。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00205",
		linknext = "0021_00207",
		line = 2880,
	},
	["0021_00207"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
