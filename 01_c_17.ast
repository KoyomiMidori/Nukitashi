					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? Nanase, ¿tienes alguna pantalla de humo? ¿Alguna cosa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦？奈奈濑，有没有什么遮掩用的道具——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦？奈奈瀨，有沒有什麼遮掩用的道具——」",
