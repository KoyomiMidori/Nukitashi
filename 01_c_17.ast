			cn = {
				{
					name = {"奈々瀬", "口塞球"},
					"“啊！嗯哈……从那、那么多鸡巴，射出精液的话，我会坏掉的",
					{"gaiji", text="①"},
					"。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "口塞球"},
					"「啊！嗯哈……從那、那麼多肉棒，射出精液的話，我會壞掉的",
					{"gaiji", text="①"},
					"。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00173",
		linknext = "0021_00175",
		line = 2500,
	},
	["0021_00175"] = {
		{"text"},
		text = {
