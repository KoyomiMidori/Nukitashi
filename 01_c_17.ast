				},
			},
			cn = {
				{
					name = {"礼"},
					"“不用担心，准备好的B级壮阳药数量是学生人数的2倍！不用急慢慢走到配给站就好！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不用擔心，準備好的B級壯陽藥數量是學生人數的2倍！不用急慢慢走到配給站就好！」",
					{"rt2"},
