		{"fg", file="misaki_01l_00001", file1="misaki_01l_00109", file2="misaki_01l_00202", path=":fg/misaki_01l/", id=7, lv=5, head="misaki_01l", ch="美岬", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
