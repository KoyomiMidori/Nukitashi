	["0021_00320"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0081", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SS二番隊隊長"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Comandante del segundo escuadrón SS"},
					"“Nos han hecho perder el tiempo, ¿saben? Gracias a ustedes todas mis aspiraciones de conseguir la beca especial se han esfumado... Jejeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SS第二中队队长"},
					"“那时候多亏你们逃跑了……我的特别奖学金也跟着泡汤了呢……呵呵呵呵……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SS第二中隊隊長"},
					"「那時候多虧你們逃跑了……我的特別獎學金也跟著泡湯了呢……呵呵呵呵……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00319",
		linknext = "0021_00321",
		line = 4591,
	},
