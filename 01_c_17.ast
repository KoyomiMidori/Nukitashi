			},
			en = {
				{
					name = {"モブ男B", "Estudiante B"},
					"“¡Eh, oí a Katagiri-san! ¡La más zorra de la escuela está gimiendo por aquí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "男学生B"},
					"“喂，被传为学园第一婊子的片桐同学，在某处呻吟着呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "男學生B"},
					"「喂，被傳為學園第一婊子的片桐同學，在某處呻吟著呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00174",
		linknext = "0021_00176",
		line = 2512,
	},
	["0021_00176"] = {
		{"text"},
		text = {
