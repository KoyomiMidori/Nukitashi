		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The safest way to travel to school is to go when no one else is around.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要说最安全的上学方法是什么，那就是在谁都不在的时间去学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要說最安全的上學方法是什麼，那就是在誰都不在的時間去學校。",
					{"rt2"},
				},
			},
		},
		linknext = "0021_00002",
		line = 18,
	},
	["0021_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In other words, if we head to school early in the morning, we won't be seen by either SHO guards or the SS, so we can make it safely there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，只要一大早去学校，就可以不被SHO警卫和SS发现，平安到达学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，只要一大早去學校，就可以不被SHO警衛和SS發現，平安到達學校。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00001",
		linknext = "0021_00003",
		line = 28,
	},
	["0021_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But on the other hand, we're at school longer that way. Which means more potential danger from this whole Shootdown King business.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是那也意味着待在学校的时间变长了，在“击落王”的活动期间反而危险。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是那也意味著待在學校的時間變長了，在「擊落王」的活動期間反而危險。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00002",
