				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tachibana-kun! ¡Hay un guardia de la SS ahí! ¿Podemos pasar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君，那边……！SS的人在监视着，没问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君，那邊……！SS的人在監視著，沒問題嗎？」",
					{"rt2"},
