	["0021_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The regular SS — the public order maintenance group who stand guard in the halls — carry the same 9mm caliber riot control handguns as the SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一般的SS——站在走廊等地方的治安维持队——和SHO一样都是9毫米口径的暴徒镇压用手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一般的SS——站在走廊等地方的治安維持隊——和SHO一樣都是9毫米口徑的暴徒鎮壓用手槍。",
					{"rt2"},
				},
			},
