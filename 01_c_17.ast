			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Han entrado en contacto. Grupo de genitales enemigos a las 12 en punto. Están equipados con rifles de asalto de la SS. Se supone que son la primera fuerza de ataque del escuadrón. Están a 13 metros de distancia.”",
