					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Comandante del segundo escuadrón SS"},
					"“¡No me importa si hay una loli en su grupo! ¡No permitiré que alteren el orden de esta manera!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SS第二中队队长"},
					"“就算你带着萝莉，我也绝对不能原谅扰乱秩序的家伙！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SS第二中隊隊長"},
					"「就算你帶著蘿莉，我也絕對不能原諒擾亂秩序的傢伙！！」",
					{"rt2"},
				},
			},
		},
