		line = 1893,
	},
	["0021_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El evento habrá finalizado y podremos volver a nuestra rutina diaria.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且活动结束后，就能回到平常的日子。",
