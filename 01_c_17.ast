					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Everyone, be ready for anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……大家要绷紧神经哦。”",
