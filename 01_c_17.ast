					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Jeje, es un placer conocerlos. Me llamo Onabuta Ikuko, soy la comandante del primer escuadrón de la SS, y también soy la oficial al mando de las fuerzas especiales avanzadas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵，初次见面。我的名字是女部田郁子。SS一队队长，也是特别尖兵的中队长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵，初次見面。我的名字是女部田郁子。SS一隊隊長，也是特別尖兵的中隊長。」",
					{"rt2"},
				},
			},
		},
