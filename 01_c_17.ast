		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0626", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Conque así son las cosas... Va a estar difícil...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……原来如此，那还真是难办了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……原來如此，那還真是難辦了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00083",
		linknext = "0021_00085",
		line = 1286,
	},
	["0021_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de clases, toda la NLNS se reúne de forma segura y escucha mi informe con expresiones sombrías.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后。平安集合的NLNS们听了我的报告后，露出为难的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後。平安集合的NLNS們聽了我的報告後，露出為難的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00084",
		linknext = "0021_00086",
		line = 1296,
	},
	["0021_00086"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=6, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0414", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Por qué es un problema enorme?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“怎么样难办呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「怎麼樣難辦呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00085",
		linknext = "0021_00087",
		line = 1310,
	},
	["0021_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan es la única que nos mira con dudas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有渡酱头上顶着问号，歪起了小脑袋。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有渡醬頭上頂著問號，歪起了小腦袋。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00086",
		linknext = "0021_00088",
		line = 1320,
	},
	["0021_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esto significa quelos actos procreativos serán mucho más intensos que antes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，单纯的性产行动因为药变得更加盛行了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，單純的性產行動因為藥變得更加盛行了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00087",
		linknext = "0021_00089",
		line = 1332,
	},
	["0021_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y eso será directamente proporcional al riesgo al que nos exponemos al intentar volver a casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样我们回家的危险就提高了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣我們回家的危險就提高了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00088",
		linknext = "0021_00090",
		line = 1344,
	},
	["0021_00090"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0627", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“También está lo que la SS mencionó antes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“而且，刚才SS说的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「而且，剛才SS說的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00089",
		linknext = "0021_00091",
		line = 1356,
	},
	["0021_00091"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00104", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=7, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="美岬", id=7, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0182", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Si tienen miembros por doquier ayudando a distribuir condones, eso significa que su número ha aumentado, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“如果在这个状态下，SS队员还为了派发安全套而配置在各个地方的话，人数肯定会增加不少吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「如果在這個狀態下，SS隊員還為了派發保險套而配置在各個地方的話，人數肯定會增加不少吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00090",
		linknext = "0021_00092",
		line = 1370,
	},
	["0021_00092"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=6, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0415", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, ya entendí! Si hay más estudiantes, también habrá más SS. La seguridad es fundamental.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，原来如此……！你是说学生如果增加了，SS的人也会为了维持安全而增加对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，原來如此……！你是說學生如果增加了，SS的人也會為了維持安全而增加對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00091",
		linknext = "0021_00093",
		line = 1385,
	},
	["0021_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eso explica por qué la SS, a quienes no solemos ver, están ayudando a mantener el orden público. No sería prudente tenerlos fuera de servicio en estas circunstancias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，那个不常见到的SS，也是为了维持治安而从非值班成员中被派出来的其中一员——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，那個不常見到的SS，也是為了維持治安而從非值班成員中被派出來的其中一員——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00092",
		linknext = "0021_00094",
		line = 1396,
	},
	["0021_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es una situación compleja.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话果然很难办。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話果然很難辦。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00093",
		linknext = "0021_00095",
		line = 1406,
	},
	["0021_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Intentar salir de aquí sin un plan nos traerá varios problemas.",
