				{"vo", file="nanase0640", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The blow-up dolls are beginning to deflate! They're going to raise suspicion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“比起那个，气球假人里的空气已经开始漏了，说不定会被怀疑——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「比起那個，氣球假人裡的空氣已經開始漏了，說不定會被懷疑——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00206",
		linknext = "0021_00208",
		line = 2894,
	},
	["0021_00208"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What!? They're not designed to deflate that quickly!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么！？我没注意到这是这么快就会漏气的设计……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼！？我沒注意到這是這麼快就會漏氣的設計……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00207",
		linknext = "0021_00209",
		line = 2906,
	},
	["0021_00209"] = {
		{"se", id=0, loop=0, file="se_b049"},
