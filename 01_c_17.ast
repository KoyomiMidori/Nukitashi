					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun! There's some SS standing guard over there! Can we get by?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君，那边……！SS的人在监视着，没问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君，那邊……！SS的人在監視著，沒問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00198",
		linknext = "0021_00200",
		line = 2799,
	},
	["0021_00200"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They're in a blind spot, so experience tells me we should be okay...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从那边看过来这里是死角，按我的经验来看应该没问题——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從那邊看過來這裡是死角，按我的經驗來看應該沒問題——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00199",
		linknext = "0021_00201",
		line = 2811,
	},
	["0021_00201"] = {
		{"text"},
		text = {
