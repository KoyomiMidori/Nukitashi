	["0021_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Podemos usarlas para fingir que estamos teniendo sexo, así que podemos seguir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果把这两者结合在一起，应该就可以一边模拟做爱一边前进——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果把這兩者結合在一起，應該就可以一邊模擬做愛一邊前進——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00192",
		linknext = "0021_00194",
		line = 2734,
	},
	["0021_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun así, esta multitud es enorme.",
