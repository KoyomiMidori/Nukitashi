		line = 2189,
	},
	["0021_00151"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0578", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Se acercan dos personas de estado virginal desconocido desde los salones. Parecen estar en medio de una situación desagradable en posición de pie. El estado genital es empapado. Es posible la penetración inmediatamente después del acercamiento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“教室方向有处女躯不明器接近中，数量是2，车站便当体位，推测正在交尾。湿润度‘一塌胡涂’状态，可以在接近后马上插入。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「教室方向有處女軀不明器接近中，數量是2，車站便當體位，推測正在交尾。濕潤度為『一塌糊塗』狀態，可以在接近後馬上插入。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00150",
		linknext = "0021_00152",
		line = 2201,
	},
	["0021_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tendremos que pasar a su lado... Nanase, saca la pantalla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无论如何都要突破——奈奈濑，把那个屏幕拿出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無論如何都要突破——奈奈瀨，把那個螢幕拿出來。」",
