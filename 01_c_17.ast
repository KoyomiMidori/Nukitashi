			cn = {
				{
					name = {"モブ女B", "女学生A"},
					"“来吧来吧，看着我身上用过的安全套和写满正字的大腿发情的大家……往安全套里射满精液吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "女學生A"},
					"「來吧來吧，看著我身上用過的保險套和寫滿正字的大腿發情的大家……往保險套裡射滿精液吧……」",
					{"rt2"},
				},
			},
		},
