			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Is that a not possible?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那不行吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那不行嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00120",
		linknext = "0021_00122",
		line = 1753,
	},
	["0021_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's no problem at this time of day, but in the evening the shutters are closed on the door near the ground-floor elevator.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个时间段没问题，但一到傍晚，一楼电梯附近的门就会被拉下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個時間段沒問題，但一到傍晚，一樓電梯附近的門就會被拉下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00121",
		linknext = "0021_00123",
		line = 1765,
	},
	["0021_00123"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0186", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Then what if we left now? Oh, wait, there's still going to be a lot of people around. That won't work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那么现在就……啊，不，这个时间段还有很多人。也就是说不可能，是吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那麼現在就……啊，不，這個時間段還有很多人。也就是說不可能，是吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00122",
		linknext = "0021_00124",
		line = 1781,
	},
	["0021_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, we have to wait until late in the evening, so there's the least number of people possible around.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，我们要等到人最少的傍晚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，我們要等到人最少的傍晚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00123",
		linknext = "0021_00125",
		line = 1793,
	},
	["0021_00125"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00103", path=":fg/nanase_02m/", id=5, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0633", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“In that case... How's this? We'll go up to the fourth floor, then weave our way down to the first floor and head for the exit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那就——上到4楼，然后穿过缝隙下到1楼，再前往出入口吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那就——上到4樓，然後穿過縫隙下到1樓，再前往出入口吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00124",
		linknext = "0021_00126",
		line = 1807,
	},
	["0021_00126"] = {
		{"text"},
		text = {
