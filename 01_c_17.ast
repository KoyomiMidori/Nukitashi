	["0021_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Behind me Asa-chan is gathering information, Hotori, Wata-chan, and Nanase making up the rear guard.",
