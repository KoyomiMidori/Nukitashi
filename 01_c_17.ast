	},
	["0021_00330"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0084", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SS二番隊隊長"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Comandante del segundo escuadrón SS"},
					"“Ahora, les daremos un castigo especial por ser tan tontos y huir del sexo pervertido. ¡Nos entregarán su virginidad!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SS第二中队队长"},
					"“来吧，你们这些逃离变态做爱的愚蠢人们准备接受特别惩罚吧。我们将夺走你们的处男和处女！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SS第二中隊隊長"},
					"「來吧，你們這些逃離變態做愛的愚蠢人們準備接受特別懲罰吧。我們將奪走你們的處男和處女！」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00329",
		linknext = "0021_00331",
		line = 4712,
	},
	["0021_00331"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0085", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SS二番隊隊長"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Comandante del segundo escuadrón SS"},
					"“¡Más vale que follen entre ustedes, desgraciados no-copuladores! ¡Así podremos dar el ejemplo con ustedes, jajajaja!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SS第二中队队长"},
					"“作为警示，让你们反交尾势力的成员，跟自己人在全校学生面前做爱好像也不错呢，啊哈哈哈哈！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SS第二中隊隊長"},
					"「作為警示，讓你們反交尾勢力的成員，跟自己人在全校學生面前做愛好像也不錯呢，啊哈哈哈哈！」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00330",
		linknext = "0021_00332",
		line = 4724,
	},
	["0021_00332"] = {
