					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Normalmente, la SS se encargaría de la preparación y gestión del evento, por lo que no participarían...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一般来说，SS只负责活动管理，应该不会直接参加才对……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一般來說，SS只負責活動管理，應該不會直接參加才對……」",
					{"rt2"},
				},
			},
		},
