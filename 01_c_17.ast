					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“开什么玩笑！不带疑问地享受着被赋予的歪曲意识的人说什么秩序啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「開什麼玩笑！不帶疑問地享受著被賦予的歪曲意識的人說什麼秩序啊！！」",
					{"rt2"},
