	["0021_00102"] = {
		{"bgm", file="bgm11", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"extrans", sync=0, time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“First of all, let's go over the situation. Asane?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先，整理情况——麻沙音。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先，整理情況——麻沙音。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00101",
		linknext = "0021_00103",
		line = 1521,
	},
	["0021_00103"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0572", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Today is the final day of Minotsuki Academy's regular Shootdown King event. Anticipating biggest crowds and highest risk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“今天是水乃月学园定期活动‘击坠王’的最后一天，预计会出现最混乱和最危险的局面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「今天是水乃月學園定期活動『擊墜王』的最後一天，預計會出現最混亂和最危險的局面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00102",
		linknext = "0021_00104",
		line = 1534,
	},
	["0021_00104"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0573", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Regarding escape routes, the rear gate currently has complications. There are currently 10 or more SS stationed at the rear of the building, and the lack of cover makes escaping through there unfeasible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“关于逃跑路线，被堵住出口的后门路线无法使用。现阶段教学楼后面有10多名SS，由于没有遮挡物，所以视为不可能突破。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「關於逃跑路線，被堵住出口的後門路線無法使用。現階段校舍後面有10多名SS，由於沒有遮擋物，所以視為不可能突破。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00103",
		linknext = "0021_00105",
		line = 1546,
	},
	["0021_00105"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0574", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Additionally anticipating inability to utilize limestone cave route due to lack of low tides.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“同时钟乳洞路线也不在退潮时期，预计从今天开始将无法使用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「同時鐘乳洞路線也不在退潮時期，預計從今天開始將無法使用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00104",
		linknext = "0021_00106",
		line = 1558,
	},
	["0021_00106"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0183", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um... excuse me. If we just need to get through today, why can't we just stay here overnight?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……不好意思，如果只需要挺过今天的话，就住在这里不行吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……不好意思，如果只需要挺過今天的話，就住在這裡不行嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00105",
		linknext = "0021_00107",
		line = 1572,
	},
	["0021_00107"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0184", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The base has a store of all the daily necessities, so we should be able to get by for a day, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“基地里的日用品也很齐全，你有说过一天的话应该没有问题的对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「基地裡的日用品也很齊全，你有說過一天的話應該沒有問題的對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00106",
		linknext = "0021_00108",
		line = 1584,
	},
	["0021_00108"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, on the weekends they lock both the front and rear gates.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个学校的大门，每逢周末都会锁上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個學校的大門，每逢週末都會鎖上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00107",
		linknext = "0021_00109",
		line = 1596,
	},
	["0021_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So if we were to stay here overnight, we wouldn't have a way out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，过了今天晚上将不能出入学校。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，過了今天晚上將不能出入學校。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00108",
		linknext = "0021_00110",
		line = 1608,
	},
	["0021_00110"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0629", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Most of us do have our parents on the island with us, after all. That'd probably be hard to swallow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对我们这些父母在岛上的人来说，这提案应该有点困难的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對我們這些父母在島上的人來說，這提案應該有點困難的吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00109",
		linknext = "0021_00111",
		line = 1621,
	},
	["0021_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The day we rescued Wata-chan, we entered the base via the elevator, but the school was open because it was Island Orgy Day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然帮助渡酱的时候是乘坐学校里的电梯来到基地的，但那是因为学校当时正在纪念姦港纪念日才对外开放的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然幫助渡醬的時候是乘坐學校裡的電梯來到基地的，但那是因為學校當時正在紀念姦港紀念日才對外開放的。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00110",
		linknext = "0021_00112",
		line = 1631,
	},
	["0021_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This being a regular weekend, the gates will all but certainly be locked this time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是这个周末，门应该会跟往常一样被锁住吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是這個週末，門應該會跟往常一樣被鎖住吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00111",
		linknext = "0021_00113",
		line = 1641,
	},
	["0021_00113"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0630", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Plus the SHO show up with their little special delivery service on weekends, right? That also serves as family structure inspection.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“而且SHO在休息日也会上门服务，那还包括家庭成员的调查呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「而且SHO在休息日也會上門服務，那還包括家庭成員的調查呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00112",
		linknext = "0021_00114",
		line = 1653,
	},
	["0021_00114"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=7, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0185", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh, really!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶，是这样啊……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸，是這樣啊……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00113",
		linknext = "0021_00115",
		line = 1668,
	},
	["0021_00115"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0631", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The SS are basically connected to the SHO, so... if we're not there, it's gonna cause our families grief. We have to get home at all costs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“SS基本上和SHO是联系在一起的……如果我们不在，会给家人带来麻烦的。无论如何都必须回家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「SS基本上和SHO是聯繫在一起的……如果我們不在，會給家人帶來麻煩的。無論如何都必須回家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00114",
		linknext = "0021_00116",
		line = 1680,
	},
	["0021_00116"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0575", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Me and Bro are the only ones in our family, so it'd be really suspicious if both of us were missing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我和哥哥是二人家庭，不在的话会很奇怪的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我和哥哥是二人家庭，不在的話會很奇怪的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00115",
		linknext = "0021_00117",
		line = 1692,
	},
	["0021_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. So, with all that in mind...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，也就是说今天——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，也就是說今天——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00116",
		linknext = "0021_00118",
		line = 1704,
	},
	["0021_00118"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“For today, we're gonna have to come up with a way to break through the front gate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无论如何都只能从正门突破。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無論如何都只能從正門突破。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00117",
		linknext = "0021_00119",
		line = 1716,
	},
	["0021_00119"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0632", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's risky, but we don't have any other options.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然风险很高，但除此之外别无他法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然風險很高，但除此之外別無他法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00118",
		linknext = "0021_00120",
		line = 1728,
	},
	["0021_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The most direct path is to get out of the elevator on the ground floor and head straight for the east exit, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最近的路线是在一楼下电梯，然后马上前往东侧的出入口……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最近的路線是在一樓下電梯，然後馬上前往東側的出入口……」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00119",
