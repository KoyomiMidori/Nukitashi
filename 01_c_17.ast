		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They're still in active service, thank you very much!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她们还是现役女友！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她們還是現役女友！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00191",
		linknext = "0021_00193",
		line = 2722,
	},
	["0021_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can use them to pretend we're having sex, so that should allow us to proceed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果把这两者结合在一起，应该就可以一边模拟做爱一边前进——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果把這兩者結合在一起，應該就可以一邊模擬做愛一邊前進——」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00192",
		linknext = "0021_00194",
		line = 2734,
	},
	["0021_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But really, this crowd is huge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，人还是太多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，人還是太多。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00193",
		linknext = "0021_00195",
		line = 2744,
	},
	["0021_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I certainly don't have unlimited TAEs on my person.",
					{"rt2"},
				},
			},
			cn = {
				{
					"T-A-E也并不是用不完。",
					{"rt2"},
				},
			},
			tw = {
				{
					"T-A-E也並不是用不完。",
					{"rt2"},
				},
