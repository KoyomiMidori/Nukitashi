			en = {
				{
					name = {"モブ男A", "Chuunibyou"},
					"“Je... Discípulo maldecido de la rebelión. Estás despertando a mis propios descendientes, atrayéndolos hacia el abismo dimensional, y los demonios plateados sellados en su interior serán— ¡Ah, mierda, me vengo...!”",
