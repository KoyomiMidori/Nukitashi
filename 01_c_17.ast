			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Las muñecas se están desinflando! Van a levantar sospechas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“比起那个，气球假人里的空气已经开始漏了，说不定会被怀疑——”",
					{"rt2"},
