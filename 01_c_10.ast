	["0011_00011"] = {
		{"fg", file="nanase_01l_00001", file1="nanase_01l_00114", path=":fg/nanase_01l/", id=4, lv=5, head="nanase_01l", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0322", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Vale, vale, ya entendí. Tenías muchas ganas de hacerlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好好好，我懂了。你就是想喊出名号试试看对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好好好，我懂了。你就是想喊出名號試試看對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00010",
		linknext = "0011_00012",
		line = 143,
	},
	["0011_00012"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0349", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Casi nunca nos daría nombre... pero es que no paró...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“明明说什么本来不打算说出名字……结果还讲了一大堆……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「明明說什麼本來不打算說出名字……結果還講了一大堆……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00011",
		linknext = "0011_00013",
		line = 155,
	},
	["0011_00013"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0323", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Conociéndote, seguro tenías muchas ganas de hacer esto, y aprovechaste la oportunidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我估计你肯定是想了很久，一直在等待这么做的机会对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我估計你肯定是想了很久，一直在等待這麼做的機會對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00012",
		linknext = "0011_00014",
		line = 167,
	},
	["0011_00014"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0350", path=":vo/", ch="asane"},
