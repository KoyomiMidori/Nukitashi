			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡A-Aun así...! Esta organización quiere destruir la ley \nsúperpervertida, ¿verdad? Son delicuentes, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但、但是！这里是为了破坏条例而建立的组织吧？大家都是坏孩子吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但、但是！這裡是為了破壞條例而建立的組織吧？大家都是壞孩子吧？」",
					{"rt2"},
				},
