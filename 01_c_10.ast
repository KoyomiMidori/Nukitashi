	["0011_00272"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0151", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Q-Q-Q-Qué es este lugar?! ¡¿Siempre estuvo debajo de nuestra escuela?! ¡No lo sabía!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“什什什，这是什么这是什么！学校下面有这样的地方！？第一次听说！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「什什什，這是什麼這是什麼！學校下面有這樣的地方！？第一次聽說！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00271",
		linknext = "0011_00273",
		line = 3903,
	},
	["0011_00273"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0346", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Así es. Solo los miembros de nuestra organización lo saben. Nosotros también nos sorprendimos cuando encontramos este lugar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“当然，除了我们之外没有人知道……我们第一次来这里的时候也很惊讶呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「當然，除了我們之外沒有人知道……我們第一次來這裡的時候也很驚訝呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00272",
		linknext = "0011_00274",
		line = 3916,
	},
	["0011_00274"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00114", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0370", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Jaaa, a quién le importa... Estoy cansada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哈啊啊……无所谓啦……总之我累了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哈啊啊……無所謂啦……總之我累了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00273",
		linknext = "0011_00275",
		line = 3930,
	},
	["0011_00275"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"bg", id=6, file="bg12_1l_00000", x=400, y=0, lv=5, path=":bg/", sync=0, time=1000, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=6, act="移動", x=-805, y=-5, time=20000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan se tumba sobre el sofá.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱瘫在基地里的沙发上。",
