			},
		},
		linkback = "0011_00207",
		linknext = "0011_00209",
		line = 2893,
	},
	["0011_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La división de combate está aquí... Como si no estuviéramos en aprietos ya.",
					{"rt2"},
				},
			},
			cn = {
				{
					"切，特殊战斗部出现了吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"嘖，特殊戰鬥部出現了嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00208",
		linknext = "0011_00210",
		line = 2903,
	},
	["0011_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La asociación general de la OSS está compuesta por varios grupos. Las guardias de la OSS son miembros del de mantenimiento del orden público.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一般社团法人SHO是由若干委员会组成的，SHO警卫属于“治安管理委员会”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一般社團法人SHO是由若干委員會組成的，SHO警衛屬於「治安管理委員會」。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00209",
		linknext = "0011_00211",
		line = 2913,
	},
	["0011_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Entre ellos se encuentran la división de mantenimiento del orden público y la división de combate especial. La división de combate cuenta con las guardias de élite especializados en combate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其中包括“治安维持部”和“特殊战斗部”，“特殊战斗部”是专门处理粗暴事件的精英SHO。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其中包括「治安維持部」和「特殊戰鬥部」，「特殊戰鬥部」是專門處理粗暴事件的精英SHO。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00210",
		linknext = "0011_00212",
		line = 2923,
	},
	["0011_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Básicamente, están ubicados en el centro de la ciudad, donde hay más gente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们基本上都被部署于人来人往的市中心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們基本上都被部署於人來人往的市中心。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00211",
		linknext = "0011_00213",
		line = 2933,
	},
	["0011_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si han llegado así de lejos, eso quiere decir...",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说我们已经逃到这里来了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說我們已經逃到這裡來了——",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00212",
		linknext = "0011_00214",
		line = 2943,
	},
	["0011_00214"] = {
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg22_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0093", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマンG"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS G"},
					"“Si intentan escapar de nuevo, los someteremos con más fuerza militar que una simple paliza. La próxima vez no habrá advertencia. ¡Les dispararemos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫G"},
					"“如果继续逃跑，我们将会采取无套做爱以上的武力镇压！！下次不是威胁，而是直接开枪！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛G"},
					"「如果繼續逃跑，我們將會採取無套做愛以上的武力鎮壓！！下次不是威脅，而是直接開槍！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00213",
		linknext = "0011_00215",
		line = 2961,
	},
	["0011_00215"] = {
		{"se", id=0, loop=0, file="se_a023"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Ignórenlos y sigan corriendo! ¡No miren atrás!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别担心背后，专心跑步——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別擔心背後，專心跑步——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00214",
		linknext = "0011_00216",
		line = 2973,
	},
	["0011_00216"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0052", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SHOガードマンH"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Guardia de la OSS H"},
					"“¡Oigan! ¿Están intentando alterar el orden público? ¡Están molestando a toda la gente que goza del sexo pervertido sano!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SHO警卫H"},
					"“你们！到底在不在乎岛上的治安啊！？对于那些进行健全做爱的人们而言这很困扰不是吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛H"},
					"「你們！到底在不在乎島上的治安啊！？對於那些進行健全做愛的人們而言這很困擾不是嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00215",
		linknext = "0011_00217",
		line = 2985,
	},
	["0011_00217"] = {
		{"se", id=0, loop=0, file="se_a023"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Desgraciados, su moralidad es muy extraña!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我和你们的价值观不同——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我和你們的價值觀不同——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00216",
		linknext = "0011_00218",
		line = 2998,
	},
	["0011_00218"] = {
