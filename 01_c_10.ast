	["0011_00025"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Vas a necesitar una excusa mejor, maldito lolicon! ¡Te llevaré con la policía por agredir a una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“找个更说得通的借口吧你这萝莉控！我要告诉警察你袭击萝莉——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「找個更說得通的藉口吧你這蘿莉控！我要告訴警察你襲擊蘿莉——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00024",
		linknext = "0011_00026",
		line = 336,
	},
	["0011_00026"] = {
