	["0011_00021"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00113", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y no es la primera vez que haces esto, ¿verdad? Te gusta acosar lolis, ¿eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看你刚刚那样子可不像是第一次啊。你是经常袭击萝莉的惯犯吗——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看你剛剛那樣子可不像是第一次啊。你是經常襲擊蘿莉的慣犯嗎——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00020",
		linknext = "0011_00022",
		line = 284,
	},
	["0011_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0051", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "男A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Hombre A"},
					"“¡No! ¡No se veía como una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "A男"},
					"“不是！这个女孩看起来又不像萝莉！”",
					{"rt2"},
