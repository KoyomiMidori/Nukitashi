		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Introduzco una moneda de 500 yenes en la máquina expendedora de cápsulas y giro la palanca.",
					{"rt2"},
