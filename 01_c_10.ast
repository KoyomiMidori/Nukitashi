		{"bg", id=1, file="bg21_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0147", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿De veras es un lugar seguro? A ver, no hay nadie cerca, pero...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这里就是非常安全的地方吗？虽然的确没有岛上的人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這裡就是非常安全的地方嗎？雖然的確沒有島上的人——」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00263",
		linknext = "0011_00265",
		line = 3758,
	},
	["0011_00265"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
