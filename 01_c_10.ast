					name = {"モブ男B", "Hombre A"},
					"“P-Pues...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "A男"},
					"“那、那是因为……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "A男"},
					"「那、那是因為……」",
