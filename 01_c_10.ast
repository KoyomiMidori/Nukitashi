		},
		linkback = "0011_00029",
		linknext = "0011_00031",
		line = 401,
	},
	["0011_00031"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0325", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya veo. Seguramente estás un poco conmocionada, debiste pasar mucho miedo... ¿Quieres un caramelo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯。我明白你很困惑，很可怕对吧……要吃糖吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯。我明白你很困惑，很可怕對吧……要吃糖嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00030",
		linknext = "0011_00032",
		line = 415,
	},
	["0011_00032"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="hinami_01m_00002", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0125", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Yay, es de sabor a fresa! ¡Oyee! ¡Ya te lo dije, que no soy una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇，是草莓的！……不对啦！我不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇，是草莓的！……不對啦！我不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00031",
		linknext = "0011_00033",
		line = 432,
	},
	["0011_00033"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0352", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Uh, manito... Las chicas de su edad se enfadan mucho cuando las tratas como si fueran niñas. Lo sé porque lo viví...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，哥哥……把这个年龄的孩子当小孩看待的话会惹他们生气的……我也是这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，哥哥……把這個年齡的孩子當小孩看待的話會惹他們生氣的……我也是這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00032",
		linknext = "0011_00034",
		line = 446,
	},
	["0011_00034"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Entiendo... Te pido perdón. Deja que nos encarguemos de toda esta problemática, Mademoiselle Lolita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……我很抱歉。之后请交给我们，洛丽塔女士。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊……我很抱歉。之後請交給我們，蘿莉塔女士。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00033",
		linknext = "0011_00035",
		line = 458,
	},
	["0011_00035"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0126", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Que no soy una loli! ¡Están equivocados! ¡Um, solo \nescúchenme, ¿bueno?! ¡No soy una loli!”",
