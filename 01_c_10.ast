		linkback = "0011_00388",
		linknext = "0011_00390",
		line = 5424,
	},
	["0011_00390"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No reacciones así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你能不能不要像愚蠢的哥哥这样做出同样的反应。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你能不能不要像愚蠢的哥哥這樣做出同樣的反應。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00389",
		linknext = "0011_00391",
		line = 5436,
	},
	["0011_00391"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0366", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, ya no va a dudar más. Solo necesitamos un último empujón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“总之我已经让她动摇了。最后再推一把应该就妥了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「總之我已經讓她動搖了。最後再推一把應該就妥了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00390",
		linknext = "0011_00392",
		line = 5450,
	},
	["0011_00392"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está bien, encontraré su punto débil.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，让我来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，讓我來吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00391",
		linknext = "0011_00393",
		line = 5462,
	},
	["0011_00393"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por cierto, ¿en qué clase estás, Hinami-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……话说，雏见酱在这个学校是几班的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……話說，雛見醬在這個學校是幾班的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00392",
		linknext = "0011_00394",
		line = 5474,
	},
	["0011_00394"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
