		linkback = "0011_00404",
		linknext = "0011_00406",
		line = 5642,
	},
	["0011_00406"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Entonces... ¿eres nuestra senpai?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那你不就是我们的前辈吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那你不就是我們的前輩嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00405",
		linknext = "0011_00407",
		line = 5655,
	},
	["0011_00407"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los papeles se han invertido y ahora somos nosotros los que nos quedamos sorprendidos ante esta repentina revelación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"发现了令人惊讶的事实，这次是我们眨了眨眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"發現了令人驚訝的事實，這次是我們眨了眨眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00406",
		linknext = "0011_00408",
		line = 5665,
	},
	["0011_00408"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No esperaba que esta loli fuera nuestra senpai y que sea un año mayor que yo... Es difícil de creer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，没想到这个萝莉居然是大我们一岁的前辈，这怎么想都……",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，沒想到這個蘿莉居然是大我們一歲的前輩，這怎麼想都……",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00407",
		linknext = "0011_00409",
		line = 5675,
	},
	["0011_00409"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está bien. ¿Te gustaría unirte a nuestra organización y ayudar a tus queridos kouhais?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那么前辈，麻烦你，就当是帮助我们后辈加入我们组织可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那麼前輩，麻煩你，就當是幫助我們後輩加入我們組織可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00408",
		linknext = "0011_00410",
		line = 5687,
	},
	["0011_00410"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[500] = {
				{"fg", file="hinami_01m_00002", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0189", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Eh?! ¡Por supuesto! ¡No hay ninguna senpai que no quisiera ayudar a un kouhai! Ejeje...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦！？好啊！如果这是后辈的请求的话，前辈是不会拒绝的！诶嘿嘿——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦！？好啊！如果這是後輩的請求的話，前輩是不會拒絕的！欸嘿嘿——」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00409",
		linknext = "0011_00411",
		line = 5704,
	},
	["0011_00411"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con ese último empujón, Hinami-chan - nuestra senpai - aceptó nuestra propuesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最后的一步，成功地让雏见酱——让前辈愉快地答应了我们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最後的一步，成功地讓雛見醬——讓前輩愉快地答應了我們。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00410",
		linknext = "0011_00412",
		line = 5714,
	},
	["0011_00412"] = {
