		line = 860,
	},
	["0011_00062"] = {
		{"fg", mode=-1, id=30, ch="奈々瀬", lv=5},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=2, file="bg08_3l_00000", x=-400, y=0, lv=5, path=":bg/", sync=0, ax=1280, ay=730, bx=-480, by=-280},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"cgact", file="cgact", id=2, act="移動", x=795, y=-5, time=25000, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0047", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SHOガードマンA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Guardia de la OSS A"},
					"“Este es el grupo de orden público de la OSS, la división de mantenimiento del orden público en el distrito S. S-1 se dirige a gran velocidad al lugar de la llamada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SHO警卫A"},
					"“这里是SHO治安管理委员会治安维持部S区担当。S-1正赶往传来紧急呼叫的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛A"},
					"「這裡是SHO治安委員會治安維持部S區負責人。S-1正趕往傳來緊急呼叫的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00061",
		linknext = "0011_00063",
		line = 880,
	},
	["0011_00063"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0048", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SHOガードマンA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Guardia de la OSS A"},
					"“S-2 y S-3 han detectado a no-copuladores y utilizarán sexo pervertido para reformarlos. División de comunicación del orden público, transmita la información una vez que haya dado con su ubicación en GPS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SHO警卫A"},
					"“S-2和S-3负责在这里寻找‘非性产者’，并进行更生做爱。请治安统筹部在获得位置信息后发送数据。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛A"},
					"「S-2和S-3負責在這裡尋找『非性產者』，並進行更生做愛。請治安統籌部在獲得位置資訊後發送數據。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00062",
		linknext = "0011_00064",
		line = 892,
	},
	["0011_00064"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0049", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SHOガードマンA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Guardia de la OSS A"},
					"“El grupo de mantenimiento del orden público se dispersará y los rodeará. Se mantendrá la lubricación vaginal. Cambio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SHO警卫A"},
					"“我们治安管理委员会将撒下包围网，保持阴道湿润。报告完毕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛A"},
					"「我們治安管理委員會將撒下包圍網，保持陰道濕潤。報告完畢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00063",
		linknext = "0011_00065",
		line = 904,
	},
	["0011_00065"] = {
