		linkback = "0011_00128",
		linknext = "0011_00130",
		line = 1767,
	},
	["0011_00130"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
