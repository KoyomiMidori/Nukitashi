					{"rt2"},
				},
			},
			cn = {
				{
					"那是当我们在接受入岛审查的时候，SHO非常严肃地告诉我们的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是當我們在接受入島審查的時候，SHO非常嚴肅地告訴我們的事情。",
					{"rt2"},
				},
