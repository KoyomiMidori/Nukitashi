		{"text"},
		text = {
			vo = {
				{"vo", file="asane0357", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Presencia enemiga detectada. Estado virgen: desconocido, se aproxima desde el noreste. Dos objetivos sospechosos. El IAE determina que el objetivo forma parte de la división de orden público de la OSS. Parecen que llevan dos pistolas calibre 44.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“捕获敌影。处女嗅探器正从东北偏北的路径接近。反应数2。 IAE，已确认对象是SHO治安维持部。装备推测为44口径的手枪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「捕獲敵影。處女軀不明器正從北北東的路徑接近中。反應數2。 IAE，已確認對象是SHO治安維持部。裝備推測為44口徑的手槍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00098",
		linknext = "0011_00100",
		line = 1431,
	},
	["0011_00100"] = {
		{"text"},
		text = {
