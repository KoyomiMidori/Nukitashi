	["0011_00059"] = {
		{"se", id=0, loop=0, file="se_a035"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0329", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Espera, Jun! Creo que hay personas ahí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“——等等，淳！那边有人的迹象。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「——等等，淳！那邊有人的跡象。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00058",
		linknext = "0011_00060",
		line = 840,
	},
	["0011_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase, que iba un paso por delante de nosotros, me hace una señal con la mano para que me detenga.",
					{"rt2"},
				},
			},
			cn = {
				{
					"走在前面的奈奈濑用一个手势阻止了我们前进。",
					{"rt2"},
				},
			},
			tw = {
				{
					"走在前面的奈奈瀨用一個手勢阻止了我們前進。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00059",
		linknext = "0011_00061",
		line = 850,
	},
	["0011_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ocultos tras los árboles, podemos ver a dos guardias de la OSS acercándose.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们躲到树后，发现有两名SHO警卫正往这边赶来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們躲到樹後，發現有兩名SHO警衛正往這邊趕來。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00060",
