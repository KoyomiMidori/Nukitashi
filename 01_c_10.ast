		linkback = "0011_00137",
		linknext = "0011_00139",
		line = 1886,
	},
	["0011_00139"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00103", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0022", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Son los niños malos que obstaculizaron las acciones procreativas, ¿verdad? ¡Sí que nos has dado bastante guerra!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“你们就是打扰性产行为的坏孩子啊？真是的，怎么可以到处乱跑呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「你們就是打擾性產行為的壞孩子啊？真是的，怎麼可以到處亂跑呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00138",
		linknext = "0011_00140",
		line = 1900,
	},
	["0011_00140"] = {
		{"text"},
		text = {
