		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Eh, maldito enfermo! ¡Sí sabes que tocar a una loli está prohibido en esta isla, ¿verdad?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你——！你知道这个岛的条例是禁止对萝莉出手的吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你——！你知道這個島的條例是禁止對蘿莉出手的吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00018",
		linknext = "0011_00020",
		line = 258,
	},
	["0011_00020"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0050", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "男A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
