				},
			},
			cn = {
				{
					"填充在其中的微粒蒸汽、二氧化碳气体、水蒸气等组成的发烟剂喷发出来，周围一带被烟幕包围了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"填充在其中的微粒蒸汽、二氧化碳氣體、水蒸氣等組成的發煙劑噴發出來，周圍一帶被煙幕包圍了。",
					{"rt2"},
				},
