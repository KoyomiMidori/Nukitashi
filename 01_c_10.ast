			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mmmf, mrgfgh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“唔啊，嗯，唔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「唔啊，嗯，唔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00378",
		linknext = "0011_00380",
		line = 5287,
	},
	["0011_00380"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0363", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Y bien? ¿No te parece triste tener que vivir así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是吧？你不觉得这是件很伤心的事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是吧？你不覺得這是件很傷心的事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00379",
		linknext = "0011_00381",
		line = 5301,
	},
	["0011_00381"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0180", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃、呃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃、呃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00380",
		linknext = "0011_00382",
		line = 5315,
	},
	["0011_00382"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0364", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿No sería maravilloso que tu primera experiencia fuera una encantadora con tu pareja?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“第一次当然要和最喜欢的人有一个美好的经历不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「第一次當然要和最喜歡的人有一個美好的經歷不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00381",
		linknext = "0011_00383",
		line = 5327,
	},
	["0011_00383"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="浮遊横", loop=3, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0181", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uuugh... ¡Urrrrrgggghh...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔唔唔唔……呜呜呜……嗯唔……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔唔唔唔……嗚嗚嗚……嗯唔……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00382",
		linknext = "0011_00384",
		line = 5342,
	},
	["0011_00384"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami-chan se agarra la cabeza y suelta quejidos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见酱抱着头，发出痛苦的呻吟声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見醬抱著頭，發出痛苦的呻吟聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00383",
		linknext = "0011_00385",
		line = 5352,
	},
	["0011_00385"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0182", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí, tienes toda la razón... Si pierdo mi virginidad, quiero que sea con alguien que me gusta...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“果然，没错呢……第一次做爱想要和喜欢的人一起呢〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「果然，沒錯呢……第一次做愛想要和喜歡的人一起呢〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00384",
		linknext = "0011_00386",
		line = 5366,
	},
	["0011_00386"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0183", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Además, si sigo por este camino, seré una chica mala de todos modos... así que no tengo nada que perder... ¡Aun así...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“反正这样下去，我也会变成坏孩子……那我干脆去学坏……但是——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「反正這樣下去，我也會變成壞孩子……那我乾脆去學壞……但是——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00385",
		linknext = "0011_00387",
		line = 5381,
	},
	["0011_00387"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0380", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sus preocupaciones son tan puras, da hasta miedo lo buena chica que es...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“多么健全的烦恼啊，这孩子也太乖了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「多麼健全的煩惱啊，這孩子也太乖了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00386",
		linknext = "0011_00388",
		line = 5395,
	},
	["0011_00388"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00111", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0365", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ahhhh... Los niños son tan pequeños y tiernos... ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哈啊啊……善变的小孩子真是可爱——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哈啊啊……善變的小孩子真是可愛——」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00387",
		linknext = "0011_00389",
		line = 5410,
	},
	["0011_00389"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0381", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Y bien? ¿Eres nuestra enemiga?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“什么，是‘敌人’吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「什麼，是『敵人』嗎？」",
