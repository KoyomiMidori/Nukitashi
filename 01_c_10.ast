			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Contacto. Se acercan enemigos. La IAE ha determinado que los objetivos son buscadores de sexo. Son seis, dos hombres y cuatro mujeres. Están en medio de un encuentro sexual entre seis. Están equipados con consoladores extremadamente gruesos, bolígrafos de pasión y tres condones marca OSS.”",
