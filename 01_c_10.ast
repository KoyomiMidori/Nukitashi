				{"vo", file="hinami0144", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh... Los onaholes son increíbles...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶——飞机杯原来这么厉害……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸——飛機杯原來這麼厲害……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00253",
		linknext = "0011_00255",
		line = 3607,
	},
	["0011_00255"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0369", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Siento que está entendiendo todo mal...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我感觉她好像误解了什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我感覺她好像誤會了什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00254",
		linknext = "0011_00256",
		line = 3621,
	},
	["0011_00256"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00111", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0345", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jeje... ¿y qué tiene? Es muy linda.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵……很可爱所以没关系！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呵呵……很可愛所以沒關係！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00255",
		linknext = "0011_00257",
		line = 3636,
	},
	["0011_00257"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, tenemos que darnos prisa. Aunque hayamos logrado despistarlos, todavía no estamos a salvo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个，赶快走吧。我们虽然逃掉了，但这并不意味着我们得救了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個，趕快走吧。我們雖然逃掉了，但這並不意味著我們得救了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00256",
		linknext = "0011_00258",
		line = 3648,
	},
	["0011_00258"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya podremos hablar cuando lleguemos al refugio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在安全的地方等待事件冷却吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在安全的地方等待事件冷卻吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00257",
		linknext = "0011_00259",
		line = 3660,
	},
	["0011_00259"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0145", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Su refugio queda cerca? O sea, ¿está en las montañas o algo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那个安全的地方是在这附近吗？在山里？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那個安全的地方是在這附近嗎？在山裡？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00258",
		linknext = "0011_00260",
		line = 3674,
	},
	["0011_00260"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No... Ya estamos ahí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——马上就要到了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——馬上就要到了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00259",
		linknext = "0011_00261",
		line = 3686,
	},
	["0011_00261"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=100},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="bg17_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"se", id=0, loop=0, file="se_a015"},
		{"bg", id=1, file="bg17_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0146", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero... esta es la escuela, ¿no...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这里是……我们的学校，对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這裡是……我們的學校，對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00260",
		linknext = "0011_00262",
		line = 3712,
	},
	["0011_00262"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así es. Hoy es festivo en toda la isla, así que la Academia Minotsuki estará vacía.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。今天是岛上的休假日，水乃月学园也是空无一人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。今天是島上的休假日，水乃月學園也是空無一人——」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00261",
		linknext = "0011_00263",
		line = 3724,
	},
	["0011_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, no hay nadie de la SS. Entremos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，没有SS，我们可以进去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好，沒有SS，我們可以進去了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00262",
		linknext = "0011_00264",
		line = 3735,
	},
	["0011_00264"] = {
