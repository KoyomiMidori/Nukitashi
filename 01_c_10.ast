	["0011_00005"] = {
		{"bg", id=1, file="bg08_3l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="asane_01l_00001", file1="asane_01l_00105", file2="asane_01l_00202", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0347", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Maldita sea, no tenemos tiempo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“真是的，完全没时间拦住你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真是的，完全沒時間攔住你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00004",
		linknext = "0011_00006",
		line = 65,
	},
	["0011_00006"] = {
		{"fg", file="nanase_01l_00001", file1="nanase_01l_00105", file2="nanase_01l_00202", path=":fg/nanase_01l/", id=4, lv=5, head="nanase_01l", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0320", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Nuestras posibilidades ya son más escasas que el pecho de esta chica! ¿Qué crees que estás haciendo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你明明没多少胜算还这样……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你明明沒多少勝算還這樣……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00005",
		linknext = "0011_00007",
		line = 78,
	},
	["0011_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Tenía que salvarla!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，也不能不去救吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，也不能不去救吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00006",
		linknext = "0011_00008",
		line = 90,
	},
	["0011_00008"] = {
		{"fg", file="nanase_01l_00001", file1="nanase_01l_00104", path=":fg/nanase_01l/", id=4, lv=5, head="nanase_01l", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0321", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, ¿podrías haberle hecho un ataque sorpresa bajo el amparo de la noche en lugar de ir gritando quiénes somos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那也可以不用告诉人家大名直接暗中解决啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那也可以不用告訴人家大名直接暗中解決啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00007",
		linknext = "0011_00009",
		line = 104,
	},
	["0011_00009"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0348", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No somos héroes, necesitamos ese tipo de entrada del mismo modo que un chico virgen necesita el prepucio de su polla. ¿Qué sentido tenía eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“刚刚那个华丽的登场可能就跟毫无意义的处男包皮（没有保护价值）一样吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「剛剛那個華麗的登場可能就跟毫無意義的處男包皮（沒有保護價值）一樣吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00008",
		linknext = "0011_00010",
		line = 116,
	},
	["0011_00010"] = {
