	["0011_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al girar el Huevo se enciende la mecha y, unos segundos después, las partículas de aluminio del interior se dispersan bajo alta presión.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把“Egg”转半圈会点燃保险丝，几秒钟后，里头的铝颗粒将被压力推出。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把「Egg」轉半圈會點燃保險絲，幾秒鐘後，裡頭的鋁顆粒將被壓力推出。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00181",
		linknext = "0011_00183",
		line = 2529,
	},
	["0011_00183"] = {
		{"text"},
		text = {
