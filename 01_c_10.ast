		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Están diciendo que no les importa lo que le hubiera pasado a esa chica? Es muy pequeña e inocente...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那你们觉得那女孩怎么样都没关系吗！？那么纯洁无辜的弱小女孩——”",
