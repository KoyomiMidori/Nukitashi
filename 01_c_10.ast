		{"bg", id=1, file="bg22_3l_00000", x=-200, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="nanase_01l_00001", file1="nanase_01l_00104", file2="nanase_01l_00202", path=":fg/nanase_01l/", id=4, lv=5, head="nanase_01l", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=200, y=0, time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0342", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun, seguro ya lo sabes, pero la división especial de combate está autorizada a disparar por el orden público. No son como el resto de la OSS y la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳，我想你应该知道与其他的SHO和SS不同，特殊战斗部在治安维持的名目下，可以在未经许可的情况下开枪哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳，我想你應該知道與其他的SHO和SS不同，特殊戰鬥部在治安維持的名目下，可以在未經許可的情況下開槍哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00222",
		linknext = "0011_00224",
		line = 3065,
	},
	["0011_00224"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
