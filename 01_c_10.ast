	},
	["0011_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pulso dos veces el botón para subir, luego dos veces el botón para bajar, y luego pulso ambos tres veces.",
					{"rt2"},
				},
			},
			cn = {
				{
					"往上两次，往下两次，然后上下同时三次——",
					{"rt2"},
				},
			},
			tw = {
				{
					"往上兩次，往下兩次，然後上下同時三次——",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00266",
		linknext = "0011_00268",
		line = 3795,
	},
