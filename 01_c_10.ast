		},
		linkback = "0011_00198",
		linknext = "0011_00200",
		line = 2771,
	},
	["0011_00200"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Llamaríamos mucho la atención si lleváramos tantas cosas a la vez. Así que lo convertimos en un lugar de reabastecimiento para evitar ese problema.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“携带很多飞机杯会被怀疑。所以要设置一个可以这样补充的站点——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「攜帶很多飛機杯會被懷疑。所以要設置一個可以這樣補充的站點——」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00199",
		linknext = "0011_00201",
		line = 2783,
	},
	["0011_00201"] = {
		{"se", id=0, loop=0, file="se_b004"},
		{"bg", id=14, file="system_radar_00001", x=0, y=0, path=":bg/", time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=14, act="アルファフェード点滅", loop=-1, alpha="90,256", time=750, alphadel=0, lv=5, x=0, y=0},
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0366", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hermano, causamos mucho alboroto. Todas las guardias de la zona nos están siguiendo. Las veo en mi radar. Tres genitales enemigos por detrás, dos por delante y cuatro cerca de la zona de la playa, están armadas con metralletas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥，我们闹太大了。所有周围的SHO都在寻找我们。雷达探测到了。后方有3名敌性器，前方有2名，海滩有4名，都装备着SHO型冲锋枪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥，我們鬧太大了。所有周圍的SHO都在尋找我們。雷達探測到了。後方有3名敵性器，前方有2名，海灘有4名，都裝備著SHO型衝鋒槍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00200",
		linknext = "0011_00202",
		line = 2799,
	},
	["0011_00202"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
