	["0011_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matarían a nadie, pero causarían bastante daño si impactaran directamente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然杀伤能力很低，但根据击中的地方不同，也具有留下后遗症程度的破坏力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然殺傷能力很低，但根據擊中的地方不同，也具有留下後遺症程度的破壞力。",
