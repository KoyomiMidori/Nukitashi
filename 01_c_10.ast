	},
	["0011_00396"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0367", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Oh? ¿Entonces son compañeritas? Qué curioso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哎呀，那你们在同一个班级是吗？真是偶巧呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哎呀，那你們在同一個班級是嗎？真是偶巧呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00395",
		linknext = "0011_00397",
		line = 5516,
	},
	["0011_00397"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero no recuerdo verla con los otros estudiante del 1-1.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是1年1班里有这样的女孩吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是1年1班裡有這樣的女孩嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00396",
		linknext = "0011_00398",
		line = 5528,
	},
	["0011_00398"] = {
