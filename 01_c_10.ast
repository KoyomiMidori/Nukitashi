	["0011_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Un par de guardias de aspecto imponente se encuentran a unas decenas de metros más adelante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"几十米之外，站着两位SHO警卫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"幾十米之外，站著兩個SHO警衛。",
					{"rt2"},
				},
