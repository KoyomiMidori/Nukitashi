	},
	["0011_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Una de las guardias está equipada con una pistola normal, pero la otra, la de cara bonita, lleva una metralleta colgada al cuello..",
					{"rt2"},
				},
			},
			cn = {
				{
					"一名SHO警卫的装备是普通的手枪，但是另一位长得漂亮的警卫的脖子上挂着一把冲锋枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一名SHO警衛的裝備是普通的手槍，但是另一位長得漂亮的警衛的脖子上掛著一把衝鋒槍。",
					{"rt2"},
				},
			},
