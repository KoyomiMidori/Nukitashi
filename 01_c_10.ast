				{"vo", file="asane0358", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Estado de los genitales del enemigo: humedecidos ",
					{"gaiji", text="①"},
					" y empapados",
					{"gaiji", text="①"},
					". Debería ser posible la penetración sin juegos previos tras la llegada. 420 segundos para contactar.”",
					{"rt2"},
