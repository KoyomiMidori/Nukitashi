		{"fg", file="hinami_01m_00002", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0138", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡E-Eso fue genial! ¡Cada color tenía distintos efectos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“刚、刚刚的道具好厉害！每个颜色效果都不一样呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「剛、剛剛的道具好厲害！每個顏色效果都不一樣呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00191",
		linknext = "0011_00193",
		line = 2673,
	},
	["0011_00193"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0341", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí, aunque usé bastantes. Solo me quedan dos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是的，但刚刚应该已经用掉了很多个。只剩下两个了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是的，但剛剛應該已經用掉了很多個。只剩下兩個了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00192",
		linknext = "0011_00194",
		line = 2687,
	},
	["0011_00194"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0365", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Acercándonos al Depósito de Huevo; a 700 metros. No hay personas en busca de sexo. Podemos reabastecer recursos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“前面700米有‘蛋仓’。没有性触者。可以进行补给。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「前方700公尺處有『蛋倉』。沒有性觸者。可以進行補給。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00193",
		linknext = "0011_00195",
		line = 2700,
	},
	["0011_00195"] = {
