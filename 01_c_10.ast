	},
	["0011_00276"] = {
		{"se", id=0, loop=0, file="se_a007"},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=100},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La loli legal se queda parada mientras mira sus alrededores.",
					{"rt2"},
				},
			},
			cn = {
				{
					"合法萝莉则正一脸新奇地到处转。",
					{"rt2"},
				},
			},
			tw = {
				{
					"合法蘿莉則正一臉新奇地到處轉。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00275",
		linknext = "0011_00277",
		line = 3960,
	},
	["0011_00277"] = {
		{"se", id=0, stop=1, time=1000},
		{"cgdel", id=6, lv=5, time=100, alphadel=1},
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se pasa una eternidad mirando su alrededor, pero luego se planta delante de mí y me mira fijamente, con los ojos bien abiertos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知是不是看足了，她回到我的面前，睁着大大的眼睛抬头看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道是不是看夠了，她回到我的面前，睜著大大的眼睛抬頭看著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00276",
		linknext = "0011_00278",
		line = 3975,
	},
	["0011_00278"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00114", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0152", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No puedo creer que hasta tengan una base... ¿Quiénes son ustedes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“居然在这里有这样的基地……大家，究竟是何方神圣……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「居然在這裡有這樣的基地……大家，究竟是何方神聖……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00277",
		linknext = "0011_00279",
		line = 3989,
	},
	["0011_00279"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya lo dije antes, pero para resumirlo un poco, somos el NLNS— un frente anti-copulación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“之前提到过，但我们是‘NLNS’——反交尾势力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「之前提到過，但我們是『NLNS』——反交尾勢力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00278",
		linknext = "0011_00280",
		line = 4001,
	},
	["0011_00280"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0153", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Un frente anti-copulación?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“反交尾势力……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「反交尾勢力……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00279",
		linknext = "0011_00281",
		line = 4015,
	},
	["0011_00281"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Somos una sociedad secreta que ayuda a las personas que valoran el amor puro. Llevaremos ante la justicia a aquellos que propagan la perversión.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们是一个认为纯爱最为尊贵，并对嚣张跋扈的变态做爱做出制裁的互助秘密结社——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們是一個認為純愛最為尊貴，並對囂張跋扈的變態做愛做出制裁的互助秘密結社——」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00280",
		linknext = "0011_00282",
		line = 4027,
	},
	["0011_00282"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0154", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00281",
		linknext = "0011_00283",
		line = 4039,
	},
	["0011_00283"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Umm, básicamente...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃，也就是说……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃，也就是說……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00282",
		linknext = "0011_00284",
		line = 4051,
	},
	["0011_00284"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0347", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Básicamente, somos un grupo de personas que se niega a acatar la ley súperpervertida de la isla y siempre estamos buscando nuevos aliados.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“也就是说，类似于将那些不喜欢因为岛上的变态条例而强制做爱的人们，聚集在一起互相帮助的社团活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「也就是說，類似於將那些不喜歡因為島上的變態條例而強制做愛的人們，聚集在一起互相幫助的社團活動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00283",
		linknext = "0011_00285",
		line = 4064,
	},
	["0011_00285"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0155", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ahh, ya veo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，原来如此——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，原來如此——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00284",
		linknext = "0011_00286",
		line = 4079,
	},
	["0011_00286"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0348", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lo siento, es que él no sabe explicar bien las cosas. Es que... está luchando contra su virginidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“抱歉哦，让你这么难理解。这个人……是个不好的处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「抱歉哦，讓你這麼難理解。這個人……是個不好的處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00285",
		linknext = "0011_00287",
		line = 4093,
	},
	["0011_00287"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Qué ruidosa eres, zorra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“吵死了婊子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「吵死了婊子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00286",
		linknext = "0011_00288",
		line = 4105,
	},
	["0011_00288"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00103", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0349", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Cállate, idiota.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨蛋闭嘴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨蛋閉嘴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00287",
		linknext = "0011_00289",
		line = 4119,
	},
	["0011_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me aclaro la garganta y prosigo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我清了下喉咙，摆正姿势。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我清了下喉嚨，擺正姿勢。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00288",
		linknext = "0011_00290",
		line = 4129,
	},
	["0011_00290"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me llamo Tachibana Junnosuke, estoy en segundo año y soy el líder de nuestra sociedad secreta, el NLNS. Soy virgen y estoy orgulloso de ello.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的名字是橘淳之介，2年级生。我是这个秘密结社‘NLNS’的领导者。是一位高傲的处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的名字是橘淳之介，2年級生。我是這個秘密結社『NLNS』的領導者。是一位高傲的處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00289",
		linknext = "0011_00291",
		line = 4140,
	},
	["0011_00291"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0156", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, es un placer... esto, orgulloso virgen Tachibana-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，请多指教……呃，处男、橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，請多指教……呃，處男、橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00290",
		linknext = "0011_00292",
		line = 4154,
	},
	["0011_00292"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Podemos dejar de insistir en ese punto, por favor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别只挑这个说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別只挑這個說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00291",
		linknext = "0011_00293",
		line = 4166,
	},
	["0011_00293"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00114", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0350", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lo siento, es que a veces se pone muy fastidioso con eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“很抱歉，他是一个非常麻烦的男人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「很抱歉，他是一個非常麻煩的男人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00292",
		linknext = "0011_00294",
		line = 4180,
	},
	["0011_00294"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y la que anda de perezosa es mi hermana menor, Tachibana Asane. Está en primer año. Vamos, Asa-chan, saluda.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后，在那里躺在沙发上的……是我的妹妹橘麻沙音，1年级生——喂，麻沙酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後，在那裡躺在沙發上的……是我的妹妹橘麻沙音，1年級生——喂，麻沙醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00293",
		linknext = "0011_00295",
		line = 4192,
	},
	["0011_00295"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0371", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“La verdad es que no me gustan las chicas tan femeninas y coquetas... Si no es mayor y gyaru, no me interesa...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……我对可爱的女孩不是很感兴趣……除了大姐姐和辣妹以外都不要谢谢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……我對可愛的女孩不是很感興趣……除了大姐姐和辣妹以外都no 3Q……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00294",
		linknext = "0011_00296",
		line = 4205,
	},
	["0011_00296"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0157", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooooh, ¿en serio? Bueno, me parece genial que demuestres lo que te gusta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦哦——这样啊……？啊，你喜欢跟不喜欢区分的很清楚呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦哦——這樣啊……？啊，你喜歡跟不喜歡區分的很清楚呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00295",
		linknext = "0011_00297",
		line = 4220,
	},
	["0011_00297"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0351", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Te pido disculpas, de verdad... Estos hermanos tienen un caso terminal del virus de la estupidez... Solo empeoran las cosas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“真的很抱歉……这对兄妹有些坏毛病……原因有些复杂。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「真的很抱歉……這對兄妹有些壞毛病……原因有些複雜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00296",
		linknext = "0011_00298",
		line = 4234,
	},
	["0011_00298"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0352", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“En fin, me llamo Katagiri Nanase, estoy en segundo año... Si asistes a la Academia Minotsuki, ya habrás oído de mí. Soy algo infame.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那么，我是片桐奈奈濑。2年级生——啊，如果你在水乃月上学的话应该知道我吧，知道一些不好的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那麼，我是片桐奈奈瀨。2年級生——啊，如果你在水乃月上學的話應該知道我吧，知道一些不好的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00297",
		linknext = "0011_00299",
		line = 4250,
	},
	["0011_00299"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00111", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0158", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, sí, he oído... algunas cosas. Eres como una celebridad, \n¿cierto, Nanase-chan...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯、嗯……只知道一点点……但是是非常有名的、奈奈濑酱……对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯、嗯……只知道一點點……但是是非常有名的、奈奈瀨醬……對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00298",
		linknext = "0011_00300",
		line = 4265,
	},
	["0011_00300"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La respuesta de la chica es un poco temerosa, pero Nanase está acostumbrada a esto y se encoge de hombros.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑耸耸肩，好像已经习惯了女孩奇怪又惊讶的反应。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨聳聳肩，好像已經習慣了女孩奇怪又驚訝的反應。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00299",
		linknext = "0011_00301",
		line = 4278,
	},
	["0011_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su apariencia externa no parece intimidante para los niños.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟她长得也不怎么被小孩喜欢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟她長得也不怎麼被小孩喜歡。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00300",
		linknext = "0011_00302",
		line = 4288,
	},
	["0011_00302"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0353", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Umm... ¿cómo te llamas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……然后，你叫什么名字？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……然後，你叫什麼名字？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00301",
		linknext = "0011_00303",
		line = 4302,
	},
	["0011_00303"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0159", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, me llamo Watarai Hinami. Es un placer.”",
