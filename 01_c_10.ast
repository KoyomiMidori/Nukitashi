					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我可以理解你们的心情，但我认为这不好！我不能与做坏事的人合作！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我可以理解你們的心情，但我認為這不好！我不能與做壞事的人合作！」",
					{"rt2"},
				},
