	["0011_00225"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como lo único que podemos hacer es incapacitarlos, en el momento en que nos veamos atrapados en este tipo de batalla, perderemos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以本来，在没有拥有无力化以上的攻击力的我们进入这种战斗状态下时，就已经",
					{"ruby", text="・・"},
					"输了",
					{"/ruby"},
					"。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以本來，在沒有擁有無力化以上的攻擊力的我們進入這種戰鬥狀態下時，就已經",
					{"ruby", text="・・"},
					"輸了",
					{"/ruby"},
					"。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00224",
		linknext = "0011_00226",
		line = 3088,
	},
	["0011_00226"] = {
		{"text"},
		text = {
