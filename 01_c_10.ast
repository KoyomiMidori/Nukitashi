					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Está bien, hablaré con ella... ¿Oye, Hinami-chan? Piénsalo un poco, ¿sí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好好好，真没办法……我说雏见酱，你可以好好考虑一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好好好，真沒辦法……我說雛見醬，你可以好好考慮一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00371",
		linknext = "0011_00373",
		line = 5193,
	},
	["0011_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así habla la zorra con el extraño lunar en forma de lágrima, actuando como si estuviera consolando a una niña.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有泪痣的辣妹婊用温和的语气说道，就像在安慰小孩子一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有淚痣的辣妹婊用溫和的語氣說道，就像在安慰小孩子一樣。",
					{"rt2"},
				},
			},
		},
