	["0011_00325"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00109", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0165", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿P-Pero, pero, y los estudiantes? Saben que soy su compañera.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但、但是但是，学校里的人呢？他们知道我是同学啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但、但是但是，學校裡的人呢？他們知道我是同學啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00324",
		linknext = "0011_00326",
		line = 4597,
	},
	["0011_00326"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0355", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Um... Creo saber por qué.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊……也许我知道是为什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊……也許我知道是為什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00325",
		linknext = "0011_00327",
		line = 4611,
	},
	["0011_00327"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cómo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00326",
		linknext = "0011_00328",
		line = 4623,
	},
	["0011_00328"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0356", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“A los habitantes de esta isla se les inculca desde pequeños que no pueden tocar a las lolis. Tocarlas es un delito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这个岛上的人们从小就被告知，‘绝对不可以对萝莉下手。出手了会被判重罪’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這個島上的人們從小就被告知，『絕對不可以對蘿莉下手。出手了會被判重罪』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00327",
		linknext = "0011_00329",
		line = 4635,
	},
	["0011_00329"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por supuesto, como Nanase también es una estudiante de transferencia, solo es una corazonada suya.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“我也是转校生，所以这是我的猜想”奈奈濑说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「我也是轉學生，所以這是我的猜想」奈奈瀨說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00328",
		linknext = "0011_00330",
		line = 4645,
	},
	["0011_00330"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0357", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Aunque supieran que eres mayor de edad, si alguien intentara ligar contigo, los demás podrían pensar que es un lolicon y que probablemente agredería a una loli de verdad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以，即使知道雏见酱是条例对象年龄，但如果做爱了，大家可能会觉得‘这家伙是萝莉控，所以有可能会对真的萝莉下手’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以，即使知道雛見醬是條例對象年齡，但如果做愛了，大家可能會覺得『這傢伙是蘿莉控，所以有可能會對真的蘿莉下手』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00329",
		linknext = "0011_00331",
		line = 4659,
	},
	["0011_00331"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
