				},
			},
			en = {
				{
					"Las partículas se dispersan instantáneamente en el aire creando una fina capa de 2 metros de diámetro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"喷射出的颗粒会立即扩散到空中，形成直径约2米的薄膜。",
