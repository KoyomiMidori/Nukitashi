	["0011_00093"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fue una interferencia. Interrumpimos sus comunicaciones. No queremos que pidan refuerzos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是干扰。我干们扰了对方的通讯手段。如果他们呼叫增援就不好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是干擾。我們干擾了對方的通訊手段。如果他們呼叫增援就不好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00092",
		linknext = "0011_00094",
		line = 1332,
	},
	["0011_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además, nuestra posición se transmite constantemente desde nuestras tablets. La OSS tiene localizada nuestra ubicación dondequiera que vayamos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且平板总是发送着我们的位置信息。所以所在地一直都被SHO掌握着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且平板總是發送著我們的位置資訊。所以所在地一直都被SHO掌握著。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00093",
		linknext = "0011_00095",
		line = 1343,
	},
	["0011_00095"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0333", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pero si las apagamos, aunque logremos escapar, perder nuestros datos de ubicación despertaría sospechas por su parte, así que eso no nos servirá...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但如果关闭电源，就算逃脱了，那段没有位置信息的时间也会遭到怀疑，所以不能这样做……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但如果關閉電源，就算逃脫了，那段沒有位置資訊的時間也會遭到懷疑，所以不能這樣做……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00094",
		linknext = "0011_00096",
		line = 1357,
	},
	["0011_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
