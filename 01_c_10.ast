	["0011_00405"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0188", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
