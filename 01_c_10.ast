			tw = {
				{
					name = {"麻沙音"},
					"「體位是站立後入的2穴插入和舔肛門。推測在舔肛門的女人的陰道正插入一個超粗按摩棒。濕潤度都是『一塌糊塗",
					{"gaiji", text="①"},
					"』狀態。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00121",
		linknext = "0011_00123",
		line = 1686,
	},
	["0011_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En pocas palabras, ¿solo hay una mujer? Qué peligro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这意味着女的多出了一位——这很危险。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這意味著女的多出了一個——這很危險。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00122",
		linknext = "0011_00124",
		line = 1698,
	},
	["0011_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No podemos seguir, Nanase. ¡Volvamos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑，不能往前走。绕道吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨，不能往前走。繞道吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00123",
		linknext = "0011_00125",
		line = 1709,
	},
	["0011_00125"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0334", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Entendido. Si nuestro camino se reduce aún más, tendremos problemas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好的，不过路再变窄的话，可能就不好办了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好的，不過路再變窄的話，可能就不好辦了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00124",
		linknext = "0011_00126",
		line = 1723,
	},
	["0011_00126"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Damos vuelta en una T.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们在丁字路口左转。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們在T字路口左轉。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00125",
		linknext = "0011_00127",
		line = 1735,
	},
	["0011_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El camino es más estrecho que antes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"进到了比刚刚更窄的后巷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"進到了比剛剛更窄的後巷。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00126",
		linknext = "0011_00128",
		line = 1745,
	},
	["0011_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apenas tiene el ancho suficiente para pasar al lado de otra persona.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是几乎无法让两个人擦肩而过的狭窄道路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是幾乎無法讓兩個人擦肩而過的狹窄道路。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00127",
		linknext = "0011_00129",
		line = 1755,
	},
	["0011_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Será difícil volver a casa si usamos esta ruta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这条路线可能回不去我家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這條路線可能回不去我家。」",
					{"rt2"},
				},
