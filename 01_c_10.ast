	["0011_00227"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"bg", id=1, file="bg22_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0094", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマンG"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS G"},
					"“¡Última advertencia! ¡Dejen sus armas sin oponer resistencia, pongan las manos detrás de la cabeza y muestren su erección!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫G"},
					"“这是最后一次！丢下武器放弃抵抗，将双手放在头后面，然后勃起鸡巴！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛G"},
					"「這是最後一次！丟下武器放棄抵抗，將雙手放在頭後面，然後勃起肉棒！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00226",
		linknext = "0011_00228",
		line = 3114,
	},
	["0011_00228"] = {
		{"se", id=0, loop=0, file="se_a023"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
