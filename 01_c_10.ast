					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por eso, cuando necesitamos escapar, simplemente jugamos con sus frecuencias de radio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我们总是这样用电子干扰来逃脱。”",
