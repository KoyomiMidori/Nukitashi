	["0011_00142"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0088", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマンC"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS C"},
					"“Si solo experimentaran los placeres del sexo pervertido, no pensarían en hacer algo tan sucio... ",
					{"gaiji", text="①"},
					" Ríndanse y saquen sus pollas y vaginas... ",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫C"},
					"“如果做爱做舒服了，那些糟糕的想法就不会浮现在脑海中了吧……",
					{"gaiji", text="①"},
					"来吧，乖乖把鸡巴和小穴露出来吧……",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛C"},
					"「如果做愛做舒服了，那些糟糕的想法就不會浮現在腦海中了吧……",
					{"gaiji", text="①"},
					"來吧，乖乖把肉棒和小穴露出來吧……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00141",
		linknext = "0011_00143",
		line = 1934,
	},
