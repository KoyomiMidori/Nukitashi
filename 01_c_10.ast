					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS C"},
					"“Está bien, Kouki-chan. Santo cielo... ¿Cómo pueden hacernos esto?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫C"},
					"“算了算了，光姬。真是的，你们……为什么要做那种事呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛C"},
					"「算了算了，光姬。真是的，你們……為什麼要做那種事呢……？」",
					{"rt2"},
