		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_012_00000"},
		{"bgm", file="bgm14", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“ATM-03, aquí Null Base. ¿Pueden escucharme?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“ATM-03。这里Null基地，听得到吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「ATM-03。這裡Null基地，聽得到嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00044",
		linknext = "0052_00046",
		line = 680,
	},
	["0052_00046"] = {
		{"fg", file="hinami_01f_00002", file3="hinami_01f_00302", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0684", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Fuerte y— ¡Uh, aquí ATM-03! ¡Te escucho fuerte y claro, beaver!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没问题——啊……这里是ATM-03！能听到哦。beaver！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒問題——啊……這裡是ATM-03！能聽到哦。beaver！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00045",
		linknext = "0052_00047",
		line = 693,
	},
	["0052_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Encontraste algún roedor en el camino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那里有有啮齿类动物吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那裡有有囓齒類動物嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00046",
		linknext = "0052_00048",
		line = 705,
	},
	["0052_00048"] = {
		{"fg", file="hinami_01f_00002", file1="hinami_01f_00112", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0685", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“O sea, ¿animales? Pues no...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“动物……？没有哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「動物……？沒有哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00047",
		linknext = "0052_00049",
		line = 718,
	},
	["0052_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya veo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00048",
		linknext = "0052_00050",
		line = 730,
	},
	["0052_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que necesita repasar un poco los términos críticos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是弄错了通讯用语吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是弄錯了通訊用語吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00049",
		linknext = "0052_00051",
		line = 740,
	},
	["0052_00051"] = {
		{"fg", file="hinami_01f_00002", file1="hinami_01f_00112", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0686", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, traje mi silla conmigo, es que ya es costumbre. ¿Está bien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……我把习惯的椅子带来了。没问题吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……我把習慣的椅子帶來了。沒問題吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00050",
		linknext = "0052_00052",
		line = 753,
	},
	["0052_00052"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, no debería haber ningún problema. Técnicamente es tu equipo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该可以把它当成备品。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該可以把它當成備品。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00051",
		linknext = "0052_00053",
		line = 765,
	},
	["0052_00053"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin, veo que ya entraste al edificio B. Por favor, empieza a buscar información sobre Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之，潜入B等部成功了，请你立刻就‘文乃’进行调查。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之，潛入B等部成功了，請你立刻就『文乃』進行調查。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00052",
		linknext = "0052_00054",
		line = 777,
	},
	["0052_00054"] = {
		{"fg", file="hinami_02f_00002", file1="hinami_02f_00101", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0687", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Vale! Veamos... Ah, disculpa, ¿tienes un momento? Estoy buscando a alguien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“明白——！那个……啊，可以打扰一下吗？我在找人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「明白——！那個……啊，可以打擾一下嗎？我在找人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00053",
		linknext = "0052_00055",
		line = 790,
	},
	["0052_00055"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0201", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "引きこもりっぽい女の子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Chica introvertida"},
					"“¿Mm? ¿Eh...? ¿Una niña? ¿Qué hace una niña aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "像家里蹲的女孩子"},
					"“嗯？咦……小孩子？为什么小孩会在这种地方……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "像家裡蹲的女孩子"},
					"「嗯？咦……小孩子？為什麼小孩會在這種地方……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00054",
		linknext = "0052_00056",
		line = 802,
	},
	["0052_00056"] = {
		{"fg", file="hinami_01f_00002", file1="hinami_01f_00118", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0688", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡No soy una niña!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是小孩子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是小孩子！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00055",
		linknext = "0052_00057",
		line = 815,
	},
	["0052_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00056",
		linknext = "0052_00058",
		line = 827,
	},
	["0052_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La están tratando como una niña. En el edificio B.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在B等部也被当做孩子来对待。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在B等部也被當做孩子來對待。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00057",
		linknext = "0052_00059",
		line = 837,
	},
	["0052_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya veo... Wata-chan, te toca peor que a mí...",
					{"rt2"},
				},
			},
			cn = {
				{
					"是吗……渡酱，居然到了这种程度——",
					{"rt2"},
				},
			},
			tw = {
				{
					"是嗎……渡醬，居然到了這種程度——",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00058",
		linknext = "0052_00060",
		line = 847,
	},
	["0052_00060"] = {
		{"fg", file="hinami_02f_00002", file1="hinami_02f_00102", file2="hinami_02f_00202", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0689", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Um, estoy buscando a una chica llamada Fumino. ¿Te suena ese nombre?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃……我在找一个叫文乃的孩子，你有没有听说过？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃……我在找一個叫文乃的孩子，你有沒有聽說過？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00059",
		linknext = "0052_00061",
		line = 860,
	},
	["0052_00061"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0202", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "引きこもりっぽい女の子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Chica introvertida"},
					"“¿Fumino? Jamás he oído ese nombre... ¿Es tu hermana mayor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "像家里蹲的女孩子"},
					"“文乃……？不知道啊……姐姐的名字？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "像家裡蹲的女孩子"},
					"「文乃……？不知道啊……姐姐的名字？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00060",
		linknext = "0052_00062",
		line = 872,
	},
	["0052_00062"] = {
		{"fg", file="hinami_02f_00002", file1="hinami_02f_00118", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0690", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡No es mi hermana mayor! ¡Soy mayor que ella!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不是姐姐啦，我年纪更大啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不是姐姐啦，我年紀更大啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00061",
		linknext = "0052_00063",
		line = 885,
	},
	["0052_00063"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0203", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "引きこもりっぽい女の子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Chica introvertida"},
					"“¿Te perdiste aquí con tu hermanita? ¿Qué hago ahora? Debería llamar a la policía, ¿no? ¡Hanamaru-chan!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "像家里蹲的女孩子"},
					"“和妹妹一起迷路了吗……怎么办啊，要叫FS的人吗……？花丸酱～……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "像家裡蹲的女孩子"},
					"「和妹妹一起迷路了嗎……怎麼辦啊，要叫FS的人嗎……？花丸醬～……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00062",
		linknext = "0052_00064",
		line = 897,
	},
	["0052_00064"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0691", path=":vo/", ch="hinami"},
			},
			ja = {
				{
