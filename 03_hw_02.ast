	["0052_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The usually incredibly strict Rei is getting flustered at Wata's compliments.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个正经的风纪委员长，居然被小小的渡酱称赞得羞答答地皱起眉头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個正經的風紀委員長，居然被小小的渡醬稱讚得羞答答地皺起眉頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00189",
		linknext = "0052_00191",
		line = 2623,
	},
	["0052_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you two know each other?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱前辈和风纪委员长认识吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬前輩和風紀委員長認識嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00190",
		linknext = "0052_00192",
		line = 2634,
	},
	["0052_00192"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
