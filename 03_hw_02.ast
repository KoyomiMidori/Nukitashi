			},
			[2800] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0722", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yup! U-Uh, yes, but of course. Incidentally, I refrained from discussing this in front of the others, but... do I come off as more adult right now to you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……啊，对了对了，话说橘君……虽然在大家面前没能问出口……现在的我，真的像大人……吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……啊，對了對了，話說橘君……雖然在大家面前沒能問出口……現在的我，真的像大人……嗎？」",
					{"rt2"},
				},
			},
		},
