	},
	["0052_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not totally implausible that they'd know each other, since they're in the same grade, but how the heck did these two end up getting along so swimmingly...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"除了年级相同之外完全找不到她们之间的共通点，究竟是有什么样的契机才能让这两个人成为好朋友呢……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"除了年級相同之外完全找不到她們之間的共通點，究竟是有什麼樣的契機才能讓這兩個人成為好朋友呢……？",
					{"rt2"},
				},
			},
		},
