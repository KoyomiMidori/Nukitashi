		linkback = "0052_00066",
		linknext = "0052_00068",
		line = 949,
	},
	["0052_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Si empiezan a hacerte muchas preguntas, nos meteremos en muchos problemas! ¡Vuelve a la base!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被问话可能会很麻烦……不好意思，拜托了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被問話可能會很麻煩……不好意思，拜託了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00067",
		linknext = "0052_00069",
		line = 961,
	},
	["0052_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que apenas comenzó nuestra investigación, pero no voy a meterla en un lío que se puede evitar fácilmente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是刚开始的调查，但是考虑到渡酱的安全也不能勉强她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是剛開始的調查，但是考慮到渡醬的安全也不能勉強她。",
					{"rt2"},
				},
			},
		},
