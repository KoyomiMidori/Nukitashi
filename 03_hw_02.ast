		{"fg", file="hinami_01l_00002", file1="hinami_01l_00116", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me aclaro la garganta y me agacho frente a Wata-chan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我清了清嗓子，蹲到渡酱面前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我清了清嗓子，蹲到渡醬麵前。",
					{"rt2"},
