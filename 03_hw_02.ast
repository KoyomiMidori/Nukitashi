			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pues... Sí, tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“说得……也是……应该吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「說得……也是……應該吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00027",
		linknext = "0052_00029",
		line = 402,
	},
	["0052_00029"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además, Asa-chan es una antisocial que se la pasa en internet, así que no nos sirve. Y Nanase es una zorra presumida, solo va a alterar a los buscadores de sexo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱是交流障碍所以无法执行询问调查之类的任务，奈奈濑是臭婊子所以马上就会让性触者的男孩子们发情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬是交流障礙所以無法執行詢問調查之類的任務，奈奈瀨是臭婊子所以馬上就會讓性觸者的男孩子們發情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00028",
		linknext = "0052_00030",
		line = 414,
	},
	["0052_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En pocas palabras, este es un trabajo que solo tú puedes hacer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——总之，能依靠的只有渡酱。”",
					{"rt2"},
				},
			},
			tw = {
