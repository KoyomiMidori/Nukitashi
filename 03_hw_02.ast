			},
		},
		text = {
			vo = {
				{"vo", file="hinami0680", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Solo yo...! Y-Ya veo, pensé que tú también te estabas burlando de mí... Lo que quieres decir es que nada va a funcionar sin mí, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“只有我……！这、这样啊……我以为连橘君都当我是小孩子了……也就是说，没有我不行吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「只有我……！這、這樣啊……我以為連橘君都當我是小孩子了……也就是說，沒有我不行嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00030",
		linknext = "0052_00032",
		line = 442,
	},
