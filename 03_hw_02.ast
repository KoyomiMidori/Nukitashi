					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? No, I'm going straight home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦？没有哦，我想直接回家哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦？沒有哦，我想直接回家哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00201",
		linknext = "0052_00203",
		line = 2775,
	},
	["0052_00203"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00202",
		linknext = "0052_00204",
		line = 2787,
	},
	["0052_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Man, and here we were managing to put on such a good front. This could almost certainly be cause for suspicion...",
					{"rt2"},
				},
			},
			cn = {
				{
					"好不容易才骗了过去，这样她又要露出怀疑的眼神——",
					{"rt2"},
				},
			},
			tw = {
				{
					"好不容易才騙了過去，這樣她又要露出懷疑的眼神——",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00203",
		linknext = "0052_00205",
		line = 2797,
	},
	["0052_00205"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0149", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I see. Make sure you get home before dark, then. Watch out for cars and strangers as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是吗……那就在太阳下山之前回去吧。小心车和奇怪的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是嗎……那就在太陽下山之前回去吧。小心車和奇怪的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00204",
		linknext = "0052_00206",
		line = 2811,
	},
	["0052_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Uh, or maybe not?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——咦？",
					{"rt2"},
				},
			},
			tw = {
				{
					"——咦？",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00205",
		linknext = "0052_00207",
		line = 2821,
	},
	["0052_00207"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[8000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0719", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Gosh, you're always a worrywart. I'm a third-year now, I'll be fine! Right, everyone, let's get going... Uh, what's up, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你太担心了啦。我都已经3年级了，没关系的。那么，大家回家吧……橘君，怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你太擔心了啦。我都已經3年級了，沒關係的。那麼，大家回家吧……橘君，怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00206",
		linknext = "0052_00208",
		line = 2837,
	},
	["0052_00208"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, uh... Nothing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，没有……没什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，沒有……沒什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00207",
		linknext = "0052_00209",
		line = 2849,
	},
	["0052_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks like less of a classmate and more of an older sister.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的风纪委员长居然还会偏袒某人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的風紀委員長居然還會偏袒某人。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00208",
		linknext = "0052_00210",
		line = 2859,
	},
	["0052_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's completely separate from her usual stern self... even her tone's significantly softened.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是平时明明会撅起嘴来——现在反倒觉得语气比平时还要柔和。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是平時明明會撅起嘴來——現在反倒覺得語氣比平時還要柔和。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00209",
		linknext = "0052_00211",
		line = 2869,
	},
	["0052_00211"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
