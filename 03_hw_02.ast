					"“So it seems. Well, that is understandable. Still, while participation in Nutsgiving is not compulsory... you are, of course, endeavoring to have sex properly, yes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是这样啊……那也没办法。但是，就算不是强制的，居然不参加‘大感泄精祭’——有好好在做爱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是這樣啊……那也沒辦法。但是，就算不是強制的，居然不參加『大感洩精祭』——有好好在做愛嗎？」",
					{"rt2"},
