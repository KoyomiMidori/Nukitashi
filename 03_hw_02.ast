				{"vo", file="hinami0716", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see, I see. Ever the hard worker, I see. Good girl!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是这样啊。今天也很努力呢，很棒很棒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是這樣啊。今天也很努力呢，很棒很棒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00185",
		linknext = "0052_00187",
		line = 2577,
	},
	["0052_00187"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00119", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
