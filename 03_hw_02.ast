				},
			},
		},
		linkback = "0052_00020",
		linknext = "0052_00022",
		line = 310,
	},
	["0052_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Chicas, ya dejen de molestarla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你们俩别这么玩弄渡酱了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你們倆別這麼玩弄渡醬了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00021",
		linknext = "0052_00023",
		line = 322,
	},
	["0052_00023"] = {
		{"se", id=0, loop=0, file="se_a156"},
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=-200},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=0, y=200, time=1500},
		{"fgact", ch="ヒナミ", id=5, act="浮遊横", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0677", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Solo soy un juguete para ustedes? ¡Habrase visto! ¡Si solo van a burlarse de mí, me iré a mi casita!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是玩乐的道具！真是的……大家都这么小看我的话我就不帮忙了哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是玩樂的道具！真是的……大家都這麼小看我的話我就不幫忙了哦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00022",
		linknext = "0052_00024",
		line = 339,
	},
	["0052_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tranquila. Mira, entiendo cómo te sientes al ser tratada como una niña.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别这样……被当成小孩所以生气的心情我可以理解……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別這樣……被當成小孩所以生氣的心情我可以理解……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00023",
		linknext = "0052_00025",
		line = 351,
	},
	["0052_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero como eres nuestra senpai, eres la única persona a la que le podemos pedir esto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但这是只能拜托作为前辈的渡酱的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但這是只能拜託作為前輩的渡醬的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00024",
		linknext = "0052_00026",
		line = 363,
	},
	["0052_00026"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
