			},
		},
		text = {
			vo = {
				{"vo", file="hinami0720", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well, see ya, Rei! Uh, I mean... salutations and good day to you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“再见了，礼酱！啊……嗯……贵安！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「再見了，禮醬！啊……嗯……貴安！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00210",
		linknext = "0052_00212",
		line = 2885,
	},
	["0052_00212"] = {
