		linknext = "0052_00066",
		line = 924,
	},
	["0052_00066"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo sé... ¡Wata-chan, vete! ¡Lo siento, pero necesito que retrocedas de inmediato!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……渡酱——不好意思，暂时撤退！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……渡醬——不好意思，暫時撤退！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00065",
		linknext = "0052_00067",
		line = 936,
	},
	["0052_00067"] = {
		{"fg", file="hinami_02f_00002", file1="hinami_02f_00106", file2="hinami_02f_00202", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
