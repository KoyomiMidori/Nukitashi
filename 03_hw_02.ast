			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“M-Maybe gussy up your speech like that a little more, it might make you sound more grown-up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“要是再加上敬语的话，不就更像大人了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「要是再加上敬語的話，不就更像大人了嗎？」",
					{"rt2"},
				},
			},
		},
