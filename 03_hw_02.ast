				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Um... R-Right, salutations to you too...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……？啊，啊啊……贵安……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
