			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿GYAAHH?! M-Misaki-chan... ¡Me asustaste! ¿Cuándo llegaste?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哎呀——！？美岬酱……吓我一跳。从什么时候开始在的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哎呀——！？美岬醬……嚇我一跳。從什麼時候開始在的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00032",
		linknext = "0052_00034",
		line = 490,
	},
	["0052_00034"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0370", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Desde siempre... ¿Eh? ¿Y este déjà vu? ¡¿Estamos en un bucle temporal...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“从一开始……咦，既视感……？难道时间在循环……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「從一開始……咦，既視感……？難道時間在循環……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00033",
		linknext = "0052_00035",
		line = 506,
	},
	["0052_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hotori... No tienes que ocultar tu presencia en la base. Sinceramente, me resulta un poco extraño.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔……在基地的时候不用把气息消去……老实说我也吓了一跳。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔……在基地的時候不用把氣息消去……老實說我也嚇了一跳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00034",
		linknext = "0052_00036",
		line = 518,
	},
	["0052_00036"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0371", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“N-No lo hago a propósito...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，我什么也没干……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，我什麼也沒幹……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00035",
		linknext = "0052_00037",
		line = 532,
	},
	["0052_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, intenta hacerte notar un poco más. Ponte a cantar o bailar, no sé.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那你来点存在感，唱歌跳舞什么的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那你來點存在感，唱歌跳舞什麼的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00036",
		linknext = "0052_00038",
		line = 543,
	},
	["0052_00038"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0372", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Pero no les daría miedo que me pusiera a cantar una canción?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“如果突然做出音乐剧一样事不会吓到你们吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「如果突然做出音樂劇一樣事不會嚇到你們嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00037",
		linknext = "0052_00039",
		line = 557,
	},
	["0052_00039"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por supuesto que no. Aquí todos somos amigos. No te preocupes por eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么会。我们是同伴，不用在意这些。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼會。我們是同伴，不用在意這些。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00038",
		linknext = "0052_00040",
		line = 569,
	},
	["0052_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, como decía... Por la falta de presencia de Hotori, también es un lastre a la hora de recabar información.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不过，畔也因为没有什么存在感，所以不适合去探听。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不過，畔也因為沒有什麼存在感，所以不適合去探聽。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00039",
		linknext = "0052_00041",
		line = 581,
	},
	["0052_00041"] = {
