		linkback = "0052_00071",
		linknext = "0052_00073",
		line = 1046,
	},
	["0052_00073"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0694", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Estoy en tercer año en los grados A... Y esa chica con la que estaba hablando estaba en primer año en los grados B... Así que está en uno, dos, tres... ¡CINCO años más abajo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我可是A等部3年级生哦……？刚才和我说话的那个人是B等部的1年级生呢……一、二、三……是比我小5岁的孩子啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我可是A等部3年級生哦……？剛才和我說話的那個人是B等部的1年級生呢……一、二、三……是比我小5歲的孩子啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00072",
		linknext = "0052_00074",
		line = 1058,
	},
	["0052_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estamos hablando de una diferencia de seis años si nos basamos únicamente en las calificaciones...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就学年来说，有时候会小6岁……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就學年來說，有時候會小6歲……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00073",
		linknext = "0052_00075",
		line = 1069,
	},
	["0052_00075"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00116", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0695", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿En serio pensó que era seis años menor que ella?!¡¿Todo lo que he crecido en los últimos seis años ha sido en vano?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我看起来比实际还要小6岁吗……！？我这6年的生活都毫无意义吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我看起來比實際還要小6歲嗎……！？我這6年的生活都毫無意義嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00074",
		linknext = "0052_00076",
		line = 1083,
	},
	["0052_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
