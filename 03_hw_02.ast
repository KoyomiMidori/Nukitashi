		linkback = "0052_00287",
		linknext = "0052_00289",
		line = 3932,
	},
	["0052_00289"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00116", file4="asane_02m_00401", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1013", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Never mind. Just leave me alone, 'kay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没什么……别管我啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒什麼……別管我啦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00288",
		linknext = "0052_00290",
		line = 3946,
	},
	["0052_00290"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Okay.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我知道了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我知道了。」",
					{"rt2"},
