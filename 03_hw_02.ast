	["0052_00087"] = {
		{"bgm", stop=1},
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00106", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0698", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun... Solo me llamas así porque crees que eso me animará y todo volverá a estar bien, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君……？你一定想着，反正像往常一样把前辈举起来，前辈就会打起精神来吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君……？你一定想著，反正像往常一樣把前輩舉起來，前輩就會打起精神來吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00086",
		linknext = "0052_00088",
		line = 1260,
	},
	["0052_00088"] = {
