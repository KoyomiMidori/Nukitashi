	["0052_00123"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00114", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="hinami_02m_00002", file1="hinami_02m_00116", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0709", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see you stifling your laughter, you jerk! Urrrgh... Why do I always have to be the laughingstock around here!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样说的橘君，你的肩膀也在颤抖哦！？呜呜呜……什么呀，大家都把我当笑话……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣說的橘君，你的肩膀也在顫抖哦！？嗚嗚嗚……什麼呀，大家都把我當笑話……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00122",
		linknext = "0052_00124",
		line = 1748,
	},
	["0052_00124"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1836", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“N-No, no, no... It's just that your acting was good enough to make everyone laugh. I mean, haven't you ever been so bowled over by something that you had to laugh before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不、不对……是因为渡酱的演技太厉害而笑了。看到太厉害的东西，就会忍不住笑出来不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不、不對……是因為渡醬的演技太厲害而笑了。看到太厲害的東西，就會忍不住笑出來不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00123",
		linknext = "0052_00125",
		line = 1763,
	},
	["0052_00125"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
