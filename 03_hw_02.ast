					name = {"礼", "Rei"},
					"“Hinami? So you stayed behind at school too...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见……？雏见也留下来了吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見……？雛見也留下來了嗎……」",
					{"rt2"},
				},
			},
