			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Esta chica es tan tierna... ¡Me dan ganas de llevarmela a casa...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这孩子怎么这么可爱……好想收养她……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這孩子怎麼這麼可愛……好想收養她……」",
