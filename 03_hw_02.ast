				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry about that... It hasn't been very long since I transferred here, so I'm still getting used to everything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思……刚转校时还不太习惯，被警告了不少次……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思……剛轉校時還不太習慣，被警告了不少次……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00151",
		linknext = "0052_00153",
		line = 2148,
	},
	["0052_00153"] = {
		{"text"},
		text = {
