				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We all walk through the gate, leaving a slightly nonplussed Rei behind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"告别了歪着头的风纪委员长，我们离开了学校。",
