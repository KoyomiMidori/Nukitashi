			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡¿Eh?! Lo sie— uh, digo, ¡a-aún puedes ayudarnos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶诶！？真不好意思……不、不对，就算是这样，渡酱……渡酱应该还是会回应我的期待的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸欸！？真不好意思……不、不對，就算是這樣，渡醬……渡醬應該還是會回應我的期待的……！」",
					{"rt2"},
				},
			},
		},
