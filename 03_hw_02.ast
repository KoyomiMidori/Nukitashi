					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo... Por proceso de eliminación, soy la única que puede hacer esto, ¿verdad...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“原来如此啊……那么，看来只有我了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「原來如此啊……那麼，看來只有我了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00040",
		linknext = "0052_00042",
		line = 595,
	},
	["0052_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. ¡Así que me gustaría pedirte que te encargaras de esto por nosotros! ¿Puedes hacerlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……正因为如此，才想拜托渡酱前辈！可以拜托你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……正因為如此，才想拜託渡醬前輩！可以拜託你嗎？」",
