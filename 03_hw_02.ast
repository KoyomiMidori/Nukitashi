					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pues eso sí puedo hacerlo... ¡Oye, ¿por qué te pones de puntillas? ¡No es justo! ¡No puedo alcanzarte!”",
					{"rt2"},
