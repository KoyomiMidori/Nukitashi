	["0052_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan se ve bastante molesta hoy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱今天也一样膨胀着双颊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬今天也一樣膨脹著雙頰。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00002",
		linknext = "0052_00004",
		line = 42,
	},
	["0052_00004"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00119", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1830", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Por qué Wata-chan se ve tan casual hoy? ¿Será que quiere animarnos con su belleza? ¡Ay, parece una niñita perdida y se ve lindísima!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……为什么渡酱是穿便服呢？新的服务？好像迷路走进学校的小朋友一样可爱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……為什麼渡醬是穿便服呢？新的服務？好像迷路走進學校的小朋友一樣可愛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00003",
		linknext = "0052_00005",
		line = 57,
	},
	["0052_00005"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1700] = {
				{"fg", file="hinami_02m_00002", file1="hinami_02m_00114", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=1700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0672", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero no soy una niña perdida! ¡Y puedes darle las gracias por decirme que me vistiera así!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是迷路的孩子！是橘君叫我拿便服来的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是迷路的孩子！是橘君叫我拿便服來的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00004",
		linknext = "0052_00006",
		line = 74,
	},
	["0052_00006"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0997", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Manito... Veo, veo... Los vírgenes que se adentran demasiado en la madriguera del conejo se vuelven bien lolicones, ¿eh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥……原来如此，扭曲的处男，终于扭曲成了萝莉控吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥……原來如此，扭曲的處男，終於扭曲成了蘿莉控嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00005",
		linknext = "0052_00007",
		line = 87,
	},
	["0052_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No lo creo. Te informo que todo esto forma parte de mi plan maestro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“绝对不是。这是为了崇高的目的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「絕對不是。這是為了崇高的目的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00006",
		linknext = "0052_00008",
		line = 99,
	},
	["0052_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Para que nos entendamos bien, respóndeme: ¿cuál es nuestro objetivo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我再问你一次——我们的目的是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我再問你一次——我們的目的是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00007",
		linknext = "0052_00009",
		line = 110,
	},
	["0052_00009"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00103", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0998", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Tener un trío contigo y una zorra elegante...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“要和辣妹婊还有哥哥3P……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「要和辣妹婊還有哥哥3P……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00008",
		linknext = "0052_00010",
		line = 124,
	},
	["0052_00010"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me temo que tus fantasías más profundas y oscuras no coinciden con los objetivos de esta organización, mocosa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不可以将个人愿望和组织目的混淆！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不可以將個人願望和組織目的混淆！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00009",
		linknext = "0052_00011",
		line = 136,
	},
	["0052_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Se supone que nuestro objetivo es encontrar a esa tal Fumino y acabar con la ley súperpervertida. ¿Por qué crees que creamos el NLNS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“找到文乃，摧毁变态条例——这才是NLNS的最终目的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「找到文乃，摧毀變態條例——這才是NLNS的最終目的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00010",
		linknext = "0052_00012",
		line = 148,
	},
	["0052_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin, como ayer descubrimos su edad, he llegado a la conclusión de que es una estudiante del edificio B.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“昨天终于掌握了‘文乃’的年龄，和在B等部的情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「昨天終於掌握了『文乃』的年齡，和在B等部的情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00011",
		linknext = "0052_00013",
		line = 159,
	},
	["0052_00013"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A partir de hoy, llevaremos a cabo una infiltración en el edificio B para encontrarla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因此——我们将在今天开始搜索‘文乃’，开始B等部潜入作战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因此——我們將在今天開始搜索『文乃』，開始B等部潛入作戰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00012",
		linknext = "0052_00014",
		line = 171,
	},
	["0052_00014"] = {
		{"bgm", stop=1},
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0999", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah... Vale, ya entendí. Como Wata-chan tiene un aspecto tan infantil, nadie sospechará si la ven paseando por el edificio B...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——我懂了……原来如此啊。渡酱的话长得像小孩，混入B等部也不会被怀疑……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊——我懂了……原來如此啊。渡醬的話長得像小孩，混入B等部也不會被懷疑……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00013",
		linknext = "0052_00015",
		line = 186,
	},
	["0052_00015"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="hinami_02m_00002", file1="hinami_02m_00114", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0673", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero si no tengo un aspecto infantil! ¡Si es por edad, a ti te saldría mejor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我才不像小孩！论年龄，麻沙音酱才是最小的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我才不像小孩！論年齡，麻沙音醬才是最小的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00014",
		linknext = "0052_00016",
		line = 204,
	},
	["0052_00016"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
