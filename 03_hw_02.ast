				{"vo", file="hinami0710", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Oh, so that was it? Sheesh, you could've said so sooner! You gave me the wrong idea for a sec there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……啊，原来是这样啊？什么嘛，你早点告诉我是这样啊。我都搞错了啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……啊，原來是這樣啊？什麼嘛，你早點告訴我是這樣啊。我都搞錯了啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00124",
		linknext = "0052_00126",
		line = 1779,
	},
	["0052_00126"] = {
