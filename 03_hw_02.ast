			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje, bueno, ya que me lo pides tan amablemente... ¡Por supuesto que ayudaré a mis adorables kouhais! ¡Ya lo verás! ¡Yo me encargo!”",
					{"rt2"},
