		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="eyecatch2_00000", x=0, y=0, path=":bg/", lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"ex", time=1000, func="wait"},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"se", id=1, loop=1, file="se_d030", vol=60},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg17_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"bgm", file="bgm01", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While we were all playing fiddle to Wata's antics, all the students in the B building were dismissed for the day, so we opted to cease activities.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在戏弄渡酱的时候，B等部的学生们也大部分都回去了，所以今天决定解散。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在戲弄渡醬的時候，B等部的學生們也大部分都回去了，所以今天決定解散。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00132",
		linknext = "0052_00134",
		line = 1922,
	},
	["0052_00134"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Man, it's been a hot minute since we were able to just walk right out the front gate like normies, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好久没从正面正常回家了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好久沒從正面正常回家了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00133",
		linknext = "0052_00135",
		line = 1934,
	},
	["0052_00135"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1006", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You got that right. We're always getting out through the back gate or that stuffy-ass cave nowadays... Nice little perk of nobody being around.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“真的……一直以来都是从洞穴走或者努力从后门逃走……没人的话居然这么轻松……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真的……一直以來都是從洞穴走或者努力從後門逃走……沒人的話居然這麼輕鬆……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00134",
		linknext = "0052_00136",
		line = 1948,
	},
	["0052_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's an event called Nutsgiving going on at the beach, so the SS and the students are all over there getting frisky.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为今天好像有“大感泄精祭”，包括FS在内的所有学生都去海滨做爱了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為今天好像有「大感洩精祭」，包括FS在內的所有學生都去海濱做愛了。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00135",
		linknext = "0052_00137",
		line = 1958,
	},
	["0052_00137"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From what I've heard, it entails assembling the largest tax donors to the Seiran government through the “benefit-your-locality” scheme to a special lodging, and giving them enough pussy to drown in. Eat your heart out, Little Saint James.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听说，好像是把从故乡纳税管道捐了高额税金到青蓝岛的人们招待到旅馆，作为回礼让他们做爱做到爽的活动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽說，好像是把從故鄉納稅管道捐了高額稅金到青藍島的人們招待到旅館，作為回禮讓他們做愛做到爽的活動。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00136",
		linknext = "0052_00138",
		line = 1970,
	},
	["0052_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suppose you could almost say that three certainties exist on Seiran Island: death, taxes, and hardcore sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"纳税的回礼是变态做爱，这样的癫狂举动非常符合这个岛的调性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"納稅的回禮是變態做愛，這樣的癲狂舉動非常符合這個島的調性。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00137",
		linknext = "0052_00139",
		line = 1980,
	},
	["0052_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nevertheless, the sum total of tax donations to this island is nothing to be scoffed at.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，捐赠的金额似乎也不能小看。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，捐贈的金額似乎也不能小看。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00138",
		linknext = "0052_00140",
		line = 1990,
	},
	["0052_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those kind donors' tax money pays for all the Ass Wall Artwork installations and permit Lewd Land to operate without charging admission fees. Almost like this island is completely subsidized by their donations or something.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上到处都是的壁尻体，免费入场的游乐场——故乡纳税似乎成了支撑起这些东西的资金来源之一。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上到處都是的壁尻體，免費入場的遊樂場——故鄉納稅似乎成了支撐起這些東西的資金來源之一。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00139",
		linknext = "0052_00141",
		line = 2000,
	},
	["0052_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh... The others seem to be running late.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过……奈奈濑他们也太迟了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過……奈奈瀨他們也太遲了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00140",
		linknext = "0052_00142",
		line = 2012,
	},
	["0052_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata should be changing into her uniform, and Hotori just needs to grab her bike. But they're taking longer than I'd have expected...",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是让渡酱换成制服然后让畔去取自行车而已，按道理应该要来了才对——",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是讓渡醬換成制服然後讓畔去取自行車而已，按道理應該要來了才對——",
					{"rt2"},
				},
			},
		},
