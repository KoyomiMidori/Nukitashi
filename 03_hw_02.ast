	["0052_00276"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00124", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=600, mode=3, x=0, y=100},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=700},
		{"fgact", ch="麻沙音", id=3, act="浮遊横", loop=3, size=5, time=125, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1009", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mgh... hm?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……啊——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……啊——？」",
					{"rt2"},
