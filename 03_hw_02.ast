					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Vas a sentirte mejor, Wata-chan-senpai?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“听好了，渡酱前辈——”",
