					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I am Watarai Hinami from class 3-1— ergo, the eldest senior around here! Hope you're having a good day, you all!”",
					{"rt2"},
