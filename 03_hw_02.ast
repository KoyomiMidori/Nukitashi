	["0052_00151"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0135", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana Junnosuke... No egregious violations of conduct, evaluated favorably among your class, but... Your record has instances of being found carrying a game console, being late, and running in the halls. Some cause for suspicion there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘淳之介——好像没有严重违反过校规，教师们的评价很高……不过带游戏机，迟到，在走廊上奔跑——这些很引人注目。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘淳之介——好像沒有嚴重違反過校規，教師們的評價很高……不過帶遊戲機，遲到，在走廊上奔跑——這些很引人注目。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00150",
		linknext = "0052_00152",
		line = 2137,
	},
	["0052_00152"] = {
		{"text"},
		text = {
