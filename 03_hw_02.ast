	["0052_00090"] = {
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00116", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0699", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Lo sabía! Tú también piensas que soy una niñita tonta, ¿verdad? Uuuugh... Soy tu senpai, ¿vale? No nací ayer...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“果然……橘君也把我当成单纯的孩子……呜……我可是前辈……明明没有那么单纯……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「果然……橘君也把我當成單純的孩子……嗚……我可是前輩……明明沒有那麼單純……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00089",
		linknext = "0052_00091",
		line = 1296,
	},
	["0052_00091"] = {
		{"text"},
		text = {
