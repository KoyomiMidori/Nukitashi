		linkback = "0052_00275",
		linknext = "0052_00277",
		line = 3782,
	},
	["0052_00277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She sluggishly turns her head to me, seemingly with some effort, from her vantage point on the sofa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"躺在沙发上的妹妹懒洋洋地回头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"躺在沙發上的妹妹懶洋洋地回頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00276",
		linknext = "0052_00278",
		line = 3792,
	},
	["0052_00278"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Were you asleep? I bought some croquettes on the way home. Let's eat 'em together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在睡觉吗？我回来的时候买了可乐饼，一起吃吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在睡覺嗎？我回來的時候買了可樂餅，一起吃吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00277",
		linknext = "0052_00279",
		line = 3804,
	},
	["0052_00279"] = {
		{"bg", id=1, file="bg19_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_02m_00001", file1="asane_02m_00116", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1010", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Don't wanna.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……不需要。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……不需要。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00278",
		linknext = "0052_00280",
		line = 3819,
	},
	["0052_00280"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They're your favorite— beef croquettes. Fresh from the store, so they're nice, hot and crispy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这可是麻沙酱最喜欢的牛肉可乐饼哦。刚炸好的热腾腾的可乐饼哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這可是麻沙醬最喜歡的牛肉可樂餅哦。剛炸好的熱騰騰的可樂餅哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00279",
		linknext = "0052_00281",
		line = 3831,
	},
	["0052_00281"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1011", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I said, don't wanna.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我说了不需要……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我說了不需要……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00280",
		linknext = "0052_00282",
		line = 3843,
	},
	["0052_00282"] = {
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=100, time=800},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=600},
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She sulks, turning her head away. She seems unwilling to upgrade from her current status as a lolling mass on the sofa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"声音里没有霸气，她转过身再次躺到沙发上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聲音裡沒有霸氣，她轉過身再次躺到沙發上。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00281",
		linknext = "0052_00283",
		line = 3857,
	},
	["0052_00283"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Strange. She's the kind to stuff her face even when she's had enough. Having seen her suffer tummy aches more times than I can count, I'd know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很奇怪。麻沙酱是个在吃饱的时候还硬说能吃，勉强吃了饭经常弄坏肚子的贪吃鬼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"很奇怪。麻沙醬是個在吃飽的時候還硬說能吃，勉強吃了飯經常弄壞肚子的貪吃鬼。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00282",
		linknext = "0052_00284",
		line = 3867,
	},
	["0052_00284"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is definitely not normal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她说“不需要”——这不正常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她說「不需要」——這不正常。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00283",
		linknext = "0052_00285",
		line = 3877,
	},
	["0052_00285"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you not feeling well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……身体不舒服吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……身體不舒服嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00284",
		linknext = "0052_00286",
		line = 3889,
	},
	["0052_00286"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", file="asane_02m_00001", file1="asane_02m_00116", file4="asane_02m_00401", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=1000},
		{"ex", time=1000, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wh-What is it, then!? Maybe we should get you to a hospital—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你、你没事吧！？不去医院的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你、你沒事吧！？不去醫院的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00285",
		linknext = "0052_00287",
		line = 3906,
	},
	["0052_00287"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00115", file4="asane_02m_00401", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1012", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, Christ, quit hollering, would ya. It's fine, okay? I know what's going on... Sigh, figured it was coming up anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊真是的，不要再大声叫了……没关系，我知道原因……哈啊……快来了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊真是的，不要再大聲叫了……沒關係，我知道原因……哈啊……快來了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00286",
		linknext = "0052_00288",
		line = 3920,
	},
	["0052_00288"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's coming up?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“快来了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「快來了……？」",
					{"rt2"},
