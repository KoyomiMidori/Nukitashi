	},
	["0052_00184"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[1700] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=1700, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0715", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Rei? Hey, fancy seeing you! Don't usually see you on your own. You on break today?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦……礼酱？是礼酱！一个人很少见啊……今天休息吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦……禮醬？是禮醬！一個人很少見啊……今天休息嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00183",
		linknext = "0052_00185",
		line = 2550,
	},
	["0052_00185"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0145", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Uh, no... I just hurried back here to get my written report done, since I figured the Nutsgiving proceedings were going smoothly anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊……不，‘大感泄精祭’顺利进行所以我时间空出来了，想去提前完成报告书。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊……不，『大感洩精祭』順利進行所以我時間空出來了，想去提前完成報告書。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00184",
		linknext = "0052_00186",
		line = 2564,
	},
	["0052_00186"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
