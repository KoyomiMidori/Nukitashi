		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“H-Hi there... We're just, uh, running a little late, is all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你、你好……我留下来做作业。”",
