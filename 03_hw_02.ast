	["0052_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In both personality and appearance, they're basically complete opposites.",
					{"rt2"},
				},
			},
			cn = {
				{
					"性格和体格都完全相反的这两个人。",
					{"rt2"},
				},
