		linknext = "0052_00130",
		line = 1839,
	},
	["0052_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'll give her one thing, she can be quite the moodmaker.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱重新调整了心情，得意洋洋。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬重新調整了心情，得意洋洋。",
