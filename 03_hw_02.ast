		{"bg", id=2, file="bg12_1l_00000", x=-300, y=-200, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="hinami_02l_00002", file1="hinami_02l_00116", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0697", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Me da igual... Solo soy una cara bonita con un cuerpo horrible, estoy plana, aunque me esfuerce no soy atractive, soy una tablita, siempre tengo el pelo desordenado, ¡y soy una tabla...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好了好了……反正我是丑女，又是贫乳，而且也没有大人的魅力，没胸，呆毛又翘很高，是个飞机场……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好了好了……反正我是醜女，又是貧乳，而且也沒有大人的魅力，沒胸，呆毛又翹很高，是個飛機場……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00080",
		linknext = "0052_00082",
		line = 1176,
	},
	["0052_00082"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00128", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1833", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Ay no, tenemos que animarla! ¡Pero, ay! ¡Mi compasión por ella y mis propios impulsos sádicos me están enloqueciendo...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“必须快点安慰渡酱才行……不过，啊啊……我因为嗜虐心和罪恶感变得有点奇怪……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「必須快點安慰渡醬才行……不過，啊啊……我因為嗜虐心和罪惡感變得有點奇怪……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00081",
		linknext = "0052_00083",
		line = 1195,
	},
	["0052_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí que le tienes ganas, ¿eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你只对渡酱这种性格呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你只對渡醬這種性格呢……」",
					{"rt2"},
				},
			},
