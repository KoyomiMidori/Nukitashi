				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「非常厲害，就像大河連續劇不用童星直接讓你出演6歲女孩子的角色也沒什麼違和感的感覺呢——」",
					{"rt2"},
				},
			},
		},
