		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"se", id=1, loop=1, file="se_d031", vol=60},
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After taking Asa back home, I decide to walk Wata back to her own home as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把麻沙酱送回家后，今天也送渡酱回家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把麻沙醬送回家後，今天也送渡醬回家。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00213",
		linknext = "0052_00215",
		line = 2964,
	},
	["0052_00215"] = {
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0721", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“We couldn't find out anything new about Fumino today, huh... That's kind of a wash. We'll have to try harder tomorrow... er, we must endeavor to work harder tomorrow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“结果今天还是没搞懂任何文乃的事呢……明天必须更加努力……啊，不……请让我努力吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「結果今天還是沒搞懂任何文乃的事呢……明天必須更加努力……啊，不……請讓我努力吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00214",
		linknext = "0052_00216",
		line = 2980,
	},
	["0052_00216"] = {
