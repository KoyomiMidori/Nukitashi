			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯？呵呵，不只是认识哦，礼酱是我最好的朋友呢！对吧，礼酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯？呵呵，不只是認識哦，禮醬是我最好的朋友呢！對吧，禮醬？」",
					{"rt2"},
				},
			},
		},
