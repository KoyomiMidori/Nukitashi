				{"fg", file="hinami_01m_00002", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=9700, time=300, mode=3, x=0, y=-200},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0676", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“M-Menos mal tengo mi arma secreta. ¡Listo! Ahora solo tengo que subirme a la silla y... ¡Oye, ¿por qué te estás alejando tanto?! ¡No puedo alcanzarte!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但、但是我还有秘密武器……嘿啾……站在这把椅子上就很容易……为什么要跑那么远啊——！？够不着啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但、但是我還有秘密武器……嘿啾……站在這把椅子上就很容易……為什麼要跑那麼遠啊——！？搆不著啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00019",
		linknext = "0052_00021",
		line = 296,
	},
	["0052_00021"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
