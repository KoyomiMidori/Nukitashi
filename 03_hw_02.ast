	["0052_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan sale del ascensor, temblando y con los ojos llenos de lágrimas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从电梯里出来的渡酱泪流满面颤抖着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從電梯裡出來的渡醬淚流滿面顫抖著。",
					{"rt2"},
				},
			},
		},
