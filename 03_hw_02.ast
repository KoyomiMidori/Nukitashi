		linkback = "0052_00075",
		linknext = "0052_00077",
		line = 1095,
	},
	["0052_00077"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1002b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Si ni siquiera te tocan, es porque no te ven como una pareja potencial. Por lo tanto, no eres apta para andar por el edificio B.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不过谁都没出手的话也就是说没被认为是性人……这样客观上来说连B等部都算不上吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不過誰都沒出手的話也就是說沒被認為是性人……這樣客觀上來說連B等部都算不上吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00076",
		linknext = "0052_00078",
		line = 1108,
	},
	["0052_00078"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00113", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
