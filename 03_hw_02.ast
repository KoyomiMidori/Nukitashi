		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="礼", id=9, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0133", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I would have expected the entire student body to be attending Nutsgiving... and yet it seems I've run into some outliers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我以为所有学生都去‘大感泄精祭’了……没想到还有学生留下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我以為所有學生都去『大感洩精祭』了……沒想到還有學生留下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00145",
		linknext = "0052_00147",
		line = 2075,
	},
	["0052_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the disciplinary committee president. Of all the times to run into an SS bigwig...",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长——没想到FS的首脑居然还在。",
