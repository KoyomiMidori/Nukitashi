					"“我，3年1班——也就是最高年级的渡会雏见！各位，贵安！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我，3年1班——也就是最高年級的渡會雛見！各位，貴安！」",
					{"rt2"},
				},
			},
