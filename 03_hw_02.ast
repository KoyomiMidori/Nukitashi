		text = {
			vo = {
				{"vo", file="hinami0711", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, sure! Uh, I mean, but of course! 'Tis but the lot in life of a senior to come through for their juniors!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，好啊！啊……嗯，好的！回应后辈们期待，是前辈必须尽的责任呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，好啊！啊……嗯，好的！回應後輩們期待，是前輩必須盡的責任呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00126",
		linknext = "0052_00128",
		line = 1809,
	},
	["0052_00128"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
