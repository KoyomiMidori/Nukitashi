		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=4, size=10, time=175, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0713", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ohohoho! Next time for certain, at my beckoning, our infiltration mission shall most surely prove fruitful!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哈～哈～哈～！这次一定会成功达成潜入作战的——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哈～哈～哈～！這次一定會成功達成潛入作戰的——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00130",
		linknext = "0052_00132",
		line = 1864,
	},
	["0052_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And so, her spirits were lifted for the rest of the day. All without her ever noticing she'd been played.",
					{"rt2"},
				},
			},
			cn = {
				{
					"连自己被戏弄一事都没有注意到，我们的前辈今天也很开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連自己被戲弄一事都沒有注意到，我們的前輩今天也很開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00131",
		linknext = "0052_00133",
		line = 1874,
	},
	["0052_00133"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
