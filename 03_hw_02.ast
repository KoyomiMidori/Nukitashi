				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bueno, se mire por donde se mire, sigues siendo una loli... ¿Qué te parece esto? Si me acaricias la cabeza, me inclinaré ante ti y te llamaré senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是怎么看都是萝莉……那如果你摸到我的头，我就认同你是前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是怎麼看都是蘿莉……那如果你摸到我的頭，我就認同你是前輩……」",
					{"rt2"},
				},
			},
		},
