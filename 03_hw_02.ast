				{"vo", file="asane1003", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Fuiste lo suficientemente buena como para reemplazar perfectamente a una niña de 6 años en una serie de época de alto presupuesto...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“非常厉害，就像大河连续剧不用童星直接让你出演6岁女孩子的角色也没什么违和感的感觉呢——”",
