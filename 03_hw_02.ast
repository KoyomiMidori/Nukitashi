		},
		linkback = "0052_00289",
		linknext = "0052_00291",
		line = 3958,
	},
	["0052_00291"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm worried, but I don't bring it up again after that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然很担心，但我还是决定不再搭话了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然很擔心，但我還是決定不再搭話了。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00290",
		linknext = "0052_00292",
		line = 3970,
	},
	["0052_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Family or not, there's still boundaries with us. If she doesn't want me to pry, I won't. Such is the nature of our relationship.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使关系亲密，也要讲究礼节。如果被说别管的话就不深入，这就是我们兄妹的做法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使關係親密，也要講究禮節。如果被說別管的話就不深入，這就是我們兄妹的做法。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00291",
		linknext = "0052_00293",
		line = 3980,
	},
	["0052_00293"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ultimately, Asane ended up staying in the same sour mood all night, much to my dismay.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果——那天晚上到很晚为止，麻沙音都一直板着脸，完全跟她说不上话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結果——那天晚上到很晚為止，麻沙音都一直板著臉，完全跟她說不上話。",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00292",
		linknext = "block_00293",
		line = 3990,
	},
