				{"fgact", ch="美岬", id=6, act="振動下", loop=5, size=12.5, time=75, ease="easeinout_sine", delay2=10800},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0376", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Pfft, c-cut that out, Asane, you shouldn't be laughing at hee hee... That's kinda PFF-rude, she's trying her best over here... hyuk hyuk hyuk...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“噗哈……不、不行啦！麻沙音，你笑得这么失礼，渡酱……呵呵，很努力……唉——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「噗哈……不、不行啦！麻沙音，你笑得這麼失禮，渡醬……呵呵，很努力……唉——」",
					{"rt2"},
