		linknext = "0052_00096",
		line = 1353,
	},
	["0052_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cuando te infiltraste en el edificio B, intentaste ser aún más infantil para integrarte mejor, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了即使在B等部也不显得不自然——故意演得比平常更孩子气对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了即使在B等部也不顯得不自然——故意演得比平常更孩子氣對吧？」",
					{"rt2"},
				},
