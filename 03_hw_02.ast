		linkback = "0052_00025",
		linknext = "0052_00027",
		line = 377,
	},
	["0052_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues si un tipo grande como yo estuviera paseando por el edificio B sin meter la polla en algún orificio, eso despertaría sospechas, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“像我这种体格的男人不做爱在B等部晃悠的话，马上就会被怀疑吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「像我這種體格的男人不做愛在B等部晃悠的話，馬上就會被懷疑吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00026",
		linknext = "0052_00028",
		line = 388,
	},
	["0052_00028"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
