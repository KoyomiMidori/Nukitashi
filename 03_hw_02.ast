			},
		},
		linkback = "0052_00147",
		linknext = "0052_00149",
		line = 2097,
	},
	["0052_00149"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00112", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0134", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hm...? Your face seems familiar. You would be... Tachibana, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……？我们好像见过几次面吧。好像是叫……橘。”",
