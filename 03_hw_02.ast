				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬？」",
					{"rt2"},
				},
