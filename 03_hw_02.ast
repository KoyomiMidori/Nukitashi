			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Gah! ¿Entonces soy como una niña de prescolar? Uuugh, siempre supe que era más bajita que los demás, pero... Ahora lo entiendo, ni siquiera lo sabía...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……！也就是说，未性年……呜呜，我还以为只比别人小一点……原来是这样啊，我都不知道……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……！也就是說，未性年……嗚嗚，我還以為只比別人小一點……原來是這樣啊，我都不知道……」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00077",
		linknext = "0052_00079",
		line = 1124,
	},
