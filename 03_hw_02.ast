			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Gussy up, huh? I'll try... Er, I shall endeavor... I shall make an effort of it! Does that sound sufficient?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“敬语……我会试试看的……试试看……请让我试试看！啊，就是这种感觉是吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「敬語……我會試試看的……試試看……請讓我試試看！啊，就是這種感覺是吧！？」",
					{"rt2"},
				},
			},
		},
