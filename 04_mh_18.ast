			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Nope, it's the same. No matter how futile things were, you always tried your utmost for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不……是一样的。无论是在多么绝望的处境，淳之介君都尽了最大的努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不……是一樣的。無論是在多麼絕望的處境，淳之介君都盡了最大的努力。」",
					{"rt2"},
				},
			},
