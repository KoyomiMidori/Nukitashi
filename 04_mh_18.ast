					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But that didn't cut it. Just putting love into words wasn't enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，果然是不行的。就算想暧昧地解释爱这个词来蒙混去，也是行不通的。”",
					{"rt2"},
				},
			},
