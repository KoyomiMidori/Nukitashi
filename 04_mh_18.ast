				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I suppose so... But this is totally diff—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“确实，以前可能是这样……但是，现在的状况完全——”",
