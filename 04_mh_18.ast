		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1739", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We fooled the disciplinary committee president by playing with my asshole in the student council room, we made all the SS have sex with Yuiko and the others, and we flew off a cliff together on a bicycle...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“为了瞒过风纪委员长，我用学生会室的门对着菊花自慰，还用过唯子她们让FS的大家互相做爱，最后骑着自行车一起从悬崖上跳下来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「為了瞞過風紀委員長，我用學生會室的門對著菊花自慰，還用過唯子她們讓FS的大家互相做愛，最後騎著自行車一起從懸崖上跳下來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00078",
		linknext = "0095_00080",
