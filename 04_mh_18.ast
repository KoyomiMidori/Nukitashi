	},
	["0095_00068"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1732", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Of course, I know how frustrating it is for you, and how it's really not good for all of us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我当然知道，这对淳之介来说是一件悲伤的事情，对大家来说也是一件非常不好的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我當然知道，這對淳之介來說是一件悲傷的事情，對大家來說也是一件非常不好的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00067",
		linknext = "0095_00069",
		line = 869,
	},
	["0095_00069"] = {
		{"fg", file="misaki_01l_00001", file2="misaki_01l_00201", file3="misaki_01l_00308", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1733", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But... speaking for myself personally... I'm incredibly happy that you can only get an erection from me. It shows to me just what I mean to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是……就我个人而言……只能对我勃起……我非常高兴。因为这说明我是多么地被爱着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是……就我個人而言……只能對我勃起……我非常高興。因為這說明我是多麼地被愛著。」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00068",
		linknext = "0095_00070",
		line = 883,
	},
	["0095_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But that just means I can't protect you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可我因为这样，而不能保护美岬……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可我因為這樣，而不能保護美岬……」",
					{"rt2"},
				},
			},
