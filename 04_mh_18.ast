	["0095_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“'No love, no sex'... That's my principle. It's everything I believe in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“No Love， No Sex”——不做没有爱的性爱。这是我的信仰。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「No Love， No Sex」——不做沒有愛的性愛。這是我的信仰。 」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00103",
		linknext = "0095_00105",
		line = 1313,
	},
	["0095_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And yet, I went off and had sex more times than I can count with people for whom I felt nothing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我一边这么说，一边和我不喜欢的人做了好几次爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我一邊這麼說，一邊和我不喜歡的人做了好幾次愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00104",
		linknext = "0095_00106",
		line = 1324,
	},
	["0095_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I told myself that I could put up with fucking anyone else, so long as I loved you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为有对美岬的爱，所以可以忍受和别人做爱——我这么告诉自己。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為有對美岬的愛，所以可以忍受和別人做愛——我這麼告訴自己。」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00105",
		linknext = "0095_00107",
		line = 1335,
	},
	["0095_00107"] = {
