	["0095_00155"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1506", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So that was the worst thing I've ever done, but I whipped up a quick sample set. I just did manual superimposition since it was urgent, but it should have the same effect as automatic superimposition.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然我非常不愿意但还是做了个样本出来……因为是急用所以是手动补全……不过和自动补全是一样的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然我非常不願意但還是做了個樣本出來……因為是急用所以是手動補全……不過和自動補全是一樣的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00154",
		linknext = "0095_00156",
		line = 1937,
	},
	["0095_00156"] = {
