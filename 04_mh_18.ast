			},
		},
		text = {
			vo = {
				{"vo", file="misaki1738", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We feigned those extreme fetishes to throw the SS off our track, we got inside Hamedori, and... we did pervy stuff at the olympiad. Twice, even.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“为了转移FS的注意力，我们装成异常性癖的样子，还进到过Hamedori君的身体里……在体欲节的时候……也做了很多色色的事情，而且是两次。”",
