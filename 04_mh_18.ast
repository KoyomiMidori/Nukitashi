	["0095_00146"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"se", id=0, loop=0, file="se_b030"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is ATM-01! Asa, come in! You there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——这里是ATM-01！麻沙酱，你在吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——這裡是ATM-01！麻沙醬，你在嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00145",
		linknext = "0095_00147",
		line = 1832,
	},
	["0095_00147"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1504", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hm? Yeah, I'm here. What's up? You sound unusually excited.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……在是在……怎么？发出这么大的声音……很少见啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……在是在……怎麼？發出這麼大的聲音……很少見啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00146",
		linknext = "0095_00148",
		line = 1845,
	},
	["0095_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Remember how you coded an algorithm to automatically superimpose uncensored pussy textures over mosaics a while back?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“以前你有做过自动将马赛克的部份补全，让画面变成无修正小穴的代码对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「以前你有做過自動將馬賽克的部份補全，讓畫面變成無修正小穴的代碼對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00147",
		linknext = "0095_00149",
		line = 1857,
	},
	["0095_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you able to modify that to make all the puppets look like Misaki?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果用那个，能不能开发出自动将傀儡的外表变成美岬的代码？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果用那個，能不能開發出自動將傀儡的外表變成美岬的代碼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00148",
		linknext = "0095_00150",
		line = 1868,
	},
	["0095_00150"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00105", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1505", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Huh? Sorry, I haven't the foggiest clue what you're on about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……？对不起，你说的话我1毫米也不懂……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……？對不起，你說的話我1毫米也不懂……」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00149",
		linknext = "0095_00151",
		line = 1881,
	},
	["0095_00151"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You'll figure it out. There's an external hard drive in my room, and it's got about a terabyte of Misaki pics on it. Put 'em to good use for me, all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“做了就知道了——我房间的外置硬盘里有1TB的美岬的照片，你就用它吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「做了就知道了——我房間的外置硬盤裡有1TB的美岬的照片，你就用它吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00150",
		linknext = "0095_00152",
		line = 1893,
	},
	["0095_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even on my end of the comms line, I can surmise that the look on her face right now must be beyond disgusted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算隔着通讯器，我也知道麻沙酱现在一副非常厌恶的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算隔著通訊器，我也知道麻沙醬現在一副非常厭惡的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00151",
		linknext = "0095_00153",
		line = 1903,
	},
	["0095_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she just sighs resignedly, and acknowledges my request. I knew I could count on her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她最后还是随着一声表示放弃的叹气，答应了。不愧是我妹妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她最後還是隨著一聲表示放棄的嘆氣，答應了。不愧是我妹妹。",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00152",
		linknext = "0095_00154",
		line = 1913,
	},
	["0095_00154"] = {
		{"ex", time=600, func="wait"},
