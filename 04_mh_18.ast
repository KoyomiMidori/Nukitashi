		linkback = "0095_00069",
		linknext = "0095_00071",
		line = 895,
	},
	["0095_00071"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00102", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1734", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That's not true. Haven't you been protecting me all this time, without even having to use it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不是这样的。即使不用小鸡鸡，淳之介君不也一直守护着我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不是這樣的。即使不用小雞雞，淳之介君不也一直守護著我嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00070",
