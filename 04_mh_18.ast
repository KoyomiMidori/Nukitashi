	},
	["0095_00074"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00101", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1736", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Remember that time I was almost assaulted? I was a complete stranger to you, yet you paid no heed to your own safety and gallantly protected me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你还记得吧？当素不相识的我被袭击的时候……你不顾危险帅气地救了我不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你還記得吧？當素不相識的我被襲擊的時候……你不顧危險帥氣地救了我不是嗎？」",
					{"rt2"},
				},
			},
		},
