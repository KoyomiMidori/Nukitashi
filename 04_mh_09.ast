	},
	["0086_01103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm trying to think about Fumino, but all I can remember is Hotori being adorable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明明打算思考文乃的事情，但不知为何只出现了畔的可爱场景集。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明明打算思考文乃的事情，但不知為何只出現了畔的可愛場景集。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01102",
		linknext = "0086_01104",
		line = 14811,
	},
	["0086_01104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though we just parted, she's all that's on my mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明才刚刚告别，脑袋里却已经充满了畔的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明才剛剛告別，腦袋裡卻已經充滿了畔的事。",
					{"rt2"},
				},
