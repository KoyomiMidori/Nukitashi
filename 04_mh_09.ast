		{"fgact", ch="美岬", id=6, act="振動下", loop=-1, size=2.5, time=125, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1081", path=":vo/", ch="misaki"},
			},
			ja = {
				{
