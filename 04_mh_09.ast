					name = {"麻沙音", "Asane"},
					"“Well, there's this. Check it out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……这个，我打印出来的……能帮我看一下吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……這個，我列印出來的……能幫我看一下嗎……？」",
