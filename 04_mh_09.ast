		line = 5677,
	},
	["0086_00418"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once I get there, I'll take the SS keycard, use it to sneak into the student council room, then extract the data. That's the plan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那里拿到FS的IC卡后，直接潜入学生会室，抽出数据——这就是这次的作战计划。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那裡拿到FS的IC卡後，直接潛入學生會室，抽出數據——這就是這次的作戰計劃。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00417",
		linknext = "0086_00419",
		line = 5687,
	},
	["0086_00419"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's no exaggeration to say that the success of the NLNS' main mission depends on me here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果要说本作战的成败完全取决于我也不为过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果要說本作戰的成敗完全取決於我也不為過。",
					{"rt2"},
				},
			},
