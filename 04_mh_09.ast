		linkback = "0086_00612",
		linknext = "0086_00614",
		line = 8197,
	},
	["0086_00614"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00102", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
