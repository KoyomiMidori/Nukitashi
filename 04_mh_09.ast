		linkback = "0086_00682",
		linknext = "0086_00684",
		line = 9120,
	},
	["0086_00684"] = {
		{"fg", file="ikuko_01m_00004", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0275", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It wouldn't be any fun if I just won by default, y'know? Plus, if it came to that... I'd just have to tell everyone that you're the Anti-Copulation Front ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不战而胜什么的，不要做那种令人寂寞的事好吗？如果弃权的话……你们是反交尾势力的事情，我会告诉大家哦♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不戰而勝什麼的，不要做那種令人寂寞的事好嗎？如果棄權的話……你們是反交尾勢力的事情，我會告訴大家哦♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00683",
		linknext = "0086_00685",
		line = 9134,
	},
	["0086_00685"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1183", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh!? H-H-H-How does she know about that!? Uh, I mean! I'm not into that sort of thing at all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶！？为、为为、为什么，女部田同学会知道这件事……！？啊，不！虽然我并不是！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸！？為、為為、為什麼，女部田同學會知道這件事……！？啊，不！雖然我並不是！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00684",
		linknext = "0086_00686",
		line = 9148,
	},
	["0086_00686"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00124", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, Hotori. Let's just say stuff happened, and she clued into it. It's just like she says... there's no way out of this for us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思，畔……发生了很多事，被她发现了。所以……我不能从这场比赛中逃走。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思，畔……發生了很多事，被她發現了。所以……我不能從這場比賽中逃走。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00685",
		linknext = "0086_00687",
		line = 9160,
	},
	["0086_00687"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know you already went through the scavenger hunt, but now we're backed into a corner with this again... I'm so sorry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没想到不止借物竞争，又变成了这种状况……真的非常抱歉……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒想到不止借物競爭，又變成了這種狀況……真的非常抱歉……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00686",
		linknext = "0086_00688",
		line = 9171,
	},
	["0086_00688"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1184", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, don't be! If it's with you, I don't mind... but you have to be in front of such a huge crowd again...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，哪里……！如果是和橘同学的话……可是，橘同学才是，在这么多人面前……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，哪裡……！如果是和橘同學的話……可是，橘同學才是，在這麼多人面前……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00687",
		linknext = "0086_00689",
		line = 9185,
	},
	["0086_00689"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00202", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't worry about it. If we managed last time, I'm sure we can manage again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别放在心上。刚才不也没事吗？这次一定也没问题的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別放在心上。剛才不也沒事嗎？這次一定也沒問題的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00688",
		linknext = "0086_00690",
		line = 9197,
	},
	["0086_00690"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I put on a brave face and turn back to Onabuta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我使出全力虚张声势，将视线转向女部田。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我使出全力虛張聲勢，將視線轉向女部田。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00689",
		linknext = "0086_00691",
		line = 9207,
	},
	["0086_00691"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Very well. We accept your challenge... on one condition.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——就是这样，我接受你的挑战。但是……我也有条件。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——就是這樣，我接受你的挑戰。但是……我也有條件。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00690",
		linknext = "0086_00692",
		line = 9219,
	},
	["0086_00692"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If Hotori wins this, you're gonna keep a tight lip about our little secret, and stop trying to shadow me all the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果畔胜利了……你就要隐瞒我们的事情，今后也不要再继续纠缠我了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果畔勝利了……你就要隱瞞我們的事情，今後也不要再繼續糾纏我了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00691",
		linknext = "0086_00693",
		line = 9230,
	},
	["0086_00693"] = {
		{"fg", file="ikuko_01m_00004", file1="ikuko_01m_00113", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0276", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huh? I dunno about that, chief. I'm not seeing any good reason to agree to your terms, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶〜……该怎么办呢？我好像没有理由要接受吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸〜……該怎麼辦呢？我好像沒有理由要接受吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00692",
		linknext = "0086_00694",
		line = 9244,
	},
	["0086_00694"] = {
		{"fg", file="jun_01f_00004", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
