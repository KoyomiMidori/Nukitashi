		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel myself wracked with anguish and groan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"挣扎的思绪涌上心头，烦恼让我心烦意乱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"掙扎的思緒湧上心頭，煩惱讓我心煩意亂。",
