	["0086_01085"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1123", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“D-During the pole topple... why did you ejaculate from me rather than Onabuta?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“最、最后的推倒棒子……为什么不是女部田同学……而是对我射精了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「最、最後的推倒棒子……為什麼不是女部田同學……而是對我射精了……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01084",
		linknext = "0086_01086",
		line = 14484,
	},
	["0086_01086"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I, uh... I'm not really sure I can say...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……就算你问我为什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……就算你問我為什麼……」",
					{"rt2"},
				},
			},
		},
