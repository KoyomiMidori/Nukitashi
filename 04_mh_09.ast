			en = {
				{
					name = {"礼", "Rei"},
					"“Ughh... Why the hell would it talk like that in the first place, anyway!? Is that cock of yours the royal weenus or something!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呜呜……我说你！为什么第一人称是鸡巴啊！你是鸡巴皇族吗！？”",
