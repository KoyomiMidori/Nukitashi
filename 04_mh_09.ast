				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She crouches down, the burning light of the setting sun at her back.",
					{"rt2"},
				},
			},
			cn = {
				{
					"背对着燃烧的夕阳，女部田把腰架得很低。",
					{"rt2"},
				},
			},
			tw = {
				{
					"背對著燃燒的夕陽，女部田把腰架得很低。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01134",
		linknext = "0086_01136",
		line = 15275,
	},
	["0086_01136"] = {
		{"text"},
		text = {
