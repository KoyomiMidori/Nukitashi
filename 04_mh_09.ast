		{"bg", id=2, file="bg17_1_1l_00000", x=0, y=100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"se", id=0, loop=0, file="se_a021"},
		{"se", id=0, stop=1, time=5000},
		{"text"},
		delay = {
			[300] = {
				{"fg", file="touka_01m_00004", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=300, time=500, mode=3, x=-200, y=-100},
				{"fgact", ch="桐香", id=8, act="移動", x=200, y=0, time=1000, delay2=300},
			},
		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voz resuena en el cielo azul, y los estudiantes de primer año se paran firmes en el estrado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"委员长的声音在蓝天下回响，排在1年级队伍里的少女静静地站到了台上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"委員長的聲音在藍天下迴響，排在1年級隊伍裡的少女靜靜地站到了臺上。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00008",
