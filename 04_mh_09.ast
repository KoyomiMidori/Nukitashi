	["0086_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hace un calor espantoso, pero hay suficientes instalaciones en los alrededores de la escuela para ayudar a aliviar esto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在炎炎烈日下，我看着校园里满满的奇特设备吞了口唾沫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在炎炎烈日下，我看著校園裡滿滿的奇特設備吞了口唾沫。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00001",
		linknext = "0086_00003",
		line = 29,
	},
	["0086_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Todos los estudiantes a mi alrededor están en trajes de baño. Nadie está teniendo sexo, y todos están formando una fila ordenada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"周围都是穿着泳装的学生。没有一个人在做爱，而是整齐地排着队。",
					{"rt2"},
				},
			},
			tw = {
				{
					"周圍都是穿著泳裝的學生。沒有一個人在做愛，而是整齊地排著隊。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00002",
