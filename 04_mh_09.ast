	["0086_01047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, there's still an elephant in the room, so the atmosphere is incredibly awkward.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但由于双方都明显地在回避特定话题，因此形成了非常僵硬的氛围。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但由於雙方都明顯地在迴避特定話題，因此形成了非常僵硬的氛圍。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01046",
		linknext = "0086_01048",
		line = 14007,
	},
	["0086_01048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It just feels like anything we say could make things so much worse. The ice feels almost unbreakable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每一句话都有可能成为炸弹，甚至还出现了不必要的紧张感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每一句話都有可能成為炸彈，甚至還出現了不必要的緊張感。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01047",
		linknext = "0086_01049",
		line = 14017,
	},
	["0086_01049"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
			},
			[5500] = {
				{"fg", file="misaki_01m_00001", file2="misaki_01m_00204", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1110", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, yeah, so, anyway! Whoa, sorry for talking so loudly... it was just a surprise to learn that the SS are looking for Fumino, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“话、话说！啊，不好意思声音太大了……话说……真让人吃惊啊，FS居然也在寻找文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「話、話說！啊，不好意思聲音太大了……話說……真讓人吃驚啊，FS居然也在尋找文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01048",
		linknext = "0086_01050",
		line = 14035,
	},
	["0086_01050"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I wouldn't have expected that. A direct order from the governor, too. Damn.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……真是太让人吃惊了……而且，还是县知事的命令，这真是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……真是太讓人吃驚了……而且，還是縣知事的命令，這真是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01049",
		linknext = "0086_01051",
		line = 14046,
	},
	["0086_01051"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1111", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Y-Yes, indeed... damn...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“真的是真是呢……真是的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「真的是真是呢……真是的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01050",
		linknext = "0086_01052",
		line = 14060,
	},
	["0086_01052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's nothing to the conversation, and it peters out as quickly as it started. And I thought it was bad when we first met.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样空洞的对话并不常见。是不是变得比刚见面时更尴尬了？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣空洞的對話並不常見。是不是變得比剛見面時更尷尬了？",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01051",
		linknext = "0086_01053",
		line = 14070,
	},
	["0086_01053"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, you know... we only know all of this because of your hard work. Seriously, you did really well today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，这一切都是托畔努力的福……你真的做得很好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，這一切都是托畔努力的福……你真的做得很好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01052",
		linknext = "0086_01054",
		line = 14082,
	},
	["0086_01054"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1112", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, it was no big deal. You're the one who worked hard today... in all sorts of ways.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，没这回事……今天反而是橘同学更努力吧……那个，在各种事物上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，沒這回事……今天反而是橘同學更努力吧……那個，在各種事物上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01053",
		linknext = "0086_01055",
		line = 14096,
	},
	["0086_01055"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not sure I'd go that far.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……？是这样吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……？是這樣嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01054",
		linknext = "0086_01056",
		line = 14108,
	},
	["0086_01056"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00204", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1113", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Then let's just say we both did. Teehee...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯——那就是我们都努力了……诶嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯——那就是我們都努力了……欸嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01055",
		linknext = "0086_01057",
		line = 14122,
	},
	["0086_01057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I guess. Let's go with that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……是啊，就当是这样吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……是啊，就當是這樣吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01056",
		linknext = "0086_01058",
		line = 14134,
	},
	["0086_01058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I really wish I could better express just how much I appreciate Hotori's efforts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——其实我的内心更想多慰劳一下畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——其實我的內心更想多慰勞一下畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01057",
		linknext = "0086_01059",
		line = 14144,
	},
	["0086_01059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I'm too paranoid that trying to put it into words would lead me right into a landmine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，今天的事情要是再具体说下去，就要看到无数地雷的影子了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，今天的事情要是再具體說下去，就要看到無數地雷的影子了。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01058",
		linknext = "0086_01060",
		line = 14154,
	},
	["0086_01060"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=100},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg10_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"text"},
		text = {
