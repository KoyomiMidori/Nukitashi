					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“明明不久前还能随便讲……最近，甚至连回家时说的‘我回来了’后面的‘小穴’都省略了……”",
					{"rt2"},
				},
			},
			tw = {
				{
