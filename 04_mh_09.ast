		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The Grand Orgy Royale is the showpiece event where all the audience and students come together and the schoolgrounds becomes a massive orgy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"性乱大合战——来宾和学生们混在一起，在校园里进行大乱交的体欲节主要竞技。",
					{"rt2"},
				},
			},
			tw = {
				{
					"性亂大合戰——來賓和學生們混在一起，在校園裡進行大亂交的體欲節主要競技。",
					{"rt2"},
				},
			},
		},
