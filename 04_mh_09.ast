			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Bueno, aunque todos a mi alrededor estén gritando pollas y coños a todo pulmón, no puedo hacerlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为……大家都毫无顾忌堂堂正正地……那个……高声呐喊着鸡巴小穴……但我心理却非常抗拒说出口……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為……大家都毫無顧忌堂堂正正地……那個……高聲吶喊著肉棒小穴……但我心理卻非常抗拒說出口……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00103",
		linknext = "0086_00105",
		line = 1443,
	},
	["0086_00105"] = {
