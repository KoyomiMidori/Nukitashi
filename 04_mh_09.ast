		text = {
			vo = {
				{"vo", file="ikuko0259", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Aww, did that hurt? Everything will be okay. Lots and loooots of pleasure with me awaits you if you're just willing to lay back and accept it ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“痛吗？但是没关系。今后，等待你的是和郁一直一直非常舒服的时间……所以先稍微休息一下吧♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「痛嗎？但是沒關係。今後，等待你的是和郁一直一直非常舒服的時間……所以先稍微休息一下吧♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01133",
		linknext = "0086_01135",
		line = 15257,
	},
	["0086_01135"] = {
