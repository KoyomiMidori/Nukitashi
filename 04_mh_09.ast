		{"bg", id=2, file="bg17_1_1l_00000", x=0, y=100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0663", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The sight of semen against the backdrop of a clear blue sky... the echoing of sweet moans throughout the island... As always, this year's olympiad was true spectacle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“精子在万里晴空下飞舞……娇美呻吟的回音回响在整个岛中——今年的体欲节也非常精彩。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「精子在萬里晴空下飛舞……嬌美呻吟的回音迴響在整個島中——今年的體欲節也非常精彩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00852",
		linknext = "0086_00854",
		line = 11329,
	},
	["0086_00854"] = {
		{"se", id=0, loop=0, file="se_d007"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once more, I can't really understand what she's saying. I don't really think I want to, anyway.",
