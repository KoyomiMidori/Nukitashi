		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2012", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Great work today, everyone! Especially you, Misaki! You did amazing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“大家辛苦了！非常努力的美岬酱更是特别辛苦呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「大家辛苦了！非常努力的美岬醬更是特別辛苦呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01011",
		linknext = "0086_01013",
		line = 13533,
	},
	["0086_01013"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1107", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ehehe, thank you. You're embarrassing me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……谢谢，不敢当。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……謝謝，不敢當。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01012",
		linknext = "0086_01014",
		line = 13546,
	},
	["0086_01014"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2010", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Seriously, great work back there. Looks like we didn't end up needing the card, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你真的很努力呢……虽然拿到的卡完全没了意义……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你真的很努力呢……雖然拿到的卡完全沒了意義……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01013",
		linknext = "0086_01015",
		line = 13559,
	},
	["0086_01015"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2013", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Now, now, all's well that ends well, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“算了算了，反正最后成功结束了，没关系啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「算了算了，反正最後成功結束了，沒關係啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01014",
		linknext = "0086_01016",
		line = 13571,
	},
	["0086_01016"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00119", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2011", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I guess. By the way... Jun, what are you doing all the way over there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，也是。对了……淳为什么坐在那么远的地方？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，也是。對了……淳為什麼坐在那麼遠的地方？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01015",
		linknext = "0086_01017",
		line = 13587,
	},
	["0086_01017"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nothing. I just like this spot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别管我……我喜欢这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別管我……我喜歡這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01016",
		linknext = "0086_01018",
		line = 13599,
	},
	["0086_01018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't possibly tell her that thinking about all the stuff that happened today makes me feel uncomfortable when I'm near Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想起今天的种种，现在只要呆在畔附近就会感到尴尬——之类的话，我说不出口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回想起今天的種種，現在只要待在畔附近就會感到尷尬——之類的話，我說不出口。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01017",
		linknext = "0086_01019",
		line = 13609,
	},
	["0086_01019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Am I the only one dwelling on what happened? I wonder what's going through Hotori's head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是我意识过度了吗……？畔是怎么想的……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是我意識過度了嗎……？畔是怎麼想的……？",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01018",
		linknext = "0086_01020",
		line = 13619,
	},
