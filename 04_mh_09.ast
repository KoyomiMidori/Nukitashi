				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eventually we arrive at Hotori's house.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果，我们就这样一直走到畔的家附近。",
					{"rt2"},
				},
