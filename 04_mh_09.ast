			},
		},
		text = {
			vo = {
				{"vo", file="hinami1999", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah! ¡Oye, si sigues tratándome como una niña, me voy a enojar de verdad! ¡Ah, ya puedo ver! ¡Les deseo suerte!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇——！！不要把我当小孩子啦！我会生气的！不过能看到了！大家加油——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇——！！不要把我當小孩子啦！我會生氣的！不過能看到了！大家加油——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00037",
		linknext = "0086_00039",
		line = 536,
	},
	["0086_00039"] = {
		{"fg", file="misaki_01f_00004", file1="misaki_01f_00107", file2="misaki_01f_00201", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
