		text = {
			vo = {
				{"vo", file="ikuko0260", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"非表示", "郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Ikuko"},
					"“A sniper? Their breath control is impressive... Or they're far enough that they're at the limits of my perception. Here's another, but I'm afraid not!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "郁子"},
					"“狙击……？不，几乎没有呼吸……距离是我认知范围的边界吗……二连击，不过可惜——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "郁子"},
					"「狙擊……？不，幾乎沒有呼吸……距離是我認知範圍的邊界嗎……二連擊，不過可惜——！」",
					{"rt2"},
				},
			},
		},
