		line = 4651,
	},
	["0086_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, I can't let the guilt get to me. I can't make Hotori start worrying again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不行。如果我这么有罪恶感，又会让畔担心的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不行。如果我這麼有罪惡感，又會讓畔擔心的。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00348",
