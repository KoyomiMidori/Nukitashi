	},
	["0086_00087"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00117", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1007", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, Tachibana-san, ¿estás bien? Sé que no te gustan las palabras que empiezan con C y P...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个，橘同学……可以吗？那个……穴……什么的……鸡……什么的，可以说吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個，橘同學……可以嗎？那個……穴……什麼的……雞……什麼的，可以說嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00086",
		linknext = "0086_00088",
		line = 1196,
	},
	["0086_00088"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00113", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, no me queda de otra. Todo el mundo tiene que usar ese tipo de lenguaje en algún momento de su vida. Ahora mismo es uno de esos momentos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这是特殊情况。任何人只要活着，就有遇上不得不说淫语的时候——现在就是那个时候。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這是特殊情況。任何人只要活著，就有遇上不得不說淫語的時候——現在就是那個時候。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00087",
		linknext = "0086_00089",
		line = 1208,
	},
	["0086_00089"] = {
