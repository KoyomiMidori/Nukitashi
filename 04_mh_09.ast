			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But I wasn't able to get the data...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是……就算拥有这个，最重要的数据……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是……就算擁有這個，最重要的數據……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00607",
		linknext = "0086_00609",
		line = 8128,
