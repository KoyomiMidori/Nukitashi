					{"rt2"},
				},
			},
			en = {
				{
					"I suddenly find myself acutely aware of Hotori's warmth and softness in my arms, and find myself getting flustered. I shake my head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"眼看就要意识到抱在怀里的畔的触感和温暖了——我慌忙地摇了摇头。",
