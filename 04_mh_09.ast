		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bg", id=2, file="bg19_1l_00000", x=200, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1369", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Impeccable timing, brother dear. I just finished processing a huge chunk of the data.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“时机真刚好……我刚刚调查完提取出的数据中最大规模的部分……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「時機真剛好……我剛剛調查完提取出的數據中最大規模的部分……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01024",
		linknext = "0086_01026",
		line = 13711,
	},
	["0086_01026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? What'd you find?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗——怎么样？”",
