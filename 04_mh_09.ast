		line = 113,
	},
	["0086_00010"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0657", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Buenos días, estudiantes. Como presidenta del consejo estudiantil de la Academia Minotsuki, es triste ver a un grupo tan grande y que no haya nadie teniendo sexo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“各位，早上好……作为水乃月学园的学生会长，没有一个人做爱的光景多少让人感到寂寞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「各位，早安……作為水乃月學園的學生會長，沒有一個人做愛的光景多少讓人感到寂寞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00009",
		linknext = "0086_00011",
		line = 125,
	},
	["0086_00011"] = {
		{"fg", file="touka_01m_00004", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=-100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0658", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sin embargo, no es más que la calma antes de la tormenta. Cuando pienso en la orgía que transformará estos alrededores, mi estado de ánimo se aclara al instante, como el brillante cielo azul de hoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“可是，这也只是暴风雨前的寂静……一想到这个操场即将变成乱交会场，心情也立刻变得像今天的蓝天一样晴朗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「可是，這也只是暴風雨前的寂靜……一想到這個操場即將變成亂交會場，心情也立刻變得像今天的藍天一樣晴朗。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00010",
		linknext = "0086_00012",
		line = 139,
	},
	["0086_00012"] = {
		{"fg", file="touka_01m_00004", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=-100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0659", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Estoy segura de que hay estudiantes que se han esforzado al máximo por no tener relaciones sexuales para prepararse para hoy. Como pueden ver, se ha reunido un numeroso público para ver los frutos de sus esfuerzos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“为了今天，应该有很多人拼命忍住了做爱。为了确认各位的努力，今天来了很多客人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「為了今天，應該有很多人拼命忍住了做愛。為了確認各位的努力，今天來了很多客人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00011",
		linknext = "0086_00013",
		line = 153,
	},
	["0086_00013"] = {
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=2, loop=1, file="se_d023"},
		{"bg", id=3, file="bg17_1_1l_00000", x=100, y=150, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=3, act="移動", x=-205, y=-5, time=20000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tal y como dijo, una gran cantidad de personas se han presentado en la escuela.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正如学生会长所说，学校里的人潮多到无法置信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正如學生會長所說，學校裡的人潮多到無法置信。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00012",
		linknext = "0086_00014",
		line = 170,
	},
	["0086_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es más, decir eso es quedarme corto. Por donde sea que mire, hay montones de personas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"环顾四周，人、人、人——就连人山人海这个词都难以形容这个盛况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"環顧四周，人、人、人——就連人山人海這個詞都難以形容這個盛況。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00013",
		linknext = "0086_00015",
		line = 180,
	},
	["0086_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por lo que he oído, fue toda una pelea conseguir asientos. La OSS y la SS tuvieron que organizar un sorteo de boletos y repartirlos esta mañana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说为了争夺观众席还进行了抽签，今天早上FS和SHO共同发放了整理券。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說為了爭奪觀眾席還進行了抽籤，今天早上FS和SHO共同發放了整理券。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00014",
		linknext = "0086_00016",
		line = 190,
	},
	["0086_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No pensé que habría tanta gente, esto se anunció esta misma semana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是周一才发表的，但才短短几天就盛况空前——这情况并不寻常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是周一才發表的，但才短短幾天就盛況空前——這情況並不尋常。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00015",
		linknext = "0086_00017",
		line = 200,
	},
	["0086_00017"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=3, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=2, stop=1, time=2000},
		{"bg", id=2, file="bg17_1_1l_00000", x=0, y=100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="touka_01m_00004", file1="touka_01m_00107", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=-100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0660", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Y a nuestros distinguidos invitados, les agradezco sinceramente por venir a observar tan temprano en la mañana. Por favor, discúlpenme por hablar desde mi posición, pero les expreso mi más sincera gratitud.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“各位来宾，非常感谢你们一大早就前来参观。虽然是在高处，但我深表谢意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「各位來賓，非常感謝你們一大早就前來參觀。雖然是在高處，但我深表謝意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00016",
		linknext = "0086_00018",
		line = 217,
	},
	["0086_00018"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0661", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Las competencias comenzarán en breve. Es un gran placer para nosotros que puedan presenciar los frutos de nuestros esfuerzos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“马上，竞技就要开始了。我们平时努力的成果……请一定要",
					{"ruby", text="・・"},
					"亲自",
					{"/ruby"},
					"体验一下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「馬上，競技就要開始了。我們平時努力的成果……請一定要",
					{"ruby", text="・・"},
					"親自",
					{"/ruby"},
					"體驗一下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00017",
		linknext = "0086_00019",
		line = 229,
	},
	["0086_00019"] = {
		{"fg", file="touka_01m_00004", file1="touka_01m_00122", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=-100},
