				{"vo", file="misaki1003", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Incluso ahora, estar cerca de ella es muy tranquilizador.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“即使在这种时候，渡酱也能给我带来治愈啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「即使在這種時候，渡醬也能給我帶來治愈啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00038",
		linknext = "0086_00040",
		line = 549,
	},
	["0086_00040"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0259", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマン"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS"},
					"“¡Oigan! ¡¿Qué están haciendo?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫"},
					"“你们这些家伙！在干什么！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛"},
					"「你們這些傢伙！在幹什麼！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00039",
		linknext = "0086_00041",
		line = 561,
	},
	["0086_00041"] = {
		{"fg", file="hinami_01l_00004", file1="hinami_01l_00109", file2="hinami_01l_00202", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=-150},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=0, y=150, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2000", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? ¡Ah, p-perdón! ¡No estamos jugando! ¡T-Tachibana-kun no está haciendo nada!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……对、对不起！我们不是在玩……橘、橘同学没有错！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……對、對不起！我們不是在玩……橘、橘同學沒有錯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00040",
		linknext = "0086_00042",
		line = 576,
	},
	["0086_00042"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0260", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマン"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS"},
					"“¡¿De qué estás hablando?! Los niños no pueden estar aquí. ¡Es peligroso! ¡Ven conmigo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫"},
					"“你在说什么！小孩子在这种地方很危险啊！过来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛"},
					"「你在說什麼！小孩子在這種地方很危險啊！過來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00041",
		linknext = "0086_00043",
		line = 588,
	},
	["0086_00043"] = {
		{"fg", file="hinami_02m_00004", file1="hinami_02m_00114", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
