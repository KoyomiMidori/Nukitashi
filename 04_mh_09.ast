	["0086_00678"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course the one from team red competing with Onabuta is Hotori. What the hell did I expect?",
					{"rt2"},
				},
			},
			cn = {
				{
					"红组的女部田的竞争对手——正是畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"紅組的女部田的競爭對手——正是畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00677",
		linknext = "0086_00679",
		line = 9054,
	},
	["0086_00679"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1180", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I-I'm really sorry, Tachibana! To think we'd do something like this again...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我真的很抱歉橘同学……！又变成这样了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我真的很抱歉橘同學……！又變成這樣了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00678",
		linknext = "0086_00680",
		line = 9068,
	},
	["0086_00680"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1181", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It'll be fine this time, though! I'll just forfeit! There's no way I can compete with Onabuta, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过，这次没事的……！我会去弃权……因为不可能赢过身为FS的女部田同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過，這次沒事的……！我會去棄權……因為不可能贏過身為FS的女部田同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00679",
		linknext = "0086_00681",
		line = 9082,
	},
	["0086_00681"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hold on, you can't. Don't withdraw.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等等——不行，畔。不能弃权。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等等——不行，畔。不能棄權。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00680",
		linknext = "0086_00682",
		line = 9094,
	},
	["0086_00682"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1182", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Why can't I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦？为什么呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦？為什麼呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00681",
		linknext = "0086_00683",
		line = 9108,
	},
	["0086_00683"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00118", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為————」",
					{"rt2"},
				},
