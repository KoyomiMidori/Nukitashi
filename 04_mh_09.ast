		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hotori's keen, and Asa's covered that earlier blind spot. I'm sure it'll be fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔也很有干劲，麻沙酱也通过刚才的反省排除了死角——一定会顺利的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔也很有幹勁，麻沙醬也通過剛才的反省排除了死角——一定會順利的。」",
					{"rt2"},
				},
