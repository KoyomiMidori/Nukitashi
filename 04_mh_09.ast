			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“作为最后的竞技，除了推倒棒子没有更适合的了！棒虽然还是棒，但那可是能不断吐出精子，大家最喜欢的棒——也就是推倒肉棒！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「作為最後的競技，除了推倒棒子沒有更適合的了！棒雖然還是棒，但那可是能不斷吐出精子，大家最喜歡的棒——也就是推倒肉棒！」",
					{"rt2"},
				},
			},
		},
