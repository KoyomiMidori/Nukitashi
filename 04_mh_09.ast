				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't even escape, let alone counterattack.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有对抗的方法，就连逃跑都很困难。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有對抗的方法，就連逃跑都很困難。",
					{"rt2"},
