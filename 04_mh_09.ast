				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What? No! That's utterly ludicrous! I do more than anyone to set an example to the students by encouraging them to go forth and fuck diligently!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么——不是！怎么可能呢！我作为学生的模范，比任何人都勤奋地学习变态做爱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼——不是！怎麼可能呢！我作為學生的模範，比任何人都勤奮地學習變態做愛！」",
					{"rt2"},
				},
			},
		},
