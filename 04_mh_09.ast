	["0086_00887"] = {
		{"fg", file="misaki_01f_00004", file1="misaki_01f_00119", file2="misaki_01f_00204", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1100", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I'm not letting this once-in-a-lifetime opportunity slip through my fingers! I'm gonna retrieve that data now! Ugh... Aaugh!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这千载难逢的机会不能错过……现在，在这里……我要拿到数据！唔、哈啊啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這千載難逢的機會不能錯過……現在，在這裡……我要拿到數據！唔、哈啊啊……！」",
					{"rt2"},
				},
			},
		},
