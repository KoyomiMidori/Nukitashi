	},
	["0086_00604"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I run through the fucking frenzy, ignoring the cacophony of moans and squeals as I carry the swimsuit-clad Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在娇声和怪声的漩涡中，我抱着穿泳装的畔奔跑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在嬌喘和怪聲的漩渦中，我抱著穿泳裝的畔奔跑著。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00603",
		linknext = "0086_00605",
		line = 8077,
	},
	["0086_00605"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's a bit heavier than Asa, but not so much that I can't run while carrying her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和麻沙酱比起来确实挺重的————但也不至于抱着跑不动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和麻沙醬比起來確實挺重的————但也不至於抱著跑不動。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00604",
		linknext = "0086_00606",
		line = 8087,
	},
	["0086_00606"] = {
		{"fgact", id=6, ch="美岬", act="stopact"},
		{"fg", file="misaki_02ll_00004", file1="misaki_02ll_00119", file2="misaki_02ll_00204", path=":fg/misaki_02ll/", id=6, lv=5, head="misaki_02ll", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=-1, size=2.5, time=125, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1082", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ugh... I'm really, really sorry! You entrusted this to me, and I just went and ruined it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呜……真的、真的很对不起……！好不容易被托付了，但我……最终还是没有成功……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗚……真的、真的很對不起……！好不容易被託付了，但我……最終還是沒有成功……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00605",
		linknext = "0086_00607",
		line = 8102,
	},
	["0086_00607"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What're you talking about? You managed to get the SS card, didn't you? You did good.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在说什么？你不是拿到FS的卡了吗？干得很好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你在說什麼？你不是拿到FS的卡了嗎？幹得很好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00606",
		linknext = "0086_00608",
		line = 8113,
	},
	["0086_00608"] = {
		{"fgact", id=6, ch="美岬", act="stopact"},
		{"fg", file="misaki_02ll_00004", file1="misaki_02ll_00117", file2="misaki_02ll_00204", path=":fg/misaki_02ll/", id=6, lv=5, head="misaki_02ll", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=-1, size=2.5, time=125, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
