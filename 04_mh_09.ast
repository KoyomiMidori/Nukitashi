		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2014", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh!? So... Rei and the SS are looking for Fumino, too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶！这么说来……礼酱她们也在找叫文乃的女孩吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸！這麼說來……禮醬她們也在找叫文乃的女孩嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01034",
		linknext = "0086_01036",
		line = 13842,
	},
	["0086_01036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's hard to imagine that it's someone with the exact same name by coincidence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"偶然同名同姓——这几率太小。",
					{"rt2"},
				},
			},
			tw = {
				{
					"偶然同名同姓——這機率太小。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01035",
		linknext = "0086_01037",
		line = 13852,
	},
	["0086_01037"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2013", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hey, Jun, check this out. Look who gave the order to secure Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“比起那个，淳，这个……发出文乃抓捕命令的人是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「比起那個，淳，這個……發出文乃抓捕命令的人是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01036",
		linknext = "0086_01038",
		line = 13864,
	},
	["0086_01038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look at the document and when I see the name on it, I catch my breath.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听了奈奈濑的话后，我发现文书上写的名字——不禁倒吸了一口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽了奈奈瀨的話後，我發現文書上寫的名字——不禁倒吸了一口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01037",
		linknext = "0086_01039",
		line = 13874,
	},
	["0086_01039"] = {
