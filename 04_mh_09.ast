		},
		linkback = "0086_01103",
		linknext = "0086_01105",
		line = 14821,
	},
	["0086_01105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe it's a leftover from the 3000 Hotoris who were in my head last night.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是因为昨晚数过的3000人的畔还留在脑内吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是因為昨晚數過的3000人的畔還留在腦內嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01104",
		linknext = "0086_01106",
		line = 14831,
	},
	["0086_01106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why did I climax from Hotori instead of Onabuta during the pole topple?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——推倒棒子的时候，为什么不是女部田，而是靠畔达到高潮呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"——推倒棒子的時候，為什麼不是女部田，而是靠畔達到高潮呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01105",
		linknext = "0086_01107",
		line = 14841,
	},
	["0086_01107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Onabuta's technique was lightyears ahead of Hotori. It really was an upset.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从技术上来说，女部田毫无疑问遥遥领先畔。",
