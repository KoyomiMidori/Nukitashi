	["0086_01087"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="misaki_01m_00001", file2="misaki_01m_00204", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1124", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, never mind! I'm sorry for asking! I just thought that maybe there was the slightest chance that... uh... No, please, just forget it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，不不！被问了这种问题会很困扰对吧！我只是觉得‘说不定……’之类的，所以请忘记吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，不不！被問了這種問題會很困擾對吧！我只是覺得『說不定……』之類的，所以請忘記吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01086",
		linknext = "0086_01088",
		line = 14512,
	},
	["0086_01088"] = {
