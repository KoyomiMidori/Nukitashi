			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No way! How!? I didn't detect him coming in... shit! There's a blind spot on the stairs by the front entrance! He must've come from there!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么会，为什么……什么反应也……啊……！正面玄关方向的楼梯是摄像头的死角……难道是从那里……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼會，為什麼……什麼反應也……啊……！正面玄關方向的樓梯是攝影機的死角……難道是從那裡……！？」",
					{"rt2"},
				},
			},
		},
