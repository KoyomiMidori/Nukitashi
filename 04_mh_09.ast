		{"fg", file="jun_01f_00004", file1="jun_01f_00122", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No time for sex!? Did the disciplinary committee president really just say that!? So controversial, yet so brave!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是做爱的时候！？作为风纪委员长居然会这么说……这是问题发言哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是做愛的時候！？作為風紀委員長居然會這麼說……這是問題發言哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00922",
		linknext = "0086_00924",
		line = 12308,
	},
	["0086_00924"] = {
