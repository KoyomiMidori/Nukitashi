		line = 39,
	},
	["0086_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es una escena muy rara de ver en la Isla Seiran.",
