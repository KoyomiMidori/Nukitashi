					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I-I'm not heavy, am I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不、不重吗……？”",
					{"rt2"},
