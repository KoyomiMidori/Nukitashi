		text = {
			vo = {
				{"vo", file="misaki1130", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, this is Chuuya. Since you left to go back home, I've been stewing on my feelings but haven't been able to figure anything out. I thought maybe smashing something would help me sort things out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……这孩子是中也先生。橘同学走后，我觉得心情很欲闷，感情无处发泄……就想说好久没骑车了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……這孩子是中也先生。橘同學走後，我覺得心情很欲悶，感情無處發洩……就想說好久沒騎車了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01159",
		linknext = "0086_01161",
		line = 15734,
	},
	["0086_01161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I didn't know you could ride a motorbike.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你会骑摩托车的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你會騎摩托車的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01160",
		linknext = "0086_01162",
		line = 15746,
	},
	["0086_01162"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00126", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1131", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, they have an engine just like a car does, so it's the same principle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“就像有引擎的自行车一样……诀窍是一样的哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就像有引擎的自行車一樣……訣竅是一樣的哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01161",
		linknext = "0086_01163",
		line = 15760,
	},
	["0086_01163"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't think that's how it works.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我觉得绝对不是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我覺得絕對不是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01162",
		linknext = "0086_01164",
		line = 15772,
	},
	["0086_01164"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00102", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1132", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Still, f-for us to run into each other, it must be fate, right? So I'll give you a ride home! I'll be fine going back if Chuuya's with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过……我觉得这样再次见面也是某种缘分，所以就送你回家吧！只要中也先生在，我一个人也没事的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過……我覺得這樣再次見面也是某種緣分，所以就送你回家吧！只要中也先生在，我一個人也沒事的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01163",
		linknext = "0086_01165",
		line = 15786,
	},
	["0086_01165"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不好意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不好意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01164",
		linknext = "0086_01166",
		line = 15798,
	},
	["0086_01166"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00110", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1133", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You don't need to thank me. I'm happy I was able to find you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“说什么不好意思……对我来说，还不如说是好事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「說什麼不好意思……對我來說，還不如說是好事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01165",
		linknext = "0086_01167",
		line = 15812,
	},
	["0086_01167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“R-Really?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01166",
		linknext = "0086_01168",
		line = 15824,
	},
	["0086_01168"] = {
		{"fg", file="misaki_01l_00001", file2="misaki_01l_00204", file3="misaki_01l_00307", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1134", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, ahahaha! Wh-What am I saying!? Hyuck hyuck hyuck hyuck...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……啊哈哈哈！我、我到底在说什么呢！？诶嘿嘿嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……啊哈哈哈！我、我到底在說什麼呢！？欸嘿嘿嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01167",
		linknext = "0086_01169",
		line = 15838,
	},
	["0086_01169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I-I know, right! Hahaha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真、真是的！哈哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真、真是的！哈哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01168",
		linknext = "0086_01170",
		line = 15850,
	},
	["0086_01170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I give her an empty smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我脸上浮现出干巴巴的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我臉上浮現出乾巴巴的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01169",
		linknext = "0086_01171",
		line = 15860,
	},
	["0086_01171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The conversation dies down, and all that can be heard is the sound of Chuuya's engine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"沉默下来后，只有中也的驱动声呜呜呜地响着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沉默下來後，只有中也的驅動聲嗚嗚嗚地響著。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01170",
		linknext = "0086_01172",
		line = 15870,
	},
	["0086_01172"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00107", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The setting sun, half hidden behind the hills, makes Hotori's cheeks seem to glow red.",
					{"rt2"},
				},
			},
			cn = {
				{
					"半边埋在山中的晚霞，将畔的脸颊染得通红。",
					{"rt2"},
				},
			},
			tw = {
				{
					"半邊埋在山中的晚霞，將畔的臉頰染得通紅。",
					{"rt2"},
				},
			},
		},
