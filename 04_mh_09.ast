	["0086_00423"] = {
		{"se", id=0, loop=0, file="se_c002"},
		{"fg", file="asane_01f_00002", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1348", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wait... bandits detected at school building front entrance. Two groups, five and seven. Sooner than expected. They're coming in from the courtyard.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呜……出入口和正面玄关，教学楼内确认敌性器的侵入……数量分别为5和7。比预期要快……操场上的人涌进来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗚……出入口和正面玄關，校舍內確認敵性器的侵入……數量分別為5和7。比預期要快……操場上的人湧進來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00422",
		linknext = "0086_00424",
		line = 5751,
	},
	["0086_00424"] = {
