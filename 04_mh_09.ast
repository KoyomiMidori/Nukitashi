					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "混蛋處男"},
					"「這個島上的女人，都是婊子……但剛才在借物競賽中看到了你……我想如果是這個女孩子的話……如果是她的話，說不定會是我的命運之人呢……」",
					{"rt2"},
				},
			},
		},
