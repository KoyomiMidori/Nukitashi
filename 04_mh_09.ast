	},
	["0086_01061"] = {
		{"bg", id=1, file="bg10_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1114", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Thanks for taking me this far. Um, take care on your way home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“谢谢你送我回家。那么……回去的路上请小心点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「謝謝你送我回家。那麼……回去的路上請小心點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01060",
		linknext = "0086_01062",
		line = 14185,
	},
	["0086_01062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Make sure you get plenty of rest tonight. See you later.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好。畔也是，今天好好休息吧……那我走了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好。畔也是，今天好好休息吧……那我走了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01061",
		linknext = "0086_01063",
		line = 14197,
	},
	["0086_01063"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I turn around to head home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我转身准备回家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我轉身準備回家。",
