	},
	["0086_01040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everyone living on Seiran Island knows that name.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要是住在青蓝岛的人，谁都知道这个名字。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要是住在青藍島的人，誰都知道這個名字。",
