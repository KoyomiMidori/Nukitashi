		},
		linkback = "0086_01022",
		linknext = "0086_01024",
		line = 13678,
	},
	["0086_01024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, yeah... I dunno. Hey, Asa! How's your progress?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……是怎样呢。喂麻沙酱！你的进展怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……是怎樣呢。喂麻沙醬！你的進展怎麼樣？」",
					{"rt2"},
				},
			},
		},
