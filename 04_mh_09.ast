	["0086_00609"] = {
		{"fgact", id=6, ch="美岬", act="stopact"},
		{"bg", id=3, file="bg17_1_1_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_02l_00004", file1="misaki_02l_00117", file2="misaki_02l_00204", path=":fg/misaki_02l/", id=6, lv=5, head="misaki_02l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=2, file="bg17_1_1l_00000", x=345, y=-5, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="jun_01f_00004", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, when's our next window of opportunity for that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——麻沙酱，下一个可以去的时机是？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——麻沙醬，下一個可以去的時機是？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00608",
		linknext = "0086_00610",
		line = 8144,
	},
	["0086_00610"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1360", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“We'll be cutting it close, but I'd say the closing ceremony. The students will all be lined up in the courtyard, so security inside should be pretty lax.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然相当紧凑……但应该是闭幕式吧……当全校学生在操场排队时，教学楼内应该人很少……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然相當緊湊……但應該是閉幕式吧……當全校學生在操場排隊時，校舍內應該人很少……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00609",
		linknext = "0086_00611",
		line = 8157,
	},
	["0086_00611"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There you go. Hotori, can you do that for us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——就是这样。畔……还能努力吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——就是這樣。畔……還能努力嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00610",
		linknext = "0086_00612",
		line = 8169,
	},
	["0086_00612"] = {
		{"fg", file="misaki_01l_00004", file1="misaki_01l_00104", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1084", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah... Y-Yes! Leave it to me! There's nothing in the world I wouldn't do for you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……是、是的！请交给我！如果是为了橘同学，我一定都会加油的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……是、是的！請交給我！如果是為了橘同學，我一定都會加油的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00611",
		linknext = "0086_00613",
		line = 8183,
	},
	["0086_00613"] = {
		{"fg", file="misaki_01l_00004", file1="misaki_01l_00111", file2="misaki_01l_00205", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1085", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“UM! S-S-Sorry, I said a bit too much... c-can you pretend you didn't hear that!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……啊！对、对不起不小心说了真心话……请当做没听到……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……啊！對、對不起不小心說了真心話……請當做沒聽到……！」",
