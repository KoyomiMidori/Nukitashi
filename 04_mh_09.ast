	["0086_01021"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00113", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When our eyes meet, we both avert our gazes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"目光交汇，彼此都移开了视线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"目光交匯，彼此都移開了視線。",
					{"rt2"},
