					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Niños? P-Pero si estoy en tercer año... Oigan... ¡Chicos, digan algo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“小孩子！？我、我可是3年级生……啊，喂……大家也说点什么啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「小孩子！？我、我可是3年級生……啊，喂……大家也說點什麼啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00042",
		linknext = "0086_00044",
		line = 604,
	},
	["0086_00044"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
