					"“Of course, you do plan to accept my little challenge, right? Or are you afraid of me making you cum? Don't you have any confidence in that girl there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“和我的胜负，你当然会接受吧？还是说你害怕被弄到高潮？那个女孩当你的同伴你会感到不安吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「和我的勝負，你當然會接受吧？還是說你害怕被弄到高潮？那個女孩當你的同伴你會感到不安嗎？」",
					{"rt2"},
				},
			},
		},
