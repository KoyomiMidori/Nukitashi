				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡Felicidades, participantes! ¡La primera prueba, la carrera de obstáculos, es una prueba selectiva!”",
					{"rt2"},
				},
			},
			cn = {
