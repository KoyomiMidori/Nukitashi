		linkback = "0086_01062",
		linknext = "0086_01064",
		line = 14210,
	},
	["0086_01064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Holy shit, that was awkward. The whole time, we just couldn't look each other in the eye. I think it was even worse at the end than it was when we left.",
					{"rt2"},
				},
			},
			cn = {
				{
					"惨了。到最后气氛都没有缓和，应该说变得更尴尬了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"慘了。到最後氣氛都沒有緩和，應該說變得更尷尬了。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01063",
		linknext = "0086_01065",
		line = 14220,
	},
	["0086_01065"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What the hell am I supposed to say to her next time we see each other?",
					{"rt2"},
				},
			},
			cn = {
				{
					"下次见面时，该用什么表情呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"下次見面時，該用什麼表情呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01064",
		linknext = "0086_01066",
		line = 14231,
	},
	["0086_01066"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00104", file2="misaki_01f_00201", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1115", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um... Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……橘同学。”",
					{"rt2"},
