	["0086_01027"] = {
		{"bgm", stop=1},
		{"fg", file="asane_01m_00002", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1370", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well, there's info on all the students from the B- and A-level classes. There isn't anyone named Kotoyose Fumino on the list, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“B等部和A等部……所有学生的资料都在里面……然后，从结论开始说的话……没有叫琴寄文乃的学生……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「B等部和A等部……所有學生的資料都在裡面……然後，從結論開始說的話……沒有叫琴寄文乃的學生……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01026",
		linknext = "0086_01028",
		line = 13738,
	},
	["0086_01028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We all catch our breaths and fall into silence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱的话，让现场转成一片令人窒息的沉默。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬的話，讓現場轉成一片令人窒息的沉默。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01027",
		linknext = "0086_01029",
		line = 13748,
	},
	["0086_01029"] = {
		{"bgm", file="bgm04.5", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, that's fine. Nanase was already told that by a teacher when she tried asking, so that checks out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——不对，没关系。“琴寄文乃”这个名字的学生不在学校里是预料之中的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——不對，沒關係。「琴寄文乃」這個名字的學生不在學校裡是預料之中的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01028",
		linknext = "0086_01030",
		line = 13759,
	},
	["0086_01030"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, other than info on Fumino herself, did you find anything else connected to her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱。除了‘文乃’本人——有和文乃有关系的线索吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬。除了『文乃』本人——有和文乃有關係的線索嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01029",
		linknext = "0086_01031",
		line = 13770,
	},
	["0086_01031"] = {
