			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Really? She doesn't seem worried at all about people seeing her abdomen today. Isn't that unusual for her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“才没有那种事。她平常会更在意肚子或其他的什么事情……但今天却什么也没说不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「才沒有那種事。她平常會更在意肚子或其他的什麼事情……但今天卻什麼也沒說不是嗎？」",
					{"rt2"},
