			vo = {
				{"vo", file="ikuko0263", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"非表示", "郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Ikuko"},
					"“But I'm better. No matter how many shots they take, they won't... ugh, huh!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "郁子"},
					"“但是这对郁酱来说是行不通的哦。不管开多少枪，都绝对———唔、呀啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "郁子"},
					"「但是這對郁醬來說是行不通的哦。不管開多少槍，都絕對———唔、呀啊！？」",
					{"rt2"},
				},
			},
		},
