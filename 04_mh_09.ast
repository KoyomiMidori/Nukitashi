		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Following Asane's directions, I make my way toward the second-year third class.",
					{"rt2"},
				},
			},
			cn = {
				{
					"按照麻沙音酱的指示，首先以2年3班为目标。",
