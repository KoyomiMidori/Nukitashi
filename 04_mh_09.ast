					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh... Don't tell me! You must be part of that Anti-Copulation Front I've been hearing so much about!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……难道——最近成为话题的反交尾势力，该不会就是指委员长吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……難道——最近成為話題的反交尾勢力，該不會就是指委員長吧！？」",
