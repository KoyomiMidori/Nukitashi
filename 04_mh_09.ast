	},
	["0086_01041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The perverted sex law that we're fighting is a product of the current prefectural governor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们应该摧毁的变态条例——就是始于现在还在做县知事的一个男人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們應該摧毀的變態條例——就是始於現在還在做縣知事的一個男人。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_01040",
		linknext = "0086_01042",
		line = 13906,
	},
