				{"fg", file="hinami_02m_00004", file1="hinami_02m_00116", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=7000, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1998", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Bien! ¡Animemos a todos! Ngh... ¡nnngh...! ¡Ay, no puedo ver!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是啊！要为大家加油才行……嗯——！嗯——看不见啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是啊！要為大家加油才行……嗯——！嗯——看不見啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00035",
		linknext = "0086_00037",
		line = 500,
	},
	["0086_00037"] = {
