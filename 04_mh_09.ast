	["0086_00086"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00113", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh... Prefiero ser parte de un ciempiés humano, pero tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶——虽然非常不想做……但迫不得已啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡——雖然非常不想做……但迫不得已啊。」",
					{"rt2"},
				},
