					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Y-You dunce! Cocks can't speak! Stop using that creepy falsetto voice!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“开、开什么玩笑！小鸡鸡怎么会说话！别发出那恶心的声音了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「開、開什麼玩笑！小雞雞怎麼會說話！別發出那噁心的聲音了！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00980",
		linknext = "0086_00982",
		line = 13045,
	},
	["0086_00982"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Creepy, you say? How unkind of you to mock Our voice...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说鸡的声音恶心真是伤心啊巴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說雞的聲音噁心真是傷心啊巴……」",
