		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a huge responsibility, but since they entrusted it to me, it's up to me to make sure it succeeds.",
					{"rt2"},
				},
			},
			cn = {
				{
					"责任重大……但是，既然把赌注下在了我身上，那我一定要成功。",
					{"rt2"},
				},
			},
			tw = {
				{
					"責任重大……但是，既然把賭注下在了我身上，那我一定要成功。",
