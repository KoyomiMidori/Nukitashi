	["0054_00245"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She nervously curls up, visibly shaken by a stranger trying to talk to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许是因为突然被搭话，女孩战战兢兢地缩起身子。",
					{"rt2"},
