	["0054_00173"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0042", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“¡Maldita sea! ¿Cómo pude dejar escapar una oportunidad tan grande? ¡Tú, búscalo por ahí! ¡Yo iré por aquí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“可恶……好不容易找到的大猎物，可不能眼睁睁地看着被别人……你们去那边！我去这边找！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「可惡……好不容易找到的大獵物，可不能眼睜睜地看著被別人……你們去那邊！我去這邊找！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00172",
		linknext = "0054_00174",
		line = 2398,
	},
	["0054_00174"] = {
