	["0054_00238"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0843", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Is that girl over there okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦……那孩子，怎么了呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦……那孩子，怎麼了呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00237",
		linknext = "0054_00239",
		line = 3289,
	},
	["0054_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I take a look and see a girl way tinier than Wata standing in the middle of the street, looking rather distressed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一看——比渡酱还小一圈的女孩子站在路边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一看——比渡醬還小一圈的女孩子站在路邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00238",
		linknext = "0054_00240",
		line = 3299,
	},
	["0054_00240"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's kinda looking around every which way... Maybe she's lost?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么回事……她四处张望着……可能是迷路了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼回事……她四處張望著……可能是迷路了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00239",
		linknext = "0054_00241",
		line = 3311,
	},
	["0054_00241"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
