				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me retiro en silencio mientras todos hacen la reverencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正当大家低着头的时候，我悄悄地逃到了走廊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正當大家低著頭的時候，我悄悄地逃到了走廊。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00002",
