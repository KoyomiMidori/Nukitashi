		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=400},
		{"se", id=0, loop=0, file="se_a073"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
