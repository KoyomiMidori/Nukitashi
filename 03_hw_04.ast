		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0843", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? ¿Esa chica estará bien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦……那孩子，怎么了呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦……那孩子，怎麼了呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00237",
		linknext = "0054_00239",
		line = 3289,
	},
	["0054_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Veo a una chica mucho más pequeña que Wata-chan parada en medio de la calle, se le ve bastante angustiada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一看——比渡酱还小一圈的女孩子站在路边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一看——比渡醬還小一圈的女孩子站在路邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00238",
		linknext = "0054_00240",
		line = 3299,
	},
	["0054_00240"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
