			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“¿Hay espacio para una más?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我可以坐你旁边吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「我可以坐你旁邊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00179",
		linknext = "0054_00181",
		line = 2490,
	},
	["0054_00181"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Eh?! ¡¿Cómo sabías que estaba aquí?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“！？你……为什么知道这里——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「！？你……為什麼知道這裡——」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00180",
		linknext = "0054_00182",
		line = 2502,
	},
	["0054_00182"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0044", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Jaa... Ay, piénsalo un segundo. Es imposible que hayas llegado tan lejos tan rápido. Deja de pensar que la SS es un arrejuntes de monos sin cerebro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“唉……请冷静地想想吧。在这么短的时间内，要逃到哪里是不可能的。真是的，FS中到处都是满脑肌肉的大猩猩，真让人困扰啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「唉……請冷靜地想想吧。在這麼短的時間內，要逃到哪裡是不可能的。真是的，FS中到處都是滿腦肌肉的大猩猩，真讓人困擾啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00181",
		linknext = "0054_00183",
		line = 2514,
	},
	["0054_00183"] = {
