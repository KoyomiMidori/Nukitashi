		{"extrans", sync=0, time=400, rule="eff_033_00000"},
		{"se", id=0, loop=0, file="se_a137"},
		{"ex", time=1000, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0036", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Profe Minase"},
					"“Así concluye la clase de hoy. Estoy libre el resto del día, así que cualquiera que necesite un coño, que se acerque. Estoy dispuesta a atender hasta ocho a la vez. ¿Quieres hacer los honores, Hanamaru-san?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“今天的班会就到此为止了。老师今天有空，想要小穴的人请到前面来。可以同时8个人。那么……花丸同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「今天的班會就到此為止了。老師今天有空，想要小穴的人請到前面來。可以同時8個人。那麼……花丸同學。」",
					{"rt2"},
				},
			},
		},
		linknext = "0054_00002",
		line = 21,
	},
	["0054_00002"] = {
		{"bg", id=1, file="bg14_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
