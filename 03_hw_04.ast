	["0054_00224"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[7500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=7500, time=300, mode=3, x=0, y=0},
			},
			[11500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=11500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0839", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Aun así, me alegra mucho que estés bien... Me salvaste, así que te debo las gracias. Debería recompensarte, pero... los besos siguen estando prohibidos, ¿verdad? Haré lo de siempre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过，你没事真是太好了啊……谢谢你帮我，橘君。为了表示感谢……呃，亲亲是不行的对吧。那样的话，就像往常一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過，你沒事真是太好了啊……謝謝你幫我，橘君。為了表示感謝……呃，親親是不行的對吧。那樣的話，就像往常一樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00223",
		linknext = "0054_00225",
		line = 3080,
	},
	["0054_00225"] = {
