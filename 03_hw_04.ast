					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Looks kinda shy, doesn't she...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好像是个相当内向的孩子呢……”",
