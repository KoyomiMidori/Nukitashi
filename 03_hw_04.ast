	["0054_00243"] = {
		{"se", id=0, stop=1, time=1000},
		{"bg", id=2, file="bg09_1l_00000", x=-300, y=50, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0845", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Holi. Es muy raro ver a alguien sola por aquí. ¿Pasó algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你好，很少有人自己在这种地方呢，你怎么了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你好，很少有人自己在這種地方呢，你怎麼了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00242",
		linknext = "0054_00244",
		line = 3354,
	},
	["0054_00244"] = {
		{"text"},
