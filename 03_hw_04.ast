	},
	["0054_00197"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0048", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Jeje, ya se está poniendo durita. Tengo muchas más técnicas poco ortodoxas bajo la manga, pero me temo que tengo poco tiempo... así que, ¿qué tal si pasamos directamente a mi coño?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“呵呵，已经开始勃起了呢……虽然作为射精管理这是邪道的手段，不过因为没有时间了……所以从一开始就请让我用小穴吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「呵呵，已經開始勃起了呢……雖然作為射精管理這是邪道的手段，不過因為沒有時間了……所以從一開始就請讓我用小穴吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00196",
		linknext = "0054_00198",
		line = 2712,
	},
	["0054_00198"] = {
		{"se", id=0, loop=0, file="se_c012"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
