					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ユキ", "有希"},
					"「媽媽和山本君的爸爸開始做愛……因為到結束前都很無聊所以去抓蟲子了，然後就不知道走到哪裡了……」",
					{"rt2"},
				},
			},
		},
