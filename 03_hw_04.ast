	["0054_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I really can't stand to see her on the verge of tears like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着吸着鼻子的渡酱，我的心情变得无比沉重。",
