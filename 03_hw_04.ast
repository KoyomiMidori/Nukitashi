			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Entendido! ¡Ah, disculpa! ¿Puedo preguntarte algo rápido?”",
