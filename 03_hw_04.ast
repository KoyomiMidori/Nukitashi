		line = 4635,
	},
	["0054_00336"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not long after that, we found Yuki's mom.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后，我们马上发现了有希的妈妈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那之後，我們馬上發現了有希的媽媽。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00335",
		linknext = "0054_00337",
		line = 4645,
	},
	["0054_00337"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She'd been looking for her daughter as well, so she had a couple of OSS officers in tow, who promptly arrested both men on the spot. All's well that ends well, I suppose.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她妈妈好像也在找有希，而且正好和SHO在一起，所以两个男人的处理也就交给他们了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她媽媽好像也在找有希，而且正好和SHO在一起，所以兩個男人的處理也就交給他們了。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00336",
		linknext = "0054_00338",
		line = 4655,
	},
	["0054_00338"] = {
		{"bgm", file="bgm21", vol=100},
		{"bg", id=1, file="bg09_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0860", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I'm so sorry... I put you in danger again, all because I can't fend for myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对不起，橘君……因为我没有好好注意才让你再次陷入危险……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對不起，橘君……因為我沒有好好注意才讓你再次陷入危險……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00337",
		linknext = "0054_00339",
		line = 4670,
	},
	["0054_00339"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you talking about? It's my fault for being away for too long.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你在说什么？这是离开了的我的责任。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你在說什麼？這是離開了的我的責任。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00338",
		linknext = "0054_00340",
		line = 4682,
	},
	["0054_00340"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0861", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, it isn't. I'm trying to be someone who can be looked up to... but I couldn't stop Yuki from having a really scary experience.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那种事……明明作为前辈的我必须更注意一点才行，但却让有希遇到了可怕的遭遇……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那種事……明明作為前輩的我必須更注意一點才行，但卻讓有希遇到了可怕的遭遇……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00339",
		linknext = "0054_00341",
		line = 4696,
	},
