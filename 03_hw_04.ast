	["0054_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Qué hago ahora? Mi oponente está armada y ya no tengo huevos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么办——？对方有枪，EGG也用完了。",
