	["0054_00171"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0041", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Ugh, no te vas a... ¡alejar! Maldito lolicon degenerado... ¡¿Dónde se metió?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“喂，别让他跑了……不在！？狡猾的萝莉控……到底跑到哪里去了……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「喂，別讓他跑了……不在！？狡猾的蘿莉控……到底跑到哪裡去了……！？」",
					{"rt2"},
				},
