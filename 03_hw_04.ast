				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No podemos quedarnos de brazos cruzados. Tenemos que hacer algo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种状况不能放任不管——必须想办法……”",
