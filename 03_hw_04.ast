	["0054_00331"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Imbécil, hacerle algo a una niña en esta isla está estrictamente prohibido. ¿Me vas a explicar lo que estabas haciendo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂……就算是青蓝岛，也严禁对小孩下手。你为什么要这样做？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂……就算是青藍島，也嚴禁對小孩下手。你為什麼要這樣做？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00330",
		linknext = "0054_00332",
		line = 4555,
	},
	["0054_00332"] = {
		{"text"},
		text = {
