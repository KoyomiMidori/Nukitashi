		text = {
			vo = {
				{"vo", file="hinami0809", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿En serio? Jeje... ¡De ser así, quizás no me traten como una niña cuando vuelva al edificio B!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的吗？诶嘿嘿……那样的话，这次就算我去了B等部也不会被当成小孩子对待了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的嗎？欸嘿嘿……那樣的話，這次就算我去了B等部也不會被當成小孩子對待了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00018",
		linknext = "0054_00020",
		line = 253,
	},
	["0054_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Creo que eso no viene al caso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这又是另一回事吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這又是另一回事吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00019",
		linknext = "0054_00021",
		line = 265,
	},
	["0054_00021"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0810", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿POR QUÉ! ¡¿No que ya era una adulta responsable?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“为什么！你明明说我像姐姐！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「為什麼！你明明說我像姐姐！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00020",
		linknext = "0054_00022",
		line = 280,
	},
	["0054_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es que... es complicado...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……你问我为什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……你問我為什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00021",
		linknext = "0054_00023",
		line = 291,
	},
	["0054_00023"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0811", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Urrgh... ¿Es porque no tengo tetas? ¡Estúpidas tetas inexistentes! ¡¿De verdad necesito tetazas para engañarlos o qué?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜呜呜……是胸吗……？果然是胸吧……！因为是贫乳所以不行吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚嗚嗚……是胸嗎……？果然是胸吧……！因為是貧乳所以不行嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00022",
		linknext = "0054_00024",
		line = 305,
	},
	["0054_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es tanto un problema de tetas, sino más bien un problema de todo su físico... pero sé que no debo decírselo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与其说是胸部，倒不如说是整体的问题——但如果说出口，她可能会更加消沉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與其說是胸部，倒不如說是整體的問題——但如果說出口，她可能會更加消沉。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00023",
		linknext = "0054_00025",
		line = 315,
	},
	["0054_00025"] = {
		{"text"},
		delay = {
			[2200] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=2200, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0812", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Grrr... Conque en esas estamos... ¡Tachibana-kun! ¡Tócalas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……那样的话……橘君！给我揉揉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……那樣的話……橘君！給我揉揉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00024",
		linknext = "0054_00026",
		line = 329,
	},
	["0054_00026"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啥……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啥……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00025",
		linknext = "0054_00027",
		line = 342,
	},
	["0054_00027"] = {
		{"bgm", file="bgm25", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0813", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Se supone que las tetas se hacen más grandes cuando un chico las toca! ¡Lo dijeron en la tele! ¡Por eso es que todas las chicas tienen unas tetazas y yo no!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我在电视上看到过，说让男孩子摸胸的话胸会变大！大家都是巨乳就我是贫乳，一定是因为这个原因！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我在電視上看到過，說讓男孩子摸胸的話胸會變大！大家都是巨乳就我是貧乳，一定是因為這個原因！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00026",
		linknext = "0054_00028",
		line = 355,
	},
	["0054_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A ver... Estoy seguro de que solo es un cuento de viejas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，是这样的吗……而且，揉了就会变大这不过是迷信罢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，是這樣的嗎……而且，揉了就會變大這不過是迷信罷了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00027",
		linknext = "0054_00029",
		line = 367,
	},
	["0054_00029"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0814", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero hay gente en este mundo que quiere creer en cuentos de viejas, ¿sabes...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“就算是迷信也想试一试……世界上就是会有这样的人哦……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「就算是迷信也想試一試……世界上就是會有這樣的人哦……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00028",
		linknext = "0054_00030",
		line = 381,
	},
	["0054_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Increíble. Nunca pensé que la escucharía decir algo tan deprimente, pero es digno de una mujer adulta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"悲哀的是——这句话，是我至今为止听过的渡酱最像大人的发言了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"悲哀的是——這句話，是我至今為止聽過的渡醬最像大人的發言了。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00029",
		linknext = "0054_00031",
		line = 391,
	},
	["0054_00031"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0815", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Sea como sea, me las vas a frotar y harás que crezcan! ¡Tu senpai te lo ordena! ¡Tenemos que garantizar el éxito de nuestra infiltración a como dé lugar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“所以说，橘君把我揉大吧！这是前辈的命令！也是为了让作战成功！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「所以說，橘君把我揉大吧！這是前輩的命令！也是為了讓作戰成功！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00030",
		linknext = "0054_00032",
		line = 405,
	},
	["0054_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿En serio...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了作战——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了作戰——？",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00031",
		linknext = "0054_00033",
		line = 415,
	},
	["0054_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pues si me lo plantea así... no puedo decirle que no, ¿verdad?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是这样的话，就没办法了……吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是這樣的話，就沒辦法了……嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00032",
		linknext = "0054_00034",
		line = 425,
	},
	["0054_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Además, ya la he tocado antes... cuando se quedó atascada en el Mural de Culos. No es para tanto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我之前，也在她陷进壁尻体的时候摸了一下……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我之前，也在她陷進壁尻體的時候摸了一下……",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00033",
		linknext = "0054_00035",
		line = 435,
	},
	["0054_00035"] = {
