		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=19, file="whiteback_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=1, alpha=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La Hanamaru menpr se mete conmigo en el casillero como si tuviera una invitación abierta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸妹妹理所当然地进到了柜子里面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"花丸妹妹理所當然地進到了櫃子裡面。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00182",
		linknext = "0054_00184",
		line = 2559,
	},
	["0054_00184"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0045", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Pero debería darte las gracias... Ahora puedo atribuirme todo el mérito por esta pequeña captura. Bien... Vamos a enderezar tu polla desquiciada, ¿te parece?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“但是这次真是谢谢大家……多亏了大家我才能独占功劳。那么……那个叛逆的小鸡鸡，让我带它去花丸街道吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「但是這次真是謝謝大家……多虧了大家我才能獨占功勞。那麼……那個叛逆的小雞雞，讓我帶它去花丸街道吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00183",
		linknext = "0054_00185",
		line = 2571,
	},
	["0054_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apenas puedo moverme con lo estrecho que es el casillero con los dos adentro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被压进狭窄储物柜的我，动弹不得。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被壓進狹窄儲物櫃的我，動彈不得。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00184",
		linknext = "0054_00186",
		line = 2581,
	},
	["0054_00186"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con una sonrisa enormemente satisfecha, me baja los pantalones y...",
					{"rt2"},
				},
			},
			cn = {
				{
					"趁这个机会，小巧的花丸妹妹把我的裤子给脱了，然后下面也——",
					{"rt2"},
				},
			},
			tw = {
				{
					"趁這個機會，小巧的花丸妹妹把我的褲子給脫了，然後下面也——",
					{"rt2"},
				},
			},
		},
