	["0054_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The walk back home tonight feels gloomier than usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回家的空气比以往任何时候都沉重。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回家的空氣比以往任何時候都沉重。",
