			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“E-Está bien, lo entiendo, haré lo que digam... ¡pero por favor, no disparen!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我明白了……我会按照你说的去做！所以不要开枪……！”",
