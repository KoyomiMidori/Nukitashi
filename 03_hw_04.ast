					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, all thanks to you. She's completely regained her appetite, and she pretty much scarfed down her supper.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，托你的福。好像也有食欲了，还吃了晚饭。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，託你的福。好像也有食慾了，還吃了晚飯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00014",
		linknext = "0054_00016",
		line = 199,
	},
	["0054_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She felt well enough to make it to school today as well. You really were a big help.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天感觉状态不错，所以也来学校了。多亏了渡酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天感覺狀態不錯，所以也來學校了。多虧了渡醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00015",
