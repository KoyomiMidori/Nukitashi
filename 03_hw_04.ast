	["0054_00013"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Walking side-by-side with her really does show off just how big the juxtaposition between her and the other students is. What with her being so teeny and loli-ish.",
					{"rt2"},
				},
			},
			cn = {
