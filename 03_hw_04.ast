		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Corre hacia su silla plegable y la coloca frente a mí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说完，渡酱小跑着去拿钢管椅，然后慢慢把它搬到我的前面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說完，渡醬小跑著去拿鋼管椅，然後慢慢把它搬到我的前面。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00224",
