	["0054_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esto es mi culpa por darle a Wata-chan indicaciones que la pusieron en peligro. Yo me lo busqué, y ahora tengo que aguantarme las consecuencias.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对渡酱下达了错误指示也是我自己的责任——我要自己善后。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對渡醬下達了錯誤指示也是我自己的責任——我要自己善後。",
					{"rt2"},
				},
