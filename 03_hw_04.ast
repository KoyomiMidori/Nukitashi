					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No te preocupes por mí. Es más o menos mi rutina diaria.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，这已经是日常工作了，请不要放在心上。”",
