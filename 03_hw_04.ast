		linknext = "0054_00247",
		line = 3388,
	},
	["0054_00247"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0846", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Heh heh! I got this! Dealing with children is my for-tay!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哼哼，交给我吧！我擅长和小孩子成为好朋友！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哼哼，交給我吧！我擅長和小孩子成為好朋友！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00246",
