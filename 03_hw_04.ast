		line = 54,
	},
	["0054_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A los pocos minutos de terminar las clases, todo el edificio se convierte en un caos sensual, ardiente y cubierto de vapor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后，教学楼会突然陷入乱交状态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後，校舍會突然陷入亂交狀態。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00003",
		linknext = "0054_00005",
		line = 64,
	},
	["0054_00005"] = {
		{"text"},
		text = {
