		{"ex", time=1000, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0036", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Ms. Minase"},
					"“That concludes homeroom for today. I'm free for the rest of the day, so anyone in need of a pussy, come forward. I'm happy to take on up to eight at a time. Now, Hanamaru, would you do the honors?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“今天的班会就到此为止了。老师今天有空，想要小穴的人请到前面来。可以同时8个人。那么……花丸同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「今天的班會就到此為止了。老師今天有空，想要小穴的人請到前面來。可以同時8個人。那麼……花丸同學。」",
					{"rt2"},
				},
			},
		},
		linknext = "0054_00002",
		line = 21,
	},
	["0054_00002"] = {
