				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But there's still people in this world who want to believe in old wives' tales, you know...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“就算是迷信也想试一试……世界上就是会有这样的人哦……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「就算是迷信也想試一試……世界上就是會有這樣的人哦……！」",
					{"rt2"},
				},
