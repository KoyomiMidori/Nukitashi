					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al final también compré algunos para Wata-chan. Aproveché la oportunidad para agradecerle debidamente que me hubiera ayudado ayer con los problemas de Asa-chan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是正好。昨天麻沙酱受到了她的照顾，我正想好好谢谢渡酱呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是正好。昨天麻沙醬受到了她的照顧，我正想好好謝謝渡醬呢。",
					{"rt2"},
				},
			},
		},
