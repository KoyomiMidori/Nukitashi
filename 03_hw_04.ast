	["0054_00359"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque, pensándolo bien, el tipo que intentó atacar a Wata-chan parecía haberlo hecho antes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想起来，以前袭击了渡酱的男人似乎也很熟练的样子。",
					{"rt2"},
				},
