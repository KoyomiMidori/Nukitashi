		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Vale, vuelve a tu rutina de loli y ve a la base! ¡Yo los distraeré mientras tanto!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱请装成跟往常一样的萝莉到基地去！这里我来对付！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
