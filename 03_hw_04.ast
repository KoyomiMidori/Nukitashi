			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, eso es terrible! ¡Deberíamos ayudarla!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
