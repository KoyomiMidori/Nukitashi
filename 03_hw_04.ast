	["0054_00188"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0046", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“¿Cómo se siente, polla lolicona? Jeje... Ya sabrá que la familia Hanamaru se encarga de los cerdos como usted, con mucho amor, amor, amor, amor y amor...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“初次见面，萝莉控小鸡鸡先生。呵呵……用花丸式射精管理术让你焦急焦急焦急焦急……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「初次見面，蘿莉控小雞雞先生。呵呵……用花丸式射精管理術讓你焦急焦急焦急焦急……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00187",
		linknext = "0054_00189",
		line = 2616,
	},
	["0054_00189"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0047", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“¿Qué tal un poco más de amor? Y solo un poquito de provocación... No vas a correrte mientras yo esté aquí, ni aunque tengas muchas ganitas. Al menos, no hasta que me cuentes todo lo que sabes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“焦急焦急焦急焦急……在你全都说出来之前，无论多想射精都不会让你射出来哦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「焦急焦急焦急焦急……在你全都說出來之前，無論多想射精都不會讓你射出來哦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00188",
		linknext = "0054_00190",
		line = 2628,
	},
	["0054_00190"] = {
		{"se", id=0, loop=0, file="se_a127"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me mira y sonríe tímidamente mientras empuja su pecho contra mí. La forma en que sus dedos delgados acarician mi miembro es insoportable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她露出浅笑，一边把胸部按过来，一边让纤细的手指像玩弄一般攀爬在鸡巴上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她露出淺笑，一邊把胸部按過來，一邊讓纖細的手指像玩弄一般攀爬在肉棒上。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00189",
		linknext = "0054_00191",
		line = 2639,
	},
	["0054_00191"] = {
