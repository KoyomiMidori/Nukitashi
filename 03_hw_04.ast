	},
	["0054_00013"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Caminar a su lado demuestra lo grande que es la diferencia entre ella y los otros estudiantes. Es por lo pequeña y loli que es.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在走廊上这样并排一看，她真的比其他学生都要显得更加萝莉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在走廊上這樣並排一看，她真的比其他學生都要顯得更加蘿莉。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00012",
		linknext = "0054_00014",
		line = 172,
	},
	["0054_00014"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0807", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Por cierto, ¿Asane-chan se ha sentido mejor desde ayer?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对了。麻沙音酱，那之后没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對了。麻沙音醬，那之後沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00013",
		linknext = "0054_00015",
		line = 187,
	},
	["0054_00015"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, y todo fue gracias a ti. Recuperó el apetito y se comió toda la cena.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，托你的福。好像也有食欲了，还吃了晚饭。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，託你的福。好像也有食慾了，還吃了晚飯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00014",
		linknext = "0054_00016",
		line = 199,
	},
	["0054_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hoy también se sintió lo suficientemente bien como para asistir. Me ayudaste bastante, Wata-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天感觉状态不错，所以也来学校了。多亏了渡酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天感覺狀態不錯，所以也來學校了。多虧了渡醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00015",
		linknext = "0054_00017",
		line = 210,
	},
	["0054_00017"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0808", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ay, no te preocupes. Solo hice lo que cualquiera habría hecho. Eso sí... me alegra que por fin haya demostrado ser una buena senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不用谢不用谢，我只是做了理所当然的事而已。诶嘿嘿，不过好高兴啊……终于做了前辈该做的事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不用謝不用謝，我只是做了理所當然的事而已。欸嘿嘿，不過好高興啊……終於做了前輩該做的事了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00016",
		linknext = "0054_00018",
		line = 224,
	},
	["0054_00018"] = {
