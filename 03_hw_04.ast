	},
	["0054_00249"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00107", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0847", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Perdón si te asusté al hablarte así. Me llamo Watarai Hinami, estoy en tercer año. ¿Y tú?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“突然找你说话把你吓了一跳呢。我是渡会雏见，3年级。你呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「突然找你說話把你嚇了一跳呢。我是渡會雛見，3年級。你呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00248",
		linknext = "0054_00250",
		line = 3426,
	},
	["0054_00250"] = {
