	["0054_00027"] = {
		{"bgm", file="bgm25", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0813", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Boobs are supposed to get bigger when a boy rubs them! They said that on TV! That's gotta be why everyone around here has big hootin' knockers and I don't!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我在电视上看到过，说让男孩子摸胸的话胸会变大！大家都是巨乳就我是贫乳，一定是因为这个原因！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我在電視上看到過，說讓男孩子摸胸的話胸會變大！大家都是巨乳就我是貧乳，一定是因為這個原因！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00026",
		linknext = "0054_00028",
		line = 355,
	},
	["0054_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
