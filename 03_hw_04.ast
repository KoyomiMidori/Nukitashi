	["0054_00023"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0811", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Urrgh... Is it my non-titties? My stupid non-existent titties! Do I seriously need big'uns to pass better or what!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜呜呜……是胸吗……？果然是胸吧……！因为是贫乳所以不行吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚嗚嗚……是胸嗎……？果然是胸吧……！因為是貧乳所以不行嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00022",
		linknext = "0054_00024",
		line = 305,
	},
	["0054_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not so much a titties problem as an “entire physical being” problem... though I know better than to say that to her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与其说是胸部，倒不如说是整体的问题——但如果说出口，她可能会更加消沉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與其說是胸部，倒不如說是整體的問題——但如果說出口，她可能會更加消沉。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00023",
		linknext = "0054_00025",
		line = 315,
	},
	["0054_00025"] = {
