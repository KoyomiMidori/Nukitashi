	["0054_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No soporto verla así, a punto de llorar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着吸着鼻子的渡酱，我的心情变得无比沉重。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著吸著鼻子的渡醬，我的心情變得無比沉重。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00347",
		linknext = "0054_00349",
		line = 4789,
	},
	["0054_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me gustaría acariciarle el cabello para tranquilizarla... pero todavía tengo la mano un poco ensangrentada, así que no quiero despeinarla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我想至少应该去抚摸一下那小脑袋，但却无法用渗血的手去做那样的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我想至少應該去撫摸一下那小腦袋，但卻無法用滲血的手去做那樣的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00348",
		linknext = "0054_00350",
		line = 4799,
	},
	["0054_00350"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así... estoy preocupado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不过……真让人在意啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不過……真讓人在意啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00349",
		linknext = "0054_00351",
		line = 4811,
	},
	["0054_00351"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0864", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Preocupado...? ¿Te preocupa lo que dijo ese hombre?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔……你说在意……是那个男人说过的话吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔……你說在意……是那個男人說過的話嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00350",
		linknext = "0054_00352",
		line = 4825,
	},
	["0054_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Pensaba que podía follar con niños en esta isla...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……他说听说可以在青蓝岛和小孩做——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……他說聽說可以在青藍島和小孩做——」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00351",
		linknext = "0054_00353",
		line = 4837,
	},
	["0054_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso... Rei estaba muy, MUY nerviosa hoy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来——今天的风纪委员长比以往任何时候都要心惊胆战。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來——今天的風紀委員長比以往任何時候都要心驚膽戰。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00352",
		linknext = "0054_00354",
		line = 4847,
	},
	["0054_00354"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Inmediatamente me confundió con un lolicon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把我误解为萝莉控，不顾一切地找我茬。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把我誤解為蘿莉控，不顧一切地找我茬。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00353",
		linknext = "0054_00355",
		line = 4857,
	},
	["0054_00355"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y ella no fue la única.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不只是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不只是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00354",
		linknext = "0054_00356",
		line = 4867,
	},
	["0054_00356"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La hermana de Hanamaru fue aún más directa y me llamó lolicon al verme. Dijo que no necesitaba permiso para dispararles en cuanto los viera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸委员长的妹妹也立即把我看成是萝莉控，还说过可以在没有许可的情况下对萝莉控开枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"花丸委員長的妹妹也立即把我看成是蘿莉控，還說過可以在沒有許可的情況下對蘿莉控開槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00355",
		linknext = "0054_00357",
		line = 4877,
	},
	["0054_00357"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La forma en que ambas actuaron hoy me hace pensar de que tenían problemas para lidiar con ese tipo de delincuentes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管哪个，都给人对那方面的问题已经变得过于敏感的印象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管哪個，都給人對那方面的問題已經變得過於敏感的印象。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00356",
		linknext = "0054_00358",
		line = 4887,
	},
	["0054_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Quizás la SS está teniendo problemas con delitos sexuales relacionados con menores?",
					{"rt2"},
