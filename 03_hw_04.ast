	["0054_00245"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se encoge de los nervios, visiblemente alterada por el hecho de que una desconocida intente hablar con ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许是因为突然被搭话，女孩战战兢兢地缩起身子。",
					{"rt2"},
				},
