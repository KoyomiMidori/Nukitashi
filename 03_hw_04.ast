					"“Supongo... pero no fue gran cosa. Además, me siento un poco mal porque tuviste que intervenir y salvarme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……可是总是拿不出什么成果啊。总是受到帮助，有点丢脸……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……可是總是拿不出什麼成果啊。總是受到幫助，有點丟臉……」",
					{"rt2"},
				},
			},
		},
