			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But I'm so glad you're safe... You really saved my butt back there, so thanks. I should reward you, but... kisses are still out, right? So I'll just go with the usual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过，你没事真是太好了啊……谢谢你帮我，橘君。为了表示感谢……呃，亲亲是不行的对吧。那样的话，就像往常一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過，你沒事真是太好了啊……謝謝你幫我，橘君。為了表示感謝……呃，親親是不行的對吧。那樣的話，就像往常一樣……」",
					{"rt2"},
				},
			},
		},
