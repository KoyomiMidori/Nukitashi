		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me acaricia la cabeza con sus manitas suaves.",
					{"rt2"},
				},
			},
			cn = {
				{
					"又小又软的手心，轻轻地抚摸着我的头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"又小又軟的手心，輕輕地撫摸著我的頭。",
