					name = {"淳之介", "Junnosuke"},
					"“Solo son ideas mías, pero... probablemente sea una amenaza para los niños.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“具体的情况我也不清楚……但是大概是对小孩子们有威胁的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「具體的情況我也不清楚……但是大概是對小孩子們有威脅的事情。」",
