		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="rei_01f_00001", file1="rei_01f_00104", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0160", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Desde que apareció el Frente Anticopulación, hemos tenido dos problemas entre manos. Pero ahora parece que ha surgido un tercero.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“——以上两点，再加上反交尾势力的出现。目前我们面临着需要解决的三大问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「——以上兩點，再加上反交尾勢力的出現。目前我們面臨著需要解決的三大問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00367",
		linknext = "0054_00369",
		line = 5064,
	},
	["0054_00369"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0563b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sí... Es natural que una carga así nos deje con falta de personal...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯……那么人手自然是不够了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯……那麼人手自然是不夠了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00368",
		linknext = "0054_00370",
		line = 5076,
	},
	["0054_00370"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0161", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Así es. Si siguiéramos adelante sin tomar las medidas adecuadas, podríamos enfrentarnos a una disminución de la moral del grupo. ¿Qué sugieres?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是的。如果就这样不制定对策，强行推行的话，最终可能会影响到士气……该怎么办呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是的。如果就這樣不制定對策，強行推行的話，最終可能會影響到士氣……該怎麼辦呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00369",
		linknext = "0054_00371",
		line = 5088,
	},
	["0054_00371"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0564", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Mmm, a ver... Si nos faltan números, ¿no sería ideal aumentarlos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯……是啊。果然……如果人数不够的话……那最好的方法就是把人数补齐对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯……是啊。果然……如果人數不夠的話……那最好的方法就是把人數補齊對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00370",
		linknext = "block_00371",
		line = 5102,
	},
