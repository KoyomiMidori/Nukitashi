					"“¿Eh? Lo siento, estoy a punto de correrme... ¿Qué hace una niña por aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "装酷的一年级男子"},
					"“嗯——不好意思，我现在有射精管理的计划……为什么这里会有小孩子？”",
					{"rt2"},
				},
			},
			tw = {
				{
