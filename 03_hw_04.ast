					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I guess... but it didn't amount to much. Plus, I feel kinda lame about how you had to step in and save me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……可是总是拿不出什么成果啊。总是受到帮助，有点丢脸……”",
