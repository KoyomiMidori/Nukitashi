			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是小孩子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是小孩子！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00073",
		linknext = "0054_00075",
		line = 986,
	},
	["0054_00075"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1043", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bueno, ya me lo veía venir. ¿Y ahora qué, manito? No podemos dejar que se repita lo de la última vez.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“果然还是这样啊……怎么办哥哥，再这样下去会重蹈覆辙的哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「果然還是這樣啊……怎麼辦哥哥，再這樣下去會重蹈覆轍的哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00074",
		linknext = "0054_00076",
		line = 999,
	},
	["0054_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, lo sé. Wata-chan, dile que eres de primer año en el nivel B.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我知道——渡酱前辈，请坚持说自己是B等部的1年级生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我知道——渡醬前輩，請堅持說自己是B等部的1年級生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00075",
		linknext = "0054_00077",
		line = 1011,
	},
	["0054_00077"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00109", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0824", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? P-Pero...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……但、但是……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……但、但是……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00076",
		linknext = "0054_00078",
		line = 1026,
	},
	["0054_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo hazlo, por favor. La recopilación de información te resultará más fácil si piensan que eres una estudiante de primer año.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“拜托了。被当做是最低年级的学生就不会受戒备，能顺利地进行调查。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「拜託了。被當做是最低年級的學生就不會受戒備，能順利地進行調查。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00077",
		linknext = "0054_00079",
		line = 1038,
	},
	["0054_00079"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00101", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0825", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, ya veo, creo que sí... ¡Soy Hinami, estudiante de primer año del nivel B!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，这样啊，原来如此啊……呃……我是B等部1年级的雏见啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，這樣啊，原來如此啊……呃……我是B等部1年級的雛見啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00078",
		linknext = "0054_00080",
		line = 1051,
	},
	["0054_00080"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0095", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "クールぶってる1年男子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Chico de primer año tranquilo"},
					"“¿De primer año? Ya veo... No me había dado cuenta de que alguien tan pequeña cursaba el mismo año que yo... Bueno, perdóname por no darme cuenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "装酷的一年级男子"},
					"“1年级？是吗……和我同年级却这么小……不，抱歉我没认出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "裝酷的一年級男子"},
					"「1年級？是嗎……和我同年級卻這麼小……不，抱歉我沒認出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00079",
		linknext = "0054_00081",
		line = 1063,
	},
	["0054_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bien. Eso estuvo cerca, pero se lo creyó.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很好——虽然蛮担心的，但还是让他相信了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"很好——雖然蠻擔心的，但還是讓他相信了。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00080",
		linknext = "0054_00082",
		line = 1073,
	},
	["0054_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun para una estudiante de primer año en los niveles B, sigue siendo bastante pequeña, probablemente la más pequeña. Pero no lo suficiente como para que sea una coartada inválida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算以B等部1年级来说也算相当娇小……应该说是最小的，不过还是可以勉强被接受的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算以B等部1年級來說也算相當嬌小……應該說是最小的，不過還是可以勉強被接受的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00081",
		linknext = "0054_00083",
		line = 1083,
	},
	["0054_00083"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0096", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "クールぶってる1年男子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Chico de primer año tranquilo"},
					"“Kotoyose Fumino, ¿verdad...? Lo siento, jamás he oído ese nombre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "装酷的一年级男子"},
					"“不过，琴寄文乃……不好意思，我没听说过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "裝酷的一年級男子"},
					"「不過，琴寄文乃……不好意思，我沒聽說過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00082",
		linknext = "0054_00084",
		line = 1095,
	},
	["0054_00084"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00101", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0826", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo, qué lástima.. ¡Bueno, está bien! ¡Voy a preguntarle a otras personas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊，真遗憾……啊，没事！别在意，我也试着问问别人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊，真遺憾……啊，沒事！別在意，我也試著問問別人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00083",
		linknext = "0054_00085",
		line = 1108,
	},
	["0054_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“ATM-03, lo estás haciendo bien. Sigue recopilando información.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“ATM-03，请以那个状态继续打听。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「ATM-03，請以那個狀態繼續打聽。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00084",
		linknext = "0054_00086",
		line = 1120,
	},
	["0054_00086"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00123", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0827", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Entendido!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“明白——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「明白——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00085",
		linknext = "0054_00087",
		line = 1133,
	},
	["0054_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seguimos escuchando mientras Wata-chan pregunta por Fumino. Lamentablemente, parece que nadie sabe nada sobre ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之后渡酱又到处打听了文乃的事，但是并没有人知道她是谁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之後渡醬又到處打聽了文乃的事，但是並沒有人知道她是誰。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00086",
		linknext = "0054_00088",
		line = 1143,
	},
	["0054_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uno pensaría que habría alguien que lo supiera entre todas las personas a las que ella ha preguntado...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“都问这么多人了，应该会有一个人知道吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「都問這麼多人了，應該會有一個人知道吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00087",
		linknext = "0054_00089",
		line = 1155,
	},
	["0054_00089"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0381", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Tal vez Fumino-san no tiene amigos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“文乃同学，你的朋友很少是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「文乃同學，你的朋友很少是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00088",
		linknext = "0054_00090",
		line = 1168,
	},
	["0054_00090"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1044", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Se parece a cierta personita...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“和某个胖子一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「和某個胖子一樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00089",
		linknext = "0054_00091",
		line = 1181,
	},
	["0054_00091"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vaya, Asa-chan. ¿Quién será?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱也没朋友不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬也沒朋友不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00090",
		linknext = "0054_00092",
		line = 1193,
	},
	["0054_00092"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00106", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0828", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Eh... Perdón si es un mal momento, pero... Me llamo Hinami, soy de primer año. ¿De casualidad conoces a una chica llamada Kotoyose Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那个——抱歉打扰你们了。我是1年级的雏见……你知道叫‘琴寄文乃’的人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
