				{
					name = {"モブ男A", "男A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男A", "Hombre A"},
					"“B-Bueno... Es que oí que en esta isla... puedes hacerlo con los niños...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男A", "A男"},
					"“那、那是……因为……我听说……其实这个岛，可以和小孩子做……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男A", "A男"},
					"「那、那是……因為……我聽說……其實這個島，可以和小孩子做……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00331",
