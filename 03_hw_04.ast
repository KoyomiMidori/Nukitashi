		{"se", id=0, loop=0, file="se_a156"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0840", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Listo... ¡Jeje, ahora puedo acariciarte la cabeza! Te esforzaste mucho hoy, gracias por todo. Te daré mucho cariño...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嘿啾……呵呵，这样就可以摸摸了！橘君，今天你也很努力呢，好伟大啊。谢谢你，好乖好乖……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嘿啾……呵呵，這樣就可以摸摸了！橘君，今天你也很努力呢，好偉大啊。謝謝你，好乖好乖……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00225",
		linknext = "0054_00227",
		line = 3113,
	},
	["0054_00227"] = {
