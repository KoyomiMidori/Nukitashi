			[200] = {
				{"se", id=3, file="se_b056"},
			},
		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Preparan sus pistolas para disparar. Así que hoy no es Ran, ¿eh...? Supongo que esta es su hermana menor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS式的手枪朝向了这边。凛——不是兰吗？是妹妹吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS式的手槍朝向了這邊。凜——不是蘭嗎？是妹妹嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00159",
		linknext = "0054_00161",
		line = 2200,
	},
	["0054_00161"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0039", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“¡Las manos en las pantalones y dame una erección! Que quede claro que no es una amenaza. No necesito permiso para dispararle a un lolicon como tú.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“把双手伸向下体露出鸡巴！这不是威胁。面对萝莉控不需要开枪许可。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「把雙手伸向下體露出肉棒！這不是威脅。面對蘿莉控不需要開槍許可。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00160",
		linknext = "0054_00162",
		line = 2212,
	},
	["0054_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lolicon, ¿eh? Esa es nueva. Pero supongo que eso significa que me vio con Wata-chan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被称呼为“萝莉控”，也就是说——已经被确认过跟渡酱在一起了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"被稱呼為「蘿莉控」，也就是說——已經被確認過跟渡醬在一起了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00161",
		linknext = "0054_00163",
		line = 2222,
	},
	["0054_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bueno, si cree que esa chica es una loli, mejor para mí. Voy a redoblar la apuesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，把渡酱当成是萝莉了，那刚好——我就借这个话柄。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，把渡醬當成是蘿莉了，那剛好——我就藉著這個話題。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00162",
		linknext = "0054_00164",
		line = 2232,
	},
	["0054_00164"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
