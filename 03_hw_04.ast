					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está mirando a todos lados... ¿Estará perdida?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么回事……她四处张望着……可能是迷路了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼回事……她四處張望著……可能是迷路了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00239",
		linknext = "0054_00241",
		line = 3311,
	},
	["0054_00241"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
