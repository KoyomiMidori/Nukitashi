				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔……你说在意……是那个男人说过的话吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔……你說在意……是那個男人說過的話嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00350",
		linknext = "0054_00352",
		line = 4825,
	},
	["0054_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. He thought you could do it with kids on this island...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……他说听说可以在青蓝岛和小孩做——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……他說聽說可以在青藍島和小孩做——」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00351",
		linknext = "0054_00353",
		line = 4837,
	},
	["0054_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Come to think of it... Rei was really, really on edge today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来——今天的风纪委员长比以往任何时候都要心惊胆战。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來——今天的風紀委員長比以往任何時候都要心驚膽戰。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00352",
		linknext = "0054_00354",
		line = 4847,
	},
	["0054_00354"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She immediately mistook me for a kiddy fiddler.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把我误解为萝莉控，不顾一切地找我茬。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把我誤解為蘿莉控，不顧一切地找我茬。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00353",
		linknext = "0054_00355",
		line = 4857,
	},
	["0054_00355"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And it wasn't just her, either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不只是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不只是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00354",
		linknext = "0054_00356",
		line = 4867,
	},
	["0054_00356"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hanamaru's sister was even more blunt, calling me a “kid-fucker.” And she said she didn't need prior permission to shoot them on sight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸委员长的妹妹也立即把我看成是萝莉控，还说过可以在没有许可的情况下对萝莉控开枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"花丸委員長的妹妹也立即把我看成是蘿莉控，還說過可以在沒有許可的情況下對蘿莉控開槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00355",
		linknext = "0054_00357",
		line = 4877,
	},
	["0054_00357"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The way they both acted today gave off the impression that they were having trouble dealing with those sorts of offenders.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管哪个，都给人对那方面的问题已经变得过于敏感的印象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管哪個，都給人對那方面的問題已經變得過於敏感的印象。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00356",
		linknext = "0054_00358",
		line = 4887,
	},
	["0054_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps the SS is having issues with minor-related sexual crimes lately?",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS内部是否已经把儿童性犯罪视为问题了？",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS內部是否已經把兒童性犯罪視為問題了？",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00357",
		linknext = "0054_00359",
		line = 4897,
	},
	["0054_00359"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though, thinking about it, the guy who tried to assault Wata seemed like he'd done that before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想起来，以前袭击了渡酱的男人似乎也很熟练的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回想起來，以前襲擊了渡醬的男人似乎也很熟練的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00358",
		linknext = "0054_00360",
		line = 4907,
	},
	["0054_00360"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Could there be something going on around this island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“青蓝岛发生什么事了吗——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「青藍島發生什麼事了嗎——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00359",
		linknext = "0054_00361",
		line = 4919,
	},
	["0054_00361"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0865", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Such as?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你说什么事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你說什麼事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00360",
		linknext = "0054_00362",
		line = 4933,
	},
	["0054_00362"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is just speculation, but... it'd be something that'd be a threat to the children.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“具体的情况我也不清楚……但是大概是对小孩子们有威胁的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「具體的情況我也不清楚……但是大概是對小孩子們有威脅的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00361",
		linknext = "0054_00363",
		line = 4945,
	},
	["0054_00363"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can't just sit on our hands. We have to do something about this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种状况不能放任不管——必须想办法……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這種狀況不能放任不管——必須想辦法……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00362",
		linknext = "0054_00364",
		line = 4957,
	},
	["0054_00364"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Because if this keeps up... It won't just be you and Yuki ending up in a situation like that. They're gonna be gunning for every single loli on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样下去……像渡酱、有希一样的萝莉又会被袭击的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣下去……像渡醬、有希一樣的蘿莉又會被襲擊的。」",
