	["0054_00199"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0049", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Vaya, ya estás temblando dentro de mí. Pero no creas que te dejaré correrte tan fácil— ¡¿Agh?! ¡¿Qué me está pasando?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“哎呀，已经在里面抖动着了……不过，我可以不会让你轻易地射精……呃……！？哈啊……这、这是什么……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「哎呀，已經在裡面抖動著了……不過，我可以不會讓你輕易地射精……呃……！？哈啊……這、這是什麼……！？」",
					{"rt2"},
				},
			},
		},
