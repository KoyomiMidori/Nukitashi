					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't worry about me. It's more or less my daily routine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，这已经是日常工作了，请不要放在心上。”",
