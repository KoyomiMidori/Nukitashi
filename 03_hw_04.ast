		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0854", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm... ¡Ya sé! Mira, es un accesorio de ardilla para mi bolso. ¿No es adorable? Le gusta que le froten las mejillas... Jeje, ¿te gustan las ardillas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……啊，对了！看，这是松鼠的挂件。可爱吧？你看，磨磨脸蛋……嘿嘿……有希喜欢松鼠吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……啊，對了！看，這是松鼠的挂件。可愛吧？你看，磨磨臉蛋……嘿嘿……有希喜歡松鼠嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00273",
		linknext = "0054_00275",
		line = 3762,
	},
	["0054_00275"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="yuki0007", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"ユキ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ユキ", "Yuki"},
					"“Me gustan más los leones marinos...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ユキ", "有希"},
					"“有希更喜欢海狮……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ユキ", "有希"},
					"「有希更喜歡海獅……」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00274",
		linknext = "0054_00276",
		line = 3774,
	},
	["0054_00276"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0855", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿A-Ah, sí? Leones marinos... Puedo entenderlo... creo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是、是这样啊……海狮啊……可以理解，对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是、是這樣啊……海獅啊……可以理解，對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00275",
		linknext = "0054_00277",
		line = 3788,
	},
	["0054_00277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan parece abatida por la falta de entusiasmo que hay por su correa de bolso pequeña. Debe de ser su favorita.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有希对渡酱包上的挂件不感兴趣，让渡酱感到很遗憾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有希對渡醬包上的挂件不感興趣，讓渡醬感到很遺憾。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00276",
		linknext = "0054_00278",
		line = 3798,
	},
	["0054_00278"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, si tiene hambre, podría ir a una tienda y comprarle algo de comer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她好像肚子饿了，我去便利店买点点心回来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她好像肚子餓了，我去便利店買點點心回來吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00277",
		linknext = "0054_00279",
		line = 3810,
	},
