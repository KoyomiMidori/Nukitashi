		{"se", id=0, loop=0, file="se_a156"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Haciendo pucheros, coloca su silla plegable frente a mí y se sube a ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边胀着脸生气，一边把钢管椅拖来放好，然后爬了上去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊脹著臉生氣，一邊把鋼管椅拖來放好，然後爬了上去。",
					{"rt2"},
				},
			},
		},
