	["0059_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“'Desarrollo legal de la Isla Seiran como destino turístico'... No es eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“青蓝岛观光资源化相关条例……不对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「青藍島觀光資源化相關條例……不對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00005",
		linknext = "0059_00007",
		line = 76,
	},
	["0059_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Veamos, este del tamaño de una guía telefónica es... 'Reglamento y código de conducta de la Academia Minotsuki'... Tampoco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这边这么厚的……水乃月学园校规概要——这也不对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這邊這麼厚的……水乃月學園校規概要——這也不對。」",
					{"rt2"},
				},
			},
