	["0059_00527"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al principio se subió para pegarme, pero ahora me está acariciando suavemente la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她从为了挥舞拳头摆放的椅子上，轻轻地抚摸着我的头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她從為了揮舞拳頭擺放的椅子上，輕輕地撫摸著我的頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00526",
		linknext = "0059_00528",
		line = 6682,
	},
	["0059_00528"] = {
