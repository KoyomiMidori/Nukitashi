		linkback = "0059_00462",
		linknext = "0059_00464",
		line = 5877,
	},
	["0059_00464"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1104", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Nadie se me acerca cuando estoy sola...Soy plana... y no tengo tetas... y pues soy una tabla de planchar...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“反正我一个人的时候谁也不跟我搭话……因为我是贫乳……因为我没有胸……因为是切菜板……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「反正我一個人的時候誰也不跟我搭話……因為我是貧乳……因為我沒有胸……因為是切菜板……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00463",
		linknext = "0059_00465",
		line = 5891,
	},
	["0059_00465"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, técnicamente eres una loli...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那不是贫乳，而是萝莉——”",
