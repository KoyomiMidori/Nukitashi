		line = 5865,
	},
	["0059_00463"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No te parece peligroso? Hay que tener cuidado con los buscadores de sexo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以就……这样不是很危险吗？说不定会碰到性触者……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以就……這樣不是很危險嗎？說不定會碰到性觸者……」",
