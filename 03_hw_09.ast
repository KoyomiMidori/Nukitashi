		line = 5780,
	},
	["0059_00456"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This meaningless banter with Wata-chan has helped me calm down a bit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是在这种时候，渡酱也像往常一样精神饱满，稍微交谈几句后让我的心情稍微平静了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是在這種時候，渡醬也像往常一樣精神飽滿，稍微交談幾句後讓我的心情稍微平靜了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00455",
		linknext = "0059_00457",
		line = 5790,
	},
	["0059_00457"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you doing here, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，你为什么在这种地方……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，你為什麼在這種地方……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00456",
		linknext = "0059_00458",
		line = 5802,
	},
	["0059_00458"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I think about it, I knew she'd still be at school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我知道她还留在学校里。",
					{"rt2"},
