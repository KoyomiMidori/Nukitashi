	["0059_00510"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1119", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Hrmph, no es que lo esté haciendo a propósito! ¡Es que ese no es el problema! ¡Si no dejas de molestarme, mi paciencia se va a agotar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真是的……这样不对吧！加前辈的地方也太奇怪了！你再这样坏心眼下去，我可是会受不鸟哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真是的……這樣不對吧！加前輩的地方也太奇怪了！你再這樣壞心眼下去，我可是會受不鳥哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00509",
		linknext = "0059_00511",
		line = 6450,
	},
	["0059_00511"] = {
