	["0059_00101"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0588", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe, how modest... Senpai, if it were up to you, how would you deal with the Anti-Copulation Front?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，你太谦虚了……前辈，如果是你，你会如何应对这个……反交尾势力的问题呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，你太謙虛了……前輩，如果是你，你會如何應對這個……反交尾勢力的問題呢？」",
					{"rt2"},
