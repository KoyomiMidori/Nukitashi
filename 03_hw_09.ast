			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Really. Here, have a look at this. You're seeing right, that is THE Katagiri Nanase's name in there. You have to laugh, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊……你看这个。连那个片桐奈奈濑都被提到了。搞笑吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊……你看這個。連那個片桐奈奈瀨都被提到了。搞笑吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00049",
		linknext = "0059_00051",
		line = 596,
	},
	["0059_00051"] = {
