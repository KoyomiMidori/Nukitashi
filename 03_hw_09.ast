				{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1121", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Acabas de repetir lo mismo! ¡Urghhh! Los chicos malos como tú necesitan cinco golpes en la cabeza. ¡Quédate quieto y no te muevas, ¿bueno?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“为什么要从那里开始！！呜呜呜呜……过分使坏的孩子要被敲头哦……橘君，不许动！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「為什麼要從那裡開始！！嗚嗚嗚嗚……過分使壞的孩子要被敲頭哦……橘君，不許動！」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00513",
		linknext = "0059_00515",
		line = 6504,
	},
	["0059_00515"] = {
