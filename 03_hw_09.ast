			},
			[7500] = {
				{"fgact", ch="郁子", id=10, act="移動", x=-100, y=0, time=3400, delay2=7500},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0112", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"非表示", "郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Ikuko"},
					"“Fóllame el coño, fóllame el coño, fóllame duro y sin condón. ♪ Ay qué divertido es montar sobre una polla dura como una roca ♪ Aaah ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "郁子"},
					"“把鸡巴拿出来啪小穴啪啊啪♪啊啪啪啪，啪啪啪♪啪啪♪要自慰还不如来啪啪啪呀",
					{"gaiji", text="①"},
					"啊啊",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "郁子"},
					"「把肉棒拿出來啪小穴啪啊啪♪啊啪啪啪，啪啪啪♪啪啪♪要自慰還不如來啪啪啪呀",
					{"gaiji", text="①"},
					"啊啊",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00089",
		linknext = "0059_00091",
		line = 1112,
	},
	["0059_00091"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, lv=5, time=300, alphadel=1},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"bgm", file="bgm09.5", vol=100},
		{"evset", file="ncg06", set="ncg06", path=":ev/ncg06/"},
		{"evset", file="ncg06_00002", set="ncg06_000", path=":ev/ncg06_000/"},
		{"bg", id=18, file="ncg06_00002", x=0, y=0, path=":cg/ncg06/", ev=1, time=500, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0387", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Rechazado. No es la época adecuada para ello y requeriría muchos recursos para llevarse a cabo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……驳回。现在不是时候，做那个也需要非常多资源。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……駁回。現在不是時候，做那個也需要非常多資源。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00090",
		linknext = "0059_00092",
		line = 1134,
	},
	["0059_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La reunión ya lleva casi una hora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反交尾势力的对策会议已经开始了近1个小时。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反交尾勢力的對策會議已經開始了近1個小時。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00091",
		linknext = "0059_00093",
		line = 1144,
	},
	["0059_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se han presentado varias propuestas, todas ellas rechazadas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然方案有很多，但都没有到采用的地步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然方案有很多，但都沒有到採用的地步。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00092",
		linknext = "0059_00094",
		line = 1154,
	},
	["0059_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La reunión ha llegado a un punto muerto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"会议本身开始停滞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"會議本身開始停滯。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00093",
		linknext = "0059_00095",
		line = 1164,
	},
	["0059_00095"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0586", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei, hoy tenemos aquí a todos los aprendices. ¿Por qué no les preguntas si tienen alguna sugerencia?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“礼……今天好不容易来了一群训练生，听听他们的意见怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「禮……今天好不容易來了一群訓練生，聽聽他們的意見怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00094",
		linknext = "0059_00096",
		line = 1176,
	},
	["0059_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voz es tranquila, pero cuando habla, todos se callan y la escuchan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那声音并不大，但却不可思议地响亮。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那聲音並不大，但卻不可思議地響亮。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00095",
		linknext = "0059_00097",
		line = 1186,
	},
	["0059_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me he acostumbrado bastante a Rei, pero sigo poniéndome tenso cuando estoy a su lado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然对礼仪前辈已经习惯了很多，但是面对学生会长还是会紧张。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然對禮儀前輩已經習慣了很多，但是面對學生會長還是會緊張。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00096",
		linknext = "0059_00098",
		line = 1196,
	},
	["0059_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con todas las miradas puestas en ella, me lanza una mirada de reojo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在场的目光都集中在她了身上——她将目光锁定在我身上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在場的目光都集中在她了身上——她將目光鎖定在我身上。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00097",
		linknext = "0059_00099",
		line = 1206,
	},
	["0059_00099"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0587", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Senpai, tus acciones ayer fueron admirables. Permíteme felicitarte.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈……听说昨天你立功了呢。真是太棒了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩……聽說昨天你立功了呢。真是太棒了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00098",
		linknext = "0059_00100",
		line = 1218,
	},
	["0059_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, no... Solo lo hice para proteger la isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有……作为FS，我只是做了自己能做的事而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有……作為FS，我只是做了自己能做的事而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00099",
		linknext = "0059_00101",
		line = 1229,
	},
	["0059_00101"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0588", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Jeje, qué modesto. En ese caso, si dependiera de ti, ¿cómo te ocuparías del Frente Anticopulación?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，你太谦虚了……前辈，如果是你，你会如何应对这个……反交尾势力的问题呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，你太謙虛了……前輩，如果是你，你會如何應對這個……反交尾勢力的問題呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00100",
		linknext = "0059_00102",
		line = 1241,
	},
	["0059_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Creo que sería impertinente de mi parte, como un recién entrado, expresar mi opinión.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种事……我觉得新人最好不要说三道四。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這種事……我覺得新人最好不要說三道四。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00101",
		linknext = "0059_00103",
		line = 1252,
	},
	["0059_00103"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0388", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No me molesta, la SS es una meritocracia. Si tienes alguna idea, no dudes en compartirla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没关系，FS是实力主义。你有什么想法就说吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒關係，FS是實力主義。你有什麼想法就說吧。」",
					{"rt2"},
				},
			},
