				{
					name = {"礼", "禮"},
					"「……哼、哈哈哈……怎麼了橘，你難道在意這種東西嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00044",
		linknext = "0059_00046",
		line = 531,
	},
	["0059_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Trivial? No, but... My name... is in there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃？你说这种东西……不不，上面可是有我的名字……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃？你說這種東西……不不，上面可是有我的名字……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00045",
		linknext = "0059_00047",
		line = 543,
	},
	["0059_00047"] = {
		{"bgm", file="bgm01", vol=100},
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0374", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Please. This is no more than a collection of individuals reported by ordinary students as having abstained from procreational actions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没事，这只是把一般学生报告的非性产者的名字归纳在一起而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒事，這只是把一般學生報告的非性產者的名字歸納在一起而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00046",
		linknext = "0059_00048",
		line = 558,
	},
	["0059_00048"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0375", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I've told you that mistaken allegations of being anti-copulation is a problem for us, yes? Plenty of the reports come from people who have grudges and want to start drama. To be blunt, it's worth next to nothing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不是说过反交尾势力的误认成了问题吗？里面有很多夹杂着私人仇恨或歹意的报告……老实说完全靠不住。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不是說過反交尾勢力的誤認成了問題嗎？裡面有很多夾雜著私人仇恨或歹意的報告……老實說完全靠不住。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00047",
		linknext = "0059_00049",
		line = 570,
	},
	["0059_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是這樣嗎？」",
					{"rt2"},
				},
