	["0059_00480"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El NLNS está muy ocupado investigando el problema de orden público y buscando a la chica conocida como Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"NLNS因为治安问题和“文乃”的问题而忙不过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"NLNS因為治安問題和「文乃」的問題而忙不過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00479",
		linknext = "0059_00481",
		line = 6081,
	},
	["0059_00481"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y aquí ando añadiendo aún más cosas a su lista de asuntos pendientes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——现在，我又要带来新的问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——現在，我又要帶來新的問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00480",
		linknext = "0059_00482",
		line = 6091,
	},
	["0059_00482"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como su líder, no puedo imponerle una carga aún mayor a mis compañeras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为队长，我不能再给同伴增加负担了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為隊長，我不能再給同伴增加負擔了。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00481",
		linknext = "0059_00483",
		line = 6101,
	},
	["0059_00483"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tengo que cargar con ese peso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自己的错误由自己纠正。这就是道理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自己的錯誤由自己糾正。這就是道理。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00482",
		linknext = "0059_00484",
		line = 6111,
	},
	["0059_00484"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tengo que hacer algo para arreglarlo...",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，我应该采取的对策是————",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，我應該採取的對策是————",
					{"rt2"},
				},
