	},
	["0059_00223"] = {
		{"fg", file="rei_01ll_00001", file1="rei_01ll_00112", file2="rei_01ll_00203", path=":fg/rei_01ll/", id=9, lv=5, head="rei_01ll", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0416", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ah, qué tonificado. Haces ejercicio, ¿verdad? Estoy impresionada, Tachibana...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊……你的身材好壮啊……锻炼得很好……好厉害啊，橘……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊……你的身材好壯啊……鍛煉得很好……好厲害啊，橘……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00222",
		linknext = "0059_00224",
		line = 2851,
	},
	["0059_00224"] = {
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=7.5, time=400, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a127"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pasa su mano enguantada en blanco por mi cuerpo, acariciándome.",
					{"rt2"},
				},
			},
			cn = {
				{
					"白色的手套在我身上滑来滑去，就像在品尝它一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"白色的手套在我身上滑來滑去，就像在品嚐它一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00223",
		linknext = "0059_00225",
		line = 2863,
	},
	["0059_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mmueve su otra mano hacia arriba a lo largo de mis músculos abdominales y acaricia mis pectorales, provocándome escalofríos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用手从下往上撩着腹肌，用五指摸着胸肌——我感到一阵阵发麻的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用手從下往上撩著腹肌，用五指摸著胸肌——我感到一陣陣發麻的感覺。",
					{"rt2"},
				},
			},
