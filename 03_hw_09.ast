	["0059_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No matter how opposed to copulation one may be, it would be impossible to resist when under the aphrodisiac's influence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果服用那个药，即使是反交尾势力大概也无法控制性冲动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果服用那個藥，即使是反交尾勢力大概也無法控制性衝動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00105",
		linknext = "0059_00107",
		line = 1297,
	},
	["0059_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The memory is a painful one, but speaking the truth here will help solidify my position within the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这对我来说是痛苦的回忆，但如果能说出心里话，在SS中的地位也会稳定下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這對我來說是痛苦的回憶，但如果能說出心裡話，在SS中的地位也會穩定下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00106",
		linknext = "0059_00108",
		line = 1307,
	},
	["0059_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It doesn't matter if it helps them form their strategy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使这对SS的作战计划有帮助也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使這對SS的作戰計劃有幫助也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00107",
		linknext = "0059_00109",
		line = 1317,
	},
	["0059_00109"] = {
		{"text"},
		text = {
