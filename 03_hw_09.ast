	},
	["0059_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mueve su mano hacia abajo, tocando mis partes a través de mi ropa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈的手伸向双腿之间——隔着衣服，摸到了我的鸡巴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩的手伸向雙腿之間——隔著衣服，摸到了我的肉棒。",
