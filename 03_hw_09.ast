		linkback = "0059_00229",
		linknext = "0059_00231",
		line = 2935,
	},
	["0059_00231"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Cálmate! ¡Soy impotente, así que hagas lo que hagas, no podemos tener sexo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……请冷静下来……！我是阳痿，所以，就算你这样做，也无法做爱……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……請冷靜下來……！我是陽痿，所以，就算你這樣做，也無法做愛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00230",
		linknext = "0059_00232",
		line = 2947,
	},
	["0059_00232"] = {
		{"fg", file="rei_01ll_00001", file1="rei_01ll_00107", file2="rei_01ll_00203", path=":fg/rei_01ll/", id=9, lv=5, head="rei_01ll", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
