	},
	["0059_00438"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I claimed to be impotent to get into the SS, but that lie has been exposed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明加入SS時自称是阳痿，但即使没有药物也能勃起的事實暴露了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明加入SS時自稱是陽痿，但即使沒有藥物也能勃起的事實暴露了。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00437",
		linknext = "0059_00439",
		line = 5575,
	},
	["0059_00439"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not only that, but it was discovered by Rei-senpai, the disciplinary committee president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且偏偏是SS的风纪委员长——礼前辈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且偏偏是SS的風紀委員長——禮前輩。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00438",
		linknext = "0059_00440",
		line = 5585,
	},
	["0059_00440"] = {
