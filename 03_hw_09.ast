	["0059_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy rebuscando en los estantes y cajones de la oficina abandonada del comité de moral pública.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在空无一人的风纪委员室里，我在书架和抽屉里搜索着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在空無一人的風紀委員室裡，我在書架和抽屜裡搜索著。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00002",
		linknext = "0059_00004",
		line = 40,
	},
	["0059_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi objetivo es encontrar documentación sobre el problema de orden público y Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"目的不是别的——为了得到有关治安问题和“文乃”的资料。",
					{"rt2"},
				},
			},
			tw = {
				{
					"目的不是別的——為了得到有關治安問題和「文乃」的資料。",
