			cn = {
				{
					"听到这句话，我无言以对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到這句話，我無言以對。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00468",
		linknext = "0059_00470",
		line = 5952,
	},
	["0059_00470"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y menos después de que la haya cagado tanto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟——刚刚做了一件不得了的大傻事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟——剛剛做了一件不得了的大傻事。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00469",
		linknext = "0059_00471",
		line = 5962,
	},
	["0059_00471"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1107", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Estás muy pálido... ¿Qué pasa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你的脸非常苍白……发生什么事了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你的臉非常蒼白……發生什麼事了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00470",
		linknext = "0059_00472",
		line = 5976,
	},
	["0059_00472"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, nada... Es que me preocupa no haber logrado ningún avance en el problema de orden público.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有。没有发生什么事……但治安问题一事停滞不前，让我有点在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有。沒有發生什麼事……但治安問題一事停滯不前，讓我有點在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00471",
		linknext = "0059_00473",
		line = 5988,
	},
	["0059_00473"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Cuándo aprendí a mentir con tanta naturalidad?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从什么时候开始，变得能如此淡然地撒谎了呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從什麼時候開始，變得能如此淡然地撒謊了呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00472",
		linknext = "0059_00474",
		line = 5998,
	},
	["0059_00474"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fue necesario para infiltrarme en la SS, pero jamás querría hacerle esto a mis amigas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那明明是为了潜入FS而学会的能力——并不是用来向同伴掩盖真相的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那明明是為了潛入FS而學會的能力——並不是用來向同伴掩蓋真相的。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00473",
		linknext = "0059_00475",
		line = 6008,
	},
	["0059_00475"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me siento abrumado por la culpa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"良心好痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"良心好痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00474",
		linknext = "0059_00476",
		line = 6018,
	},
	["0059_00476"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1108", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿El problema de orden público? Sí, nosotras también lo hemos estado investigando. Parece que sí es cierto que se están dando casos de acoso hacia los niños...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“治安问题啊……我们大家也努力调查了很久。果然，小孩子的受害人数在增加一事，好像是真的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「治安問題啊……我們大家也努力調查了很久。果然，小孩子的受害人數在增加一事，好像是真的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00475",
		linknext = "0059_00477",
		line = 6032,
	},
	["0059_00477"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio...? Ten mucho cuidado, Wata-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……渡酱，你也要多多小心啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……渡醬，你也要多多小心啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00476",
		linknext = "0059_00478",
		line = 6044,
	},
	["0059_00478"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1109", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Sí! No puedo dejar que los niños sufran... ¡Estaré pendiente!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！不能再让小孩子遇到危险了……我会小心到处看看的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！不能再讓小孩子遇到危險了……我會小心到處看看的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00477",
		linknext = "0059_00479",
		line = 6059,
	},
	["0059_00479"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
