	["0059_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es la hora del almuerzo del día siguiente a mi trabajo en la playa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"沙滩上立功的隔天午休。",
