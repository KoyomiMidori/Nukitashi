		},
		linkback = "0059_00483",
		linknext = "0059_00485",
		line = 6121,
	},
	["0059_00485"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tal vez visite a Rei-senpai mañana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我明天想去拜访礼前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我明天想去拜訪禮前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00484",
		linknext = "0059_00486",
		line = 6133,
	},
	["0059_00486"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1110", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? ¿Vas a visitar a Rei-chan? ¿Vas a ir al dormitorio de la SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……礼酱家？这么说来……你要去FS的宿舍吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……禮醬家？這麼說來……你要去FS的宿舍嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00485",
		linknext = "0059_00487",
		line = 6147,
	},
	["0059_00487"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Después del incidente en la playa, creo que me he ganado su confianza, así que tal vez le pregunte sobre el problema de orden público.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。因为沙滩上的事件，我得到了她的信任……所以我想直接问问有关治安的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。因為沙灘上的事件，我得到了她的信任……所以我想直接問問有關治安的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00486",
		linknext = "0059_00488",
		line = 6158,
	},
	["0059_00488"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es del todo mentira, pero lo que realmente me preocupa es lo que pasó antes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然——主要是为了刚才做的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然——主要是為了剛才做的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00487",
		linknext = "0059_00489",
		line = 6168,
	},
	["0059_00489"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tengo que pensarlo muy, MUY bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"试着冷静地想一想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"試著冷靜地想一想。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00488",
		linknext = "0059_00490",
		line = 6178,
	},
	["0059_00490"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque sepan que mi impotencia era una mentira, eso no significa que ahora sepan que formo parte del Frente Anticopulación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使阳痿是谎言，她应该也不会马上把我当成反交尾势力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使陽痿是謊言，她應該也不會馬上把我當成反交尾勢力。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00489",
		linknext = "0059_00491",
		line = 6188,
	},
	["0059_00491"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como dijo Nanase, la correlación no implica causalidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是奈奈濑所说的后此谬误吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是奈奈瀨所說的後此謬誤吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00490",
