				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh...? ¿En serio? ¿Te ayudé?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……真的吗？我帮到了橘君的忙吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……真的嗎？我幫到了橘君的忙嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00521",
		linknext = "0059_00523",
		line = 6614,
	},
	["0059_00523"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, sabes muy bien cómo animarme, Wata-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。和渡酱在一起就会变得有精神。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
