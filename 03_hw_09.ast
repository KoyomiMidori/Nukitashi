					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Grrrr! ¡Es como si fueras mejor amigo de ella! Eso no... ¡En ese caso, llámame también por mi nombre de pila!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔唔唔唔……！好、好像比我还要要好了……好羡慕啊……那也叫我下面的名字吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔唔唔唔……！好、好像比我還要要好了……好羨慕啊……那也叫我下面的名字吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00497",
