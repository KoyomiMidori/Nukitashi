	["0059_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como dijo Rei-senpai, estamos en la oficina del consejo estudiantil, reunidos para discutir estrategias para lidiar con el Frente Anticopulación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"按照预定计划，在学生会室里举行了反交尾势力的对策会议。",
					{"rt2"},
				},
			},
			tw = {
				{
					"按照預定計劃，在學生會室裡舉行了反交尾勢力的對策會議。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00087",
		linknext = "0059_00089",
		line = 1074,
	},
	["0059_00089"] = {
		{"bgm", file="bgm08", vol=100},
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00107", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0111", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“¿Por qué no cantar canciones de SexoNavidad? Eso pondría a todos de humor para follar, y quien no este de acuerdo es que forma parte del Frente Anticopulación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那么，试着来个变态集体舞怎么样？那样的话大家都会做爱，没做爱的人不就是反交尾势力吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「那麼，試著來個變態集體舞怎麼樣？那樣的話大家都會做愛，沒做愛的人不就是反交尾勢力嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00088",
		linknext = "0059_00090",
		line = 1089,
	},
	["0059_00090"] = {
		{"bg", id=2, file="bg16_1l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-75, y=-5, time=3700, lv=5},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
