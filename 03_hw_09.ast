					"I lay Rei-senpai down in the infirmary and take deep breaths.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我让失去意识的礼前辈躺在保健室里，用肩膀调整呼吸。",
					{"rt2"},
				},
			},
			tw = {
