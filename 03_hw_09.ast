		line = 638,
	},
	["0059_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wait, how am I supposed to go thanking a slut? It'd probably just end in tears for me... Yeah, never mind. Scratch that idea.",
					{"rt2"},
