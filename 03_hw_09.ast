			tw = {
				{
					"我知道她還留在學校裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00457",
		linknext = "0059_00459",
		line = 5812,
	},
	["0059_00459"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I told everyone to wait at the base for my report, since I was attending the strategy meeting for dealing with the Anti-Copulation Front.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为有反交尾势力对策的会议，所以我告诉同伴们在基地等我的报告。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為有反交尾勢力對策的會議，所以我告訴同伴們在基地等我的報告。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00458",
		linknext = "0059_00460",
		line = 5822,
	},
	["0059_00460"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
