					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pfft, jaja... Tranquilo. ¿En serio te interesa algo tan insignificante?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……哼、哈哈哈……怎么了橘，你难道在意这种东西吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……哼、哈哈哈……怎麼了橘，你難道在意這種東西嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00044",
		linknext = "0059_00046",
		line = 531,
	},
	["0059_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? ¿Insignificante? No, pero... mi nombre está ahí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃？你说这种东西……不不，上面可是有我的名字……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃？你說這種東西……不不，上面可是有我的名字……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00045",
		linknext = "0059_00047",
		line = 543,
	},
	["0059_00047"] = {
		{"bgm", file="bgm01", vol=100},
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0374", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Por favor. Esto no es más que una recopilación de personas denunciadas por estudiantes comunes por haberse abstenido de realizar actos reproductivos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没事，这只是把一般学生报告的非性产者的名字归纳在一起而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒事，這只是把一般學生報告的非性產者的名字歸納在一起而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00046",
		linknext = "0059_00048",
		line = 558,
	},
	["0059_00048"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0375", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya te he dicho que las acusaciones erróneas de ser anti-copulación son un problema para nosotros, ¿no? Muchas de las denuncias provienen de personas que guardan rencor y quieren crear drama. Sinceramente, no tienen ningún valor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不是说过反交尾势力的误认成了问题吗？里面有很多夹杂着私人仇恨或歹意的报告……老实说完全靠不住。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不是說過反交尾勢力的誤認成了問題嗎？裡面有很多夾雜著私人仇恨或歹意的報告……老實說完全靠不住。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00047",
		linknext = "0059_00049",
		line = 570,
	},
	["0059_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00048",
		linknext = "0059_00050",
		line = 581,
	},
	["0059_00050"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0376", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí. O sea, mira nada más esto. Fíjate, ahí está el nombre de Katagiri Nanase. Es gracioso, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊……你看这个。连那个片桐奈奈濑都被提到了。搞笑吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊……你看這個。連那個片桐奈奈瀨都被提到了。搞笑吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00049",
		linknext = "0059_00051",
		line = 596,
	},
	["0059_00051"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jajaja... Tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈哈……是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈哈……是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00050",
		linknext = "0059_00052",
		line = 608,
	},
	["0059_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hablando en serio... a mí no me da risa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"完全——我真的完全笑不出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"完全——我真的完全笑不出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00051",
		linknext = "0059_00053",
		line = 618,
	},
	["0059_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que nos han incluido en la lista de sospechosos sin que nos hayamos enterado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在不知不觉中，我们已经上升为嫌疑犯了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在不知不覺中，我們已經上升為嫌疑犯了。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00052",
		linknext = "0059_00054",
		line = 628,
	},
	["0059_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Menos mal que Nanase es una puta... Nota para mí mismo: tengo que darle las gracias la próxima vez que la vea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"多亏奈奈濑是婊子才得救了……下次跟她道个谢吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"多虧奈奈瀨是婊子才得救了……下次跟她道個謝吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00053",
		linknext = "0059_00055",
		line = 638,
	},
	["0059_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Espera, ¿cómo así que le voy a dar las gracias a una puta? Probablemente lloraría... Sí, no importa. Mejor me olvido de esa idea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，如果想感谢婊子该做些什么好呢……？可能会贞节不保，还是算了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，如果想感謝婊子該做些什麼好呢……？可能會貞節不保，還是算了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00054",
		linknext = "0059_00056",
		line = 648,
	},
	["0059_00056"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo, me sorprende un poco ver mi nombre en la lista.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是我很惊讶……居然被怀疑……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是我很驚訝……居然被懷疑……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00055",
		linknext = "0059_00057",
		line = 660,
	},
	["0059_00057"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0377", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Te sentiste tocado, ¿no? No te preocupes, sé lo trabajador que eres. No voy a desconfiar de mis compañeros.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“想不到你这么神经质。唉，别担心。你的努力我都看在眼里，我不会怀疑同伴的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「想不到你這麼神經質。唉，別擔心。你的努力我都看在眼裡，我不會懷疑同伴的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00056",
		linknext = "0059_00058",
		line = 674,
	},
	["0059_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me quedo sin palabras al oír eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直接听到这样的话，我反而说不出话来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直接聽到這樣的話，我反而說不出話來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00057",
		linknext = "0059_00059",
		line = 684,
	},
	["0059_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He estado tratando de ganarme su confianza todo este tiempo, pero ahora que lo he conseguido, las palabras se me atascan en la garganta. No sé cómo responder.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明按照当初的目的得到了信赖，但是不知为什么，胸中积压着消化不了的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明按照當初的目的得到了信賴，但是不知為什麼，胸中積壓著消化不了的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00058",
		linknext = "0059_00060",
		line = 694,
	},
	["0059_00060"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0378", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pero ¿venir aquí durante tu hora del almuerzo para investigar al Frente Anticopulación? Aplaudo tu entusiasmo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过……明明是午休时间，还特意在调查反交尾势力吗？你也真是个热心的家伙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不過……明明是午休時間，還特意在調查反交尾勢力嗎？你也真是個熱心的傢伙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00059",
		linknext = "0059_00061",
		line = 708,
	},
	["0059_00061"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No puedo ignorar a los traidores que se rebelan contra la ley.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——对于违反条例的逆贼，我是不会置之不理的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——對於違反條例的逆賊，我是不會置之不理的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00060",
		linknext = "0059_00062",
		line = 720,
	},
	["0059_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me trago mi orgullo y respondo sin mucho entusiasmo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"抹杀自己的内心，说出背离心思的话语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"抹殺自己的內心，說出背離心思的話語。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00061",
		linknext = "0059_00063",
		line = 730,
	},
	["0059_00063"] = {
