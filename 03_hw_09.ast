					"「呀啊啊！？欸！什麼什麼！有什麼嗎！？妖怪！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00449",
		linknext = "0059_00451",
		line = 5714,
	},
	["0059_00451"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wata-chan... No me asustes así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱……不要吓唬我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬……不要嚇唬我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00450",
		linknext = "0059_00452",
		line = 5727,
	},
	["0059_00452"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1100", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡N-No era mi intención! Te saludé desde la puerta, pero no te diste cuenta, así que te hablé y me gritaste así... Me asustaste mucho. Todavía me late fuerte el corazón...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那、那是我要说的吧！我刚刚挥手时你没有注意到我，所以我才直接跟你说话的，结果你却突然大叫……吓了我一跳。我的心脏还在怦怦乱跳呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那、那是我要說的吧！我剛剛揮手時你沒有注意到我，所以我才直接跟你說話的，結果你卻突然大叫……嚇了我一跳。我的心臟還在怦怦亂跳呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00451",
		linknext = "0059_00453",
		line = 5742,
	},
	["0059_00453"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1101", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, si mi corazón sigue latiendo con fuerza contra mis pechos, ¿se volverán más grandes?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……一直心跳加速的话，胸部会不会被推上来变成巨乳呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……一直心跳加速的話，胸部會不會被推上來變成巨乳呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00452",
		linknext = "0059_00454",
		line = 5756,
	},
	["0059_00454"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque eso fuera verdad, solo afectaría al izquierdo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使假设成立也只有左胸哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使假設成立也只有左胸哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00453",
		linknext = "0059_00455",
		line = 5768,
	},
	["0059_00455"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00124", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Suspiro aliviado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"呼，我叹了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"呼，我嘆了口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00454",
		linknext = "0059_00456",
		line = 5780,
	},
	["0059_00456"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta charla sin sentido con Wata-chan me ha ayudado a calmarme un poco.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是在这种时候，渡酱也像往常一样精神饱满，稍微交谈几句后让我的心情稍微平静了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是在這種時候，渡醬也像往常一樣精神飽滿，稍微交談幾句後讓我的心情稍微平靜了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00455",
		linknext = "0059_00457",
		line = 5790,
	},
	["0059_00457"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero ¿qué haces aquí...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，你为什么在这种地方……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，你為什麼在這種地方……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00456",
		linknext = "0059_00458",
		line = 5802,
	},
	["0059_00458"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso, sabía que todavía estaría en la escuela.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我知道她还留在学校里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我知道她還留在學校裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00457",
		linknext = "0059_00459",
		line = 5812,
	},
	["0059_00459"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Les dije que esperaran en la base mi informe, ya que iba a asistir a la reunión estratégica para tratar el tema del Frente Anticopulación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为有反交尾势力对策的会议，所以我告诉同伴们在基地等我的报告。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為有反交尾勢力對策的會議，所以我告訴同伴們在基地等我的報告。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00458",
		linknext = "0059_00460",
		line = 5822,
	},
	["0059_00460"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
