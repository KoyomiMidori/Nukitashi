					"“Lo haces sonar tan fácil...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然打着前辈的名号，但到底还是幼鸟啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然打著前輩的名號，但到底還是幼鳥啊。」",
