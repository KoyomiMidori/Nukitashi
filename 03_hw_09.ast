					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Además, dices que es peligroso, pero ¿no estás en las mismas o peor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“而且……要说危险的话，橘君比我更危险。”",
