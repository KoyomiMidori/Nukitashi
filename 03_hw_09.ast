				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“In any case, you're in luck. We're holding a strategy meeting regarding the Anti-Copulation Front — the traitors, as you called them — after school.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“好了……开心点橘，放学后要召开反交尾势力——你刚刚说的逆贼的对策会议。”",
					{"rt2"},
