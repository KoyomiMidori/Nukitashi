			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ejejeje... Me haces sentir halagada. Pero veo que lo estás pasando mal. Solo me molestas así cuando las cosas se ponen difíciles.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿嘿……没什么啦……这样啊。不过，橘君也很辛苦呢。要是很辛苦的话，也会有想要恶作剧的时候呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿嘿……沒什麼啦……這樣啊。不過，橘君也很辛苦呢。要是很辛苦的話，也會有想要惡作劇的時候呢。」",
					{"rt2"},
