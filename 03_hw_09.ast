	["0059_00464"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1104", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No one ever approaches me when I'm alone... since I'm flat... and I have no boobs... not to mention I'm a cutting board...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“反正我一个人的时候谁也不跟我搭话……因为我是贫乳……因为我没有胸……因为是切菜板……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「反正我一個人的時候誰也不跟我搭話……因為我是貧乳……因為我沒有胸……因為是切菜板……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00463",
		linknext = "0059_00465",
		line = 5891,
	},
	["0059_00465"] = {
