		{"fg", file="hinami_01m_00001", file1="hinami_01m_00116", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=-150},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1123", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Me da igual... Solo soy una enana, demasiado bajita para darte una paliza sin mi silla, y eso que ya estoy grande...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好啦好啦……反正我就是个矮子，没有椅子就敲不了头，还是雏鸟的长老……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好啦好啦……反正我就是個矮子，沒有椅子就敲不了頭，還是雛鳥的長老……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00517",
		linknext = "0059_00519",
		line = 6564,
	},
	["0059_00519"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
