		line = 2899,
	},
	["0059_00228"] = {
		{"fg", file="rei_01ll_00001", file1="rei_01ll_00102", file2="rei_01ll_00203", path=":fg/rei_01ll/", id=9, lv=5, head="rei_01ll", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0418", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Jeje, por mucho que hayas entrenado, siempre serás sensible ahí. Jaa... ¿y aquí abajo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呵呵……即使锻炼了，这里还是很弱啊……啊……那么，这边呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
