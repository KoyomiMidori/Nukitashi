	["0059_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Good job Nanase's a slut, though... Note to self, I need to thank her for that next time I see her.",
