				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por alguna razón, las caricias de esta senpai enana hacen que todas mis preocupaciones desaparezcan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不可思议的是——只有在被小前辈抚摸着的这段时间里，我才能安心地放下心中的问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不可思議的是——只有在被小前輩撫摸著的這段時間裡，我才能安心地放下心中的問題。",
					{"rt2"},
				},
			},
