		linkback = "0059_00103",
		linknext = "0059_00105",
		line = 1275,
	},
	["0059_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si me lo permiten, sugeriría utilizar el afrodisíaco que me administraron durante los exámenes de ingreso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，虽然很冒昧——入队考试时使用的媚药，用那个怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，雖然很冒昧——入隊考試時使用的媚藥，用那個怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00104",
		linknext = "0059_00106",
		line = 1286,
	},
	["0059_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por mucho que uno se oponga a la copulación, sería imposible resistirse bajo la influencia del afrodisíaco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果服用那个药，即使是反交尾势力大概也无法控制性冲动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果服用那個藥，即使是反交尾勢力大概也無法控制性衝動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00105",
		linknext = "0059_00107",
		line = 1297,
	},
	["0059_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Recordarlo es doloroso, pero decir la verdad aquí me ayudará a consolidar mi posición dentro de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这对我来说是痛苦的回忆，但如果能说出心里话，在FS中的地位也会稳定下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這對我來說是痛苦的回憶，但如果能說出心裡話，在FS中的地位也會穩定下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00106",
		linknext = "0059_00108",
		line = 1307,
	},
	["0059_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No importa si eso les ayuda a elaborar su estrategia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使这对FS的作战计划有帮助也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使這對FS的作戰計劃有幫助也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00107",
		linknext = "0059_00109",
		line = 1317,
	},
	["0059_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya que estoy aquí, puedo filtrar los detalles para que podamos tomar medidas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为在内部的我能清楚知道作战的内容——所以绝对能够采取对策。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為在內部的我能清楚知道作戰的內容——所以絕對能夠採取對策。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00108",
		linknext = "0059_00110",
		line = 1327,
	},
	["0059_00110"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0389", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Nada mal, pero si no podemos identificarlos, ¿cómo podemos hacer que lo tomen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那个吗……就方案来说也许还不错。但还没有锁定反交尾势力的成员，所以如何让他们喝下去将成为一个难题……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那個嗎……就方案來說也許還不錯。但還沒有鎖定反交尾勢力的成員，所以如何讓他們喝下去將成為一個難題……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00109",
		linknext = "0059_00111",
		line = 1339,
	},
	["0059_00111"] = {
