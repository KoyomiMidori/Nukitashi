				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since I'm here, I can leak the details so we can enact countermeasures.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为在内部的我能清楚知道作战的内容——所以绝对能够采取对策。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為在內部的我能清楚知道作戰的內容——所以絕對能夠採取對策。",
					{"rt2"},
				},
			},
		},
