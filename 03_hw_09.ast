			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ah, cierto... Necesitabas la medicina... Bueno, da igual... Ya no puedo contenerme más...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊，也对……你没有药的话……但是……我无法控制啊……好想要这个……受不了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊，也對……你沒有藥的話……但是……我無法控制啊……好想要這個……受不了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00231",
