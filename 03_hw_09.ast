			tw = {
				{
					"為此，我應該採取的對策是————",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00483",
		linknext = "0059_00485",
		line = 6121,
	},
	["0059_00485"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I might pay Rei's place a visit tomorrow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我明天想去拜访礼前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我明天想去拜訪禮前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00484",
		linknext = "0059_00486",
		line = 6133,
	},
	["0059_00486"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1110", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Rei-chan's place? You mean the SS dorm?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……礼酱家？这么说来……你要去SS的宿舍吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……禮醬家？這麼說來……你要去SS的宿舍嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00485",
		linknext = "0059_00487",
		line = 6147,
	},
	["0059_00487"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. After the beach incident, I think I've gained her trust, so I might ask her directly about the public order problem.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。因为沙滩上的事件，我得到了她的信任……所以我想直接问问有关治安的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。因為沙灘上的事件，我得到了她的信任……所以我想直接問問有關治安的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00486",
		linknext = "0059_00488",
		line = 6158,
	},
	["0059_00488"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not entirely a lie, but my main concern is really what happened earlier.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然——主要是为了刚才做的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然——主要是為了剛才做的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00487",
		linknext = "0059_00489",
		line = 6168,
	},
	["0059_00489"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I gotta think rationally about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"试着冷静地想一想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"試著冷靜地想一想。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00488",
		linknext = "0059_00490",
		line = 6178,
	},
	["0059_00490"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if they know that my impotence was a lie, that doesn't mean I'm instantly exposed as part of the Anti-Copulation Front.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使阳痿是谎言，她应该也不会马上把我当成反交尾势力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使陽痿是謊言，她應該也不會馬上把我當成反交尾勢力。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00489",
		linknext = "0059_00491",
		line = 6188,
	},
	["0059_00491"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As Nanase said, correlation does not imply causation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是奈奈濑所说的后此谬误吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是奈奈瀨所說的後此謬誤吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00490",
		linknext = "0059_00492",
		line = 6198,
	},
	["0059_00492"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know Rei-senpai is more thoughtful than that. She's open to discussion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈既不是那么武断也不是那么耿直的人——她是能对话的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩既不是那麼武斷也不是那麼耿直的人——她是能對話的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00491",
		linknext = "0059_00493",
		line = 6208,
	},
	["0059_00493"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why I think the best course of action is to talk to her about it directly before the weekend is over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此，我才想在有时间的休息日里，亲自到宿舍去谈这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此，我才想在有時間的休息日裡，親自到宿舍去談這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00492",
		linknext = "0059_00494",
		line = 6218,
	},
	["0059_00494"] = {
