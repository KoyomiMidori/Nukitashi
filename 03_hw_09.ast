				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me quedo atónito mientras me desnuda la parte superior del cuerpo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"束手无策，上半身的衣服被简简单单地扒了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"束手無策，上半身的衣服被簡簡單單地扒了下來。",
					{"rt2"},
				},
