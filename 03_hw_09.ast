			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun and Rei-chan are really getting along, huh? Ehehe, that's nice to see. Rei-chan is a really nice girl, isn't she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君和礼酱关系变好了呢。诶嘿嘿，不知怎么的好开心……礼酱是个好孩子对吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君和禮醬關係變好了呢。欸嘿嘿，不知怎麼的好開心……禮醬是個好孩子對吧！」",
