		},
		linkback = "0059_00217",
		linknext = "0059_00219",
		line = 2791,
	},
	["0059_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En cuanto intento resistirme, me inmovilizan los brazos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"试图抵抗的瞬间，手臂马上被按住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"試圖抵抗的瞬間，手臂馬上被按住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00218",
		linknext = "0059_00220",
		line = 2801,
	},
	["0059_00220"] = {
		{"fg", file="rei_01ll_00001", file1="rei_01ll_00118", file2="rei_01ll_00203", path=":fg/rei_01ll/", id=9, lv=5, head="rei_01ll", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0415", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Eres muy travieso... Te he dicho tantas veces que no tienes ninguna posibilidad de ganarme... Necesito inculcarte esa lección en tu cuerpo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真是个坏家伙啊……变成这样你已经没有胜算了，我不是已经告诉过你很多次了吗……看来必须让你有更深刻的体会……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真是個壞傢伙啊……變成這樣你已經沒有勝算了，我不是已經告訴過你很多次了嗎……看來必須讓你有更深刻的體會……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00219",
		linknext = "0059_00221",
		line = 2815,
	},
	["0059_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun en este estado, intentar resistirse es inútil. De alguna manera, no tiene debilidades.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不行。即使被媚药混乱了大脑，她也完全不露出丝毫空隙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不行。即使被媚藥混亂了大腦，她也完全不露出絲毫空隙。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00220",
		linknext = "0059_00222",
		line = 2825,
	},
	["0059_00222"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
