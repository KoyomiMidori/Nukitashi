				{"vo", file="rei0377", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hit a sore spot, huh? Don't worry, I know firsthand what a hard worker you are. I'm not going to distrust my companions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“想不到你这么神经质。唉，别担心。你的努力我都看在眼里，我不会怀疑同伴的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「想不到你這麼神經質。唉，別擔心。你的努力我都看在眼裡，我不會懷疑同伴的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00056",
		linknext = "0059_00058",
		line = 674,
	},
	["0059_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm at a loss for words from being told that directly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直接听到这样的话，我反而说不出话来。",
