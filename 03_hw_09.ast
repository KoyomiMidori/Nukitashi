		{"fgact", ch="郁子", id=10, act="移動", x=-300, y=0, time=3600},
		{"fgact", ch="郁子", id=10, act="振動下", loop=12, size=17.5, time=403.5, ease="easeinout_sine"},
		{"text"},
		delay = {
