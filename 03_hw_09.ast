	["0059_00476"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1108", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“The public order issue? Yeah, we've been looking into it on our end, too. Apparently it's true that little kids are being assaulted...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“治安问题啊……我们大家也努力调查了很久。果然，小孩子的受害人数在增加一事，好像是真的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「治安問題啊……我們大家也努力調查了很久。果然，小孩子的受害人數在增加一事，好像是真的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00475",
		linknext = "0059_00477",
		line = 6032,
	},
	["0059_00477"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? You'd better be careful for yourself, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……渡酱，你也要多多小心啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……渡醬，你也要多多小心啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00476",
		linknext = "0059_00478",
		line = 6044,
	},
	["0059_00478"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1109", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Right! I can't let little kids suffer. I'll keep an eye out for them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！不能再让小孩子遇到危险了……我会小心到处看看的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！不能再讓小孩子遇到危險了……我會小心到處看看的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00477",
		linknext = "0059_00479",
		line = 6059,
	},
	["0059_00479"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not really what I meant, but sure...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不是这个意思……”",
