	},
	["0059_00492"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que Rei-senpai es más reflexiva. Está abierta al diálogo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈既不是那么武断也不是那么耿直的人——她是能对话的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩既不是那麼武斷也不是那麼耿直的人——她是能對話的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00491",
		linknext = "0059_00493",
		line = 6208,
	},
	["0059_00493"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por eso, creo que lo mejor es hablar con ella antes de que termine el fin de semana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此，我才想在有时间的休息日里，亲自到宿舍去谈这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此，我才想在有時間的休息日裡，親自到宿舍去談這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00492",
		linknext = "0059_00494",
		line = 6218,
	},
	["0059_00494"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=7000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1111", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Se volvieron muy cercanos, ¿eh? Jeje, me alegra mucho. Rei-chan es una buena chica, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君和礼酱关系变好了呢。诶嘿嘿，不知怎么的好开心……礼酱是个好孩子对吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君和禮醬關係變好了呢。欸嘿嘿，不知怎麼的好開心……禮醬是個好孩子對吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00493",
		linknext = "0059_00495",
		line = 6234,
	},
	["0059_00495"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Que si es buena...? Pues, no es malvada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“与其说是好孩子……我想应该不是坏人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「與其說是好孩子……我想應該不是壞人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00494",
		linknext = "0059_00496",
		line = 6246,
	},
	["0059_00496"] = {
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
			},
			[4000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00113", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1112", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Es una buena chica! ¿Eh...? Espera... ¡¿Desde cuándo la llamas Rei y no Tadasugawa?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……是个好孩子啦……咦？等一下……不知不觉间从糺川前辈变成礼前辈了！为什么！？什么时候开始的！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……是個好孩子啦……咦？等一下……不知不覺間從糺川前輩變成禮前輩了！為什麼！？什麼時候開始的！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00495",
		linknext = "0059_00497",
		line = 6263,
	},
	["0059_00497"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, me pidió que la llamara así a la hora del almuerzo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她让我这么叫……所以从中午开始的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她讓我這麼叫……所以從中午開始的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00496",
		linknext = "0059_00498",
		line = 6275,
	},
	["0059_00498"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
