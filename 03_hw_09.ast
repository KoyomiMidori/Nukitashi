	},
	["0059_00230"] = {
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a127"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Comienza a acariciarlo, desde la base del glande, intentando ver si me excito.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，就好像为了确认是否有感觉——她开始从根部往龟头抚摸鸡巴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，就好像為了確認是否有感覺——她開始從根部往龜頭撫摸肉棒。",
					{"rt2"},
				},
