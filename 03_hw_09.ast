			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hahaha... You're right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈哈……是啊。”",
					{"rt2"},
