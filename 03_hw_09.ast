		line = 6071,
	},
	["0059_00480"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The NLNS have their hands full doing what they can to investigate the public order and the girl known as Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"NLNS因为治安问题和“文乃”的问题而忙不过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"NLNS因為治安問題和「文乃」的問題而忙不過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00479",
		linknext = "0059_00481",
		line = 6081,
	},
	["0059_00481"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Meanwhile, here I am putting even more on their plate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——现在，我又要带来新的问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——現在，我又要帶來新的問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00480",
		linknext = "0059_00482",
		line = 6091,
	},
	["0059_00482"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As their leader, I can't let myself put even more burden on my companions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为队长，我不能再给同伴增加负担了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為隊長，我不能再給同伴增加負擔了。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00481",
		linknext = "0059_00483",
		line = 6101,
	},
	["0059_00483"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is my cross to bear.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自己的错误由自己纠正。这就是道理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自己的錯誤由自己糾正。這就是道理。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00482",
		linknext = "0059_00484",
		line = 6111,
	},
	["0059_00484"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I need to start moving to fix this myself...",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，我应该采取的对策是————",
					{"rt2"},
