	["0059_00521"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así... Gracias. Hablar contigo me hizo sentir un poco mejor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……谢谢你。和渡酱说了话后，我稍微轻松了一些。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……謝謝你。和渡醬說了話後，我稍微輕鬆了一些。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00520",
		linknext = "0059_00522",
		line = 6600,
	},
	["0059_00522"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=-150},
		{"text"},
		text = {
