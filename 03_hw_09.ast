	["0059_00501"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eso dices, pero ¿no es más infantil usar el nombre de pila de alguien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话是这么说。但是渡酱前辈，叫下面的名字不会比现在的感觉更孩子气吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話是這麼說。但是渡醬前輩，叫下面的名字不會比現在的感覺更孩子氣嗎？」",
					{"rt2"},
				},
