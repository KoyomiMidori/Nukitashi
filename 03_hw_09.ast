		line = 684,
	},
	["0059_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've been trying to gain their trust all along, but now that I've got it, my words catch in my throat. I don't know how to respond.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明按照当初的目的得到了信赖，但是不知为什么，胸中积压着消化不了的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明按照當初的目的得到了信賴，但是不知為什麼，胸中積壓著消化不了的東西。",
