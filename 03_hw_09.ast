		linkback = "0059_00470",
		linknext = "0059_00472",
		line = 5976,
	},
	["0059_00472"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, uh, nothing... I'm just concerned that I haven't made any real headway on the public order issue yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有。没有发生什么事……但治安问题一事停滞不前，让我有点在意。”",
					{"rt2"},
				},
			},
			tw = {
