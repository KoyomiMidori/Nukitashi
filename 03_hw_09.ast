				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se sienta en cuclillas en su silla, abrazándose las rodillas, y golpea con desánimo su ardillita.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她完全消沉了，开始在椅子上抱着膝盖戳着松鼠挂件。",
					{"rt2"},
				},
			},
			tw = {
