			},
		},
		text = {
			vo = {
				{"vo", file="hinami1112", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Of course she is! Also, wait. Since when do you call her Rei-senpai and not Tadasugawa-senpai!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……是个好孩子啦……咦？等一下……不知不觉间从糺川前辈变成礼前辈了！为什么！？什么时候开始的！？”",
