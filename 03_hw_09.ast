					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Vale, ven aquí! Tu senpai quiere darte caricias en la cabeza por todo tu esfuerzo. Bien, bien... Hiciste un buen trabajo, Tachibana-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……过来！前辈要好好摸一摸努力工作的橘君……好乖好乖……橘君真了不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……過來！前輩要好好摸一摸努力工作的橘君……好乖好乖……橘君真了不起。」",
					{"rt2"},
				},
