				},
			},
			cn = {
				{
					"但是，她的这句话完全没猜中我的想法——让我反而觉得很郁闷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，她的這句話完全沒猜中我的想法——讓我反而覺得很鬱悶。",
					{"rt2"},
				},
