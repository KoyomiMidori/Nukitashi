				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...And that's how I got saved from a wild boar piglet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——就这样，我从小野猪的危机中被拯救了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——就這樣，我從小野豬的危機中被拯救了。」",
					{"rt2"},
				},
			},
		},
		linknext = "0105_00002",
