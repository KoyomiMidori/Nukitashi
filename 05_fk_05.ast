	["0105_00176"] = {
		{"fg", file="touka_01f_00004", file1="touka_01f_00102", path=":fg/touka_01f/", id=30, ch="桐香", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
