		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"se", id=2, loop=1, file="se_d026", vol=30},
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So it's come to this...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……没想到会变成这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……沒想到會變成這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00223",
		linknext = "0105_00225",
		line = 3234,
	},
	["0105_00225"] = {
		{"bgm", file="bgm04.5", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wait for Fukiko at our meeting place, and sigh.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在和吹子约好的集合场所叹了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在和吹子約好的集合場所嘆了口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00224",
		linknext = "0105_00226",
		line = 3245,
	},
	["0105_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The president's conditions was that I would be available from emergency mobilization on weekends and the like when they were short on people, and in emergency situations.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长的条件是休息日等人手不足的时候，或者非常时期时需要紧急出动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長的條件是休息日等人手不足的時候，或者非常時期時需要緊急出動。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00225",
		linknext = "0105_00227",
		line = 3255,
	},
	["0105_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's provisional, but she said my name will be officially registered with the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是临时的，但据说在文件上要登记为FS。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是臨時的，但據說在文件上要登記為FS。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00226",
		linknext = "0105_00228",
		line = 3265,
	},
	["0105_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She smiled, saying it would basically be like being a member of the reserves.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说像后备人员般的存在，她笑着说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說像後備人員般的存在，她笑著說。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00227",
		linknext = "0105_00229",
		line = 3275,
	},
	["0105_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had to accept it as a situation where I had to make a sacrifice to get out of the situation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为没有选择，所以只能答应了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為沒有選擇，所以只能答應了——",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00228",
		linknext = "0105_00230",
		line = 3285,
	},
	["0105_00230"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Can't believe I sold myself out to the enemy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“向敌对组织出卖自己什么的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「向敵對組織出賣自己什麼的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00229",
		linknext = "0105_00231",
		line = 3297,
	},
	["0105_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, even if I didn't accept it on the spot, I would have had to accept her conditions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即使不是在那种场合，这个条件我也应该接受吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即使不是在那種場合，這個條件我也應該接受吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00230",
		linknext = "0105_00232",
		line = 3307,
	},
	["0105_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'll be forever struggling to find Fumino as long as I keep procrastinating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要继续将时间花在这边，寻找“文乃”一事将很难获得进展。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要繼續將時間花在這邊，尋找「文乃」一事將很難獲得進展。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00231",
		linknext = "0105_00233",
		line = 3317,
	},
	["0105_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to settle this quickly, to make less work for Nanase. I mean, I wanna hurry up and give these fuckers what for too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是为了减少奈奈濑的负担，也应该尽快结束。我也想早点狠狠地揍扁他们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是為了減少奈奈瀨的負擔，也應該盡快結束。我也想早點狠狠地揍扁他們。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00232",
		linknext = "0105_00234",
		line = 3328,
	},
	["0105_00234"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But man... What a tall order for a proud virgin like me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，身为高傲处男的我——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，身為高傲處男的我——」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00233",
		linknext = "0105_00235",
		line = 3340,
	},
