				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱在和奈奈濑进行摄像数据的解析工作，所以没法来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬在和奈奈瀨進行攝像數據的解析工作，所以沒法來。」",
