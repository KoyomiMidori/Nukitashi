	["0105_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I leap out of my skin when she appears without a sound yet again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对今天也无声无息出现的吹子，我不由自主地跳了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對今天也無聲無息出現的吹子，我不由自主地跳了起來。",
					{"rt2"},
				},
			},
