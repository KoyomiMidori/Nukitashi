	["0105_00047"] = {
		{"bgm", file="bgm12", vol=100},
		{"cgact", file="cgact", id=1, act="移動", x=95, y=-5, time=20000},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=400},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir, with all due respect, why is it imperative that we rush this along?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……老爷爷，我知道这么问很失礼，但你为什么这么着急？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……老爺爺，我知道這麼問很失禮，但你為什麼這麼著急？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00046",
