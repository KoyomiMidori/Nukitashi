		},
		linkback = "0105_00167",
		linknext = "0105_00169",
		line = 2454,
	},
	["0105_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her voice quietly takes command of the environment.",
					{"rt2"},
