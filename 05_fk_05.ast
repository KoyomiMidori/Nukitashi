				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“M-My apologies... That explains why you've acted so strangely since last night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“真是对不起……所以，从昨天晚上开始……您就一直……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「真是對不起……所以，從昨天晚上開始……您就一直……」",
					{"rt2"},
				},
			},
		},
