					name = {"麻沙音", "Asane"},
					"“And the one spot in Minotsuki Academy where you're most likely to find any good info is... You thinking what I'm thinking?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“水乃月学园中，信息聚集最多的地方……就是",
					{"ruby", text="・・"},
					"那里",
					{"/ruby"},
					"了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「水乃月學園中，資訊聚集最多的地方……就是",
					{"ruby", text="・・"},
					"那裡",
					{"/ruby"},
					"了。」",
					{"rt2"},
				},
			},
		},
