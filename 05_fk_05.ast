	},
	["0105_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'll admit that failing to account for the OSS searching for her at the same time as us was an oversight on my part.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和NLNS在寻找她一样，没预测到SHO也在寻找她是我的错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和NLNS在尋找她一樣，沒預測到SHO也在尋找她是我的錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00064",
		linknext = "0105_00066",
		line = 916,
	},
	["0105_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're gonna need to give him results as quickly and smoothly as possible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"必须尽快且确实地取得成果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"必須盡快且確實地取得成果。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00065",
		linknext = "0105_00067",
		line = 926,
	},
	["0105_00067"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If the OSS have been searching for Fumino as well, it's fair to assume that they have some measure of intel on her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……如果说SHO在寻找文乃，那就应该认定他们已经收集了一些她的情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……如果說SHO在尋找文乃，那就應該認定他們已經收集了一些她的情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00066",
		linknext = "0105_00068",
		line = 938,
	},
	["0105_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In which case... our best bet on getting more info is heading for the one spot that's as close to the OSS as you can get in this academy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如此一来……从这个学校里离SHO最近的地方把数据偷出来是最快的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如此一來……從這個學校裡離SHO最近的地方把數據偷出來是最快的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00067",
		linknext = "0105_00069",
		line = 950,
	},
	["0105_00069"] = {
