		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=100, ease="easeinout_sine"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=5, size=5, time=50, ease="easeinout_sine"},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0107", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Then what the hell do you have to show for that!? You have an objective, do not lose sight of it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“那那副不争气的样子是怎么回事！？难道你们忘了原本的夙愿吗——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「那那副不爭氣的樣子是怎麼回事！？難道你們忘了原本的夙願嗎——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00041",
		linknext = "0105_00043",
		line = 609,
	},
	["0105_00043"] = {
