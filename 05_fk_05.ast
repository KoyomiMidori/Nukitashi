		{"cgact", file="cgact", id=2, act="移動", x=495, y=-5, time=20000, lv=5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That sound... Gather round the screen, people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个声音——大家集合。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個聲音——大家集合。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00028",
