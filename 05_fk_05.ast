			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah, screw it, do whatever you want. Can we at least get back to discussing our search for this Fumino girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊——好了好了随你的便。然后，关于我这边寻找‘文乃’的部份——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊——好了好了隨你的便。然後，關於我這邊尋找『文乃』的部份——」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00027",
		linknext = "0105_00029",
		line = 415,
	},
	["0105_00029"] = {
