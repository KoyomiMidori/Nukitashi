	["0105_00307"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=7.5, time=100, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00122", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, I'm not, not in the slightest! I just wanted to see if you were a ghost or not!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是那样的！我是想确认你到底是不是幽灵！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是那樣的！我是想確認你到底是不是幽靈！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00306",
		linknext = "0105_00308",
		line = 4272,
	},
	["0105_00308"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00114", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes go wide with astonishment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吹子一脸茫然地瞪大了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吹子一臉茫然地瞪大了眼睛。",
