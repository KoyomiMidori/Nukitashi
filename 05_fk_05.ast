				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“A-Are you sure about having me do this? I mean, this is usually Asane's job...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是，我可以吗？好不安啊，因为这是麻沙音酱的工作啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是，我可以嗎？好不安啊，因為這是麻沙音醬的工作啊……」",
