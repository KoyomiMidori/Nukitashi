				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“EEEK! C-Cut that shit out, Hotori! You made Asa here faint from the shock!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咿——！住手畔！麻沙酱都害怕到晕过去了哦！？”",
