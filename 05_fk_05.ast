		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2104", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Umm... Hold up, I don't see the issue here. Do you seriously think that girl might be a ghost?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃……等一下，我找不到问题点……你觉得那个孩子可能是幽灵吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃……等一下，我找不到問題點……你覺得那個孩子可能是幽靈嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00003",
		linknext = "0105_00005",
		line = 59,
	},
	["0105_00005"] = {
