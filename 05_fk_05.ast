				{"fg", file="hinami_02m_00001", file1="hinami_02m_00116", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=-600, y=0},
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00119", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami2108", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Haaaah! Man, I could barely breathe this time! That was scary...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……噗哈啊啊……！总觉得这次太令人喘不过气了……！好可怕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……噗哈啊啊……！總覺得這次太令人喘不過氣了……！好可怕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00057",
		linknext = "0105_00059",
		line = 824,
	},
	["0105_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, the old codger does have a point...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，老人说的话也没错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，老人說的話也沒錯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00058",
		linknext = "0105_00060",
		line = 836,
	},
	["0105_00060"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase, be real with us. How's our situation?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……奈奈濑，你实际上成果怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……奈奈瀨，你實際上成果怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00059",
		linknext = "0105_00061",
		line = 852,
	},
	["0105_00061"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2114", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Just like I said, it's still a wash. We're combing the OSS cams for potential suspects, but nobody matches the profile.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“就像我说的，几乎没有啊……虽然查遍了SHO的间谍摄像头，还把可疑人物列了个名单，但还是没有找到类似的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「就像我說的，幾乎沒有啊……雖然查遍了SHO的間諜攝影機，還把可疑人物列了個名單，但還是沒有找到類似的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00060",
		linknext = "0105_00062",
		line = 866,
	},
	["0105_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see... Well, you're doing what you can, anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……但是这个方法应该没有问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……但是這個方法應該沒有問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00061",
		linknext = "0105_00063",
		line = 878,
	},
	["0105_00063"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I can get Asane to put some time into things, we should have a better chance of finding her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要和麻沙音一起花时间，发现率就会提高。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
