			cn = {
				{
					"奈奈濑吓了一跳。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨嚇了一跳。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00042",
		linknext = "0105_00044",
		line = 622,
	},
	["0105_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But that was no reason to scold Nanase.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……但是奈奈濑并没有被斥责的理由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……但是奈奈瀨並沒有被斥責的理由。",
					{"rt2"},
				},
