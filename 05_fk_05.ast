		linkback = "0105_00307",
		linknext = "0105_00309",
		line = 4285,
	},
	["0105_00309"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, well, it's just that I've heard people from the nearby settlement talking about a ghost who has long hair and wears a kimono!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊不是，我从村落的人那里听说了这一带会出现长头发的和服幽灵……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊不是，我從村落的人那裡聽說了這一帶會出現長頭髮的和服幽靈……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00308",
		linknext = "0105_00310",
		line = 4297,
	},
	["0105_00310"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So I ended up wondering if you were, in fact, that ghost! I've been terrified outta my damn wits about that all along!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我就想说会不会是吹子——！那让我一直好害怕……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我就想說會不會是吹子——！那讓我一直好害怕……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00309",
		linknext = "0105_00311",
		line = 4309,
