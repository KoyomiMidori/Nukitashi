					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just saying so doesn't make it true! Is there anyone who's definitively proven that ghosts don't exist?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“尽管很多人都这么说，但谁能证明幽灵真的不存在？”",
