		linkback = "0105_00017",
		linknext = "0105_00019",
		line = 281,
	},
	["0105_00019"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00112", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1577", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Jibblie jibblie jibblie wait please forgive me Miss Landlord I'll get you the rest of this month's rent just gimme a little more time pleeeeease!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊波碑碑啊叭叭叭请等一下对不起房东先生本月的房租请再稍微等我一下啊啊啊啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊波碑碑啊叭叭叭請等一下對不起房東先生本月的房租請再稍微等我一下啊啊啊啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00018",
		linknext = "0105_00020",
		line = 294,
	},
	["0105_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Snap out of it! We own our house!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“振作起来麻沙酱！我们家是自己的哦——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「振作起來麻沙醬！我們家是自己的哦——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00019",
		linknext = "0105_00021",
		line = 306,
	},
	["0105_00021"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2107", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“As if that kind of ghost's gonna be rich anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话说回来那个幽灵绝对不是有钱人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話說回來那個幽靈絕對不是有錢人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00020",
		linknext = "0105_00022",
		line = 320,
	},
	["0105_00022"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase clears her throat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑咳了一声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨咳了一聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00021",
		linknext = "0105_00023",
		line = 333,
	},
	["0105_00023"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2108", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, anyway. I'll ask just to be sure. If that girl 'might' be a ghost, does that mean you're gonna stop working with her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……那么，我姑且问一下，你不帮那个可能是幽灵的女孩了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……那麼，我姑且問一下，你不幫那個可能是幽靈的女孩了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00022",
		linknext = "0105_00024",
		line = 347,
	},
	["0105_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I-I never said I'd go that far... I'm going to keep helping her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不、不能这样……我会继续的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不、不能這樣……我會繼續的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00023",
		linknext = "0105_00025",
		line = 359,
	},
	["0105_00025"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2109", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I see. Well, just suck it up and you'll get through the scary part. And check to see if the broad has legs while you're at it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哦。那你就好好一边害怕一边加油吧。或是让她给你看看她有没有腿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哦。那你就好好一邊害怕一邊加油吧。或是讓她給你看看她有沒有腿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00024",
		linknext = "0105_00026",
		line = 373,
	},
	["0105_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“R-Right, she wouldn't have legs if she were a ghost... That'd explain the lack of footstep noises she makes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如、如果是幽灵就没有腿，而且也能说明为什么几乎没有脚步声。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如、如果是幽靈就沒有腿，而且也能說明為什麼幾乎沒有腳步聲。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00025",
		linknext = "0105_00027",
		line = 385,
	},
	["0105_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But checking out the legs of an unspoiled maiden... I'm a proud virgin! That'd basically be first base right there, wouldn't it!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是作为一名高傲的处男居然要让纯洁的少女给自己看腿，这种事说是性行为也不为过吧——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是作為一名高傲的處男居然要讓純潔的少女給自己看腿，這種事說是性行為也不為過吧——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00026",
		linknext = "0105_00028",
		line = 397,
	},
	["0105_00028"] = {
		{"bgm", stop=1},
		{"text"},
		delay = {
