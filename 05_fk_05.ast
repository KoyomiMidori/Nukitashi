		linkback = "0105_00212",
		linknext = "0105_00214",
		line = 3047,
	},
	["0105_00214"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0703", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Does that mean you've come to see if we've put into place countermeasures to prevent young girls below the legal age being assaulted?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这么说来，前辈……你是来确认我们FS有没有在处理未满条例年龄子女被袭击的事件是吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這麼說來，前輩……你是來確認我們FS有沒有在處理未滿條例年齡子女被襲擊的事件是吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00213",
		linknext = "0105_00215",
		line = 3062,
	},
	["0105_00215"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“W-Well, yeah... I wanted to see if you knew anything about that. I'm trying to make myself useful too, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，没错……有情报的话我还想偷走。因为我比较有用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，沒錯……有情報的話我還想偷走。因為我比較有用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00214",
		linknext = "0105_00216",
		line = 3074,
	},
	["0105_00216"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0704", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Fair enough... the SS is chronically short of people, thus we do not have much information on the issue.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“原来如此……现在FS慢性人才不足。所以关于那件事，并没有什么太有用的情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「原來如此……現在FS慢性人才不足。所以關於那件事，並沒有什麼太有用的情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00215",
		linknext = "0105_00217",
		line = 3088,
	},
	["0105_00217"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0705", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But we've received scholarships from the OSS, who maintain the island's public order. Naturally, we do have some information.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是我们也是从维护岛上治安的SHO那里获得奖学金的人，所以当然也知道一些事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是我們也是從維護島上治安的SHO那裡獲得獎學金的人，所以當然也知道一些事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00216",
		linknext = "0105_00218",
		line = 3100,
	},
	["0105_00218"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0706", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm not against revealing the investigative data we have, if you want it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“想知道这个情报的话……也不是不能公开调查资料。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「想知道這個情報的話……也不是不能公開調查資料。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00217",
		linknext = "0105_00219",
		line = 3114,
	},
	["0105_00219"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? Really!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么，真的吗——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼，真的嗎——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00218",
		linknext = "0105_00220",
		line = 3127,
	},
	["0105_00220"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1071", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Miss Touka! What on earth!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“桐香大人！你到底在说什——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「桐香大人！你到底在說什——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00219",
		linknext = "0105_00221",
		line = 3142,
	},
	["0105_00221"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00120", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00110", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0593", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ah-ah-ah, not so fast! That kind of info's strictly limited to sharing among members of the SS, Darling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过很可惜，我们规定这些情报只能在FS之间互相传递，懂了吗亲爱的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過很可惜，我們規定這些情報只能在FS之間互相傳遞，懂了嗎親愛的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00220",
		linknext = "0105_00222",
		line = 3158,
	},
	["0105_00222"] = {
		{"bgm", stop=1},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0707", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Precisely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，所以说——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，所以說——」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00221",
		linknext = "0105_00223",
		line = 3173,
	},
	["0105_00223"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0708", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Ergo, if you were to become a provisional SS member, I could use my authority as student council president to allow it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果你成为FS的临时成员，我就以学生会长的名义允许这件事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「如果你成為FS的臨時成員，我就以學生會長的名義允許這件事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00222",
		linknext = "0105_00224",
		line = 3188,
	},
	["0105_00224"] = {
