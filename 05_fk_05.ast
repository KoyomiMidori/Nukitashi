		line = 2464,
	},
	["0105_00170"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The disciplinary committee president had taken a pair of pliers out but stops in her tracks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"取出钳子的风纪委员长突然停了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"取出鉗子的風紀委員長突然停了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00169",
		linknext = "0105_00171",
		line = 2475,
	},
	["0105_00171"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00103", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1066", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But, Miss Touka, there's the possibility this guy's part of the Anti-Copulation Front that is giving us trouble.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是桐香大人，这家伙很有可能是我们的眼中钉反交尾势力——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是桐香大人，這傢伙很有可能是我們的眼中釘反交尾勢力——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00170",
		linknext = "0105_00172",
		line = 2488,
	},
	["0105_00172"] = {
		{"fg", file="touka_01f_00004", file1="touka_01f_00111", path=":fg/touka_01f/", id=30, ch="桐香", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0697", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Still, he is one of our students, and we do not torture our own on school grounds. Is that not so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不过光是我们学校的学生进了学校的房间，可没有到需要拷问的程度不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不過光是我們學校的學生進了學校的房間，可沒有到需要拷問的程度不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00171",
		linknext = "0105_00173",
		line = 2501,
	},
	["0105_00173"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00115", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1067", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yes, you're absolutely right. I was being hasty. I'm terribly sorry, Miss Touka.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……是的，没错。我太性急了。很抱歉，桐香大人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……是的，沒錯。我太性急了。很抱歉，桐香大人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00172",
		linknext = "0105_00174",
		line = 2514,
	},
	["0105_00174"] = {
		{"fg", file="touka_01f_00004", file1="touka_01f_00110", path=":fg/touka_01f/", id=30, ch="桐香", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0698", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm sorry, our Rei was being hasty. She almost crossed the line there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不好意思，我家的礼太急了，一不小心就做过头了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不好意思，我家的禮太急了，一不小心就做過頭了。」",
					{"rt2"},
				},
			},
		},
