		line = 674,
	},
	["0105_00048"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We have not forgotten our objective. Abolishing the perverted sex law is our desired outcome.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们并没有忘记自己的本分，破坏变态条例才是我的夙愿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們並沒有忘記自己的本分，破壞變態條例才是我的夙願。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00047",
		linknext = "0105_00049",
		line = 686,
	},
	["0105_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure you are aware of that. With the scale of our objective, we cannot reasonably expect to get results within a mere few days.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老爷爷你应该也很清楚，很清楚这不是几天就能得出结果的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「老爺爺你應該也很清楚，很清楚這不是幾天就能得出結果的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00048",
		linknext = "0105_00050",
		line = 698,
	},
	["0105_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So why do you rush us along like this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，为何你还这么着急呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，為何你還這麼著急呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00049",
		linknext = "0105_00051",
		line = 710,
	},
	["0105_00051"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0108", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“My motives are none of your concern. As your benefactor, it is my responsibility to expect results.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“……我的想法和你没有关系。既然出了资，当然会期待成果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「……我的想法和你沒有關係。既然出了資，當然會期待成果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00050",
		linknext = "0105_00052",
		line = 723,
	},
	["0105_00052"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0109", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“However... I will acknowledge that with the scale of activity around me, I am growing restless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“……不过……我就承认吧，因为周围的活动变得活跃，让我感到着急。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「……不過……我就承認吧，因為周圍的活動變得活躍，讓我感到著急。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00051",
		linknext = "0105_00053",
		line = 736,
	},
	["0105_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……什么？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……什麼？",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00052",
		linknext = "0105_00054",
		line = 746,
	},
	["0105_00054"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you talking about how the OSS are looking for Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道……SHO在寻找文乃？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道……SHO在尋找文乃？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00053",
		linknext = "0105_00055",
		line = 758,
	},
	["0105_00055"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0110", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Precisely. She is the ace in the hole capable of destroying their final stronghold. As such, it is imperative that we get ahold of her as soon as possible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“没错。对他们来说，‘文乃’是唯一能摧毁他们堡垒的大炮和宝剑。想要尽快得到她也是理所当然的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「沒錯。對他們來說，『文乃』是唯一能摧毀他們堡壘的大砲和寶劍。想要盡快得到她也是理所當然的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00054",
		linknext = "0105_00056",
		line = 771,
	},
	["0105_00056"] = {
		{"bgm", stop=1},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0111", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“So I do expect you to secure her promptly. That will be all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“正因为如此，我才希望你们能尽快救出‘文乃’，就这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「正因為如此，我才希望你們能盡快救出『文乃』，就這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00055",
		linknext = "0105_00057",
		line = 785,
	},
