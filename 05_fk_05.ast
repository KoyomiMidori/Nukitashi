		},
		linkback = "0105_00043",
		linknext = "0105_00045",
		line = 632,
	},
	["0105_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As the leader, all the responsibility lies with me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"责任全部在于作为领导者的我。",
