	["0105_00046"] = {
		{"se", id=0, loop=0, file="se_a032"},
		{"bg", id=1, file="bg12_1l_00000", x=100, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="nanase_02l_00001", file1="nanase_02l_00119", file2="nanase_02l_00202", path=":fg/nanase_02l/", id=4, lv=5, head="nanase_02l", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
