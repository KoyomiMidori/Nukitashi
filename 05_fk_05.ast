			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, I think I've gotten the hang of this now, but there's a lot of flashing red lights on here, it's kinda tough to tell them apart... Um, am I doing all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，我已经渐渐上手了……红色闪光的数量很多，让人难以判断的地方很多啊……呃，应该没事吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，我已經漸漸上手了……紅色閃光的數量很多，讓人難以判斷的地方很多啊……呃，應該沒事吧……？」",
					{"rt2"},
				},
			},
		},
