			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There is something that has us rather curious, though. Namely, the question of how you managed to get that door open... So?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我们只是想知道，你用了什么魔术打开了风纪委员室的门，之类的……你说呢，前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我們只是想知道，你用了什麼魔術打開了風紀委員室的門，之類的……你說呢，前輩？」",
					{"rt2"},
				},
			},
