		linkback = "0105_00166",
		linknext = "0105_00168",
		line = 2441,
	},
	["0105_00168"] = {
		{"fg", file="touka_01f_00004", file1="touka_01f_00110", path=":fg/touka_01f/", id=30, ch="桐香", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0696", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I believe that will be enough intimidation, Rei.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——差不多就好，别再吓他了，礼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——差不多就好，別再嚇他了，禮。」",
