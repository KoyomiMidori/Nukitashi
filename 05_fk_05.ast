	["0105_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't feel frightened by her anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我已经不再对学生会长感到恐惧了。",
					{"rt2"},
				},
			},
			tw = {
