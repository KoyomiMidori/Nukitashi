	["0105_00031"] = {
		{"bgm", file="bgm14", vol=100},
		{"se", id=0, loop=0, file="se_b032"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a prolonged display of static, and then the old man appears.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一段长时间的杂讯过后，老人的脸出现了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一段長時間的雜訊過後，老人的臉出現了。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00030",
		linknext = "0105_00032",
		line = 462,
	},
	["0105_00032"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0103", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“All present and accounted for, I see. What is your progress in regard to searching for the girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“所有人都在吗……关于搜索少女一事，情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「所有人都在嗎……關於搜索少女一事，情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00031",
		linknext = "0105_00033",
		line = 476,
	},
	["0105_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The search for Fumino is currently entrusted to Nanase.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最近寻找“文乃”的任务交给了奈奈濑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最近尋找「文乃」的任務交給了奈奈瀨。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00032",
		linknext = "0105_00034",
		line = 486,
	},
	["0105_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look at her imploringly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我用眼神示意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我用眼神示意。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00033",
		linknext = "0105_00035",
		line = 496,
	},
	["0105_00035"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=0, loop=0, file="se_a032"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2111", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sir, our search is still ongoing right now. However, we have been unable to locate her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是的……现在正在进行调查，但还没有发现。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是的……現在正在進行調查，但還沒有發現。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00034",
		linknext = "0105_00036",
		line = 512,
	},
	["0105_00036"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0104", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Hmm. Have you found any leads?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“嗯……有掌握什么线索吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「嗯……有掌握什麼線索嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00035",
		linknext = "0105_00037",
		line = 525,
	},
	["0105_00037"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2112", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We've actually been investigating OSS surveillance cameras and whatever other information we can. Still nothing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不，老实说……已经检查过SHO的监控录像了，但什么都没有发现……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不，老實說……已經檢查過SHO的監控畫面了，但什麼都沒有發現……」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00036",
		linknext = "0105_00038",
		line = 539,
	},
	["0105_00038"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0105", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“And yet, the atmosphere on your end seems rather lax. Enough so to be carrying on casual conversation with each other...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“但你看起来倒是一脸不着急的样子呢。顶多像在闲聊的程度吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「但你看起來倒是一臉不著急的樣子呢。頂多像在閒聊的程度吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00037",
		linknext = "0105_00039",
		line = 552,
	},
	["0105_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Irritation is clear in his voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人的声音中透露出明显不满。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人的聲音中透露出明顯不滿。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00038",
		linknext = "0105_00040",
		line = 562,
	},
	["0105_00040"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0106", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“I am not funding your operations out of charity, or on a personal whim. If you fail to deliver results... you do know what that means, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“我并没有打算白白把这一大笔钱交给你们……如果没有成果会怎样，你们明白吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「我並沒有打算白白把這一大筆錢交給你們……如果沒有成果會怎樣，你們明白吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00039",
		linknext = "0105_00041",
		line = 575,
	},
	["0105_00041"] = {
		{"text"},
		delay = {
