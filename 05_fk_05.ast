	["0105_00153"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="rei_01f_00001", file1="rei_01f_00103", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1062", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don't move. Make one unnecessary move and you'll be rendered unconscious instantly. You'll experience the effectiveness of the SS handguns firsthand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不要动。如果敢乱来，我就让你马上晕倒。那会让你切身体会到FS式手枪的威力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不要動。如果敢亂來，我就讓你馬上暈倒。那會讓你切身體會到FS式手槍的威力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00152",
