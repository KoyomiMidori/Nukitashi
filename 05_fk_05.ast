	["0105_00112"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00111", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
