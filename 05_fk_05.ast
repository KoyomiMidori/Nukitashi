	["0105_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So our plan is to infiltrate the office of the disciplinary committee. Luckily for us, sex classes are in session now, so all the SS should be out on duty.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在开始潜入风纪委员室。幸好现在正在上性爱课，为了监视大家，FS应该都出去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在開始潛入風紀委員室。幸好現在正在上性愛課，為了監視大家，FS應該都出去了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00081",
		linknext = "0105_00083",
		line = 1159,
	},
	["0105_00083"] = {
