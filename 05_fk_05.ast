		linkback = "0105_00211",
		linknext = "0105_00213",
		line = 3037,
	},
	["0105_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They can torture me all they like, but I plan to resist regardless.",
					{"rt2"},
