		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2105", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Not this crazy shit again... You do realize there's no such thing as ghosts, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么可能会有那种不现实的事情……幽灵什么的怎么可能存在啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼可能會有那種不現實的事情……幽靈什麼的怎麼可能存在啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00008",
		linknext = "0105_00010",
		line = 142,
	},
	["0105_00010"] = {
