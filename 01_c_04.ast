		{"bg", id=18, file="kcg020103", x=-5, y=-5, path=":cg/kcg02/", lv=5, ev=1, time=500, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0065", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oye... Tachibana... kun, ¿verdad? ¿Puedes probarlo por mí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂，你……呃，橘、君？能帮我尝尝这个吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂，你……呃，橘、君？能幫我嚐嚐這個嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00190",
