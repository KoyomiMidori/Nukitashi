				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No te preocupes, su virginidad está a flor de piel.”",
					{"rt2"},
				},
			},
			cn = {
