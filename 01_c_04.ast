					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Nanase"},
					"“Bien, ya hice algo de comer. Creo que no has comido aún, así que disfruta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "奈奈濑"},
					"“来。首先是第一道菜。看起来你们什么都没吃的样子，先用这个填填肚子吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "奈奈瀨"},
					"「來。首先是第一道菜。看起來你們什麼都沒吃的樣子，先用這個填填肚子吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00201",
		linknext = "0005_00203",
		line = 2584,
	},
	["0005_00203"] = {
