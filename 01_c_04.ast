				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No había ningún defecto en su postura y sus movimientos eran impecables.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那姿势没有一丝破绽，动作没有一点多余。",
