		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0067", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"非表示", "奈々瀬"},
