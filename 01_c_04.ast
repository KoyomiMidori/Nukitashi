	["0005_00208"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00109", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-400, y=0, time=600},
		{"fg", file="asane_01m_00003", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0231", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Manitoo! ¡Estoy muy triste! ¡No hay sitio para mí en el mundo online! ¡Por favor, acaríciame la cabeza y haz que todo mejoreee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥〜！好寂寞啊〜！果然在网络的海洋里没有自己的容身之处啊〜！摸摸我的头啊〜！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥〜！好寂寞啊〜！果然在網路的海洋裡沒有自己的容身之處啊〜！摸摸我的頭啊〜！」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00207",
		linknext = "0005_00209",
		line = 2657,
	},
	["0005_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi hermana finalmente aparece, aunque llorando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"眼中带泪的妹妹终于下来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"眼中帶淚的妹妹終於下來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00208",
		linknext = "0005_00210",
		line = 2667,
	},
	["0005_00210"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y en cuanto ve quién está en la cocina, se detiene en seco.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后她看到厨房里的人，跳了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後她看到廚房裡的人，跳了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00209",
		linknext = "0005_00211",
		line = 2680,
	},
	["0005_00211"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00112", file2="asane_02m_00204", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0232", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Eh... ¡¿E-E-E-E-E-E-Esa es Katagiri Nanase-san?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶……什什什什么，片桐奈奈濑同学——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸……什什什什麼，片桐奈奈瀨同學——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00210",
		linknext = "0005_00212",
		line = 2695,
	},
	["0005_00212"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00117", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
