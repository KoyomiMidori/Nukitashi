			},
		},
		linkback = "0005_00243",
		linknext = "0005_00245",
		line = 3131,
	},
	["0005_00245"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No pensé que me lo preguntaría directamente, así que dudé.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我没想到她会这么直接问我，结果一时语塞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沒想到她會這麼直接問我，結果一時語塞。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00244",
		linknext = "0005_00246",
		line = 3141,
	},
	["0005_00246"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Detesto la idea de tener sexo pervertido con una puta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我最讨厌婊子和变态做爱了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我最討厭婊子和變態做愛了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00245",
		linknext = "0005_00247",
		line = 3152,
	},
	["0005_00247"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun así, le digo lo que realmente pienso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我还是坦率地告诉了她我的真心话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我還是坦率地告訴了她我的真心話。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00246",
		linknext = "0005_00248",
		line = 3162,
	},
	["0005_00248"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No hay otra razón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为除此之外，没有其他理由——",
					{"rt2"},
