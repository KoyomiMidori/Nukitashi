	},
	["0005_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es probable que se deba a los cinco monitores y al PC ostentoso que utiliza.",
