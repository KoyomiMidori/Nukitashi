			},
			cn = {
				{
					name = {"淳之介"},
					"“你会说出‘前列腺说不想和色情的棒子离开呢～都黏在一起了",
					{"gaiji", text="①"},
					"’然后开发我对吧！！就像色情漫画那样！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你會說出『前列腺說不想和色色的棒子離開呢～都黏在一起了",
