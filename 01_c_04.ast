		},
		linkback = "0005_00251",
		linknext = "0005_00253",
		line = 3221,
	},
	["0005_00253"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0076", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Está bien. Si eso es lo quieres, no lo haré.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样啊，既然你都那么说了，那我也不打算做哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣啊，既然你都那麼說了，那我也不打算做哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00252",
		linknext = "0005_00254",
		line = 3235,
	},
	["0005_00254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Una respuesta completamente inesperada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是个令人意外的反应。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是個令人意外的回覆。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00253",
		linknext = "0005_00255",
		line = 3245,
	},
	["0005_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estaba bastante seguro de que esta zorra iba a interrogarme sobre por qué no me gusta excitarme todo el tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还以为这个婊子会追问我为什么不想做些舒服的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還以為這個婊子會追問我為什麼不想做些舒服的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00254",
		linknext = "0005_00256",
		line = 3255,
	},
	["0005_00256"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al fin y al cabo, es la respuesta que espero de la gente de esta isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我以为这是作为一个岛民的合理反应——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我以為這是作為一個島民的合理反應——",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00255",
		linknext = "0005_00257",
		line = 3265,
	},
	["0005_00257"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00117", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0077", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“... Es más, me estás haciendo un favor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……而且，这样对我来说也比较刚好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……而且，這樣對我來說也比較剛好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00256",
		linknext = "0005_00258",
		line = 3279,
	},
	["0005_00258"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cómo así? ¿A qué te refieres?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么？那是是什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼？那是什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00257",
		linknext = "0005_00259",
		line = 3291,
	},
	["0005_00259"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0078", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pues nada. ¿Por qué iba a querer follarme a un tipo que se la pasa llamándome puta y que no deja de ser un imbécil? Idiota.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没什么。意思是我打从一开始就不想和一个骂自己是婊子的人做，笨蛋。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒什麼。意思是我打從一開始就不想和一個罵自己是婊子的人做，笨蛋。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00258",
		linknext = "0005_00260",
		line = 3305,
	},
	["0005_00260"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0079", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pero bueno. No voy a hacer nada pervertido en tu casa, te lo prometo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“总之，我向你保证不会在你家做任何变态的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「總之，我向你保證不會在你家做任何變態的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00259",
		linknext = "0005_00261",
		line = 3319,
	},
	["0005_00261"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0080", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Y en cuanto a tus violaciones de la ley... guardaré silencio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你打算违反条例的事情……也帮你对其他人保密。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你打算違反條例的事情……也幫你對其他人保密。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00260",
		linknext = "0005_00262",
		line = 3333,
	},
	["0005_00262"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0081", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pero a cambio... ¿puedo pedirte un favor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以，作为回报……我有个希望你帮忙的事情，可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以，作為回報……我有個希望你幫忙的事情，可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00261",
		linknext = "0005_00263",
		line = 3347,
	},
	["0005_00263"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Q-Qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什……什么事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什……什麼事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00262",
		linknext = "0005_00264",
		line = 3359,
	},
	["0005_00264"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00112", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0082", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Me gustaría que mantuvieras en secreto el hecho de que hago este servicio de limpieza. Lo cierto es que tengo prohibido realizar trabajos a tiempo parcial.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“家务代理服务的事情，要帮我保密……学校一般不让打工。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「家事代理服務的事情，要幫我保密……學校一般不讓打工。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00263",
		linknext = "0005_00265",
		line = 3373,
	},
	["0005_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso... un trabajo así, normal, y a tiempo parcial, estaría prohibido aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说起来……普通的打工好像是禁止的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說起來……普通的打工好像是禁止的。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00264",
		linknext = "0005_00266",
		line = 3383,
	},
	["0005_00266"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0083", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ahora cada uno tiene secretos que guardar. Cumplamos nuestras partes del trato, ¿vale?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“为了我们双方好，今后要守护好秘密……约好了哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「為了我們雙方好，今後要保守好秘密……約好了哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00265",
		linknext = "0005_00267",
		line = 3397,
	},
	["0005_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y tras haber dicho todo eso, la zorra gyaru...",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着现在才想起这件事的我的脸，辣妹婊——",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著現在才想起這件事的我的臉，辣妹婊——",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00266",
		linknext = "0005_00268",
		line = 3407,
	},
