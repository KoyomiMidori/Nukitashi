					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tachibana Asane. Mi hermanita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“橘麻沙音，我的妹妹。”",
