	["0005_00185"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0061", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Traje algunos ingredientes para cocinar, pero no sabía que querías que hiciera más para después. ¿Te importa si sirvo lo que hay en la nevera?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我是有带一些食材来，但没想到要做可以保存的，我可以用冰箱里的东西吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我是有帶一些食材來，但沒想到要做可以保存的，我可以用冰箱裡的東西嗎？」",
					{"rt2"},
				},
			},
