	["0005_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estaba descansando de lo más cómodo. ¿En serio me hizo levantarme para eso?",
