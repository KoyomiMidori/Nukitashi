		line = 3172,
	},
	["0005_00249"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0075", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mmm... ¿Un chico que odia el sexo pervertido? Pues qué novedad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呼……我可从来没听说过有男人会讨厌有关变态做爱的事物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呼……我可從來沒聽說過有男人會討厭有關變態做愛的事物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00248",
		linknext = "0005_00250",
		line = 3186,
	},
	["0005_00250"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El corazón me late de manera desagradable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"胸口突然传来一阵不舒服的鼓动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"胸口突然傳來一陣不舒服的鼓動。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00249",
		linknext = "0005_00251",
		line = 3197,
	},
	["0005_00251"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siento que entendió todas mis intenciones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为感觉有什么被她看穿了一样。",
