		{"fg", file="kouki_01f_00001", file1="kouki_01f_00109", path=":fg/kouki_01f/", id=30, ch="光姫", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0016", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“¡Eh, espera! ¡Este es un servicio especial de fin de semana para los locales! ¡Mi entrenamiento de división de combate hará que te corras en un abrir y cerrar de ojos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“诶，等等！？这可是给镇上人们的假日特别服侍哦〜！？特殊战斗部的速舔服务哦〜！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「欸，等等！？這可是給鎮上人們的假日特別服侍哦〜！？特殊戰鬥部的速舔服務哦〜！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00004",
		linknext = "0005_00006",
		line = 86,
	},
	["0005_00006"] = {
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No me importa. Vete.",
					{"rt2"},
				},
			},
			cn = {
				{
					"关我何事，给我去其他地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不關我的事，給我去其他地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00005",
		linknext = "0005_00007",
		line = 97,
	},
	["0005_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
