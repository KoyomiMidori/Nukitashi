				},
			},
		},
		linkback = "0005_00017",
		linknext = "0005_00019",
		line = 271,
	},
	["0005_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tiene un juego diferente en cada uno de sus monitores. MMORPGs, FPS, MOBAs, cualquier cosa que se te ocurra la está jugando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"五个显示器各别都单独运行着游戏，MMORPG、FPS和MOBA，有各式各样的类型。",
					{"rt2"},
				},
			},
			tw = {
				{
					"五個顯示器各別都單獨運行著遊戲，MMORPG、FPS和MOBA，有各式各樣的類型。",
