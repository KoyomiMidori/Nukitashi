	["0005_00149"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0048", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Vale. Haré lo que pueda en el tiempo que me corresponde. ¿Te parece bien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好好好，那我就做时间内能完成的事吧？这样可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好好好，那我就做時間內能完成的事吧？這樣可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00148",
		linknext = "0005_00150",
		line = 1880,
	},
	["0005_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me parece bien. Pero la comida es lo que importa, así que te pido que tengas cuidado con eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没问题，但我希望你优先做饭……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒問題，但我希望你優先做飯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00149",
		linknext = "0005_00151",
		line = 1891,
	},
	["0005_00151"] = {
		{"text"},
		text = {
