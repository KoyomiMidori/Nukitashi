					name = {"奈々瀬", "Nanase"},
					"“¿Estás preocupado por mí porque ya oscureció? Ehh... conque sí puedes ser lindo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
