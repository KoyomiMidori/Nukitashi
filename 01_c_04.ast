	["0005_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me doy cuenta de que su monitor principal en el centro no está ejecutando un juego, sino una especie de editor de texto con un montón de cadenas introducidas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是中央主显示器上的并不是游戏画面，而是一长串文字。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是中央主顯示器上的並不是遊戲畫面，而是一長串文字。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00022",
		linknext = "0005_00024",
		line = 326,
	},
	["0005_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"También puedo ver una librería de desarrollo abierta al lado de esa ventana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她似乎还同时在运行着开发用的程序库。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她似乎還同時在運行著開發用的程式庫。",
