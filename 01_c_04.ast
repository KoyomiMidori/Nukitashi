			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Cada vez que pierdo en los FPS esos malditos extranjeros del chat se dedican a insultarme...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“从刚刚开始我一输FPS就有外国人在世界频道上嘲讽我……！”",
