		linknext = "0005_00214",
		line = 2721,
	},
	["0005_00214"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0069", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Eh, manita... Un placer conocerte, Asane-chan. Ya que me conoces, tú también vas a la Academia Minotsuki, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶，橘君的……初次见面，麻沙音酱……既然你知道我，那你也是水乃月学园的学生吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸，橘君的……初次見面，麻沙音醬……既然你知道我，那你也是水乃月學園的學生吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00213",
		linknext = "0005_00215",
		line = 2735,
	},
	["0005_00215"] = {
