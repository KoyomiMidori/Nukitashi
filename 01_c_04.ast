	},
	["0005_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La habitación estaba hecha un desastre, pero en una hora no queda ni una mota de polvo y se encuentra limpia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么凌乱的房间，只花了一个小时就变成了没有一丝灰尘的空间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼凌亂的房間，只花了一個小時就變成了沒有一絲灰塵的空間。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00181",
