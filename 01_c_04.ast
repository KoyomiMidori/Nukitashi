		{"text"},
		delay = {
			[3000] = {
				{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=200, y=0},
				{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=3000, time=500, mode=3, x=200, y=0},
				{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=700, delay2=3000},
			},
		},
		text = {
