					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, representante Hanamaru... Buenos días. Solo vine a comprar unas cosas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“花丸委员长……早上好，我想说买东西顺便……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「花丸委員長……早安，我想說買東西順便……」",
