				},
			},
			cn = {
				{
					"它属于“缓系列”系统，洞口的两翼备有比较大的",
					{"ruby", text="・・・"},
					"小阴唇",
					{"/ruby"},
					"，属于高级志向。作为非穿透形的特征，它有着强力的吸引力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"它屬於「療癒系」系統，洞口的兩翼備有比較大的",
					{"ruby", text="・・・"},
					"小陰唇",
					{"/ruby"},
					"，側重品質。作為非穿透型的特徵，它有著強力的吸引力。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00120",
