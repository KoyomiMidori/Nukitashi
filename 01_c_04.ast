	["0005_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al abrir la puerta, encuentro a mi hermana en su posición habitual frente al ordenador, mirando fijamente los monitores.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我打开门时，妹妹正盯着家用电脑的显示器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我打開門時，妹妹正盯著家用電腦的顯示器。",
					{"rt2"},
				},
