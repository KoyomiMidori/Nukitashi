	["0005_00252"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero la puta se da la vuelta y se pone a pensar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，辣妹婊只是别过了头，用鼻子呼了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，辣妹婊只是別過了頭，用鼻子呼了口氣。",
					{"rt2"},
				},
