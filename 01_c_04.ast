					name = {"淳之介", "Junnosuke"},
					"“Bueno, hacer tantas cosas al mismo tiempo no hará que mejores.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看来你即使可以同时玩几个游戏，但玩得并不好呢。”",
