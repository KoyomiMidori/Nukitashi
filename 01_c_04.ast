	["0005_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Acto seguido, abre su bolso y saca todo tipo de utensilios de limpieza.",
					{"rt2"},
				},
			},
			cn = {
