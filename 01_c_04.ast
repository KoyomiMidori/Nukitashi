	["0005_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He designado este modelo 1 de la “serie de empuje”. Está equipado con grandes aletas a ambos lados del orificio vaginal, en un esfuerzo por construirlo al nivel máximo. Como es resistente a la perforación, se le pueden aplicar altos niveles de succión.",
