	["0005_00216"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="asane_01l_00003", file1="asane_01l_00106", file2="asane_01l_00204", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Inmediatamente se acobarda detrás de mí, incapaz de articular palabra.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她完全说不出话来，躲到了我身后。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她完全說不出話來，躲到了我身後。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00215",
		linknext = "0005_00217",
		line = 2763,
	},
	["0005_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora mismo soy su escudo de carne.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后把我当成了盾牌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後把我當成了盾牌。",
