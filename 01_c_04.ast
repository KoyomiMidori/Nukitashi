			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡H-H-H-H-Ho-Hol, ho-ho-ho-hol...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你、你你你你你……！”",
					{"rt2"},
