			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estás jugando 4 o 5 juegos a la vez, ¿eh? Increíble.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你居然能同时玩着4、5个游戏……”",
					{"rt2"},
