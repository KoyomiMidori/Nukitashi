		linkback = "0005_00216",
		linknext = "0005_00218",
		line = 2773,
	},
	["0005_00218"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", file2="nanase_01m_00202", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0070", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah... ¿disculpa? Pues entré hace poco y vine a realizar tareas domésticas. Hice sándwiches, ¿quieres uno?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊……抱歉，我擅自进来了。我是来做家务代理的。如果你愿意，要吃三明治吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊……抱歉，我擅自進來了。我是來做家事代理的。如果你願意，要吃三明治嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00217",
		linknext = "0005_00219",
		line = 2788,
	},
	["0005_00219"] = {
		{"fg", file="asane_01l_00003", file1="asane_01l_00113", file2="asane_01l_00204", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0234", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ayy eres más que bienvenida aquí además estoy bien emocionada ante la idea de ser capaz de disfrutar de la comida de Nanase-san lo aceptaré con mucho gusto jejeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么会，怎么会是擅自能将奈奈濑同学的饭放入胃里我反而觉得惶恐至极呢嘿嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼會，怎麼會是擅自能將奈奈瀨同學的飯放入胃裡我反而覺得惶恐至極呢嘿嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00218",
		linknext = "0005_00220",
		line = 2802,
	},
	["0005_00220"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se la pasa observándola y sus ojos se mueven nerviosamente hasta que finalmente se lleva el sándwich a la boca.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她在我后面一边兴奋地喘着气，一边睁大眼睛吃着三明治。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她在我身後一邊興奮地喘著氣，一邊睜大眼睛吃著三明治。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00219",
		linknext = "0005_00221",
		line = 2813,
	},
	["0005_00221"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00119", file2="nanase_01m_00202", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
