				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El sabor persistente del caldo en mi boca es algo nostálgico.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知为何，留在嘴里的味道让我感到怀念。",
