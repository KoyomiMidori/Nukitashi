		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg08_00005", x=0, y=0, path=":cg/kcg08/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0218", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pues, ni siquiera he dormido... ¡Este puto me tuvo despierta toda la noche!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“应该说我还没睡……可恶，我可不能就这样去睡觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「應該說我還沒睡……可惡，我可不能就這樣去睡覺……」",
