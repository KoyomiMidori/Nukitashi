		},
		linkback = "0005_00013",
		linknext = "0005_00015",
		line = 221,
	},
	["0005_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El verano apenas comenzó, y tenemos el aire acondicionado funcionando a tope, pero parece que aún hace mucho calor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然夏天才刚开始却开着空调，但还是有点热。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然夏天才剛開始卻開著空調，但還是有點熱。",
					{"rt2"},
				},
			},
