			},
		},
		linkback = "0005_00242",
		linknext = "0005_00244",
		line = 3119,
	},
	["0005_00244"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為——」",
					{"rt2"},
