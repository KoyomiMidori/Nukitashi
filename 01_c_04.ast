				{"vo", file="asane0219", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Soy capaz... No pasa nada si me concentro y capto lo que pasa en cada uno... Solo es sentido e intuición.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这是有诀窍的……只要专注于掌握整体情况就ok了……接下来只要靠气息和直觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這是有訣竅的……只要專注於掌握整體情況就ok了……接下來只要靠氣息和直覺……」",
					{"rt2"},
				},
			},
		},
