		{"bgm", file="bgm06", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Vuelve a atarse el delantal y canturrea para sí misma en la cocina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再次系好围裙后，她站在厨房里哼着歌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再次穿好圍裙後，她站在廚房裡哼著歌。",
