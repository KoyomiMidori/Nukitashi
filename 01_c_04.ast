			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seguro que ahora mismo me sale vapor por las orejas, pero ella se limita a mirarme mal y se agacha junto a la nevera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面露反感的辣妹婊蹲到冰箱旁边，和激动的我形成鲜明的对比。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面露反感的辣妹婊蹲到冰箱旁邊，和激動的我形成鮮明的對比。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00167",
		linknext = "0005_00169",
		line = 2109,
	},
	["0005_00169"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0055", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Si pones cinta adhesiva de doble cara en una vara así, podrás utilizarla para llegar a lugares realmente estrechos que necesiten limpieza.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“只要用这种带有双面胶的棒子，就可以把手够不到的地方也清扫干净喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「只要用這種帶有雙面膠的棒子，就可以把手搆不到的地方也清掃乾淨喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00168",
		linknext = "0005_00170",
		line = 2122,
	},
	["0005_00170"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0056", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Siempre hago esto cuando entro en una casa. Me ayuda a hacerme una idea de lo sucia que está.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我每到一个新的家，都会检查家里有多脏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我每到一個新的家，都會檢查家裡有多髒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00169",
		linknext = "0005_00171",
		line = 2134,
	},
	["0005_00171"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00115", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0057", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mmm... Parece un poco acumulado ahí atrás. ¿Puedo tomar un poco de agua de tu grifo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……嗯，没被清扫过的样子呢……借你们的水用哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……嗯，沒怎麼清掃過的樣子呢……借你們的水用哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00170",
		linknext = "0005_00172",
		line = 2148,
	},
	["0005_00172"] = {
		{"se", id=0, loop=0, file="se_a001"},
