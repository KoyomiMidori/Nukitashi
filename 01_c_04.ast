		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0066", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya veo. Prefieres lo salado a lo dulce. No tengo tiempo de dejar que el caldo hierva a fuego lento así que iba a usar algún saborizante extra, pero ¿ustedes creen en la comida orgánica?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是吗，那比起甜的你更喜欢辣的呢。这次我用的是鲜味调味料，因为没有足够的时间炖高汤。你是天然食材的信奉者之类吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是嗎，那比起甜的你更喜歡辣的呢。這次我用的是鮮味調味料，因為沒有足夠的時間燉高湯。你是天然食材的信奉者之類嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00195",
		linknext = "0005_00197",
		line = 2505,
	},
	["0005_00197"] = {
