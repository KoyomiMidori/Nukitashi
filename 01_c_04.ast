		{"evset", file="kcg02", set="kcg02", path=":ev/kcg02/"},
		{"evset", file="kcg020103", set="kcg020103", path=":ev/kcg020103/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg020105", x=-5, y=-5, path=":cg/kcg02/", lv=5, ev=1, time=500, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0064", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sabes... es como una jungla, pero al menos tienes cosas que puedo usar. Con esto debería poder hacer comida para dos o tres días. Comenzaré con algo que pueda hervir...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……什么嘛，虽然很乱，但是材料还蛮多的嘛。这样做2、3天的份应该没问题。那就做些炖煮料理……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……什麼嘛，雖然很亂，但是材料還蠻多的嘛。這樣做2、3天的份應該沒問題。那就做些燉煮料理……」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00187",
		linknext = "0005_00189",
		line = 2404,
	},
	["0005_00189"] = {
		{"se", id=0, loop=0, file="se_a172"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pica con ritmo los ingredientes que ha sacado y hierve algo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她有节奏地切着拿出来的材料，并把某些东西煮熟了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她有節奏地切著拿出來的材料，並同時把某些東西煮熟了。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00188",
		linknext = "0005_00190",
		line = 2415,
	},
	["0005_00190"] = {
		{"text"},
		text = {
