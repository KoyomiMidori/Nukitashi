			en = {
				{
					"The yakuza would use Fumino to threaten Hitoura to abolish the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"黑社会用文乃威胁仁浦知事，让变态条例崩坏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"黑社會用文乃威脅仁浦知事，讓變態條例崩壞。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00072",
