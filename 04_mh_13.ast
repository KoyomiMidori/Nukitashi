		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0062", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "校内放送"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "School Broadcast"},
					"“A schoolwide general assembly will be held shortly. Please promptly interrupt your intercourse and assemble in the gymnasium, or continue engaging in intercourse as you make your way there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "校内广播"},
					"“——现在开始，举行全校集会。请迅速中断性行为，或一边进行性行为一边到体育馆集合。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "校內廣播"},
					"「——現在開始，舉行全校集會。請迅速中斷性行為，或一邊進行性行為一邊到體育館集合。」",
					{"rt2"},
				},
			},
		},
