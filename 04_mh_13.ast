		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That is all we have to report.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……以上是报告。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……以上是報告。」",
					{"rt2"},
				},
			},
		},
		linknext = "0090_00002",
		line = 19,
	},
	["0090_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You could cut the tension right now with a knife.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基地的气氛空前紧张。",
					{"rt2"},
				},
			},
			tw = {
				{
					"基地的氣氛空前緊張。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00001",
		linknext = "0090_00003",
		line = 29,
	},
	["0090_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's quiet enough that you can practically hear a pin drop.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每个人都把嘴抿成一字，一动也不动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每個人都把嘴抿成一字，一動也不動。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00002",
		linknext = "0090_00004",
		line = 39,
	},
	["0090_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No one in the base dares break the deafening silence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"寂静得令人窒息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"寂靜得令人窒息。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00003",
		linknext = "0090_00005",
		line = 49,
	},
	["0090_00005"] = {
		{"bgm", file="bgm09", vol=100},
		{"bg", id=2, file="bg12_1l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0090", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“YOU IMBECILE!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“蠢货！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「蠢貨！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00004",
		linknext = "0090_00006",
		line = 64,
	},
	["0090_00006"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00113", file2="hinami_01f_00202", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2042", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Eep!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呀……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呀……」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00005",
		linknext = "0090_00007",
		line = 77,
	},
	["0090_00007"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00103", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0091", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Not only have you failed to secure Fumino, but you let her fall into enemy hands as well!? This is how you repay me, you little shit!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“不仅没能确保文乃，还让她被敌人抓起来了！？你这个恩将仇报的蠢货……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「不僅沒能確保文乃，還讓她被敵人抓起來了！？你這個恩將仇報的蠢貨……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00006",
		linknext = "0090_00008",
		line = 90,
	},
	["0090_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I am terribly, terribly sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我无话可说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我無話可說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00007",
		linknext = "0090_00009",
		line = 101,
	},
	["0090_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's irate enough that I can envision him reaching through the monitor to throttle me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"隔着画面，我的前襟仿佛被人揪住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隔著畫面，我的前襟彷彿被人揪住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00008",
		linknext = "0090_00010",
		line = 111,
	},
	["0090_00010"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00103", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0092", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“How do you intend to atone for your incompetence? You do have some sort of contingency plan to retrieve her, I assume?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“这个结果，你打算怎么负责任？至少有在筹划如何夺回吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「這個結果，你打算怎麼負責任？至少有在籌劃如何奪回吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00009",
		linknext = "0090_00011",
		line = 124,
	},
	["0090_00011"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm afraid not...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“…………没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「…………沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00010",
		linknext = "0090_00012",
		line = 136,
	},
	["0090_00012"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0093", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You disgust me. Surely I must have been mad to entrust this job with the likes of you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——真是个让人无语的男人。我的眼睛一定是生锈了，才会看上你这样的家伙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——真是個讓人無語的男人。我的眼睛一定是生鏽了，才會看上你這樣的傢伙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00011",
		linknext = "0090_00013",
		line = 149,
	},
	["0090_00013"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1397", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“N-Now hang on, there's no need to say that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“请、请等一下，你也不需要说到那么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「請、請等一下，你也不需要說到那麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00012",
		linknext = "0090_00014",
		line = 163,
	},
	["0090_00014"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0094", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“A newcomer speaks? If you intend on interjecting, I presume you have something to say that will not waste my time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——是新面孔吗？既然插嘴了，一定有什么有意义的话要讲吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——是新面孔嗎？既然插嘴了，一定有什麼有意義的話要講吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00013",
		linknext = "0090_00015",
		line = 176,
	},
	["0090_00015"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1398", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, um... it's true that we don't have a plan for retrieving her, but we know who abducted her, so I'm sure we can come up with something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，呃……夺回文乃酱的方法的确还没有……不过我们知道是谁夺走了文乃酱……所以，一定会有好办法的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，呃……奪回文乃醬的方法的確還沒有……不過我們知道是誰奪走了文乃醬……所以，一定會有好辦法的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00014",
		linknext = "0090_00016",
		line = 188,
	},
	["0090_00016"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0095", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Ridiculous. Everyone knows who was after Fumino— the OSS, and its subordinate division, the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“无聊。看上文乃的人根本不用多说，是SHO和下级组织FS对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「無聊。看上文乃的人根本不用多說，是SHO和下級組織FS對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00015",
		linknext = "0090_00017",
		line = 201,
	},
	["0090_00017"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1399", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? No, that's wrong. Right, Junnosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……咦？不，不是的……对吧？淳之介君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……咦？不，不是的……對吧？淳之介君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00016",
		linknext = "0090_00018",
		line = 216,
	},
	["0090_00018"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. Sir, with all due respect, she is telling the truth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的——老爷爷，容我说一句。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的——老爺爺，容我說一句。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00017",
		linknext = "0090_00019",
		line = 228,
	},
	["0090_00019"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Neither the SS nor the OSS have abducted Fumino. The yakuza who have overrun this island are to blame for that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“夺走文乃的既不是FS也不是SHO，而是岛上猖獗的黑社会组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奪走文乃的既不是FS也不是SHO，而是島上猖獗的黑社會組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00018",
		linknext = "0090_00020",
		line = 241,
	},
	["0090_00020"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0096", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Yakuza, you say?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——你说是黑社会？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——你說是黑社會？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00019",
		linknext = "0090_00021",
		line = 254,
	},
	["0090_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. There was one specific man who took her from us. He said his name was Toshihide Teshima.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。在我们面前带走文乃的，是自称手嶋俊英的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。在我們面前帶走文乃的，是自稱手嶋俊英的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00020",
		linknext = "0090_00022",
		line = 265,
	},
	["0090_00022"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0097", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Teshima...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“手嶋————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「手嶋————」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00021",
		linknext = "0090_00023",
		line = 278,
	},
	["0090_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His facial expression changes slightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人的脸色似乎变了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人的臉色似乎變了。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00022",
		linknext = "0090_00024",
		line = 288,
	},
	["0090_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You know of him?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——有什么线索吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——有什麼線索嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00023",
		linknext = "0090_00025",
		line = 300,
	},
	["0090_00025"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0098", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Never heard of him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“不知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「不知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00024",
		linknext = "0090_00026",
		line = 313,
	},
	["0090_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That response was almost too quick. He must know something.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也回答得太快了——他一定知道些什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也回答得太快了——他一定知道些什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00025",
		linknext = "0090_00027",
		line = 323,
	},
	["0090_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But it's probably wise not to pry any further into that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，他这语气听起来像是要我们不要刨根问底。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，他這語氣聽起來像是要我們不要刨根問底。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00026",
		linknext = "0090_00028",
		line = 333,
	},
	["0090_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Clearly, we fucked up by failing to secure Fumino. But now we are in need of information to help plan our next move.",
					{"rt2"},
				},
			},
			cn = {
				{
					"保护文乃失败毫无疑问是我们的过错。但尽管如此，现在还是需要一些用来施行下一步的情报。",
					{"rt2"},
				},
			},
			tw = {
				{
					"保護文乃失敗毫無疑問是我們的過錯。但儘管如此，現在還是需要一些用來施行下一步的情報。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00027",
		linknext = "0090_00029",
		line = 343,
	},
	["0090_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I need to choose my words wisely.",
					{"rt2"},
				},
			},
			cn = {
				{
					"必须慎重地选择词语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"必須慎重地選擇詞語。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00028",
		linknext = "0090_00030",
		line = 353,
	},
	["0090_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The men who took her seemed to know about her. They wouldn't have gone after her specifically unless they knew about her connection to the law, and being able to destroy it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那些家伙似乎知道文乃的事情。知道她是摧毁条例的关键存在——如果不是这样，就毫无道理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那些傢伙似乎知道文乃的事情。知道她是摧毀條例的關鍵存在——如果不是這樣，就毫無道理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00029",
		linknext = "0090_00031",
		line = 365,
	},
	["0090_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not to mention, the governor was searching for her as well. And even you. Everyone had her in their sights.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事也派人在搜查文乃，而且你也是——所有人都盯上了她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事也派人在搜查文乃，而且你也是——所有人都盯上了她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00030",
		linknext = "0090_00032",
		line = 376,
	},
	["0090_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So why would everybody be gunning for this one girl at once? Is there something she knows?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么她非得被这么多人盯上。文乃——知道是为什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼她非得被這麼多人盯上。文乃——知道是為什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00031",
		linknext = "0090_00033",
		line = 387,
	},
	["0090_00033"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"10 seconds of painful silence passes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在沉重的沉默中过了10秒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在沉重的沉默中過了10秒。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00032",
		linknext = "0090_00034",
		line = 399,
	},
	["0090_00034"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0099", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“In all likelihood, she knows nothing. Hitoura is the one who knows.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“恐怕——文乃什么也不知道。知道的是仁浦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「恐怕——文乃什麼也不知道。知道的是仁浦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00033",
		linknext = "0090_00035",
		line = 412,
	},
	["0090_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wait quietly for him to continue.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我沉默着，等待他继续说下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沉默著，等待他繼續說下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00034",
		linknext = "0090_00036",
		line = 422,
	},
	["0090_00036"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0100", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Toshiaki Hitoura... that vile man responsible for the law. Portrays himself as good-natured on the surface. What a laugh. In reality, he is nothing but a boor who covers up any inconvenient truths surrounding him with the power of money.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“在岛上创造了邪恶条例的男人，仁浦俊明——虽然表面上是个好人，但着实可笑。他是用钱将对自己不利的情报埋葬在暗黑中的人渣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「在島上創造了邪惡條例的男人，仁浦俊明——雖然表面上是個好人，但著實可笑。他是用錢將對自己不利的情報埋葬在暗黑中的人渣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00035",
		linknext = "0090_00037",
		line = 435,
	},
	["0090_00037"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Does that mean Fumino's existence is inconvenient to Hitoura?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说———文乃的存在，对仁浦来说是个不利的事实？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說———文乃的存在，對仁浦來說是個不利的事實？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00036",
		linknext = "0090_00038",
		line = 447,
	},
	["0090_00038"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0101", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Indeed. It would not be an exaggeration to say that her existence is his largest inconvenience. Naturally, this is not public knowledge... but he has fathered an illegitimate child.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“是的。对那家伙来说，说文乃是最麻烦的存在也不为过。当然没有对外公开——但仁浦有个私生女。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「是的。對那傢伙來說，說文乃是最麻煩的存在也不為過。當然沒有對外公開——但仁浦有個私生女。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00037",
		linknext = "0090_00039",
		line = 460,
	},
	["0090_00039"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ohhh... Now I get it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"啊——我终于明白了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"啊——我終於明白了。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00038",
		linknext = "0090_00040",
		line = 471,
	},
	["0090_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
