		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg03_1l_00000", x=0, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, ax=1280, ay=730, bx=-480, by=-280},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_012_00000"},
		{"bgm", file="bgm09.5", vol=100},
		{"bg", id=1, file="bg03_1l_00000", x=0, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, style="blur", blurx=11, blury=11, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The echoes of moans are heard as a man appears on a huge screen on the podium.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在呻吟声中，台上的大屏幕上出现了一位男子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在呻吟聲中，臺上的大螢幕上出現了一位男子。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00075",
		linknext = "0090_00077",
		line = 1055,
	},
	["0090_00077"] = {
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=100},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never met him in person, but ever since coming to the island, I've seen his face everywhere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然没有直接见过，但来到青蓝岛之后已经看过了无数次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然沒有直接見過，但來到青藍島之後已經看過了無數次。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00076",
		linknext = "0090_00078",
		line = 1068,
	},
	["0090_00078"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0134", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Thank you all for coming here today, on such short notice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“非常感谢大家今天至此参加紧急会见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「非常感謝大家今天至此參加緊急會見。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00077",
		linknext = "0090_00079",
		line = 1080,
	},
	["0090_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Toshiaki Hitoura — the man responsible for the Seiran Island perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦俊明——在青蓝岛制定变态条例的男子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦俊明——在青藍島制定變態條例的男子。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00078",
		linknext = "0090_00080",
		line = 1090,
	},
	["0090_00080"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0135", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I'll get straight to the point. The other day, discussions were held regarding the law which has drawn tourists to Seiran Island, popularly known as the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我想先开门见山地说明要点。有关青蓝岛观光资源化相关条例——也就是所谓的变态条例。前几天我们对此进行了协商。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我想先開門見山地說明要點。有關青藍島觀光資源化相關條例——也就是所謂的變態條例。前幾天我們對此進行了協商。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00079",
		linknext = "0090_00081",
		line = 1102,
	},
	["0090_00081"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0136", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“As I'm sure you're all aware, the aforesaid law is responsible for having dramatically increased tourism and emigration to our island since its establishment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“本条例自实施以来，为青蓝岛带来了大量游客以及人口，这点想必大家都知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「本條例自實施以來，為青藍島帶來了大量遊客以及人口，這點想必大家都知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00080",
		linknext = "0090_00082",
		line = 1114,
	},
	["0090_00082"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0137", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But as a result of the discussions, it has been decided that the law is in need of drastic changes. I would like to announce the specific details of these changes now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是协商的结果——虽然非常唐突，今后本条例必须进行重大的变更，所以想在这里告知大家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是協商的結果——雖然非常唐突，今後本條例必須進行重大的變更，所以想在這裡告知大家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00081",
		linknext = "0090_00083",
		line = 1126,
	},
	["0090_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hold my breath.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我倒吸了一口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我倒吸了一口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00082",
		linknext = "0090_00084",
		line = 1136,
	},
	["0090_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is the law really going to be abolished right now?",
					{"rt2"},
				},
			},
			cn = {
				{
					"条例真的要废除了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"條例真的要廢除了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00083",
		linknext = "0090_00085",
		line = 1146,
	},
	["0090_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He leaves a deliberate pause before slowly opening his mouth again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生停顿了好一会儿——终于，慢慢地开口了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生停頓了好一陣子——終於，慢慢地開口了。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00084",
		linknext = "0090_00086",
		line = 1156,
	},
	["0090_00086"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0138", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“As the one who originally bestowed this law upon the island, I announce that the 'New Perverted Sex Law' will henceforth be replacing it. We also announce the establishment of the Seiran Island Paid Perverted Sex Project.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我在青蓝岛上实施的变态条例将会被废除——然后制定新的‘新・变态条例’——这里，将施行青蓝岛变态做爱收费制计划。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我在青藍島上實施的變態條例將會被廢除——然後制定新的『新・變態條例』——這裡，將施行青藍島變態做愛收費制計劃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00085",
		linknext = "block_00086",
		line = 1169,
	},
