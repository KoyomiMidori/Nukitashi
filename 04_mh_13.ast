		{"extrans", sync=0, time=600, rule="eff_012_00000"},
		{"bgm", file="bgm11", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even after the transmission is cut, the tension remains in the air.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通讯结束后，基地里还是弥漫着紧张的气氛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通訊結束後，基地裡還是瀰漫著緊張的氣氛。",
