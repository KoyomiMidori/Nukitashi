					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's wait and see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……会是怎么样呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……會是怎麼樣呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00074",
