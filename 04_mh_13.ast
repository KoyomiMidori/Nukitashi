				},
			},
			en = {
				{
					name = {"モブ女A", "Female SS Student"},
					"“Mic check, one, two. Prefectural Governor Hitoura will be holding an emergency press conference presently. It involves very important news, so I will ask all of you to please listen while in the missionary position.”",
