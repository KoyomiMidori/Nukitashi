		line = 994,
	},
	["0090_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If that happens, whilst the means would be dubious, our primary objective will have been achieved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是那样的话，虽然方法扭曲，但也实现了我当初的目的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是那樣的話，雖然方法扭曲，但也實現了我當初的目的——",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00073",
