				},
			},
			cn = {
				{
					name = {"モブ女A", "FS女学生"},
					"“啊——啊——县知事仁浦先生将召开紧急记者会。这是非常重大的发表，请各位用正常位好好听着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "FS女學生"},
					"「啊——啊——縣知事仁浦先生將召開緊急記者會。這是非常重大的發表，請各位用正常位好好聽著。」",
					{"rt2"},
				},
			},
		},
