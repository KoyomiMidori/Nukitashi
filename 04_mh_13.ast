	["0090_00043"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2040", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“An illegitimate child... Now I finally understand how Fumino could be the key.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“私生女……文乃为什么会成为关键，我终于明白了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「私生女……文乃為什麼會成為關鍵，我終於明白了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00042",
		linknext = "0090_00044",
		line = 551,
	},
	["0090_00044"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2043", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But is that enough to bring down the law?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是，仅仅这样就能破坏条例吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是，僅僅這樣就能破壞條例嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00043",
		linknext = "0090_00045",
		line = 564,
	},
	["0090_00045"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1457", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Depends on the approach. From the way he said it, there's probably a lot more to it, and the illegitimate child aspect is enough to light the fire. With enough fuel thrown on it, it'll blaze out of control.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这就要看怎么做了……听他的口气，他好像知道更多其他的事情，只要在私生女这个星星之火上不停扔燃料，话题就会瞬间爆发……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這就要看怎麼做了……聽他的口氣，他好像知道更多其他的事情，只要在私生女這個星星之火上不停扔燃料，話題就會瞬間爆發……」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00044",
		linknext = "0090_00046",
		line = 577,
	},
	["0090_00046"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00129", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1458", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Stripping it bare, the governor's personal problems can be intertwined with the problems with the law, and once the general view is overwhelmingly critical of a law, that spells the end of it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“如果做好事前准备，就可以把县知事的个人问题和条例问题混为一谈，然后引导社会舆论让大家一味地批评条例，如此一来条例就完蛋了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「如果做好事前準備，就可以把縣知事的個人問題和條例問題混為一談，然後引導社會輿論讓大家一味地批評條例，如此一來條例就完蛋了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00045",
		linknext = "0090_00047",
		line = 591,
	},
	["0090_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You've spent a lot of time thinking about this stuff, I see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你还真了解这样的事情呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你還真了解這樣的事情呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00046",
		linknext = "0090_00048",
		line = 603,
	},
	["0090_00048"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00110", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1459", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I got this shit. The other day, I ended up getting some shithead hung up on being Moderately Interesting Online to delete their account after I posted a sick burn at them. Just like how I'll get Hotori to delete you from her life someday.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“交给我吧……前些日子我也让一些自我意识高涨的账号炎上让他把号删了。总有一天我也会让畔同学炎上然后和哥哥分手的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「交給我吧……前些日子我也讓一些自我意識高漲的帳號炎上讓他把帳號刪了。總有一天我也會讓畔同學炎上然後和哥哥分手的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00047",
		linknext = "0090_00049",
		line = 617,
	},
	["0090_00049"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1400", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, you needn't worry yourself about that. I'm already dancing in the flames of love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“就算你不费那个心力，爱情的火焰早就已经熊熊燃烧起来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就算你不費那個心力，愛情的火焰早就已經熊熊燃燒起來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00048",
		linknext = "0090_00050",
		line = 632,
	},
	["0090_00050"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1460", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Shit... I think the middle finger of my fist is getting an erection or something!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好烦……紧握的拳头中的中指快要勃起了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好煩……緊握的拳頭中的中指快要勃起了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00049",
		linknext = "0090_00051",
		line = 646,
	},
	["0090_00051"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think the island brainworms have gotten to you a little too much if you're saying things like that, little missy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要使用像青蓝岛居民的说法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要使用像青藍島居民的說法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00050",
		linknext = "0090_00052",
		line = 658,
	},
	["0090_00052"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway. Since he didn't say anything about Fumino's relationship with the governor before, that means he never really trusted us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是——他到目前为止都将文乃与县知事的关系对我们保持沉默……他果然没有打从心底相信我们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是——他到目前為止都將文乃與縣知事的關係對我們保持沉默……他果然沒有打從心底相信我們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00051",
		linknext = "0090_00053",
		line = 670,
	},
	["0090_00053"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1401", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“True... I hate to bring it up now, but I think he called me a newcomer? Did I hear that right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊……话说回来……如果没听错的话，他刚刚好像说我是新人……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊……話說回來……如果沒聽錯的話，他剛剛好像說我是新人……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00052",
		linknext = "0090_00054",
		line = 684,
	},
	["0090_00054"] = {
