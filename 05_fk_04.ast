			},
		},
		linkback = "0104_00015",
		linknext = "0104_00017",
		line = 246,
	},
	["0104_00017"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2102", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hm... Well, anyway, what do you want to do? If you hate the rich that much, are you just going to give up on looking for sex slavers with that girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，比起那个淳，那你打算怎么做？因为讨厌有钱人，所以不跟那个孩子一起找地下风俗了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，比起那個淳，那你打算怎麼做？因為討厭有錢人，所以不跟那個孩子一起找地下風俗了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00016",
		linknext = "0104_00018",
		line = 262,
	},
	["0104_00018"] = {
		{"bgm", file="bgm11", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course not.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然不能那样做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然不能那樣做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00017",
		linknext = "0104_00019",
		line = 275,
	},
	["0104_00019"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if I'm all in for eating the rich, she's still got a lead on the sex slavers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算再怎么讨厌有钱人，她都有地下风俗的线索啊——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算再怎麼討厭有錢人，她都有地下風俗的線索啊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00018",
		linknext = "0104_00020",
		line = 287,
	},
	["0104_00020"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=400},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=400},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=400},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just yesterday, she told me about the places where kids regularly go missing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“实际上，在昨天的巡逻中，她告诉了我关于失踪事件频繁发生的地点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「實際上，在昨天的巡邏中，她告訴了我關於失踪事件頻繁發生的地點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00019",
		linknext = "0104_00021",
		line = 305,
	},
	["0104_00021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The places are scattered, but one of them is near the settlement... here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“地点虽然很分散，但其中也有接近村落的地方……就是这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「地點雖然很分散，但其中也有接近村落的地方……就是這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00020",
		linknext = "0104_00022",
		line = 317,
	},
	["0104_00022"] = {
		{"se", id=0, loop=0, file="se_b030"},
		{"text"},
