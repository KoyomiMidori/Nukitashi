		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But this time, I'm ready for them, so they can bring it! I can take on one or two of those yakuza assholes with one hand tied behind—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过有我在所以不用担心，一两个黑社会的话我简简单单就——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過有我在所以不用擔心，一兩個黑社會的話我簡簡單單就——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00176",
		linknext = "0104_00178",
		line = 2399,
	},
