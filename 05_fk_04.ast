		linkback = "0104_00014",
		linknext = "0104_00016",
		line = 234,
	},
	["0104_00016"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I told you about that? Huh... Maybe I just forgot or something...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是这样吗……？我说过这个吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是這樣嗎……？我說過這個嗎……？」",
					{"rt2"},
