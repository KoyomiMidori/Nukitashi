					{"rt2"},
				},
			},
			en = {
				{
					"Long white hair...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"发着暗光的长发少女——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"發著暗光的長發少女——？",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00119",
		linknext = "0104_00121",
