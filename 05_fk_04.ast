	["0104_00009"] = {
		{"se", id=1, loop=0, file="se_a098"},
		{"se", id=0, loop=0, file="se_a100"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg12_1l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="asane_02l_00001", file1="asane_02l_00113", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We exchange a warm embrace and tearily acknowledge our mutual hatred.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们紧紧拥抱在一起，流着泪敬仰两人的相知相惜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們緊緊擁抱在一起，流著淚敬仰兩人的相知相惜。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00008",
		linknext = "0104_00010",
		line = 144,
	},
	["0104_00010"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2099", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uh, okay, I guess that dug up some bad memories for Jun... So, I figure you've heard of them by now, but there's this group of people called the 'Seiran nouveau riche.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那个啥，因为淳有心理阴影嘛……想想看，我想你们两个人也知道，这里不是有所谓的‘青蓝暴发户’吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那個啥，因為淳有心理陰影嘛……想想看，我想你們兩個人也知道，這裡不是有所謂的『青藍暴發戶』嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00009",
		linknext = "0104_00011",
		line = 164,
	},
	["0104_00011"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1946", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, right. Our settlement isn't connected to them, but those people bought up a bunch of newly developed land and then moved their subordinates into those places, didn't they?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，是的。虽然和我家这边的村落没有什么干系，不过很多关系人士因为土地开发而拥有了权利，都搬了过来呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，是的。雖然和我家這邊的村落沒有什麼關係，不過很多關係人士因為土地開發而擁有了權利，都搬了過來呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00010",
		linknext = "0104_00012",
		line = 179,
	},
	["0104_00012"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2100", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, these two used to live here before, and those upper-middle-class-at-best dickheads bullied them. Seems like they still hold a grudge, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳他们以前住在这个岛的时候，大概被那种小富翁欺负了……所以现在才会讨厌他们吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳他們以前住在這個島的時候，大概被那種小富翁欺負了……所以現在才會討厭他們吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00011",
		linknext = "0104_00013",
		line = 193,
	},
	["0104_00013"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, just because they got a bigger allowance than me, they'd say that we were poor, or losers, or gay, or that we smelled like ass, or that I had a freaky dick...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊因为他们的零用钱多就说别人很穷很可怜很悲惨很臭很烦那个很大——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊因為他們的零用錢多就說別人很窮很可憐很悲慘很臭很煩那個很大——」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00012",
		linknext = "0104_00014",
		line = 205,
	},
	["0104_00014"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait... How'd you know about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……咦？为什么奈奈濑知道呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
