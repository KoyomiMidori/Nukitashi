			},
		},
		text = {
			vo = {
				{"vo", file="nanase2101", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? Uh, well... I thought you told me about it before, don't you remember?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶……啊……之前你不是有告诉过我吗？已经忘了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸……啊……之前你不是有告訴過我嗎？已經忘了嗎？」",
