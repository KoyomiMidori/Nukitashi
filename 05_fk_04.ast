			},
			cn = {
				{
					name = {"淳之介"},
					"“……好，那开始打听吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……好，那開始打聽吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00028",
		linknext = "0104_00030",
		line = 458,
	},
	["0104_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After school, Nanase's group headed out of the base first and went to the settlement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后，我们比奈奈濑他们还早离开基地，并来到了村落。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後，我們比奈奈瀨他們還早離開基地，並來到了村落。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00029",
		linknext = "0104_00031",
		line = 468,
	},
	["0104_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tourists don't come here so the OSS have no presence, and the settlement itself is virtually deserted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一带因为游客也不来，所以没有SHO，村落本身也冷清。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一帶因為遊客也不來，所以沒有SHO，村落本身也冷清。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00030",
		linknext = "0104_00032",
		line = 478,
	},
	["0104_00032"] = {
		{"bg", id=1, file="bg10_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1949", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But, are you sure we're okay for this? Asane's best suited for this sort of data gathering.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“可是……靠我们没问题吗？这种总结数据的工作，不是麻沙音酱比较擅长吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「可是……靠我們沒問題嗎？這種總結數據的工作，不是麻沙音醬比較擅長嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00031",
		linknext = "0104_00033",
		line = 494,
	},
	["0104_00033"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's a whiz with any kind of data, so I'll leave her to that. It's best to have people familiar with the area for this operation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“数据的解析在之后随时都可以进行，现在还是有两个有方向感的人跟着我会更有帮助。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「數據的解析在之後隨時都可以進行，現在還是有兩個有方向感的人跟著我會更有幫助。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00032",
		linknext = "0104_00034",
		line = 506,
	},
	["0104_00034"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2096", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I got this! I actually haven't been here myself, but I basically know the lay of the land, so we won't get lost!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“交给我吧！虽然没有来过这边，不过我大致知道这里是哪里所以不会迷路哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「交給我吧！雖然沒有來過這邊，不過我大致知道這裡是哪裡所以不會迷路哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00033",
		linknext = "0104_00035",
		line = 521,
	},
	["0104_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Awesome. That's our senior.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是太感谢了，不愧是前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是太感謝了，不愧是前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00034",
		linknext = "0104_00036",
		line = 533,
	},
	["0104_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though, there's a more vital reason why we brought Wata along.",
					{"rt2"},
				},
			},
			cn = {
				{
					"话虽如此，但把渡酱带过来是有某个重要的理由的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"話雖如此，但把渡醬帶過來是有某個重要的理由的。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00035",
		linknext = "0104_00037",
		line = 543,
	},
	["0104_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all, where we're going, we won't find anyone hesitant to speak to her based on how she looks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为这位前辈跟看上去一样，是不怕跟人搭话的性格。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為這位前輩跟看上去一樣，是不怕跟人搭話的性格。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00036",
		linknext = "0104_00038",
		line = 553,
	},
	["0104_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Old people would no doubt be happy to chat her up with her loli appearance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"外表也是萝莉，适合与老人相处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"外表也是蘿莉，適合與老人相處。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00037",
		linknext = "0104_00039",
		line = 563,
	},
	["0104_00039"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, uh... I'm just gonna wait here, so I'll leave it up to you two, all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么……我在这里等你们，拜托你们两个可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼……我在這裡等你們，拜託你們兩個可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00038",
		linknext = "0104_00040",
		line = 575,
	},
	["0104_00040"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2097", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Wait, you're not coming? You're gonna hold down the fort here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦，橘君不去吗？你在这里待机吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦，橘君不去嗎？你在這裡待機嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00039",
		linknext = "0104_00041",
		line = 590,
	},
	["0104_00041"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00114", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1950", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You're the one who knows the actual locations, so shouldn't you come along?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“橘同学知道具体的地点，所以我觉得在一起比较好吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「橘同學知道具體的地點，所以我覺得在一起比較好吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00040",
		linknext = "0104_00042",
		line = 604,
	},
	["0104_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00125", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, well... On paper, yes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔……话是这么说啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔……話是這麼說啦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00041",
		linknext = "0104_00043",
		line = 616,
	},
	["0104_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know that it would be more efficient if I were to ask directly or we were to split up into three.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我知道自己直接去打听，或者三个人分头去打听会更有效率。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我知道自己直接去打聽，或者三個人分頭去打聽會更有效率。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00042",
		linknext = "0104_00044",
		line = 626,
	},
	["0104_00044"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But to be honest... I'm not very comfortable being around the other islanders.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……说实话，我不怎么擅长岛上的人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……說實話，我不怎麼擅長島上的人啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00043",
		linknext = "0104_00045",
		line = 638,
	},
	["0104_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Anyone who's grateful for the perverted sex law, like the people I ran into when I used to live here before... I'd rather not have any contact with them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不太愿意见到那些从以前开始就在岛上的人——尤其是对条例心存感激的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不太願意見到那些從以前開始就在島上的人——尤其是對條例心存感激的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00044",
		linknext = "0104_00046",
		line = 648,
	},
	["0104_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's too easy to associate them with my past traumas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……理由是容易联想到以前不喜欢的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……理由是容易聯想到以前不喜歡的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00045",
		linknext = "0104_00047",
		line = 658,
	},
	["0104_00047"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00103", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1951", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“B-But all the people around here are really nice! Plus they're all elderly, so they're not gonna bug you for sex or anything! They're all kind-hearted and tolerant, I can assure you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不、不过这里的人都是好人哦！都是老人，也不会邀请别人做爱……！大家都心地善良，或者说器量很大！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不、不過這裡的人都是好人哦！都是老人，也不會邀請別人做愛……！大家都心地善良，或者說器量很大！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00046",
		linknext = "0104_00048",
		line = 673,
	},
	["0104_00048"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I suppose I could trust your word...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然畔这么说了，应该就是那样吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
