				{"vo", file="misaki1962", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes, you're right. Tachibana here, pfft... He has a question for you all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的，就是这样。这位……呵呵……橘同学说有事想请教大家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的，就是這樣。這位……呵呵……橘同學說有事想請教大家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00097",
		linknext = "0104_00099",
		line = 1375,
	},
	["0104_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm seriously about to kick your ass.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“揍你哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「揍你哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00098",
		linknext = "0104_00100",
		line = 1387,
	},
	["0104_00100"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1963", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Do you know anything about the kidnapping incidents in the area?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你知道这附近发生的绑架事件吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你知道這附近發生的綁架事件嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00099",
		linknext = "0104_00101",
		line = 1401,
	},
	["0104_00101"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0047", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Kidnappings? Oh, right. Well, I ain't the one with kids, so... Hey, lads! Yer 'ere, right? C'mon out!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“绑架事件？哦——那个啊。可是我没有孩子……喂，大家——！都在吗——！都出来吧——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「綁架事件？哦——那個啊。可是我沒有孩子……喂，大家——！都在嗎——！都出來吧——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00100",
		linknext = "0104_00102",
		line = 1413,
	},
	["0104_00102"] = {
		{"se", id=0, loop=0, file="se_a053"},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He slowly turns around and calls out to the villagers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"健藏老人朝民宅方向喊话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"健藏老人朝民宅方向喊話。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00101",
		linknext = "0104_00103",
		line = 1430,
	},
	["0104_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Old folks appear out of nowhere and gather.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于是其他老人们便争先恐后地围了过来，简直让人怀疑他们之前藏在哪里了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"於是其他老人們便爭先恐後地圍了過來，簡直讓人懷疑他們之前藏在哪裡了。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00102",
		linknext = "0104_00104",
		line = 1440,
	},
	["0104_00104"] = {
		{"se", id=0, stop=1, time=2000},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0006", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "老人A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Old Man A"},
					"“Oh, it's you, Kenzou... So ya wanna know 'bout the kidnappings?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "老人A"},
					"“怎么了，健藏先生啊……什么，绑架事件吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "老人A"},
					"「怎麼了，健藏先生啊……什麼，綁架事件嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00103",
		linknext = "0104_00105",
		line = 1453,
	},
	["0104_00105"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0007", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "老人B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Old Man B"},
					"“Yeah, I heard Kuramochi's grandkid got abducted after comin' over t' visit. They found 'er the day after...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "老人B"},
					"“是啊，仓持家的孙子来玩的时候被掳走了，但过了一天就被找到了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "老人B"},
					"「是啊，倉持家的孫子來玩的時候被擄走了，但過了一天就被找到了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00104",
		linknext = "0104_00106",
		line = 1465,
	},
	["0104_00106"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=500},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=500},
		{"se", id=0, loop=0, file="se_a142"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I listen in on the old folks talking amongst themselves, and gather what data I can.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边倾听老人们的闲话家常，一边收集数据。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊傾聽老人們的閒話家常，一邊收集數據。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00105",
		linknext = "0104_00107",
		line = 1480,
	},
	["0104_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently, there have been incidents involving children disappearing in the area.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这附近确实发生过小孩失踪的事件。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這附近確實發生過小孩失踪的事件。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00106",
		linknext = "0104_00108",
		line = 1490,
	},
	["0104_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The old folks have been describing them as having been spirited away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人们称之为神隐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人們稱之為神隱。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00107",
		linknext = "0104_00109",
		line = 1500,
	},
	["0104_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But it appears that the children aren't locals; rather, they're young boys and girls who came to visit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是对象并不是这一带附近的孩子，而是来玩，或者偶然靠近的少年少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是對象並不是這一帶附近的孩子，而是來玩，或者偶然靠近的少年少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00108",
		linknext = "0104_00110",
		line = 1510,
	},
	["0104_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There weren't any children in this settlement to begin with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个村子里原本就没有小孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個村子裡原本就沒有小孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00109",
		linknext = "0104_00111",
		line = 1520,
	},
	["0104_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We hear that Hotori's family is the youngest one here, and you won't find anyone younger until you get to the town.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一问之下才知道畔家是最年轻的，再年经的话一定要下到镇上才有。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一問之下才知道畔家是最年輕的，再年經的話一定要下到鎮上才有。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00110",
		linknext = "0104_00112",
		line = 1530,
	},
	["0104_00112"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2104", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“How'd it go, Tachibana? Any substantial information you can use?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“怎么样，橘君……？得到有利的情报了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「怎麼樣，橘君……？得到有利的情報了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00111",
		linknext = "0104_00113",
		line = 1545,
	},
	["0104_00113"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, not quite... I just know there's a lot of things I still don't know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，还没到那种程度……不过倒是知道了些原本不知道的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，還沒到那種程度……不過倒是知道了些原本不知道的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00112",
		linknext = "0104_00114",
		line = 1557,
	},
	["0104_00114"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I had something more concrete to go on, we might be able to find a lead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果能再掌握一些具体的情报就可以成为线索了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果能再掌握一些具體的情報就可以成為線索了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00113",
		linknext = "0104_00115",
		line = 1569,
	},
	["0104_00115"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1964", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, is there anything else any of you know? Anything at all. A rumor you might have heard, whatever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃——那么大家，还有别的吗？什么都可以。比如听说过的传闻——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃——那麼大家，還有別的嗎？什麼都可以。比如聽說過的傳聞——」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00114",
		linknext = "0104_00116",
		line = 1583,
	},
	["0104_00116"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0008", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "老人B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Old Man B"},
					"“Lemme see... Oh, this ain't about them kids wot been spirited away, but I been hearin' a lotta gums flappin' 'bout that ghost girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "老人B"},
					"“这样啊……啊，说到神隐，是不是经常听说那个孩子变成了幽灵啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "老人B"},
					"「這樣啊……啊，說到神隱，是不是經常聽說那個孩子變成了幽靈啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00115",
		linknext = "0104_00117",
		line = 1595,
	},
	["0104_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ghost?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……幽灵？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……幽靈？",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00116",
		linknext = "0104_00118",
		line = 1605,
	},
	["0104_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's quite an unexpected twist...",
					{"rt2"},
				},
			},
			cn = {
				{
