	["0104_00119"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0048", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Ooh, the ghost, eh? Almost forgot about 'er. Evidently people been seein' her a lot more lately. Like, she's got a real blank expression, and long white hair...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“噢，那个幽灵的故事啊，确实忘了讲。听说最近经常有人看到……说是有个看起来像发着暗光的长发少女出现什么的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「噢，那個幽靈的故事啊，確實忘了講。聽說最近經常有人看到……說是有個看起來像發著暗光的長發少女出現什麼的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00118",
		linknext = "0104_00120",
		line = 1627,
	},
	["0104_00120"] = {
