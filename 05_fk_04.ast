					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“After school, the two people familiar with the area will come with team A and collect information! Okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“放学后，A组会带上两名有方向感的人前往收集情报！知道了吗！”",
