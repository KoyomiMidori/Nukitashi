		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2094", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, um... So, this Fukiko, if that's her name? You say she's rich, but what exactly is the problem here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃……那个吹子酱？你说她有钱，有什么问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃……那個吹子醬？你說她有錢，有什麼問題嗎？」",
					{"rt2"},
				},
			},
		},
