	["0104_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since it's that close, I figure it's a possibility we could get some eyewitness testimony from the locals.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后既然是如此接近人们聚集的地方，也许能在周边得到有力的目击证言。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後既然是如此接近人們聚集的地方，也許能在周邊得到有力的目擊證言。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00024",
		linknext = "0104_00026",
		line = 366,
	},
	["0104_00026"] = {
