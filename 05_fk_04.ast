					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“One time they let me eat a cucumber from the fields when I was hungry, and when I play with my asshole in the hay in their barns, they just pretend not to see me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为肚子太饿随便吃了田里的黄瓜时大家都笑着原谅了我，还有用库房的桑树自慰的时候大家也都装作没看见——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為肚子太餓隨便吃了田裡的黃瓜時大家都笑著原諒了我，還有用庫房的桑樹自慰的時候大家也都裝作沒看見——！」",
					{"rt2"},
				},
			},
		},
