				{"fg", ch="文乃", id=7, mode=2, path=":fg/fumino_01m/", file="fumino_01m_00001", size="m", file1="fumino_01m_00114", head="fumino_01m", lv=5},
				{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=25, time=350, ease="easeinout_sine"},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0419", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Oh, a wild boar? Must be a young one... Is something the matter?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“哎，是野猪吗……大概还小吧……您、怎么了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「哎，是野豬嗎……大概還小吧……您、怎麼了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00178",
		linknext = "0104_00180",
		line = 2439,
	},
	["0104_00180"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
