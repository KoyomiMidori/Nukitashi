		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The next day after school I explain everything that happened, from the night before through to morning.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第二天放学后，我向全体人员说明昨晚到早上发生的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第二天放學後，我向全體人員說明昨晚到早上發生的事情。",
					{"rt2"},
				},
			},
		},
