		line = 2451,
	},
	["0104_00181"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=600, mode=2, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0420", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Well... you seem to be embracing that large tree quite vigorously.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“呃……您好像抱着大树呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「呃……您好像抱著大樹呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00180",
		linknext = "0104_00182",
		line = 2465,
	},
	["0104_00182"] = {
		{"se", id=0, loop=0, file="se_a035"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh... yeah! I'm just imagining it's one of those yakuza guys!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……啊啊当然！我正把大树想象成黑社会进行脑内训练呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……啊啊當然！我正把大樹想像成黑社會進行腦內訓練呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00181",
		linknext = "0104_00183",
		line = 2482,
	},
	["0104_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It should go without saying that if I hold him like this, then he'll be completely pinned and unable to move, no matter what weapon he tries to get out!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要这样做无论对方想拿出任何武器我都能抱着他封住他的行动对吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要這樣做無論對方想拿出任何武器我都能抱著他封住他的行動對吧！？」",
					{"rt2"},
				},
			},
		},
