			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, this is just another one of his made-up stories! I think he's just getting senile with age!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，这些话最好别相信橘同学！毕竟是老人了，可能有点痴呆……！”",
