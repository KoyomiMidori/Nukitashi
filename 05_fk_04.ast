	["0104_00055"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1953", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, uh, this is Old Man Kenzou, he lives in this area. He's an elderly farmer, as I'm sure you can see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，呃，这位是住在我家附近的健藏爷爷。如同你看到的，他是农家的老人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，呃，這位是住在我家附近的健藏爺爺。如同你看到的，他是農家的老人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00054",
		linknext = "0104_00056",
		line = 788,
	},
	["0104_00056"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0034", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Yer supposed ta be introducin' me as an 'engineer', Misaki! I was a soldier wot did maintenance durin' th' war!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“可不可以好好介绍我是‘技师’啊美岬酱！好歹我也是战争时期的维修兵哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「可不可以好好介紹我是『技師』啊美岬醬！好歹我也是戰爭時期的維修兵哦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00055",
		linknext = "0104_00057",
		line = 800,
	},
	["0104_00057"] = {
