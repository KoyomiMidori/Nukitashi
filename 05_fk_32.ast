					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「新SHO也不會強制做愛，進公司的時候可以自由決定！不過大家都很喜歡做愛，所以基本上都是天天打炮……」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00080",
