				{"vo", file="hinami2287", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, nothing in particular!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没有，没什么事！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒有，沒什麼事！」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00148",
		linknext = "0132_00150",
		line = 2012,
	},
	["0132_00150"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then why are you here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那你为什么要来这里？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那你為什麼要來這裡？」",
					{"rt2"},
				},
