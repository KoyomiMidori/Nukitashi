	["0132_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I sit up and stretch.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我抬起上半身，伸展身体。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我抬起上半身，伸展身體。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00002",
		linknext = "0132_00004",
		line = 43,
	},
	["0132_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel pleasantly invigorated, despite having just woken up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚睡醒的身体发出舒适的刺激。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛睡醒的身體發出舒適的刺激。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00003",
		linknext = "0132_00005",
		line = 53,
	},
	["0132_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel almost no pain anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"疼痛几乎都消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"疼痛幾乎都消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00004",
		linknext = "0132_00006",
		line = 63,
	},
	["0132_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all that, I nearly died from massive internal hemorrhaging, and received very strict orders from Nanase to rest up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后，我因为大量出血差点死掉，奈奈濑下达了绝对静养的命令。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那之後，我因為大量出血差點死掉，奈奈瀨下達了絕對靜養的命令。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00005",
		linknext = "0132_00007",
		line = 73,
	},
	["0132_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And then there was the medical shit. The side effects of my meds gave me hell, I had a grand mal seizure, vomited up blood, was rushed to the ER, spent most of my summer cooped up in there, and so on, and so forth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为那个药的副作用而非常痛苦，全身痉挛吐血后紧急住院，因为这些，整个暑假都报销了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為那個藥的副作用而非常痛苦，全身痙攣吐血後緊急住院，因為這些，整個暑假都報銷了。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00006",
		linknext = "0132_00008",
		line = 83,
	},
	["0132_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Too much happened to recount here in any brief period of time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然发生了数不胜数的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然發生了數不勝數的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00007",
		linknext = "0132_00009",
		line = 93,
	},
	["0132_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But now, all my wounds fully healed, and all my fractured bones have gone back to normal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但如今伤都已经痊愈了，断掉的骨头也恢复了原状。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但如今傷都已經痊癒了，斷掉的骨頭也恢復了原狀。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00008",
		linknext = "0132_00010",
		line = 103,
	},
	["0132_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've got some trouble bending my right index finger, but blood's still flowing through it, at least.",
					{"rt2"},
				},
			},
			cn = {
				{
					"右手的食指有点不容易弯曲，但是血液也在循环。",
					{"rt2"},
				},
			},
			tw = {
				{
					"右手的食指有點不容易彎曲，但是血液也在循環。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00009",
		linknext = "0132_00011",
		line = 113,
	},
	["0132_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I'm pretty much in top form now, all things considered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以今天，我依旧状态绝佳。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以今天，我依舊狀態絕佳。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00010",
