				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And you! Don't carry your partner down the hallway in a suspended congress! That's dangerous!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……那里的你们也是！不要保持着车站便当的姿势走在走廊上！太危险了吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……那裡的你們也是！不要保持著車站便當的姿勢走在走廊上！太危險了吧……！」",
