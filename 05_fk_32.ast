				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「對了，從現在開始也行，加入SHO吧？橘君一定會出人頭地的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00079",
		linknext = "0132_00081",
