		line = 878,
	},
	["0132_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Discrimination still exists against them even now, but public institutions have started to accept them, and steps are being taken to educate the general public on how to cast off their prejudices.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在歧视意识仍然存在的今日，青蓝岛在公众场所接受了这一切，同时还开始了消除偏见的教育。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在歧視意識仍然存在的今日，青藍島在公眾場所接受了這一切，同時還開始了消除偏見的教育。",
					{"rt2"},
				},
