				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We both fold our arms and look baffled.",
					{"rt2"},
				},
			},
			cn = {
				{
					"两人抱着胳膊，歪着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"兩人雙手抱胸，歪著頭。",
