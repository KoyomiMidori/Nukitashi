					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whatever you say. Just don't go back to living the same way while you're in school this time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你可别嘴上这么说，然后开学后还是过着同样的生活哦？”",
