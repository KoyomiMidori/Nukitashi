				},
			},
			en = {
				{
					name = {"モブ女A", "Announcement"},
					"“The opening ceremony will soon be starting in the gymnasium. All students, please cease sexual activities now and assemble there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "广播"},
