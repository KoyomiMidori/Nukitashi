		text = {
			vo = {
				{"vo", file="rei1185", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Have a little more concern for your appearance. Good grief... There, your collar's straightened out. Off to the gym with you, chop-chop!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你衣冠不整啊。真是的……好，领子整好了。你也快点去体育馆吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你衣冠不整啊。真是的……好，領子整好了。你也快點去體育館吧！」",
					{"rt2"},
				},
			},
		},
