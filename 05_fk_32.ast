		linkback = "0132_00061",
		linknext = "0132_00063",
		line = 846,
	},
	["0132_00063"] = {
		{"fg", mode=-1, id=11, ch="光姫", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The official OSS copulation license has a column for writing your sexual orientation on both sides, and you can also list your preferred locations.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO公认的交配许可证上，双面都有能写上自己性取向的栏位，可以写在自己喜欢的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO公認的交配許可證上，雙面都有能寫上自己性取向的欄位，可以寫在自己喜歡的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00062",
		linknext = "0132_00064",
		line = 858,
	},
	["0132_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, if you prefer to keep things private, that's okay too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可以公开，也可以不公开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可以公開，也可以不公開。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00063",
		linknext = "0132_00065",
		line = 868,
	},
	["0132_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In addition, gay and bisexual people have the right to refuse someone if the other party's sexual orientation isn't in line with theirs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"同性恋、双性恋的人，可以拒绝来自性取向不同的人的邀请。",
