	["0132_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because of that, approaching someone outside those zones for procreational actions or other sexual acts is strictly forbidden.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此，在范围外进行性产行为以及以性行为为目的的搭讪是被禁止的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此，在範圍外進行性產行為以及以性行為為目的的搭訕是被禁止的。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00055",
