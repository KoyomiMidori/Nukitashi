	["0132_00051"] = {
		{"fg", mode=-1, id=11, ch="光姫", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Areas where sex is allowed have been designated, and are referred to as erogenous zones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真变态条例中规划了可以做爱的地区，通称“性感地区”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真變態條例中規劃了可以做愛的地區，通稱「性感地區」。",
					{"rt2"},
				},
