		{"fg", file="kouki_01m_00001", file1="kouki_01m_00118", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0190", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“We've had a lot of new arrivals this summer. I guess all those repressed emotions from the new perverted sex law fiasco really boiled over. Summer holidays are technically over now, but the crowds aren't letting up...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“可能是因为新变态条例期间，很多人受到了压抑，所以今年夏天的人特别多。就连暑假结束了，人都还没有减少……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「可能是因為新變態條例期間，很多人受到了壓抑，所以今年夏天的人特別多。就連暑假結束了，人都還沒有減少……」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00048",
		linknext = "0132_00050",
		line = 701,
	},
	["0132_00050"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00107", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0191", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“That said, having procreational actions limited to certain designated zones has definitely made my job easier.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“话虽如此，可进行性产行为的空间毕竟被限制住了，所以工作起来比以前方便多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「話雖如此，可進行性產行為的空間畢竟被限制住了，所以工作起來比以前方便多了。」",
					{"rt2"},
				},
