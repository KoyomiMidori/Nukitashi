		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg050101", x=-5, y=-5, path=":cg/kcg05/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm30", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0902", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Good morning, everyone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——各位，早上好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——各位，早安。」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00203",
		linknext = "0132_00205",
		line = 2855,
	},
	["0132_00205"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0903", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I am Reizeiin Touka, as I'm sure you all remember. I have just been reinstated as SS representative and student council president. I look forward to working with you all again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我是冷泉院桐香，再次被任命为FS的代表兼学生会长，今后也请多多关照。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我是冷泉院桐香，再次被任命為FS的代表兼學生會長，今後也請多多關照。」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00204",
		linknext = "0132_00206",
		line = 2867,
	},
	["0132_00206"] = {
		{"se", id=1, loop=0, file="se_d007"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She is met with rousing applause.",
					{"rt2"},
				},
			},
			cn = {
				{
					"周围响起了雷鸣般的喝彩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"周圍響起了雷鳴般的喝彩。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00205",
		linknext = "0132_00207",
		line = 2878,
	},
	["0132_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her charisma is as strong as ever. It's no surprise that she's still so beloved among the student body.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长——冷泉院的领导魅力依然健在，现在依然享有压倒性的人望。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長——冷泉院的領導魅力依然健在，現在依然享有壓倒性的人望。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00206",
		linknext = "0132_00208",
		line = 2888,
	},
	["0132_00208"] = {
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0904", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Summer break has concluded, and we now enter a new academic term. It is nothing short of a terrific joy to be standing at this podium and seeing your faces once again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“暑假结束，新学期到来了。能够再次从这个讲台上看到各位的脸，我也感到非常高兴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「暑假結束，新學期到來了。能夠再次從這個講臺上看到各位的臉，我也感到非常高興。」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00207",
		linknext = "0132_00209",
		line = 2901,
	},
	["0132_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's no different from usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷泉院还是老样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷泉院還是老樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00208",
		linknext = "0132_00210",
		line = 2911,
	},
	["0132_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her usual unflappable smile is on her face, as she waves her right hand in the air.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她像往常一样露出凉爽的笑容，像往常一样举起右手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她像往常一樣露出涼爽的笑容，像往常一樣舉起右手。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00209",
		linknext = "0132_00211",
		line = 2921,
	},
	["0132_00211"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg050102", x=-5, y=-5, path=":cg/kcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0905", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“These last few months have brought Seiran Island many trials and tribulations. While we faced countless hardships during that time, it is crucial that we look back and learn from them now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这半年，青蓝岛发生了各种各样的事。也有很多痛苦，我们必须将这些化为粮食，好好学习。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這半年，青藍島發生了各種各樣的事。也有很多痛苦，我們必須將這些化為糧食，好好學習。」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00210",
		linknext = "0132_00212",
		line = 2937,
	},
	["0132_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though, maybe she has changed a little.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说有什么变化的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說有什麼變化的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00211",
		linknext = "0132_00213",
		line = 2947,
	},
	["0132_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For one thing, she started to casually show up at my house whenever the other NLNS members weren't around.",
					{"rt2"},
				},
			},
			cn = {
				{
					"暑假期间，NLNS成员不在的时候，她突然出现在我家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"暑假期間，NLNS成員不在的時候，她突然出現在我家。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00212",
		linknext = "0132_00214",
		line = 2957,
	},
	["0132_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She'd talk about random trifling topics, instill some kind of unusual fear in my sister, and eventually tried to entice me back to the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她总是说些无聊的话，然后给妹妹一种莫名其妙的恐惧，最后一定会劝我加入FS，之后才回去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她總是說些無聊的話，然後給妹妹一種莫名其妙的恐懼，最後一定會勸我加入FS，之後才回去。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00213",
		linknext = "0132_00215",
		line = 2967,
	},
	["0132_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hardly even brought up the topic of sex, even.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有就是不太提性方面的事了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有就是不太提性方面的事了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00214",
		linknext = "0132_00216",
		line = 2977,
	},
	["0132_00216"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0906", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sex is a most precious thing. And so...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“做爱是非常重要的东西，所以——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
