					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now Hinami is free from having to deal with the fear of having an appearance outside the scope of the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见也不需要害怕自己的存在是违反条例了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見也不需要害怕自己的存在是違反條例了。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00145",
		linknext = "0132_00147",
		line = 1975,
	},
	["0132_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Plus, being able to complete her duties as a senior and fulfill her juniors' wishes has her immensely satisfied.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后能做为前辈帮助后辈实现愿望，她本人似乎很满意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後能做為前輩幫助後輩實現願望，她本人似乎很滿意。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00146",
		linknext = "0132_00148",
		line = 1985,
	},
	["0132_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, did you want something from me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那找我有什么事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那找我有什麼事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00147",
		linknext = "0132_00149",
		line = 1997,
	},
	["0132_00149"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
