				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We don't have any real battles left to fight, so they're YOUR responsibility now! Hurry up and get the first-years in line!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“因为没有正式战斗了，所以这就是你现在的工作！快把1年级学生引导过来！”",
