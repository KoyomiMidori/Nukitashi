	["0132_00095"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0319", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female Student B"},
					"“Umm... is it really true that you're not a slut?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生B"},
					"“那个——听说你实际上不是炮王，是真的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生B"},
					"「那個——聽說你實際上不是炮王，是真的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00094",
		linknext = "0132_00096",
		line = 1279,
	},
	["0132_00096"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="nanase_01m_00006", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2361", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uh... yeah. Sorry 'bout lying to y'all. I'm not all that interested in sex, to be honest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊——嗯。抱歉哦，之前一直在说谎。其实我对色情的事不太感兴趣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊——嗯。抱歉哦，之前一直在說謊。其實我對色情的事不太感興趣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00095",
		linknext = "0132_00097",
		line = 1297,
	},
	["0132_00097"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The misconception surrounding Nanase was cleared up surprisingly quickly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑的误解，意外地很快就解开了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨的誤會，意外地很快就解開了。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00096",
		linknext = "0132_00098",
		line = 1309,
	},
	["0132_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once the new perverted sex law was established, a flood of guys who were dying for it all stormed her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真变态条例制定之后，迎来忍耐极限的男生们好像很快就涌到了她的面前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真變態條例制定之後，迎來忍耐極限的男生們好像很快就湧到了她的面前。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00097",
		linknext = "0132_00099",
		line = 1319,
	},
	["0132_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And apparently, after she politely turned them all down one by one, the rumor made it outside of the school and spread across the whole island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当她一个个认真地拒绝之后，这事情从学校里蔓延到了整个岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當她一個個認真地拒絕之後，這事情從學校裡蔓延到了整個島。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00098",
		linknext = "0132_00100",
		line = 1329,
	},
	["0132_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hell, it was such a big deal that the news made it outside the island. The blogs screamed with headlines like, “Always Has Been!? Infamous Ultra-Charismatic Slut of Minotsuki Academy Actually a Virgin!”",
					{"rt2"},
				},
			},
			cn = {
				{
					"最后还传出了岛外，网路上刊登了“其实是处女！？虚假的水乃月学园婊子领袖！”的新闻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最後還傳出了島外，網路上刊登了「其實是處女！？虛假的水乃月學園婊子領袖！」的新聞。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00099",
		linknext = "0132_00101",
		line = 1339,
	},
	["0132_00101"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0320", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female Student B"},
					"“I see... Ah, well, this is a great opportunity, so why not come along with us to the beach and have your first time there with us? I'm sure anybody'd gladly be your partner!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生B"},
					"“这样啊……啊，那刚好，下次一起去海滩初次做爱吧？如果是片桐同学，大家都会高兴的～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生B"},
					"「這樣啊……啊，那剛好，下次一起去海灘初次做愛吧？如果是片桐同學，大家都會高興的～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00100",
		linknext = "0132_00102",
		line = 1351,
	},
	["0132_00102"] = {
