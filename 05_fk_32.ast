			},
			cn = {
				{
					"再加上舆论的力量，新的变态条例在那之后以罕见的速度被颁布了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再加上輿論的力量，新的變態條例在那之後以罕見的速度被頒布了。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00041",
