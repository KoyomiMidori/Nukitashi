					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, Tachibana. Good morning, nice weather we're having! Ikuko, I'm fairly certain you were the one left in charge of leading the students to today's assembly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哦，橘吗。早上好，今天天气也很好呢！……郁子，今天不是说过有集会要你负责引导吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哦，橘嗎。早，今天天氣也很好呢！……郁子，今天不是說過有集會要你負責引導嗎？」",
					{"rt2"},
				},
			},
