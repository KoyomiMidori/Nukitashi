		},
		linkback = "0132_00149",
		linknext = "0132_00151",
		line = 2024,
	},
	["0132_00151"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00111", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2288", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hmm... I'm not really sure myself... but I guess you could say, I was kinda just dying to see your face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……这一点我也不太清楚啊……虽然不知道为什么，但就是很想看看淳君的脸……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……這一點我也不太清楚啊……雖然不知道為什麼，但就是很想看看淳君的臉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00150",
		linknext = "0132_00152",
		line = 2038,
	},
	["0132_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My face? During the summer vacation you all came and visited me every day in hospital.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说我的脸……暑假期间大家不是每天都有来看我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說我的臉……暑假期間大家不是每天都有來看我嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00151",
		linknext = "0132_00153",
		line = 2050,
	},
	["0132_00153"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
