			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“After all, we did have the eyes of the media on us for a hot minute... Oh, and we've also had a lot more same-sex couples coming lately as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“毕竟有段时间一直被媒体报道着……啊，而且同性恋的客人也增加了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「畢竟有段時間一直被媒體報導著……啊，而且同性戀的客人也增加了。」",
					{"rt2"},
				},
			},
