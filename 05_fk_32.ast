		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm, you want to be loved?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，你想被喜欢吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，你想被喜歡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00128",
		linknext = "0132_00130",
		line = 1744,
	},
	["0132_00130"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2166", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“W-Well of course I do! I've been watching him so closely all this time, and even though I know he has a girlfriend, I still can't help worrying about whether he thinks I'm fat!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那、那是当然啊……！一直在这么近的距离看着，所以即使知道有爱慕的人在，也还是会在意……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那、那是當然啊……！一直在這麼近的距離看著，所以即使知道有愛慕的人在，也還是會在意……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00129",
		linknext = "0132_00131",
		line = 1761,
	},
	["0132_00131"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
