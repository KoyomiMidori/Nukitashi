	["0132_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The True Perverted Sex Law's establishment came hand-in-hand with the resurrection of the formerly disbanded public authority, the OSS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随着真变态条例，即将崩溃的公益社团法人SHO重启成功。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨著真變態條例，即將崩潰的公益社團法人SHO重啟成功。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00169",
		linknext = "0132_00171",
		line = 2292,
	},
	["0132_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And with the OSS being revived, so was the SS and its accompanying scholarship. Pretty cut and dry.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然母体“OSS”复活了，拿取奖学金的“SS”也会一起复活。很简单的道理。",
