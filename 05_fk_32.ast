		line = 777,
	},
	["0132_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Additionally, even if you are in the regions where perverted sex is allowed, you are not allowed to fornicate unless you have the official OSS permission placard around your neck.",
					{"rt2"},
				},
			},
			cn = {
				{
					"另外，即使是在能够做爱的地区，如果脖子上没有挂SHO公认许可证，也不能进行无套交配。",
					{"rt2"},
				},
			},
			tw = {
				{
					"另外，即使是在能夠做愛的地區，如果脖子上沒有掛SHO公認許可證，也不能進行無套交配。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00056",
