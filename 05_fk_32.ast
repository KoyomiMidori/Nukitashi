			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Fine... Yaaawn. And that's summer already over, huh... Bye-bye hedonistic lifestyle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……呼啊啊啊～……暑假已经结束了吗——堕落生活的终结啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……呼啊啊啊～……暑假已經結束了嗎——墮落生活的終結啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00018",
		linknext = "0132_00020",
		line = 273,
	},
	["0132_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
