		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=40000, lv=5},
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After that, the so-called 'new perverted sex law', which was established to abolish the former perverted sex law, was declared null and void.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——从那之后，为了废除变态条例的条例，通称“新变态条例”被废除了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——從那之後，為了廢除變態條例的條例，通稱「新變態條例」被廢除了。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00039",
		linknext = "0132_00041",
		line = 591,
	},
	["0132_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It came about as a result of Fumino's big speech, and the subsequent reinstatement of Senator Hitoura as prefectural governor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是因为之前那个演说的效果，和东山再起的仁浦县知事努力的结果吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是因為之前那個演說的效果，和東山再起的仁浦縣知事努力的結果吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00040",
		linknext = "0132_00042",
		line = 601,
	},
	["0132_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Afterwards, thanks to overwhelming public opinion, an even newer perverted sex law was established at unprecedented speed.",
