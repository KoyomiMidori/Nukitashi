					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「怎麼樣？現在的話，SHO治安管理委員會特殊戰鬥部，還兼任理事長的仙波光姬會大力推薦你哦！」",
					{"rt2"},
				},
