		linkback = "0132_00130",
		linknext = "0132_00132",
		line = 1773,
	},
	["0132_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm not sure what she's talking about, but it's going to be tough trying to diet after eating such big meals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道她在说什么，但是从那个食量来看，要减肥的话应该会很辛苦吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道她在說什麼，但是從那個食量來看，要減肥的話應該會很辛苦吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0132_00131",
		linknext = "0132_00133",
		line = 1783,
	},
