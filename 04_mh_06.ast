		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0788", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ugh... but what if I don't end up losing any weight? If I want to get anywhere before the weekend, I'll need to reduce meal size as much as possible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“唔——要是这样还是瘦不下来怎么办……尽可能减少吃饭的量，想办法撑到周末……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「唔——要是這樣還是瘦不下來怎麼辦……盡可能減少吃飯的量，想辦法撐到週末……」",
					{"rt2"},
				},
			},
		},
