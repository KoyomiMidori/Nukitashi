		},
		linkback = "0083_00285",
		linknext = "0083_00287",
		line = 3778,
	},
	["0083_00287"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I was around, so I thought I'd stop by... You all right? You're pretty out of breath.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，正好来到了附近……没事吧？都喘不过气来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，正好來到了附近……沒事吧？都喘不過氣來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00286",
		linknext = "0083_00288",
		line = 3790,
	},
	["0083_00288"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00111", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0070", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ah, I just stepped out fer a minute and some crazy bitch came after me. I was able to get outta there, though. Fuckin' hell, this island is insane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嗯……我出去了一会儿结果被人邀请了……虽然顺利挺过了……哎呀，真是敌不过这个岛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嗯……我出去了一下結果被人邀請了……雖然順利挺過了……哎呀，真是敵不過這個島……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00287",
		linknext = "0083_00289",
		line = 3804,
	},
	["0083_00289"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're telling me. Still, good job getting away. Don't you have problems with the SS and OSS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我懂……不过，亏你能躲开呢，不会被FS和SHO盯上吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我懂……不過，虧你能躲開呢，不會被FS和SHO盯上嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00288",
		linknext = "0083_00290",
		line = 3816,
	},
	["0083_00290"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0071", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Meh, I've gotten good at avoidin' 'em. No one can come up with excuses like ya boi here. They don't suspect a damn thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嗯……为了不变成那样，我平时很用心。我总是诱导对方，用不让对方埋怨我的方式拒绝。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嗯……為了不變成那樣，我平時很用心。我總是誘導對方，用不讓對方埋怨我的方式拒絕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00289",
		linknext = "0083_00291",
		line = 3830,
	},
	["0083_00291"] = {
