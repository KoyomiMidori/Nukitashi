			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hey, man, I get it. If yer always fappin' to the same shit, ya get attached to it. It gets better over time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我懂。用同样的东西撸了好几次就会逐渐涌出感情……不断重复使用就会让撸管合适度上升……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我懂。用同樣的東西手淫了好幾次就會逐漸湧出感情……不斷重複使用就會讓手淫合適度上升……！」",
					{"rt2"},
