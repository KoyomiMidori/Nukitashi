				{"vo", file="misaki0766", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Oh, yeah... I'm worried about that, yeah, but that's not what I'm talking about. Thinking about the olympiad is depressing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……呃？啊，嗯……当然那个我也很担心，但不是的……那个……一想到体欲节，我就觉得郁闷……”",
