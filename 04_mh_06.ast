			},
		},
		text = {
			vo = {
				{"vo", file="teshima0069", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Haahh... huh? Hey, it's Junnosuke! Hah... shoppin'?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈啊哈啊……嗯……？哦……淳之介君……哈哈……来购物吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
