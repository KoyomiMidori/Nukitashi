			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“However, I have heard frequent comments that the championship has left you completely spent.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是……击坠王锦标赛结束后就完全失去了激情——我们也经常听到这样的意见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是……擊墜王錦標賽結束後就完全失去了激情——我們也經常聽到這樣的意見。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00049",
