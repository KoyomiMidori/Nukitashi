			},
			en = {
				{
					name = {"モブ女A", "School Broadcast"},
					"“All students, please report to the gymnasium for a general school assembly. Either stop or relocate your intercourse there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "校内广播"},
					"“现在开始，进行全校集会。请尽快停止性行为，或者一边进行性行为一边到体育馆集合。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "校內廣播"},
					"「現在開始，進行全校集會。請盡快停止性行為，或者一邊進行性行為一邊到體育館集合。」",
					{"rt2"},
				},
			},
		},
