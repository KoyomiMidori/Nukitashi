		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bgm", file="bgm09.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0652", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Good morning. As always, I feel privileged to hear your brilliant moans once again today. Their beauty rivals that of any school song.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“早上好。不亚于校歌的娇声合唱——今天也非常出色，我确实听见了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「早安。不亞於校歌的嬌喘合唱——今天也非常出色，我確實聽見了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00041",
		linknext = "0083_00043",
		line = 614,
	},
	["0083_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The student council president I saw just a few days ago stands on the podium.",
					{"rt2"},
				},
			},
			cn = {
				{
					"站在讲台上的，和上次一样是学生会长。",
					{"rt2"},
				},
			},
			tw = {
				{
					"站在講臺上的，和上次一樣是學生會長。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00042",
		linknext = "0083_00044",
		line = 624,
	},
	["0083_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once again, I find myself captivated by her aura of graceful aloofness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使声音稳重，但却依然让人有种超然的感觉——眼睛在无意识间被吸引。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使聲音穩重，但卻依然讓人有種超然的感覺——眼睛在無意識間被吸引。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00043",
		linknext = "0083_00045",
		line = 634,
	},
	["0083_00045"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0653", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I would like to congratulate you all on your efforts during the recent Shootdown King event. Know that nothing pleases your student council president more than seeing the school grounds bustling with sex, as during those days.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“大家，上次的击坠王锦标赛辛苦了。期间学校中到处都充满了做爱，学生会十分满意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「大家，上次的擊墜王錦標賽辛苦了。期間學校中到處都充滿了做愛，學生會十分滿意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00044",
		linknext = "0083_00046",
		line = 646,
	},
	["0083_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can sense her emotions in her voice, but nothing is showing on her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是充满了强弱抑扬的演说，但完全看不出情感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是充滿了強弱抑揚的演說，但完全看不出情感。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00045",
		linknext = "0083_00047",
		line = 656,
	},
	["0083_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't read her at all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——她到底在想什么？",
					{"rt2"},
				},
			},
			tw = {
				{
					"——她到底在想什麼？",
