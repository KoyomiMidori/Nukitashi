					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But, if I'm in a swimsuit... it means I'll be showing off this ugly, flabby body to everyone... I even named it Ugflab... hahaha...”",
					{"rt2"},
