		linkback = "0083_00248",
		linknext = "0083_00250",
		line = 3282,
	},
	["0083_00250"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0784", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I know it's against my principles to not obey my cravings, but if I want to lose at least a little weight before the weekend, I have no other options. I can't believe need to part from my beloved ramen...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“抑制食欲虽然违背我的信念……但为了在周末之前减轻体重，我也没有办法……只能和最爱的拉面暂时分手……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「抑制食慾雖然違背我的信念……但為了在周末之前減輕體重，我也沒有辦法……只能和最愛的拉麵暫時分手……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00249",
		linknext = "0083_00251",
		line = 3296,
	},
	["0083_00251"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn't there low-calorie ramen now? Why not try that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最近也有低热量的健康拉面之类的，吃那种的不就好了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最近也有低熱量的健康拉麵之類的，吃那種的不就好了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00250",
		linknext = "0083_00252",
		line = 3308,
	},
	["0083_00252"] = {
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00304", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0785", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Worrying about calories while eating ramen is a form of self-abuse. I'd sooner die than subject myself to that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“吃拉面却担心热量的话还是别当人了。过这种人生还不如一死了之。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「吃拉麵卻擔心熱量的話還是別當人了。過這種人生還不如一死了之。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00251",
		linknext = "0083_00253",
		line = 3322,
	},
	["0083_00253"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're exaggerating. What did healthy ramen do to you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得太过了吧……健康拉面对你做了什么啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得太過了吧……健康拉麵對你做了什麼啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00252",
		linknext = "0083_00254",
		line = 3334,
	},
	["0083_00254"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00105", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0786", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Healthy ramen didn't do anything. Sure, it's better for you, but that's all it's got going for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“健康拉面什么都没做……它可能很健康，但也不过如此。”",
					{"rt2"},
				},
