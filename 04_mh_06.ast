		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At the start of the next week, I feel like my legs are made of lead as I walk to school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"周一——前往学校的我，脚上像长了根一样沉重。",
