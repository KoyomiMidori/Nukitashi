			cn = {
				{
					name = {"美岬"},
					"“就是那个……学校内发生色情暴动的时候。虽然那时候突然就回家了……不过不是有聊到要直接插入抽出的话题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就是那個……學校內發生色情暴動的時候。雖然那時候突然就回家了……不過不是有聊到要直接插入抽出的話題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00110",
		linknext = "0083_00112",
		line = 1500,
	},
	["0083_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you talking about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有说过那种话题吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有說過那種話題嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00111",
		linknext = "0083_00113",
		line = 1512,
	},
	["0083_00113"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1293", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I remember talk of penetrating some terminal with your long, hard data stick and pulling out data?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是在说直接把连接器插入终端抽出数据的话题吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是在說直接把連接器插入終端抽出數據的話題嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00112",
		linknext = "0083_00114",
		line = 1525,
	},
	["0083_00114"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now that you mention it, I remember, but why would you recall it in such obscene terms?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，这么说来有说过……但你为什么就只记得那些猥琐的词汇呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，這麼說來有說過……但你為什麼就只記得那些猥瑣的詞彙呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00113",
		linknext = "0083_00115",
		line = 1537,
	},
	["0083_00115"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00121", file2="misaki_02m_00201", path=":fg/misaki_02m/", id=4, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=100, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=4, act="振動下", loop=4, size=7.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0755", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hyuk hyuk hyuk hyuk...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00114",
		linknext = "0083_00116",
		line = 1552,
	},
	["0083_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Don't give me that Curly laugh...",
					{"rt2"},
				},
			},
			cn = {
				{
					"诶嘿嘿个鬼啊……",
					{"rt2"},
				},
			},
			tw = {
				{
					"欸嘿嘿個鬼啊……",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00115",
		linknext = "0083_00117",
		line = 1562,
	},
	["0083_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, you're right, we never did finish that discussion. While it's important to prepare for the olympiad, our primary goal is still to crush the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，的确还没说完。虽然有必要为NDT做准备，但我们的第一目标依然是彻底摧毁条例——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，的確還沒說完。雖然有必要為NDT做準備，但我們的第一目標依然是徹底摧毀條例——」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00116",
		linknext = "0083_00118",
		line = 1574,
	},
	["0083_00118"] = {
		{"fg", mode=-1, id=4, ch="美岬", lv=5, time=300},
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gathering intel on Fumino is an important step in accomplishing that. Asa, picking up where we left off, do you have any ideas for access points?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为此，文乃的情报是不可或缺的——麻沙酱，能重新抽出数据的地方是？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為此，文乃的情報是不可或缺的——麻沙醬，能重新抽出數據的地方是？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00117",
		linknext = "0083_00119",
		line = 1589,
	},
	["0083_00119"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1294", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“There are a few possibilities, but I don't know which would be best. Bro, you look at this and decide.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我有几个猜测……不过不知道哪里好……哥哥，你看看这些决定一下……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我有幾個猜測……不過不知道哪裡好……哥哥，你看看這些決定一下……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00118",
		linknext = "0083_00120",
		line = 1601,
	},
	["0083_00120"] = {
		{"se", id=0, loop=0, file="se_a001"},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a163"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's see... OSS headquarters? That would be a hell of an undertaking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我看看……SHO总部——看起来很难。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我看看……SHO總部——看起來很難。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00119",
		linknext = "0083_00121",
		line = 1616,
	},
	["0083_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Or the personal PC of an OSS executive. Could we even pull that off?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“SHO干部拥有的个人电脑——这个还算比较现实吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「SHO幹部擁有的個人電腦——這個還算比較現實吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00120",
		linknext = "0083_00122",
		line = 1628,
	},
	["0083_00122"] = {
		{"cgact", file="cgact", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1295", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Theoretically. Not sure how much it'd get us, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……不过，如果是个人电脑的话，里面或许没有什么重要的数据……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……不過，如果是個人電腦的話，裡面或許沒有什麼重要的數據……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00121",
		linknext = "0083_00123",
		line = 1641,
	},
	["0083_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Which leaves this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么——果然是这里吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼——果然是這裡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00122",
		linknext = "0083_00124",
		line = 1653,
	},
	["0083_00124"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0756", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The student council room? That looks more doable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“学生会室吗……确实，这里的话，我们也能轻松进去吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「學生會室嗎……確實，這裡的話，我們也能輕鬆進去吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00123",
		linknext = "0083_00125",
		line = 1668,
	},
	["0083_00125"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1958", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Isn't it keycard locked, though? You can't just borrow a key and waltz on in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是那里是用房卡出入的吧？这样就不能借钥匙潜入了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是那裡是用房卡出入的吧？這樣就不能借鑰匙潛入了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00124",
		linknext = "0083_00126",
		line = 1685,
	},
	["0083_00126"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm... Asa, could you forge a keycard?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……麻沙酱，你能制作解锁用的IC卡吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……麻沙醬，你能製作解鎖用的IC卡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00125",
		linknext = "0083_00127",
		line = 1697,
	},
	["0083_00127"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00103", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1296", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Making it from scratch would be basically im-fucking-possible, but it'd be easy to modify an existing card.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“从零开始的话相当麻烦……但是如果有原来的卡就会轻松很多了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「從零開始的話相當麻煩……但是如果有原來的卡就會輕鬆很多了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00126",
		linknext = "0083_00128",
		line = 1711,
	},
	["0083_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like one of the regular SS keycards?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说……如果有FS平时用的卡的话，就能做出来？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說……如果有FS平時用的卡的話，就能做出來？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00127",
		linknext = "0083_00129",
		line = 1723,
	},
	["0083_00129"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1297", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That'd work, yeah. I can copy the code and just write it to a blank card. Even a damn monkey could do it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯。只要把里面的代码全部抽出来写在空白的卡上……大猩猩也能做到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯。只要把裡面的代碼全部抽出來寫在空白的卡上……大猩猩也能做到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00128",
		linknext = "0083_00130",
		line = 1737,
	},
	["0083_00130"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0757", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ooh, that's amazing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哇——好厉害啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哇——好厲害啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00129",
		linknext = "0083_00131",
		line = 1751,
	},
	["0083_00131"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00110", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1298", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hotori couldn't, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“畔同学是做不到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「畔同學是做不到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00130",
		linknext = "0083_00132",
		line = 1765,
	},
	["0083_00132"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00125", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0758", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I'm less than a monkey to you!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我比大猩猩还不如吗呜嚯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我比大猩猩還不如嗎嗚齁！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00131",
		linknext = "0083_00133",
		line = 1779,
	},
	["0083_00133"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Chill. Anyway, we can work with that and come up with a plan. What've you got for us, Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好了好了。总之，把作战计划简单总结一下吧——奈奈濑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好了好了。總之，把作戰計劃簡單總結一下吧——奈奈瀨。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00132",
		linknext = "0083_00134",
		line = 1791,
	},
	["0083_00134"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00119", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=7000, time=300, mode=3, x=-600, y=0},
			},
			[8500] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1959", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, first, we need to swipe the card from an SS member. Asa can extract the... code...? From it, then use that to make a new card.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“首先，要从FS的某人手中夺取卡片，然后让麻沙酱把卡片中的……代码？给抽出来伪造卡片……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「首先，要從FS的某人手中奪取卡片，然後讓麻沙醬把卡片中的……代碼？給抽出來偽造卡片……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00133",
		linknext = "0083_00135",
		line = 1809,
	},
	["0083_00135"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[8700] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=8700, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1960", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Then we use that card to infiltrate the student council room, plug into the terminal, and extract the data. That's basically it, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“——然后，用做好的卡片潜入到学生会室……直接把连接器连接到终端上取出数据，这样的流程可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「——然後，用做好的卡片潛入到學生會室……直接把連接器連接到終端上取出數據，這樣的流程可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00134",
		linknext = "0083_00136",
		line = 1825,
	},
	["0083_00136"] = {
		{"se", id=0, loop=0, file="se_a100"},
		{"fg", file="asane_02m_00001", file1="asane_02m_00113", file2="asane_02m_00201", file4="asane_02m_00401", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=100, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1299", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Amazing as always, Nanase. It's super crazy how you never fail to be perfect. We can extract the data, scour it for anything on Fumino, Bro and Nanase go and get their marriage licenses, and operation complete.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“真完美不愧是奈奈濑同学毫无纰漏……从抽出的数据中调查文乃的信息，然后哥哥和奈奈濑同学结婚就算完成了本次作战……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真完美不愧是奈奈瀨同學毫無紕漏……從抽出的數據中調查文乃的資訊，然後哥哥和奈奈瀨同學結婚就算完成了本次作戰……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00135",
		linknext = "0083_00137",
		line = 1841,
	},
	["0083_00137"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What was that bit about marriage licenses?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要呼吸般地让我们两个结婚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要呼吸般地讓我們兩個結婚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00136",
		linknext = "0083_00138",
		line = 1853,
	},
	["0083_00138"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1961", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“That's an outline, but we don't have a proper strategy yet. Got anything in mind?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……虽然作战是决定了，但具体的事情还完全没有决定呢。怎么做呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……雖然作戰是決定了，但具體的事情還完全沒有決定呢。怎麼做呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00137",
		linknext = "0083_00139",
		line = 1867,
	},
	["0083_00139"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's see... stealing someone's card and sneaking into the office... How about during class?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……要从谁那里抢卡，什么时候潜入学生会室——上课时怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……要從誰那裡搶卡，什麼時候潛入學生會室——上課時怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00138",
		linknext = "0083_00140",
		line = 1879,
	},
	["0083_00140"] = {
		{"se", id=0, loop=0, file="se_a100"},
		{"fg", file="asane_02m_00001", file1="asane_02m_00114", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1300", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I wouldn't if I were you. Even if it's with a copy, anyone accessing the room would be logged. It'd be hella sus to do it during class.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要那样做比较好……即使是复制的，但只要使用了卡片，时间就会被记录下来……如果当时不在课堂上一定会被怀疑……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要那樣做比較好……即使是複制的，但只要使用了卡片，時間就會被記錄下來……如果當時不在課堂上一定會被懷疑……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00139",
		linknext = "0083_00141",
		line = 1895,
	},
	["0083_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There's too many people around at recess, plus someone would probably come in while we're inside. Doing it during school at all would be risky.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但休息时间很引人注目，有人在学生会室的可能性也很高……也就是说白天很困难吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但休息時間很引人注目，有人在學生會室的可能性也很高……也就是說白天很困難吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00140",
		linknext = "0083_00142",
		line = 1907,
	},
	["0083_00142"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1962", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“How about after school? Wait until no one's around, then enter the office?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“放学后怎么样？等到没人的时间，再进入学生会室……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「放學後怎麼樣？等到沒人的時間，再進入學生會室……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00141",
		linknext = "0083_00143",
		line = 1921,
	},
	["0083_00143"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1301", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Soon as we use the card, the OSS and SS get notified in their dorms, so they might come down on us immediately. We'd need to stop the elevators somehow for that to work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“使用卡的时候数据应该会传到SHO和FS的宿舍，所以FS可能会马上赶过来……电梯也可能会被关掉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「使用卡的時候數據應該會傳到SHO和FS的宿舍，所以FS可能會馬上趕過來……電梯也可能會被關掉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00142",
		linknext = "0083_00144",
		line = 1933,
	},
	["0083_00144"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Never thought infiltrating a secure office would be so hard. When could we do it, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看来情况比想象中要严峻啊——那么，什么时候可以潜入呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看來情況比想像中要嚴峻啊——那麼，什麼時候可以潛入呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00143",
		linknext = "0083_00145",
		line = 1945,
	},
	["0083_00145"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Trying to enter during class would make anyone absent a suspect.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果上课时间潜入，没上课的人会被怀疑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果上課時間潛入，沒上課的人會被懷疑。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00144",
		linknext = "0083_00146",
		line = 1961,
	},
	["0083_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if we do it when no one's in the school, they'd hear about it and come down on us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但如果在没有人的时间侵入，又有可能会被抓住。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但如果在沒有人的時間侵入，又有可能會被抓住。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00145",
		linknext = "0083_00147",
		line = 1971,
	},
	["0083_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The best way to avoid suspicion would be to do it when others are around, but that would be suicidal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话，就在有人也不奇怪的时间偷偷潜入——但这就只是单纯的自杀行为吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話，就在有人也不奇怪的時間偷偷潛入——但這就只是單純的自殺行為吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00146",
		linknext = "0083_00148",
		line = 1981,
	},
	["0083_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So we need sometime during the day, when the SS aren't there, where they won't suspect us even if our infiltration is recorded.",
					{"rt2"},
				},
			},
			cn = {
				{
					"白天，在FS不在学生会室的时候潜入——同时选在就算留下了记录我们也不会被嫌疑的时间点，这是必要条件。",
					{"rt2"},
				},
			},
			tw = {
				{
					"白天，在FS不在學生會室的時候潛入——同時選在就算留下了記錄我們也不會被嫌疑的時間點，這是必要條件。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00147",
		linknext = "0083_00149",
		line = 1991,
	},
	["0083_00149"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no situation where all those conditions would be met.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么好的状况真的存在吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼好的狀況真的存在嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00148",
		linknext = "0083_00150",
		line = 2002,
	},
	["0083_00150"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, what about...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……有了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……有了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00149",
		linknext = "0083_00151",
		line = 2014,
	},
	["0083_00151"] = {
		{"bgm", file="bgm14", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The NGO! If we infiltrate during the NGO, they won't be able to trace us!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是NDT！如果是在NDT的时候，即使潜入进去也不会被发现吧——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是NDT！如果是在NDT的時候，即使潛入進去也不會被發現吧——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00150",
		linknext = "0083_00152",
		line = 2027,
	},
	["0083_00152"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0759", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, are no-GF organisms really good at infiltration...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……自然处男和潜入有什么关系呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……自然處男和潛入有什麼關係呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00151",
		linknext = "0083_00153",
		line = 2040,
	},
	["0083_00153"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I mean the Nut Games of the ☆XXX☆ Olympiad. It has nothing to do with my lack of a girlfriend.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我说的是大炮开枪☆射精体欲节的简称……别再提处男了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我說的是大砲開槍☆射精體欲節的簡稱……別再提處男了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00152",
		linknext = "0083_00154",
		line = 2052,
	},
	["0083_00154"] = {
		{"se", id=0, loop=0, file="se_a061"},
		{"se", id=0, stop=1, time=3000},
		{"fgact", ch="美岬", id=6, act="移動", x=400, y=0, time=1500},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wait... Would that phrase mean I'm biologically incapable of having a girlfriend?",
					{"rt2"},
				},
			},
			cn = {
				{
					"啊……并不是因为我是处男……才这样说的哦……",
					{"rt2"},
				},
			},
			tw = {
				{
					"啊……並不是因為我是處男……才這樣說的哦……",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00153",
		linknext = "0083_00155",
		line = 2067,
	},
	["0083_00155"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=6, time=300, x=0, y=0, alphadel=1, style="reset"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, anyway, let's see. First of all, during the NGO — that is, the olympiad — the SS should all be outside.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……然后。首先NDT——体欲节期间，FS应该都在外面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……然後。首先NDT——體欲節期間，FS應該都在外面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00154",
		linknext = "0083_00156",
		line = 2081,
	},
	["0083_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There's no way they could keep track of everyone who isn't part of the current event at any given time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且，没有参加竞技的学生在哪里——就算是FS也不能完全掌握。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且，沒有參加競技的學生在哪裡——就算是FS也不能完全掌握。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00155",
		linknext = "0083_00157",
		line = 2093,
	},
	["0083_00157"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What if we do it then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果这时潜入学生会室……会怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果這時潛入學生會室……會怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00156",
		linknext = "0083_00158",
		line = 2105,
	},
	["0083_00158"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1963", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So even if they've got a record of someone breaking in, they'd have no way of knowing who it was?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“就算看到记录有潜入的痕迹……也无法掌握那个时间不在操场上的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「就算看到記錄有潛入的痕跡……也無法掌握那個時間不在操場上的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00157",
		linknext = "0083_00159",
		line = 2118,
	},
	["0083_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's correct.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00158",
		linknext = "0083_00160",
		line = 2129,
	},
	["0083_00160"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1972", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But didn't you say earlier that the SS would come down on us as soon as we entered? What do we do about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是，刚才说的……进去的瞬间FS的人可能会突然过来……不要紧吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是，剛才說的……進去的瞬間FS的人可能會突然過來……不要緊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00159",
		linknext = "0083_00161",
		line = 2145,
	},
	["0083_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even during the olympiad, they'd probably expect there to be a few people coming and going from the office. It shouldn't set off any alarms, at least not right away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽说是在体欲节中，但应该还是多少会有人出入学生会室……所以大概不会被当作问题吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖說是在體欲節中，但應該還是多少會有人出入學生會室……所以大概不會被當作問題吧。」",
					{"rt2"},
				},
			},
