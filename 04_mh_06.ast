			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我再补充一下，长绳是指在到达高潮之前能摩擦几次的竞技项目，男女组队大概是指勃起跳远吧。就是竞争精子飞行的距离。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我再補充一下，長繩是指在到達高潮之前能摩擦幾次的競技項目，男女組隊大概是指勃起跳遠吧。就是競爭精子飛行的距離。」",
					{"rt2"},
				},
			},
		},
