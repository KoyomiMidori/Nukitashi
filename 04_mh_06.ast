		linknext = "0083_00162",
		line = 2157,
	},
	["0083_00162"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We need to find a time when the SS definitely wouldn't be around.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，只要算准FS绝对不会来的时机潜入……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，只要算準FS絕對不會來的時機潛入……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00161",
		linknext = "0083_00163",
		line = 2169,
	},
	["0083_00163"] = {
		{"text"},
		text = {
			ja = {
				{
