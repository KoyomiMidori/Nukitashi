					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Kidding. Obviously I know better than to let my personal feelings get in the way here. I'll wait until the mission is done to ruin her day.”",
