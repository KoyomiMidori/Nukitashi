	["0083_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, she grew up here, so she'd be the one who knows.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，既然纯青蓝岛长大的畔这么说，那实际上就是穿着泳装进行竞技吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，既然純青藍島長大的畔這麼說，那實際上就是穿著泳裝進行競技吧。",
					{"rt2"},
