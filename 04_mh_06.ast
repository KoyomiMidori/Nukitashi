			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Ah, wait, you mean me!? Uh, umm... can you really entrust such a vital mission to me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶？啊，是、是我吗……！？呃、呃……这样可以吗？让我扮演这么重要的角色……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸？啊，是、是我嗎……！？呃、呃……這樣可以嗎？讓我扮演這麼重要的角色……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00174",
		linknext = "0083_00176",
		line = 2326,
	},
	["0083_00176"] = {
