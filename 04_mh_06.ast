		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1286", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Still moping about it? I thought you said you weren't worried.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你又在说了……不是不介意了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你又在說了……不是不介意了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00003",
		linknext = "0083_00005",
		line = 57,
	},
	["0083_00005"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No shit I'm worried! The enemy knows who I am!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话是这么说……！不过我的真实身份被敌人发现了哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話是這麼說……！不過我的真實身份被敵人發現了哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00004",
		linknext = "0083_00006",
		line = 70,
	},
	["0083_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Onabuta knows I'm Anti-Copulation Front.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被女部田发现我是反交尾势力了。",
