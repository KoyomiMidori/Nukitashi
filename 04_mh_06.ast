				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑你……这次应该用同样的方法就没问题了吧。毕竟还有5P的风评，大概会比去年还要被人畏惧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨你……這次應該用同樣的方法就沒問題了吧。畢竟還有5P的風評，大概會比去年還要被人畏懼。」",
					{"rt2"},
				},
			},
		},
