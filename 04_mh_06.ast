					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then we plug into the terminal, extract the data, and we're home free.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后，把连接器和终端连接，抽出数据——这样作战就完成了。”",
