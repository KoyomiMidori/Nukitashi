		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm still waffling over it when we arrive at school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在焦急之中到达了学校。",
					{"rt2"},
				},
			},
