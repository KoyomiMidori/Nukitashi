			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“How many frickin' times were you like 'well we haven't run into any issues lately so it's all good, mwahahaha' on the weekends, anyway...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“休息期间什么都没发生所以没问题了哈哈哈——你不是自己说了好几次这句话吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「休息期間什麼都沒發生所以沒問題了哈哈哈——你不是自己說了好幾次這句話嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00007",
		linknext = "0083_00009",
		line = 107,
	},
	["0083_00009"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the fuck do you want from me? I was worried sick so I obviously HAD to keep telling myself that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为我超级不安，所以才会一直这么告诉自己的好吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是因為我超級不安，所以才會一直這麼告訴自己的好嗎！」",
					{"rt2"},
				},
			},
		},
