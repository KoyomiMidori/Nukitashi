		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg050102", x=-5, y=-5, path=":cg/kcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
