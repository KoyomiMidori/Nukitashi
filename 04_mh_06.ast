	},
	["0083_00248"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ugh... Unforgivable! Now it's personal. The bloated law must be crushed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可恶……不可饶恕的鞭太条例——我一定要废除。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可惡……不可饒恕的鞭太條例——我一定要廢除。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00247",
		linknext = "0083_00249",
		line = 3272,
	},
	["0083_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wait, no. The perverted law is the one that's going down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"错了。变态条例——我一定要废除。",
					{"rt2"},
				},
			},
			tw = {
				{
					"錯了。變態條例——我一定要廢除。",
