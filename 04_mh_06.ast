	},
	["0083_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I'd just said “yes I'd love to” like my instincts demanded without thinking, I would've set up yet another trope.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果我刚刚说出“彼此彼此，今后也请多关照”，那我肯定会受到一生无法痊愈的伤害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果我剛剛說出「彼此彼此，今後也請多關照」，那我肯定會受到一生無法痊癒的傷害。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00268",
		linknext = "0083_00270",
		line = 3544,
	},
	["0083_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As a proud virgin, I'm well-versed in the art of parsing others' poor communication and misunderstandings from the safety of my monitor, so I was able to escape that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是个高傲的处男。我已经通过屏幕经历过无数次没说清楚造成误解的事件——多亏这样我才侥幸逃过一劫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是個高傲的處男。我已經通過螢幕經歷過無數次沒說清楚造成誤會的事件——多虧這樣我才僥倖逃過一劫。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00269",
		linknext = "0083_00271",
		line = 3554,
	},
	["0083_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
