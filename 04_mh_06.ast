	},
	["0083_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Refusing sex is allowed before the olympiad, so it's probably much safer now than it is normally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在是体欲节前——允许拒绝做爱，与平时相比应该非常安全吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在是體欲節前——允許拒絕做愛，與平時相比應該非常安全吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00190",
		linknext = "0083_00192",
		line = 2565,
	},
	["0083_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, considering how fucked-up this island is, you can never know for sure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，存在于这个岛上的核心思想——变态最棒做爱万岁的想法并不会改变，还是小心点好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，存在於這個島上的核心思想——變態最棒做愛萬歲的想法並不會改變，還是小心點好。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00191",
		linknext = "0083_00193",
		line = 2575,
	},
	["0083_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I mostly just want to give her as much support as possible, considering I just dumped a huge burden onto her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"更重要的——既然要让她担当重要角色，我想尽可能地支持畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"更重要的——既然要讓她擔當重要角色，我想盡可能地支持畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00192",
		linknext = "0083_00194",
		line = 2585,
	},
	["0083_00194"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00113", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
