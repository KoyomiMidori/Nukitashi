	["0083_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After dropping Asa off at our place, I'm walking Hotori home when she bows her head to me respectfully.",
