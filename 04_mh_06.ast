			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ugh... but what do I do? I'm worried.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“唉……不过该怎么办呢……好担心……”",
