		linkback = "0083_00005",
		linknext = "0083_00007",
		line = 80,
	},
	["0083_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As Asa knows I used 'that' again, I told her the rest of the story.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为麻沙酱知道我“用过”的事情，所以就把事情的来龙去脉说了出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為麻沙醬知道我「用過」的事情，所以就把事情的來龍去脈說了出去。",
					{"rt2"},
				},
			},
		},
