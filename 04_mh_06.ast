		linkback = "0083_00079",
		linknext = "0083_00081",
		line = 1104,
	},
	["0083_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's not like the Shootdown King. This is going to be something held in one specific spot for an audience of spectators. If we don't show up, the wrong people are gonna notice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和击坠王不同，是在一处举行的大规模活动……缺席将被立即注意到——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和擊墜王不同，是在一處舉行的大規模活動……缺席將被立刻注意到——」",
					{"rt2"},
				},
			},
		},
