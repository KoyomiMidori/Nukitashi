	["0083_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I calm down and think about it rationally, if the SS knew I was from the Anti-Copulation Front, I would've already been apprehended.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷静想一想，如果FS知道我是反交尾势力的话，是不会让我自由行动到这一刻的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷靜想一想，如果FS知道我是反交尾勢力的話，是不會讓我自由行動到這一刻的。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00016",
		linknext = "0083_00018",
		line = 250,
	},
	["0083_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can only conclude that I haven't been found out yet.",
					{"rt2"},
				},
			},
			cn = {
