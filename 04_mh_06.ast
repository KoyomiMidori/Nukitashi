		linknext = "0083_00292",
		line = 3842,
	},
	["0083_00292"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0072", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Yeah, I actually used to study a bit o' psychology. I've got a knack for readin' people, ya know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嗯，其实我以前学过一点心理学，所以我其实挺擅长从外观和谈吐中看出对方的人品。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嗯，其實我以前學過一點心理學，所以我其實挺擅長從外觀和談吐中看出對方的人品。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00291",
		linknext = "0083_00293",
		line = 3854,
	},
	["0083_00293"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0073", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I'm hella good at deflectin', like, 'ain't that guy over there more yer type?' I just put them on some other dude.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“所以可以迎合对方……说‘比起我，和那边的男人做应该更舒服吧？’这样诱导对方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「所以可以迎合對方……說『比起我，和那邊的男人做應該更舒服吧？』這樣誘導對方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00292",
		linknext = "0083_00294",
		line = 3866,
	},
	["0083_00294"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see. That's actually... incredible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，还可以那样做啊……真厉害呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，還可以那樣做啊……真厲害呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00293",
		linknext = "0083_00295",
		line = 3878,
	},
	["0083_00295"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00102", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0074", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, it's nothin'. The people here are hella simple. I'm basically a sex counsellor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不是什么值得夸奖的事情。这个岛上的人在某种意义上很容易理解……而且我做的是性爱咨询师。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「不是什麼值得誇獎的事情。這個島上的人在某種意義上很容易理解……而且我做的是性愛諮詢師。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00294",
		linknext = "0083_00296",
		line = 3892,
	},
	["0083_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He laughs at himself, but being able to do that consistently is really amazing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然手嶋先生自嘲地笑了笑，但如果光是稍微说几句话就真的可以做到那种事，是真的很厉害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然手嶋先生自嘲地笑了笑，但如果光是稍微說幾句話就真的可以做到那種事，是真的很厲害。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00295",
		linknext = "0083_00297",
		line = 3902,
	},
	["0083_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never even thought about psychology, but if it could help me like that, maybe it's worth looking into.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心理学对我来说是个很遥远的领域，如果能发展到那种程度的话会产生兴趣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心理學對我來說是個很遙遠的領域，如果能發展到那種程度的話會產生興趣。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00296",
		linknext = "0083_00298",
		line = 3912,
	},
	["0083_00298"] = {
		{"text"},
		text = {
