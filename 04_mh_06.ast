		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So they hold back their lust and let it build up for the day. Textbook ejaculation regulation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……压抑性欲，让其在当日爆发——也就是说，能把射精管理当作盾牌吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……壓抑性慾，讓其在當日爆發——也就是說，能把射精管理當作盾牌嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00072",
		linknext = "0083_00074",
		line = 1026,
	},
	["0083_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As a healthy, red-blooded young man, I generally masturbate three times a day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是平凡的健康优良儿，所以基本上每天都自慰3次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是平凡的健康優良兒，所以基本上每天都自慰3次。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00073",
		linknext = "0083_00075",
		line = 1036,
	},
	["0083_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Very occasionally I'll go without fapping for a day, and my ejaculation is indeed more vigorous the next day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有时候也会一整天不撸管——但第二天的射精的确会不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有時候也會一整天不手淫——但第二天的射精的確會不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00074",
		linknext = "0083_00076",
		line = 1046,
	},
	["0083_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Makes sense, especially considering one of the events is a semen-shooting contest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说在体欲祭中也有比精子飞行距离的项目，所以射精管理是合乎道理的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說在體欲祭中也有比精子飛行距離的項目，所以射精管理是合乎道理的。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00075",
		linknext = "0083_00077",
		line = 1056,
	},
	["0083_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In other words, we'll have it fairly easy until the weekend?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……也就是说，本周不需要像往常一样冒着风险逃亡。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……也就是說，本週不需要像往常一樣冒著風險逃亡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00076",
		linknext = "0083_00078",
		line = 1067,
	},
	["0083_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh... This might actually work out for us, I guess?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……可以说是一个出乎意料的，不错的展开吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……可以說是一個出乎意料的，不錯的展開嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00077",
		linknext = "0083_00079",
		line = 1079,
	},
	["0083_00079"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00105", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1291", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I wouldn't go that far. Regardless of what happens during the week, the main question is, how do we get through this olympiad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“也不能这么说吧……就算这周没问题，但最关键的体欲节怎么办……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「也不能這麼說吧……就算這週沒問題，但最關鍵的體欲節怎麼辦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00078",
		linknext = "0083_00080",
		line = 1092,
	},
	["0083_00080"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fair enough... We're not gonna get a free pass for this event.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“的确……那活动本身的确是不可避免的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「的確……那活動本身的確是不可避免的。」",
