	["0083_00299"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0075", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Huh, maybe. Ya like fappin' to older eroge more than the newer shit, don't ya?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“是啊。淳之介君你……在自慰的时候，比起新颖的色情作品，还是比较常用旧的色情作品来撸对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「是啊。淳之介君你……在自慰的時候，比起新穎的色情作品，還是比較常用舊的色情作品來擼對吧？」",
					{"rt2"},
				},
			},
		},
