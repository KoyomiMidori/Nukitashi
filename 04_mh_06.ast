			en = {
				{
					name = {"桐香", "Touka"},
					"“In order to rectify that situation, we have made a decision to move a regular annual student event up and hold it early.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“学生会为了解决这一问题，今年决定把往年的活动提前举行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「學生會為了解決這一問題，今年決定把往年的活動提前舉行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00050",
