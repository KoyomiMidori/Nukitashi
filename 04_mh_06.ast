	["0083_00301"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0076", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh... I've seen ya buy a shit ton o' sex sleeves, but ya never get the new mags or DVDs. Figured ya already knew what ya liked.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“呵……淳之介君虽然买了大量飞机杯，却没怎么买新的杂志和DVD对吧？所以我才想说你经常用自己熟悉的配菜来撸。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「呵……淳之介君雖然買了大量飛機杯，卻沒怎麼買新的雜誌和DVD對吧？所以我才想說你經常用自己熟悉的配菜來擼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00300",
		linknext = "0083_00302",
		line = 3963,
