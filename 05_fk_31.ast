					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There's snipers on the summit! If they target you, it's curtains!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“山顶上有狙击手！如果被瞄准可就完蛋了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「山頂上有狙擊手！如果被瞄準可就完蛋了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00185",
		linknext = "0131_00187",
		line = 3180,
	},
	["0131_00187"] = {
