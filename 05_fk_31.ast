	["0131_00306"] = {
		{"fg", file="ikuko_01m_00001", file3="ikuko_01m_00305", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0657", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I've been told to refrain from using that, because whenever I do, I end up cumming every time when I cut someone down... but these are special circumstances, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这么做的话，每次砍人都会高潮，所以被警告过最好不要这么做……但这次没办法吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這麼做的話，每次砍人都會高潮，所以被警告過最好不要這麼做……但這次沒辦法吧？」",
					{"rt2"},
				},
			},
		},
