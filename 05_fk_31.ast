		{"cgact", file="cgact", id=18, act="移動", x=-100, y=0, time=50000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All this hubbub will give the island the shot in the arm it needs! If the people want both sides to coexist, they'll make it happen!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要有这种热度，岛一定会重生。如果大家都希望，就一定能共存！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要有這種熱度，島一定會重生。如果大家都希望，就一定能共存！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00450",
		linknext = "0131_00452",
		line = 7827,
	},
