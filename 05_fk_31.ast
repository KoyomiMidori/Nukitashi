			ja = {
				{
					name = {"モブ男B", "精鋭警備兵E"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Elite Guard E"},
					"“Commando unit C here! We've arrived, the enemy is— What the hell happened here!? It's a blowout! That son of a bitch!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "精锐警备兵E"},
					"“特攻部队C班，抵达！敌人是——这是怎么回事！？全军覆没！？你们竟敢——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "精銳警備兵E"},
					"「特攻部隊C班，抵達！敵人是——這是怎麼回事！？全軍覆沒！？你們竟敢——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00297",
		linknext = "0131_00299",
		line = 5367,
