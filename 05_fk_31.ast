				{"vo", file="touka0897", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The coins are merely a diversionary tactic. You haven't even seen my real weapon yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我的硬币就像吸引目光的魔术——真正的武器并不是这种东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我的硬幣就像吸引目光的魔術——真正的武器並不是這種東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00380",
		linknext = "0131_00382",
		line = 6707,
	},
	["0131_00382"] = {
