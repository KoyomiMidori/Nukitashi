	["0131_00400"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=3, file="bg29_3l_00000", x=-300, y=0, lv=5, path=":bg/", sync=0, ev=1, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"bg", id=18, file="pm3_00001", x=0, y=0, path=":cg/pm3/", ev=1, time=500, lv=5, ax=1250, ay=455, bx=-450, by=-5},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, path=":bg/", sync=0, time=500, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=3, file="bg29_3l_00000", x=-300, y=0, lv=5, path=":bg/", sync=0, ev=1, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=3, act="移動", x=295, y=-5, time=5000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The roof of the battlefield site.",
					{"rt2"},
				},
			},
			cn = {
				{
					"战场遗址，屋顶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"戰場遺址，屋頂。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00399",
		linknext = "0131_00401",
		line = 7054,
	},
	["0131_00401"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This was apparently created long ago to survey for enemy submarines.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说这里是以前为了监视敌国的潜艇而建造的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說這裡是以前為了監視敵國的潛艇而建造的。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00400",
		linknext = "0131_00402",
		line = 7065,
	},
	["0131_00402"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So you can get quite an impressive view from up here. Even the OSS building is clearly visible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此视野开阔，SHO总部大楼也能清楚看到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此視野開闊，SHO總部大樓也能清楚看到。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00401",
		linknext = "0131_00403",
		line = 7075,
	},
	["0131_00403"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"fg", file="jun_01m_00001", file1="jun_01m_00101", file4="jun_01m_00402", path=":fg/jun_01m/", id=4, lv=5, head="jun_01m", ch="淳之介", mw="mw", sync=0, style="blur", blurx=11, blury=11, time=1000, mode=3, x=50, y=0},
		{"fgact", ch="淳之介", id=4, act="移動", x=50, y=0, time=2000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've finally made it here, with the breeze against my back.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我来到了这个刮着风的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我來到了這個刮著風的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00402",
		linknext = "0131_00404",
		line = 7088,
	},
	["0131_00404"] = {
		{"cgdel", id=13, time=100, alphadel=1, lv=5},
		{"cgdel", id=3, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"fg", mode=-1, id=4, ch="淳之介", lv=5, time=100},
		{"bg", id=3, file="bg29_3l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="jun_01m_00001", file1="jun_01m_00110", file4="jun_01m_00402", path=":fg/jun_01m/", id=4, lv=5, head="jun_01m", ch="淳之介", mw="mw", sync=0, time=300, mode=3, x=100, y=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We meet at last... And you look pretty comfy in your easy chair there, you boomer fuck.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……终于见到你了，你这躺在安乐椅上的混蛋老头子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……終於見到你了，你這躺在安樂椅上的混蛋老頭子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00403",
		linknext = "0131_00405",
		line = 7107,
	},
	["0131_00405"] = {
		{"fg", mode=-1, id=4, ch="淳之介", lv=5, time=1000},
		{"cgdel", id=3, lv=5, time=1000, alphadel=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=5, time=1000, x=0, y=0, alphadel=1, style="reset"},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=1000, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=12, file="bg29_3l_00000", x=0, y=250, lv=5, path=":bg/", sync=0, time=1000, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=12, act="移動", x=-5, y=-505, time=10000, lv=5},
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00112", path=":fg/sakimori_01m/", id=13, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=1000, mode=3, x=0, y=1000},
		{"fgact", ch="防人老人", id=13, act="移動", x=0, y=-1000, time=10000},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0224", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Hm. So you managed to get this far. Your pride will be the death of you, boy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“嗯……终于来到这里了吗，将为矜持战死的年轻人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「嗯……終於來到這裡了嗎，將為矜持戰死的年輕人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00404",
		linknext = "0131_00406",
		line = 7132,
	},
	["0131_00406"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At long last, Sakimori and I meet face to face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"终于，我和防人老人见面了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"終於，我和防人老人見面了。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00405",
		linknext = "0131_00407",
		line = 7142,
	},
	["0131_00407"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He stands before me, his stature slightly smaller than I expected.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一个比我想象得要娇小的老人站在我面前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一個比我想像得要嬌小的老人站在我面前。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00406",
		linknext = "0131_00408",
		line = 7152,
	},
	["0131_00408"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=12, time=1000, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=13, ch="防人老人", lv=5, time=1000},
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00101", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"fgact", ch="防人老人", id=11, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0225", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“If nothing else, the way you overcame so many obstacles to make it here is certainly admirable. But... for what cause?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“我要表扬你克服了种种障碍，终于来到了这里。但是——就算这样你能怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「我要表揚你克服了種種障礙，終於來到了這裡。但是——就算這樣你能怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00407",
		linknext = "0131_00409",
		line = 7170,
	},
	["0131_00409"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00110", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0226", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Even if you defeat me here, will that mean a thing for the law? You cannot stop the destruction of the OSS headquarters.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“就算打倒了我，条例也不会因此改变。你也无法阻止SHO总部大楼的崩坏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「就算打倒了我，條例也不會因此改變。你也無法阻止SHO總部大樓的崩壞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00408",
		linknext = "0131_00410",
		line = 7184,
	},
	["0131_00410"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00111", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0227", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Now that you and I are sharing the best seat in the house, you'll at least have the best possible view of your defeat! Bwahahaha, hahaha!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“你只能跟我在特等席上看着你们的失败——哈哈哈哈，啊哈哈哈哈哈！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「你只能跟我在特等席上看著你們的失敗——哈哈哈哈，啊哈哈哈哈哈！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00409",
		linknext = "0131_00411",
		line = 7198,
	},
	["0131_00411"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wonder what the people have to say about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——真的是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——真的是這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00410",
		linknext = "0131_00412",
		line = 7210,
	},
	["0131_00412"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00104", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0228", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What? The audacity of you, to spout such poppycock in the face of your demise.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“——什么？都到这个时候了，你还在说什么梦话——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——什麼？都到這個時候了，你還在說什麼夢話——」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00411",
		linknext = "0131_00413",
		line = 7224,
	},
	["0131_00413"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Call it poppycock all you want. But I think you're about to find out exactly what that longstanding desire of yours has wrought.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是不是梦话，你可以自己确认看看。你的行为的真正价值，现在就能知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是不是夢話，你可以自己確認看看。你的行為的真正價值，現在就能知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00412",
		linknext = "0131_00414",
		line = 7236,
	},
	["0131_00414"] = {
		{"se", id=0, loop=0, file="se_a190"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At that moment, his radio goes off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无线电响了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無線電響了。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00413",
		linknext = "0131_00415",
		line = 7247,
	},
	["0131_00415"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00109", file2="sakimori_01m_00202", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0229", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What!? They're rioting outside the building!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“——什么，大楼前发生了暴动！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——什麼，大樓前發生了暴動！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00414",
		linknext = "0131_00416",
		line = 7262,
	},
	["0131_00416"] = {
		{"se", id=0, loop=0, file="se_b032"},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0186", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "警備兵A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guard A"},
					"“Yes, sir! The islanders came down on us almost spontaneously, it's a madhouse down here! At this rate, the demolition can't be— AAAAAAAGH!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "警备兵A"},
					"“是的！好像是岛上的人突然发起的，人数多得不得了！这样下去没办法施工、呜啊啊啊啊啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "警備兵A"},
					"「是的！好像是島上的人突然發起的，人數多得不得了！這樣下去沒辦法施工、嗚啊啊啊啊啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00415",
		linknext = "0131_00417",
		line = 7275,
	},
	["0131_00417"] = {
		{"se", id=5, stop=1, time=1000},
		{"se", id=3, stop=1, time=3000},
		{"bgm", file="bgm15", vol=100},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, time=100, alphadel=1, lv=5},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=11, ch="防人老人", lv=5, time=100},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg01_3_00000", x=0, y=0, path=":bg/", sync=0, ev=1, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="pm3_00001", x=0, y=0, path=":cg/pm3/", ev=1, lv=5, ax=1250, ay=455, bx=-450, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00104", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg01_3_00000", x=0, y=0, path=":bg/", sync=0, ev=1, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="pm3_00001", x=0, y=0, path=":cg/pm3/", ev=1, time=300, lv=5, ax=1250, ay=455, bx=-450, by=-5},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0183", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“We will not stand idly by and allow our proudest symbol to be destroyed! The time to take a stand is now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“——作为我们的象征的这里是绝对不能被破坏的！！现在正是奋起的时候！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「——作為我們的象徵的這裡是絕對不能被破壞的！！現在正是奮起的時候！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00416",
		linknext = "0131_00418",
		line = 7322,
	},
	["0131_00418"] = {
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00103", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg01_3l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0184", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“I swear that on my name— Senba Kouki, representing the Special Combat Unit of the OSS Public Order Division! People, violence is not the answer here! Let us do no harm to anyone, but continue to hinder this operation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“赌上SHO治安管理委员会特殊战斗部，仙波光姫的名字！……大家，暴力是不行的！用不伤害他人的程度——妨碍工程吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「賭上SHO治安管理委員會特殊戰鬥部，仙波光姫的名字！……大家，暴力是不行的！用不傷害他人的程度——妨礙工程吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00417",
		linknext = "0131_00419",
		line = 7339,
	},
	["0131_00419"] = {
		{"fg", mode=-1, id=11, ch="光姫", lv=5, time=1000},
		{"se", id=0, loop=0, file="se_a023"},
		{"bg", id=1, file="bg01_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00103", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="ran_01m_00001", file1="ran_01m_00103", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"fgact", ch="蘭", id=8, act="移動", x=0, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0339", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“To all the resistance fighters— I want you to seize control of the artillery batteries! We, the SS and OSS, will be your vanguard! Together, our combined forces will occupy the inside!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“请那边的反叛者们前去镇压炮台！好好听从我们FS和SHO的命令！我们的队伍会去占领里面！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「請那邊的反叛者們前去鎮壓砲臺！好好聽從我們FS和SHO的命令！我們的隊伍會去佔領裡面！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00418",
		linknext = "0131_00420",
		line = 7359,
	},
	["0131_00420"] = {
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=1000},
		{"bg", id=1, file="bg01_3l_00000", x=0, y=0, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0096", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“Reporting live from the scene. You have just heard and seen the residents opposed to the forceful removal of these facilities.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“……请看，这些是反对强制拆迁设施的居民们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「……請看，這些是反對強制拆遷設施的居民們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00419",
		linknext = "0131_00421",
		line = 7375,
	},
	["0131_00421"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0097", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“This sudden massive protest was sparked by way of an address delivered via online livestream from one Kotoyose Fumino, previously presumed missing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“因为刚才被认为是失踪了的琴寄文乃小姐的网络直播，大家都奋起了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「因為剛才被認為是失踪了的琴寄文乃小姐的網路直播，大家都奮起了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00420",
		linknext = "0131_00422",
		line = 7387,
	},
	["0131_00422"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0098", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“The details from her livestream are greatly at odds with the earlier press conference held by Mr. Sakimori, and it has created a massive online uproar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“现场直播的内容，与政治家防人先生的记者会内容有很大的出入，因此在网络上成为了热门话题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「現場直播的內容，與政治家防人先生的記者會內容有很大的出入，因此在網路上成為了熱門話題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00421",
		linknext = "0131_00423",
		line = 7399,
	},
	["0131_00423"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0099", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“Many netizens and observers are now highly distrusting of Sakimori's words and actions, and accuse him of effectively opting to impose martial law on the island without revealing the true story.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“迄今，对防人先生的单方面决定和言行抱有怀疑态度的人也很多，也有声音表示在实情还没明朗前就发生过多骚动并不合理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「迄今，對防人先生的單方面決定和言行抱有懷疑態度的人也很多，也有聲音表示在實情還沒明朗前就發生過多騷動並不合理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00422",
		linknext = "0131_00424",
		line = 7411,
	},
	["0131_00424"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0100", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“In addition, rumors are now circulating regarding Sakimori's possible connection to organized crime. He seems to be gradually losing more and more credibility with the people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“另外也有传闻说防人先生与黑社会人士有所勾结，这样的质疑不胜枚举。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「另外也有傳聞說防人先生與黑社會人士有所勾結，這樣的質疑不勝枚舉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00423",
		linknext = "0131_00425",
		line = 7423,
	},
	["0131_00425"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0101", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“It is currently late evening, but due to these events, our regular programming is suspended, and we will continue with our live news coverage around the clock... Oh, thank you for the tea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“虽然这里是深夜了，但我们变更了节目，继续进行独家现场直播……啊，麻烦也给我一杯茶，谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「雖然這裡是深夜了，但我們變更了節目，繼續進行獨家現場直播……啊，麻煩也給我一杯茶，謝謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00424",
		linknext = "0131_00426",
		line = 7436,
	},
	["0131_00426"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0069", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Not at all. All people who come to Seiran Island are our guests to be welcomed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“不不，来青蓝岛的人们都是客人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「不不，來青藍島的人們都是客人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00425",
		linknext = "0131_00427",
		line = 7448,
	},
	["0131_00427"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"se", id=0, loop=0, file="se_a204"},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00113", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="防人老人", id=11, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0230", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Grrrrrrgh... Those bloody idiotic plebeians! They would have been better off succumbing to despair...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“可、可恶……！愚蠢的民众们，明明像以前那样绝望就好了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「可、可惡……！愚蠢的民眾們，明明像以前那樣絕望就好了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00426",
		linknext = "0131_00428",
		line = 7470,
	},
	["0131_00428"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Funny how you mention despair, Sakimori. Now do you understand how people behave when they're oppressed so hard they can barely stand? And what happens when they're desperate?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说绝望是吧，防人。你知道抱着绝望、被压迫的民众会怎么行动吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說絕望是吧，防人。你知道抱著絕望、被壓迫的民眾會怎麼行動嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00427",
		linknext = "0131_00429",
		line = 7482,
	},
	["0131_00429"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The more oppressed they are, the more violent they turn when things finally snap.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“越被压迫，爆炸时的威力就越大——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「越被壓迫，爆炸時的威力就越大——」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00428",
		linknext = "0131_00430",
		line = 7494,
	},
	["0131_00430"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All they need is one person to incite them, and it wakes them right up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一旦煽动的人出现，便将一下子爆发！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一旦煽動的人出現，便將一下子爆發！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00429",
		linknext = "0131_00431",
		line = 7506,
	},
	["0131_00431"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You can go on believing that might makes right, but that's not gonna win you any support from them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后过于武断的正义，必定会引起猜疑！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後過於武斷的正義，必定會引起猜疑！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00430",
		linknext = "0131_00432",
		line = 7518,
	},
	["0131_00432"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Everybody knows that life isn't fair! The world can never be perfect!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为大家都知道，这个世界并不是那么的完美！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為大家都知道，這個世界並不是那麼的完美！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00431",
		linknext = "0131_00433",
		line = 7530,
	},
	["0131_00433"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yet at the same time, everybody also wishes for a better, more beautiful world to live in!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“同时——大家果然也都希望，真正的世界是个美丽的地方！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「同時——大家果然也都希望，真正的世界是個美麗的地方！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00432",
		linknext = "0131_00434",
		line = 7542,
	},
	["0131_00434"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00103", file2="sakimori_01m_00202", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="防人老人", id=11, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0231", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“And you used your little tragic heroine as the means to that end? You treacherous dog...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“为此你利用了悲剧的女主角是吗，居然用那种卑鄙手段——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「為此你利用了悲劇的女主角是嗎，居然用那種卑鄙手段——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00433",
		linknext = "0131_00435",
		line = 7557,
	},
	["0131_00435"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00303", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bwahahaha! You think I came all the way here unprepared!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈哈哈哈！你以为我什么准备都没做就来了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈哈哈哈！你以為我什麼準備都沒做就來了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00434",
		linknext = "0131_00436",
		line = 7569,
	},
	["0131_00436"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My mentor's name is Toshihide Teshima! A specialist in controlling people's minds!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我师傅名叫手嶋俊英！是个掌握人心的专家！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我師傅名叫手嶋俊英！是個掌握人心的專家！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00435",
		linknext = "0131_00437",
		line = 7580,
	},
	["0131_00437"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I borrowed his strength, devised a strategy, and just like you, swayed the public's opinion!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我借助了师傅的力量订立作战，就像你一样，让大众成为了我的同伴！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我借助了師傅的力量訂立作戰，就像你一樣，讓大眾成為了我的同伴！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00436",
		linknext = "0131_00438",
		line = 7592,
	},
	["0131_00438"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00113", file2="sakimori_01m_00202", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="防人老人", id=11, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0232", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You... How could you have turned the public in your favor alone!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“年轻人，你以为那种程度就能改变舆论吗——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「年輕人，你以為那種程度就能改變輿論嗎——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00437",
		linknext = "0131_00439",
		line = 7607,
	},
	["0131_00439"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=3, size=5, time=50, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, I can't take the credit for that. But Fumino can!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“改变的不是我，是文乃！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「改變的不是我，是文乃！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00438",
		linknext = "0131_00440",
		line = 7622,
	},
	["0131_00440"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That girl whom you threw aside after she'd served her purpose to you... Her voice set the world in motion!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你认为已经没用而抛弃的小姑娘的声音，改变了世界啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你認為已經沒用而拋棄的小姑娘的聲音，改變了世界啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00439",
		linknext = "0131_00441",
		line = 7633,
	},
	["0131_00441"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She may have some speech difficulty, but she inherited her father's leadership skills, and she used her voice to make a plea for the world she desires...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“尽管那个孩子不善言辞，但还是用从父亲身上继承的领袖力量，以自己的声音阐述自己所希望的世界……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「儘管那個孩子不善言辭，但還是用從父親身上繼承的領袖力量，以自己的聲音闡述自己所希望的世界……」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00440",
		linknext = "0131_00442",
		line = 7645,
	},
	["0131_00442"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And the whole fuckin' nation lent her their ears!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让自己的话语，传遍了全国！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「讓自己的話語，傳遍了全國！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00441",
		linknext = "0131_00443",
		line = 7656,
	},
