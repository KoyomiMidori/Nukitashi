	["0131_00299"] = {
		{"bg", id=1, file="bg27_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1173", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hm, sending in backup, I see. Looks like they're about 30 strong.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，增援吗……大概有30个人吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，增援嗎……大概有30個人吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00298",
		linknext = "0131_00300",
		line = 5383,
	},
	["0131_00300"] = {
		{"fg", file="ikuko_01m_00001", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0654", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Teehee... Seems like a tight spot, even for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵……就算是礼酱，这个数字也很危险吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵……就算是禮醬，這個數字也很危險吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00299",
		linknext = "0131_00301",
		line = 5397,
	},
	["0131_00301"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00116", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1174", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Surely you jest. He left things up to me, so it's my credo to uphold my own end of the bargain.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没那回事……既然被那位拜托了，无论什么事情我都会达成，这就是我的信念。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒那回事……既然被那位拜託了，無論什麼事情我都會達成，這就是我的信念。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00300",
		linknext = "0131_00302",
		line = 5411,
	},
	["0131_00302"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00110", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0655", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oh, don't try to hide it. You're just doing all this for Darling, aren't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“好好好，又再说那种话了，其实全都是为了亲爱的对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「好好好，又再說那種話了，其實全都是為了親愛的對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00301",
		linknext = "0131_00303",
		line = 5426,
	},
	["0131_00303"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1175", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“R-Ridiculous! Why would I do such a thing for that turncoat...!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“说、说什么傻话……！怎么可能是那样的，那样的叛徒……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「說、說什麼傻話……！怎麼可能是那樣的，那樣的叛徒……！」",
					{"rt2"},
				},
			},
		},
