			en = {
				{
					"Taking this many hits, combined with the uphill march, has taken a toll on my stamina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……一边被这么多子弹击中还一边继续在斜坡上前进，体力果然还是太消耗了吗。",
