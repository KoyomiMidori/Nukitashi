		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, mode=3, x=0, y=0},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"se", id=0, loop=0, file="se_a023"},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0895", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Heh heh, who'd have thought I'd be doing this? I never thought of this as something I'd want to be doing... Strange, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……呵呵，没想到我竟然会做这样的事。我还以为自己什么都不想做……真是不可思议啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……呵呵，沒想到我竟然會做這樣的事。我還以為自己什麼都不想做……真是不可思議啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00376",
		linknext = "0131_00378",
		line = 6645,
	},
	["0131_00378"] = {
		{"se", id=0, stop=1, time=5000},
		{"bg", id=18, file="pm3_00001", x=0, y=0, path=":cg/pm3/", ev=1, time=400, lv=5, ax=1250, ay=455, bx=-450, by=-5},
		{"bg", id=1, file="bg28_3_00000", x=0, y=0, path=":bg/", sync=0, ev=1, time=400, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00115", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=400, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0172", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "精鋭警備兵リーダー"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Elite Guard Leader"},
					"“Hey... You seem reasonably capable, but do you really plan to take us all on?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "精锐警备兵队长"},
					"“喂……看来你还有点本事，难道你真的要对付我们吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "精銳警備兵隊長"},
					"「喂……看來你還有點本事，難道你真的要對付我們嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00377",
		linknext = "0131_00379",
		line = 6662,
	},
	["0131_00379"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0173", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "精鋭警備兵リーダー"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Elite Guard Leader"},
					"“One girl with nothing but a mere coin trick up her sleeve has absolutely no chance against us. I'm sure you understand that, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "精锐警备兵队长"},
					"“就凭一位小姑娘，用那种硬币是不可能打败我们队伍的，你应该明白吧——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "精銳警備兵隊長"},
					"「就憑一個小姑娘，用那種硬幣是不可能打敗我們隊伍的，你應該明白吧——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00378",
		linknext = "0131_00380",
		line = 6674,
	},
	["0131_00380"] = {
		{"bgm", file="bgm13.5", vol=100},
		{"se", id=0, loop=0, file="se_b012"},
		{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0896", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, I'm afraid you are mistaken there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，应该没那回事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，應該沒那回事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00379",
		linknext = "0131_00381",
		line = 6691,
	},
	["0131_00381"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3000] = {
				{"se", id=0, loop=0, file="se_b013", delay2=3000},
				{"bg", id=4, file="be4_00006", x=0, y=0, path=":cg/be4/", ev=1, delay2=3000, time=400, rule="eff_008_00000", lv=5, ax=822, ay=465, bx=-22, by=-15},
			},
		},
		text = {
