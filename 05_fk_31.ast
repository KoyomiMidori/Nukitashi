	["0131_00231"] = {
		{"fg", mode=-1, id=30, ch="オーガスト", lv=5},
		{"cgdel", id=2, time=100, alphadel=1, lv=5},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=5, ch="手嶋", lv=5, time=100},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"bgm", file="bgm10", vol=100},
		{"fg", mode=-1, id=30, ch="オーガスト", lv=5},
		{"evset", file="fcg09", set="fcg09", path=":ev/fcg09/"},
		{"evset", file="fcg09_00003", set="fcg09_000", path=":ev/fcg09_000/"},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="fcg09_00003", x=0, y=0, path=":cg/fcg09/", ev=1, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1392", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“First of all, I ask your leniency for how I have come to reveal myself to you all in this way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“首先，请原谅我以这种无礼的形式与各位见面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「首先，請原諒我以這種無禮的形式與各位見面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00230",
		linknext = "0131_00232",
		line = 4137,
	},
	["0131_00232"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1392b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have learned from various television reports that many have been concerned about my disappearance.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我在电视上看到很多人担心我的失踪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我在電視上看到很多人擔心我的失踪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00231",
		linknext = "0131_00233",
		line = 4149,
	},
	["0131_00233"] = {
		{"evset", file="fcg09", set="fcg09", path=":ev/fcg09/"},
		{"evset", file="fcg09_00001", set="fcg09_000", path=":ev/fcg09_000/"},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=400, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="fcg09_00001", x=0, y=0, path=":cg/fcg09/", ev=1, time=400, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1393", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“However, such reports of me are greatly exaggerated. I have simply come back to where I am meant to be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“可是……那是一个很大的错误。因为我只是回到了自己应该呆的地方而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「可是……那是一個很大的錯誤。因為我只是回到了自己應該待的地方而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00232",
		linknext = "0131_00234",
		line = 4168,
	},
	["0131_00234"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1394", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I lived on Seiran Island from a young age, and now I have returned to the one place I was allowed to be before— the point from where one can see a view of the entire island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我从小就是在青蓝岛上长大的。因为我唯一被允许存在的地方，就是能够一览这个岛的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我從小就是在青藍島上長大的。因為我唯一被允許存在的地方，就是能夠一覽這個島的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00233",
		linknext = "0131_00235",
		line = 4180,
	},
	["0131_00235"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="fcg09_00002", x=0, y=0, path=":cg/fcg09/", ev=1, time=400, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1395", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It is from there that I have seen so many things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“在那里，我看到了各式各样的景象。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「在那裡，我看到了各式各樣的景象。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00234",
		linknext = "0131_00236",
		line = 4195,
	},
	["0131_00236"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1395b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Those who celebrate sexual acts normally suppressed. Those who cast off their inhibitions and discover a new side to themselves. Those who come to appreciate the true joy of interpersonal connections.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“讴歌着平时被压抑的性行为的人。从禁欲当中解放自己，发现新的一面的人。享受附带的人际关系的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「謳歌著平時被壓抑的性行為的人。從禁慾當中解放自己，發現新的一面的人。享受附帶的人際關係的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00235",
		linknext = "0131_00237",
		line = 4207,
	},
	["0131_00237"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1396", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“And I could sense that those people... were brimming with true happiness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“每个人——身上都洋溢着幸福。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「每個人——身上都洋溢著幸福。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00236",
		linknext = "0131_00238",
		line = 4219,
	},
