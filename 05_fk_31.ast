	},
	["0131_00387"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0899", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm just glad we're inside a building. Military base defense is my fundamental strength, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……这边是建筑里真是太好了。毕竟我原本的力量，就是用来防守据点的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……這邊是建築裡真是太好了。畢竟我原本的力量，就是用來防守據點的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00386",
		linknext = "0131_00388",
		line = 6806,
	},
	["0131_00388"] = {
		{"text"},
		text = {
			vo = {
