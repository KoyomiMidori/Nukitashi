	["0131_00390"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0900", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“My threads weave a cage of cool spring water, a box in which tension dances in the evening chill.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“纺丝是冷泉之笼。随着紧张舞动的纳凉之盒——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「紡絲是冷泉之籠。隨著緊張舞動的納涼之盒——」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00389",
		linknext = "0131_00391",
		line = 6845,
	},
	["0131_00391"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0901", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Right, now that your limbs are all spread out, would you care to dance with me, if you can?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——来吧，要试试即使肢体四散是否也能跳舞吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——來吧，要試試即使肢體四散是否也能跳舞嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00390",
		linknext = "0131_00392",
		line = 6860,
	},
	["0131_00392"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
