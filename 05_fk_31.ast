			en = {
				{
					name = {"オーガスト", "August"},
					"“Roger. Ogre Ride Protocol enabled. Let us go and make mincemeat out of these cocksucking motherfuckers, mon ami.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "Orgast"},
					"“明白。实行‘Orgaride协议’。把该死的‘鸡巴’们变成‘肉末’献给你吧。亲爱的朋友。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "Orgast"},
					"「明白。實行『Orgaride協議』。把該死的『肉棒』們變成『肉末』獻給你吧。親愛的朋友。」",
					{"rt2"},
				},
			},
		},
