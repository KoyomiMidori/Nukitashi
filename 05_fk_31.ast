			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Let's do this thang! Who wants to get run over? Step forward and I'll GLADLY OBLIGE!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“就这样干掉他们吧！想被踩死的人请往前站啊啊啊啊啊啊啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就這樣幹掉他們吧！想被踩死的人請往前站啊啊啊啊啊啊啊！！」",
					{"rt2"},
				},
