		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgact", file="cgact", id=4, act="stopact", lv=5, x=0, y=0},
		{"cgdel", id=4, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=100},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"cgact", file="cgact", id=1, act="stopact"},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=18, file="fcg09_00002", x=0, y=0, path=":cg/fcg09/", ev=1, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm10", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1404", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You will not find my name in any family registry; this much is true. My complex situation forced me to live as someone I was not.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我确实没有户籍，因为一些复杂的原因，一直以他人的身份生活着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我確實沒有戶籍，因為一些複雜的原因，一直以他人的身份生活著。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00391",
		linknext = "0131_00393",
		line = 6907,
	},
	["0131_00393"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1405", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This brought my mother horrific grief. Even after apologizing to me endlessly, she fell ill and lost her life. In a sense, she was a victim of Seiran Island itself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这件事让我母亲很痛苦。她多次向我道歉，作为某种意义上的青蓝岛受害者，她最终因病去世了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這件事讓我母親很痛苦。她多次向我道歉，作為某種意義上的青藍島受害者，她最終因病去世了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00392",
		linknext = "0131_00394",
		line = 6919,
	},
	["0131_00394"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="fcg09_00005", x=0, y=0, path=":cg/fcg09/", ev=1, time=400, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=400, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1406", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But Mother held grudges for no one. Not those who backed her into a corner to defend the law. And not those who made her a pariah to the outside world. She blamed no one for her lot in life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是，母亲谁也没有责怪。无论是为了保护条例而逼迫母亲的人们。还是从外部批评的人们，她谁也没有责怪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是，母親誰也沒有責怪。無論是為了保護條例而逼迫母親的人們。還是從外部批評的人們，她誰也沒有責怪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00393",
		linknext = "0131_00395",
		line = 6935,
	},
	["0131_00395"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="fcg09_00002", x=0, y=0, path=":cg/fcg09/", ev=1, time=400, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1407", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“And so, I shall blame no one for my own lot in life. I merely wish to be accepting of all human beings. To be the same kind of person Mother was.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以，我也没有责怪任何人的意思。我想原谅所有的人。我想成为母亲那样的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以，我也沒有責怪任何人的意思。我想原諒所有的人。我想成為母親那樣的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00394",
		linknext = "0131_00396",
		line = 6950,
	},
	["0131_00396"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1408", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“And I also wish to find a new road to walk along. Selfish and naive though it may be, that is the world I pray for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“然后，我想要探索新的道路。任性也好，不现实也罢，因为这就是我所追求的世界……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「然後，我想要探索新的道路。任性也好，不現實也罷，因為這就是我所追求的世界……」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00395",
		linknext = "0131_00397",
		line = 6962,
	},
	["0131_00397"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1409", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“There is someone whom I love. And that person has accepted such a way of life. Thus...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是我所爱的人包容了我的生存方式，所以——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是我所愛的人包容了我的生存方式，所以——」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00396",
		linknext = "0131_00398",
		line = 6974,
	},
	["0131_00398"] = {
		{"evset", file="fcg09", set="fcg09", path=":ev/fcg09/"},
		{"evset", file="fcg09_00006", set="fcg09_000", path=":ev/fcg09_000/"},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="fcg09_00006", x=0, y=0, path=":cg/fcg09/", ev=1, time=400, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1410", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It is my wish to live in a world where those who pursue sexual activity and those who avoid it can coexist peacefully.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“——我希望，寻求性行为的人，与避免性行为的人，两者能够共存。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「——我希望，尋求性行為的人，與避免性行為的人，兩者能夠共存。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00397",
		linknext = "0131_00399",
		line = 6992,
	},
	["0131_00399"] = {
		{"bgm", stop=1},
