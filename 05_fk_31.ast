			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“If I'm to be taken down, I shan't go down alone! I need only give the word, and the OSS building shall go up in smoke! Any human casualties will be but sad necessities!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“我本来就打算和你们一起殉情了！只要有我的命令，SHO的大楼就会倒塌！就算出现死者——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「我本來就打算和你們一起殉情了！只要有我的命令，SHO的大樓就會倒塌！就算出現死者——！」",
					{"rt2"},
				},
