		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"se", id=5, loop=1, file="se_d038"},
		{"se", id=0, loop=0, file="se_a261"},
		{"text"},
