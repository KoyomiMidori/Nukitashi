					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. Former SS representative and student council president Reizeiin Touka, at your service. Fancy meeting you again, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。前FS代表兼学生会长，冷泉院桐香……好久不见了，前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。前FS代表兼學生會長，冷泉院桐香……好久不見了，前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00360",
		linknext = "0131_00362",
		line = 6371,
	},
	["0131_00362"] = {
		{"text"},
		text = {
