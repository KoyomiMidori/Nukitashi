			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I don't really enjoy using this, considering I have to give up my favorite stole for it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这样做的话，我喜欢的披肩会掉，所以就没怎么用……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這樣做的話，我喜歡的披肩會掉，所以就沒怎麼用……」",
