		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=1, time=500, x=0, y=0, alphadel=1, style="reset"},
		{"bg", id=18, file="pm3_00001", x=0, y=0, path=":cg/pm3/", ev=1, time=300, lv=5, ax=1250, ay=455, bx=-450, by=-5},
		{"bg", id=1, file="bg29_3l_00000", x=-400, y=0, path=":bg/", sync=0, ev=1, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="sakimori_01l_00001", file1="sakimori_01l_00113", path=":fg/sakimori_01l/", id=11, lv=5, head="sakimori_01l", ch="防人老人", mw="mw", sync=0, time=500, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0238", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Hi...tou...raaaaaa...!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“仁——浦……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「仁——浦……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00479",
		linknext = "0131_00481",
		line = 8396,
	},
	["0131_00481"] = {
		{"cgdel", id=2, time=100, alphadel=1, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mr. Sakimori glares at Hitoura with a diabolical look on his face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随后防人老人以恶鬼般的表情瞪向仁浦先生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨後防人老人以惡鬼般的表情瞪向仁浦先生。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00480",
		linknext = "0131_00482",
		line = 8408,
	},
	["0131_00482"] = {
		{"fg", mode=-1, id=11, ch="防人老人", lv=5, time=400},
		{"bg", id=1, file="bg29_3l_00000", x=400, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="hitoura_01l_00001", file1="hitoura_01l_00104", path=":fg/hitoura_01l/", id=10, lv=5, head="hitoura_01l", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0325", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Pleasure seeing you again, Sakimori. We only ever met once in parliament, if memory serves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“好久不见，防人先生。上次见面是在议会上吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「好久不見，防人先生。上次見面是在議會上吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00481",
		linknext = "0131_00483",
		line = 8425,
	},
	["0131_00483"] = {
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=400},
		{"bg", id=1, file="bg29_3l_00000", x=-400, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="sakimori_01l_00001", file1="sakimori_01l_00103", path=":fg/sakimori_01l/", id=11, lv=5, head="sakimori_01l", ch="防人老人", mw="mw", sync=0, time=500, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0239", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Yes, of course! And after that, I hatched my little plot to string you up and make a spectacle of you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“嗯，是啊……！从那时起，把你血祭的计划就在进行着……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「嗯，是啊……！從那時起，把你血祭的計劃就在進行著……」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00482",
		linknext = "0131_00484",
		line = 8442,
	},
	["0131_00484"] = {
		{"fg", mode=-1, id=11, ch="防人老人", lv=5, time=400},
		{"bg", id=1, file="bg29_3l_00000", x=400, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="hitoura_01l_00001", file1="hitoura_01l_00114", path=":fg/hitoura_01l/", id=10, lv=5, head="hitoura_01l", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0326", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I suppose you really got me there... But I'm here to repay the favor. I'm going to re-establish the former perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“然后我就被你陷害了吗……但是，现在我来拿回属于我的东西了。为了取回以前的变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「然後我就被你陷害了嗎……但是，現在我來拿回屬於我的東西了。為了取回以前的變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00483",
		linknext = "0131_00485",
		line = 8459,
	},
	["0131_00485"] = {
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=400},
		{"bg", id=1, file="bg29_3l_00000", x=0, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="jun_01l_00001", file1="jun_01l_00116", file4="jun_01l_00402", path=":fg/jun_01l/", id=2, lv=5, head="jun_01l", ch="淳之介", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like hell I'll let you do that... You wanna chase after the future? Then you're gonna have to leave the past behind!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我可不允许——如果你想继续往前走的话，就必须把旧的扔掉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我可不允許——如果你想繼續往前走的話，就必須把舊的扔掉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00484",
		linknext = "0131_00486",
		line = 8475,
	},
	["0131_00486"] = {
		{"fg", mode=-1, id=2, ch="淳之介", lv=5, time=400},
		{"bg", id=1, file="bg29_3l_00000", x=400, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="hitoura_01l_00001", file1="hitoura_01l_00104", path=":fg/hitoura_01l/", id=10, lv=5, head="hitoura_01l", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0327", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Coexistence is an impossible pipe dream, Tachibana. The original law is the best option, in purely pragmatic and financial terms.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“共存什么的是不可能的，痴人说梦，橘君。之前的那种形式，才是对金钱和现实方面最好的选择。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「共存什麼的是不可能的，癡人說夢，橘君。之前的那種形式，才是對金錢和現實方面最好的選擇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00485",
		linknext = "0131_00487",
		line = 8492,
	},
	["0131_00487"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=400},
		{"bg", id=1, file="bg29_3l_00000", x=0, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="jun_01l_00001", file1="jun_01l_00128", file2="jun_01l_00202", file4="jun_01l_00402", path=":fg/jun_01l/", id=2, lv=5, head="jun_01l", ch="淳之介", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"fgact", ch="淳之介", id=2, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Spare me your bullshit adult reasoning! All you ever cared about was making money to build up the island, and that fact didn't care about anyone's feelings! Face the music!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"不要拿大人的歪理来说嘴！你必须为建造了一个只靠撒钱成立的岛，而且无视了人们的内心一事悔改！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"不要拿大人的歪理來說嘴！你必須為建造了一個只靠撒錢成立的島，而且無視了人們的內心一事悔改！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00486",
		linknext = "0131_00488",
		line = 8510,
	},
	["0131_00488"] = {
		{"fg", mode=-1, id=2, ch="淳之介", lv=5, time=400},
		{"bg", id=1, file="bg29_3l_00000", x=-400, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="sakimori_01l_00001", file1="sakimori_01l_00103", path=":fg/sakimori_01l/", id=11, lv=5, head="sakimori_01l", ch="防人老人", mw="mw", sync=0, time=500, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0240", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Enough with your bickering! This island is finished! Block my orders if you will, it shall not matter! There's more ways than one to destroy this island!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“别胡说八道！这个岛已经走到尽头了。就算能阻止我的命令也没有意义！摧毁这个岛的方法还有很多呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「別胡說八道！這個島已經走到盡頭了。就算能阻止我的命令也沒有意義！摧毀這個島的方法還有很多呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00487",
		linknext = "0131_00489",
		line = 8527,
	},
	["0131_00489"] = {
		{"cgdel", id=1, time=500, alphadel=1, lv=5},
		{"fg", mode=-1, id=11, ch="防人老人", lv=5, time=500},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=19, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, path=":bg/", sync=0, time=500, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=400, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0328", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I wonder about that myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……是那样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……是那樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00488",
		linknext = "0131_00490",
		line = 8550,
	},
	["0131_00490"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00489",
		linknext = "0131_00491",
		line = 8562,
	},
	["0131_00491"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0329", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Think about it. Sakimori has only so much time left in his aging husk of a body. Why would he come all the way here to see this through?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你想想看，防人先生为什么会拖着年迈的身体来到这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你想想看，防人先生為什麼會拖著年邁的身體來到這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00490",
		linknext = "0131_00492",
		line = 8576,
	},
	["0131_00492"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Doesn't he want to witness the destruction of the OSS firsthand?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为——他想亲眼看到SHO被摧毁吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是因為——他想親眼看到SHO被摧毀吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00491",
		linknext = "0131_00493",
		line = 8588,
	},
	["0131_00493"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0330", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That too. But there is more. He sold out the yakuza on the mainland. And you know how persistent they are. Tracking down a politician, ergo, a public figure, is hardly like searching for a needle in a haystack.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那也有。另外还有一点——他背叛了本岛上的黑社会。他们很执拗，如果是台面上的政治家，很容易就会被他们找到行踪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那也有。另外還有一點——他背叛了本島上的黑社會。他們很執拗，如果是檯面上的政治家，很容易就會被他們找到行踪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00492",
		linknext = "0131_00494",
		line = 8602,
	},
	["0131_00494"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0331", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Which means this is his first, and only, chance. If he fails this time, there won't be a next time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“所以对防人先生来说，这应该是第一次也是最后一次的机会吧。如果这次失败的话，就没有下一次了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「所以對防人先生來說，這應該是第一次也是最後一次的機會吧。如果這次失敗的話，就沒有下一次了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00493",
		linknext = "0131_00495",
		line = 8614,
	},
	["0131_00495"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00110", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="防人老人", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0241", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Then we shall finish it here! I need only give the word to destroy everything you've ever built!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“那我就让这次成功吧！只要一个联络，我就能完全摧毁你建立起的一切——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「那我就讓這次成功吧！只要一個聯絡，我就能完全摧毀你建立起的一切——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00494",
		linknext = "0131_00496",
		line = 8628,
	},
	["0131_00496"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you that bent on revenge, asshole!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你就这么执着于复仇吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你就這麼執著於復仇嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00495",
		linknext = "0131_00497",
		line = 8641,
	},
	["0131_00497"] = {
		{"se", id=0, loop=0, file="se_b029"},
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00103", path=":fg/sakimori_01m/", id=11, lv=5, head="sakimori_01m", ch="防人老人", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0242", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“My revenge is just! Against the bastard who took that girl away from me, I have the right!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“这可是正当的复仇！被夺走女儿的人，就有这种权利！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「這可是正當的復仇！被奪走女兒的人，就有這種權利！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00496",
		linknext = "0131_00498",
		line = 8656,
	},
	["0131_00498"] = {
		{"se", id=1, loop=0, file="se_b057"},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00103", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0332", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The girl was taken from me as well. So I believe I am entitled to my own just revenge!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“女儿被夺走这点我也一样。那么我也有正当的复仇权利吧——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「女兒被奪走這點我也一樣。那麼我也有正當的復仇權利吧——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00497",
		linknext = "0131_00499",
		line = 8672,
	},
	["0131_00499"] = {
