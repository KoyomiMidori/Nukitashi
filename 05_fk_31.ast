					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Is this a private party? Or can I join in as well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我也想参加——可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我也想參加——可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00474",
		linknext = "0131_00476",
		line = 8321,
	},
	["0131_00476"] = {
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Governor Hitoura!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“仁浦、县知事——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「仁浦、縣知事——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00475",
		linknext = "0131_00477",
		line = 8335,
	},
	["0131_00477"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0323", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Do not get the wrong idea, Tachibana. I am not a knight in shining armor here to rescue you. By all accounts, we are enemies.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“别误会了，橘君。我并不是来救你的。我和你原本就是敌人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「別誤會了，橘君。我並不是來救你的。我和你原本就是敵人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00476",
		linknext = "0131_00478",
		line = 8350,
	},
	["0131_00478"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0324", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I am here... to get what I still desire. And that is to fight both of you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我是——为了得到我还想要的东西而来到了这里。也就是说，为了和你——还有那个男人战斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我是——為了得到我還想要的東西而來到了這裡。也就是說，為了和你——還有那個男人戰鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00477",
		linknext = "0131_00479",
		line = 8364,
	},
	["0131_00479"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hitoura glances at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生投去了视线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生投去了視線。",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00478",
		linknext = "0131_00480",
		line = 8374,
	},
	["0131_00480"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=500},
