		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bgm", file="bgm10", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1397", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“On the other hand, I have also met people with no desire for sexual activity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……另一方面，我也遇到了一群不追求性行为的人们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……另一方面，我也遇到了一群不追求性行為的人們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00312",
		linknext = "0131_00314",
		line = 5642,
	},
	["0131_00314"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1398", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“These people abhor procreational actions, and each individual has their own reason for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那些人以各种各样的理由避开性产行为，并对其忌讳厌恶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那些人以各種各樣的理由避開性產行為，並對其忌諱厭惡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00313",
		linknext = "0131_00315",
		line = 5654,
	},
	["0131_00315"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1399", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“A crippling personal complex. Deep emotional trauma. Only being able to love the same sex. Being perceived as unsuitable due to their own physical appearance.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“强烈的自卑感、严重的心理阴影、性对象是同性、因外表因素无法发生性行为——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「強烈的自卑感、嚴重的心理陰影、性對象是同性、因外表因素無法發生性行為——」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00314",
		linknext = "0131_00316",
		line = 5666,
	},
	["0131_00316"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1400", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It is for all those reasons that being coerced into proactive participation in sexual activity has brought them no end of anguish.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“因为这些原因，他们对被强制的积极性行为感到痛苦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「因為這些原因，他們對被強制的積極性行為感到痛苦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00315",
		linknext = "0131_00317",
		line = 5678,
	},
	["0131_00317"] = {
		{"evset", file="fcg09", set="fcg09", path=":ev/fcg09/"},
		{"evset", file="fcg09_00005", set="fcg09_000", path=":ev/fcg09_000/"},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="fcg09_00005", x=0, y=0, path=":cg/fcg09/", ev=1, time=400, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=400, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1401", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Which begs the question— who is in the wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那么，有哪一方是错误的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那麼，有哪一方是錯誤的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00316",
		linknext = "0131_00318",
		line = 5697,
	},
	["0131_00318"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1402", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Is it the mainland, for repressing the desire of the people to engage in sexual acts?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“像本岛那样的压抑性行为是错误的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「像本島那樣的壓抑性行為是錯誤的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00317",
		linknext = "0131_00319",
		line = 5709,
	},
	["0131_00319"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1402b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Or is it Seiran Island, for turning sexual acts into a public spectacle?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“还是像青蓝岛那样的公开性行为是错误的呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「還是像青藍島那樣的公開性行為是錯誤的呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00318",
		linknext = "0131_00320",
		line = 5721,
	},
	["0131_00320"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="fcg09_00001", x=0, y=0, path=":cg/fcg09/", ev=1, time=400, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1403", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I believe... that both those ways of thought can co-exist. Neither is invalid, and both deserve respect.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我认为……双方都应该受到尊重，都应该被允许才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我認為……雙方都應該受到尊重，都應該被允許才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00319",
		linknext = "0131_00321",
