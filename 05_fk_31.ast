	["0131_00185"] = {
		{"fgact", id=6, ch="美岬", act="stopact"},
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00102", file4="misaki_01l_00401", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=140},
		{"fgact", ch="美岬", id=6, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2152", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I ended up wrecking Seiran Mk. II, so I wanted to apologize to you firsthand! But don't worry, I managed to destroy all the cannons!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为我搞坏了青蓝・改，所以来道歉的！不过请放心！炮台都被我破坏了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為我搞壞了青藍・改，所以來道歉的！不過請放心！砲臺都被我破壞了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00184",
		linknext = "0131_00186",
		line = 3166,
	},
	["0131_00186"] = {
		{"fgact", id=2, ch="淳之介", act="stopact"},
		{"fg", file="jun_01l_00001", file1="jun_01l_00112", file2="jun_01l_00202", file4="jun_01l_00402", path=":fg/jun_01l/", id=2, lv=5, head="jun_01l", ch="淳之介", mw="mw", sync=0, time=300, mode=3, x=250, y=0},
