				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Leave it to me! Time for Hotori Misaki to crank it up to 11! Let's do this, August!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“交给我吧！让你见识一下畔美岬的‘鬼冲’吧！要上喽，Orgast酱！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「交給我吧！讓你見識一下畔美岬的『鬼衝』吧！要上嘍，Orgast醬！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00186",
		linknext = "0131_00188",
		line = 3196,
	},
	["0131_00188"] = {
