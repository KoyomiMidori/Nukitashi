		{"fg", file="teshima_01l_00001", file1="teshima_01l_00124", path=":fg/teshima_01l/", id=8, lv=5, head="teshima_01l", ch="手嶋", mw="mw", sync=0, time=1000, mode=3, x=0, y=-200},
