		{"cgact", file="cgact", id=16, act="移動", x=-100, y=0, time=50000, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0234", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Mwahaha! In your dreams, boy! Your enthusiasm matters not! Once the building goes down, it's curtains for you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“哈哈哈，真是乐观的预测啊年轻人！如果大楼没有了，那种热度也会就此消失吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「哈哈哈，真是樂觀的預測啊年輕人！如果大樓沒有了，那種熱度也會就此消失吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0131_00451",
		linknext = "0131_00453",
		line = 7861,
	},
