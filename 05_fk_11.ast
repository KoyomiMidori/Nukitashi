					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“After all, Asa and I know what it's like to be alone. We only had that sibling bond to keep us sane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我和麻沙酱也都曾是一个人。因为我们是兄妹，所以活了下来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我和麻沙醬也都曾是一個人。因為我們是兄妹，所以活了下來……」",
					{"rt2"},
				},
			},
		},
