		text = {
			vo = {
				{"vo", file="hinami2136", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But isn't that in the forest? That's odd. I haven't heard of there being a house there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是，这边是森林里吧……？好奇怪，我没听说过这里有房子哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是，這邊是森林裡吧……？好奇怪，我沒聽說過這裡有房子哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00112",
		linknext = "0111_00114",
		line = 1417,
	},
	["0111_00114"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I told you guys she gives off a rich girl sort of air, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不是说那个孩子看起来很有钱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不是說那個孩子看起來很有錢嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00113",
		linknext = "0111_00115",
		line = 1429,
	},
	["0111_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, wouldn't she be living in a mansion?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以应该是住在宅邸不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以應該是住在宅邸不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00114",
		linknext = "0111_00116",
		line = 1441,
	},
	["0111_00116"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2149", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You're said that a lot, but think about it. She has no living relatives. Mr. Sakimori doesn't provide her with support, either. Isn't that unlikely?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然你经常那样说……但是想想看，那个孩子一直是一个人吧？防人老人也没有金援她，所以那种可能性不高吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然你經常那樣說……但是想想看，那個孩子一直是一個人吧？防人老人也沒有金援她，所以那種可能性不高吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00115",
		linknext = "0111_00117",
		line = 1453,
	},
	["0111_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Really?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是吗……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是嗎……？",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00116",
		linknext = "0111_00118",
		line = 1463,
	},
	["0111_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then why does she have such an expensive kimono?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是她怎么会有好几件那么贵的和服呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是她怎麼會有好幾件那麼貴的和服呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00117",
		linknext = "0111_00119",
		line = 1473,
	},
	["0111_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That reminds me, she said that her home was near the battleground.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，她说过战场遗址离家很近。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，她說過戰場遺址離家很近。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00118",
		linknext = "0111_00120",
		line = 1485,
	},
	["0111_00120"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“On the map, that's probably around here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“用地图来说……大概是这附近吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「用地圖來說……大概是這附近吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00119",
		linknext = "0111_00121",
		line = 1497,
	},
	["0111_00121"] = {
		{"text"},
		delay = {
			[6500] = {
				{"se", id=0, loop=0, file="se_a163", delay2=6500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1615", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"非表示", "麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Asane"},
					"“No, Bro. That's near the Grand Cock Shrine. You can't read maps, your sense of direction sucks. Umm, this is about where we've investigated up to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "麻沙音"},
					"“不哥哥，那里是鸡巴大社附近哦？路痴是看不懂地图的……呃，从调查看来应该是这里吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "麻沙音"},
					"「不哥哥，那裡是肉棒大社附近哦？路痴是看不懂地圖的……呃，從調查看來應該是這裡吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00120",
		linknext = "0111_00122",
		line = 1510,
	},
	["0111_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She points out a location in the forest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱在森林中画出了一个点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬在森林中畫出了一個點。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00121",
		linknext = "0111_00123",
		line = 1520,
	},
	["0111_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The summit that overlooks the sea. Come to think of it, I get the feeling it was there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"能看到海的山顶，这么说来确实是在这里的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"能看到海的山頂，這麼說來確實是在這裡的感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00122",
		linknext = "0111_00124",
		line = 1530,
	},
	["0111_00124"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2002", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, yeah... I think Old Man Kenzou said something about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊——话说……健藏爷爷好像有这么说过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊——話說……健藏爺爺好像有這麼說過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00123",
		linknext = "0111_00125",
		line = 1542,
	},
	["0111_00125"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2003", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“This island was something like the last line of defense. There are a lot of ruins from the old Japanese imperial army.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“他说这个岛好像曾经是最终防卫线，所以留下了很多旧日本军使用过的战争遗址……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「他說這個島好像曾經是最終防衛線，所以留下了很多舊日本軍使用過的戰爭遺址……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00124",
		linknext = "0111_00126",
		line = 1554,
	},
	["0111_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I glare at the hillside and battleground locations.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我注视着战场遗址和她被发现的山之手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我注視著戰場遺址和她被發現的山之手。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00125",
		linknext = "0111_00127",
		line = 1564,
	},
	["0111_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I happen to find a clearing there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后偶然发现了一个空出的空间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後偶然發現了一個空出的空間。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00126",
		linknext = "0111_00128",
		line = 1574,
	},
	["0111_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Say, what's this space below the battle location?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂，战场遗址下面的这个空间是——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂，戰場遺址下面的這個空間是——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00127",
		linknext = "0111_00129",
		line = 1586,
	},
	["0111_00129"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I squint and see what's written there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仔细一看，上头写着——",
					{"rt2"},
				},
			},
			tw = {
				{
					"仔細一看，上頭寫著——",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00128",
		linknext = "0111_00130",
		line = 1597,
	},
	["0111_00130"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A shrine?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——神社？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——神社？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00129",
		linknext = "0111_00131",
		line = 1609,
	},
	["0111_00131"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But the Grand Cock Shrine's over here, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说到神社，鸡巴大社是在这边对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說到神社，肉棒大社是在這邊對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00130",
		linknext = "0111_00132",
		line = 1621,
	},
	["0111_00132"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2137", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I seem to remember the old shrine was here... it was called Sengu, or something? I heard about it when they built the new Grand Cock Shrine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃……好像听说这里本来有个古老的神社，后来迁宫时才新建了鸡巴大社？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃……好像聽說這裡本來有個古老的神社，後來遷宮時才新建了肉棒大社？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00131",
		linknext = "0111_00133",
		line = 1633,
	},
	["0111_00133"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So does that mean this was where the original shrine's building was?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，这里是用旧了的本来的正殿吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，這裡是用舊了的本來的正殿嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00132",
		linknext = "0111_00134",
		line = 1645,
	},
	["0111_00134"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2004", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah. The Shinto priest who was there for generations died a long time ago. The Association of Shinto Shrines declared that the Grand Cock Shrine would be the main shrine, since it was bigger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊。世代相传的宫司很早之前就去世了，属于神社本厅的鸡巴大社规模也很大，所以那边就变成主要的了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊。世代相傳的宮司很早之前就去世了，屬於神社本廳的肉棒大社規模也很大，所以那邊就變成主要的了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00133",
		linknext = "0111_00135",
		line = 1657,
	},
	["0111_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So it's actually a shrine ruin, to put it correctly. I think we've drifted off the topic a bit, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，这里准确来说应该是神社遗址吧。不过总觉得好像几乎没有人说过这件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，這裡準確來說應該是神社遺址吧。不過總覺得好像幾乎沒有人說過這件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00134",
		linknext = "0111_00136",
		line = 1669,
	},
	["0111_00136"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2005", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's near the summit, and at the top of a few hundred steps' climb, so people rarely visit there. No one besides the old folks even know about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为离山顶很近，还要爬一百多阶楼梯，所以很少人去吧……不是老人的话几乎不会知道……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為離山頂很近，還要爬一百多階樓梯，所以很少人去吧……不是老人的話幾乎不會知道……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00135",
		linknext = "0111_00137",
		line = 1681,
	},
	["0111_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori's detailed explanation just goes in one ear and out the other.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔的详细说明，朦朦胧胧地从左耳进右耳出。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔的詳細說明，朦朦朧朧地從左耳進右耳出。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00136",
		linknext = "0111_00138",
		line = 1691,
	},
	["0111_00138"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just stare at the point on the map and murmur to myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我只是一边看着地图上的那个地点，一边小声碎念。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我只是一邊看著地圖上的那個地點，一邊小聲碎念。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00137",
		linknext = "0111_00139",
		line = 1702,
	},
	["0111_00139"] = {
