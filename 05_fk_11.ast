	["0111_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure she doesn't understand what I mean. Most likely, she cannot.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也对，这对她本人来说可能连意思都不明白，也无法理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也對，這對她本人來說可能連意思都不明白，也無法理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00248",
