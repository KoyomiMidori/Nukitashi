				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa ingratiatingly borrows Nanase's tablet and mirrors its display for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱一边弯着腰走进来，一边借用奈奈濑的平板进行投影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬一邊彎著腰走進來，一邊借用奈奈瀨的平板進行投影。",
