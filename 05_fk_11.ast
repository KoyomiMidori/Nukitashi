	["0111_00010"] = {
		{"se", id=0, loop=0, file="se_a163"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Looking over the incredibly formally written document...",
					{"rt2"},
				},
			},
			cn = {
				{
					"简单描述一下这篇写得很有格调且生硬的文章的话……",
					{"rt2"},
				},
			},
			tw = {
				{
					"簡單描述一下這篇寫得很有格調且生硬的文章的話……",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00009",
		linknext = "0111_00011",
		line = 137,
	},
	["0111_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It says something to the effect of Seiran Island being a smokescreen for a hotbed of crime and how its activities must be stopped at once, etc., etc., etc.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文中写道“青蓝岛是犯罪的温床和掩护，因此应该立即停止活动”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文中寫道「青藍島是犯罪的溫床和掩護，因此應該立即停止活動」。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00010",
		linknext = "0111_00012",
		line = 147,
	},
	["0111_00012"] = {
		{"fgact", ch="麻沙音", id=3, act="移動", x=-400, y=0, time=800},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh, pretty savage. So how's Hitoura dealt with stuff like this in the past?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，说的不错嘛。以前也发生过这样的事情吧，仁浦先生都在干什么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，說的不錯嘛。以前也發生過這樣的事情吧，仁浦先生都在幹什麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00011",
		linknext = "0111_00013",
		line = 160,
	},
	["0111_00013"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1998", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Basically, he buys out the politicians and government officials... And I think he bribes the media to be less vicious about him, too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好像基本上是通过收买政治家和官员之类的手段……除此之外，好像还会花钱塑造在媒体上的印象……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好像基本上是通過收買政治家和官員之類的手段……除此之外，好像還會花錢塑造在媒體上的印象……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00012",
		linknext = "0111_00014",
		line = 175,
	},
	["0111_00014"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So if the OSS is slow to move, that must mean the top brass is busy mopping up the mess.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO的动作会有些缓慢，也是因为最上层要先处理这些事吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO的動作會有些緩慢，也是因為最上層要先處理這些事嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00013",
		linknext = "0111_00015",
		line = 191,
	},
	["0111_00015"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, all that's made it a lot more difficult for us to make a move. Thanks a lot, fatcats.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——多亏了他们，我们才会变得更容易行动。谢谢了官员们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——多虧了他們，我們才會變得更容易行動。謝謝了官員們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00014",
