	["0111_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hadn't forgotten that I've got a terrible sense of direction this time, so I've left the destination to Asa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为这次没有忘了自己是路痴，所以有让麻沙酱设定好地点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為這次沒有忘了自己是路痴，所以有讓麻沙醬設定好地點。",
					{"rt2"},
				},
			},
