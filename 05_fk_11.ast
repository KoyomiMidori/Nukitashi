		line = 4207,
	},
	["0111_00335"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0614", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“These eagle eyes I am gifted with— I shall utilize them to protect you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我的瞳孔，我丰玉的保佑，将为您存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我的瞳孔，我豐玉的保佑，將為您存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00334",
		linknext = "0111_00336",
		line = 4220,
	},
	["0111_00336"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0615", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I pledge myself to you from the bottom of my heart.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“从今以后，琴寄文乃发誓将打从心底效忠您……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「從今以後，琴寄文乃發誓將打從心底效忠您……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00335",
		linknext = "0111_00337",
		line = 4235,
	},
	["0111_00337"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0616", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“By way of compensation... please feel free to use me... however you desire.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不管怎么样，请……自由使用我吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不管怎麼樣，請……自由使用我吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00336",
		linknext = "0111_00338",
		line = 4247,
	},
	["0111_00338"] = {
