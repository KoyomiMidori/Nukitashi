					name = {"淳之介", "Junnosuke"},
					"“If you still want to fight, let us help you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你还是想战斗的话，就让我们也来帮忙吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你還是想戰鬥的話，就讓我們也來幫忙吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00231",
		linknext = "0111_00233",
		line = 2988,
	},
	["0111_00233"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And that's not all. If you're out to crush the law, let us help with that too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不只是这样。如果想破坏条例的话，我们也会帮忙的。让我们帮忙吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不只是這樣。如果想破壞條例的話，我們也會幫忙的。讓我們幫忙吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00232",
		linknext = "0111_00234",
		line = 3000,
	},
	["0111_00234"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0594", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm terribly sorry, but I must refuse.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“对不起，我拒绝。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「對不起，我拒絕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00233",
		linknext = "0111_00235",
		line = 3018,
	},
	["0111_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She slips away from me, and shakes her head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从我身边溜过去的她，还是摇了摇头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從我身邊溜過去的她，還是搖了搖頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00234",
		linknext = "0111_00236",
		line = 3028,
	},
	["0111_00236"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼？」",
					{"rt2"},
				},
			},
