		linkback = "0111_00256",
		linknext = "0111_00258",
		line = 3310,
	},
	["0111_00258"] = {
		{"bgm", file="bgm10", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Your father's law is clearly in the wrong!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你父亲创造的变态条例确实是错的——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你父親創造的變態條例確實是錯的——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00257",
		linknext = "0111_00259",
		line = 3323,
	},
	["0111_00259"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And it has brought us suffering!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有我们也一直都很痛苦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有我們也一直都很痛苦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00258",
		linknext = "0111_00260",
		line = 3335,
	},
	["0111_00260"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pathetic. Absolutely pathetic.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……她很可怜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……她很可憐。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00259",
		linknext = "0111_00261",
		line = 3345,
	},
	["0111_00261"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But why the fuck does his daughter have to be the one to atone for that? Huh!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，他的女儿有什么理由需要为此赎罪呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，他的女兒有什麼理由需要為此贖罪呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00260",
		linknext = "0111_00262",
		line = 3357,
	},
	["0111_00262"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you have ANY good reason to be apologizing to me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你为什么要向我道歉呢——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你為什麼要向我道歉呢——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00261",
		linknext = "0111_00263",
		line = 3369,
	},
	["0111_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's perpetually trying to atone for what she sees as her own sins.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被囚禁在自己的罪里，不断地赎罪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被囚禁在自己的罪裡，不斷地贖罪。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00262",
		linknext = "0111_00264",
		line = 3379,
	},
	["0111_00264"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why do you think it's just the right course of action to fight all on your own!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么理所当然地认为要一个人战斗——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼理所當然地認為要一個人戰鬥——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00263",
		linknext = "0111_00265",
		line = 3391,
	},
	["0111_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn't even think of her own unfortunate circumstances as unfortunate, and only thinks of atonement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不认为自己不幸的处境是不幸，一心只想着赎罪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不認為自己不幸的處境是不幸，一心只想著贖罪。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00264",
		linknext = "0111_00266",
		line = 3401,
	},
	["0111_00266"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why can't you understand that!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么你无法理解这件事！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼你無法理解這件事！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00265",
		linknext = "0111_00267",
		line = 3413,
	},
	["0111_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's nothing else I can feel for her tragic circumstances but sheer, unbridled pity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这件事本身就非常不幸，我打从心底觉得她很可怜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這件事本身就非常不幸，我打從心底覺得她很可憐。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00266",
		linknext = "0111_00268",
		line = 3423,
	},
	["0111_00268"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You think it's just the right course of action for you to have to fight, to be constantly hurt, and under the threat of death? Well, I say you're delusional!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“带着大大的伤口和淤青战斗，并觉得那对自己来说是理所当然的事，怎么能有那样病态的想法！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「帶著大大的傷口和淤青戰鬥，並覺得那對自己來說是理所當然的事，怎麼能有那樣病態的想法！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00267",
		linknext = "0111_00269",
		line = 3435,
	},
	["0111_00269"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg29_3l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00109", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Listen up, Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“———听好了，文乃！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「———聽好了，文乃！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00268",
		linknext = "0111_00270",
		line = 3454,
	},
	["0111_00270"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you won't allow yourself to rely on another...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你自己如果不原谅自己去依靠其他人的话！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你自己如果不原諒自己去依靠其他人的話！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00269",
		linknext = "0111_00271",
		line = 3466,
	},
	["0111_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To think she doesn't know how to accept a helping hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然连他人伸出援手的时候，都不知道要去抓住。",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然連他人伸出援手的時候，都不知道要去抓住。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00270",
		linknext = "0111_00272",
		line = 3476,
	},
	["0111_00272"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then no one else can force you to accept their help!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就谁也原谅不了你啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就誰也原諒不了你啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00271",
		linknext = "0111_00273",
		line = 3488,
	},
	["0111_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't want to think it's okay to let her be like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不希望她认为自己这样就可以了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不希望她認為自己這樣就可以了。",
					{"rt2"},
				},
