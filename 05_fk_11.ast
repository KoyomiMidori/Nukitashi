ast = {
	["0111_00001"] = {
		{"fg", mode=-1, id=30},
		{"savetitle", text="孤独心中", ja="孤独心中", en="Lonely Hearts", cn="孤独内心", tw="孤獨內心"},
		{"eval", exp="g.05_fk_11=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"bgm", file="bgm07", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For the next few days, Seiran Island was rocked by the news of the illegal sex industry's discovery.",
					{"rt2"},
				},
			},
			cn = {
				{
					"此后的几天里，青蓝岛因地下风俗事件被暴露而人心惶惶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"此後的幾天裡，青藍島因地下風俗事件被暴露而人心惶惶。",
					{"rt2"},
				},
			},
		},
		linknext = "0111_00002",
		line = 19,
	},
	["0111_00002"] = {
		{"se", id=1, loop=0, file="se_a163"},
		{"se", id=0, loop=0, file="se_a123"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, no surprises here. The public was bound to come down on this shit hard.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到底还是没能避开舆论的批评啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到底還是沒能避開輿論的批評啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00001",
		linknext = "0111_00003",
		line = 33,
	},
	["0111_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I scan over the news on my tablet and put my hand to my chin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边用平板浏览新闻网站，一边用手摸着下巴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊用平板瀏覽新聞網站，一邊用手摸著下巴。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00002",
		linknext = "0111_00004",
		line = 43,
	},
	["0111_00004"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00110", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1613", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I mean, yeah. This island's already walking on eggshells. If they find a hidden prostitution ring, of course they're gonna suspect direct involvement.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是啊……本来就有可疑之处，如果真的在看不见的地方有着性交易，会被怀疑和岛上有关也是理所当然的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是啊……本來就有可疑之處，如果真的在看不見的地方有著性交易，會被懷疑和島上有關也是理所當然的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00003",
		linknext = "0111_00005",
		line = 58,
	},
	["0111_00005"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1997", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“At any rate, the governor has consistently denied any direct involvement. Looks like once the news dies down, it'll just end up being written off with all the other criticism of this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“县知事似乎一贯坚持与岛无关……如果继续这样下去，我想会像往常的青蓝岛批判一样快速冷下来的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「縣知事似乎一貫堅持與島無關……如果繼續這樣下去，我想會像往常的青藍島批判一樣快速冷下來的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00004",
		linknext = "0111_00006",
		line = 72,
	},
	["0111_00006"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[6500] = {
				{"se", id=0, loop=0, file="se_a094", delay2=6500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2144", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But that one politician guy, can't remember his name... He's always criticizing the island, and he had particularly scathing words about it this time around. Look.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是你看，这到底是谁来着……一直批评青蓝岛的政治家，他这次又写了一篇强烈的批评文章。你看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是你看，這到底是誰來著……一直批評青藍島的政治家，他這次又寫了一篇強烈的批評文章。你看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00005",
		linknext = "0111_00007",
		line = 87,
	},
	["0111_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, I can't really read it on there. Can you put it up on the main screen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看不清楚，把它放在中央显示器上吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看不清楚，把它放在中央顯示器上吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00006",
		linknext = "0111_00008",
		line = 99,
	},
	["0111_00008"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
