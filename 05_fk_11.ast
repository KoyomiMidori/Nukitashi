			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You're right. He was all hung up on crushing the law before now, but his priorities have changed a little.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“的确……之前是个‘一定要摧毁条例人’，但是现在优先度好像有点不一样了……为什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「的確……之前是個『一定要摧毀條例人』，但是現在優先度好像有點不一樣了……為什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00086",
		linknext = "0111_00088",
		line = 1082,
	},
	["0111_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
