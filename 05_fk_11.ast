	},
	["0111_00320"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0610", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“All I need do is take your hand...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我只是、不知道要握住这个……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我只是、不知道要握住這個……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00319",
		linknext = "0111_00321",
		line = 4034,
	},
	["0111_00321"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0610b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“And yet... perhaps I had no idea... I could allow myself to...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“只是不知道……要原谅自己、是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「只是不知道……要原諒自己、是嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00320",
		linknext = "0111_00322",
		line = 4046,
	},
	["0111_00322"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I nod.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00321",
		linknext = "0111_00323",
		line = 4056,
	},
	["0111_00323"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's not your fault.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，那不是你的错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，那不是你的錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00322",
		linknext = "0111_00324",
		line = 4068,
	},
	["0111_00324"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You've been all alone for so long, you had nobody to tell you that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你一直是一个人，所以谁也没告诉你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你一直是一個人，所以誰也沒告訴你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00323",
		linknext = "0111_00325",
		line = 4080,
	},
	["0111_00325"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My companions helped me realize that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也是从同伴那里学来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也是從同伴那裡學來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00324",
		linknext = "0111_00326",
		line = 4092,
	},
	["0111_00326"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So let's get things started now. For both you, and for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，从现在开始吧。为了文乃，也为了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，從現在開始吧。為了文乃，也為了我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00325",
		linknext = "0111_00327",
		line = 4104,
	},
	["0111_00327"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks at me with those peculiar eyes, her expression unchanging.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃用那双不可思议的眼睛面不改色地凝视着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃用那雙不可思議的眼睛面不改色地凝視著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00326",
		linknext = "0111_00328",
		line = 4116,
	},
	["0111_00328"] = {
