					{"rt2"},
				},
			},
		},
		linkback = "0111_00168",
		linknext = "0111_00170",
		line = 2223,
	},
	["0111_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hardly says anything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她几乎没说什么话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她幾乎沒說什麼話。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00169",
		linknext = "0111_00171",
		line = 2233,
	},
	["0111_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She keeps her mouth shut, occasionally glancing at me, but just waiting, with that emotionless visage of hers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她只是静静地不时窥探着我的样子，并且一如往常地面无表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她只是靜靜地不時窺探著我的樣子，並且一如往常地面無表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00170",
		linknext = "0111_00172",
		line = 2243,
	},
	["0111_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I practically can't read what she's feeling at all from her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我几乎读不懂她的情绪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我幾乎讀不懂她的情緒。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00171",
		linknext = "0111_00173",
		line = 2253,
	},
	["0111_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nonetheless, I can just barely make out some of the inner workings of her heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是即便如此，还是能感觉到她心中有些感情的波动——现在的我是明白的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是即便如此，還是能感覺到她心中有些感情的波動——現在的我是明白的。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00172",
		linknext = "0111_00174",
		line = 2263,
	},
	["0111_00174"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Man, I never thought you'd be living like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没想到你会住在那种地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒想到你會住在那種地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00173",
		linknext = "0111_00175",
		line = 2275,
	},
	["0111_00175"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0577", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00174",
		linknext = "0111_00176",
		line = 2289,
	},
	["0111_00176"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I could have sworn you'd be some kinda bougie girl living in a swanky mansion, based on your conduct, and that kimono you wear.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看你的动作还有和服，我还以为你是住在宅邸里的有钱大小姐呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看你的動作還有和服，我還以為你是住在宅邸裡的有錢大小姐呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00175",
		linknext = "0111_00177",
		line = 2301,
	},
	["0111_00177"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0578", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Is that so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00176",
		linknext = "0111_00178",
		line = 2315,
	},
	["0111_00178"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don't even have anywhere to bathe out here. What do you do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是那里连热水都烧不了吧，都是怎么过的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是那裡連熱水都燒不了吧，都是怎麼過的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00177",
		linknext = "0111_00179",
		line = 2327,
	},
	["0111_00179"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", file2="fumino_02m_00201", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0579", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I occasionally... use the school facilities.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……偶尔会……利用一下学校的设施。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……偶爾會……利用一下學校的設施。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00178",
		linknext = "0111_00180",
		line = 2341,
	},
	["0111_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She blushes slightly for some reason.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知为什么，她的脸颊微微染上了颜色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知為什麼，她的臉頰微微染上了顏色。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00179",
		linknext = "0111_00181",
		line = 2351,
	},
	["0111_00181"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……为什么会在那种地方？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……為什麼會在那種地方？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00180",
		linknext = "0111_00182",
		line = 2363,
	},
	["0111_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not normal for people to live in a run-down old shrine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"废弃的神社，通常不是人能居住的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"廢棄的神社，通常不是人能居住的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00181",
		linknext = "0111_00183",
		line = 2373,
	},
	["0111_00183"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00111", file2="fumino_02m_00202", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hesitates.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她犹豫了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她猶豫了。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00182",
		linknext = "0111_00184",
		line = 2385,
	},
	["0111_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she does respond.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，她一定会告诉我的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，她一定會告訴我的。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00183",
		linknext = "0111_00185",
		line = 2395,
	},
	["0111_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fukiko', after all, is a girl who can't tell lies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为",
					{"ruby", text="・・"},
					"吹子",
					{"/ruby"},
					"的性格是不会撒谎的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為",
					{"ruby", text="・・"},
					"吹子",
					{"/ruby"},
					"的性格是不會撒謊的。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00184",
		linknext = "0111_00186",
		line = 2405,
	},
	["0111_00186"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0580", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I lived here with my mother, when she was still alive. The priest told us it would be an ideal hideout.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我母亲在世时就一直生活在那里……因为宫司大人的厚意，说可以在那里隐居……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我母親在世時就一直生活在那裡……因為宮司大人的厚意，說可以在那裡隱居……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00185",
		linknext = "0111_00187",
		line = 2420,
	},
	["0111_00187"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0581", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“He had friends in very high places... He managed to forge a birth certificate and identity for me in the birth registry... And countless more things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“还有……因为宫司大人的人脉很广……也为我准备了假的户籍……还有其他的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「還有……因為宮司大人的人脈很廣……也為我準備了假的戶籍……還有其他的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00186",
		linknext = "0111_00188",
		line = 2434,
	},
	["0111_00188"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All so you could attend school as a boy? That's pretty wild.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是为了作为男人去学校上学吗……真是太乱来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是為了作為男人去學校上學嗎……真是太亂來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00187",
		linknext = "0111_00189",
		line = 2446,
	},
	["0111_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, he must have been a nice person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，那个人一定是个好人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，那個人一定是個好人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00188",
		linknext = "0111_00190",
		line = 2458,
	},
	["0111_00190"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0582", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Thanks to him, I have been able to survive up to this point... Though, I am now completely alone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“多亏了他，我才能活到现在……虽然现在只剩我一个人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「多虧了他，我才能活到現在……雖然現在只剩我一個人……」",
					{"rt2"},
				},
