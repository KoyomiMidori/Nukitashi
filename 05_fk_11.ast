	["0111_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've got a fleshlight, rations just in case, and a weapon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"拿着手电筒和以防万一的携带食品，然后带着一套武器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"拿著手電筒和以防萬一的攜帶食品，然後帶著一套武器。",
