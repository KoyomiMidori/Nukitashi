			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“The origin of the problem is the law that my father created... Therefore, as his daughter, I must resolve it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“事情的起因是、我父亲的条例……那么，作为女儿的我，就必须解决……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「事情的起因是、我父親的條例……那麼，作為女兒的我，就必須解決……」",
					{"rt2"},
				},
			},
		},
