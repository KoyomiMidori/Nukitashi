					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And constant loneliness is something that will eat away at you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但一直孤单一人的话……是的，就如渡酱所说的，是种毒啊。”",
