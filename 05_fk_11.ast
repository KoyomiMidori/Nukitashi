	},
	["0111_00332"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0612", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Thank you, Tachibana... You have saved me twice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“谢谢您，橘大人……您、救了我",
					{"ruby", text="・・"},
					"两次",
					{"/ruby"},
					"……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「謝謝您，橘大人……您、救了我",
					{"ruby", text="・・"},
					"兩次",
					{"/ruby"},
					"……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00331",
		linknext = "0111_00333",
		line = 4183,
	},
	["0111_00333"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0613", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Not just in body, but in soul as well... I am eternally grateful to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不仅是我的身体，连心都……这件事，我必须下跪深表谢意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不僅是我的身體，連心都……這件事，我必須下跪深表謝意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00332",
		linknext = "0111_00334",
		line = 4195,
	},
	["0111_00334"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, you really don't need to be so—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不需要真的下跪啦——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
