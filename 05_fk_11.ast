	["0111_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I also feel...",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有，绝对不想让她感到寂寞——",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有，絕對不想讓她感到寂寞——",
