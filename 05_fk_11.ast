		linkback = "0111_00329",
		linknext = "0111_00331",
		line = 4155,
	},
	["0111_00331"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Wait, what're you—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶？等……文乃……！？”",
					{"rt2"},
