	["0111_00257"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00109", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
