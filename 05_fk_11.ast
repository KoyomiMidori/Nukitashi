		},
		linkback = "0111_00299",
		linknext = "0111_00301",
		line = 3806,
	},
	["0111_00301"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0608", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fumino"},
					"“Me...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "文乃"},
					"“……我？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "文乃"},
					"「……我？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00300",
		linknext = "0111_00302",
		line = 3818,
	},
	["0111_00302"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You feel a sense of responsibility due to the law your father created, and you're suffering and fighting for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你因为对自己父亲创造的错误的条例感到责任，而痛苦地战斗至今。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你因為對自己父親創造的錯誤的條例感到責任，而痛苦地戰鬥至今。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00301",
		linknext = "0111_00303",
		line = 3830,
	},
	["0111_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And so...",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00302",
		linknext = "0111_00304",
		line = 3840,
	},
	["0111_00304"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I want to save everyone suffering at the hands of that law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我想要拯救所有因为变态条例而痛苦的人们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我想要拯救所有因為變態條例而痛苦的人們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00303",
		linknext = "0111_00305",
		line = 3852,
	},
	["0111_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like when I was looking out solely for my sister.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像我会最先考虑妹妹的安全一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像我會最先考慮妹妹的安全一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00304",
		linknext = "0111_00306",
		line = 3862,
	},
	["0111_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like when I assembled my companions under one roof.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像我把同伴集中到一起一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像我把同伴集中到一起一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00305",
		linknext = "0111_00307",
		line = 3872,
	},
	["0111_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to save everyone for whom the law has been a source of distress.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想要拯救所有因为这个条例而忧郁的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想要拯救所有因為這個條例而憂鬱的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00306",
		linknext = "0111_00308",
		line = 3882,
	},
	["0111_00308"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I couldn't save her myself... the least I can do is atone for it. Right here, right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——作为无法拯救那个人的补偿。现在，我要在这里拯救大家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——作為無法拯救那個人的補償。現在，我要在這裡拯救大家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00307",
		linknext = "0111_00309",
		line = 3894,
	},
	["0111_00309"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
