				{"vo", file="fumino0596", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I cannot allow you to help me... when you must help yourselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“既然如此……我实在不能再借用……大家的力量……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「既然如此……我實在不能再借用……大家的力量……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00239",
		linknext = "0111_00241",
		line = 3089,
	},
	["0111_00241"] = {
		{"text"},
		text = {
