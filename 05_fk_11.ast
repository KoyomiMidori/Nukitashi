		linkback = "0111_00296",
		linknext = "0111_00298",
		line = 3772,
	},
	["0111_00298"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was the perverted sex law that killed her. She was a casualty of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她是被变态条例所杀害的受害者。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她是被變態條例所殺害的受害者。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00297",
		linknext = "0111_00299",
		line = 3784,
	},
	["0111_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That I mustn't allow her to face any more horrors.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我打从心底这么想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我打從心底這麼想。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00298",
		linknext = "0111_00300",
		line = 3794,
	},
	["0111_00300"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And you... You're the same.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而——你也一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而——你也一樣。」",
					{"rt2"},
				},
