		linkback = "0111_00084",
		linknext = "0111_00086",
		line = 1055,
	},
	["0111_00086"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2001", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, I'm sure that's part of it, but... he seems a lot more enthusiastic... Like, almost too much so, if I can say that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“虽然当然是这样……不过我也觉得现在的橘同学是前所未有的认真……有点过于血气方刚了呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「雖然當然是這樣……不過我也覺得現在的橘同學是前所未有的認真……有點過於血氣方剛了呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00085",
		linknext = "0111_00087",
		line = 1069,
	},
	["0111_00087"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00101", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
