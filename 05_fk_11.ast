	["0111_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After about half an hour, lactic acid builds up in my thighs. I turn around and see I'm frighteningly high up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当大腿上累积了几十分钟的乳酸，我回头一看，发现自己已经到达了非常可怕的高度。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當大腿上累積了幾十分鐘的乳酸，我回頭一看，發現自己已經到達了非常可怕的高度。",
					{"rt2"},
