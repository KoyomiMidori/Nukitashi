		linkback = "0111_00235",
		linknext = "0111_00237",
		line = 3040,
	},
	["0111_00237"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's clearly a shadow over her emotionless expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她面无表情的脸上明显出现了阴影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她面無表情的臉上明顯出現了陰影。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00236",
		linknext = "0111_00238",
		line = 3053,
	},
	["0111_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes are darting every which way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的视线明显动摇了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的視線明顯動搖了。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00237",
		linknext = "0111_00239",
		line = 3063,
	},
	["0111_00239"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0595", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I heard that you... and everyone else... you have all been suffering for a long time as a result of my father's law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“橘大人……我听您说、大家因为父亲的条例……痛苦了很长的时间……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「橘大人……我聽您說、大家因為父親的條例……痛苦了很長的時間……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00238",
		linknext = "0111_00240",
		line = 3075,
	},
	["0111_00240"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
