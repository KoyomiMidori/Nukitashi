		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=2, file="bg12_1l_00000", x=300, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"bgm", file="bgm12", vol=100},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0121", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“What is your progress?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00017",
		linknext = "0111_00019",
		line = 244,
	},
	["0111_00019"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Who should call up but our sponsor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"出资的老人接通了通讯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"出資的老人接通了通訊。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00018",
		linknext = "0111_00020",
		line = 255,
	},
	["0111_00020"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0122", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“I have received word from a certain source. The OSS have quelled the disorder on the island, and are about to resume their search for Fumino in earnest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“我从一个消息灵通的人士那里得到了消息，说SHO在解决目前的青蓝岛舆论后，会马上正式开始寻找文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「我從一個消息靈通的人士那裡得到了消息，說SHO在解決目前的青藍島輿論後，會馬上正式開始尋找文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00019",
		linknext = "0111_00021",
		line = 268,
	},
	["0111_00021"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0123", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Up until now, they have been dealing with the chivalrous organization in tandem. Now, they will be devoting all their resources to looking for her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“到目前为止，SHO同时开展了摧毁侠义组织和搜索文乃的工作。这次如果把全部精力全都集中在搜索文乃上的话——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「到目前為止，SHO同時開展了摧毀俠義組織和搜索文乃的工作。這次如果把全部精力全都集中在搜索文乃上的話——」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00020",
		linknext = "0111_00022",
		line = 281,
	},
	["0111_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And with them being able to focus more resources where it counts, it should be easier for them to find Fumino in the field.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人手充分。在野外的“文乃”应该很容易被发现吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人手充分。在野外的「文乃」應該很容易被發現吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00021",
		linknext = "0111_00023",
		line = 291,
	},
	["0111_00023"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0124", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“With that said... Knowing that the organization's leader has escaped is an unexpected stroke of luck for us, one could say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“话虽如此——有关黑社会老大逃走一事，对我们来说也是一种侥幸吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「話雖如此——有關黑社會老大逃走一事，對我們來說也是一種僥倖吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00022",
		linknext = "0111_00024",
		line = 304,
	},
	["0111_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait a minute. Why are there still yakuza on the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请等一下。黑社会们为什么还留在岛上？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請等一下。黑社會們為什麼還留在島上？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00023",
		linknext = "0111_00025",
		line = 316,
	},
	["0111_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It probably won't do them any more good to stay here, right? They can't work here any longer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他们留在这里也不能工作了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他們留在這裡也不能工作了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00024",
		linknext = "0111_00026",
		line = 328,
	},
	["0111_00026"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0125", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Naturally, because Fumino is still at large. They were originally after her because she was a hindrance to their operations. But now, they too understand she is the key to the destruction of the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“当然是为了‘文乃’吧。他们本来就把‘文乃’作为麻烦制造者追捕着。现在只是变成了寻找作为摧毁条例关键的‘文乃’而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「當然是為了『文乃』吧。他們本來就把『文乃』作為麻煩製造者追捕著。現在只是變成了尋找作為摧毀條例關鍵的『文乃』而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00025",
		linknext = "0111_00027",
		line = 341,
	},
	["0111_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having had their den virtually destroyed, they still have the opportunity to turn things around with Fumino by abolishing the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在失去立足之地的现在，“文乃”成为了一个可以逆转情势的好机会是吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"在失去立足之地的現在，「文乃」成為了一個可以逆轉情勢的好機會是嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00026",
		linknext = "0111_00028",
		line = 351,
	},
	["0111_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They have to find her before the illegal sex industry problem is resolved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对他们来说……应该无论如何也要赶在地下风俗问题被解决之前找到她吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對他們來說……應該無論如何也要趕在地下風俗問題被解決之前找到她吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00027",
		linknext = "0111_00029",
		line = 361,
	},
	["0111_00029"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0126", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“They are engaged in an intense manhunt for her, night after night. Once the OSS are able to make their move, that should be quieted down in due course.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“实际上，他们每天晚上都在山里进行猛烈的搜寻，如果SHO开始活跃的话，他们应该也会躲起来吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「實際上，他們每天晚上都在山裡進行積極的搜尋，如果SHO開始活躍的話，他們應該也會躲起來吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00028",
		linknext = "0111_00030",
		line = 374,
	},
	["0111_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ultimately, Fumino is still in danger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——结果，文乃的危险状况还是没有改变。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——結果，文乃的危險狀況還是沒有改變。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00029",
		linknext = "0111_00031",
		line = 384,
	},
	["0111_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"These last few days, that's been the only conclusion we have come to, without fail.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这和这几天我们得出的结论是一样的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這和這幾天我們得出的結論是一樣的。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00030",
		linknext = "0111_00032",
		line = 394,
	},
	["0111_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So what can we do on that front?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，我们能做的是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，我們能做的是——",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00031",
		linknext = "0111_00033",
		line = 404,
	},
	["0111_00033"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0127", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You must immediately secure Fumino before they can, at all costs. That is a direct order.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“在那之前，无论如何都要确保‘文乃’的安全。这是紧急命令。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「在那之前，無論如何都要確保『文乃』的安全。這是緊急命令。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00032",
		linknext = "0111_00034",
		line = 417,
	},
	["0111_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He conveys to us the same conclusion we came to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人说出和我们得出的答案一样的意见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人說出和我們得出的答案一樣的意見。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00033",
		linknext = "0111_00035",
		line = 427,
	},
	["0111_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We are all in agreement with you on that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——关于这件事，我们也是同样的想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——關於這件事，我們也是同樣的想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00034",
		linknext = "0111_00036",
		line = 439,
	},
	["0111_00036"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“However, to be perfectly honest... I cannot trust you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是——坦率地说，我不相信你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是——坦率地說，我不相信你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00035",
		linknext = "0111_00037",
		line = 451,
	},
	["0111_00037"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0128", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“What did you say?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“……你说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「……你說什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00036",
		linknext = "0111_00038",
		line = 464,
	},
	["0111_00038"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00113", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the members look uneasy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一瞬间，成员们露出了不安的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一瞬間，成員們露出了不安的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00037",
		linknext = "0111_00039",
		line = 482,
	},
	["0111_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, the old man is equally flustered. He doesn't have the upper hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是或许老人也是一样，没有情况的优劣差异。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是或許老人也是一樣，沒有情況的優劣差異。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00038",
		linknext = "0111_00040",
		line = 492,
	},
	["0111_00040"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=30, ch="防人老人", lv=5},
		{"bg", id=2, file="bg12_1l_00000", x=300, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I have no reason to trust someone whose name I don't even know. And neither do my colleagues. Is that not natural?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是当然的吧。连名字都不知道的人该怎么信任呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是當然的吧。連名字都不知道的人該怎麼信任呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00039",
		linknext = "0111_00041",
		line = 512,
	},
	["0111_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is my chance to say it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么——只有现在可以说出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼——只有現在可以說出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00040",
		linknext = "0111_00042",
		line = 522,
	},
	["0111_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino is Hitoura's daughter, so that would mean she can be used as a pawn against him in order to destroy the law. That much I understand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘文乃’是仁浦先生的女儿。所以可以摧毁变态条例。这是可以理解的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『文乃』是仁浦先生的女兒。所以可以摧毀變態條例。這是可以理解的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00041",
		linknext = "0111_00043",
		line = 534,
	},
	["0111_00043"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So with that in mind, do you have anything to say that will convince me you don't intend to utilize her for malicious purposes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——因为可以理解。所以你又有什么证据，能证明不会恶用她？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——因為可以理解。所以你又有什麼證據，能證明不會惡用她？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00042",
		linknext = "0111_00044",
		line = 546,
	},
	["0111_00044"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0129", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00043",
		linknext = "0111_00045",
		line = 559,
	},
	["0111_00045"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I will find her before anyone else can. And I won't let anyone stand in the way of that goal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我一定会找出文乃，比任何组织都要快，我不会让任何人妨碍我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我一定會找出文乃，比任何組織都要快，我不會讓任何人妨礙我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00044",
		linknext = "0111_00046",
		line = 571,
	},
	["0111_00046"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if you simply intend to use her to your own ends, even if I do manage to secure her, I will not hand her over to you. That is not up for discussion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……但是，如果你试图利用那个孩子，就算我找到了她，也绝对不会交给你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……但是，如果你試圖利用那個孩子，就算我找到了她，也絕對不會交給你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00045",
		linknext = "0111_00047",
		line = 583,
	},
	["0111_00047"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I stare him directly in the eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"隔着显示器，我和老人的视线互相冲突。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隔著顯示器，我和老人的視線互相衝突。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00046",
		linknext = "0111_00048",
		line = 594,
	},
	["0111_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In the dark room, across the thin LCD panel, I can't read his expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"呆在昏暗的房间，几乎不知道身在何处的老人的脸，我无法透过液晶看清他的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"待在昏暗的房間，幾乎不知道身在何處的老人的臉，我無法透過液晶看清他的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00047",
		linknext = "0111_00049",
		line = 604,
	},
	["0111_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nonetheless, I keep staring at him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便如此，我也没有移开视线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便如此，我也沒有移開視線。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00048",
		linknext = "0111_00050",
		line = 614,
	},
	["0111_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That continues for half a minute.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这段时间持续了数十秒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這段時間持續了數十秒。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00049",
		linknext = "0111_00051",
		line = 624,
	},
	["0111_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then he puts on a nihilistic smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直到老人露出了虚弱的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直到老人露出了虛弱的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00050",
		linknext = "0111_00052",
		line = 634,
	},
	["0111_00052"] = {
		{"bgm", file="bgm14", vol=100},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0130", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Hmm... I suppose it is terribly discourteous of me not to introduce myself. Very well. I shall tell you my name.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“嗯……没想到我居然没报上名字。失礼了。那我就告诉你我是谁——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「嗯……沒想到我居然沒報上名字。失禮了。那我就告訴你我是誰——」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00051",
		linknext = "0111_00053",
		line = 648,
	},
	["0111_00053"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0131", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I am of a family called Sakimori. I am a humble old man, and an instructor on the mainland.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“——我的姓是防人，是个在本岛被称为",
					{"ruby", text="・・"},
					"老师",
					{"/ruby"},
					"的老人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——我的姓是防人，是個在本島被稱為",
					{"ruby", text="・・"},
					"老師",
					{"/ruby"},
					"的老人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00052",
		linknext = "0111_00054",
		line = 661,
	},
	["0111_00054"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sakimori...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……防人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……防人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00053",
		linknext = "0111_00055",
		line = 673,
	},
	["0111_00055"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0132", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Yes. Perhaps you are unfamiliar with that name. It is somewhat known within Kyushu, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“没错。你不知道这个名字吧？在九州多少有些人知道——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「沒錯。你不知道這個名字吧？在九州多少有些人知道——」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00054",
		linknext = "0111_00056",
		line = 686,
	},
	["0111_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wait... That name sounds familiar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，这个名字好像在哪里——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，這個名字好像在哪裡——",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00055",
		linknext = "0111_00057",
		line = 696,
	},
	["0111_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Very well then, Sakimori. Why do you wish to secure Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——那么，防人老爷爷，你为什么要保护文乃呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——那麼，防人老爺爺，你為什麼要保護文乃呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00056",
		linknext = "0111_00058",
		line = 708,
	},
	["0111_00058"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0133", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Old age and senility will not diminish one's own desire to save their own blood relative.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“想要拯救流淌着自己血缘的人的想法，多老都不会改变。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「想要拯救流淌著自己血緣的人的想法，多老都不會改變。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00057",
		linknext = "0111_00059",
		line = 720,
	},
	["0111_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你說什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00058",
		linknext = "0111_00060",
		line = 732,
	},
	["0111_00060"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Does that mean... Fumino is your granddaughter?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，莫非……文乃是你的孙子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，莫非……文乃是你的孫子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00059",
		linknext = "0111_00061",
		line = 744,
	},
	["0111_00061"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0134", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Yes. She is the child of my daughter and the controller of Seiran Island, Governor Hitoura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“是的……那是我的女儿和治理青蓝岛的仁浦县知事所生的孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「是的……那是我的女兒和治理青藍島的仁浦縣知事所生的孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00060",
		linknext = "0111_00062",
		line = 757,
	},
	["0111_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He doesn't look like he's lying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从防人老人的脸上看不出虚假。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從防人老人的臉上看不出虛假。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00061",
		linknext = "0111_00063",
		line = 767,
	},
	["0111_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00062",
		linknext = "0111_00064",
		line = 777,
	},
	["0111_00064"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She herself said she has no parents, nor any living relatives.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——那孩子说过她没有父母，无依无靠。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——那孩子說過她沒有父母，無依無靠。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00063",
		linknext = "0111_00065",
		line = 789,
	},
	["0111_00065"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0135", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“That is more or less the case. I have only ever spoken to her once. She cut off all contact after my daughter died.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“只能说差不多是那样吧。实际上文乃也只和我聊过一次。在女儿死后，就没有消息了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「只能說差不多是那樣吧。實際上文乃也只和我聊過一次。在女兒死後，就沒有消息了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00064",
		linknext = "0111_00066",
		line = 802,
	},
	["0111_00066"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0136", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“That is why I am asking you to find her. If she is still alive, she can still be found.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“所以我才让你们去追查她的下落。如果她还活着，应该就能找到她吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「所以我才讓你們去追查她的下落。如果她還活著，應該就能找到她吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00065",
		linknext = "0111_00067",
		line = 815,
	},
	["0111_00067"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1999", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So does that mean, um, that you made that request of us... because you're searching for your granddaughter?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“也就是说，呃，你是为了寻找自己的外孙女，才委托我们的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「也就是說，呃，你是為了尋找自己的外孫女，才委託我們的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00066",
		linknext = "0111_00068",
		line = 831,
	},
	["0111_00068"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0137", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Of course. Is it so strange to desire my granddaughter to be taken out of harm's way, and be allowed to live a normal life?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“当然。找回生活困难的外孙女，让她过上正常人的生活，这是那么奇怪的事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「當然。找回生活困難的外孫女，讓她過上正常人的生活，這是那麼奇怪的事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00067",
		linknext = "0111_00069",
		line = 844,
	},
	["0111_00069"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0138", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“The only reason I could not conduct an open investigation is because she is that man's relative.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“没有公开调查是因为外孙女和那个男人有血缘关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「沒有公開調查是因為外孫女和那個男人有血緣關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00068",
		linknext = "0111_00070",
		line = 859,
	},
	["0111_00070"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0139", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Fumino is the one chink in his armor. I have no idea how to deal with her. So I conducted my investigation under a veil of secrecy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“对那个男人来说，‘文乃’是唯一的弱点。我不知道他会怎么对待我的外孙女，所以我才在背后偷偷调查。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「對那個男人來說，『文乃』是唯一的弱點。我不知道他會怎麼對待我的外孫女，所以我才在背後偷偷調查。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00069",
		linknext = "0111_00071",
		line = 872,
	},
	["0111_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So he wants to get Fumino back to keep her from being abused, and give her a chance at an ordinary life again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，防人老人是为了避免文乃被恶意利用，以及为了让文乃过上普通人的生活，才想收养她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，防人老人是為了避免文乃被惡意利用，以及為了讓文乃過上普通人的生活，才想收養她。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00070",
		linknext = "0111_00072",
		line = 882,
	},
	["0111_00072"] = {
		{"se", id=0, stop=1, time=1000},
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That much I can understand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是这样，那当然可以理解……",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是這樣，那當然可以理解……",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00071",
		linknext = "0111_00073",
		line = 894,
	},
	["0111_00073"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0140", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Let me emphasize this again: this is a race against time. I want you to rescue my granddaughter as soon as possible. That is all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“我再次重复，这件事分秒必争。希望你们能尽快救出我的外孙女。就这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「我再次重複，這件事分秒必爭。希望你們能盡快救出我的外孫女。就這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00072",
		linknext = "0111_00074",
		line = 906,
	},
	["0111_00074"] = {
		{"se", id=0, loop=0, file="se_a163"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
