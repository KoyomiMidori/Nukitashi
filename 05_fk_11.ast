				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oh, right. Nanase's a luddite with tech. Forgot about that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对了，我忘了这家伙很不擅长机械……",
					{"rt2"},
				},
			},
			tw = {
				{
					"對了，我忘了這傢伙很不擅長機械……",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00007",
		linknext = "0111_00009",
		line = 112,
	},
	["0111_00009"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00113", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=400, y=0, time=800},
		{"fgact", ch="麻沙音", id=3, act="浮遊", loop=8, size=12.5, time=50, ease="easeinout_sine"},
		{"text"},
		text = {
