	["0111_00075"] = {
		{"bgm", file="bgm07", vol=100},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So... what do you guys think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你们怎么想？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你們怎麼想？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00074",
		linknext = "0111_00076",
		line = 929,
	},
	["0111_00076"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2134", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well, I can understand wanting to protect your own granddaughter, so I say we support him. What about you guys?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果是想保护自己的外孙女的话，我能理解也能支持他。对吧，大家？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果是想保護自己的外孫女的話，我能理解也能支持他。對吧，大家？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00075",
		linknext = "0111_00077",
		line = 945,
	},
	["0111_00077"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2000", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, she's probably going to be better off being with her relative.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊，比起一个人，跟有血缘关系的人在一起绝对更好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊，比起一個人，跟有血緣關係的人在一起絕對更好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00076",
		linknext = "0111_00078",
		line = 960,
	},
	["0111_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, exactly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，说得对——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，說得對——」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00077",
		linknext = "0111_00079",
		line = 972,
	},
	["0111_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have my apprehensions, but there are things I have to prioritize first.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然还有些疑虑——但是现在有比那个更应该优先的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然還有些疑慮——但是現在有比那個更應該優先的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00078",
		linknext = "0111_00080",
		line = 982,
	},
	["0111_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It'd be putting the cart before the horse to worry about those things before we actually secure her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么烦恼，实际上如果不能找到她的话，一切都只是浮云。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼煩惱，實際上如果不能找到她的話，一切都只是浮雲。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00079",
		linknext = "0111_00081",
		line = 992,
	},
	["0111_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
