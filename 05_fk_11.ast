	["0111_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We've been repeatedly investigating the area where we assume Fumino lives these last few days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们在最近几天反复调查了被认为是文乃住所的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們在最近幾天反複調查了被認為是文乃住所的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00106",
		linknext = "0111_00108",
		line = 1347,
	},
	["0111_00108"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2147", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Misaki, Wata, and I have been investigating the places where there have been reports of that white-haired ghost appearing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我和美岬和渡酱调查的是关于‘淡色头发的幽灵’出现的地点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我和美岬和渡醬調查的是關於『淡色頭髮的幽靈』出現的地點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00107",
		linknext = "0111_00109",
		line = 1359,
	},
	["0111_00109"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2148", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We've been investigating the hillside tooth and comb based on the assumption that she's Fumino. Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我们假定她是‘文乃’，并从听说目击到她的地方，将山之手的角角落落都调查了一遍……然后，麻沙酱——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我們假定她是『文乃』，並從聽說目擊到她的地方，將山之手的角角落落都調查了一遍……然後，麻沙醬——」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00108",
		linknext = "0111_00110",
		line = 1371,
	},
	["0111_00110"] = {
