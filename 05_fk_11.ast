				{"vo", file="nanase2145", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Say, Jun? I understand how you feel, but why are you so obsessed with Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……呐，淳？你的心情我可以理解，但为什么……你会对‘文乃’这么执着？”",
