	["0111_00276"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says nothing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她什么都没说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她什麼都沒說。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00275",
		linknext = "0111_00277",
		line = 3533,
	},
	["0111_00277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She just stares at me wide-eyed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是睁大眼睛，望着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是睜大眼睛，望著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00276",
		linknext = "0111_00278",
		line = 3543,
	},
	["0111_00278"] = {
		{"bgm", stop=1},
		{"fg", file="fumino_01l_00001", file3="fumino_01l_00306", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0603", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Why are you doing this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……为什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……為什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00277",
		linknext = "0111_00279",
		line = 3558,
	},
	["0111_00279"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She asks a question in response.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，终于开口问道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，終於開口問道。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00278",
		linknext = "0111_00280",
		line = 3568,
	},
	["0111_00280"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She honestly looks completely baffled.",
					{"rt2"},
				},
			},
			cn = {
				{
					"似乎真的打从心底觉得不可思议一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"似乎真的打從心底覺得不可思議一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00279",
		linknext = "0111_00281",
		line = 3578,
	},
	["0111_00281"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0604", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Why... go this far? For a girl you hardly even know, have only met a few times...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“为什么、您要对我……那么……？对素未谋面、只见过几次的、女人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「為什麼、您要對我……那麼……？對素未謀面、只見過幾次的、女人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00280",
		linknext = "0111_00282",
		line = 3590,
	},
	["0111_00282"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0605", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“And even while knowing... I am the daughter of your enemy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“而且……还是敌人的、女儿……您即使知道了……还对我……这么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「而且……還是敵人的、女兒……您即使知道了……還對我……這麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00281",
		linknext = "0111_00283",
		line = 3602,
	},
	["0111_00283"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0606", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Why... are you so interested in me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“为什么……要那么、在意我呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「為什麼……要那麼、在意我呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00282",
		linknext = "0111_00284",
		line = 3614,
	},
	["0111_00284"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A valid question. Why am I so interested in her?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么我要这么在意文乃呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼我要這麼在意文乃呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00283",
		linknext = "0111_00285",
		line = 3624,
	},
	["0111_00285"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Was I compelled by a desire to cure her of her loneliness?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是觉得必须解决名为孤独的毒吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是覺得必須解決名為孤獨的毒嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00284",
		linknext = "0111_00286",
		line = 3634,
	},
	["0111_00286"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a question from when Fumino was Fukiko to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是……文乃还是吹子时就开始有的疑问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是……文乃還是吹子時就開始有的疑問。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00285",
		linknext = "0111_00287",
		line = 3644,
	},
	["0111_00287"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's remained an unsolved mystery to me all along.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一直不明真相的，我自己的谜团。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一直不明真相的，我自己的謎團。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00286",
		linknext = "0111_00288",
		line = 3654,
	},
	["0111_00288"] = {
		{"bgm", file="bgm26", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Long ago, there were two people I was indebted to on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——以前，有两位在这个岛上照顾过我的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——以前，有兩位在這個島上照顧過我的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00287",
		linknext = "0111_00289",
		line = 3667,
	},
	["0111_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But her eyes...",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是——那双眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是——那雙眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00288",
		linknext = "0111_00290",
		line = 3677,
	},
	["0111_00290"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“One was a girl that went to the same school as me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一个人是在同一所学校就读的女孩。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一個人是在同一所學校就讀的女孩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00289",
		linknext = "0111_00291",
		line = 3688,
	},
	["0111_00291"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The other one was an adult woman.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有一个——是个成年女性。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有一個——是個成年女性。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00290",
		linknext = "0111_00292",
		line = 3700,
	},
	["0111_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I always feel deja vu when I see her unusually colored eyes, and her beautiful facial features.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那不可思议的颜色的瞳孔，和过于美丽的容貌，让我总有些既视感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那不可思議的顏色的瞳孔，和過於美麗的容貌，讓我總有些既視感。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00291",
		linknext = "0111_00293",
		line = 3710,
	},
	["0111_00293"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The first girl was incredibly kind to me, after I'd made a grave mistake, and was wallowing in the pit of despair. The other was like a mother to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个人对因为犯了很大的错误而被击垮的我非常温柔，就像我的另一个母亲。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個人對因為犯了很大的錯誤而被擊垮的我非常溫柔，就像我的另一個母親。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00292",
		linknext = "0111_00294",
		line = 3722,
	},
	["0111_00294"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I cannot show anything outside of my best self to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有这个少女——我绝对不想让她看到我的丑态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有這個少女——我絕對不想讓她看到我的醜態。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00293",
		linknext = "0111_00295",
		line = 3732,
	},
	["0111_00295"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But the islanders persecuted her for working in the illegal sex industry. And eventually, she took ill and died.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，她——因为在地下风俗工作，被岛上的人迫害，被谴责，最后卧病在床死了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，她——因為在地下風俗工作，被島上的人迫害，被譴責，最後臥病在床死了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00294",
		linknext = "0111_00296",
		line = 3744,
	},
	["0111_00296"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00109", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
