	["0111_00329"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She slowly sits down in place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，她在原地慢慢地跪坐下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，她在原地慢慢地跪坐下來。",
