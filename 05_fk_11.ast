	["0111_00310"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's why I have to crush that law. That is my dream.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“正因为如此，我才要毁掉变态条例，这是我的梦想。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「正因為如此，我才要毀掉變態條例，這是我的夢想。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00309",
		linknext = "0111_00311",
		line = 3916,
	},
	["0111_00311"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
