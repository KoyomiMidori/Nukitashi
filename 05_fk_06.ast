			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“If that has... been unpleasant to you... then I apologize...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“如果、因为这样……而让橘大人、感到不愉快的话……我很抱歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
