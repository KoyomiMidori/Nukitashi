	["0106_00134"] = {
		{"se", id=0, loop=0, file="se_a019"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I start running a bit along the way to pick up the pace, stopping at irregular intervals to do some push-ups.",
					{"rt2"},
				},
			},
			cn = {
				{
					"中途我踏着训练般的脚步，根据节奏以一定的间隔停下，做起了俯卧撑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"中途我踏著訓練般的腳步，根據節奏以一定的間隔停下，做起了伏地挺身。",
					{"rt2"},
