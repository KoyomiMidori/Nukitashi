					{"rt2"},
				},
			},
			en = {
				{
					"I'm not sure what she really means with that look, but at least I know she plans to wait.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我不明白她的意图，但至少知道她想等我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我不明白她的意圖，但至少知道她想等我。",
