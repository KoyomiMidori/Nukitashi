		linkback = "0106_00169",
		linknext = "0106_00171",
		line = 2300,
	},
	["0106_00171"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0465", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“That is to say... I don't normally converse... on a daily basis. So I am unaccustomed to... holding a conversation with another person...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“也就是说……因为我、平时没什么机会……日常对话……所以不怎么、习惯……和别人聊天……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「也就是說……因為我、平時沒什麼機會……日常對話……所以不怎麼、習慣……和別人聊天……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00170",
		linknext = "0106_00172",
		line = 2314,
	},
	["0106_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She chooses her words carefully, and deliberates before vocalizing them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她选择着词汇，拼命地说出口来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她選擇著詞彙，拼命地說出口來。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00171",
		linknext = "0106_00173",
		line = 2324,
	},
	["0106_00173"] = {
