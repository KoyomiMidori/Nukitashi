	["0106_00059"] = {
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Did she just throw ice water on me? Why would—",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么我被泼了冷水……",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼我被潑了冷水……",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00058",
		linknext = "0106_00060",
		line = 851,
	},
	["0106_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oh, right... I remember now. I was doing SS training.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……啊，对了，是FS的训练。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……啊，對了，是FS的訓練。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00059",
		linknext = "0106_00061",
		line = 861,
	},
	["0106_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I finished some basic stretches, and then endured an hour and a half of being hurled abuse by the diabolical committee president while standing to attention.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基本的伸展运动结束后，我们被风纪委员长责骂着进行了完全不觉得有意义的服装和列队检查一个半小时。",
					{"rt2"},
				},
			},
			tw = {
				{
					"基本的伸展運動結束後，我們被風紀委員長責罵著進行了完全不覺得有意義的服裝和列隊檢查一個半小時。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00060",
		linknext = "0106_00062",
		line = 871,
	},
	["0106_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then I did 300 SS style push ups, 100 chin ups, and two more hours of full body exercises.",
					{"rt2"},
				},
			},
			cn = {
				{
					"接着直接进行了FS式俯卧撑300次，垂直拉伸100次，全身运动2小时后。",
					{"rt2"},
				},
			},
			tw = {
				{
					"接著直接進行了FS式伏地挺身300次，垂直拉伸100次，全身運動2小時後。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00061",
		linknext = "0106_00063",
		line = 881,
	},
	["0106_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had to avoid getting the absurdly heavy assault rifle wet as I carried it while crossing a swamp, climbing ropes, and crawling under barbed wire.",
					{"rt2"},
				},
			},
			cn = {
				{
					"扛着不可以被淋湿的超级沉重突击步枪越过泥沼，绳索攀登，在铁栅下匍匐前进。",
					{"rt2"},
				},
			},
			tw = {
				{
					"扛著不可以被淋濕的超級沉重突擊步槍越過泥沼，繩索攀登，在鐵柵下匍匐前進。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00062",
		linknext = "0106_00064",
		line = 891,
	},
	["0106_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then I ran all around the island with all of my equipment on, and eventually collapsed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这样全副武装在岛上来回跑着的时候，我晕倒了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"就這樣全副武裝在島上來回跑著的時候，我暈倒了——",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00063",
		linknext = "0106_00065",
		line = 901,
	},
	["0106_00065"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0595", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I got to hold you niiiiice n' tight as I carried you back here. Pretty good exercise, I'd say ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“所以郁就紧紧抱着亲爱的的身体回来了。成了很好的运动哦〜♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「所以郁就緊緊抱著親愛的的身體回來了。成了很好的運動哦〜♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00064",
		linknext = "0106_00066",
		line = 915,
	},
	["0106_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can barely even stand right now, but the first squad commander here still looks fresh as a daisy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我甚至站都站不起来，但一队队长却面不改色地活蹦乱跳。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我甚至站都站不起來，但一隊隊長卻面不改色地活蹦亂跳。",
					{"rt2"},
				},
			},
