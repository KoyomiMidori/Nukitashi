			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess there's just too much data to deal with. It doesn't seem like looking any further is going to give us any leads.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“确实量本来就很多了……但是除此之外也没有其他线索……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「確實量本來就很多了……但是除此之外也沒有其他線索……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00033",
		linknext = "0106_00035",
		line = 469,
	},
	["0106_00035"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2118", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So next, we'll get team B to extract the data from where it's all stored.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以，B组接下来打算从有完整情报的地方把数据偷出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以，B組接下來打算從有完整情報的地方把數據偷出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00034",
		linknext = "0106_00036",
		line = 486,
	},
	["0106_00036"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that'd mean getting it from the SS again? I'm gonna try to do whatever I can on that front...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说完整的情报——还打算从FS那边偷吗？那边我是打算由我自己来的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說完整的情報——還打算從FS那邊偷嗎？那邊我是打算由我自己來的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00035",
		linknext = "0106_00037",
		line = 498,
	},
	["0106_00037"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2119", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I mean from the big cheese. OSS HQ. They should be managing all the data on the islanders from there. We might be able to get a lead on Fumino from that data.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是它的母体。SHO总部设施。那里的话应该管理着岛上所有居民的数据。这样应该找得到‘文乃’的线索吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是它的母體。SHO總部設施。那裡的話應該管理著島上所有居民的數據。這樣應該找得到『文乃』的線索吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00036",
		linknext = "0106_00038",
		line = 512,
	},
	["0106_00038"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, in theory, yeah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“或许是吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「或許是吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00037",
		linknext = "0106_00039",
		line = 524,
	},
	["0106_00039"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But how do we even get in there? Is that a realistic idea? What about their security?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……但是那种事有可能吗？安全系统呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……但是那種事有可能嗎？安全系統呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00038",
		linknext = "0106_00040",
		line = 536,
	},
	["0106_00040"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2120", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, uh, we can at least try, can't we? Being an evil organization and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那部份的话，会再努力看看吧？毕竟我们是邪恶组织啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那部份的話，會再努力看看吧？畢竟我們是邪惡組織啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00039",
		linknext = "0106_00041",
		line = 550,
	},
	["0106_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Such a reliable teammate I've cultivated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真的可靠队友。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真的可靠隊友。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00040",
		linknext = "0106_00042",
		line = 560,
	},
	["0106_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yesterday taught us that using the Ariadne Protocol in a multi-story building with enemies on different levels makes things more difficult.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“昨天我发现了，当诱导对象不在同一楼层时，在多层设施里‘Ariadne协议’很难发挥作用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「昨天我發現了，當誘導對象不在同一樓層時，在多層設施裡『Ariadne協議』很難發揮作用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00041",
		linknext = "0106_00043",
		line = 572,
	},
	["0106_00043"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00120", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00121", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So could you please keep a close eye on the battle situation going forward? I don't want a repeat of all that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了不步上我的后尘，你们要在准备万全的状态下执行作战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了不步上我的後塵，你們要在準備萬全的狀態下執行作戰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00042",
		linknext = "0106_00044",
		line = 590,
	},
	["0106_00044"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1582", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No need to worry there. We can't use the entire system this time. Besides, there's no chance of being able to hack the cameras at OSS HQ either way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这次不会使用整个系统所以没关系……不管怎么样，我都无法黑进SHO总部的摄像头……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這次不會使用整個系統所以沒關係……不管怎麼樣，我都無法黑進SHO總部的攝影機……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00043",
		linknext = "0106_00045",
		line = 609,
	},
	["0106_00045"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00104", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1583", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So after school, team B will be heading for the OSS. What's your plan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以B队放学后会去SHO……哥哥那边要做什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以B隊放學後會去SHO……哥哥那邊要做什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00044",
		linknext = "0106_00046",
		line = 623,
	},
	["0106_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've got a date with the SS. They say I need to get started on my combat training.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我被FS呼叫了，说有战斗训练……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我被FS呼叫了，說有戰鬥訓練……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00045",
		linknext = "0106_00047",
		line = 635,
	},
	["0106_00047"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1980", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? SS combat training, you say!? Uh, I've heard things about it, and it's apparently pretty intense stuff...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶，要参加FS的战斗训练……！？我听说那个超级辛苦的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸，要參加FS的戰鬥訓練……！？我聽說那個超級辛苦的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00046",
		linknext = "0106_00048",
		line = 653,
	},
	["0106_00048"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure it will be. It's training meant to be put to use in the real world, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然是假定会进行实践的战斗训练，多少会有点难度吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然是假定會進行實踐的戰鬥訓練，多少會有點難度吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00047",
		linknext = "0106_00049",
		line = 665,
	},
	["0106_00049"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00111", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2119", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, just so you know, Rei once told me this, but every year they have a certain number of dropouts and even deaths occur in training.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，之前礼酱说过……每年年初都会有落选者和死者……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，之前禮醬說過……每年年初都會有落選者和死者……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00048",
		linknext = "0106_00050",
		line = 680,
	},
	["0106_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, come on. That's ridiculous. You don't seriously think they'd let that happen in a school environment, do you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说什么傻话——学校里怎么可能有那种事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說什麼傻話——學校裡怎麼可能有那種事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00049",
		linknext = "0106_00051",
		line = 692,
	},
	["0106_00051"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's just another one of those stories the SS makes up and peddles to everyone, in order to proclaim how powerful they are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一定是FS为了宣扬自己的力量而捏造的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一定是FS為了宣揚自己的力量而捏造的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00050",
		linknext = "0106_00052",
		line = 704,
	},
	["0106_00052"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Besides, I've done some training myself. I'm pretty confident in my own strength and combat capability, if I do say so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且我也积累了一定程度的训练，对基础体力和战斗力很有自信。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且我也積累了一定程度的訓練，對基礎體力和戰鬥力很有自信。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00051",
		linknext = "0106_00053",
		line = 718,
	},
