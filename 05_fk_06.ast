	["0106_00158"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00101", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0462", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“My evening meal was a full course of soup and three sides. I have night watch to tend to, after all.”",
					{"rt2"},
				},
			},
