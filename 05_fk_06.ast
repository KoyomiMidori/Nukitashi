		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1077", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Let's dive right into the deep end. This is the standard SS-issue handgun. Today I'll be teaching you how to use it. It's a very dangerous item, so be careful with it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，这就是FS的标准装备，手枪。从今天开始你也要学会使用它的方法。它是个危险的东西，注意一点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，這就是FS的標準裝備，手槍。從今天開始你也要學會使用它的方法。它是個危險的東西，注意一點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00105",
		linknext = "0106_00107",
		line = 1458,
	},
	["0106_00107"] = {
