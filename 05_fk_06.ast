		linknext = "0106_00135",
		line = 1857,
	},
	["0106_00135"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, I'm gonna be falling a little behind. You can go on ahead of me... Huff... And I can catch up to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思，我会稍微慢一点……你先往前也没关系……呼……我会追上你的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
