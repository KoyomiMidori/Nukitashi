					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So if I'm evil, and I'm working for the SS, which is also evil... that means I can change them and turn them good from the inside!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“邪恶的我去了邪恶的FS，负负得正后就是正义！”",
