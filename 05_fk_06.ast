	["0106_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She really does give off quite an aura (I guess you could call it) of taciturn stoicism.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说到底，她所拥有的气质——气场之类的东西，可能是最大的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說到底，她所擁有的氣質——氣場之類的東西，可能是最大的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00147",
		linknext = "0106_00149",
		line = 2028,
	},
	["0106_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even just standing still, there's some sort of invisible power to her presence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她光是站着就很有存在感，感觉散发着看不见的力量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她光是站著就很有存在感，感覺散發著看不見的力量。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00148",
		linknext = "0106_00150",
		line = 2038,
	},
	["0106_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suppose you could say it's sort of like the presence Reizeiin has, albeit a little different.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这与学生会长冷泉院桐香那种受民众爱戴的人似乎很像，但总觉得有些许不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這與學生會長冷泉院桐香那種受民眾愛戴的人似乎很像，但總覺得有些許不同。",
					{"rt2"},
				},
			},
		},
