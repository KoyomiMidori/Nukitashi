	["0106_00057"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0594", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ah, you're finally awake, Darling ♪ I was startled when you suddenly collapsed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊，终于醒过来了啊……亲爱的♪你突然昏倒吓了我一跳呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊，終於醒過來了啊……親愛的♪你突然昏倒嚇了我一跳呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00056",
		linknext = "0106_00058",
		line = 827,
	},
	["0106_00058"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
