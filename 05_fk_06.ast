					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like, who'd've ever thought I was that pissweak? Guess I'm just too reliant on my TAEs...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没想到自己居然弱到这种程度。也许过于依赖T-A-E了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
