					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We're mainly about battle strategies, escaping, surprise attacks, infiltration and so on. That doesn't sound like a righteous organization.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“作战行动也是以逃亡或突袭、侵入为主，根本不像正义的伙伴啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「作戰行動也是以逃亡或突襲、侵入為主，根本不像正義的伙伴啊……」",
