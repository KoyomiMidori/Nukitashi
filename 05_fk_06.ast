					name = {"淳之介"},
					"“可恶……居然真的对我开枪……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡……居然真的對我開槍……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00117",
		linknext = "0106_00119",
		line = 1662,
	},
	["0106_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She did minimize the damage by aiming for my legs but I did fall over, hit my head, and lose consciousness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然她把威力压到最小打中了脚，但我还是摔倒撞到了头失去了意识。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然她把威力壓到最小打中了腳，但我還是摔倒撞到了頭失去了意識。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00118",
		linknext = "0106_00120",
		line = 1672,
	},
	["0106_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And after that, during the combat training, my incapability against them led to me getting my ass kicked.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之后，我也因为太弱而在战斗训练中被狂揍了一顿。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之後，我也因為太弱而在戰鬥訓練中被狂揍了一頓。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00119",
		linknext = "0106_00121",
		line = 1682,
	},
	["0106_00121"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00114", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay, so I got owned today. But this shit ain't over yet. That disciplinary committee president's gonna eat her words.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天确实是输了，但我不会就这么结束的风纪委员长……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天確實是輸了，但我不會就這麼結束的風紀委員長……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00120",
		linknext = "0106_00122",
		line = 1696,
	},
	["0106_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to be triumphant one day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总有一天我要赢过你——",
					{"rt2"},
				},
			},
			tw = {
				{
					"總有一天我要贏過你——",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00121",
		linknext = "0106_00123",
		line = 1706,
	},
	["0106_00123"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00101", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0453", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Disciplinary committee president... You mean, of the SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“风纪委员长……是FS的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「風紀委員長……是FS的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00122",
		linknext = "0106_00124",
		line = 1720,
	},
	["0106_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. I managed to infiltrate the SS in order to gather info on the illegal sex industry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，其实为了这次的地下风俗事件，我为了收集情报潜入了FS。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，其實為了這次的地下風俗事件，我為了收集情報潛入了FS。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00123",
		linknext = "0106_00125",
		line = 1732,
	},
	["0106_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So they put me in their reserves, and during training today, I really got whaled on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后就顺其自然地成了FS的后备人员，今天的第一次训练我被狠狠揍了一顿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後就順其自然地成了FS的後備人員，今天的第一次訓練我被狠狠揍了一頓……」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00124",
		linknext = "0106_00126",
		line = 1744,
	},
	["0106_00126"] = {
