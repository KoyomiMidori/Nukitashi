	["0106_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She stares at me with her usual emotionless expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她面无表情，什么都没说地凝视着这边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她面無表情，什麼都沒說地凝視著這邊。",
					{"rt2"},
				},
