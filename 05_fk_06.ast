	},
	["0106_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I realized just how weak I really am today, so I figure my regimen could use some improvement.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……通过这次的事情，我重新认识到了自己的软弱。所以我想重新锻炼自己的身体。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……通過這次的事情，我重新認識到了自己的軟弱。所以我想重新鍛煉自己的身體。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00137",
		linknext = "0106_00139",
		line = 1910,
	},
	["0106_00139"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I don't, well... I'm not gonna be able to protect everyone when it counts, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“否则……万一发生紧急情况，就不能保护大家了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「否則……萬一發生緊急情況，就不能保護大家了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00138",
		linknext = "0106_00140",
		line = 1922,
	},
	["0106_00140"] = {
