				{
					"所以麻沙酱不知道从哪里廉价购买了外国研究所的失败试作品——新液晶显示器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以麻沙醬不知道從哪裡廉價購買了外國研究所的失敗試作品——新液晶顯示器。",
					{"rt2"},
