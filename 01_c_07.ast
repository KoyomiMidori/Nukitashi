	["0008_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Además, el consumo de energía se controla mediante tecnología de accionamiento de baja frecuencia, lo que se traduce en una mayor duración de batería, ideal para gozar de muchísimos videos porno.",
					{"rt2"},
				},
			},
			cn = {
				{
					"此外，通过使用低频驱动技术来执行功耗率的控制，使其只需要内部的电池就可以充分享受小黄片。",
					{"rt2"},
				},
			},
			tw = {
				{
					"此外，通過使用低頻驅動技術來執行功耗率的控制，使其只需要內部的電池就可以充分享受小黃片。",
					{"rt2"},
				},
