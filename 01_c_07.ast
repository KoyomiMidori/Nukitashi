	["0008_00253"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Te acuerdas de la píldora a largo plazo que se distribuye a los residentes locales, ¿verdad? Bueno, está a punto de hacerle efecto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“分发给决定在岛上定居的人们的长期避孕药……效果很快就要出现了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「分發給決定在島上定居的人們的長期避孕藥……效果很快就要出現了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00252",
