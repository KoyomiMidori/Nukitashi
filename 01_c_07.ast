	["0008_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se metieron en mi cuarto y lo limpiaron sin que yo lo pidiera, y ella sigue perdiéndose en sus fantasías. Es que no tiene nada de vergüenza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有，在打扫房间后还做这种事的家伙真是个混蛋。",
