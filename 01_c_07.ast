				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我们在用新液晶验证它们带来的工业利益以及观察它们之间的相互关系所带来的经济影响对吧哥哥？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我們在用新液晶驗證它們帶來的工業利益以及觀察它們之間的相互關係所帶來的經濟影響對吧哥哥？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00098",
		linknext = "0008_00100",
		line = 1210,
	},
	["0008_00100"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, el efecto recípro... Recíproc... ahh, ¡lo que dijo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对对，相互关系！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對對，相互關係！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00099",
		linknext = "0008_00101",
		line = 1222,
	},
	["0008_00101"] = {
		{"se", id=1, loop=0, file="se_d004"},
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="nanase_02m_00002", file1="nanase_02m_00115", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0221", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hmm, ¿de verdad? Suena complicado... Esperen, ¿oyen algo extraño en esta habitación?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……在想很难的事情呢……刚刚这个房间有发出奇怪的声音吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……在想很難的事情呢……剛剛這個房間有發出奇怪的聲音嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00100",
		linknext = "0008_00102",
		line = 1239,
	},
	["0008_00102"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Serán las personas que follan con tanta pasión en las calles?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不知道呢，可能是岛上的人正在激烈做爱吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不知道呢，可能是島上的人正在瘋狂做愛吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00101",
		linknext = "0008_00103",
		line = 1251,
	},
	["0008_00103"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
