	["0008_00107"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00104", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0335", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Y su entrepierna aún más...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“主要是我哥哥的裤裆——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「主要是我哥哥的褲襠——」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00106",
		linknext = "0008_00108",
		line = 1323,
	},
	["0008_00108"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00104", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0224", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Es no es como que, peligroso? ¿Por qué ponen esto en la habitación de un chico?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那不是超级危险的吗……为什么它会出现在普通男生的房间里啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那不是超級危險的嗎……為什麼它會出現在普通男生的房間裡啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00107",
		linknext = "0008_00109",
		line = 1337,
	},
	["0008_00109"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Es lo que hace un hombre!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有就是有！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有就是有！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00108",
		linknext = "0008_00110",
		line = 1349,
	},
	["0008_00110"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0336", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Es más, creo que la mayoría de chicos tendrían algo así en sus habitaciones!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“应该说大多数男生的家里都是这样的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「應該說大多數男生的家裡都是這樣的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00109",
		linknext = "0008_00111",
		line = 1362,
	},
	["0008_00111"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0225", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí que se entienden muy bien... En fin, si tanto te preocupa, no lo tocaré.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你们感情真好……好吧，如果是这样我就不碰它了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你們感情真好……好吧，如果是這樣我就不碰它了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00110",
		linknext = "0008_00112",
		line = 1378,
	},
	["0008_00112"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se levanta y se lleva las manos a las caderas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"弯下腰的奈奈濑站了起来，双手放在腰上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彎下腰的奈奈瀨站了起來，雙手放在腰上。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00111",
		linknext = "0008_00113",
		line = 1389,
	},
	["0008_00113"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0226", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lo siento, pero tengo que pedirles un favor. Me faltan ingredientes para la sopa de consomé que voy a prepararles en la cena.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“抱歉。我有事情想拜托橘兄妹。晚餐材料的高汤块用完了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「抱歉。我有事情想拜託橘兄妹。晚餐材料的高湯塊用完了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00112",
		linknext = "0008_00114",
		line = 1406,
	},
	["0008_00114"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Sopa de consomé?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“高汤？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「高湯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00113",
		linknext = "0008_00115",
		line = 1418,
	},
	["0008_00115"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0227", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Estaba pensando en preparar pot-au-feu hoy, pero se me olvidaron los cubitos de consomé, y los necesito para hacerlo.\n¿Podrían comprarlos por mí si no les molesta?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我原先想做火上锅的，但却忘了最重要的高汤块……能帮我买来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我原先想做火上鍋的，但卻忘了最重要的高湯塊……能幫我買來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00114",
		linknext = "0008_00116",
		line = 1432,
	},
	["0008_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Pot-au-feu?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“火上锅？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「火上鍋？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00115",
		linknext = "0008_00117",
		line = 1443,
	},
	["0008_00117"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0228", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí, pot-au-feu. ¿Nunca lo has probado?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对，火上锅。没吃过吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對，火上鍋。沒吃過嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00116",
		linknext = "0008_00118",
		line = 1457,
	},
	["0008_00118"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Es uno de los familiares de Pol Pot?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是类似火上加油的创意料理吗——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是類似火上加油的創意料理嗎——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00117",
		linknext = "0008_00119",
		line = 1470,
	},
	["0008_00119"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00115", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0229", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“La comida no puede hacer genocidios...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么可能会有那么可怕的食物啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼可能會有那麼可怕的食物啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00118",
		linknext = "0008_00120",
		line = 1484,
	},
	["0008_00120"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0337", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bien, solo tenemos que comprar consomé, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好的，那我们只要把高汤块买来就可以了对吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好的，那我們只要把高湯塊買來就可以了對吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00119",
		linknext = "0008_00121",
		line = 1499,
	},
	["0008_00121"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0230", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lo siento, Asa-chan. ¿Podrías hacerlo por mí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“抱歉啊麻沙酱，可以拜托你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「抱歉啊麻沙醬，可以拜託你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00120",
		linknext = "0008_00122",
		line = 1513,
	},
	["0008_00122"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0338", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Déjalo en mis manos. Compraré todo el consomé del barrio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“包在我身上……我会把这附近的高汤块全买来的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「包在我身上……我會把這附近的高湯塊全買來的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00121",
		linknext = "0008_00123",
		line = 1527,
	},
	["0008_00123"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0231", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Tampoco necesito tanto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不需要那么多哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不需要那麼多哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00122",
		linknext = "0008_00124",
		line = 1541,
	},
	["0008_00124"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eh, no tan rápido, Asane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等等，别一个人乱跑麻沙音。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等等，別一個人亂跑麻沙音。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00123",
		linknext = "0008_00125",
		line = 1553,
	},
	["0008_00125"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0232", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Me sentiría mejor si la acompañaras, Jun...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过有淳跟着我就放心了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過有淳跟著我就放心了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00124",
		linknext = "0008_00126",
		line = 1567,
	},
	["0008_00126"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Primero tenemos que discutirlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为此要先从谈判开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為此要先從談判開始。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00125",
		linknext = "0008_00127",
		line = 1579,
	},
	["0008_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es importante saber cuánto vas a necesitar, hasta el último gramo. Si vas a una tienda buscando consomé, te pueden cobrar lo que quieran. Así es como estafan a la gente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“购买的克数是关键。不能因为被对方知道我们需要高汤块而被看出破绽。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「購買的克數是關鍵。不能因為被對方知道我們需要高湯塊而被看出破綻。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00126",
		linknext = "0008_00128",
		line = 1590,
	},
	["0008_00128"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00114", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0233", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Estás igual que tu hermanita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“完了，这个哥哥跟妹妹一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「完了，這個哥哥跟妹妹一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00127",
		linknext = "0008_00129",
		line = 1604,
	},
	["0008_00129"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No temas, Nanase. Tengo un don para esto. Utilicé la herencia de mis padres para negociar el precio de las judías azuki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“放心吧奈奈濑，我身上有使用了双亲的遗产在红豆原料市场上锻炼出来的‘才能’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「放心吧奈奈瀨，我身上有使用了雙親的遺產在紅豆原料市場上鍛煉出來的『才能』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00128",
		linknext = "0008_00130",
		line = 1616,
	},
	["0008_00130"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00115", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0234", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pero ¿no fallecieron tus padres hace poco?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你父母过世是最近的事情吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你父母過世是最近的事情吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00129",
		linknext = "0008_00131",
		line = 1630,
	},
	["0008_00131"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0339", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Fue muy duro para nosotros. Perdí como un millón de yenes en el mercado de divisas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那个时候真的很难熬，因为在炒外汇上赔掉了100万日元左右。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那個時候真的很難熬，因為在炒外匯上賠掉了100萬日元左右。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00130",
		linknext = "0008_00132",
		line = 1644,
	},
	["0008_00132"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00103", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0235", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Cometiste un gran error en pocos meses!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“才几个月就大赔了不是吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「才幾個月就大賠了不是嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00131",
		linknext = "0008_00133",
		line = 1659,
	},
	["0008_00133"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Después de eso, hubo un rey excéntrico en algún país cuyo nombre no recuerdo que acabó renunciando al trono, y antes de darme cuenta, volví a obtener beneficios.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后因为不知道是哪个国家的国王退位了等我发现的时候又赚了一笔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後因為不知道是哪個國家的國王退位了等我發現的時候又賺了一筆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00132",
		linknext = "0008_00134",
		line = 1671,
	},
	["0008_00134"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00120", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0236", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No quiero ni imaginar cómo hiciste eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“完全无法理解为什么会赢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「完全無法理解為什麼會贏……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00133",
		linknext = "0008_00135",
		line = 1685,
	},
	["0008_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase se llevó la mano a la cabeza y suspiró.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑无奈地摇着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨無奈地搖著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00134",
		linknext = "0008_00136",
		line = 1695,
	},
	["0008_00136"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0237", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, no necesito mucho consomé para hacer un pot-au-feu. Tranquilos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那个，嗯。不需要很多高汤块我也能做火上锅的。所以没事的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那個，嗯。不需要很多高湯塊我也能做火上鍋的。所以不要緊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00135",
		linknext = "0008_00137",
		line = 1709,
	},
	["0008_00137"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么嘛，原来是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼嘛，原來是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00136",
		linknext = "0008_00138",
		line = 1721,
	},
	["0008_00138"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[5000] = {
				{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0238", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Voy a necesitar como una cosa nada más. No dos, una. Ah, y cuando digo una cosa, no me refiero a una caja entera. Me basta con un paquete pequeño.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以高汤块只要一颗就可以了，买一盒就够了。啊，我说的一盒不是一整盒纸箱哦。是那种市场上零售的一盒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以高湯塊只要一顆就可以了，買一盒就夠了。啊，我說的一盒不是一整盒紙箱哦。是那種市場上零售的一盒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00137",
		linknext = "0008_00139",
		line = 1736,
	},
	["0008_00139"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0340", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Vaya, tampoco tienes que decirlo así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不用说得那么复杂啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不用說得那麼複雜啦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00138",
		linknext = "0008_00140",
		line = 1750,
	},
	["0008_00140"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, no somos niños.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们又不是小孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們又不是小孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00139",
		linknext = "0008_00141",
		line = 1762,
	},
	["0008_00141"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00114", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0239", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Estaban dispuestos a comprar tiendas enteras, así que mejor no me arriesgo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你们都打算把全部买下来了，当然当你们是小孩子啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你們都打算把全部買下來了，當然當你們是小孩子啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00140",
		linknext = "0008_00142",
		line = 1776,
	},
	["0008_00142"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, no importa. Necesitas este consomé para hacer la cena, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之，没有高汤块就做不了饭对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之，沒有高湯塊就做不了飯對嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00141",
		linknext = "0008_00143",
		line = 1788,
	},
	["0008_00143"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00116", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0240", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí. Odio tener que pedirle esto a mi empleador, pero... ¿me puedes hacer el favor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是的，所以虽然拜托雇主有点不好意思……但可以拜托你们吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是的，所以雖然拜託雇主有點不好意思……但可以拜託你們嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00142",
		linknext = "0008_00144",
		line = 1802,
	},
	["0008_00144"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está bien. Normalmente no haría nada por una estúpida zorra gyaru, pero puedo hacer una excepción para la cena.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真拿你没办法。我本来没有责任要帮助下流的该死辣妹婊做事，但吃饭是另一回事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真拿你沒辦法。我本來沒有責任要幫助下流的該死辣妹婊做事，但吃飯是另一回事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00143",
		linknext = "0008_00145",
		line = 1814,
	},
	["0008_00145"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00104", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0241", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Cuando quiera un editorial tuyo, te lo pediré.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这些话不需要讲！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這些話不需要講！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00144",
		linknext = "0008_00146",
		line = 1828,
	},
	["0008_00146"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien, ¿me acompañas, Asa-chan? Es peligroso ir solo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，我和麻沙酱一起去吧。一个人行动很危险。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好，我和麻沙醬一起去吧。一個人行動很危險。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00145",
		linknext = "0008_00147",
		line = 1840,
	},
	["0008_00147"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00121", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0341", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡No me importa! ¡Si puedo serle útil a Nanase-san aunque sea una vez, derribaré esa puerta y lo haré enseguida!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我才不管，如果能帮到奈奈濑同学我现在就能飞奔出去——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我才不管，如果能幫到奈奈瀨同學我現在就能飛奔出去——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00146",
		linknext = "0008_00148",
		line = 1855,
	},
	["0008_00148"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Te veo muy motivada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真牛逼的斗志。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「鬥志真高。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00147",
		linknext = "0008_00149",
		line = 1867,
	},
	["0008_00149"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0242", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Vale, me quedaré aquí y me encargaré de ordenar el lugar. Tengan cuidado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那我先去清扫和整理东西，拜托你们了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
