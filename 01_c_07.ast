	},
	["0008_00185"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0248", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ay, por favor. Era muy obvio. O sea, ¿debajo de la cama y \ndetrás del casillero? ¡A ver si puedes limpiar una habitación sin meterte en esos sitios!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不是，根本就一目了然啊……比如床铺下面、柜子后面……在清扫的时候，呵呵，一下就发现了呀……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不是，根本就一目了然啊……比如床鋪下面、櫃子後面……在清掃的時候，呵呵，馬上就發現了呀……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00184",
		linknext = "0008_00186",
		line = 2408,
	},
	["0008_00186"] = {
