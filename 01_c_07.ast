		linkback = "0008_00180",
		linknext = "0008_00182",
		line = 2358,
	},
	["0008_00182"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Por qué te aguantas la risa?! ¡Vamos! ¡Ríete, zorra!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你别笑着蒙混过去要做就认真做！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你別笑著蒙混過去要做就認真做！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00181",
		linknext = "0008_00183",
		line = 2370,
	},
	["0008_00183"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00102", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0247", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Por favor, Jun! ¡Me sorprende lejos que fuiste para esconder esas cosas! No puedes negar que es bastante divertido...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“因为淳那么努力地想要藏起来……所以让我觉得很有趣……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為淳那麼努力地想要藏起來……所以讓我覺得很有趣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00182",
		linknext = "0008_00184",
		line = 2384,
	},
	["0008_00184"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
