		{"text"},
		text = {
			vo = {
				{"vo", file="asane0334", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Solo estamos probando cómo se comportan los últimos avances tecnológicos en pantallas LCD y admirando a las empresas que las producen, al tiempo que consideramos los efectos recíprocos que están teniendo en la economía, ¿no es \nasí?”",
