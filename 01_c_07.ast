	},
	["0008_00262"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además, pronto será verano. En la Isla Seiran, en más de un sentido, es la estación más caliente del año...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且马上就要夏天了。对青蓝岛而言，最热最激烈的季节——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且馬上就要夏天了。對青藍島而言，最熱最激烈的季節——」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00261",
		linknext = "0008_00263",
		line = 3377,
	},
	["0008_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El número de personas que buscan sexo pervertido aumentará en verano.",
					{"rt2"},
				},
			},
			cn = {
				{
					"夏天来临时，将有更多人来此寻求性爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"夏天來臨時，將有更多人來此尋求性愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00262",
		linknext = "0008_00264",
		line = 3387,
	},
	["0008_00264"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A medida que aumente el número de personas, aumentará la probabilidad de que pidan sexo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人越多，被要求做爱的概率就越高。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人越多，被要求做愛的概率就越高。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00263",
		linknext = "0008_00265",
		line = 3397,
	},
	["0008_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seguramente aumentará el número de guardias de la OSS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO的警卫也会按比例增加吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO的警衛也會按比例增加吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00264",
		linknext = "0008_00266",
		line = 3407,
	},
	["0008_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Todo eso significa que esta isla se volverá mucho más peligrosa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"危险程度将与现在完全不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"危險程度將和現在完全不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00265",
		linknext = "0008_00267",
		line = 3417,
	},
	["0008_00267"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además, a ella sí le gustan las chicas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她喜欢的是女孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她喜歡的是女孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00266",
		linknext = "0008_00268",
		line = 3429,
	},
	["0008_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las orientaciones sexuales sin normativa nunca son consideradas por la gente de esta isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但这个岛根本不顾虑有这种性倾向的人类。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但這個島根本不顧慮有這種性傾向的人類。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00267",
		linknext = "0008_00269",
		line = 3439,
	},
	["0008_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque termine en un trío, va a tener que hacerlo con hombres y mujeres.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算想做也会变成3P，而且绝对是以男人和女人为前提。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算想做也會變成3P，而且絕對是以男人和女人為前提。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00268",
		linknext = "0008_00270",
		line = 3449,
	},
	["0008_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y desde luego que no se preocupan por gente como yo que quiere evitar las actividades procreativas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后也不顾虑像我这样忌讳性行为的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後也不顧慮像我這種忌諱性行為的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00269",
		linknext = "0008_00271",
		line = 3459,
	},
	["0008_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Puedo entender que se dé prioridad a la mayoría por motivos económicos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了钱而优先考虑多数派是可以理解的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了錢而優先考慮多數派是可以理解的。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00270",
		linknext = "0008_00272",
		line = 3469,
	},
	["0008_00272"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero lo que no puedo aceptar no es solo la exclusión deliberada de las minorías, sino que se finja que ni siquiera existen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，排除少数派——应该说直接否定少数派存在的行为，我是不会原谅的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，排除少數派——應該說直接否定少數派存在的行為，我是不會原諒的。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00271",
		linknext = "0008_00273",
		line = 3479,
	},
	["0008_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es por esto que me niego a aceptar la “ley del sexo pervertido”.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是我为什么不能接受“变态条例”的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是我為什麼不能接受「變態條例」的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00272",
