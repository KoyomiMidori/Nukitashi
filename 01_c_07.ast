		linkback = "0008_00102",
		linknext = "0008_00104",
		line = 1268,
	},
	["0008_00104"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=6, size=5, time=50, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
