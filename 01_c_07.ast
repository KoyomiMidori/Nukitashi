	["0008_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fue ahí cuando Asa-chan me echó una mano; consiguió cristal \nlíquido como nuevo rebuscando entre prototipos rechazados que pertenecían al laboratorio de investigación de algún país extranjero.",
