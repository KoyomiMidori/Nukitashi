					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Cómo las encontraste?! ¡Las escondí bien, ¿no?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是怎么发现的！？我不是藏起来了吗？”",
					{"rt2"},
