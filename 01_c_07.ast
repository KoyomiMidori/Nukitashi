		text = {
			vo = {
				{"vo", file="nanase0259", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Eso dice el que me acompaña a casa otra vez?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“说是那样说，但你今天也送我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「說是那樣說，但你今天也送我嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00220",
		linknext = "0008_00222",
		line = 2896,
	},
	["0008_00222"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No seas tonta, quién le daría atención a una zorra como tú... Tengo asuntos pendientes en la oficina de correos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别说傻话了，谁要送你这样的婊子……我是有事想找那边的那个……那个邮箱啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別說傻話了，誰要送你這樣的婊子……我是有事想找那邊的那個……那個郵箱啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00221",
		linknext = "0008_00223",
		line = 2908,
	},
	["0008_00223"] = {
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0260", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya veo. Bueno, si tú lo dices...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样啊，你说怎样就是怎样吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣啊，你說怎樣就是怎樣吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00222",
		linknext = "0008_00224",
		line = 2923,
	},
	["0008_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sigo murmurando quejas mientras hablo con ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我想说些隐晦的话来反击，但大概说不过她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我想說些隱晦的話來反擊，但大概說不過她。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00223",
		linknext = "0008_00225",
		line = 2933,
	},
	["0008_00225"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0261", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jeje, perdón por tomarte del pelo hoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵，对不起哦，我今天做了恶作剧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呵呵，對不起哦，我今天做了點惡作劇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00224",
		linknext = "0008_00226",
		line = 2948,
	},
	["0008_00226"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues sí. Me imagino que ni te sientes mal por ello.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你真的有觉得对不起吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你真的有覺得對不起嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00225",
		linknext = "0008_00227",
		line = 2960,
	},
	["0008_00227"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=5500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0262", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Solo era una pequeña broma, pero tu respuesta fue mucho más tierna de lo que esperaba. Jejeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我本来只是打算开一个小玩笑，但淳比我想像得还要可爱，所以就，呵呵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我本來只是打算開一個小玩笑，但淳比我想像得還要可愛，所以就，呵呵。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00226",
		linknext = "0008_00228",
		line = 2975,
	},
	["0008_00228"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Me acabas de dar la razón!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你根本不觉得对不起吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你根本不覺得對不起吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00227",
		linknext = "0008_00229",
		line = 2987,
	},
	["0008_00229"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0263", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Perdón, no lo volveré a hacer. A partir de ahora no entraré en tu habitación sin tu permiso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对不起对不起，我再也不会那样了。未经允许我不会进入房间的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對不起對不起，我再也不會那樣了。未經允許我不會進入房間的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00228",
		linknext = "0008_00230",
		line = 2999,
	},
	["0008_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo dice como si de una promesa se tratara.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑向我保证。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨向我保證。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00229",
		linknext = "0008_00231",
		line = 3009,
	},
	["0008_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siendo así, seguramente lo dice en serio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙都说到这个地步了，大概是真的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙都說到這個地步了，大概是真的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00230",
		linknext = "0008_00232",
		line = 3019,
	},
	["0008_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es de las que niegan una promesa. Aunque hace poco nos conocimos, lo sé muy bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她不是那种说话不守信用的人……在这短暂的相处中，我清楚得知了这一点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她不是那種說話不守信用的人……在這短暫的相處中，我清楚得知了這一點。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00231",
		linknext = "0008_00233",
		line = 3029,
	},
	["0008_00233"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Más vale que no estés mintiendo. No puedo confiar en una zorra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这话不是谎言吧？因为婊子有点难信任。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這話不是謊言吧？因為婊子有點難信任。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00232",
		linknext = "0008_00234",
		line = 3041,
	},
	["0008_00234"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0264", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Entonces qué? ¿Quieres despedirme y contratar a otro para que se ocupe de la casa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那不然要怎样？要解雇我去找其他家务代理服务吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那不然要怎樣？要解僱我去找其他家事代理服務嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00233",
		linknext = "0008_00235",
		line = 3055,
	},
	["0008_00235"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me encantaría, pero lamentablemente, mi hermana se está muriendo de amor por ti.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也想这样做，但是我妹妹非常喜欢你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也想這樣做，但我妹妹愛你愛得要死……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00234",
		linknext = "0008_00236",
		line = 3067,
	},
	["0008_00236"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0265", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jeje. ¿Me guardas algún rencor fraternal por eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嘻嘻，身为哥哥的你对此感到不爽是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嘻嘻，身為哥哥的你對此感到不爽是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00235",
		linknext = "0008_00237",
		line = 3082,
	},
	["0008_00237"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo un poquito. Aun así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是当然。不过——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是當然。不過——」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00236",
		linknext = "0008_00238",
		line = 3094,
	},
	["0008_00238"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Reconozco que mi hermana ha estado mucho más alegre desde que llegaste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——自从你来之后，妹妹变得更开朗了也是事实。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——自從你來之後，妹妹變得更開朗了也是事實。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00237",
		linknext = "0008_00239",
		line = 3106,
	},
	["0008_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se la ha pasado llorando desde que perdimos a nuestros padres.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一下子失去了双亲，让麻沙音常把自己关在房里哭泣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一下子失去了雙親，讓麻沙音常把自己關在房裡哭泣。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00238",
		linknext = "0008_00240",
		line = 3116,
	},
	["0008_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero la influencia de Nanase ha sido lo suficientemente poderosa como para traer de vuelta a la Asa-chan feliz, y no solo por fuera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而现在麻沙音能不光是表面上，而是在真正意义上恢复到以往的样子，有很大部分是奈奈濑的功劳。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而現在麻沙音能不光是表面上，而是在真正意義上恢復到以往的樣子，有很大部分是奈奈瀨的功勞。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00239",
		linknext = "0008_00241",
		line = 3126,
	},
	["0008_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cocinarnos comidas deliciosas, mantener nuestra casa ordenada... Hacer todo eso sirve inconscientemente para quitarnos un peso de encima.",
					{"rt2"},
				},
			},
			cn = {
				{
					"美味的食物、干净的房间，使压力在不知不觉中被消除了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"美味的食物、乾淨的房間，使壓力在不知不覺中被消除了。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00240",
		linknext = "0008_00242",
		line = 3136,
	},
	["0008_00242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde que a nuestras vidas llegó la figura de una responsable hermana mayor, Asa-chan se ha sentido mucho mejor, tanto mental como emocionalmente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像出现了一个可靠的姐姐，让其得到了精神上的救赎——大概是这种感觉吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像出現了一個可靠的姐姐，讓其得到了精神上的救贖——大概是這種感覺吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00241",
		linknext = "0008_00243",
		line = 3146,
	},
	["0008_00243"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Dudo que un hermano mayor pudiera lograrlo solo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那可是身为哥哥的我没办法一个人办到的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那可是身為哥哥的我沒辦法一個人辦到的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00242",
		linknext = "0008_00244",
		line = 3158,
	},
	["0008_00244"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gracias, Nanase... Nos has ayudado bastante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你，奈奈濑……多亏了你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你，奈奈瀨……多虧了你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00243",
		linknext = "0008_00245",
		line = 3170,
	},
	["0008_00245"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00120", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6500] = {
				{"fg", file="nanase_02m_00002", file1="nanase_02m_00107", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0266", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mm... Me estás haciendo sonrojar con eso que me dices... Sé lo mucho que quieres a tu hermanita, Jun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……被你直接夸奖还真有点害羞呢……麻沙酱对淳来说真的很重要呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……被你直接誇獎還真有點害羞呢……麻沙醬對淳來說真的很重要呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00244",
		linknext = "0008_00246",
		line = 3186,
	},
	["0008_00246"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se queda mirando a lo lejos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑望向远处说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨望向遠處說道。",
					{"rt2"},
				},
			},
