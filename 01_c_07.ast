		line = 3196,
	},
	["0008_00247"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tiene razón. Asa-chan es mi querida hermanita.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的，麻沙音是我重要的妹妹。",
