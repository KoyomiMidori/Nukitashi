					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya, ya. No hay que enojarse tanto. El pot-au-feu está listo, así que vamos a comer. Hoy también hay pan de ajo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好了好了，不要那么生气了……火上锅做好了我们来吃饭吧。今天吃蒜香吐司。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好了好了，不要那麼生氣了……火上鍋做好了我們來吃飯吧。今天吃蒜香吐司。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00206",
		linknext = "0008_00208",
		line = 2689,
	},
