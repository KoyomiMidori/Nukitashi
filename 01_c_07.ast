					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Qué hago ahora que la aplicación me ignora por completo y el hardware no se apaga por más que lo fuerce...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
