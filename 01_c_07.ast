		linkback = "0008_00037",
		linknext = "0008_00039",
		line = 440,
	},
	["0008_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque creé la carcasa exterior mediante impresión 3D, mi impresora es demasiado básica para manejar el cristal líquido y los componentes que irían en el interior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然外部骨架是用3D打印机制作的，但液晶之类的就不能用我的便宜打印机制作了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然外部骨架是用3D列印機製作的，但液晶之類的就不能用我的便宜列印機製作了。",
					{"rt2"},
				},
