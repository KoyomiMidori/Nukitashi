					name = {"麻沙音", "Asane"},
					"“Entonces podría sonreírme dulcemente y decirme “si te interesa esto qué tal si lo pruebas” y se llevaría la mano a mi \ncoño para sentir que ya está húmedo y...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“然后露出妖艳的笑容说道‘你这么有兴趣的话就试一试吧’一边把手伸向被薄薄的衣物遮挡着却稍微湿润的蜜穴——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「然後露出妖豔的笑容說道『你這麼有興趣的話就試一試吧』一邊把手伸向被薄薄的衣物遮擋著卻稍微濕潤的蜜穴——」",
					{"rt2"},
				},
			},
		},
