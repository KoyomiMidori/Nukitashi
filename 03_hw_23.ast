		linkback = "0073_00037",
		linknext = "0073_00039",
		line = 427,
	},
	["0073_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I couldn't accept it as reality, and I refused to believe it. I think the trauma caused me to block the memory.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是因为我无法接受，无法相信这就是现实，而抗拒去记住。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是因為我無法接受，無法相信這就是現實，而抗拒去記住。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00038",
		linknext = "0073_00040",
		line = 437,
	},
	["0073_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, what I do remember is weeping uncontrollably in bed that night. It just hurt so much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"唯一清楚记得的，是那天晚上痛得在被窝里哭泣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"唯一清楚記得的，是那天晚上痛得在被窩裡哭泣。",
					{"rt2"},
				},
