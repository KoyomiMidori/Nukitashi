	["0073_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even so, though, I didn't know if I liked the person I was becoming.",
					{"rt2"},
