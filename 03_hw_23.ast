	["0073_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Where did it go?",
					{"rt2"},
				},
			},
			cn = {
				{
					"————我的椅子在哪里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"————我的椅子在哪裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00102",
		linknext = "0073_00104",
		line = 1126,
	},
	["0073_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The classroom was silent for a moment, but no one offered a response.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一瞬间，教室安静了下来，但没有一个人告诉我答案。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一瞬間，教室安靜了下來，但沒有一個人告訴我答案。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00103",
		linknext = "0073_00105",
		line = 1136,
	},
	["0073_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They resumed their idle chatting shortly after.",
					{"rt2"},
				},
			},
			cn = {
				{
					"闲谈马上重新开始。",
					{"rt2"},
				},
			},
			tw = {
				{
					"閒談馬上重新開始。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00104",
		linknext = "0073_00106",
		line = 1146,
	},
	["0073_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could hear scattered laughter, and I believed it was all directed at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"四处传来的笑声，感觉都是冲着我的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"四處傳來的笑聲，感覺都是衝著我的。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00105",
		linknext = "0073_00107",
		line = 1156,
	},
	["0073_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was when my heart finally broke.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时，我的内心终于崩溃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時，我的內心終於崩潰了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00106",
		linknext = "0073_00108",
		line = 1166,
	},
	["0073_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even after I fled the mainland, I even found myself ostracized here. There was nowhere I could feel like I belonged.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从本岛逃了出来，结果在青蓝岛也被排斥，我想，哪里都没有我的立足之地了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從本島逃了出來，結果在青藍島也被排斥，我想，哪裡都沒有我的立足之地了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00107",
		linknext = "0073_00109",
		line = 1176,
	},
	["0073_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn't want them to see me cry. I didn't want them to see my weakness. I couldn't stand it, and the tears were welling up...",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明决定不在他人面前哭泣，决定不在这样的家伙们面前表现出软弱，但我却无法忍受，大颗大颗的眼泪掉了下来——",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明決定不在他人面前哭泣，決定不在這樣的傢伙們面前表現出軟弱，但我卻無法忍受，大顆大顆的眼淚掉了下來——",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00108",
		linknext = "0073_00110",
		line = 1186,
	},
	["0073_00110"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1733", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "???"},
					"“Use this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "？ ？ ？"},
					"“用这个吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "？？？"},
					"「用這個吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00109",
		linknext = "0073_00111",
		line = 1198,
	},
	["0073_00111"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0749", path=":vo/", ch="rei"},
