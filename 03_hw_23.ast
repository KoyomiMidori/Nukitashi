	["0073_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hadn't yet reached the sexual maturity age where the law applies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时我还没有达到条例的对象年龄。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時我還沒有達到條例的對象年齡。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00040",
		linknext = "0073_00042",
		line = 457,
	},
	["0073_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But, even though I wasn't required by the law to start having sex, my mom said I had to do it anyway if people told me to. She said I could save everyone that way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以其实应该还不能做爱，但是母亲说如果我做爱，大家就会得救，所以我就照她说的做了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以其實應該還不能做愛，但是母親說如果我做愛，大家就會得救，所以我就照她說的做了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00041",
		linknext = "0073_00043",
		line = 467,
	},
	["0073_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But apparently they didn't see me as satisfactory.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我的评价似乎不好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我的評價似乎不好。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00042",
		linknext = "0073_00044",
		line = 477,
	},
	["0073_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn't make any sounds, and it was plainly clear that I wasn't enjoying it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为我连声音都不发出，满脸都渗透着厌恶感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為我連聲音都不發出，滿臉都滲透著厭惡感。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00043",
		linknext = "0073_00045",
		line = 487,
	},
	["0073_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They saw me as worthless, so my mom abused me more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲骂我这样很不像话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親罵我這樣很不像話。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00044",
		linknext = "0073_00046",
		line = 497,
	},
	["0073_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She said that if my little brother and sister ended up homeless, it would be my fault.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不想因为自己的错而让弟弟妹妹流落街头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不想因為自己的錯而讓弟弟妹妹流落街頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00045",
		linknext = "0073_00047",
		line = 507,
	},
	["0073_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I studied desperately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以我拼命学习了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以我拼命學習了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00046",
		linknext = "0073_00048",
		line = 517,
	},
	["0073_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I observed the islanders to learn what sounds I should make and what I should be saying to turn them on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我观察岛上的人，学习他们发出什么样的声音，说什么样的话，才能让对方兴奋。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我觀察島上的人，學習他們發出什麼樣的聲音，說什麼樣的話，才能讓對方興奮。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00047",
		linknext = "0073_00049",
		line = 527,
	},
	["0073_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wasn't good at it, but tackling my weaknesses and trying to improve was something I was always good at.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我并不精明，但很擅长踏实努力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我並不精明，但很擅長踏實努力。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00048",
		linknext = "0073_00050",
		line = 537,
	},
	["0073_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Their responses obviously improved when I started imitating what I'd seen and heard from others.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我尝试着模仿学会的技巧，评价显而易见地变好了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我嘗試著模仿學會的技巧，評價顯而易見地變好了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00049",
		linknext = "0073_00051",
		line = 547,
	},
	["0073_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I made incredible amounts of money that way, and I was finally able to buy beautiful clothes like the ones I always saw in manga.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我拿到了多到难以置信的钱，穿上了只能在漫画中看到的漂亮衣服。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我拿到了多到難以置信的錢，穿上了只能在漫畫中看到的漂亮衣服。",
