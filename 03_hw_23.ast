	["0073_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shortly afterwards, I learned what Seiran Island really was.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后，我马上了解了青蓝岛的事情。",
					{"rt2"},
