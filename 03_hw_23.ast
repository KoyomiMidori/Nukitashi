		linkback = "0073_00053",
		linknext = "0073_00055",
		line = 591,
	},
	["0073_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though my classmates at the time were underaged for the law, they still engaged in sex 'play' in secret.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时候的同班同学，即使还没有达到条例对象年龄，也在偷偷地玩着名为性爱的“游戏”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時候的同班同學，即使還沒有達到條例對象年齡，也在偷偷地玩著名為性愛的「遊戲」。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00054",
		linknext = "0073_00056",
		line = 601,
	},
	["0073_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The way they saw it, while it was forbidden for an adult to have sex with an underage child, that didn't mean that children couldn't have sex with each other.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有到达条例的对象年龄的孩子是禁止做爱的，但没有条例禁止孩子们之间的性爱——这是他们的说法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有到達條例的對象年齡的孩子是禁止做愛的，但沒有條例禁止孩子們之間的性愛——這是他們的說法。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00055",
		linknext = "0073_00057",
		line = 611,
	},
	["0073_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I learned that I could join the SS once I reached the B-level classes, so I started striving to be an exemplary student.",
					{"rt2"},
				},
			},
			cn = {
				{
					"进入B等部之后被推荐加入FS的我，从那时起打算成为认真的模范生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"進入B等部之後被推薦加入FS的我，從那時起打算成為認真的模範生。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00056",
		linknext = "0073_00058",
		line = 621,
	},
	["0073_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I took it upon myself to reprimand my peers for breaking regulations, which naturally led to me immediately being ostracized. I became even more isolated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无视自身行为谴责违反条例的他人，其结果是理所当然地转眼间就被孤立了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無視自身行為譴責違反條例的他人，其結果是理所當然地轉眼間就被孤立了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00057",
		linknext = "0073_00059",
		line = 631,
	},
	["0073_00059"] = {
