	},
	["0073_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought that no one paid any attention to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我以为没有人在关注我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我以為沒有人在關注我。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00123",
		linknext = "0073_00125",
		line = 1356,
	},
	["0073_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even my own mother never gave me sincere praise like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是母亲，也一次都没对我说过“你真努力”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是母親，也一次都沒對我說過「你真努力」。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00124",
		linknext = "0073_00126",
		line = 1366,
	},
	["0073_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But, faced with those kind words, I couldn't hold back the floodgates.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那样的情况下，她对我说了温柔的话——这让我抑制不住复杂的情感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那樣的情況下，她對我說了溫柔的話——這讓我抑制不住複雜的情感。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00125",
		linknext = "0073_00127",
		line = 1376,
	},
	["0073_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess that was all I always wanted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我应该一直很希望被别人这么说吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我應該一直很希望被別人這麼說吧。",
					{"rt2"},
				},
			},
		},
