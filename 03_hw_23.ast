		linkback = "0073_00023",
		linknext = "0073_00025",
		line = 283,
	},
	["0073_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For reasons that I still don't understand to this day, he'd accumulated massive amounts of debt.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然现在已经不知道原因了，但是那时父亲背负了很多的债务。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然現在已經不知道原因了，但是那時父親背負了很多的債務。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00024",
		linknext = "0073_00026",
		line = 293,
	},
	["0073_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"People would come banging on our door late at night. Those days were hell.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每晚公寓的门都被敲响，地狱般的日子开始了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每晚公寓的門都被敲響，地獄般的日子開始了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00025",
		linknext = "0073_00027",
		line = 303,
	},
	["0073_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'd gently hold my crying brother and sister in my arms and whisper soothing words to them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我双手抱着快要哭出来的弟弟妹妹，小声地说着温柔的话语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我雙手抱著快要哭出來的弟弟妹妹，小聲地說著溫柔的話語。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00026",
		linknext = "0073_00028",
		line = 313,
	},
	["0073_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On top of that, just because our dad was gone didn't mean we didn't get beaten. Mom started doing it instead.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不久，母亲就像死去的父亲附身了一样，对我们行使暴力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不久，母親就像死去的父親附身了一樣，對我們行使暴力。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00027",
		linknext = "0073_00029",
		line = 323,
	},
	["0073_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As the older sister, I thought it was my job to protect my little brother and sister, no matter what we went through. I'd shield them from our mother.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论多么难受也要作为姐姐保护弟弟妹妹，所以我总是站在最前面挨打。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論多麼難受也要作為姐姐保護弟弟妹妹，所以我總是站在最前面挨打。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00028",
		linknext = "0073_00030",
		line = 333,
	},
	["0073_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just endured it all. I told myself that life has its hard times, and this would pass.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人生也有痛苦的时候，我总是这样对自己说，忍耐着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人生也有痛苦的時候，我總是這樣對自己說，忍耐著。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00029",
		linknext = "0073_00031",
		line = 343,
	},
	["0073_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was on one of these days that I came home from school, and my mom greeted me with a broad grin. She had an unfamiliar man beside her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有一天，从学校回来时，母亲笑眯眯地迎接了我。旁边站着一个不认识的男人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有一天，從學校回來時，母親笑瞇瞇地迎接了我。旁邊站著一個不認識的男人。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00030",
		linknext = "0073_00032",
		line = 353,
	},
	["0073_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was the first time I heard the name Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时候，我才第一次听到“青蓝岛”这个名字。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時候，我才第一次聽到「青藍島」這個名字。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00031",
		linknext = "0073_00033",
		line = 363,
	},
	["0073_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mom excitedly told me that going there would make my life better. It would let me escape from all I'd been suffering through.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲高兴地告诉我，只要去那里，就能从这种艰苦的生活中解放出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親高興地告訴我，只要去那裡，就能從這種艱苦的生活中解放出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00032",
		linknext = "0073_00034",
		line = 373,
	},
	["0073_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Finally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——终于。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——終於。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00033",
		linknext = "0073_00035",
		line = 383,
	},
	["0073_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I started crying out of happiness. It was like my fairy godmother had finally appeared.",
					{"rt2"},
				},
			},
			cn = {
				{
					"魔法师终于出现在灰姑娘面前了——得到回报了——我不由自主地流下了眼泪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"魔法師終於出現在灰姑娘面前了——得到回報了——我不由自主地流下了眼淚。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00034",
		linknext = "0073_00036",
		line = 393,
	},
	["0073_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What a fool I was.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但，我终究还是太愚蠢了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但，我終究還是太愚蠢了。",
					{"rt2"},
				},
