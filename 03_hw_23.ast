	},
	["0073_00112"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1734", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "???"},
					"“You lost your chair, right? Use this one!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "？ ？ ？"},
					"“你椅子不见了吧？我的这个借你！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "？？？"},
					"「你椅子不見了吧？我的這個借你！」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00111",
		linknext = "0073_00113",
		line = 1222,
	},
	["0073_00113"] = {
		{"se", id=0, loop=0, file="se_a156"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That amicable, innocent-looking classmate said something absurd as she held out a folding chair.",
					{"rt2"},
				},
			},
			cn = {
				{
					"头脑看似很和平的同班同学，说着奇怪的话把钢管椅子递给了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"頭腦看似很和平的同班同學，說著奇怪的話把鋼管椅遞給了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00112",
		linknext = "0073_00114",
		line = 1233,
	},
	["0073_00114"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1735", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "???"},
					"“Go on, don't be shy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "？ ？ ？"},
					"“来吧来吧，不必客气啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "？？？"},
					"「來吧來吧，不必客氣啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00113",
		linknext = "0073_00115",
		line = 1245,
	},
	["0073_00115"] = {
		{"se", id=0, loop=0, file="se_a157"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was dumbfounded, but she sat me down forcibly on the chair.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她硬让呆住的我坐到钢管椅子上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她硬讓呆住的我坐到鋼管椅上。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00114",
		linknext = "0073_00116",
		line = 1256,
	},
	["0073_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was like a bizarre dream.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我以为自己在做奇怪的梦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我以為自己在做奇怪的夢。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00115",
		linknext = "0073_00117",
		line = 1266,
	},
	["0073_00117"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1736", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "???"},
					"“Ehehe, thank goodness. I've always wanted to talk to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "？ ？ ？"},
					"“诶嘿嘿，太好了。我一直想和礼酱说说话呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "？？？"},
					"「欸嘿嘿，太好了。我一直想和禮醬說說話呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00116",
		linknext = "0073_00118",
		line = 1278,
	},
	["0073_00118"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0750", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……为什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……為什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00117",
		linknext = "0073_00119",
		line = 1290,
	},
	["0073_00119"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1737", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "???"},
					"“Because I can see how hard you're always working! You're always trying your best, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "？ ？ ？"},
					"“因为礼酱一直在努力啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "？？？"},
					"「因為禮醬一直在努力啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00118",
		linknext = "0073_00120",
		line = 1302,
	},
	["0073_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wanted to say something in response, but the words didn't come out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想回嘴说些什么，但张开的嘴里什么话也吐不出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想回嘴說些什麼，但張開的嘴裡什麼話也吐不出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00119",
		linknext = "0073_00121",
		line = 1312,
	},
	["0073_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For the first time since I came to Seiran Island, I cried in front of someone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个时候，我来到这个岛后第一次——在他人面前哭了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個時候，我來到這個島後第一次——在他人面前哭了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00120",
		linknext = "0073_00122",
		line = 1322,
	},
	["0073_00122"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1738", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "???"},
					"“Wh-Wha!? R-Rei, are you okay!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "？ ？ ？"},
					"“哇哇！？礼、礼酱没事吧！？”",
					{"rt2"},
