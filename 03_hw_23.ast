	["0073_00004"] = {
		{"bgm", file="bgm21", vol=100},
		{"bg", id=1, file="bg26_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1500, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's been six years since Dad died.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父亲去世已经是6年前的事了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父親去世已經是6年前的事了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00003",
		linknext = "0073_00005",
		line = 75,
	},
	["0073_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Back then, all five of us lived in a small apartment in the Kanto region: myself, my parents, and my siblings.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时，我和父母、弟弟妹妹5个人住在关东的一个小公寓里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時，我和父母、弟弟妹妹5個人住在關東的一個小公寓裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00004",
		linknext = "0073_00006",
		line = 85,
	},
	["0073_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was too young to know about it back then, but we were exceptionally poor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然当时没有意识到，但现在回想起来，那是个非常贫困的家庭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然當時沒有意識到，但現在回想起來，那是個非常貧困的家庭。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00005",
		linknext = "0073_00007",
		line = 95,
	},
	["0073_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Most of my socks had holes in them, and having a side dish with meals was a luxury.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每个袜子上都有洞，吃饭时只要有配菜就已经不错了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每個襪子上都有洞，吃飯時只要有配菜就已經不錯了。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00006",
		linknext = "0073_00008",
		line = 105,
	},
	["0073_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We weren't exactly happy, either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再加上，应该也不算是个好家庭吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再加上，應該也不算是個好家庭吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00007",
		linknext = "0073_00009",
		line = 115,
	},
	["0073_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dad spent a lot of time away, but even when he was there he was either violent or asleep.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父亲经常不在家，偶尔在家也只会大声叫骂或是睡觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父親經常不在家，偶爾在家也只會大聲叫罵或是睡覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00008",
		linknext = "0073_00010",
		line = 125,
	},
	["0073_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mom would always be complaining about him, and if we ever supported him, she'd be hysterical.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲总是抱怨那样的父亲，只要我稍微替父亲说点话，她就会马上歇斯底里起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親總是抱怨那樣的父親，只要我稍微替父親說點話，她就會馬上歇斯底里起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00009",
		linknext = "0073_00011",
		line = 135,
	},
	["0073_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just to spite him, Mom didn't do any housework, so I had to take care of most of it myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为母亲为了抵抗父亲而不做家务，所以家里的事基本上都是我在做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為母親為了抵抗父親而不做家事，所以家裡的事基本上都是我在做。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00010",
		linknext = "0073_00012",
		line = 145,
	},
	["0073_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Naturally, I was going to school as well at the time, but I didn't really fit in there, either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算这样，我也上了学，但在学校里我也不怎么自在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算這樣，我也上了學，但在學校裡我也不怎麼自在。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00011",
		linknext = "0073_00013",
		line = 155,
	},
	["0073_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The other girls my age were focused on fashion and picking up guys, so they didn't have any time for me and my worn-out, childish clothes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在同年代的女孩子开始注意形象的时候，总是穿着破破烂烂的童装的我，很自然地在群体中被孤立。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在同年代的女孩子開始注意形象的時候，總是穿著破破爛爛的童裝的我，很自然地在群體中被孤立。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00012",
		linknext = "0073_00014",
		line = 165,
	},
	["0073_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The only way I got to enjoy myself was by reading shoujo manga.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时少有的乐趣就是偶尔看看少女漫画。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時少有的樂趣就是偶爾看看少女漫畫。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00013",
		linknext = "0073_00015",
		line = 175,
	},
	["0073_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There was a used bookstore in the neighborhood, run by a kind old woman who let me read manga on the weekends, even if I didn't by anything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"附近的旧书店有一位慈祥的老奶奶，休息日去玩时，即使没有钱，也会一直让我看漫画。",
					{"rt2"},
				},
			},
			tw = {
				{
					"附近的舊書店有一位慈祥的老奶奶，休息日去玩時，即使沒有錢，也會一直讓我看漫畫。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00014",
		linknext = "0073_00016",
		line = 185,
	},
	["0073_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Manga gave me an escape from my difficult life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看漫画的时候，我可以轻易忘记讨厌的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看漫畫的時候，我可以輕易忘記討厭的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00015",
		linknext = "0073_00017",
		line = 195,
	},
	["0073_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'd daydream about the love stories, and come up with my own Cinderella-like tales in my head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"憧憬着幻想中的爱情故事，梦想着终有一天自己也能遇上，在脑海里无数次想象着灰姑娘的故事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"憧憬著幻想中的愛情故事，夢想著終有一天自己也能遇上，在腦海裡無數次想像著灰姑娘的故事。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00016",
		linknext = "0073_00018",
		line = 205,
	},
	["0073_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know it was childish, but I fantasized that if I wore pretty clothes and worked hard, I could change my life, just like her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怀抱着童心的我坚信，如果能穿这么漂亮的衣服，就连我也会改变，只要努力就会有好事发生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"懷抱著童心的我堅信，如果能穿這麼漂亮的衣服，就連我也會改變，只要努力就會有好事發生。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00017",
		linknext = "0073_00019",
		line = 215,
	},
	["0073_00019"] = {
		{"bg", id=1, file="bg26_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1500, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was after returning home from that bookstore one day that I heard that my dad had died.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有一天，当我从旧书店回家时，传来了父亲去世的消息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有一天，當我從舊書店回家時，傳來了父親去世的消息。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00018",
		linknext = "0073_00020",
		line = 229,
	},
	["0073_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently he fell down the stairs in a drunken stupor, and no one found him until it was too late.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说他深夜在烂醉状态下从楼梯上摔了下来，被发现时已经为时已晚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說他深夜在爛醉狀態下從樓梯上摔了下來，被發現時已經為時已晚。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00019",
		linknext = "0073_00021",
		line = 239,
	},
	["0073_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despite how much she complained about him, our mom was wailing uncontrollably. Meanwhile, my siblings were too young to understand as they looked on, bewildered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知道为什么，发了那么多牢骚的母亲竟号啕大哭，不知道死亡的意思的弟弟妹妹只是一个劲儿地歪着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道為什麼，發了那麼多牢騷的母親竟號啕大哭，不知道死亡的意思的弟弟妹妹只是一個勁地歪著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00020",
		linknext = "0073_00022",
		line = 249,
	},
	["0073_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was disillusioned. I hadn't truly loved him for several years, so I didn't cry over him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我没有特别惊讶，因为不喜欢父亲，所以也没有哭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沒有特別驚訝，因為不喜歡父親，所以也沒有哭。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00021",
		linknext = "0073_00023",
		line = 259,
	},
	["0073_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The only thing I missed was the way he carried me on his shoulders when I was little.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是，小的时候让我坐过的肩膀——今后再也坐不了了，我这样想着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是，小的時候讓我坐過的肩膀——今後再也坐不了了，我這樣想著。",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00022",
		linknext = "0073_00024",
		line = 269,
	},
	["0073_00024"] = {
		{"bg", id=1, file="bg26_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1500, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was all I was nostalgic for, and before long I no longer had time to dwell on things like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"沉浸在过去中的只有那一次，那种从容很快就消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沉浸在過去中的只有那一次，那種從容很快就消失了。",
					{"rt2"},
				},
