	},
	["0073_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I wore pretty clothes and worked hard, I could change my life—those childish fantasies were actually coming true.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总有一天想穿漂亮的衣服，那样的话我一定也会改变的——没想到，梦想就这样实现了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總有一天想穿漂亮的衣服，那樣的話我一定也會改變的——沒想到，夢想就這樣實現了。",
					{"rt2"},
				},
