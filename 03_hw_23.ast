	["0073_00123"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0751", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Aah... uuh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……唔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
