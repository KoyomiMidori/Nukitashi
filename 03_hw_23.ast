	["0073_00038"] = {
		{"bg", id=1, file="bg25_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1500, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't even remember anymore how I first found out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第一次的事情，我完全不记得了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第一次的事情，我完全不記得了。",
					{"rt2"},
