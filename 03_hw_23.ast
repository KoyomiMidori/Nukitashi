		{"msgoff", time=1},
		{"extrans", sync=0, time=1500, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because of the work I was doing in secret, I naturally couldn't fit in at Minotsuki Academy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为在私底下做了那些事，所以当然也无法融入水乃月学园。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為在私底下做了那些事，所以當然也無法融入水乃月學園。",
					{"rt2"},
				},
