	["0098_00563"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Recuerdo haber visto a Asa-chan mirando mal a Misaki.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱用带刺的眼光看向美岬的样子，仿佛浮现在了眼前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬用帶刺的眼光看向美岬的樣子，彷彿浮現在了眼前。",
					{"rt2"},
				},
			},
		},
