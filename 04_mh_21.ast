					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now you're talking! Quick, everybody get strapped in!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你真懂！好了，大家坐进去吧！”",
