		},
		linkback = "0098_01018",
		linknext = "0098_01020",
		line = 15359,
	},
	["0098_01020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've been saying all along.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，我不是一直在说吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，我不是一直在說嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01019",
		linknext = "0098_01021",
		line = 15371,
	},
	["0098_01021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if you gave me the runaround... I rather enjoyed talking with you. I always had a feeling that you and I were kindred spirits.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算你说你在骗我……但和你聊天我很开心，手嶋先生。我以为你是可以互相理解的同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算你說你在騙我……但和你聊天我很開心，手嶋先生。我以為你是可以互相理解的同伴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01020",
		linknext = "0098_01022",
		line = 15383,
	},
	["0098_01022"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Perhaps in a different reality, if we'd met under different circumstances... I could have called you friend.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果相识的方式不同，说不定真的能成为朋友……我是这么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果相識的方式不同，說不定真的能成為朋友……我是這麼想的。」",
					{"rt2"},
				},
