				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……穿過了！沒有人追上來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00095",
		linknext = "0098_00097",
		line = 1225,
	},
	["0098_00097"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uf... Qué alivio. ¿Lograste extender tu habilidad de bloqueo de percepción para cubrir a Aikaze?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呼……太好了。美岬的气息隐藏能力扩展到爱风了吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呼……太好了。美岬的氣息隱藏能力擴展到愛風了嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00096",
		linknext = "0098_00098",
		line = 1237,
	},
	["0098_00098"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00116", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1525", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Creo que más bien es que la cosa parece ridícula para un observador y por eso no sospecharon nada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“也许只是外表太过怪异，反而让人不起疑心吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「也許只是外表太過怪異，反而讓人不起疑心吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00097",
		linknext = "0098_00099",
		line = 1250,
	},
	["0098_00099"] = {
		{"fg", file="nanase_02f_00001", file1="nanase_02f_00114", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2073", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, me alegra que esta cosa tenga el diseño que tiene.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“从某种意义上来说，这个设计或许不错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「從某種意義上來說，這個設計或許不錯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00098",
		linknext = "0098_00100",
		line = 1263,
	},
	["0098_00100"] = {
		{"se", id=1, stop=1, time=1000},
		{"fg", mode=-1, id=30, ch="奈々瀬", lv=5},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"cgact", file="cgact", id=16, act="stopact", lv=5, x=-5, y=-5},
		{"cgdel", id=16, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg10_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Escapamos de las garras del mal con el poder del amor y nos acercamos a un asentamiento cerca de la colina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"用爱情的力量穿过敌人的魔爪后，我们来到山附近的村落。",
					{"rt2"},
				},
			},
			tw = {
				{
					"用愛情的力量穿過敵人的魔爪後，我們來到山附近的村落。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00099",
		linknext = "0098_00101",
		line = 1283,
	},
	["0098_00101"] = {
		{"se", id=1, loop=1, file="se_d030", vol=60},
		{"se", id=2, loop=1, file="se_b061", vol=50},
		{"evset", file="mci_m", set="mci_m", path=":ev/mci_m/"},
		{"evset", file="mci_m-11", set="mci_m-11", path=":ev/mci_m-11/"},
		{"bg", id=1, file="bg10_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=2, file="bg10_1l_00000", x=-300, y=200, lv=5, path=":bg/", sync=0, ev=1, style="blur", blurx=15, blury=1, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"bg", id=16, file="mci_m-11", x=-5, y=-5, path=":cg/mci_m/", lv=5, ev=1, time=300, bx=800, by=450},
		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=30000, lv=5},
		{"cgact", file="cgact", id=16, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine", lv=5, x=-5, y=-5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Falta poco. Asane, ¿hay algún enemigo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还差一点——麻沙音，敌人呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還差一點——麻沙音，敵人呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00100",
		linknext = "0098_00102",
		line = 1305,
	},
	["0098_00102"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1526", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“La información es limitada, apenas hay cámaras en esa zona. Pero parece que no hay enemigos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然那一带几乎没有摄像头……但能确认的范围内没有敌人的影子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然那一帶幾乎沒有攝影機……但能確認的範圍內沒有敵人的影子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00101",
		linknext = "0098_00103",
		line = 1318,
	},
	["0098_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que aún no llegan hasta allá.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来这一带还没受到监控。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來這一帶還沒受到監控。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00102",
		linknext = "0098_00104",
		line = 1328,
	},
	["0098_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rápido, Misaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要赶快了，美岬。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要趕快了，美岬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00103",
		linknext = "0098_00105",
		line = 1340,
	},
	["0098_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dejaremos a Aikaze en las colinas y llevaremos a Fumino a la base por el camino de la cueva.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这样在山中停下爱风后，我们穿过洞窟将文乃带到基地。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就這樣在山中停下愛風後，我們穿過洞窟將文乃帶到基地。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00104",
		linknext = "0098_00106",
		line = 1350,
	},
	["0098_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Una vez que hayamos garantizado su seguridad, Teshima no podrá hacer nada y nuestra victoria estará asegurada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当文乃的安全受到确保后，手嶋就完蛋了——我们的胜利将唾手可得。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當文乃的安全受到確保後，手嶋就完蛋了——我們的勝利將唾手可得。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00105",
		linknext = "0098_00107",
		line = 1360,
	},
	["0098_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me preocupan las heridas de Fumino, pero si resuelvo esta situación, podré llevar a un médico de confianza a la base para que la examine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但令我挂念的是文乃的伤——只要能突破现状，找个可以信赖的医生带去基地就行了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但令我掛念的是文乃的傷——只要能突破現狀，找個可以信賴的醫生帶去基地就行了。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00106",
		linknext = "0098_00108",
		line = 1370,
	},
	["0098_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Solo tengo que protegerla por ahora...",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之，现在必须保护好文乃——",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之，現在必須保護好文乃——",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00107",
		linknext = "0098_00109",
		line = 1380,
	},
	["0098_00109"] = {
		{"cgact", file="cgact", id=16, act="stopact", lv=5, x=-5, y=-5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=16, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=2, lv=5, time=300, alphadel=1, evmaskoff=1},
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1527", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Mmm?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“————嗯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「————嗯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00108",
		linknext = "0098_00110",
		line = 1397,
	},
	["0098_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué pasa? ¿Viste algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了？发生了什么事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了？發生了什麼事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00109",
		linknext = "0098_00111",
		line = 1409,
	},
	["0098_00111"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00105", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1528", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, no, no pasó nada malo. Solo me pareció oír algo extraño. Lo siento, debe ser mi imaginación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊不，没什么问题……我好像听到了奇怪的声音……对不起，我想是错觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊不，沒什麼問題……我好像聽到了奇怪的聲音……對不起，我想是錯覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00110",
		linknext = "0098_00112",
		line = 1422,
	},
	["0098_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vale, ten cuidado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明白了，小心点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「明白了，小心點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00111",
		linknext = "0098_00113",
		line = 1434,
	},
	["0098_00113"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00104", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1810", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Asane-chan también ha estado trabajando muy duro... Hasta ha estado gestionando el MARQualia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“麻沙音酱也一直很努力呢……Merqualia的调整之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「麻沙音醬也一直很努力呢……Merqualia的調整之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00112",
		linknext = "0098_00114",
		line = 1447,
	},
	["0098_00114"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Cuando esto acabe, se lo compensa—”",
					{"rt2"},
				},
			},
			cn = {
