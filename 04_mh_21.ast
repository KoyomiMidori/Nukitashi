	["0098_00475"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Utiliza el principio de la eyaculación para lanzar a una persona.",
					{"rt2"},
				},
