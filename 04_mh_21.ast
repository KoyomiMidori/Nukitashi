	["0098_00426"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El NLNS, la SS e incluso parte de la OSS han unido fuerzas para luchar contra un enemigo común.",
					{"rt2"},
				},
			},
			cn = {
				{
					"NLNS和FS，甚至是SHO的一部分——对立的组织在共同的敌人面前这样携手合作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"NLNS和FS，甚至是SHO的一部分——對立的組織在共同的敵人面前這樣攜手合作。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00425",
