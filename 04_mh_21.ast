		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asane es como una familia irremplazable para mí y una integrante muy valiosa del NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙音对我来说是不可替代的家人——同时对NLNS成员来说也是重要的同伴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙音對我來說是不可替代的家人——同時對NLNS成員來說也是重要的同伴。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00310",
		linknext = "0098_00312",
		line = 4069,
	},
	["0098_00312"] = {
		{"text"},
		text = {
