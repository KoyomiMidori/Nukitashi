			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Nos vemos luego... manito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“那么拜拜……",
					{"ruby", text="・・"},
					"哥哥",
					{"/ruby"},
					"。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「那麼拜拜……",
					{"ruby", text="・・"},
					"哥哥",
					{"/ruby"},
					"。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00300",
		linknext = "0098_00302",
		line = 3960,
	},
	["0098_00302"] = {
		{"bgm", stop=1},
		{"se", id=1, loop=1, file="se_d030", vol=40},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al terminar la llamada, me lanza una última burla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到最后都刺激我的神经，手嶋挂断了电话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到最後都刺激我的神經，手嶋掛斷了電話。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00301",
		linknext = "0098_00303",
