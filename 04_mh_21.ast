	["0098_00625"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our plan was to engage the enemy from the front and distract them while they used that opportunity to communicate with the betrayers and infiltrate from another route, but shit... they were quicker than I expected.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们似乎是利用我们从正面突破并吸引敌人的空挡，和内应者取得联络并从别的路线侵入的——但真的有够快。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們似乎是利用我們從正面突破並吸引敵人的空擋，和內應者取得聯絡並從別的路線侵入的——但真的有夠快。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00624",
