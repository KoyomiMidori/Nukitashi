					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Really? Thank God for that... Oh, prez? He just said it's all over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……是吗，太好了———嗯会长，他说都结束了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……是嗎，太好了———嗯會長，他說都結束了。」",
					{"rt2"},
				},
			},
		},
