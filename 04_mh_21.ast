				},
			},
			tw = {
				{
					"受了那麼多傷，但還是請求要我來她來的理由。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00851",
		linknext = "0098_00853",
		line = 12750,
	},
	["0098_00853"] = {
		{"text"},
		text = {
