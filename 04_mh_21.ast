					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔…………”",
					{"rt2"},
