		line = 4926,
	},
	["0098_00378"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00104", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0688", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Actualmente, todos los vigilantes dentro del edificio son nuestros colaboradores. Las armas y la artillería antiaérea son nuestras.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“现在，建筑物内的监视都是由协助者进行，炮台也……对空炮都被控制住了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「現在，建築物內的監視都是由協助者進行，砲臺也……對空砲都被控制住了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00377",
		linknext = "0098_00379",
		line = 4940,
	},
	["0098_00379"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque tengas el control de la artillería antiaérea, no podemos usar la salida al mar...”",
