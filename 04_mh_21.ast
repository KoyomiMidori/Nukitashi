		{"se", id=1, loop=1, file="se_d030", vol=60},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0022", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“¿Eh? ¿A quién estás buscando? Kotoyose... ¿qué es eso? ¡Últimamente no escucho muy bien! ¿Qué? ¿Que sí sé pelear? Ooh, aprendí algunos conceptos básicos, ¡pero nunca entrené!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“啊啊！？你说要找谁！？琴技……什么！？最近我的耳朵听不太清啊……什么！？今年也请多关照！？啊，已经过年了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「啊啊！？你說要找誰！？琴技……什麼！？最近我的耳朵聽不太清啊……什麼！？今年也請多關照！？啊，已經過年了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00253",
		linknext = "0098_00255",
		line = 3396,
	},
	["0098_00255"] = {
		{"text"},
		text = {
