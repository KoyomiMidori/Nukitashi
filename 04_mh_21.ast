			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, tienes razón. ¿Puedes encargarte de esto, Misaki?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，说得对——美岬，这个可以拜托你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，說得對——美岬，這個可以拜託你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00429",
		linknext = "0098_00431",
		line = 5649,
	},
	["0098_00431"] = {
		{"se", id=0, loop=0, file="se_a185"},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=7.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1822", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Una tableta? ¿Es la de Asane-chan...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“平板……？这是麻沙音酱的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「平板……？這是麻沙音醬的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00430",
		linknext = "0098_00432",
		line = 5665,
	},
	["0098_00432"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Quiero que ocupes su lugar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想拜托你代替麻沙音来引导。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想拜託你代替麻沙音來引導。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00431",
		linknext = "0098_00433",
		line = 5677,
	},
	["0098_00433"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1823", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“... ¿Estás seguro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……我可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……我可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00432",
		linknext = "0098_00434",
		line = 5691,
	},
	["0098_00434"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por supuesto. Lo probé antes, y es fácil aprender las funciones básicas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是要美岬才好。我刚才试了一下，基本没那么难。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是要美岬才好。我剛才試了一下，基本沒那麼難。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00433",
		linknext = "0098_00435",
		line = 5702,
	},
	["0098_00435"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo necesito que actives el MARQualia y me des las ubicaciones del GPS cuando sea necesario.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要启动Merqualia，告诉我地点的位置就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要啟動Merqualia，告訴我地點的位置就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00434",
		linknext = "0098_00436",
		line = 5713,
	},
	["0098_00436"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sé que es patético, pero sigo estando nervioso. Por eso quiero oír tu voz. ¿Puedes hacerlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……虽然很丢人，但说实话我还是感到有些不安——所以，我想一直听着美岬的声音。能拜托你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……雖然很丟人，但說實話我還是感到有些不安——所以，我想一直聽著美岬的聲音。能拜託你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00435",
		linknext = "0098_00437",
		line = 5725,
	},
	["0098_00437"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=7.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1824", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sí... ¡No te preocupes! ¡Puedes confiar en mí para lo que sea, Junnosuke-kun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的……当然可以！如果淳之介君希望的话，就交给我吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的……當然可以！如果淳之介君希望的話，就交給我吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00436",
		linknext = "0098_00438",
		line = 5740,
	},
	["0098_00438"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Gracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——謝謝。」",
					{"rt2"},
				},
