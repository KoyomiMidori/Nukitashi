					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso los isleños nos están ayudando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就连岛上的居民们也伸出了援手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就連島上的居民們也伸出了援手。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00426",
		linknext = "0098_00428",
