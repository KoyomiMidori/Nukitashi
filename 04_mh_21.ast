	["0098_00961"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Teshima... what you wanted wasn't a steel junk to make people do your bidding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“手嶋……你想要的，不是什么能随心所欲操纵他人的钢铁鸡巴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「手嶋……你想要的，不是什麼能隨心所欲操縱他人的鋼鐵肉棒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00960",
		linknext = "0098_00962",
		line = 14548,
	},
	["0098_00962"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let alone to make the whole world do your bidding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“更别说什么世界了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「更別說什麼世界了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00961",
		linknext = "0098_00963",
		line = 14559,
	},
	["0098_00963"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's the embodiment of evil who threw Seiran Island into complete turmoil, and had us at our wit's end— but right now, he looks so very small.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大肆扰乱青蓝岛以及我们的恶之象征——这时候看起来非常渺小。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大肆擾亂青藍島以及我們的惡之象徵——這時候看起來非常渺小。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00962",
		linknext = "0098_00964",
		line = 14569,
	},
	["0098_00964"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What you wanted was someone to love you and say that even being small is fine, and that whatever you had, it wouldn't matter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“短小也没关系，不管是什么样的都可以——你想要的，是能对你如此说道，无条件爱你的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「短小也沒關係，不管是什麼樣的都可以——你想要的，是能對你如此說道，無條件愛你的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00963",
		linknext = "0098_00965",
		line = 14580,
	},
	["0098_00965"] = {
