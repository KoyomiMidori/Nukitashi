					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guardia de la OSS D"},
					"“Dije Kotoyose Fumino porque... ah, olvídelo. Mierda, no están por aquí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "SHO警卫D"},
					"“我是说琴寄文乃……唉……算了，够了。可恶，不是在这里吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "SHO警衛D"},
					"「我是說琴寄文乃……唉……算了，夠了。可惡，不是在這裡嗎……？」",
					{"rt2"},
				},
			},
		},
