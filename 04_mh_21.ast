	["0098_00280"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si me enojo, le estaré dando lo que desea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"生气会正中他的下怀。",
					{"rt2"},
				},
			},
			tw = {
