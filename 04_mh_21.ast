					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Kenzou-san... ¿Se le ocurre algo? Su avión de combate—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“健藏先生……你有什么手段吗！？难道是那架战斗机……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「健藏先生……你有什麼手段嗎！？難道是那架戰鬥機……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00380",
		linknext = "0098_00382",
		line = 4981,
	},
	["0098_00382"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0026", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“No, eso no tiene arreglo. Pero hay otra manera. Aunque vas a necesitar unas pelotas de acero. ¿Te ves capaz?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“不，那是修不好了……不过，还有别的办法。虽然需要有很深厚的勇气……你有这个觉悟吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「不，那是修不好了……不過，還有別的辦法。雖然需要有很深厚的勇氣……你有這個覺悟嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00381",
		linknext = "0098_00383",
		line = 4993,
	},
	["0098_00383"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
