			},
		},
		linkback = "0098_00569",
		linknext = "0098_00571",
		line = 7839,
	},
	["0098_00571"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya no hay que darle tantas vueltas.",
