	["0098_00424"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="misaki_01m_00001", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1820", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“El viejo Kenzou y los demás deberían llegar pronto... Es increíble lo rápido que reunimos a una alianza tan grande de voluntarios.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“健藏爷爷他们好像马上就要来了……不知怎么的，突然之间就变成这么大的规模了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「健藏爺爺他們好像馬上就要來了……不知怎麼的，突然之間就變成這麼大的規模了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00423",
		linknext = "0098_00425",
		line = 5581,
	},
	["0098_00425"] = {
