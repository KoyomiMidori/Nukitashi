	},
	["0098_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su historia suena verídica.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长们的话里没有半点虚假。",
