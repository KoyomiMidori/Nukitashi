	["0098_00852"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was so badly injured, but still wanted to come with us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"受了那么多伤，但还是请求要我来她来的理由。",
