			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, es que era un secreto... Perdón, Rei-chan... ¿E-Estás molesta?”",
					{"rt2"},
