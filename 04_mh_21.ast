	},
	["0098_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así, tenemos que llevarla a la base. Es el lugar más seguro de la isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之先带文乃去基地。那里肯定是岛上最安全的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之先帶文乃去基地。那裡肯定是島上最安全的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00079",
		linknext = "0098_00081",
		line = 1039,
	},
	["0098_00081"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1524", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A la derecha, hay cuatro guardias de la OSS y un posible yakuza. Enfrentamiento en 30 segundos. No hay información en el GPS sobre ellos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“前进方向右侧，有4名SHO警卫和1名看起来像黑社会的男子。30秒后接触。全都没有位置情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「前進方向右側，有4名SHO警衛和1名看起來像黑社會的男子。30秒後接觸。全都沒有位置情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00080",
		linknext = "0098_00082",
		line = 1052,
	},
	["0098_00082"] = {
