					name = {"美岬", "Misaki"},
					"“Ehehe... it kinda feels like it was already years ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……感觉像是好几年前的事了。”",
