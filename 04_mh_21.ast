	["0098_00313"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Era el líder la yakuza. Se llama Teshima. Y—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚才，黑社会们的老大——叫手嶋的男人打来了电话。然后——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剛才，黑社會們的老大——叫手嶋的男人打來了電話。然後——」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00312",
		linknext = "0098_00314",
		line = 4091,
	},
	["0098_00314"] = {
