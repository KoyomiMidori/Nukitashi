			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Fumino's safety is already assured. I have no obligation to take orders from you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……文乃的安全已经被确保了。我没有必要再去服从你这样的家伙。”",
