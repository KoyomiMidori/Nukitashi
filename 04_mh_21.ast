				{"vo", file="teshima0190", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I ain't no fuckin' peewee dick! Ya seriously think I'm gonna swallow yer fuckin' bluff!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我不是短小！你以为那种虚张声势对我有用吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我不是短小！你以為那種虛張聲勢對我有用嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00866",
		linknext = "0098_00868",
		line = 12935,
	},
