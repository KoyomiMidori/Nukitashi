		linknext = "0098_00369",
		line = 4812,
	},
	["0098_00369"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0685", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Tenemos aliados en la sede central con los que tuviste relaciones sexuales y que siguen fingiendo estar controlados.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……以前跟前辈做过爱的同伴们，现在还装作被洗脑留在本部。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……以前跟前輩做過愛的同伴們，現在還裝作被洗腦留在本部。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00368",
		linknext = "0098_00370",
		line = 4825,
	},
	["0098_00370"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Aún tienen topos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你是说有内应吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你是說有內應嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00369",
		linknext = "0098_00371",
		line = 4837,
	},
	["0098_00371"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0686", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sí. Nuestro objetivo principal no era rescatar a Fumino, sino acabar con la alianza de la yakuza y rescatar al gobernador Hitoura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。原本我们的最终目的不是要夺回文乃，而是要消灭黑社会联盟并夺回仁浦知事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。原本我們的最終目的不是要奪回文乃，而是要消滅黑社會聯盟並奪回仁浦知事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00370",
		linknext = "0098_00372",
		line = 4852,
	},
	["0098_00372"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eso significa que van a regresar al cuartel general de la OSS? ¡Llévenme! ¡Por favor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说又要潜入SHO总部？拜托了！也带上我们——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說又要潛入SHO總部？拜託了！也帶上我們——」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00371",
		linknext = "0098_00373",
		line = 4864,
	},
	["0098_00373"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0687", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No... es que íbamos a cambiar a todos nuestros guardias y encargados de las armas en una hora. Ese era el momento que habíamos planeado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不……监视和炮手全部换成我们的同伙是在1小时后……我们本来想抓住那个时机……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不……監視和砲手全部換成我們的同夥是在1小時後……我們本來想抓住那個時機……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00372",
		linknext = "0098_00374",
		line = 4878,
	},
	["0098_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Una hora... Sería demasiado tarde.",
					{"rt2"},
				},
			},
			cn = {
				{
					"1个小时后——那就完全晚了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"1個小時後——那就完全晚了。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00373",
		linknext = "0098_00375",
		line = 4888,
	},
	["0098_00375"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No pueden hacer algo? ¿Como hacer el cambio antes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没办法了吗？比如提早换班……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒辦法了嗎？比如提早換班……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00374",
		linknext = "0098_00376",
		line = 4900,
	},
	["0098_00376"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00105", path=":fg/rei_01m/", id=8, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1050", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Es imposible. Todos tienen que aparentar que Teshima les ha lavado el cerebro. Si se desvían aunque sea un poco, se expondrían a un riesgo que pondría en peligro sus vidas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不可能。表面上大家都被手嶋洗脑了。如果做出稍微违背那家伙指示的举动，甚至会危及同伴的生命。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不可能。表面上大家都被手嶋洗腦了。如果做出稍微違背那傢伙指示的舉動，甚至會危及同伴的生命。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00375",
		linknext = "0098_00377",
		line = 4914,
	},
	["0098_00377"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
