		{"se", id=0, loop=0, file="se_b063"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1884", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Engines, check! Runup distance, check! Direction, check!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“引擎准备就绪！助跑距离没问题！方向没问题！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「引擎準備就緒！助跑距離沒問題！方向沒問題！」",
