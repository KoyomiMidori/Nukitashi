		line = 121,
	},
	["0098_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si cumple su promesa y podemos protegerla hasta el final, podremos exigir su renuncia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果仁浦先生不违背约定，只要能坚守文乃，甚至可以要求他辞职。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果仁浦先生不違背約定，只要能堅守文乃，甚至可以要求他辭職。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00010",
		linknext = "0098_00012",
		line = 131,
	},
	["0098_00012"] = {
