	["0098_00561"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00202", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1841", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, no... es que si Asane-chan estuviera aquí, probablemente estaríamos diciendo que es admirable...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，没事……我在想如果麻沙音酱在的话，一定会说‘那个女人更可怕哦’这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，沒事……我在想如果麻沙音醬在的話，一定會說『那個女人更可怕哦』這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00560",
		linknext = "0098_00562",
		line = 7722,
	},
	["0098_00562"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
