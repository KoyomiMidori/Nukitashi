			cn = {
				{
					name = {"麻沙音"},
					"“啊……呜呜呜住手……如果是在长时间的不安之后被这样……就算是畔还是会有效果的……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……嗚嗚嗚住手……如果是在長時間的不安之後被這樣……就算是畔還是會有效果的……！！」",
					{"rt2"},
				},
			},
		},
