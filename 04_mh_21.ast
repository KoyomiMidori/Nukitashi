	["0098_01007"] = {
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"bg", id=2, file="bg03_1l_00000", x=0, y=-200, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Teshima! You seriously wanna die!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“手嶋——喂！？连自己都想死吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「手嶋——喂！？連自己都想死嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01006",
		linknext = "0098_01008",
		line = 15212,
	},
	["0098_01008"] = {
		{"fg", file="teshima_01l_00001", file1="teshima_01l_00116", file2="teshima_01l_00202", path=":fg/teshima_01l/", id=8, lv=5, head="teshima_01l", ch="手嶋", mw="mw", sync=0, time=600, mode=3, x=0, y=200},
		{"fgact", ch="手嶋", id=8, act="移動", x=0, y=-100, time=700},
		{"fgact", ch="手嶋", id=8, act="浮遊横", loop=3, size=5, time=125, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0217", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh... Heh heh heh... I fucked up real bad... No matter how ya slice it, I'm already dead. So I figure I'd rather go out in a fuckin' blaze o' glory!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“唔……嘿嘿嘿嘿……我捅出这么大的娄子……无论如何都会被杀死。那干脆就华丽地消逝吧！！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「唔……嘿嘿嘿嘿……我捅出這麼大的婁子……無論如何都會被殺死。那乾脆就華麗地消逝吧！！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01007",
		linknext = "0098_01009",
		line = 15227,
	},
	["0098_01009"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00305", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You son of a...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这家伙……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你這傢伙……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01008",
		linknext = "0098_01010",
		line = 15239,
	},
	["0098_01010"] = {
		{"fg", file="teshima_01l_00001", file1="teshima_01l_00117", path=":fg/teshima_01l/", id=8, lv=5, head="teshima_01l", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0218", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“That first bomb's blocked off the exit! The fuck you gonna do, Tachibana!? Let's see ya put yer fuckin' power o' love ta good use!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“最初的炸弹把出口封住了！怎么办呢橘！让我看看你爱的力量吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「最初的炸彈把出口封住了！怎麼辦呢橘！讓我看看你愛的力量吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01009",
		linknext = "0098_01011",
		line = 15253,
	},
	["0098_01011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no helping this guy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个男人真的是——无可救药。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個男人真的是——無可救藥。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01010",
		linknext = "0098_01012",
		line = 15263,
	},
	["0098_01012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unloved, unable to accept his own failure... Surely this is the endpoint of extreme hatred.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不被爱，不容许自己——他仇恨的尽头，可能就是这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不被愛，不容許自己——他仇恨的盡頭，可能就是這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01011",
		linknext = "0098_01013",
		line = 15273,
	},
	["0098_01013"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
