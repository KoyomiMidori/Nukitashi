			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Fuck off with that bullshit, Tachibana! Hey, fucksods! If ya can't shoot 'im, use yer knives! Go dice 'im into li'l virginfag cutlets!”",
					{"rt2"},
				},
			},
			cn = {
