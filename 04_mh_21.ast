	["0098_00864"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's my hostage now. If you'd rather I didn't kill her, then let Asane go.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我把文乃当成人质——如果不希望她被杀就放开麻沙音。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我把文乃當成人質——如果不希望她被殺就放開麻沙音。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00863",
		linknext = "0098_00865",
		line = 12896,
	},
	["0098_00865"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00126", file2="teshima_01f_00202", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0189", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Huh? Wha... The fuck you on about!? She's my fuckin' hostage, asshole!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啥……？什么，你……你在说什么！？手上有人质的人是我吧！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啥……？什麼，你……你在說什麼！？手上有人質的人是我吧！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00864",
		linknext = "0098_00866",
		line = 12909,
	},
	["0098_00866"] = {
		{"fg", file="jun_01l_00001", file3="jun_01l_00302", file4="jun_01l_00402", path=":fg/jun_01l/", id=16, lv=5, head="jun_01l", ch="淳之介", mw="mw", sync=0, time=300, mode=3, x=400, y=-150},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Guess again, peewee dick. You can't order Hitoura around if she's dead. That's what we call a checkmate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也有啊，短小混蛋。如果没有文乃的话，仁浦也不会服从你了。那个时候你就完蛋了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也有啊，短小混蛋。如果沒有文乃的話，仁浦也不會服從你了。那個時候你就完蛋了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00865",
		linknext = "0098_00867",
		line = 12922,
	},
	["0098_00867"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00119", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
