	},
	["0098_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Recibí una llamada de ese desgraciado. Me dijo que iba a matarla si no le traía a Fumino en una hora.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚才，那家伙联系了我。说想要麻沙音的命，就在1个小时内，带着文乃一个人去他那里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剛才，那傢伙聯繫了我。說想要麻沙音的命，就在1個小時內，帶著文乃一個人去他那裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00352",
		linknext = "0098_00354",
		line = 4633,
	},
	["0098_00354"] = {
