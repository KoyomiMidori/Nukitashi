				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hasta podría acabar con la ley súperpervertida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"根据事情发展——也许也可以让他自己来推翻变态条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"根據事情發展——也許也可以讓他自己來推翻變態條例。",
