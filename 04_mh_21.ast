		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0185", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Oh, you'll see soon enough! Hey! I'm givin' ya 10 seconds ta show yer face, or the dyke dies! I know yer listenin', Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“当然要笑……喂！如果10秒之内不出来的话，我就杀了这个女人——你听到了吧，文乃！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「當然要笑……喂！如果10秒之內不出來的話，我就殺了這個女人——你聽到了吧，文乃！？」",
					{"rt2"},
				},
			},
		},
