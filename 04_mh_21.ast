	["0098_01019"] = {
		{"fg", file="teshima_01l_00001", file1="teshima_01l_00121", path=":fg/teshima_01l/", id=8, lv=5, head="teshima_01l", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0220", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ha... You a spacker or what!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……哈……你是个笨蛋吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
