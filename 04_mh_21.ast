				},
			},
			cn = {
				{
					name = {"礼"},
					"“不——现在不是生气的时候。对了，雏见……这么说来，以前说的5P……脚在阴道里的……那个……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不——現在不是生氣的時候。對了，雛見……這麼說來，以前說的5P……腳在陰道裡的……那個……」",
					{"rt2"},
				},
