		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00116", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
