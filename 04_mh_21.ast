				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不……这么点事情……我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不……這麼點事情……我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00018",
		linknext = "0098_00020",
		line = 245,
	},
	["0098_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estás temblando... Cálmate y quédate ahí, por favor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这不是在发抖吗……别说了，现在就先乖乖躺好吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這不是在發抖嗎……別說了，現在就先乖乖躺好吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00019",
		linknext = "0098_00021",
		line = 257,
	},
	["0098_00021"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1805", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Tiene razón. ¡Te golpearon tan fuerte que te desmayaste!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊……文乃酱，你都已经满身是伤地晕倒了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊……文乃醬，你都已經滿身是傷地暈倒了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00020",
		linknext = "0098_00022",
		line = 270,
	},
	["0098_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0312", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“¿Fueron... ustedes...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“您们是……那时的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「您們是……那時的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00021",
		linknext = "0098_00023",
		line = 282,
	},
	["0098_00023"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00115", file2="fumino_01m_00202", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0313", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No pude darles las gracias como es debido.. Les agradezco muchísimo por haberme rescatado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那时无法对您们表达充足的感谢……对于您们的帮助，我真的感到非常感激……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那時無法對您們表達充足的感謝……對於您們的幫助，我真的感到非常感激……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00022",
		linknext = "0098_00024",
		line = 296,
	},
	["0098_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No tienes que agradacernos... Deberíamos ser nosotros quienes deberían disculparse. Dijimos que te protegeríamos, pero te entregamos al enemigo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“感谢什么的……要低头的是我。明明说了要保护你，却把你交给了敌人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「感謝什麼的……要低頭的是我。明明說了要保護你，卻把你交給了敵人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00023",
		linknext = "0098_00025",
		line = 308,
	},
	["0098_00025"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0548", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Sí, perdón por haberte perseguido y todo eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我也是，一直追着你跑，真对不起哦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我也是，一直追著你跑，真對不起哦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00024",
		linknext = "0098_00026",
		line = 323,
	},
	["0098_00026"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00109", file2="fumino_01m_00202", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0314", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“T-Tú...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“您是……啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「您是……啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00025",
		linknext = "0098_00027",
		line = 337,
	},
	["0098_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tranquilo. Para no extenderme mucho, Onabuta ahora es nuestra aliada. Fue ella quien te curó.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不用警戒。说来话长……不过，女部田已经成了我们的一员，她还帮你做了应急治疗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你不用警戒。說來話長……不過，女部田已經成了我們的一員，她還幫你做了應急治療。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00026",
		linknext = "0098_00028",
		line = 349,
	},
	["0098_00028"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00106", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0315", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“¿En serio...? Lo siento. Discúlpame por pensar cosas que no eran...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……是这样吗……失礼了。我对自己贸然的误会表示歉意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……是這樣嗎……失禮了。我對自己貿然的誤會表示歉意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00027",
		linknext = "0098_00029",
		line = 363,
	},
	["0098_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun cuando se encuentra así, sigue siendo igual de determinada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使如此残破不堪，举止却丝毫不让人这么觉得。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使如此殘破不堪，舉止卻絲毫不讓人這麼覺得。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00028",
		linknext = "0098_00030",
		line = 373,
	},
	["0098_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Qué tan poderoso es el espíritu que habita en su pequeño cuerpo?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如此——如此娇弱的身体里，究竟藏着多么强大的精神力啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如此——如此嬌弱的身體裡，究竟藏著多麼強大的精神力啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00029",
		linknext = "0098_00031",
		line = 383,
	},
	["0098_00031"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00106", file4="fumino_01l_00402", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=2, file="bg19_1l_00000", x=0, y=-50, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Fumino, quiero preguntarte algo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃，我有件事想问你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃，我有件事想問你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00030",
		linknext = "0098_00032",
		line = 402,
	},
	["0098_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estabas detenida en la sede de la OSS, pero ¿cómo terminaste ahí? ¿Alguien te ayudó?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被抓到SHO总部的你，为什么会在那里？你得到了谁的帮助？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被抓到SHO總部的你，為什麼會在那裡？你得到了誰的幫助？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00031",
		linknext = "0098_00033",
		line = 413,
	},
	["0098_00033"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00111", file4="fumino_01l_00402", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0316", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Pues...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……那是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……那是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00032",
		linknext = "0098_00034",
		line = 427,
	},
	["0098_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No quieres decirlo...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好说出口的事情吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好說出口的事情嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00033",
		linknext = "0098_00035",
		line = 438,
	},
	["0098_00035"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00113", file4="fumino_01l_00402", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0317", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No, mis recuerdos están un poco borrosos... Lo siento mucho...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“没有……只是我的记忆有点混乱……非常抱歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「沒有……只是我的記憶有點混亂……非常抱歉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00034",
		linknext = "0098_00036",
		line = 452,
	},
	["0098_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es de esperarse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也没办法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也沒辦法。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00035",
		linknext = "0098_00037",
		line = 462,
	},
	["0098_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La mantuvieron cautiva durante bastante tiempo y la golpearon hasta dejarla inconsciente. Debe estar agotada física y mentalmente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"长时间被当作人质，受到了足以失去意识的伤害——身心应该已经疲惫不堪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"長時間被當作人質，受到了足以失去意識的傷害——身心應該已經疲憊不堪。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00036",
		linknext = "0098_00038",
		line = 472,
	},
	["0098_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es un milagro que pueda hablar bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"能像这样说话就已经是奇迹了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"能像這樣說話就已經是奇蹟了。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00037",
		linknext = "0098_00039",
		line = 482,
	},
	["0098_00039"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00115", file4="fumino_01l_00402", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0318", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Recuerdo que alguien me guió cuando escapé... y después de eso, me persiguieron y luché.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“逃脱的时候……我记得有人给我带路……后来，和追兵展开了战斗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「逃脫的時候……我記得有人給我帶路……後來，和追兵展開了戰鬥……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00038",
		linknext = "0098_00040",
		line = 496,
	},
	["0098_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En ese momento te lastimaron...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后受伤了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後受傷了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00039",
		linknext = "0098_00041",
		line = 508,
	},
	["0098_00041"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Baja la mirada y asiente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃垂下眼睛点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃垂下眼睛點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00040",
		linknext = "0098_00042",
		line = 519,
	},
	["0098_00042"] = {
		{"bgm", stop=1},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00104", file4="fumino_01l_00402", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0319", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Creo que aún me están buscando. Si me quedo, solo les causaré problemas. Debo irme de inmediato.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那些人应该还在找我……在这里会给大家带来麻烦的……我必须马上走……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那些人應該還在找我……在這裡會給大家帶來麻煩的……我必須馬上走……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00041",
		linknext = "0098_00043",
		line = 534,
	},
	["0098_00043"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Espera. Si te vas, tendremos problemas. Si intentas salir por tu cuenta sabiendo que te persiguen, no te lo vamos a permitir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等一下，那样做才会带来麻烦。如果知道自己被盯上了还想一个人出去的话———我们会尽全力阻止的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等一下，那樣做才會帶來麻煩。如果知道自己被盯上了還想一個人出去的話———我們會盡全力阻止的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00042",
		linknext = "0098_00044",
		line = 546,
	},
	["0098_00044"] = {
		{"bgm", file="bgm01", vol=100},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00126", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1806", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡No tienes que preocuparte por causar problemas! ¡Después de todo, yo le estoy causando muchísimos problemas a Asane-chan con solo estar aquí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不要在意给我们带来麻烦什么的。我只是在这里就被麻沙音酱当成大麻烦了呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不要在意給我們帶來麻煩什麼的。我只是在這裡就被麻沙音醬當成大麻煩了呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00043",
		linknext = "0098_00045",
		line = 564,
	},
	["0098_00045"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1522", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Entonces sí lo sabes... ¿Pa qué lo presumes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“原来你有自觉啊……为什么还那么自豪……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「原來你有自覺啊……為什麼還那麼自豪……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00044",
		linknext = "0098_00046",
		line = 577,
	},
	["0098_00046"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2071", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, somos gente tranquila... No tienes que preocuparte por causarnos problemas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“就是这样的一群人……所以你也不用在意什么哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「就是這樣的一群人……所以你也不用在意什麼哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00045",
		linknext = "0098_00047",
		line = 592,
	},
	["0098_00047"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0320", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Estoy muy agradecida por su hospitalidad...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“各位……我对您们的厚意深感惶恐……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「各位……我對您們的厚意深感惶恐……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00046",
		linknext = "0098_00048",
		line = 606,
	},
	["0098_00048"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2073", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tranquila, no te preocupes! ¡La mayor tiene que ser amable con los menores!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好了好了。姐姐一定要对小孩子温柔的啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好了好了。姐姐一定要對小孩子溫柔的啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00047",
		linknext = "0098_00049",
		line = 621,
	},
	["0098_00049"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00111", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0321", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“... ¿Es en serio...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……是那样的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……是那樣的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00048",
		linknext = "0098_00050",
		line = 635,
	},
	["0098_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Mira, Wata-chan es 3 años mayor que tú.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……先跟你说，渡酱可是比文乃大三岁哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……先跟你說，渡醬可是比文乃大三歲哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00049",
		linknext = "0098_00051",
		line = 647,
	},
	["0098_00051"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00109", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0322", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“... ¿Perdón?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00050",
		linknext = "0098_00052",
		line = 661,
	},
	["0098_00052"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2074", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Pensaste que era menor?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你以为我年纪比你小吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你以為我年紀比你小嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00051",
		linknext = "0098_00053",
		line = 676,
	},
	["0098_00053"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00106", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[7500] = {
				{"fg", file="fumino_01m_00001", file1="fumino_01m_00123", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, delay2=7500, time=300, mode=3, x=0, y=0},
			},
			[8500] = {
				{"fgact", ch="文乃", id=7, act="振動下", loop=3, size=5, time=250, ease="easeinout_sine", delay2=8500},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0323", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Ah... Por favor, perdónenme. No estoy acostumbrada a las bromas... Ah, ajaja.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“啊……真是失礼了……我还不习惯跟他人开玩笑……啊、啊哈哈哈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「啊……真是失禮了……我還不習慣跟他人開玩笑……啊、啊哈哈哈。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00052",
		linknext = "0098_00054",
		line = 693,
	},
	["0098_00054"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2075", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿De veras no me crees?! ¡Sí soy mayor! ¡Soy la mayor aquí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“难道你还不相信！？我真的比你大！我是这里面最年长的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
