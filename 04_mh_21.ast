		{"bg", id=1, file="bg01_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1056", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Seamos compañeros o no, me sorprende que hayas podido entrar tú solo... Eres un hombre admirable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽说有协助者，但还真的一个人打破了僵局……真是个可怕的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖說有協助者，但還真的一個人打破了僵局……真是個可怕的男人。」",
					{"rt2"},
				},
			},
		},
