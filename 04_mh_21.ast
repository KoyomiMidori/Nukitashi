				},
			},
			cn = {
				{
					name = {"礼"},
					"“唉……真没想到雏见也是反交尾势力的一员。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唉……真沒想到雛見也是反交尾勢力的一員。」",
					{"rt2"},
				},
