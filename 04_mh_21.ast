		linknext = "0098_00439",
		line = 5752,
	},
	["0098_00439"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras Misaki esté aquí y sea mi aliada, todo estará bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有这么多同伴——还有美岬在的话，一定没问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有這麼多同伴——還有美岬在的話，一定沒問題。",
