	["0098_00538"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00104", file2="misaki_01f_00202", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1835", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Una a la izquierda, a las cuatro en punto! ¿Eh? Tiene un comunicador... ¡Y-Ya te vio!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“剩下一名看守在4点钟方向——啊！？在通讯中……！！你、你被发现了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「剩下一名看守在4點鐘方向——啊！？在通訊中……！！你、你被發現了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00537",
		linknext = "0098_00539",
		line = 7365,
	},
	["0098_00539"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
