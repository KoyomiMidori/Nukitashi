	["0098_00790"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It doesn't matter if it's handguns, sniper rifles, or machine guns.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管是手枪，还是狙击步枪，或是冲锋枪———",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管是手槍，還是狙擊步槍，或是衝鋒槍———",
