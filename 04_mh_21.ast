		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0174", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Chill out, carpet-muncher. They're rubber bullets, so he ain't gonna die... long as they don't hit 'im anywhere too vital, that is!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不用担心百合妹，因为是橡皮弹打不死人的———如果击中的地方不危险的话！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「不用擔心百合妹，因為是橡皮彈打不死人的———如果擊中的地方不危險的話！」",
					{"rt2"},
				},
			},
		},
