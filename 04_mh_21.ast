	["0098_00413"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2080", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ejeje. Probablemente no debería decir esto ahora mismo... pero me siento feliz peleando al lado de Rei-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿。虽然这种话不和时宜……但能和礼酱一起战斗好高兴啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿。雖然這種話不和時宜……但能和禮醬一起戰鬥好高興啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00412",
		linknext = "0098_00414",
		line = 5430,
	},
	["0098_00414"] = {
