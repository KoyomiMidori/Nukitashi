					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What you need's a goddamn sanity check! Shit, I shoulda just stayed that asshole's hostage!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“绝对都有问题吧……！当人质的时候可能还比较好……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「絕對都有問題吧……！當人質的時候可能還比較好……！」",
