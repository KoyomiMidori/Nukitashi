					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nos hemos cruzado muchas veces, e incluso hemos cruzado genitales dos veces. Siempre la he considerado una mujer bastante despistada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到目前为止和她见过几次面，还做过两次爱——说实话，她给人的印象比较偏向没用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到目前為止和她見過幾次面，還做過兩次愛——說實話，她給人的印像比較偏向沒用。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00394",
		linknext = "0098_00396",
		line = 5191,
	},
	["0098_00396"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es tan despistada que ni siquiera necesitó una follada para que le lavaran el cerebro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟第二次根本就和小鸡鸡没有任何关系，她就被简单地洗脑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟第二次根本就和小雞雞沒有任何關係，她就被簡單地洗腦了。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00395",
		linknext = "0098_00397",
		line = 5201,
	},
	["0098_00397"] = {
		{"fg", file="ikuko_01m_00002", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0562", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Kouki-chan no es muy lista, pero es una experta en edición de videos. De hecho, empezó haciendo videos promocionales por su cuenta, y se le daba tan bien que la contrataron y la convirtieron en empleada oficial.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“光姬酱虽然脑袋很差，但对影像的处理很擅长哦？她本来就是先在网上个人直播后，才被提拔为观光大使的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「光姬醬雖然腦袋很差，但對影像的處理很擅長哦？她本來就是先在網上個人直播後，才被提拔為觀光大使的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00396",
		linknext = "0098_00398",
		line = 5215,
	},
	["0098_00398"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No lo sabía...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这我就不知道了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這我就不知道了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00397",
		linknext = "0098_00399",
		line = 5227,
	},
	["0098_00399"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No parece que Onabuta tenga una buena opinión de Senba-san. ¿Tiene algún rencor personal contra ella?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过女部田对仙波小姐的整体评价也太过分了吧。是有私怨吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過女部田對仙波小姐的整體評價也太過分了吧。是有私怨嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00398",
		linknext = "0098_00400",
		line = 5237,
	},
	["0098_00400"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En fin, la OSS debería estar a cargo de la división superior de la SS, pero incluso eso parece controlarlo la carismática presidenta del consejo estudiantil.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么样——SHO应该是FS的上级组织，但连他们都在指挥之下，不愧是学生会长。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼樣——SHO應該是FS的上級組織，但連他們都在指揮之下，不愧是學生會長。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00399",
		linknext = "0098_00401",
		line = 5247,
	},
	["0098_00401"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece ocultar algo, así que no entiendo cuáles son sus verdaderas intenciones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明一副呆呆的样子，却深不见底。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明一副呆呆的樣子，卻深不見底。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00400",
		linknext = "0098_00402",
		line = 5257,
	},
	["0098_00402"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"bg", id=2, file="bg05_1l_00000", x=-200, y=-100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="ran_01m_00001", file1="ran_01m_00104", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1051", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Ran, Rin! ¡Van a proporcionar apoyo logístico! ¡Ikuko, ven aquí! Te nombro comandante del primer escuadrón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“兰、凛！你们赶紧去支援后方吧！然后……郁子，过来！一队的队长就交给你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「蘭、凜！你們趕緊去支援後方吧！然後……郁子，過來！一隊的隊長就交給你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00401",
		linknext = "0098_00403",
		line = 5278,
	},
	["0098_00403"] = {
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=300},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00116", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0563", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“¿Eh? ¿No me echaron de la SS? Ahora soy miembro del NLNS. Quiero estar con mi amorcito...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶——？郁不是被FS开除了吗？现在我是NLNS的成员哦？我要和亲爱的在一起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸——？郁不是被FS開除了嗎？現在我是NLNS的成員哦？我要和親愛的在一起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00402",
		linknext = "0098_00404",
		line = 5293,
	},
	["0098_00404"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1052", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Deja de dar largas! ¡Eres la única que puede mantener a raya a los eslabones más débiles de nuestra fuerza de ataque! ¡Por favor, hasta tengo tu uniforme!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别废话了！能领导强袭部队里的倔性子们的人只有你一个！你看，制服也准备好了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別廢話了！能領導強襲部隊裡的倔性子們的人只有你一個！你看，制服也準備好了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00403",
		linknext = "0098_00405",
		line = 5307,
	},
	["0098_00405"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00120", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[7500] = {
				{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00113", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=7500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0564", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“¡Vaya, vaya, vaya! ¡Así sí me dan ganas de ayudarte! ¿No te molesta, cariño?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哎呀哎呀……都被这样说了，会让我想帮忙啊。亲爱的，只有现在可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哎呀哎呀……都被這樣說了，會讓我想幫忙啊。親愛的，只有現在可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00404",
		linknext = "0098_00406",
		line = 5323,
	},
	["0098_00406"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por supuesto que no. Si las ayudas, tendremos más posibilidades de ganar, ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——拜托你了。这样作战的成功率会更高对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯——拜託你了。這樣作戰的成功率會更高對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00405",
		linknext = "0098_00407",
		line = 5335,
	},
	["0098_00407"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=1, mode=3, x=400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0565", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Sí, ya me reconcilié con los viejos miembros de la SS, pero... ¿también puedo seguir siendo amiga del NLNS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯，虽然和FS的大家和好了……但我今后也能和NLNS的大家和睦相处吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯，雖然和FS的大家和好了……但我今後也能和NLNS的大家和睦相處嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00406",
		linknext = "0098_00408",
		line = 5350,
	},
	["0098_00408"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Claro que sí. Eres una compañera muy valiosa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然。你是我们重要的同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然。你是我們重要的同伴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00407",
		linknext = "0098_00409",
		line = 5362,
	},
	["0098_00409"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00102", file2="ikuko_01m_00201", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0566", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Jeje... ¡Como que sí me terminaste gustando, cariño! Esto debe ser amor, ¿verdad? Oye, ¿me das un besito?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唔呵呵。郁果然最喜欢亲爱的了！这就是所谓的爱情吧？呐，可以亲你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「唔呵呵。郁果然最喜歡親愛的了！這就是所謂的愛情吧？吶，可以親你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00408",
		linknext = "0098_00410",
		line = 5376,
	},
	["0098_00410"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00409",
		linknext = "0098_00411",
		line = 5388,
	},
	["0098_00411"] = {
		{"fg", file="ikuko_01m_00002", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0567", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ejeje, también me encanta ese lado travieso tuyo. ¡Nos vemos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶诶诶——那么冷淡的部份我也很喜欢哦？那就待会儿见！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸欸欸——那麼冷淡的部份我也很喜歡哦？那就待會見！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00410",
		linknext = "0098_00412",
		line = 5402,
	},
	["0098_00412"] = {
		{"fgact", ch="郁子", id=10, act="移動", x=200, y=0, time=600},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=400},
		{"se", id=0, loop=0, file="se_a064"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Corre hacia el primer escuadrón con una sonrisa en su rostro.",
					{"rt2"},
				},
			},
			cn = {
				{
