			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然。」",
					{"rt2"},
				},
			},
		},
