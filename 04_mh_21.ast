	["0098_00472"] = {
		{"bgm", file="bgm13", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0029", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“¡Jijijiji! No pensé que volvería a usar mi cañón... ¡He estado esperando este día!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“咿嘿嘿嘿！能使用这尊大炮的日子终于到来了……活得久真是好事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「咿嘿嘿嘿！能使用這尊大砲的日子終於到來了……活得久真是好事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00471",
		linknext = "0098_00473",
		line = 6218,
	},
	["0098_00473"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sí, esta fue la idea del hombre bala que los ancianos del asentamiento crearon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的——这是健藏老人和村里的疯狂老人们制造的人肉大炮。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的——這是健藏老人和村裡的瘋狂老人們製造的人肉大砲。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00472",
		linknext = "0098_00474",
		line = 6228,
	},
	["0098_00474"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Un hombre bala utiliza aire comprimido, pero con este cañón es diferente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一般的人肉大炮利用的是压缩空气，但这个大炮不同。",
					{"rt2"},
