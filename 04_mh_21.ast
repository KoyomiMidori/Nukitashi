		linkback = "0098_00055",
		linknext = "0098_00057",
		line = 732,
	},
	["0098_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tienes razón. Supongo que no querría bajar la guardia ante un grupo de personas cuyos nombres ni siquiera conoce.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。被连名字都不知道的人包围着，心情也不会放松啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。被連名字都不知道的人包圍著，心情也不會放鬆啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00056",
