	["0098_00849"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00118", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=7, size=5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0187", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hahaha! Looks like things ended up how I wanted 'em after all! Now we can finally have ourselves a proper exchange of hostages.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈哈哈！结果还是按照我的安排进展了！那么，我们就按当初的计划来交换人质吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈哈哈！結果還是按照我的安排進展了！那麼，我們就按當初的計劃來交換人質吧。」",
					{"rt2"},
				},
			},
		},
