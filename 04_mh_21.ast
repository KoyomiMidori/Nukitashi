				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ahora que lo pienso, creo que nunca nos presentamos bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这么说来，还没有向文乃酱做过自我介绍呢。”",
