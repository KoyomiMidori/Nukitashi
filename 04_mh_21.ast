					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛D"},
					"「笨蛋！你以為這麼點事我們就會害怕嗎？只要沒有裝甲車，我們就能贏——大家準備好！」",
					{"rt2"},
				},
			},
