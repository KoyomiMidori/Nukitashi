	["0098_00002"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Quiere que protejamos a Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“希望我们保护文乃——是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「希望我們保護文乃——是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00001",
		linknext = "0098_00003",
		line = 30,
	},
	["0098_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Murmuro mientras miro la carta de Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一手拿着仁浦先生的信，一边喃喃自语着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一手拿著仁浦先生的信，一邊喃喃自語著。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00002",
		linknext = "0098_00004",
		line = 40,
	},
	["0098_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pensé que solo estaba haciendo lo que Teshima le pedía porque le preocupaba la repercusión negativa que tendría al revelarse que Fumino es su hija ilegitima.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他之所以对手嶋言听计从，是因为害怕被世人知道私生女文乃的存在，所以为了明哲保身——我一直是这么想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他之所以對手嶋言聽計從，是因為害怕被世人知道私生女文乃的存在，所以為了明哲保身——我一直是這麼想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00003",
		linknext = "0098_00005",
		line = 50,
	},
	["0098_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero siempre se preocupó por su hija...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为担心女儿的安全——原来是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為擔心女兒的安全——原來是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00004",
		linknext = "0098_00006",
		line = 62,
	},
	["0098_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso el creador de esa maldita ley tiene el alma de un padre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"制定条例的疯狂男人，也有颗作为父亲的心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"制定條例的瘋狂男人，也有顆作為父親的心。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00005",
		linknext = "0098_00007",
		line = 72,
	},
	["0098_00007"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2070", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Si acepta nuestras exigencias a cambio de proteger a Fumino, es porque de verdad se preocupa por ella.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“只要能保护文乃，什么要求都能接受……看来他很重视呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「只要能保護文乃，什麼要求都能接受……看來他很重視呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00006",
		linknext = "0098_00008",
		line = 86,
	},
	["0098_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Pero hay algo que pasó por alto. ¿De verdad pensaba que no la cuidaríamos aun sin la condición?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。不过，我们还真是被小看了……难道他认为如果没有这种条件交换，我们就会抛弃文乃吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。不過，我們還真是被小看了……難道他認為如果沒有這種條件交換，我們就會拋棄文乃嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00007",
		linknext = "0098_00009",
		line = 98,
	},
	["0098_00009"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1521", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bueno, quizá sea precipitado decir esto, pero si la protegemos, creo que podemos resolver todo esto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不过，虽然有点不太谨慎……但如果能守护文乃到最后，一切就都能圆满解决了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不過，雖然有點不太謹慎……但如果能守護文乃到最後，一切就都能圓滿解決了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00008",
		linknext = "0098_00010",
		line = 111,
	},
	["0098_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tiene toda la razón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正如麻沙音所说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正如麻沙音所說。",
