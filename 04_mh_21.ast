	["0098_00429"] = {
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1821", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Tal vez no deba decirlo ahora, pero... me tranquiliza tener de nuestro lado a los enemigos poderosos con los que luchamos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“虽然在这种情况下有点不和时宜……但以前一直战斗过来的强敌成了我们的战友，我觉得很心安。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「雖然在這種情況下有點不和時宜……但以前一直戰鬥過來的強敵成了我們的戰友，我覺得很心安。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00428",
		linknext = "0098_00430",
		line = 5637,
	},
	["0098_00430"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
