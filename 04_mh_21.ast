	["0098_00316"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=500, mode=3, x=-400, y=0},
		{"fgact", ch="礼", id=9, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A sus espaldas están la presidenta del comité de moral pública y otros miembros de la SS.",
