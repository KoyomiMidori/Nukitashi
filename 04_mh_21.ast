					"生氣會正中他的下懷。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00279",
		linknext = "0098_00281",
		line = 3707,
	},
	["0098_00281"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00111", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0154", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Escúchame, Junnosuke-kun. Estoy muy deprimido. Un amigo cercano me traicionó, me quitaron a una muchacha muy especial, todo tipo de mierdas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“听我说啊淳之介君……我直到刚才都好难过啊。被重要的同伴背叛，最珍惜的女孩也被掳走了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「聽我說啊淳之介君……我直到剛才都好難過啊。被重要的同伴背叛，最珍惜的女孩也被擄走了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00280",
		linknext = "0098_00282",
		line = 3720,
	},
	["0098_00282"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00117", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0155", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“¡Pero mira! ¡Ahora mismo me siento alegre! ¡Así que te tengo una pregunta sorpresa! ¿Por qué estoy de tan buen humor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“但是！我现在心情超级好啊！来吧问你个问题！我心情这么好的原因是什么呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「但是！我現在心情超級好啊！來吧問你個問題！我心情這麼好的原因是什麼呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00281",
		linknext = "0098_00283",
		line = 3733,
	},
	["0098_00283"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00117", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0156", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“1. ¡Porque eres un imbécil! 2. ¡Porque tengo una nueva rehén! 3. Eh... ¡A la mierda, todas las anteriores! ¿Qué vas a responderme?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“1.因为你是笨蛋！　2.因为我有新的人质了！　3.呃……就1和2吧！来吧，是哪个？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「1.因為你是笨蛋！　2.因為我有新的人質了！　3.呃……就1和2吧！來吧，是哪個？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00282",
		linknext = "0098_00284",
		line = 3746,
	},
	["0098_00284"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es un golpe bajo. No voy a caer en sus provocaciones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"廉价的挑衅。我不能上钩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"廉價的挑釁。我不能上鉤。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00283",
		linknext = "0098_00285",
		line = 3756,
	},
	["0098_00285"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00115", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0157", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ah, ¿me vas a ignorar? Si hubieras respondido bien, te habría dejado escuchar la voz de tu preciosa hermanita. Qué lástima...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“喂喂不说话吗？我还想着你答对的话，就给你听听可爱妹妹的声音呢，真遗憾啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「喂喂不說話嗎？我還想著你答對的話，就給你聽聽可愛妹妹的聲音呢，真遺憾啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00284",
		linknext = "0098_00286",
		line = 3769,
	},
	["0098_00286"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Asane está ahí?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙音在那里吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙音在那裡嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00285",
		linknext = "0098_00287",
		line = 3781,
	},
	["0098_00287"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00116", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0158", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“¡Mucho mejor! ¡Deberías haber dicho eso más bien! ¡Jajaja! ¡Bueno, como estoy de buen humor, te buscaré una muestra de voz en la página oficial para que la escuches!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“对对！从一开始就要给我这种反应啊！哈哈哈！因为我心情好，所以这次特别在官方网站中给你听听样本声音吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「對對！從一開始就要給我這種反應啊！哈哈哈！因為我心情好，所以這次特別在官方網站中給你聽聽樣本聲音吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00286",
		linknext = "0098_00288",
		line = 3794,
	},
	["0098_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hay un silencio muy breve.",
					{"rt2"},
				},
			},
			cn = {
				{
					"暂时的沉默。",
					{"rt2"},
				},
			},
			tw = {
				{
					"暫時的沉默。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00287",
		linknext = "0098_00289",
		line = 3804,
	},
	["0098_00289"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00112", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1531", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿M-Manito...? Lo siento... Yo... ¡Yo...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……哥、哥哥……？对不起……我、我……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……哥、哥哥……？對不起……我、我……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00288",
		linknext = "0098_00290",
		line = 3817,
	},
	["0098_00290"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Asane! Lo siento mucho... ¡Todo va a estar bien! Voy a salvarte, te lo prometo—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙音！！我才……你等着！我绝对会救出你——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙音！！我才……你等著！我絕對會救出你——」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00289",
		linknext = "0098_00291",
		line = 3829,
	},
	["0098_00291"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00116", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0159", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“¡Se acabó la prueba! ¡Tendrás que comprar el juego completo para escuchar más!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啊——好，时间到！接下来请购买产品版哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啊——好，時間到！接下來請購買產品版哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00290",
		linknext = "0098_00292",
		line = 3842,
	},
	["0098_00292"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡D-Desgraciado...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你……这个混蛋……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你……這個混蛋……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00291",
		linknext = "0098_00293",
		line = 3854,
	},
	["0098_00293"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00118", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0160", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“¡Jajajaja! ¡Solo con oír su voz ya estás chillando como un cerdo! ¡Eres muy gracioso, virgen! ¡Nunca pensé que joderte iba a ser tan divertido!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈哈哈哈哈哈！听到妹妹的声音就那么兴奋真有趣啊，你这个声控猪头处女厨！不过让你活下来真是太好了！居然能在这种地方派上用场！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈哈哈哈哈哈！聽到妹妹的聲音就那麼興奮真有趣啊，你這個聲控豬頭處女廚！不過讓你活下來真是太好了！居然能在這種地方派上用場！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00292",
		linknext = "0098_00294",
		line = 3867,
	},
	["0098_00294"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Si llegas a ponerle un dedo encima, te juro que—!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你有种就碰麻沙声一根手指试试……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你有種就碰麻沙聲一根手指試試……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00293",
		linknext = "0098_00295",
		line = 3878,
	},
	["0098_00295"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00114", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0161", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“No me jodas, maricón. ¿Andas creído solo porque deshiciste el lavado de cerebro? Más te vale que te pongas las pilas. Yo soy el que tiene a tu rehén.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“——别得意忘形了。以为自己能解除洗脑就很牛逼吗？看清楚自己的立场吧处女厨。被人质要挟的人是你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「——別得意忘形了。以為自己能解除洗腦就很屌嗎？看清楚自己的立場吧處女廚。被人質要挾的人是你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00294",
		linknext = "0098_00296",
		line = 3891,
	},
	["0098_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me trago mi respuesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反驳的话卡在喉头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反駁的話卡在喉頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00295",
		linknext = "0098_00297",
		line = 3901,
	},
	["0098_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Obviamente sabía que me deshice del lavado de cerebro. Al fin y al cabo, fui bastante descarado con eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我干得那么高调，想必解除洗脑的事也会传入那家伙的耳朵。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我幹得那麼高調，想必解除洗腦的事也會傳入那傢伙的耳朵。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00296",
		linknext = "0098_00298",
		line = 3911,
	},
	["0098_00298"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0162", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Te tengo un trato. Trae a Fumino aquí, sola, y te daré a tu hermanita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“来交易吧。你一个人带着文乃来这里，和妹妹做人质交换。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「來交易吧。你一個人帶著文乃來這裡，和妹妹做人質交換。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00297",
		linknext = "0098_00299",
		line = 3923,
	},
	["0098_00299"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Como si fuera un trato justo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和你这家伙交易什么的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和你這傢伙交易什麼的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00298",
		linknext = "0098_00300",
		line = 3935,
	},
	["0098_00300"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0163", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Tienes una hora. No quieres que esa sea la última vez que escuches a esa zorra con vida, ¿verdad? Entonces tráela aquí en una hora.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“1个小时。如果不想把刚才的当成人生最后的对话，就在1个小时内带来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「1個小時。如果不想把剛才的當成人生最後的對話，就在1個小時內帶來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00299",
		linknext = "0098_00301",
		line = 3947,
	},
	["0098_00301"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00116", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
