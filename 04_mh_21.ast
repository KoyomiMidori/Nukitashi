	["0098_00564"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Presidenta del consejo estudiantil, ¿sabes dónde podrían estar Asane, Teshima y Hitoura?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“学生会长。麻沙音……还有手嶋和仁浦先生，你知道在哪里吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「學生會長。麻沙音……還有手嶋和仁浦先生，你知道在哪裡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00563",
		linknext = "0098_00565",
		line = 7761,
	},
	["0098_00565"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0691", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Según mis datos, deberían estar en la oficina. Está el último piso del edificio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“报告表示在首长室，是在大楼的最上层吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「報告表示在首長室，是在大樓的最上層吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00564",
		linknext = "0098_00566",
		line = 7775,
	},
	["0098_00566"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El último piso, ¿eh? Entendido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最上面吗——简单易懂。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最上面嗎——簡單易懂。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00565",
		linknext = "0098_00567",
		line = 7787,
	},
	["0098_00567"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00104", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0692", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Lo ideal sería entrar sigilosamente y con mucho secretismo al último piso, pero no podemos aplicar un enfoque tan metódico ahora.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“本来预定是要隐密潜入——秘密前往最顶层，但现在应该没办法这么悠闲了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「本來預定是要隱密潛入——祕密前往最頂層，但現在應該沒辦法這麼悠閒了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00566",
		linknext = "0098_00568",
		line = 7801,
	},
	["0098_00568"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora mismo, el tiempo es esencial. Lamento estropearte los planes, pero tendremos que llegar allí cuanto antes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在分秒必争。很抱歉让你们的计划半途而废——我将以最快的速度冲向顶层。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在分秒必爭。很抱歉讓你們的計劃半途而廢——我將以最快的速度衝向頂層。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00567",
		linknext = "0098_00569",
		line = 7813,
	},
	["0098_00569"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0693", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No me molesta. Al fin y al cabo, salvaste a mis queridos compañeros del lavado de cerebro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没关系。因为前辈……你是把我重要的同伴从洗脑中解救出来的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒關係。因為前輩……你是把我重要的同伴從洗腦中解救出來的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00568",
		linknext = "0098_00570",
		line = 7827,
	},
	["0098_00570"] = {
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
