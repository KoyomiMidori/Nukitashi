	["0098_00390"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eso sí, hay bastante gente aquí. ¿No nos verá Teshima desde las cámaras espía?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说回来，这么多人聚集在这种地方不要紧吗？不用担心手嶋那边透过监视摄像头盯着吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說回來，這麼多人聚集在這種地方不要緊嗎？不用擔心手嶋那邊透過監視攝影機盯著嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00389",
		linknext = "0098_00391",
		line = 5128,
	},
	["0098_00391"] = {
