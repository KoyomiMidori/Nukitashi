					"Nonetheless, I still have to speak to him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——即便如此，也得先和他谈谈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——即便如此，也得先和他談談。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00988",
