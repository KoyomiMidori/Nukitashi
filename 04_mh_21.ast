	["0098_00840"] = {
		{"fg", file="hitoura_01f_00001", file1="hitoura_01f_00104", path=":fg/hitoura_01f/", id=30, ch="仁浦", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
