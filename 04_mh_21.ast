					name = {"美岬"},
					"「嗯……應該沒辦法！從本來就不是路的地方過來結果讓路直接消失了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01039",
		linknext = "0098_01041",
		line = 15642,
	},
	["0098_01041"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right... Only one thing to do, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然如此——就只剩下一条路了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然如此——就只剩下一條路了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01040",
		linknext = "0098_01042",
		line = 15654,
	},
	["0098_01042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Everybody hop into Aikaze!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大家，坐上爱风！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大家，坐上愛風！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01041",
		linknext = "0098_01043",
		line = 15668,
	},
	["0098_01043"] = {
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"fg", file="asane_02m_00001", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1540", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Huh? I've got a bad feeling about this on so many levels... What're you gonna do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶……我已经有不好的预感了……你打算干什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸……我已經有不好的預感了……你打算幹什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01042",
		linknext = "0098_01044",
		line = 15683,
	},
	["0098_01044"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're gonna ride the shockwaves from the explosion and fly outta here. If we can make it to the ocean surface, we should be safe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“乘着爆炸气流从这里飞出去。如果飞到大海就得救了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「乘著爆炸氣流從這裡飛出去。如果飛到大海就得救了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01043",
		linknext = "0098_01045",
		line = 15695,
	},
	["0098_01045"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00103", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0147", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Are you out of your mind?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“…………你们疯了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「…………你們瘋了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01044",
		linknext = "0098_01046",
		line = 15708,
	},
	["0098_01046"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1883", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“He sure is! Nuttier than a fruitcake! Anything less, and I'd be unfit to be this guy's girlfriend!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“当然疯了！不然就没法当淳之介君的恋人了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「當然瘋了！不然就沒法當淳之介君的戀人了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_01045",
		linknext = "0098_01047",
		line = 15721,
	},
	["0098_01047"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
