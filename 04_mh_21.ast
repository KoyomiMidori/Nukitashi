	["0098_00326"] = {
		{"bgm", stop=1},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00109", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0557", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Esto... ¿eh? Si no las manipularon, ¿por qué me hicieron eso...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶……咦？这么说来桐香酱……你明明没有被操纵，却把我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸……咦？這麼說來桐香醬……你明明沒有被操縱，卻把我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00325",
		linknext = "0098_00327",
		line = 4263,
	},
	["0098_00327"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="touka_01m_00001", file1="touka_01m_00106", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0680", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Lo siento mucho, Ikuko. Es una larga historia. Pero, para no alargar tanto el asunto, quería que fueras la mensajera.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……对不起郁子。说来话长……但简单来说，我是想让你帮我传达信息。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……對不起郁子。說來話長……但簡單來說，我是想讓你幫我傳達訊息。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00326",
		linknext = "0098_00328",
		line = 4280,
	},
	["0098_00328"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0681", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Quería que transmitieras la información de que la polla de Tachibana era la clave para deshacer el lavado de cerebro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈的小鸡鸡是解除洗脑的关键……我想让你告诉他这件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩的小雞雞是解除洗腦的關鍵……我想讓你告訴他這件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00327",
		linknext = "0098_00329",
		line = 4294,
	},
	["0098_00329"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué...? Entonces... ¿ya conocían la historia de mi polla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……？你这么早就发现……我鸡巴的事情了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……？你這麼早就發現……我肉棒的事情了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00328",
		linknext = "0098_00330",
		line = 4306,
	},
	["0098_00330"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1044", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Teniendo en cuenta que Teshima utilizó su polla para lavarles el cerebro, lo más lógico sería que otra polla revirtiera el daño. En un destello de sabiduría, Touka-sama lo comprendió.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“手嶋用鸡巴给大家洗了脑。那么，打败鸡巴的也会是鸡巴吧——聪明的桐香大人是这么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「手嶋用肉棒給大家洗了腦。那麼，打敗肉棒的也會是肉棒吧——聰明的桐香大人是這麼想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00329",
		linknext = "0098_00331",
		line = 4320,
	},
	["0098_00331"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=7000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0682", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No lo sabía, pero tenía un fuerte presentimiento. Fue un poco arriesgado de mi parte, pero parece que valió la pena.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然没有确凿的证据，但我已经猜到了。虽然像是在赌博……但我好像赌赢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然沒有確鑿的證據，但我已經猜到了。雖然像是在賭博……但我好像賭贏了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00330",
		linknext = "0098_00332",
		line = 4336,
	},
	["0098_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Qué tan premeditado fue todo esto?",
					{"rt2"},
				},
			},
			cn = {
				{
					"她到底计算到了什么程度呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"她到底計算到了什麼程度呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00331",
		linknext = "0098_00333",
		line = 4346,
	},
	["0098_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siempre pensé que era imposible entenderla, pero se las arregló para dejarme expuesto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前就觉得她是个看不透的女人，但她似乎完全看透了我们这边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前就覺得她是個看不透的女人，但她似乎完全看透了我們這邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00332",
		linknext = "0098_00334",
		line = 4356,
	},
	["0098_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso, aunque intenté ocultarlo, expuse mis partes íntimas frente a todos en la olimpiada y le mostré mi polla a la presidenta del comité de moral pública.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想起在体欲节时，虽然不太显眼却在大众面前暴露了鸡巴，而且还自己给风纪委员长看了巨根——",
					{"rt2"},
				},
			},
			tw = {
				{
					"回想起在體欲節時，雖然不太顯眼卻在大眾面前暴露了肉棒，而且還自己給風紀委員長看了巨根——",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00333",
		linknext = "0098_00335",
		line = 4366,
	},
	["0098_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tal vez fue en ese momento que se dieron cuenta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许那就是她发现的契机。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許那就是她發現的契機。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00334",
		linknext = "0098_00336",
		line = 4376,
	},
	["0098_00336"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así que cuando apareciste frente a mí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，之前你会出现在我面前也是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，之前你會出現在我面前也是——」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00335",
		linknext = "0098_00337",
		line = 4388,
	},
	["0098_00337"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0683", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Era porque quería que deshicieras el lavado de cerebro que les habían hecho. Necesitaba muchas personas para rescatar a Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的，为了解除洗脑。为了夺回成为人质的文乃，我们需要人数。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的，為了解除洗腦。為了奪回成為人質的文乃，我們需要人數。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00336",
		linknext = "0098_00338",
		line = 4402,
	},
	["0098_00338"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00109", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2079", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah! ¡¿Eso quiere decir que el equipo de Rei-chan ayudó a Fumino-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……！难道是礼酱她们救了文乃酱！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……！難道是禮醬她們救了文乃醬！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00337",
		linknext = "0098_00339",
		line = 4415,
	},
	["0098_00339"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1045", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí. Fingimos que aún nos controlaban y aprovechamos una oportunidad contra Teshima cuando se nos presentó.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯。我们装出洗脑还没被解除的样子，趁手嶋不注意————总算。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯。我們裝出洗腦還沒被解除的樣子，趁手嶋不注意————總算。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00338",
		linknext = "0098_00340",
		line = 4429,
	},
	["0098_00340"] = {
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"bg", id=2, file="bg10_1l_00000", x=0, y=-100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino... ¿Es cierto?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃……真的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃……真的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00339",
		linknext = "0098_00341",
		line = 4449,
	},
	["0098_00341"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=7.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0327", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Sí... Mi memoria es débil, pero recuerdo que me guiaron... Quizá sea tarde, pero gracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯……虽然很模糊，但印象中确实是这些人给我带了路……虽然晚了，谢谢您们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗯……雖然很模糊，但印像中確實是這些人給我帶了路……雖然晚了，謝謝您們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00340",
		linknext = "0098_00342",
		line = 4462,
	},
	["0098_00342"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00119", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1046", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tranquila. No hay motivo para que nos des las gracias. Intentamos llevarte a salvo, pero te lastimaste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“把头抬起来……你不用道谢。本想把你完好无损地送出去，结果却让你受了伤。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「把頭抬起來……你不用道謝。本想把你完好無損地送出去，結果卻讓你受了傷。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00341",
