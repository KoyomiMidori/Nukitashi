	["0098_00074"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Buena pregunta... Me gustaría hablar con nuestro patrocinador.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……应该要告诉出资者吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……應該要告訴出資者吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00073",
		linknext = "0098_00075",
		line = 975,
	},
	["0098_00075"] = {
		{"fg", file="ikuko_01f_00002", file1="ikuko_01f_00109", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0550", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“El hombre que construyó la base, ¿verdad? Nunca lo he visto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是准备基地的人吧？我还没见过呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是準備基地的人吧？我還沒見過呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00074",
		linknext = "0098_00076",
		line = 988,
	},
	["0098_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es verdad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像是那样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像是那樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00075",
		linknext = "0098_00077",
		line = 998,
	},
	["0098_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El viejo no ha hablado con nosotros desde que le dijimos que Teshima secuestró a Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个老人在文乃被手嶋掳走后，就再也没有任何消息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個老人在文乃被手嶋擄走後，就再也沒有任何消息。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00076",
		linknext = "0098_00078",
		line = 1008,
	},
	["0098_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tal vez está en problemas, pero eso no es algo que podamos investigar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许是他本人发生了什么问题，但我也无从得知。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許是他本人發生了什麼問題，但我也無從得知。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00077",
		linknext = "0098_00079",
		line = 1018,
	},
	["0098_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En fin, parece que no podremos confiar en él.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎样，现在要依靠那个人好像有点困难。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎樣，現在要依靠那個人好像有點困難。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00078",
