	["0098_00968"] = {
		{"cgact", file="cgact", id=15, act="stopact"},
		{"cgdel", id=15, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00103", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2083", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun! We've taken control of all floors! How's things on your end?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳！整个楼层都压制完了！往你那边去比较好吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳！整個樓層都壓制完了！要往你那邊去嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00967",
		linknext = "0098_00969",
		line = 14646,
	},
	["0098_00969"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's all over. I've saved Asa, and everyone's unhurt. A perfect resolution.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——已经结束了。也救出麻沙酱了……大家都平安无事，简直像是圆满大结局……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——已經結束了。也救出麻沙醬了……大家都平安無事，簡直像是圓滿大結局……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00968",
		linknext = "0098_00970",
		line = 14658,
	},
	["0098_00970"] = {
