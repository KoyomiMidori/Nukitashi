	["0098_00442"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sostiene lo que parece ser un rifle de francotirador que tomó de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃手里还拿着从FS那里抢来的狙击步枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃手裡還拿著從FS那裡搶來的狙擊步槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00441",
		linknext = "0098_00443",
		line = 5800,
	},
	["0098_00443"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que debería decirle que no.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不行——我应该要这么说才对吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不行——我應該要這麼說才對吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00442",
		linknext = "0098_00444",
		line = 5810,
	},
	["0098_00444"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00103", file4="fumino_01l_00402", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=2, file="bg05_1l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, style="blur", blurx=15, blury=15, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero al ver la determinación en sus ojos rojos y resplandecientes, guardo silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，当我看到那双亮着决心的红色眼睛时，不知怎么的就说不出话来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，當我看到那雙亮著決心的紅色眼睛時，不知怎麼的就說不出話來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00443",
		linknext = "0098_00445",
		line = 5823,
	},
	["0098_00445"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He visto esa mirada antes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在哪里见过这样的瞳孔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在哪裡見過這樣的瞳孔。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00444",
		linknext = "0098_00446",
		line = 5833,
	},
	["0098_00446"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quizás veo en sus ojos la misma intención que tenía yo cuando dije que rescataría a Asane.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是我在文乃的眼中，看到了自己为了救出麻沙音而燃烧的眼睛——",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是我在文乃的眼中，看到了自己為了救出麻沙音而燃燒的眼睛——",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00445",
		linknext = "0098_00447",
		line = 5843,
	},
	["0098_00447"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿Puedes pelear en ese estado?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……在这种状态下，你能战斗吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……在這種狀態下，你能戰鬥嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00446",
		linknext = "0098_00448",
		line = 5854,
	},
	["0098_00448"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0332", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No siento nada por estas heridas. Aunque me encuentre en este estado, sigo siendo una mujer fuerte.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这种程度的伤，对我不痛不痒……因为文乃是个坚强的女人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這種程度的傷，對我不痛不癢……因為文乃是個堅強的女人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00447",
		linknext = "0098_00449",
		line = 5866,
	},
	["0098_00449"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voluntad es inquebrantable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"意志似乎非常坚决。",
					{"rt2"},
				},
			},
			tw = {
				{
					"意志似乎非常堅決。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00448",
		linknext = "0098_00450",
		line = 5876,
	},
	["0098_00450"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Ten mucho cuidado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——记得别勉强自己了。”",
					{"rt2"},
				},
			},
			tw = {
