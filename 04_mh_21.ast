			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Tachibana-sama... A mí también me gustaría estar en el frente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……橘大人……我也想加入战线……”",
