	},
	["0098_00990"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="hitoura_01l_00001", file1="hitoura_01l_00104", path=":fg/hitoura_01l/", id=10, lv=5, head="hitoura_01l", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=2, file="bg03_1l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Governor, can I talk to you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“知事——可以打扰一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「知事——可以打擾一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00989",
		linknext = "0098_00991",
		line = 14940,
	},
	["0098_00991"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0145", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oh, you're Tachibana? You went out of your way to save me. I owe you a debt. I suppose this is about the law?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“啊……是橘少年啊。文乃也是——连我都获救了，我非常感谢……是条例的事对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「啊……是橘少年啊。文乃也是——連我都獲救了，我非常感謝……是條例的事對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00990",
		linknext = "0098_00992",
		line = 14952,
	},
	["0098_00992"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. You promised you'd accept our conditions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。那个会答应我们的要求的约定——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。那個會答應我們的要求的約定——」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00991",
		linknext = "0098_00993",
		line = 14963,
	},
	["0098_00993"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0146", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“A man doesn't go back on his word. Whatever demands you have, I will listen to them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“男人言出必行。不管你们的要求是什么我都会听的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「男人言出必行。不管你們的要求是什麼我都會聽的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00992",
		linknext = "0098_00994",
		line = 14975,
	},
	["0098_00994"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel a tightening in my chest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"光是听到这句话，我就觉得胸口被什么给堵住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"光是聽到這句話，我就覺得胸口被什麼給堵住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00993",
		linknext = "0098_00995",
		line = 14986,
	},
