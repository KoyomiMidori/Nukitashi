		linkback = "0098_00359",
		linknext = "0098_00361",
		line = 4722,
	},
	["0098_00361"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No digas nada más, Fumino. Tú misma deberías saber que no te corresponde decir cosas así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……闭嘴文乃。你应该知道我们不是在说那种事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……閉嘴文乃。你應該知道我們不是在說那種事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00360",
