	["0098_01050"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00111", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
