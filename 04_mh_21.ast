				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫B"},
					"“咦……魔镜号？到底是哪里的……等等，太奇怪了吧！？等一下……停下……等等等等一下——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛B"},
					"「咦……魔鏡號？到底是哪裡的……等等，太奇怪了吧！？等一下……停下……等等等等一下——！？」",
					{"rt2"},
				},
			},
		},
