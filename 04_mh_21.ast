	["0098_00317"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca había visto a tantos juntos. Deben haberse encontrado de camino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"数量比刚才还多。是在哪里汇合的呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"數量比剛才還多。是在哪裡會合的呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00316",
		linknext = "0098_00318",
		line = 4152,
	},
	["0098_00318"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0677", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No tienes por qué ponerte a la defensiva. Me atrevo a decir que ahora estamos más o menos de tu lado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“请不要紧张。说不定我们是同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「請不要緊張。說不定我們是同伴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00317",
		linknext = "0098_00319",
		line = 4164,
	},
	["0098_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Teshima... no les lavó el cerebro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你……不是被手嶋洗脑了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你……不是被手嶋洗腦了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00318",
		linknext = "0098_00320",
		line = 4175,
	},
	["0098_00320"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0678", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No... Solo estaba fingiendo que me controlaba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯……因为我是这样演得。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯……因為我是這樣演得。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00319",
		linknext = "0098_00321",
		line = 4189,
	},
	["0098_00321"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fingiendo... ¿Entonces nunca te lavaron el cerebro? ¿Cómo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“演……？也就是说，你根本没有被洗脑？为什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「演……？也就是說，你根本沒有被洗腦？為什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00320",
		linknext = "0098_00322",
		line = 4201,
	},
	["0098_00322"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0679", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yo tampoco lo sé. Pero si tuviera que responder a esa pregunta... tal vez fue porque no soy prisionera de los deseos mundanos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“到底是为什么呢？硬要说的话……也许是因为我连想屈于人下的欲望都没有吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「到底是為什麼呢？硬要說的話……也許是因為我連想屈於人下的慾望都沒有吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00321",
		linknext = "0098_00323",
		line = 4215,
	},
	["0098_00323"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1043", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No es que todos se sometieran a su voluntad. Si fuera así, no habría necesidad de tener rehénes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“并不是谁都屈服在那家伙之下。说到底，如果他真的办得到，那就不需要人质了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「並不是誰都屈服在那傢伙之下。說到底，如果他真的辦得到，那就不需要人質了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00322",
		linknext = "0098_00324",
		line = 4229,
	},
	["0098_00324"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es verdad... Si le hubiera lavado el cerebro a Hitoura, no habría tenido que llegar a estos extremos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，只要一开始直接给仁浦先生洗脑就可以了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，只要一開始直接給仁浦先生洗腦就可以了。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00323",
		linknext = "0098_00325",
		line = 4239,
	},
	["0098_00325"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En pocas palabras, a ellas no les afectó el lavado de cerebro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，这两个人也没有受到洗脑的影响吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，這兩個人也沒有受到洗腦的影響吧。",
