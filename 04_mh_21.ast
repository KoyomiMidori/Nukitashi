		{"fg", file="teshima_01m_00001", file1="teshima_01m_00121", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0165", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Tachibana... how the fuck did you get here...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“橘……你他妈……是怎么到这里的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「橘……你他媽……是怎麼到這裡的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00762",
		linknext = "0098_00764",
		line = 11456,
	},
	["0098_00764"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like I need to answer you, asshole. Give Asane back. Now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我没有义务回答你。把麻沙音还给我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我沒有義務回答你。把麻沙音還給我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00763",
		linknext = "0098_00765",
		line = 11468,
	},
	["0098_00765"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=2, size=5, time=100, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3300] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00118", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, delay2=3300, time=300, mode=3, x=0, y=0},
				{"fgact", ch="手嶋", id=8, act="振動下", loop=10, size=5, time=100, ease="easeinout_sine", delay2=3300},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0166", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, heh heh... Hahaha... BWAHAHAHAHA!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……呼、呵呵……哈哈哈……哈——哈哈哈！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「……呼、呵呵……哈哈哈……哈——哈哈哈！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00764",
		linknext = "0098_00766",
		line = 11486,
	},
	["0098_00766"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00117", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0167", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You seriously are a fuckin' mong, Tachibana! I'm surprised ya managed t' join us and all, but what the fuck you plannin' on doin' barging in here empty-handed!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“橘你果然是个笨蛋啊！虽然能来到这里让我有点惊讶……但你一个人空手跑来这里，能做什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「橘你果然是個笨蛋啊！雖然能來到這裡讓我有點驚訝……但你一個人空手跑來這裡，能做什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00765",
		linknext = "0098_00767",
		line = 11500,
	},
	["0098_00767"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, I've got something in mind. You really think I'd come here empty-handed?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——当然没问题。你看起来我像空手是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——當然沒問題。你看起來我像空手是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00766",
		linknext = "0098_00768",
		line = 11512,
	},
	["0098_00768"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm carrying the most powerful weapon in the world right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我现在拥有比世上任何武器都强大的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我現在擁有比世上任何武器都強大的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00767",
		linknext = "0098_00769",
		line = 11524,
	},
	["0098_00769"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00121", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0168", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Huh... Li'l shit's gotten good at bluffin'. So, whatcha got? Them fruity goggles o' yers shoot lasers or what!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啊啊？……你的虚张声势变厉害了呢？但是，你说你拥有什么？难道那副护目镜会射出光束吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啊啊？……你的虛張聲勢變厲害了呢？但是，你說你擁有什麼？難道那副護目鏡會射出光束嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00768",
		linknext = "0098_00770",
		line = 11538,
	},
	["0098_00770"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“————是爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「————是愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00769",
		linknext = "0098_00771",
		line = 11550,
	},
	["0098_00771"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00106", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0169", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啥？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啥？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00770",
		linknext = "0098_00772",
		line = 11564,
	},
	["0098_00772"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I came here with love. Something a motherfucker like you, who won't even give the time of day to someone who isn't subservient to him, would never be able to have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我有爱。只能通过洗脑来接触他人的你，是绝对无法得到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我有愛。只能通過洗腦來接觸他人的你，是絕對無法得到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00771",
		linknext = "0098_00773",
		line = 11576,
	},
	["0098_00773"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00118", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="手嶋", id=8, act="振動下", loop=5, size=5, time=100, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0170", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh... Heh heh... BWAHAHAHAHA!! Well, shit on a shingle! You hearin' this shit, King of the Thots!? How 'bout you, scissor sister!? Love! Love, he fuckin' says!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“呼……呵呵呵……哈哈哈哈哈哈！喂喂喂！听到了吗变态大将和百合妹！？爱！他说爱哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「呼……呵呵呵……哈哈哈哈哈哈！喂喂喂！聽到了嗎變態大將和百合妹！？愛！他說愛哦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00772",
		linknext = "0098_00774",
		line = 11593,
	},
	["0098_00774"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00117", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0171", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ha! What... What the actual fuck! Yer killin' me over here! Virginfag does it again! You a fuckin' genius or what!? Never thought this big damn hero was such a fortune cookie Confucius!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈！难、难道……难道你……是打算让我笑死吗！？哈哈……不愧是处女厨！真是天才啊！？没想到这种地方居然有诸葛孔明！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈！難、難道……難道你……是打算讓我笑死嗎！？哈哈……不愧是處女廚！真是天才啊！？沒想到這種地方居然有諸葛孔明！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00773",
		linknext = "0098_00775",
		line = 11607,
	},
	["0098_00775"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I pity you, Teshima. It must suck being a man who doesn't know what love is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真可悲啊手嶋。连爱都不知道的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真可悲啊手嶋。連愛都不知道的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00774",
		linknext = "0098_00776",
		line = 11619,
	},
	["0098_00776"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00118", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0172", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You think YOU get to fuckin' decide who deserves pity right now!? Is that love o' yers gonna save yer fuckin' ass? WELL!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“可悲的是谁啊！？那个爱能保护你吗！啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「可悲的是誰啊！？那個愛能保護你嗎！啊！？」",
					{"rt2"},
				},
			},
		},
