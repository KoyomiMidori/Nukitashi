	["0098_00304"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si no llevo a Fumino a la sede de la OSS, Asane va a—",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那之前如果不把文乃带到SHO总部，麻沙音就会——",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那之前如果不把文乃帶到SHO總部，麻沙音就會——",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00303",
		linknext = "0098_00305",
		line = 3992,
	},
	["0098_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero si le entrego a Fumino, todo esto habrá sido en vano.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，如果把文乃交出去，情况又会回到一开始。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，如果把文乃交出去，情況又會回到一開始。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00304",
		linknext = "0098_00306",
		line = 4002,
	},
	["0098_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque eso salvara a Asane—  Esperen, ¿cómo puedo dar por sentado que va a cumplir su parte del trato?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是可以拯救麻沙音的生命————不，那家伙会遵守约定吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是可以拯救麻沙音的生命————不，那傢伙會遵守約定嗎？",
					{"rt2"},
				},
			},
		},
