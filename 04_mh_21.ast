					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヤクザA", "黑社會A"},
					"「哈哈哈！你不交給我嗎？在這種情況下，你居然還能說出那種話來，真了不起。老實說，我並不討厭你這樣的……不過真不巧，這是手嶋大人的命令！」",
					{"rt2"},
