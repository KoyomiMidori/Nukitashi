	["0098_00277"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00118", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0153", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“¡JAJAJAJA! ¡Me alegra escucharte tan animado! Ya encontraron a Fumino, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啊哈哈哈！！看来你很有精神呢！这么说来文乃你也找到了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啊哈哈哈！！看來你很有精神呢！這麼說來文乃你也找到了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00276",
		linknext = "0098_00278",
		line = 3675,
	},
	["0098_00278"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
