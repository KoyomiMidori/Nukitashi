		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0181", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SHOガードマンA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "OSS Guard A"},
					"“That damned SS... a mere student organization thinks they can defy Mr. Teshima? They deserve divine retribution... oops, it's time for a change of guard. Perfect timing. I wanna get prepared and go out and engage those SS... hmm?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SHO警卫A"},
					"“可恶的FS……区区学生组织居然敢对抗手嶋大人，会遭天谴的……差不多是换班的时间了。正好，到外面做好迎击FS的……嗯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛A"},
					"「可惡的FS……區區學生組織居然敢對抗手嶋大人，會遭天譴的……差不多是換班的時間了。正好，到外面做好迎擊FS的……嗯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00575",
		linknext = "0098_00577",
		line = 7945,
	},
