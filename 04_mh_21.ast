		{"fg", file="touka_01l_00001", file1="touka_01l_00101", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=500, mode=3, x=-30, y=0},
		{"fgact", ch="桐香", id=8, act="移動", x=30, y=0, time=2000},
		{"text"},
		text = {
