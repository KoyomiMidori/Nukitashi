			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，那是秘密啊……对不起礼酱……你、你生气了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，那是秘密啊……對不起禮醬……你、你生氣了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00414",
		linknext = "0098_00416",
