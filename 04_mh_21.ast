					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Por favor. Yo misma me he buscado esta desgracia. Tu hermanita no se merece sufrir en mi lugar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“拜托了……这本来就是我自己酿成的灾祸……如果能成为橘大人最重要的家人的替身，我一点也不觉得可惜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「拜託了……這本來就是我自己釀成的災禍……如果能成為橘大人最重要的家人的替身，我一點也不覺得可惜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00358",
		linknext = "0098_00360",
		line = 4712,
	},
	["0098_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
