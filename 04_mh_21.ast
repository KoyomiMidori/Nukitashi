			},
			en = {
				{
					"Perfecto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事情定下来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"事情定下來了。",
					{"rt2"},
