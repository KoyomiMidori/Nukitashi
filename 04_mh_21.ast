	},
	["0098_00344"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0558", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“... Si ese era tu plan, podrías habérmelo dicho antes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……如果是那样的计划的话，告诉我就好了啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……如果是那樣的計劃的話，告訴我就好了啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00343",
		linknext = "0098_00345",
		line = 4504,
	},
	["0098_00345"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[3700] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00124", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=3700, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1047", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Para engañar al enemigo, primero hay que engañar a los aliados... Bueno, aunque no teníamos otra opción en estas circunstancias... Eso me sienta mal. Quiero darte las gracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“要想欺骗敌人，首先得从自己人开始……不过，虽说在那种情况下也没办法……我也觉得不太好意思……很感谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「要想欺騙敵人，首先得從自己人開始……不過，雖說在那種情況下也沒辦法……我也覺得不太好意思……很感謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00344",
		linknext = "0098_00346",
		line = 4520,
	},
	["0098_00346"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00109", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=1, mode=3, x=400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0559", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“¡¿Eh?! No puede ser... Rei-chan me dio las gracias... C-Creo que aún la están controlando...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶！？骗人的吧……被礼酱感谢了……你、你果然还是洗脑状态吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸！？騙人的吧……被禮醬感謝了……你、你果然還是洗腦狀態吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00345",
		linknext = "0098_00347",
		line = 4535,
	},
	["0098_00347"] = {
		{"bgm", stop=1},
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1048", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oye... ¡¿Te muestro un poco de respeto y me respondes así?! ¡Esto no habría si no hubieras mantenido en secreto lo que sabías de los anticopuladores! ¡¿Entiendes?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你这人……人家一放低姿态就这样！说到底，如果你不隐瞒反交尾势力的事情，就不会变成这样了！你知道吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你這人……人家一放低姿態就這樣！說到底，如果你不隱瞞反交尾勢力的事情，就不會變成這樣了！你知道嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00346",
		linknext = "0098_00348",
		line = 4550,
	},
	["0098_00348"] = {
