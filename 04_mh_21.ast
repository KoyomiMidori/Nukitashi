			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Tranquilo. Nuestra colaboradora está reemplazando los videos con material antiguo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不用担心。已经让协助者把监视影像换成过去的影像了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不用擔心。已經讓協助者把監視影像換成過去的影像了。」",
					{"rt2"},
				},
