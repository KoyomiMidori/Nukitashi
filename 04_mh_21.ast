			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Siempre me da pena cuando hace estas locuras sin remedio.. Jaa. Bueno, ya para qué me sorprendo.”",
					{"rt2"},
				},
			},
			cn = {
				{
