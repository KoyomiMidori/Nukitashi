			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“So you say! The SS an' the OSS ain't nothin' more than Hitoura's trained dogs. He just needs ta give th'word, and everything's gonna be reversed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“是这样吗……反正FS和SHO都是仁浦养的狗。只要这个男人能听我的命令，什么办法都有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「是這樣嗎……反正FS和SHO都是仁浦養的狗。只要這個男人能聽我的命令，什麼辦法都有。」",
					{"rt2"},
