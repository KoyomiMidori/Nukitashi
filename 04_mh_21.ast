	["0098_00423"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tengo que mirar hacia adelante — Concéntrate en la sede de la OSS y piensa en rescatar a Asane.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我看着前方——凝视着远方的SHO本部，心里只想着如何拯救被囚禁在那里的麻沙音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我看著前方——凝視著遠方的SHO本部，心裡只想著如何拯救被囚禁在那裡的麻沙音。",
					{"rt2"},
