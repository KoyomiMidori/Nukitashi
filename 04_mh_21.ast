					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Tch...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“切——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嘖——！」",
