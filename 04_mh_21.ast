				},
			},
			cn = {
				{
					name = {"礼"},
					"“贪睡放纵之人啊……听此枪声睁眼吧！然后在主人回归之时觉悟吧！全队同时扫射！发射！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「貪睡放縱之人啊……聽此槍聲睜眼吧！然後在主人回歸之時覺悟吧！全隊同時掃射！發射！」",
					{"rt2"},
				},
