	["0119_00196"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
