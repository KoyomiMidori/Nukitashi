			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I didn't do... that much... it was all Junnosuke's efforts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我……没有做、那么厉害的事情……都是淳之介同学的功劳……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我……沒有做、那麼厲害的事情……都是淳之介同學的功勞……」",
