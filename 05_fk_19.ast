	["0119_00282"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00204", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=450, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1053", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm terribly sorry... I'll be sure to... properly smile next time we meet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“非常抱歉……下次见面之前，我一定……一定……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「非常抱歉……下次見面之前，我一定……一定……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00281",
		linknext = "0119_00283",
		line = 3894,
	},
	["0119_00283"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She returns to her usual expression and nods.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃恢复了平常的表情，点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃恢復了平常的表情，點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00282",
		linknext = "0119_00284",
		line = 3904,
	},
	["0119_00284"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She seems to have resolved herself on all fronts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她好像已经做好了某种心理准备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她好像已經做好了某種心理準備。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00283",
		linknext = "0119_00285",
		line = 3917,
	},
	["0119_00285"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1054", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Experience repeated hardships, overcome numerous difficulties, and finally attain the fulfillment of your goals through your trials and tribulations.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“尝过多重辛酸，克服无数苦难，在辛苦艰难的尽头，成就圆满夙愿——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嚐過多重辛酸，克服無數苦難，在辛苦艱難的盡頭，成就圓滿夙願——」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00284",
		linknext = "0119_00286",
		line = 3929,
	},
	["0119_00286"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？」",
					{"rt2"},
				},
			},
		},
