					name = {"淳之介", "Junnosuke"},
					"“Of course. If you need anything, I'll send them to your new place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然了。有必要会随时送到文乃的新家的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然了。有必要會隨時送到文乃的新家的。」",
