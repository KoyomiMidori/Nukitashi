					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, how were things with the flight simulator, Hotori?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起那个，畔，交给你的飞行模拟器，怎么样了？”",
