			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I've mastered it, of course! You said not to come to school until I got a perfect score, so I didn't!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“当然是完美完成了！因为被说没拿到100分就别来学校，所以我当天就……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「當然是完美完成了！因為被說沒拿到100分就別來學校，所以我當天就……！」",
					{"rt2"},
				},
			},
		},
