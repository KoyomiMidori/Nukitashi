			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Next time, it shall be my turn.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这次轮到我了。”",
