					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The operation's tomorrow. So try to make a good stopping point for the housekeeping, and get to bed early, all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明天还有作战行动，扫得差不多就早点去睡吧。”",
