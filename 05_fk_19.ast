		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll find an apartment somewhere. Though Asa's obviously going to be coming with me, so it might get rowdy again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后我会在某处租房子。虽然麻沙酱大概还是在一起，所以会有些吵闹——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後我會在某處租房子。雖然麻沙醬大概還是在一起，所以會有些吵鬧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00271",
		linknext = "0119_00273",
		line = 3758,
	},
	["0119_00273"] = {
