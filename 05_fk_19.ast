ast = {
	["0119_00001"] = {
		{"fg", mode=-1, id=30},
		{"savetitle", text="宣戦布告", ja="宣戦布告", en="Declaration of War", cn="开战宣言", tw="開戰宣言"},
		{"eval", exp="g.05_fk_19=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"bg", id=1, file="bg12_1l_00000", x=350, y=0, path=":bg/", sync=0, time=600, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0153", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“At long last, our mission shall be fulfilled tomorrow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“……明天就是作战执行日了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「……明天就是作戰執行日了。」",
					{"rt2"},
				},
			},
		},
		linknext = "0119_00002",
		line = 23,
	},
	["0119_00002"] = {
		{"bgm", file="bgm12", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mr. Sakimori says that to us the day before we hand Fumino over, with a humble look on his face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃被引渡的前一天，作为资助人的防人老人带着神秘的表情这样说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃被引渡的前一天，作為資助人的防人老人帶著神秘的表情這樣說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00001",
		linknext = "0119_00003",
		line = 34,
	},
	["0119_00003"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0154", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“How is your progress with preparing for the day to come?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“这一天的准备，情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「這一天的準備，情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00002",
		linknext = "0119_00004",
		line = 46,
	},
	["0119_00004"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Very smooth. We had some concerns about tackling the OSS indoors, but we've managed to come up with appropriate countermeasures.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“很顺利。对比较担心的与SHO的室内战，我也有所对策。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「很順利。對比較擔心的與SHO的室內戰，我也有所對策。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00003",
		linknext = "0119_00005",
		line = 58,
	},
	["0119_00005"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0155", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Hmm, I see. Hm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“嗯……是吗……嗯……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「嗯……是嗎……嗯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00004",
		linknext = "0119_00006",
		line = 70,
	},
	["0119_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He nods to himself and occasionally glances over at Fumino, who's looking uneasy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人点了好几次头，并且不时将目光带到文乃身上，但似乎无法平静下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人點了好幾次頭，並且不時將目光帶到文乃身上，但似乎無法平靜下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00005",
		linknext = "0119_00007",
		line = 80,
	},
	["0119_00007"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0156", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I wish you all good luck in your tough battle ahead. Fumino's safety rests on your shoulders. That is all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“那么，期待你们的奋战……文乃就拜托你们了。就这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「那麼，期待你們的奮戰……文乃就拜託你們了。就這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00006",
		linknext = "0119_00008",
		line = 93,
	},
	["0119_00008"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_b032"},
		{"fg", mode=-1, id=30, ch="防人老人", lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He bows to us, in a rare gesture, and ends the transmission.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人难得低下了头，结束了通讯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人難得低下了頭，結束了通訊。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00007",
		linknext = "0119_00009",
		line = 108,
	},
	["0119_00009"] = {
		{"se", id=0, stop=1, time=1000},
		{"bgm", file="bgm07", vol=100},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2183", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's the most serious I've ever seen our sponsor act. He even bowed to us, that was a surprise.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“出资的防人老爷爷，表情真的好认真啊……都没见过呢……好惊讶啊，第一次看到他低头的样子哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「出資的防人老爺爺，表情真的好認真啊……都沒見過呢……好驚訝啊，第一次看到他低頭的樣子哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00008",
		linknext = "0119_00010",
		line = 124,
	},
	["0119_00010"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
