		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2262", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yep, fine. We managed to have a party in safety, which we almost never have. Plus, you probably have a lot to talk about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
