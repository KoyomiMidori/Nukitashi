		linkback = "0119_00269",
		linknext = "0119_00271",
		line = 3734,
	},
	["0119_00271"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And after that, I'm leaving the island. Not sure if I'm gonna do college or just enter the workforce, but I'm still going to leave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“之后无论是工作还是升学，我都打算离开这个岛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「之後無論是工作還是升學，我都打算離開這個島。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00270",
		linknext = "0119_00272",
		line = 3746,
	},
	["0119_00272"] = {
