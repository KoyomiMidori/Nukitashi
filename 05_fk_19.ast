		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2061", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's fine, Fumino. You weren't with us for that long, but thanks for all you did!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没事的文乃酱，虽然时间很短，但是辛苦你了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒事的文乃醬，雖然時間很短，但是辛苦你了……！」",
