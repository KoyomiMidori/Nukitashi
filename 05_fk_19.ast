	["0119_00277"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The year will fly by before you even know it. So don't worry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别担心，一年一转眼就过去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別擔心，一年一轉眼就過去了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00276",
		linknext = "0119_00278",
