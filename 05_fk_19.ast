		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00107", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="仁浦", id=10, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0216", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Mmm... this place is nice. The sea breeze and the silence are quite soothing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯……这里果然不错啊，静谧中的海风真让人心情舒畅……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯……這裡果然不錯啊，靜謐中的海風真讓人心情舒暢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00073",
		linknext = "0119_00075",
		line = 1122,
	},
	["0119_00075"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It'd be more relaxing if it weren't for the moans being carried on the wind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果没有随风而来的娇喘声，应该会更舒服吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果沒有隨風而來的嬌喘聲，應該會更舒服吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00074",
		linknext = "0119_00076",
