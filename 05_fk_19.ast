		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1723", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ever since she came here she's been doing all the housework for us and Nanase hasn't come even once, like, she does all the housekeeping, all the cooking, and our clothes are never dirty!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为文乃来了之后奈奈濑同学就完全没有来我们家做家务了，会打扫房子，饭也会做，衣服也总是很干净……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為文乃來了之後奈奈瀨同學就完全沒有來我們家做家事了，會打掃房子，飯也會做，衣服也總是很乾淨……！」",
					{"rt2"},
				},
			},
		},
