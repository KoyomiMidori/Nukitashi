	["0119_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You've been fighting off the yakuza since you were little. Thanks to that, their activities have been minimized.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“能把黑社会的坏勾当减少到最小，是因为你从小就在跟他们战斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「能把黑社會的壞勾當減少到最小，是因為你從小就在跟他們戰鬥。」",
