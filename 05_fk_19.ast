		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2251", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sorry, Fumino. Everybody's pretty on edge, so why don't you put on some tea? Look, even Asa's flaking out on us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对不起文乃，大家好像都很紧张，能帮我们倒茶吗？看，麻沙酱都筋疲力尽了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對不起文乃，大家好像都很緊張，能幫我們倒茶嗎？看，麻沙醬都筋疲力盡了……」",
					{"rt2"},
				},
			},
		},
