	["0119_00079"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0218", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Heh. I have no clue what that dead-eyed girl is telling you, but the OSS gets word of everything that goes on in that academy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵，虽然不知道那个‘无欲的少女’说了什么，但学校中的事情SHO可以说是一清二楚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵，雖然不知道那個『無欲的少女』說了什麼，但學校中的事情SHO可以說是一清二楚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00078",
		linknext = "0119_00080",
		line = 1188,
	},
	["0119_00080"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Dead-eyed girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……无欲的少女？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……無欲的少女？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00079",
		linknext = "0119_00081",
		line = 1200,
	},
	["0119_00081"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0219", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Reizeiin Touka, the student council president. You know how commendable she is as well, yes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“担任学生会长的冷泉院桐香。你也知道那个人也是个特别奇特的姑娘吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「擔任學生會長的冷泉院桐香。你也知道那個人也是個特別奇特的姑娘吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00080",
		linknext = "0119_00082",
		line = 1214,
	},
	["0119_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, she often says how she has no interest in neither the SS nor the OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，她说她对FS和SHO都不感兴趣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，她說她對FS和SHO都不感興趣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00081",
		linknext = "0119_00083",
		line = 1226,
	},
	["0119_00083"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0220", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“She has absolutely no loyalty to speak of, but she's capable. That's to be expected of an orphan from the eminently capable Reizeiin family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“虽然完全没有忠诚心，但却能做好工作。不愧是‘十得的冷泉院’的孤儿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「雖然完全沒有忠誠心，但卻能做好工作。不愧是『十得的冷泉院』的孤兒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00082",
		linknext = "0119_00084",
		line = 1238,
	},
	["0119_00084"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is it a famous lineage?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是有名的家世吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是有名的家世嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00083",
		linknext = "0119_00085",
		line = 1250,
	},
	["0119_00085"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0221", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Long ago, it was. It's virtually unknown in the west of the nation, but in the east, it ranks with the families of Fumikane, Shinoshiki and Tsudzurahara.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“在以前。虽然在西方没有什么知名度，但在东方却以‘文钟’、‘四色’、‘黑葛原’等齐名的一族而闻名。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「在以前。雖然在西方沒有什麼知名度，但在東方卻以『文鐘』、『四色』、『黑葛原』等齊名的一族而聞名。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00084",
		linknext = "0119_00086",
		line = 1264,
	},
	["0119_00086"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0222", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Reizeiin is a family known for its omnipotence. But that dead-eyed girl is a master of non-conformity. She is well-suited for this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“冷泉院被认为是万能的一族。但是，无欲的少女是特化型的异端，所以才跟这个岛合得来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「冷泉院被認為是萬能的一族。但是，無欲的少女是特化型的異端，所以才跟這個島合得來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00085",
		linknext = "0119_00087",
		line = 1278,
	},
	["0119_00087"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0223", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“She has zero interest in fame or fortune. She's just satisfied existing. People like that are hard to handle, but I don't dislike them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那个姑娘没有金钱欲也没有名声欲。光是以原本的样貌存在就很满足的少女。这样的人很难操纵，但我并不讨厌。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那個姑娘沒有金錢欲也沒有名聲欲。光是以原本的樣貌存在就很滿足的少女。這樣的人很難操縱，但我並不討厭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00086",
		linknext = "0119_00088",
		line = 1292,
	},
	["0119_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can't imagine her ever rising up in revolt. She's more of the type who would quietly knife me in the back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不怕她总有一天会背叛是吗？是我的话早就从背后断喉了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不怕她總有一天會背叛是嗎？是我的話早就從背後斷喉了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00087",
		linknext = "0119_00089",
		line = 1304,
	},
	["0119_00089"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6000] = {
				{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, delay2=6000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=450, ease="easeinout_sine", delay2=6000},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0224", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Were she not so rebellious, I wouldn't have given her the top position of a large organization. And yet... Heh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果没有那种程度的反抗精神，就无法胜任大组织的领导哦……不过……嗯……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果沒有那種程度的反抗精神，就無法勝任大組織的領導哦……不過……嗯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00088",
		linknext = "0119_00090",
		line = 1321,
	},
	["0119_00090"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00089",
		linknext = "0119_00091",
		line = 1333,
	},
	["0119_00091"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0225", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“They often talk about what happens if you don't see a man for three days. You were like a fawn before but now you have the eyes of a lion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“俗话说士别三日，刮目相看。以前还像只小鹿一样，现在已经是狮子的眼睛了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「俗話說士別三日，刮目相看。以前還像隻小鹿一樣，現在已經是獅子的眼睛了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00090",
		linknext = "0119_00092",
		line = 1347,
	},
	["0119_00092"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I have no reason whatsoever to feel timid.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我没有任何值得胆怯的理由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我沒有任何值得膽怯的理由。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00091",
		linknext = "0119_00093",
		line = 1359,
	},
	["0119_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That may sound defiant, but I don't care either way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然也可以说是在逞强，但是怎样都好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然也可以說是在逞強，但是怎樣都好。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00092",
		linknext = "0119_00094",
		line = 1369,
	},
	["0119_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm prepared to face the worst for her sake.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我只是为了那个孩子而下定了决心而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我只是為了那個孩子而下定了決心而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00093",
		linknext = "0119_00095",
		line = 1379,
	},
	["0119_00095"] = {
		{"bgm", stop=1},
		{"se", id=3, stop=1, time=1200},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00107", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0226", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So... how's Fumino doing? Is she well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那么……文乃怎么样了？她过得好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那麼……文乃怎麼樣了？她過得好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00094",
		linknext = "0119_00096",
		line = 1396,
	},
	["0119_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When your name came up she managed to call you a 'worthless father'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在说到你的时候，她都会说‘那是个没用的父亲’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在說到你的時候，她都會說『那是個沒用的父親』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00095",
		linknext = "0119_00097",
		line = 1408,
	},
	["0119_00097"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0227", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Really...? She said that...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……是吗……她那样说了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……是嗎……她那樣說了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00096",
		linknext = "0119_00098",
		line = 1423,
	},
	["0119_00098"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, more or less.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……嗯，类似这样的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……嗯，類似這樣的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00097",
		linknext = "0119_00099",
		line = 1435,
	},
	["0119_00099"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00106", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0228", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Really...? Worthless, eh... I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这样啊……很没用是吗……这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這樣啊……很沒用是嗎……這樣啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00098",
		linknext = "0119_00100",
		line = 1450,
	},
	["0119_00100"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I-It wasn't quite so harsh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她、她没说得那么严重哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她、她沒說得那麼嚴重哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00099",
		linknext = "0119_00101",
		line = 1462,
	},
	["0119_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is he just acting?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是演技吗……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是演技嗎……？",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00100",
		linknext = "0119_00102",
		line = 1472,
	},
	["0119_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He definitely doesn't look like he is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，看起来不像……",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，看起來不像……",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00101",
		linknext = "0119_00103",
		line = 1482,
	},
	["0119_00103"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But more importantly. You seem to have more or less figured out her location now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起那个，你已经在一定程度上准确地掌握了文乃的所在地。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起那個，你已經在一定程度上準確地掌握了文乃的所在地。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00102",
		linknext = "0119_00104",
		line = 1495,
	},
	["0119_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So why aren't you trying to seize her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那又为什么不来把她抓回去？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那又為什麼不來把她抓回去？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00103",
		linknext = "0119_00105",
		line = 1507,
	},
	["0119_00105"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0229", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I'm happy for you to think of it as a reward for destroying the illegal sex industry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你可以认为那是歼灭了地下风俗的奖励哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你可以認為那是殲滅了地下風俗的獎勵哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00104",
		linknext = "0119_00106",
		line = 1521,
	},
	["0119_00106"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, even if you don't seize her, you could solve everything by taking me into custody and forcing me to talk. So why won't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不对，就算你还没掌握，只要抓住我逼我说就好了。为什么不这样做？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不對，就算你還沒掌握，只要抓住我逼我說就好了。為什麼不這樣做？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00105",
		linknext = "0119_00107",
		line = 1533,
	},
	["0119_00107"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0230", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Even if I did, I am highly doubtful you would talk, young man. A person of talent is useless to me unless they willingly join my organization.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“就算抓住你，你也不会说的吧，少年。有能力的人，如果不是让他以自己的意志来我的组织，就无法发挥作用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「就算抓住你，你也不會說的吧，少年。有能力的人，如果不是讓他以自己的意志來我的組織，就無法發揮作用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00106",
		linknext = "0119_00108",
		line = 1545,
	},
	["0119_00108"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Meaning, you're giving me time to think about it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，你在给我考虑的时间……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，你在給我考慮的時間……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00107",
		linknext = "0119_00109",
		line = 1557,
	},
	["0119_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if it means I can get Fumino out of your reach and destroy the island first?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……就算在这个期间里，我把文乃保护在你够不着的地方，然后摧毁这个岛也没关系吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……就算在這個期間裡，我把文乃保護在你搆不著的地方，然後摧毀這個島也沒關係嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00108",
		linknext = "0119_00110",
		line = 1569,
	},
	["0119_00110"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0231", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“There are limits to what you can do alone, should it come to that. That means you'll need people to guide you. It's crucial that I bring them to light.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“就算想这么干，你一个人的力量也是有限的。也就是说有人在引导你。调查出那个人的底细才是最重要的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「就算想這麼幹，你一個人的力量也是有限的。也就是說有人在引導你。調查出那個人的底細才是最重要的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00109",
		linknext = "0119_00111",
		line = 1583,
	},
	["0119_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shit, so he knew about that too...",
					{"rt2"},
				},
			},
			cn = {
				{
					"切，连这个都知道了吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"嘖，連這個都知道了嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00110",
		linknext = "0119_00112",
		line = 1593,
	},
	["0119_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, it's your funeral, then. I'm going to keep her in my custody, no matter what.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那我就好好利用你的误解，就这样一直保护她吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那我就好好利用你的誤解，就這樣一直保護她吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00111",
		linknext = "0119_00113",
		line = 1605,
	},
	["0119_00113"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0232", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Do what you will. Anything you obtain in battle can be lost again in battle. Am I mistaken?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那应该也不错吧。在战斗中被抢走的东西，就要在战斗中夺回。不是吗，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那應該也不錯吧。在戰鬥中被搶走的東西，就要在戰鬥中奪回。不是嗎，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00112",
		linknext = "0119_00114",
		line = 1619,
	},
	["0119_00114"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What, you're gonna take her back in a fair fight? That's rich. As if you were ever on the side of the righteous.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是说抢的时候要光明正大地抢吗？一副自己是正义的同伴的嘴脸——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是說搶的時候要光明正大地搶嗎？一副自己是正義的同伴的嘴臉——」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00113",
		linknext = "0119_00115",
		line = 1631,
	},
	["0119_00115"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0233", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I am a villain. That is precisely why I've been able to bring this island the prosperity it enjoys now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我是坏人。正因为是坏人，才能让这个岛繁荣起来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我是壞人。正因為是壞人，才能讓這個島繁榮起來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00114",
		linknext = "0119_00116",
		line = 1645,
	},
	["0119_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, you brought that prosperity to the island by forcing sex upon the islanders. Not the most accommodating environment for people in the minority like us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是通过强迫岛上的人卖淫而获得的繁荣吧。通过迫害像我们这样的少数群体——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是通過強迫島上的人賣淫而獲得的繁榮吧。通過迫害像我們這樣的少數群體——」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00115",
		linknext = "0119_00117",
		line = 1657,
	},
	["0119_00117"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00116", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0234", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hm. You talk of forcing sex upon them. But is that not the case on the mainland as well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯……如果你说的是性方面的强求，那么本岛不也是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯……如果你說的是性方面的強求，那麼本島不也是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00116",
		linknext = "0119_00118",
		line = 1671,
	},
	["0119_00118"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00117",
		linknext = "0119_00119",
		line = 1683,
	},
	["0119_00119"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0235", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You can't walk around nude in public. You can't have sex wherever you please. Even mosaics on pornography are in place as a token gesture of safety.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不允许脱衣服，不允许自由的性行为，以为用了马赛克等形式化的保护机制就保护了自己。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不允許脫衣服，不允許自由的性行為，以為用了馬賽克等形式化的保護機制就保護了自己。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00118",
		linknext = "0119_00120",
		line = 1697,
	},
	["0119_00120"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Those are well-established norms required to sustain a healthy society!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就是规定，为了社会的健全，遵守规定是理所当然的吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就是規定，為了社會的健全，遵守規定是理所當然的吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00119",
		linknext = "0119_00121",
		line = 1709,
	},
	["0119_00121"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0236", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“What sort of discipline is achieved by blurring genitalia? Does obscuring that specific area when the act of sex is exploited for entertainment lead to a wholesome society at large? Answer me that, young man.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“即使性器官变模糊了，又能有什么抑制作用？难道隐藏了已经娱乐化的性行为的其中一部分，就是所谓健全的社会吗？回答我，少年。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「即使性器官變模糊了，又能有什麼抑製作用？難道隱藏了已經娛樂化的性行為的其中一部分，就是所謂健全的社會嗎？回答我，少年。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00120",
		linknext = "0119_00122",
		line = 1723,
	},
	["0119_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's a compromise! A wholesome society has to save face somehow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是客套话和真心话的差别！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是客套話和真心話的差別！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00121",
		linknext = "0119_00123",
		line = 1735,
	},
	["0119_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you're gonna apply logic to an emotional argument, the only proper solution would be to show no penetration! It's an adult decision!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了终结扯上感情论的争辩，只能采取不承认插入的手段，这是大人的解决方法！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了終結扯上感情論的爭辯，只能採取不承認插入的手段，這是大人的解決方法！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00122",
		linknext = "0119_00124",
		line = 1747,
	},
	["0119_00124"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0237", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So these adults who call the shots are fools, then. In that case, what purpose does the system serve for them? All their restrictions have failed to protect anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“也就是说，这是愚蠢的大人们的手段。那么，监督这些的机构到底有什么意义呢？明明无法通过规定保护任何人啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「也就是說，這是愚蠢的大人們的手段。那麼，監督這些的機構到底有什麼意義呢？明明無法通過規定保護任何人啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00123",
		linknext = "0119_00125",
		line = 1761,
	},
	["0119_00125"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0238", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“True, this island has been revitalized through no shortage of generous spending. But is there not plenty of dirty money being circulated over there as well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“青蓝岛的确是靠撒钱所立起根基的。但那边的钱不是更加扭曲吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「青藍島的確是靠撒錢所立起根基的。但那邊的錢不是更加扭曲嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00124",
		linknext = "0119_00126",
		line = 1773,
	},
	["0119_00126"] = {
		{"se", id=0, loop=0, file="se_a204"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fair enough! But the world at large is still wholesome, at least compared to this island!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那当然也无法完全否定……！但是世界是健全的，至少比这个岛好！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那當然也無法完全否定……！但是世界是健全的，至少比這個島好！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00125",
		linknext = "0119_00127",
		line = 1786,
	},
	["0119_00127"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0239", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“However, the population here is currently increasing. And why? Emigrants from the mainland. People who have been sexually oppressed, seeking paradise to escape their suffering.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是实际上，青蓝岛的人口在不断增长，而且都是来自本岛的移居者。他们对性感到压抑、痛苦，所以才前来寻找乐园。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是實際上，青藍島的人口在不斷增長，而且都是來自本島的移居者。他們對性感到壓抑、痛苦，所以才前來尋找樂園。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00126",
		linknext = "0119_00128",
		line = 1798,
	},
	["0119_00128"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0240", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If you are fighting for the sake of the minority, then is it not proper that I fight in return, for the sake of Seiran Island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果你的战斗是为了保护少数群体，那么为了青蓝岛，在我的手下战斗不是更正确吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果你的戰鬥是為了保護少數群體，那麼為了青藍島，在我的手下戰鬥不是更正確嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00127",
		linknext = "0119_00129",
		line = 1810,
	},
	["0119_00129"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=3, size=2.5, time=100, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Make all the excuses you want! What you've created is an apartheid state! And I ain't gonna play your fuckin' Sun City!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你做的事情根本就是种族隔离！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你做的事情根本就是種族隔離！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00128",
		linknext = "0119_00130",
		line = 1824,
	},
	["0119_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you're segregating groups of people without trying to understand them, they're only gonna end up being more conscious of their differences!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有理解就进行分类，这样只会产生意识上的差异！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有理解就進行分類，這樣只會產生意識上的差異！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00129",
		linknext = "0119_00131",
		line = 1835,
	},
	["0119_00131"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0241", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Then we shall have to make the mainland think the same way we do here. Expansion by way of sex is inevitable. Would you not agree, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那就只要把本岛染成我们的思想。也就是说性的扩张是必然的，不是吗少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那就只要把本島染成我們的思想。也就是說性的擴張是必然的，不是嗎少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00130",
		linknext = "0119_00132",
		line = 1849,
	},
	["0119_00132"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, sure! And manifest destiny worked out so fuckin' well before!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“提倡天命什么的，完全就是过激者会说的话——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「提倡天命什麼的，完全就是過激者會說的話——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00131",
		linknext = "0119_00133",
		line = 1861,
	},
	["0119_00133"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0242", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I am a cosmopolitan at heart. I aim to unify all humanity. Through sex, of course.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我可是世界主义者。人类会成为一体，以性为手段。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我可是世界主義者。人類會成為一體，以性為手段。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00132",
		linknext = "0119_00134",
		line = 1876,
	},
	["0119_00134"] = {
		{"se", id=0, loop=0, file="se_a204"},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=600},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ah, I get it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——啊，是这样啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——啊，是這樣啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00133",
		linknext = "0119_00135",
		line = 1889,
	},
	["0119_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now I know what preoccupies his thinking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"会被县知事影响的理由，我现在终于明白了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"會被縣知事影響的理由，我現在終於明白了。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00134",
		linknext = "0119_00136",
		line = 1899,
	},
	["0119_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm a lot like him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我和这个男人很像。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我和這個男人很像。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00135",
		linknext = "0119_00137",
		line = 1909,
	},
	["0119_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why we're incompatible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也正因为如此——我们才不相容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也正因為如此——我們才不相容。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00136",
		linknext = "0119_00138",
		line = 1919,
	},
	["0119_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It matters not that we share views on certain things.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然处境相似，但我绝对——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然處境相似，但我絕對——",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00137",
		linknext = "0119_00139",
		line = 1929,
	},
	["0119_00139"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, that desire of yours killed someone very important to me. All thanks to those non-virgins you allowed to flourish.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——因为你的野心，我失去了最重要的人。是被你养育的非处女们所造成的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——因為你的野心，我失去了最重要的人。是被你養育的非處女們所造成的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00138",
		linknext = "0119_00140",
		line = 1941,
	},
	["0119_00140"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0243", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If you're talking about when you were young, that was probably during the period I was away from the island, owing to a donations scandal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果是你小时候的事，那正好是我因为捐款事件离开岛的时候。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果是你小時候的事，那正好是我因為捐款事件離開島的時候。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00139",
		linknext = "0119_00141",
		line = 1955,
	},
	["0119_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, so it's actually not your fault? Well, ain't that fuckin' convenient!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你就认为自己没有责任是吗，根本就是自说自话！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你就認為自己沒有責任是嗎，根本就是自說自話！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00140",
		linknext = "0119_00142",
		line = 1967,
	},
	["0119_00142"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0244", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That is not what I mean. If you are so set in your beliefs, you ought not to be aiming to destroy the island, but to get revenge. If you made use of your junk, it would be yours for the taking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“并非如此。那你就不应该想着要摧毁岛，而是应该考虑复仇。只要用你的鸡巴就能做到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「並非如此。那你就不應該想著要摧毀島，而是應該考慮復仇。只要用你的肉棒就能做到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00141",
		linknext = "0119_00143",
		line = 1981,
	},
	["0119_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Revenge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复仇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"復仇。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00142",
		linknext = "0119_00144",
		line = 1991,
	},
	["0119_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even he's feeding me that bullshit now...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙也说了同样的话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙也說了同樣的話——",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00143",
		linknext = "0119_00145",
		line = 2001,
	},
	["0119_00145"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you're demanding that I hand over Fumino and help build a sovereign nation with you, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你要我把文乃交给你，帮你建立国家是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你要我把文乃交給你，幫你建立國家是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00144",
		linknext = "0119_00146",
		line = 2014,
	},
	["0119_00146"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0245", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I acknowledge that Fumino is my one weakness. However, I am her parent. I won't harm her if you hand her over. If anything, wouldn't she be safest with me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我承认文乃是我唯一的痛处。但我也是她的父亲，如果把她交给我，我是不会亏待她的。应该说在我这里是最安全的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我承認文乃是我唯一的痛處。但我也是她的父親，如果把她交給我，我是不會虧待她的。應該說在我這裡是最安全的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00145",
		linknext = "0119_00147",
		line = 2028,
	},
	["0119_00147"] = {
		{"bgm", file="bgm12", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... She probably would be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……嗯，或许会是安全的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……嗯，或許會是安全的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00146",
		linknext = "0119_00148",
		line = 2041,
	},
	["0119_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But only because you'd just lock her up in a cage. Keep her where no one can ever see her or contact her, in order to hide away your own shame.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过另一方面，你会把她幽禁起来，不让任何人发现她对吧。像要隐藏自己的失态一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過另一方面，你會把她幽禁起來，不讓任何人發現她對吧。像要隱藏自己的失態一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00147",
		linknext = "0119_00149",
		line = 2053,
	},
	["0119_00149"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00109", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you were serious about it, you could've scoured every inch of this island trying to find her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你如果真的那么想，就应该能光明正大地寻找文乃才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你如果真的那麼想，就應該能光明正大地尋找文乃才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00148",
		linknext = "0119_00150",
		line = 2068,
	},
	["0119_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you didn't. Because you didn't want anyone to know she even existed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但你没这么做，因为你根本不想让别人知道这件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但你沒這麼做，因為你根本不想讓別人知道這件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00149",
		linknext = "0119_00151",
		line = 2079,
	},
	["0119_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She is the illegitimate daughter of this island's very founder. If the world at large were to learn of her existence, that would amplify tenfold every rumor that this place is a hotbed of illegal activity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“创造青蓝岛的县知事的私生女。她是会让你落入比被说成犯罪温床还要难堪的境地的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「創造青藍島的縣知事的私生女。她是會讓你落入比被說成犯罪溫床還要難堪的境地的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00150",
		linknext = "0119_00152",
		line = 2091,
	},
	["0119_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So what the hell else would you do, if not keep her locked away from the public eye for all eternity with no one the wiser? That's the most favorable state of affairs to you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你会把她藏起来，幽禁起来不让任何人发现，这样才符合你的期望——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你會把她藏起來，幽禁起來不讓任何人發現，這樣才符合你的期望——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00151",
		linknext = "0119_00153",
		line = 2102,
	},
	["0119_00153"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=3, size=2.5, time=100, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In the end, you only did what you did to save your own ass!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说到底，你都是为了明哲保身！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說到底，你都是為了明哲保身！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00152",
		linknext = "0119_00154",
		line = 2116,
	},
	["0119_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You never did a damn thing that wasn't in the name of your own lust for glory!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一切都是为了你自己的野心而进行的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一切都是為了你自己的野心而進行的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00153",
		linknext = "0119_00155",
		line = 2127,
	},
	["0119_00155"] = {
		{"bgm", stop=1},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0246", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
