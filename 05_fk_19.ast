					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What's wrong, Bro? Hurry up and get inside. The others will be here soon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……怎么了哥哥？快进家里吧。奈奈濑同学他们要来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……怎麼了哥哥？快進家裡吧。奈奈瀨同學他們要來了……」",
					{"rt2"},
				},
			},
