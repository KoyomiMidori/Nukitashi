		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0217", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I'd like to express my belated gratitude to you for taking care of Fumino's school life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那么少年，作为父母，我还是先给你个迟来的道谢，感谢你照看文乃的学园生活。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那麼少年，作為父母，我還是先給你個遲來的道謝，感謝你照顧文乃的學園生活。」",
					{"rt2"},
				},
			},
		},
