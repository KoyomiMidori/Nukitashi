	},
	["0119_00185"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=300, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1729", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well I, for one, am overjoyed! Thank God for that, I say! Finally I can go back to being a lazy bum all the time, like I prefer!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我倒是很高兴哦～！啊——真的好高兴啊！这样终于可以变回麻沙酱喜欢的气氛了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我倒是很高興哦～！啊——真的好高興啊！這樣終於可以變回麻沙醬喜歡的氣氛了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00184",
		linknext = "0119_00186",
		line = 2607,
	},
	["0119_00186"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
