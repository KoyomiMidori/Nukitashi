		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1033", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This may be a selfish request, but... may I leave everything else here in your care?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“虽然很尚做主张……但剩下的可以先放在这里吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「雖然很尚做主張……但剩下的可以先放在這裡嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00206",
		linknext = "0119_00208",
		line = 2962,
	},
	["0119_00208"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
