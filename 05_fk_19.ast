		linknext = "0119_00288",
		line = 3956,
	},
	["0119_00288"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1056", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'll give you everything you desire...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“给予了我一切的您的期望……文乃会为您实现的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「給予了我一切的您的期望……文乃會為您實現的。」",
					{"rt2"},
				},
			},
		},
