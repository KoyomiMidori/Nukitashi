					name = {"淳之介", "Junnosuke"},
					"“Christ, you're being an asshole to the end... At least try to be nice to her for one second.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到最后的最后你都……这种时候就温柔一点吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到最後的最後你都……這種時候就溫柔一點吧。」",
					{"rt2"},
				},
