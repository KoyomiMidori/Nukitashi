			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's only natural, considering his very own granddaughter is the one at stake.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为关系到孙子的去留问题，所以应该说是理所当然的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為關係到孫子的去留問題，所以應該說是理所當然的吧。」",
					{"rt2"},
				},
			},
		},
