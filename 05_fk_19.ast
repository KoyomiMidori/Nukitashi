		},
		linkback = "0119_00154",
		linknext = "0119_00156",
		line = 2143,
	},
	["0119_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He says nothing, instead staring at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生什么都没说，和我面对面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生什麼都沒說，和我面對面。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00155",
		linknext = "0119_00157",
		line = 2153,
	},
	["0119_00157"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0247", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I'll ask one more time. Will you not join me, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我再问一次。你有没有想助我一臂之力的打算，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我再問一次。你有沒有想助我一臂之力的打算，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00156",
		linknext = "0119_00158",
		line = 2167,
	},
	["0119_00158"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Up yours. I'm gonna protect that girl, no matter what. And your little perverted sex law? Its days are numbered, asshole.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我拒绝。我要保护那个孩子——毁掉变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我拒絕。我要保護那個孩子——毀掉變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00157",
		linknext = "0119_00159",
		line = 2179,
	},
	["0119_00159"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0248", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hm. Then I shall have to meet you head-on. You may head home safely today, but tomorrow we fight. If you try to take Fumino and run before then, I will know right away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯，那就只有战斗了。今天就让你安全回家吧，战斗从明天开始。如果在那之前把文乃带出去的话，你会马上明白的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯，那就只有戰鬥了。今天就讓你安全回家吧，戰鬥從明天開始。如果在那之前把文乃帶出去的話，你會馬上明白的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00158",
		linknext = "0119_00160",
		line = 2193,
	},
	["0119_00160"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll take that under advisement, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我知道了——那就这样吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我知道了——那就這樣吧。」",
					{"rt2"},
				},
			},
		},
