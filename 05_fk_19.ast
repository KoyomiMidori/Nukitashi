			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm in your debt... so I wanted to do a last cleaning...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“承蒙您照顾……所以最后，我想把家弄干净……”",
					{"rt2"},
				},
