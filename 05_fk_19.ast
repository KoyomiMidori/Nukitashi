				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Too much modesty is an unpleasant quality.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这么谦虚我可要不开心了哦？”",
