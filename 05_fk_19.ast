	["0119_00281"] = {
		{"se", id=0, loop=0, file="se_a200"},
		{"bg", id=2, file="whiteback_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=1, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=2, act="アルファフェード点滅", loop=1, alpha="0,256", time=100, alphadel=1, lv=5},
		{"ex", time=1000, func="wait"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haha... You still suck at it, I see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……哈哈，文乃果然还是不擅长摆出笑脸。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
