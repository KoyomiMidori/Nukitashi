			cn = {
				{
					name = {"淳之介"},
					"“我是觉得麻沙酱并没有对你很好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我是覺得麻沙醬並沒有對你很好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00214",
		linknext = "0119_00216",
		line = 3061,
	},
	["0119_00216"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1036", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have never encountered anyone who spoke quite so harshly to me as her before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我从来……没有听到过……那么严厉的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我從來……沒有聽到過……那麼嚴厲的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00215",
		linknext = "0119_00217",
		line = 3075,
	},
	["0119_00217"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", file2="fumino_01m_00201", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1037", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“So I am just a little bit happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以、有些高兴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以、有些高興……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00216",
		linknext = "0119_00218",
		line = 3090,
	},
	["0119_00218"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I'm glad to hear that, I guess.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……既然文乃这么说，那我就放心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……既然文乃這麼說，那我就放心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00217",
		linknext = "0119_00219",
		line = 3102,
	},
	["0119_00219"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you enjoyed your time here, that makes me happy too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你觉得在我家生活很开心的话，那我也会很开心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你覺得在我家生活很開心的話，那我也會很開心的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00218",
		linknext = "0119_00220",
		line = 3114,
	},
	["0119_00220"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1038", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“They really are... just fond memories... I'm sure I'll... remember them my whole life...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“真的……都是快乐的回忆……一定……会成为我一生的回忆……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「真的……都是快樂的回憶……一定……會成為我一生的回憶……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00219",
		linknext = "0119_00221",
		line = 3129,
	},
	["0119_00221"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Remember them her whole life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一生的回忆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一生的回憶。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00220",
		linknext = "0119_00222",
		line = 3141,
	},
	["0119_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tomorrow I'll hand Fumino over to the old man, and the perverted sex law will be crushed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……明天，只要把文乃移交给老人，那么变态条例就完了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……明天，只要把文乃移交給老人，那麼變態條例就完了。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00221",
		linknext = "0119_00223",
		line = 3151,
	},
	["0119_00223"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But it's still sad to know she's leaving us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是即便如此，她从这里消失，还是让我很悲伤……",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是即便如此，她從這裡消失，還是讓我很悲傷……",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00222",
		linknext = "0119_00224",
		line = 3161,
	},
	["0119_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I were to continue harboring her here, I could have my chance to take revenge on the islanders.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……如果继续把她藏在这里，我就有机会报复岛上的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……如果繼續把她藏在這裡，我就有機會報復島上的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00223",
		linknext = "0119_00225",
		line = 3171,
	},
	["0119_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Could it be...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是否——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是否——",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00224",
		linknext = "0119_00226",
		line = 3181,
	},
	["0119_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm still considering that possibility?",
					{"rt2"},
				},
			},
			cn = {
				{
					"还将这件事作为一种可能性，存放在脑中？",
					{"rt2"},
				},
			},
			tw = {
				{
					"還將這件事作為一種可能性，存放在腦中？",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00225",
		linknext = "0119_00227",
		line = 3191,
	},
	["0119_00227"] = {
		{"bgm", stop=1},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1039", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Must the perverted sex law... be abolished?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“变态条例……必须要摧毁吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「變態條例……必須要摧毀嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00226",
		linknext = "0119_00228",
		line = 3205,
	},
	["0119_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I couldn't respond immediately to her faltering question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对于她的这句话，我没能立刻做出反应。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對於她的這句話，我沒能立刻做出反應。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00227",
		linknext = "0119_00229",
		line = 3215,
	},
	["0119_00229"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00228",
		linknext = "0119_00230",
		line = 3228,
	},
	["0119_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her unusual eyes stare off into the distance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃那不可思议的瞳孔，望着虚空。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃那不可思議的瞳孔，望著虛空。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00229",
		linknext = "0119_00231",
		line = 3238,
	},
	["0119_00231"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00112", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1040", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I grew up watching the people of the island... so I was wondering if there wasn't a way for you to coexist with them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我是看着岛上的人长大的……所以我在想，难道没有与他们、与她们……共存的道路吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我是看著島上的人長大的……所以我在想，難道沒有與他們、與她們……共存的道路嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00230",
		linknext = "0119_00232",
		line = 3252,
	},
	["0119_00232"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sadly, that's never going to work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……很遗憾，这是不可能的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……很遺憾，這是不可能的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00231",
		linknext = "0119_00233",
		line = 3264,
	},
	["0119_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The Seiran Islanders and I could never coexist. We wouldn't be able to understand each other.",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛人和我们这样的人，是绝对不可能互相理解的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島人和我們這樣的人，是絕對不可能互相理解的。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00232",
		linknext = "0119_00234",
		line = 3274,
	},
	["0119_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our way of thinking, our values, the environments we grew up in— They are all dramatically different.",
					{"rt2"},
				},
			},
			cn = {
				{
					"核心观念的差异，思考基准的不同，成长环境的差异——",
					{"rt2"},
				},
			},
			tw = {
				{
					"核心觀念的差異，思考基準的不同，成長環境的差異——",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00233",
		linknext = "0119_00235",
		line = 3284,
	},
	["0119_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With such a deep ravine separating me from them, there is no way to fill it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这道深深的鸿沟，是怎么也无法填补的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這道深深的鴻溝，是怎麼也無法填補的。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00234",
		linknext = "0119_00236",
		line = 3294,
	},
	["0119_00236"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There's only one way for us to survive here. And that's destroying the law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……如果我们想生存下去，就必须要毁掉变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……如果我們想生存下去，就必須要毀掉變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00235",
		linknext = "0119_00237",
		line = 3306,
	},
	["0119_00237"] = {
		{"bgm", stop=1},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00112", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1041", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes... I think you're right. Nothing else could bring your happiness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……我觉得没错。淳之介同学们的幸福，是什么都无法改变的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……我覺得沒錯。淳之介同學們的幸福，是什麼都無法改變的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00236",
		linknext = "0119_00238",
		line = 3322,
	},
	["0119_00238"] = {
		{"bgm", file="bgm26", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But that's not why I'm handing you over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是文乃，我并不是因为这样才把你交出去的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是文乃，我並不是因為這樣才把你交出去的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00237",
		linknext = "0119_00239",
		line = 3335,
	},
	["0119_00239"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00114", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1042", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Huh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“呃……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「呃……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00238",
		linknext = "0119_00240",
		line = 3350,
	},
	["0119_00240"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Everyone on this island is after you. Every minute you stay here is a minute you're in danger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所有的组织都看上了文乃。所以如果你就这样待在这里的话，会很危险。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所有的組織都看上了文乃。所以如果你就這樣待在這裡的話，會很危險。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00239",
		linknext = "0119_00241",
		line = 3362,
	},
	["0119_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The only problem I had was that I couldn't very well send you off to live with someone you didn't even know. That held me up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，我又不能把你交给身份不明的人……这就是我烦恼的根源。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，我又不能把你交給身份不明的人……這就是我煩惱的根源。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00240",
		linknext = "0119_00242",
		line = 3373,
	},
	["0119_00242"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But then an alternative came into view. That old man is undoubtedly your grandfather.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是我确认了。那个老人是文乃的爷爷错不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是我確認了。那個老人是文乃的爺爺錯不了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00241",
		linknext = "0119_00243",
		line = 3385,
	},
	["0119_00243"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So I decided I could take him to you. It was the deciding factor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我才会带你过去。我是因为这样才下了最后的判断。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我才會帶你過去。我是因為這樣才下了最後的判斷。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00242",
		linknext = "0119_00244",
		line = 3397,
	},
	["0119_00244"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It is most important to me that you are able to live somewhere where you can be happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为文乃能够幸福地生活，对我来说是比任何事都更重要的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為文乃能夠幸福地生活，對我來說是比任何事都更重要的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00243",
		linknext = "0119_00245",
		line = 3409,
	},
	["0119_00245"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00109", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1043", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Junnosuke...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……淳之介……同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……淳之介……同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00244",
		linknext = "0119_00246",
		line = 3424,
	},
	["0119_00246"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00245",
		linknext = "0119_00247",
		line = 3436,
	},
	["0119_00247"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00121", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1044", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I am beyond fortunate... Though I may be leaving your side, my devotion to you shall never fade.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文乃是个知恩图报的人……虽然我就要离开您的身边了，但我的忠诚绝不会消失……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「文乃是個知恩圖報的人……雖然我就要離開您的身邊了，但我的忠誠絕不會消失……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00246",
		linknext = "0119_00248",
		line = 3450,
	},
	["0119_00248"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1045", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You have given me so very much... With all the memories I take with me, I shall not be lonely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“您给予了文乃所有的东西……和那些回忆一起，文乃就不寂寞……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「您給予了文乃所有的東西……和那些回憶一起，文乃就不寂寞……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00247",
		linknext = "0119_00249",
		line = 3466,
	},
	["0119_00249"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00248",
		linknext = "0119_00250",
		line = 3478,
	},
	["0119_00250"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She puts her hand to her chest and bows deeply.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃把手放在自己胸前，点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃把手放在自己胸前，點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00249",
		linknext = "0119_00251",
		line = 3488,
	},
	["0119_00251"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As though making a vow to never lose her loyalty to something precious to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那里似乎有什么重要的东西在——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡似乎有什麼重要的東西在——",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00250",
		linknext = "0119_00252",
		line = 3498,
	},
	["0119_00252"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those words pop into my mind again...",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃就像在收好她的忠诚心，绝对不让它掉下去一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃就像在收好她的忠誠心，絕對不讓它掉下去一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00251",
		linknext = "0119_00253",
		line = 3508,
	},
	["0119_00253"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Humble and faithful Sakimori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“犬马防人”……这句话在我脑子里闪过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「犬馬防人」……這句話在我腦子裡閃過。",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00252",
		linknext = "0119_00254",
		line = 3518,
	},
	["0119_00254"] = {
		{"bgm", stop=1},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00111", file2="fumino_02m_00201", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1046", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But... If I could please ask you to indulge me on one more request...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是……如果……如果，淳之介同学……愿意听……一个文乃的任性的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是……如果……如果，淳之介同學……願意聽……一個文乃的任性的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00253",
		linknext = "0119_00255",
		line = 3534,
	},
	["0119_00255"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00112", file2="fumino_02m_00201", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1047", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I want you to give me one more... just one more memory...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……还有一个……还有一个，我想要的……最后的回忆……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……還有一個……還有一個，我想要的……最後的回憶……」",
					{"rt2"},
				},
			},
		},
		linkback = "0119_00254",
		linknext = "0119_00256",
		line = 3549,
	},
	["0119_00256"] = {
		{"se", id=1, loop=1, file="se_a105"},
		{"text"},
		text = {
