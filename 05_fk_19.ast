		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1032", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes... I don't have that many belongings. Just this treasured kimono I got from Mother...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……因为不能带太多……所以我就穿这件母亲非常珍爱的和服去……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……因為不能帶太多……所以我就穿這件母親非常珍愛的和服去……」",
					{"rt2"},
				},
			},
		},
