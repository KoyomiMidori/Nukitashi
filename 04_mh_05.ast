				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well in that case... ehehe, I'll take you up on your offer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“如果是这样的话……嘿嘿，就恭敬不如从命了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「如果是這樣的話……嘿嘿，就恭敬不如從命了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00293",
