	["0082_00119"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm the same. 'No Love, No Sex' - it's wrong to have sex without love!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也是同样的想法。‘No Love， No Sex’——没有爱的性爱不该存在！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也是同樣的想法。『No Love， No Sex』——沒有愛的性愛不該存在！」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00118",
		linknext = "0082_00120",
		line = 1516,
	},
	["0082_00120"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00102", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0058", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Oh... ooh! You too! I fuckin' knew it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啊啊……啊啊！淳之介君果然也是这样啊！我昨天的判断并没有错……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啊啊……啊啊！淳之介君果然也是這樣啊！我昨天的判斷並沒有錯……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00119",
		linknext = "0082_00121",
		line = 1530,
	},
	["0082_00121"] = {
		{"text"},
		text = {
			ja = {
