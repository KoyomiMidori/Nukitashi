	["0082_00003"] = {
		{"bgm", file="bgm06", vol=100},
		{"fg", file="asane_02ll_00007", file1="asane_02ll_00108", path=":fg/asane_02ll/", id=3, lv=5, head="asane_02ll", ch="麻沙音", mw="mw", sync=0, time=100, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1262", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“B... Bro? Bro!? You're awake? You okay? Aware of your surroundings? Able to see? What's 9 times 7?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……哥哥……哥哥！？醒来了吗？没事吧？有意识吗？眼睛看得见吗？九乘七是？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……哥哥……哥哥！？醒來了嗎？沒事吧？有意識嗎？眼睛看得見嗎？九乘七是？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00002",
		linknext = "0082_00004",
		line = 50,
	},
	["0082_00004"] = {
