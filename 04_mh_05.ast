		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00120", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0244", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ahaha, sorry. I was hoping that'd flush them out... but I guess not. Oopsie ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊哈哈……抱歉哦。我还在想都做到那种程度了，应该会让他们露出马脚来……但是好像还是失败了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊哈哈……抱歉哦。我還在想都做到那種程度了，應該會讓他們露出馬腳來……但是好像還是失敗了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00297",
		linknext = "0082_00299",
		line = 4026,
	},
	["0082_00299"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1005", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What the hell is wrong with you!? The school devolved into total chaos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真是的……你这家伙真是让人傻眼……！把学校的治安搞得那么乱七八糟结果还——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真是的……你這傢伙真是讓人傻眼……！把學校的治安搞得亂七八糟，結果還——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00298",
		linknext = "0082_00300",
		line = 4039,
	},
	["0082_00300"] = {
		{"fgact", ch="郁子", id=10, act="移動", x=-200, y=0, time=500},
		{"fgact", ch="礼", id=9, act="移動", x=200, y=0, time=500},
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"fgact", ch="桐香", id=8, act="移動", x=0, y=-100, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0651", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now, now, Rei, what's done is done, so why not drop it? It's not just her fault, anyway. We haven't exactly made progress, have we?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“算了算了，礼，先这样就好。我们可不能一味责怪郁子……毕竟我们这边一样没有进展，对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「算了算了，禮，先這樣就好。我們可不能一味責怪郁子……畢竟我們這邊一樣沒有進展，對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00299",
		linknext = "0082_00301",
		line = 4055,
	},
	["0082_00301"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[1800] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1800, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1006", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Understood, Miss Touka. But what are we supposed to do? We don't have the personnel to deal with the Anti-Copulation Front.”",
					{"rt2"},
				},
			},
