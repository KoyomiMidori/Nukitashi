			},
			en = {
				{
					name = {"非表示", "???"},
					"“Ah, no worries. Makes sense when some stranger's just showin' up at yer home. Still, lemme give ya me name, at least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
