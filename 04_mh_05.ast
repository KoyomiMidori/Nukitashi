					"“What's she like when Nanase's here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“如果是奈奈濑同学会有什么反应呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「如果是奈奈瀨同學會有什麼反應呢？」",
