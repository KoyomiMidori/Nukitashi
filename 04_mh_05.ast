	["0082_00089"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00106", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0048", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Fuckin' boss's orders. He needed a guy to sell sex toys here, and so here I am. I'm sure ya can see business is boomin'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“是上面的命令……上头说如果是这样的色情岛，成人玩具应该会卖得很好，所以就派我来了……结果就像你看到的一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「是上面的命令……上頭說如果是這樣的色情島，成人玩具應該會賣得很好，所以就派我來了……結果就像你看到的一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00088",
		linknext = "0082_00090",
		line = 1141,
	},
	["0082_00090"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00110", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0049", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Our company's got a lot a' shit to sell here, but no one here wants it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“虽然如果由我来负责销售我们的商品，那规模也算相当大……但这也挺困难的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「雖然如果由我來負責銷售我們的商品，那規模也算相當大……但這也挺困難的。」",
					{"rt2"},
				},
			},
