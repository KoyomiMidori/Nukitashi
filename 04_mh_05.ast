	["0082_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What happened? That's right, I was assaulted by Onabuta after leaving Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我——对了，在送畔回家的回程中被女部田袭击了……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我——對了，在送畔回家的回程中被女部田襲擊了……",
					{"rt2"},
