	["0082_00222"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't worry about her and just come on in. Asa, Hotori brought food.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要在意，快进来。麻沙酱，畔给我们带来了食物哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要在意，快進來。麻沙醬，畔給我們帶來了食物哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00221",
		linknext = "0082_00223",
		line = 2949,
	},
	["0082_00223"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00116", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1275", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hey, Bro, I don't know what freaky shit you've been getting into, but vore ain't my thing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我可对同类相食没什么兴趣……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我可對同類相食沒什麼興趣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00222",
		linknext = "0082_00224",
		line = 2963,
	},
	["0082_00224"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
