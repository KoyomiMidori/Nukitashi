		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0729", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Here it is. I don't know if you'll like it, but please feel free to eat, Asane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“在这里。虽然不知道合不合你们的口味……但请麻沙音酱也一定要吃吃看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「在這裡。雖然不知道合不合你們的口味……但請麻沙音醬也一定要吃吃看。」",
