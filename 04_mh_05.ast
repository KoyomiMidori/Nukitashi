					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? I come here a lot, but I had no idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是吗？我还挺常来的……却不知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是嗎？我還挺常來的……卻不知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00079",
		linknext = "0082_00081",
		line = 1021,
	},
	["0082_00081"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0044", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“That's what the curtain's for, see? Still, I thought there was some kid comin' by lately. It was you, uh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“因为为了让彼此看不到对方，我用窗帘遮住了……这样啊，我还在想说最近有个年轻客人，原来就是你啊……呃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「因為為了讓彼此看不到對方，我用窗簾遮住了……這樣啊，我還在想說最近有個年輕客人，原來就是你啊……呃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00080",
		linknext = "0082_00082",
		line = 1033,
	},
