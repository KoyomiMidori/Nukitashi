		linknext = "0082_00018",
		line = 227,
	},
	["0082_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that she mentions it, I do vaguely remember something like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然记忆模糊想不起来，但或许确实发生了那样的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然記憶模糊想不起來，但或許確實發生了那樣的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00017",
