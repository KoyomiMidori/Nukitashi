				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori beams broadly and we start up the hill.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔开心地笑了出来。我开始边散步边送她回家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔開心地笑了出來。我開始邊散步邊送她回家。",
