	["0082_00136"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Still, hearing you say that makes me feel a bit better.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……不过，你能那样对我说……让我稍微放松了一点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……不過，你能那樣對我說……讓我稍微放鬆了一點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00135",
		linknext = "0082_00137",
		line = 1726,
	},
	["0082_00137"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haha, sorry for making things awkward. I just came here to buy stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈……把气氛搞得这么奇怪真是抱歉。我明明只是来购物的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈……把氣氛搞得這麼奇怪真是抱歉。我明明只是來購物的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00136",
		linknext = "0082_00138",
		line = 1738,
	},
	["0082_00138"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0064", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ah, no worries. So, what're ya buyin'?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“没关系啦。那你今天是来买什么东西的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「沒關係啦。那你今天是來買什麼東西的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00137",
		linknext = "0082_00139",
		line = 1752,
	},
	["0082_00139"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, a few dutch wives...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“买几个充气娃娃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「買幾個充氣娃娃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00138",
		linknext = "0082_00140",
		line = 1764,
	},
	["0082_00140"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0065", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, a fine choice. When I'm feelin' down, they can bring me back up again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“原来如此。受伤的时候……只有她们会温柔地治愈我们……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「原來如此。受傷的時候……只有她們會溫柔地治愈我們……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00139",
		linknext = "0082_00141",
		line = 1776,
	},
	["0082_00141"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00108", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're so right! Ah, who would have thought there'd be someone who understands on this island!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——！是啊！哎呀——这个岛上居然有能够这么互相理解的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——！是啊！哎呀——這個島上居然有能夠這麼互相理解的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00140",
		linknext = "0082_00142",
		line = 1788,
	},
	["0082_00142"] = {
