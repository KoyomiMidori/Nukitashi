			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“H-Hello, Asane. Pardon my intrusion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你、你好，麻沙音酱……打扰了哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你、你好，麻沙音醬……打擾了哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00219",
		linknext = "0082_00221",
		line = 2920,
	},
	["0082_00221"] = {
