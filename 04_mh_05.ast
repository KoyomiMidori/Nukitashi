		line = 237,
	},
	["0082_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But more to the point...",
					{"rt2"},
				},
			},
			cn = {
				{
