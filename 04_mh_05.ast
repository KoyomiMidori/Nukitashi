	["0082_00109"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00110", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0055", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Me colleagues were so fuckin' jealous when I was sent here, but I just can't get over how these weirdos live, ya know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“虽然我决定前往青蓝岛时同事都羡慕死了……但是我总觉得无法融入这个岛上……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「雖然我決定前往青藍島時同事都羨慕死了……但是我總覺得無法融入這個島上……」",
					{"rt2"},
				},
			},
		},
