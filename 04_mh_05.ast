		line = 163,
	},
	["0082_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're normally quarreling but we're the only family we've got.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然平时总是互相斗嘴，但我们是彼此唯一的家人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然平時總是互相鬥嘴，但我們是彼此唯一的家人。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00012",
		linknext = "0082_00014",
		line = 173,
	},
	["0082_00014"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shit, Nanase told me to contact her as soon as I got home. I need to call her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“糟了。奈奈濑说回来要我和她联络……我得立刻联络才行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「糟了。奈奈瀨說回來要我和她聯絡……我得立刻聯絡才行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00013",
		linknext = "0082_00015",
		line = 185,
	},
	["0082_00015"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00106", file2="asane_02l_00202", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1265", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wait, what? Don't you remember?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“咦？为什么……难道哥哥不记得了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「咦？為什麼……難道哥哥不記得了？」",
