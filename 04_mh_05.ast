				{
					name = {"美岬", "Misaki"},
					"“On top you've got rice balls, sushi rolls, and tofu sushi, then under that are assorted sandwiches, various deep fried meat, rolled omelettes, and a few other things. Please, help yourselves!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“饭类的手卷寿司跟稻荷寿司，下方是三明治，还有各种肉类油炸类跟煎蛋卷以及其他东西……请尽情享用吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「飯類的手捲壽司跟稻荷壽司，下方是三明治，還有各種肉類油炸類跟煎蛋捲以及其他東西……請盡情享用吧！」",
					{"rt2"},
				},
			},
