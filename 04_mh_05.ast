		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=700},
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		delay = {
			[15000] = {
				{"fg", file="asane_02m_00007", file1="asane_02m_00103", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=15000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1274", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yawn... Bro, why'd you head off while I was sleeping? I'm starving, and the food Nanase made is all gone, so I need some... huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呼哇……哥哥……我睡觉的时候去了哪里啊……肚子饿了啊……奈奈濑做的饭菜全没了，肚子好饿啊……有什么……啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「呼哇……哥哥……我睡覺的時候去了哪裡啊……肚子餓了啊……奈奈瀨做的飯菜全沒了，肚子好餓啊……有什麼……啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00218",
		linknext = "0082_00220",
		line = 2907,
	},
	["0082_00220"] = {
		{"fg", file="misaki_01f_00002", file1="misaki_01f_00101", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
