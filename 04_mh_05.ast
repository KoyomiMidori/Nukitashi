		{"fg", file="teshima_01l_00001", file1="teshima_01l_00107", path=":fg/teshima_01l/", id=8, lv=5, head="teshima_01l", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0054", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You fuckin' know it! Ya bought a shit ton! The fuckers here don' know about 'em, but I think they're fuckin' great.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“是的。你也经常买对吧？虽然这个岛的人看都不看一眼……但我果然还是最喜欢这个了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「是的。你也經常買對吧？雖然這個島的人看都不看一眼……但我果然還是最喜歡這個了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00105",
		linknext = "0082_00107",
		line = 1367,
	},
