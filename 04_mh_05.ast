	["0082_00168"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00110", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0706", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, it's fine. I know how forgettable I am, so it's an honor that you remembered at all... haha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不不不……光是我的存在本身就很容易被忘记，所以能想起来就很厉害了……哈哈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不不不……光是我的存在本身就很容易被忘記，所以能想起來就很厲害了……哈哈。」",
					{"rt2"},
				},
			},
