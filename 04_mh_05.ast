			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, uh, y-yeah, I guess I told her we're friends. Sorry if I jumped the gun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……我擅自在家里吹嘘我有朋友这件事被发现了……对不起，我只是一时冲动……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……我擅自在家裡吹噓我有朋友這件事被發現了……對不起，我只是一時衝動……」",
					{"rt2"},
				},
			},
