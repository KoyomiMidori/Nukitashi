			en = {
				{
					name = {"美岬", "Misaki"},
					"“She's honest with me! If I'm honest back to her, then with time I'm sure we'll come to understand each other, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为麻沙音酱都会毫不客气地对我说话！所以只要我也毫不客气地说回去，总有一天会互相理解的……你不认为这样很有道理吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為麻沙音醬都會毫不客氣地對我說話！所以只要我也毫不客氣地說回去，總有一天會互相理解的……你不認為這樣很有道理嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00284",
		linknext = "0082_00286",
		line = 3829,
	},
	["0082_00286"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
