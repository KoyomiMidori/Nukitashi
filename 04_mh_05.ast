			},
			[8300] = {
				{"fg", file="misaki_01m_00002", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=8300, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0747", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“There, that's all six tiers. I guess I'll be going, then. Thanks for spending time with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嘿咻……这样六层都收好了吧……嗯。那么，我也差不多该回去了。今天谢谢你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嘿咻……這樣六層都收好了吧……嗯。那麼，我也差不多該回去了。今天謝謝你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00288",
		linknext = "0082_00290",
		line = 3881,
	},
	["0082_00290"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don't have your bike, right? Who knows what's lurking out there, so I'll walk you home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是走路回去对吧？不知道会不会发生意外，我送你回家吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是走路回去對吧？不知道會不會發生意外，我送你回家吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00289",
		linknext = "0082_00291",
		line = 3893,
	},
	["0082_00291"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0748", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Are you sure?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……但是……可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸……但是……可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00290",
		linknext = "0082_00292",
		line = 3907,
	},
	["0082_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's giving me an inquisitive look. Maybe this is just me seeing what I want to see, but she looks a little pleased.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她像在估量般抬眼看我——看起来好像有点高兴，是我的误会吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"她像在估量般抬眼看我——看起來好像有點高興，是我的誤會嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00291",
		linknext = "0082_00293",
		line = 3917,
	},
	["0082_00293"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't worry about it. I could use a little post-meal walk, anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别放在心上，只是饭后顺便去散个步。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別放在心上，只是飯後順便去散個步。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00292",
		linknext = "0082_00294",
		line = 3929,
	},
	["0082_00294"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
