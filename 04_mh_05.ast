	["0082_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we have the energy to squabble among ourselves, we should direct that toward the real enemy: the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的敌人始终是控制岛屿的条例。没有时间闹内讧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的敵人始終是控制島嶼的條例。沒有時間鬧內訌。",
					{"rt2"},
				},
			},
		},
