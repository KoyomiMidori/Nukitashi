		linkback = "0082_00174",
		linknext = "0082_00176",
		line = 2280,
	},
	["0082_00176"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's fine. We're like-minded comrades, right? I'd say that makes us friends.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没关系。我们是志同道合的同伴——也就是‘朋友’吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒關係。我們是志同道合的同伴——也就是『朋友』吧？」",
