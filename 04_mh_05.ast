	["0082_00122"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, it's amazing you were able to figure me out. Everyone else here just mindlessly has sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过……真亏你能察觉我是同类呢……明明四处都有人在做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過……真虧你能察覺我是同類呢……明明四處都有人在做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00121",
		linknext = "0082_00123",
		line = 1553,
	},
	["0082_00123"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0059", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hmm, I wonder? Ya just got that vibe, I guess. I never woulda done somethin' that fuckin' crazy, but I couldn't help meself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嗯……是为什么呢？大概是闻到了同样的味道吧。平常我明明绝对不会做那种事，可是身体却不由自主地动了起来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嗯……是為什麼呢？大概是聞到了同樣的味道吧。平常我明明絕對不會做那種事，可是身體卻不由自主地動了起來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00122",
		linknext = "0082_00124",
		line = 1567,
	},
	["0082_00124"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00110", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0060", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, really it was super fuckin' dangerous. Normally me motto is 'Live peacefully', ya know? What woulda happened if I was wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈哈……现在想起来还真是危险呢。明明我的座右铭是和平安稳……如果那时误会了会怎么样呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈哈……現在想起來還真是危險呢。明明我的座右銘是和平安穩……如果那時誤會了會怎麼樣呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00123",
		linknext = "0082_00125",
		line = 1581,
	},
	["0082_00125"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
