				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She fawns over her, begging her to not go home and stay the night. That kind of thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是要她不要回去，就是要她干脆住下来……差不多这种感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是要她不要回去，就是要她乾脆住下來……差不多這種感覺。」",
					{"rt2"},
				},
			},
		},
