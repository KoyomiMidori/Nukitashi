	},
	["0082_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Maintaining a diet through exercise, not through monitoring food intake, is Hotori's way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“体重不是通过饮食而是通过运动来调整——这好像是畔的减肥哲理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「體重不是通過飲食而是通過運動來調整——這好像是畔的減肥哲理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00269",
		linknext = "0082_00271",
		line = 3610,
	},
	["0082_00271"] = {
