			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, it's prolly weird comin' from an old fart like me, but I think ya shouldn't be doin' that shit wit' someone ya don't love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“虽然这个岁数还说这样的话有点害羞……但——我觉得那种行为果然还是应该和有爱之人做才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「雖然這個歲數還說這樣的話有點害羞……但——我覺得那種行為果然還是應該和有愛之人做才對。」",
					{"rt2"},
				},
			},
		},
