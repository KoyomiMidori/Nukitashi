				{"vo", file="teshima0061", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Huh? Oh, the chick? She was pretty unsteady on her feet, kinda like you. She probably passed out pretty quick. I just got away and called the OSS to pick her up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“咦？……啊，她吗？因为她像淳之介君那样摇摇晃晃的……大概那之后就失去知觉了吧。所以离开之后我有呼叫SHO……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「咦？……啊，她嗎？因為她像淳之介君那樣搖搖晃晃的……大概那之後就失去知覺了吧。所以離開之後我有呼叫SHO……」",
					{"rt2"},
				},
			},
		},
