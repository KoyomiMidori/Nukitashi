					name = {"麻沙音", "Asane"},
					"“Hotori ate 95% of it though. It was like eating at a pig's trough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“9点5成是畔吃的……真的是和猪一样的吃法啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「9點5成是畔吃的……真的是和豬一樣的吃法啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00268",
		linknext = "0082_00270",
