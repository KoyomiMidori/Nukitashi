					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, I'm sure this rampant gluttony is a result of excessive obsession with sex, why wouldn't it be? Definitely not a personality issue with this girl, of course not.”",
					{"rt2"},
				},
			},
			cn = {
