	["0082_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never imagined there'd be someone like him on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真没想到青蓝岛居然会有手嶋先生那样的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真沒想到青藍島居然會有手嶋先生那樣的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00152",
		linknext = "0082_00154",
		line = 1981,
	},
	["0082_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never been able to discuss that stuff with someone in person before, aside from Asa. He's truly a like-minded soul.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到现在为止，能在现实中进行“自慰谈话”也就只有麻沙酱——但今后可以和手嶋先生聊聊了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到現在為止，能在現實中進行「自慰談話」也就只有麻沙醬——但今後可以和手嶋先生聊聊了。",
					{"rt2"},
				},
			},
		},
