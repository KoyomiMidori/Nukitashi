				{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4400, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0722", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hmm... first of all, what do you consider 'regular'? Would JoJo count?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃……应该说哪些叫做普通……啊，jojo是普通漫画吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃……應該說哪些叫做普通……啊，jojo是普通漫畫嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00204",
		linknext = "0082_00206",
		line = 2675,
	},
	["0082_00206"] = {
