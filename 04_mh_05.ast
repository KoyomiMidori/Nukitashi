					name = {"美岬", "Misaki"},
					"“Oh... ooohhh, really!? You're really okay with me calling you me friends!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哦、哦哦哦〜……这样可以吗？我可以合法地主张是朋友吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哦、哦哦哦〜……這樣可以嗎？我可以合法地主張是朋友嗎！？」",
