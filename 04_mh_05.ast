	["0082_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thanks to being assaulted by Onabuta, I'd totally forgotten our arrangement for Hotori to come over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为女部田的事让我忘得一干二净，原来畔今天要来我家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為女部田的事讓我忘得一乾二淨，原來畔今天要來我家。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00168",
		linknext = "0082_00170",
		line = 2202,
	},
	["0082_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How imprudent of me to forget such an important event.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我居然会忘记这般重要的事件——真是太大意了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我居然會忘記這般重要的事件——真是太大意了。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00169",
		linknext = "0082_00171",
		line = 2212,
	},
	["0082_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I haven't even had a chance to study my love reference material (eroge). If she does end up confessing, then what do I do!?",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且还忘了要",
					{"ruby", text="玩"},
					"研读",
					{"/ruby"},
					{"ruby", text="色情游戏"},
					"恋爱指南书",
					{"/ruby"},
					"。万一被表白了该怎么办……！？",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且還忘了要",
					{"ruby", text="玩"},
					"研讀",
					{"/ruby"},
					{"ruby", text="色情遊戲"},
					"戀愛指南書",
					{"/ruby"},
					"。萬一被表白了該怎麼辦……！？",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00170",
		linknext = "0082_00172",
		line = 2222,
	},
	["0082_00172"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0707", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um... Tachibana? Is something wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……橘同学？怎么了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……橘同學？怎麼了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00171",
		linknext = "0082_00173",
		line = 2236,
	},
	["0082_00173"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, uh, nothing. I was just thinking that's quite the big cloth napkin you've got there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，没有——我在想你的包袱可真大啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，沒有——我在想你的包袱可真大啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00172",
		linknext = "0082_00174",
		line = 2248,
	},
	["0082_00174"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[700] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=700},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0708", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, yes! It's a six-tiered box! It's meant for athletic meets! When I told my mom I was going to a friend's house, she insisted I bring this one!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，对啊！这是运动会规格的六层箱！我说要去朋友家后，妈妈就卖力替我做了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯，對啊！這是運動會規格的六層箱！我說要去朋友家後，媽媽就賣力替我做了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00173",
		linknext = "0082_00175",
		line = 2263,
	},
	["0082_00175"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00111", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
