		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shrugging off Asa's nonsense, I invite Hotori inside.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我应付了一下垂头丧气的麻沙酱，并让畔进入家里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我應付了一下垂頭喪氣的麻沙醬，並讓畔進入家裡。",
					{"rt2"},
				},
			},
		},
