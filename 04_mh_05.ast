			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“For her... uh... she probably at least sees you as an acquaintance... of a friend... of a friend. You know, six degrees, and all that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱的话……嗯……呃……朋友的朋友……的熟人——我想她大概是这么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬的話……嗯……呃……朋友的朋友……的熟人——我想她大概是這麼想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00184",
		linknext = "0082_00186",
		line = 2414,
	},
	["0082_00186"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00113", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[10500] = {
				{"fg", file="misaki_02m_00002", file1="misaki_02m_00114", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=10500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0714", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So distant! Ugh... I'd like to get closer to her. I read that the best way to do that is to find a common interest. Are there any books she likes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“关系好远……！呜……好想接近……之前曾在书里读到如果要增进和睦，有共同话题是最好的……麻沙音酱有什么喜欢读的书吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「關係好遠……！嗚……好想接近……之前曾在書裡讀到如果要增進和睦，有共同話題是最好的……麻沙音醬有什麼喜歡讀的書嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00185",
		linknext = "0082_00187",
		line = 2430,
	},
	["0082_00187"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Manga, maybe. You read manga?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱应该比起小说更喜欢漫画吧……畔也读漫画吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬應該比起小說更喜歡漫畫吧……畔也讀漫畫嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00186",
		linknext = "0082_00188",
		line = 2442,
	},
	["0082_00188"] = {
		{"bgm", stop=1},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0715", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“When I was little I'd read some Hoe/Men Jump. Lately I've been getting more into some stuff from Fap Comix.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“小时候每个月都会看《色色月刊》……最近也有读一些类似Manko Time birara的杂志。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「小時候每個月都會看《色色月刊》……最近也有讀一些類似Manko Time birara的雜誌。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00187",
		linknext = "0082_00189",
		line = 2457,
	},
	["0082_00189"] = {
		{"bgm", file="bgm08", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That sounds like it's really something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“出现了好多听起来很糟糕的词……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「出現了好多聽起來很糟糕的詞……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00188",
		linknext = "0082_00190",
		line = 2470,
	},
	["0082_00190"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0716", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hoe/Men Jump?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是指色色月刊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是指色色月刊？」",
					{"rt2"},
				},
