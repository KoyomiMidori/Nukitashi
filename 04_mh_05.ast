	["0082_00028"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't get it. Why did he save me?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不懂。那个人为什么要救我？",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不懂。那個人為什麼要救我？",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00027",
		linknext = "0082_00029",
		line = 354,
	},
	["0082_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Interfering with an act of intercourse without a valid reason would bring the wrath of the OSS down on him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有正当的理由就妨碍他人的性行为，如果被SHO发现一定会成为处罚的对象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有正當的理由就妨礙他人的性行為，如果被SHO發現一定會成為處罰的對象。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00028",
		linknext = "0082_00030",
		line = 364,
	},
	["0082_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess me being on the verge of passing out could've been seen as a valid reason.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过我当时都快昏厥了，也不是不能说是正当理由——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過我當時都快昏厥了，也不是不能說是正當理由——",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00029",
		linknext = "0082_00031",
		line = 374,
	},
	["0082_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, couldn't he see she was SS? Just brushing her off like that is unusual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但即便如此，对方是FS这一点还是一目了然的。但他依旧帮了我，这点并不寻常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但即便如此，對方是FS這一點還是一目了然的。但他依舊幫了我，這點並不尋常。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00030",
