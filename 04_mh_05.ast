				{"fg", file="asane_02l_00007", file1="asane_02l_00108", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, delay2=9000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1266", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Some guy brought you home, then you let everyone know you were safe before you passed out cold.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥你昨天和另一个男人一起回来了……然后，就和大家联络过了哦？只不过……那之后突然就倒了下来……呜呜……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥你昨天和另一個男人一起回來了……然後，就和大家聯絡過了哦？只不過……那之後突然就倒了下來……嗚嗚……」",
					{"rt2"},
				},
			},
		},
