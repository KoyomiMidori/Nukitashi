		},
		linkback = "0082_00189",
		linknext = "0082_00191",
		line = 2484,
	},
	["0082_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not that one... well, yes, that too, but the other one especially.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是那个……不对，虽然那边也有……不过是后者”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是那個……不對，雖然那邊也有……不過是後者」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00190",
		linknext = "0082_00192",
		line = 2495,
	},
	["0082_00192"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0717", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Fapcom?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“Manbira？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「Manbira？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00191",
		linknext = "0082_00193",
		line = 2509,
	},
	["0082_00193"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please don't call it that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要省略。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要省略。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00192",
		linknext = "0082_00194",
		line = 2521,
	},
	["0082_00194"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0718", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“What, you haven't heard of it? That's like the premiere anthology mag for laid-back manga.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你没听过吗？我一直以为这是轻松漫画的领头羊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你沒聽過嗎？我一直以為這是輕鬆漫畫的領頭羊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00193",
		linknext = "0082_00195",
		line = 2535,
	},
	["0082_00195"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The way you say 'laid-back' makes me think of the 'lying back and thinking of England' meaning, honestly...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种松绝对另有含义吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種鬆絕對另有含義吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00194",
		linknext = "0082_00196",
		line = 2547,
	},
	["0082_00196"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0719", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But this is Japan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“就是字面上的意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就是字面上的意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00195",
		linknext = "0082_00197",
		line = 2561,
	},
	["0082_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Laid-back, eh...",
					{"rt2"},
				},
			},
			cn = {
				{
					"松（另有含义）VS松（字面上的意思）。",
					{"rt2"},
				},
			},
			tw = {
				{
					"鬆（另有含義）VS鬆（字面上的意思）。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00196",
		linknext = "0082_00198",
		line = 2571,
	},
	["0082_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Makes me think of some 80's synth band I heard once.",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然有这种事……两边根本就是同样的意思。",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然有這種事……兩邊根本就是同樣的意思。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00197",
		linknext = "0082_00199",
		line = 2581,
	},
	["0082_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They sang about riding a white horse... or something.",
					{"rt2"},
				},
			},
			cn = {
				{
					"中文真厉害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"中文真厲害。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00198",
		linknext = "0082_00200",
		line = 2591,
	},
	["0082_00200"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00128", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0720", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Does Asane read Fap Comix?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“麻沙音酱不读吗？Manko Time birara”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「麻沙音醬不讀嗎？Manko Time birara」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00199",
		linknext = "0082_00201",
		line = 2605,
	},
	["0082_00201"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She doesn't. I feel like it's my duty as her brother to keep her on a righteous path, so I will not have her read them. In fact, I'd prefer if you avoided bringing it up at all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她不读，作为哥哥也不能让她读。还有以后请竭尽全力不要说出那本杂志的名字好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她不讀，作為哥哥也不能讓她讀。還有以後請竭盡全力不要說出那本雜誌的名字好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00200",
		linknext = "0082_00202",
		line = 2617,
	},
	["0082_00202"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00109", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[800] = {
				{"fg", file="misaki_02m_00002", file1="misaki_02m_00106", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=800, time=300, mode=3, x=0, y=0},
			},
			[7000] = {
				{"fg", file="misaki_02m_00002", file1="misaki_02m_00113", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=7000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0721", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Ah, that's right! You said I should refrain from using sexual terms. That means the magazine's name is out too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦？啊，原来是这样！你有说过有关性的单词要尽量克制……原来连杂志的名字都不行啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦？啊，原來是這樣！你有說過有關性的單詞要盡量克制……原來連雜誌的名字都不行啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00201",
		linknext = "0082_00203",
		line = 2635,
	},
	["0082_00203"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In fact, I'd say it's the biggest problem here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该说那本杂志的名字才是最大的问题……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該說那本雜誌的名字才是最大的問題……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00202",
		linknext = "0082_00204",
		line = 2647,
	},
	["0082_00204"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In any case, I wasn't talking about some weird shit that only circulates on this island. I meant regular manga, like shonen or shoujo stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“除了那些只在青蓝岛上流通的有病书籍，你有在读普通的漫画吗？像少年漫画或少女漫画之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「除了那些只在青藍島上流通的有病書籍，你有在讀普通的漫畫嗎？像少年漫畫或少女漫畫之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00203",
		linknext = "0082_00205",
		line = 2659,
	},
	["0082_00205"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
