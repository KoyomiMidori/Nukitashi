	["0082_00024"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00105", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1267", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“How would I fucking know!? I was pretty focused on the well-being of my dear brother at the time, so forgive me if I don't remember all the details.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你说他是什么样的人……我不怎么记得啊……光是哥哥的事我就忙不过来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你說他是什麼樣的人……我不怎麼記得啊……光是哥哥的事我就忙不過來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00023",
		linknext = "0082_00025",
		line = 305,
	},
	["0082_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“He saved me. Did he at least tell you his name?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他是我的恩人……他有说过名字之类的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他是我的恩人……他有說過名字之類的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00024",
		linknext = "0082_00026",
		line = 316,
	},
	["0082_00026"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00106", file2="asane_02l_00202", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1268", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“He didn't actually say anything at all. He just dropped you off and left.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没特别说什么……送哥哥回来后，他就马上走了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒特別說什麼……送哥哥回來後，他就馬上走了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00025",
		linknext = "0082_00027",
		line = 330,
	},
	["0082_00027"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
