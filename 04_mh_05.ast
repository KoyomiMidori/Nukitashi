	["0082_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's always able to keep up that cheeky yet optimistic outlook, even if she's been corrupted by the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔的个性依旧低三下四但却乐观积极——虽然价值观被青蓝岛毒害着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔的個性依舊低三下四但卻樂觀積極——雖然價值觀被青藍島毒害著。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00295",
		linknext = "0082_00297",
		line = 3966,
	},
	["0082_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Casually talking with this unusual girl makes it seem silly to have stressed out so much over Onabuta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要和这个不可思议的少女对话，我就觉得因为女部田的事而烦恼不已的自己像个傻瓜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要和這個不可思議的少女對話，我就覺得因為女部田的事而煩惱不已的自己像個傻瓜。",
					{"rt2"},
				},
			},
		},
