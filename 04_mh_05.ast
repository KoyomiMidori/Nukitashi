		{"text"},
		delay = {
			[7000] = {
				{"fg", file="misaki_01m_00002", file1="misaki_01m_00110", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=7000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0705", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Phew! Y-You scared me for a minute! I thought I'd misremembered, and I was about to eat all the food I was bringing you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……！吓、吓了我一跳……我还以为我误会了什么……差点就要把带过来的饭菜都自己一个人吃光了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……！嚇、嚇了我一跳……我還以為我誤會了什麼……差點就要把帶過來的飯菜都自己一個人吃光了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00165",
		linknext = "0082_00167",
		line = 2166,
	},
	["0082_00167"] = {
