	["0082_00273"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1285", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yes, yes, very good food, yada yada yada. That's all you came for, so go home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好好好很做作很可爱……如果没事就可以先回去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好好好很做作很可愛……如果沒事就可以先回去了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00272",
		linknext = "0082_00274",
		line = 3651,
	},
	["0082_00274"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the hell's your problem? How can you react so differently to Hotori than to Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和对奈奈濑做出的反应比也差太多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和對奈奈瀨做出的反應比也差太多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00273",
		linknext = "0082_00275",
		line = 3663,
	},
	["0082_00275"] = {
