astver = 2.0
ast = {
	["0122_00001"] = {
		{"fg", mode=-1, id=30},
		{"savetitle", text="存在危殆", ja="存在危殆", en="Existential Jeopardy", cn="存在危机", tw="存在危機"},
		{"eval", exp="g.05_fk_22=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg05_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After that, the next few days on Seiran Island were practically a maelstrom.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那之后，这几天的青蓝岛简直就是惊涛骇浪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那之後，這幾天的青藍島簡直就是驚濤駭浪。",
					{"rt2"},
				},
			},
		},
		linknext = "0122_00002",
		line = 18,
	},
	["0122_00002"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg17_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0089", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“Excuse me, you there! You're a student at this academy, right? Do you have any thoughts on the current turmoil?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“那边的你！你是这个学校的学生吧！？对这次的骚动，你是怎么想的！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「那邊的你！你是這個學校的學生吧！？對這次的騷動，你是怎麼想的！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00001",
		linknext = "0122_00003",
		line = 36,
	},
	["0122_00003"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0207", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "アナウンサーB"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Newslady B"},
					"“This Kotoyose Fumino girl is currently a major news topic! Do you know anything about her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "主播B"},
					"“成为话题的叫琴寄文乃的女孩子，你有听说过吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "主播B"},
					"「成為話題的叫琴寄文乃的女孩子，你有聽說過嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00002",
		linknext = "0122_00004",
		line = 48,
	},
	["0122_00004"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, not particularly...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不，我没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不，我沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00003",
		linknext = "0122_00005",
		line = 60,
	},
	["0122_00005"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0090", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“You there, miss! Were any friends of yours victims of prostitution? If you know anything, would you care to tell us? You'll be recompensed handsomely!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“那边的女孩也是！你的朋友中也有卖淫的受害者吗！？知道的话能告诉我吗！我会给你报酬的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「那邊的女孩也是！你的朋友中也有賣淫的受害者嗎！？知道的話能告訴我嗎！我會給你報酬的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00004",
		linknext = "0122_00006",
		line = 72,
	},
	["0122_00006"] = {
		{"bg", id=1, file="bg17_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00109", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="蘭", id=8, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="ran_01m_00001", file1="ran_01m_00104", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ran0333", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“What!? That's absolutely ridiculous! This is a paradise for individuals who crave perverted sex! No one is being forced to do anything!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“这里没有那样的人！！这里是希望变态做爱的人们的乐园！这里根本没有强制做爱的事实！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「這裡沒有那樣的人！！這裡是希望變態做愛的人們的樂園！這裡根本沒有強制做愛的事實！」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00005",
		linknext = "0122_00007",
		line = 89,
	},
	["0122_00007"] = {
		{"se", id=0, loop=0, file="se_a200"},
		{"bg", id=2, file="whiteback_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=1, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=2, act="アルファフェード点滅", loop=1, alpha="0,256", time=100, alphadel=1, lv=5},
		{"ex", time=1000, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0091", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“It is not unlikely that all students attending the island's lone educational academy have been indoctrinated in much the same way as this girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“……就像这样，岛上唯一的学校的学生们，也受到了同样的教育。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「……就像這樣，島上唯一的學校的學生們，也受到了同樣的教育。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00006",
		linknext = "0122_00008",
		line = 105,
	},
	["0122_00008"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00112", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="蘭", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0334", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“H-Hey, that's fake news right there! Cut that out!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“这、这是随意篡改！请停止！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「這、這是隨意篡改！請停止！」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00007",
		linknext = "0122_00009",
		line = 120,
	},
	["0122_00009"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0067", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Let it go, sis! No matter what you say, they're just gonna edit it to fit their own narrative!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“等一下姐姐，不管怎么说都会被断章取义的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「等一下姐姐，不管怎麼說都會被斷章取義的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00008",
		linknext = "0122_00010",
		line = 132,
	},
	["0122_00010"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0068", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Dammit... All that work I did to move up through the SS ranks and take over the OSS... What a fat lot of good that'll be doing me now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“切……爬上FS顶端把SHO收入囊中的我的计划……就这样打水漂了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「嘖……爬上FS頂端把SHO收入囊中的我的計劃……就這樣打水漂了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00009",
		linknext = "0122_00011",
		line = 144,
	},
	["0122_00011"] = {
		{"se", id=0, loop=0, file="se_a015"},
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The media have been hassling people on the island like this every day, and as a result, everyone's been behaving totally different from before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像这样，媒体连日蜂拥到青蓝岛上，出现了和以往不同的热闹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像這樣，媒體連日蜂擁到青藍島上，出現了和以往不同的熱鬧。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00010",
		linknext = "0122_00012",
		line = 157,
	},
	["0122_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The island has become the target of international scorn for being a hive of scum and villainy, owing to its prostitution problem being linked with the illegal sex industry.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟地下风俗有关的卖淫问题，邪恶的老巢，因为这些事情，岛受到了世间的批评。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟地下風俗有關的賣淫問題，邪惡的老巢，因為這些事情，島受到了世間的批評。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00011",
		linknext = "0122_00013",
		line = 167,
	},
	["0122_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The once-abundant tourists are virtually gone, no one's having sex by the roadside, and local businesses have shut down to avoid prying from reporters.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本人山人海的游客也变少了，再也没有人在路边做爱，为了避开采访，店铺也都关门了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本人山人海的遊客也變少了，再也沒有人在路邊做愛，為了避開採訪，店鋪也都關門了。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00012",
		linknext = "0122_00014",
		line = 177,
	},
	["0122_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The festive atmosphere in the air has utterly vanished, replaced by a thick, disquieting unease.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像节日般的气氛已经消失无踪，取而代之的是与平常不同的光景。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像節日般的氣氛已經消失無踪，取而代之的是與平常不同的光景。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00013",
		linknext = "0122_00015",
		line = 187,
	},
	["0122_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And, admittedly to little surprise, there's also this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，就如压倒骆驼的最后一根稻草般——",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，就如壓倒駱駝的最後一根稻草般——",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00014",
		linknext = "0122_00016",
		line = 197,
	},
	["0122_00016"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"evset", file="kcg05", set="kcg05", path=":ev/kcg05/"},
		{"evset", file="kcg050103", set="kcg050103", path=":ev/kcg050103/"},
		{"bg", id=1, file="bg17_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg050103", x=-5, y=-5, path=":cg/kcg05/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0869", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As I'm sure you're all aware, Seiran Island is currently the subject of massive scrutiny from the world at large.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——正如大家所知，现在青蓝岛受到了世人的极大关注。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——正如大家所知，現在青藍島受到了世人的極大關注。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00015",
		linknext = "0122_00017",
		line = 240,
	},
	["0122_00017"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0870", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Regarding the alleged issue of prostitution, the island has not been charged under penal law over this, but we have received strict guidance from administration.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对于卖淫等问题，岛没有受到任何处罚，但行政方面受到了严厉的指导。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對於賣淫等問題，島沒有受到任何處罰，但行政方面受到了嚴厲的指導。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00016",
		linknext = "0122_00018",
		line = 252,
	},
	["0122_00018"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0871", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As a result, the perverted sex law is currently under consideration for revision, and the decision has been made to temporarily suspend it until further notice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因此从现在开始，青蓝岛的变态条例修改一事在经过检讨之后，决定暂时停止条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因此從現在開始，青藍島的變態條例修改一事在經過檢討之後，決定暫時停止條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00017",
		linknext = "0122_00019",
		line = 264,
	},
	["0122_00019"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0150", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "男子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Male Student A"},
					"“Huh? Does that mean... that sex is now prohibited!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "男学生A"},
					"“诶……那也就是说……做爱被禁止了吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "男學生A"},
					"「欸……那也就是說……做愛被禁止了嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00018",
		linknext = "0122_00020",
		line = 276,
	},
	["0122_00020"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0872", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Procreational actions are now strictly forbidden on the island, and punishment for doing so will be doled out in accordance with mainland law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“全岛全面禁止性产行为，罚则比照本岛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「全島全面禁止性產行為，罰則比照本島。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00019",
		linknext = "0122_00021",
		line = 288,
	},
	["0122_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In summary...",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说——",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說——",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00020",
		linknext = "0122_00022",
		line = 298,
	},
	["0122_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0873", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“We also hereby inform everyone that both the OSS, the public authority which manages matters relating to the perverted sex law, and the SS, the organization for students with special scholarships, are to be abolished.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“同时，管理变态条例的公益社团法人‘OSS’以及特别奖学生‘SS’也决定解散，特此通知。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「同時，管理變態條例的公益社團法人『OSS』以及特別獎學生『SS』也決定解散，特此通知。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00021",
		linknext = "0122_00023",
		line = 310,
	},
	["0122_00023"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's basically informing everyone that Seiran Island is collapsing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个告知，实际上就是宣示青蓝岛崩溃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個告知，實際上就是宣示青藍島崩潰了。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00022",
		linknext = "0122_00024",
		line = 321,
	},
