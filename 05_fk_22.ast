	["0122_00052"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0310", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Newslady A"},
					"“He's on his own again! Excuse me, can I ask you a few questions? Just get in the car! Don't you want to be on TV?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "主播A"},
					"“又来了一个人……你，跟我讲讲话吧！在车里讲！你不想上电视吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "主播A"},
					"「又來了一個人……你，跟我講講話吧！在車裡講！你不想上電視嗎……！？」",
					{"rt2"},
