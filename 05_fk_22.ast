	},
	["0122_00113"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1780", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“All she wanted was to live a normal life... And look what they did to her! Everything's fucked now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那个孩子、只不过、想过上、一般的日子……却被迫上电视……！全部、都被毁了啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那個孩子、只不過、想過上、一般的日子……卻被迫上電視……！全部、都被毀了啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00112",
		linknext = "0122_00114",
		line = 1537,
	},
	["0122_00114"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
