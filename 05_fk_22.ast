	["0122_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just duck my head and pay no heed to the unasked-for advances of the media vultures.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了避开媒体的烦人追问，我低下了头。",
