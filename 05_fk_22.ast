		linkback = "0122_00035",
		linknext = "0122_00037",
		line = 532,
	},
	["0122_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, I had considered the possibility.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，作为可能性，这是完全能考虑到的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，作為可能性，這是完全能考慮到的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00036",
		linknext = "0122_00038",
		line = 542,
	},
	["0122_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But who would have anticipated a blood relative would use their own granddaughter like that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是……谁会想到有人会这样对待自己的外孙女呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是……誰會想到有人會這樣對待自己的外孫女呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00037",
		linknext = "0122_00039",
		line = 552,
	},
	["0122_00039"] = {
