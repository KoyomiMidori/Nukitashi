				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2094", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You're telling me... Ah! Fumino's on TV again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊……啊……！文乃酱又出现在电视上了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊……啊……！文乃醬又出現在電視上了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00025",
		linknext = "0122_00027",
		line = 399,
	},
	["0122_00027"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2095", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It feels like she's on the news every day now... Do these vultures not care about her privacy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“现在媒体一直跟着她……还、还有没有隐私了……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「現在媒體一直跟著她……還、還有沒有隱私了……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00026",
		linknext = "0122_00028",
		line = 415,
	},
	["0122_00028"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1775", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The whole thing's gone viral online, too. I'm seeing pics of Fumino on every forum. And on top of that, I keep seeing posts calling her a roastie and no shortage of other shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……网络上也上了热门呢。有很多关于文乃的照片……还有人批评说她也不是处女……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……網路上也上了熱門呢。有很多關於文乃的照片……還有人批評說她也不是處女……」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00027",
		linknext = "0122_00029",
		line = 428,
	},
	["0122_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"None of the NLNS members can hide their unease.",
					{"rt2"},
				},
			},
			cn = {
				{
					"NLNS的成员们掩饰不住内心的动摇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"NLNS的成員們掩飾不住內心的動搖。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00028",
		linknext = "0122_00030",
		line = 438,
	},
	["0122_00030"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2218", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That old guy was our sponsor all along, right? Why did he have to go and do this? That's his granddaughter, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那个人，是出资的老爷爷啊……？他为什么要做这样的事情……？不是自己的外孙女吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那個人，是出資的老爺爺啊……？他為什麼要做這樣的事情……？不是自己的外孫女嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00029",
		linknext = "0122_00031",
		line = 452,
	},
	["0122_00031"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2295", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“He used her real name. Must have figured that it'd be most effective to do that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“会说出真名……大概是认为这样更有效吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「會說出真名……大概是認為這樣更有效吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00030",
		linknext = "0122_00032",
		line = 466,
	},
	["0122_00032"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1776", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That way, anyone could look her up and learn she's not in the family registry. It gives Sakimori a solid alibi, and it means society can just accept his word as fact.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“说她没有户籍后，只要有人去查很快就能知道了……这样的话，也能证明防人老人说的是事实，而被世间认同……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「說她沒有戶籍後，只要有人去查很快就能知道了……這樣的話，也能證明防人老人說的是事實，而被世間認同……」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00031",
		linknext = "0122_00033",
		line = 479,
	},
	["0122_00033"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2096", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Since he hasn't said she's his granddaughter, that means people wouldn't see his actions as relating to his feud with Senator Hitoura— he'd just look like someone in the right trying to incite the public that way, wouldn't he?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
