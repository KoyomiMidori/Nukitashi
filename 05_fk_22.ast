				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I keep walking this route, I'm probably going to get more of these hack fucks harassing me, so I'll just take the low road.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想着如果就这样走上学路的话，一定还有记者会等着，于是我走进了往常的那条小巷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想著如果就這樣走上學路的話，一定還有記者會等著，於是我走進了往常的那條小巷。",
					{"rt2"},
				},
			},
		},
