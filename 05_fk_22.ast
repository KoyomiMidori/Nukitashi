	},
	["0122_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think back on what she said to me before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时的声音被唤醒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時的聲音被喚醒。",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00114",
		linknext = "0122_00116",
		line = 1559,
	},
	["0122_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"“What I desire... Perhaps to live a normal life would suffice?”",
					{"rt2"},
				},
			},
			cn = {
				{
					"——我的愿望……嗯，应该是一般的生活吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"——我的願望……嗯，應該是一般的生活吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00115",
		linknext = "0122_00117",
		line = 1569,
	},
	["0122_00117"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1781", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“And even to the end... I was still a snarky asshole to her... Now I can't even tell her I'm sorry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“而且……我……到最后……对文乃都……糟透了……我没办法道歉了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「而且……我……到最後……對文乃都……糟透了……我沒辦法道歉了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0122_00116",
