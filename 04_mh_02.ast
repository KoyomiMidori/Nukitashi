	["0079_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hasta ahora, había podido mantener una conversación relativamente normal, pero se nos acabaron los temas y la charla se fue apagando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明刚才我还和她在正常说话——但一旦对话中断，就又说不出话来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明剛才我還和她在正常說話——但一旦對話中斷，就又說不出話來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00062",
		linknext = "0079_00064",
		line = 842,
	},
	["0079_00064"] = {
		{"bgm", file="bgm11", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero está bien. A comparación de ayer, soy un hombre nuevo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——没有问题。今天的我和昨天的我不一样。",
