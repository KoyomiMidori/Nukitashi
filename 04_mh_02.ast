					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Así funcionan las cosas para ti?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是……那样的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是……那樣的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00256",
		linknext = "0079_00258",
		line = 3377,
