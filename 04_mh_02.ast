		line = 3062,
	},
	["0079_00232"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Se te ocurre algo? ¿Algún lugar donde nadie podría encontrarla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔你对能避开别人目光的地点有想法吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔你對能避開別人目光的地點有想法嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00231",
		linknext = "0079_00233",
		line = 3074,
	},
	["0079_00233"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0558", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“A ver... Cuando estoy sola, voy a la escuela por caminos casi vacíos para que nadie me vea, pero no creo que ella esté en esos caminos. Solo se me ocurre eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……虽然我一个人的时候也会尽量避开目光上下学，不过我并不认为人会藏在那些地方……除此之外的地点，说实话我不清楚……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……雖然我一個人的時候也會盡量避開目光上下學，不過我並不認為人會藏在那些地方……除此之外的地點，說實話我不清楚……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00232",
		linknext = "0079_00234",
		line = 3088,
	},
	["0079_00234"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
