	["0079_00216"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00124", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1239", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ay otra vez con esa tontería de loli virgen dulcesita, te juro que te meteré un vibrador tan profundo en tu estúpida garganta de cerda gorda para que se te quite lo virgen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你说什么怎么酱啊想装没事炫耀自己是处女吗小心我把这个按摩棒从你这可恶肥女的喉咙捅进去把你的处女膜捅破哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你說什麼怎麼醬啊想裝沒事炫耀自己是處女嗎小心我把這個按摩棒從你這可惡肥女的喉嚨捅進去把你的處女膜捅破哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00215",
		linknext = "0079_00217",
		line = 2843,
	},
	["0079_00217"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0556", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ahh. ¡¿P-Puedes hacer eso?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呀……麻、麻沙音酱做得到那种事吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呀……麻、麻沙音醬做得到那種事嗎……！？」",
