		linkback = "0079_00197",
		linknext = "0079_00199",
		line = 2610,
	},
	["0079_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Was anyone able to learn anything about Kotoyose Fumino? Any lead is good, no matter how small it seems.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“关于‘琴寄文乃’，有明白的事吗？再小的线索都没关系。”",
