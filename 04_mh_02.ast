		text = {
			vo = {
				{"vo", file="misaki0508", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, that's it! Thank you! Sorry, I'm so fat that I just make problems for everyone, aren't I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……就是这个，谢谢你！不好意思，都因为我是胖子，给橘同学添麻烦了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……就是這個，謝謝你！不好意思，都因為我是胖子，給橘同學添麻煩了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00039",
		linknext = "0079_00041",
		line = 534,
	},
	["0079_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's going a bit far. You're not even that fat, I don't think.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你太夸张了……之前也说过，我觉得你并不胖喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你太誇張了……之前也說過，我覺得你並不胖喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00040",
		linknext = "0079_00042",
		line = 546,
	},
	["0079_00042"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0509", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“P-Please, you don't need to flatter me! I'm well aware that only a fatty like me could just pop one of her own buttons off like that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“请、请不要那么勉强自己顾虑我！我知道只有像我这样的超级臭胖子才会有崩飞扣子的本领……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「請、請不要那麼勉強自己顧慮我！我知道只有像我這樣的超級臭胖子才會有崩飛釦子的本領……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00041",
		linknext = "0079_00043",
		line = 560,
	},
	["0079_00043"] = {
