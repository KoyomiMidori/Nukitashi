			},
			[6000] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=6000},
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00118", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=6000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0566", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Sí! Además, ¿no te acosa a ti también? Te llama virgen, o... impotente... ¡pfft!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊。而且麻沙音酱不也对橘同学说得很过分吗？什么大处男啊，阳痿之类的……噗噗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊。而且麻沙音醬不也對橘同學說得很過分嗎？什麼大處男啊，陽痿之類的……噗噗……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00257",
		linknext = "0079_00259",
		line = 3397,
	},
	["0079_00259"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso duele.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我心里受了很深的伤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我心裡受了很深的傷。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00258",
		linknext = "0079_00260",
		line = 3407,
	},
	["0079_00260"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eso, uh... es una muestra de lo bien que nos llevamos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为……我们彼此都知道对方的心意啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是因為……我們彼此都知道對方的心意啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00259",
		linknext = "0079_00261",
		line = 3419,
	},
	["0079_00261"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[300] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=300},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0567", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sí, lo entiendo. Al principio fue un poco impactante, pero significa que se llevan tan bien que no necesitan andar con tanto cuidado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，这我也知道。刚开始我还吓了一跳……不过你们是因为关系很好，所以才可以那样毫不客气地交谈呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯，這我也知道。剛開始我還嚇了一跳……不過你們是因為關係很好，所以才可以那樣毫不客氣地交談呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00260",
		linknext = "0079_00262",
		line = 3434,
	},
	["0079_00262"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, me imagino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这倒也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這倒也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00261",
		linknext = "0079_00263",
		line = 3446,
	},
	["0079_00263"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00116", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0568", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Siempre se dice que al estar muy unidos se puede discutir, ¿verdad? Cuando los veo, se nota que su conexión es profunda. Me da un poco de envidia, la verdad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“就像‘越吵关系越好’这句话吧。只要看着橘同学跟麻沙音酱，就会觉得你们真的感情很深，让我有点羡慕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就像『越吵關係越好』這句話吧。只要看著橘同學跟麻沙音醬，就會覺得你們真的感情很深，讓我有點羨慕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00262",
		linknext = "0079_00264",
		line = 3462,
	},
	["0079_00264"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0569", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“A veces me gustaría tener amigos con los que tuviera tanta confianza, ¿sabes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“所以，我也会有点期待总有一天自己也能成为那种能够互骂的朋友。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「所以，我也會有點期待總有一天自己也能成為那種能夠互罵的朋友。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00263",
		linknext = "0079_00265",
		line = 3476,
	},
	["0079_00265"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
