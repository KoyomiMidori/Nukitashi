					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No estoy de acuerdo, pero tal vez Hotori sea una glotona, aunque tampoco está tan gorda como cree.",
					{"rt2"},
				},
			},
			cn = {
				{
