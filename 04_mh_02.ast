		linkback = "0079_00216",
		linknext = "0079_00218",
		line = 2858,
	},
	["0079_00218"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, ya deja de decirle tonterías a Hotori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不能回应她那些无理取闹的话哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不能回應她那些無理取鬧的話哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00217",
		linknext = "0079_00219",
		line = 2870,
	},
	["0079_00219"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La información de Hotori sí es útil.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过——确实，畔所说的话或许很有参考价值。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過——確實，畔所說的話或許很有參考價值。」",
					{"rt2"},
