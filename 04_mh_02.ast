		},
		linkback = "0079_00264",
		linknext = "0079_00266",
		line = 3488,
	},
	["0079_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun así, que ella me llamara virgen estúpido como lo hace Asa-chan sería terrible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果被畔骂说是混蛋处男我也许会原地去世。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果被畔罵說是混蛋處男我也許會原地去世。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00265",
		linknext = "0079_00267",
		line = 3498,
	},
	["0079_00267"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00126", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0570", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Además, nos parecemos mucho, ¿no? Ella es una recluida con crapulencia y yo una aparecida con corpulencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且，我觉得仔细想想就会觉得自己跟她很合得来！因为麻沙音酱是宅女，而我是肥胖症嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且，我覺得仔細想想就會覺得自己跟她很合得來！因為麻沙音醬是宅女，而我是肥胖症嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00266",
		linknext = "0079_00268",
		line = 3512,
	},
	["0079_00268"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué demonios...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那有关联吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那有關聯嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00267",
		linknext = "0079_00269",
		line = 3524,
	},
	["0079_00269"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, sé que podrán llevarse bien. Después de todo, somos compañeros que comparten las mismas ideas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，畔一定能成为她的好朋友的。毕竟我们是拥有相同志向的同伴嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，畔一定能成為她的好朋友的。畢竟我們是擁有相同志向的同伴嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00268",
		linknext = "0079_00270",
		line = 3536,
	},
	["0079_00270"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0571", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ejeje, gracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……谢谢你，橘同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……謝謝你，橘同學。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00269",
		linknext = "0079_00271",
		line = 3550,
	},
	["0079_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Este tipo de conversaciones triviales me hace darme cuenta de que es una chica normal, aunque sí es un poco rara.",
					{"rt2"},
				},
			},
			cn = {
				{
					"向这样跟她对话——虽然有些奇怪的部份，但还是会让人觉得她就是个普通的女孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"向這樣跟她對話——雖然有些奇怪的部份，但還是會讓人覺得她就是個普通的女孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00270",
		linknext = "0079_00272",
		line = 3560,
	},
	["0079_00272"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso hace que la sorpresa que me dio por lo que hizo durante el almuerzo sea aún mayor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但也正因为这样，白天的冲击才会如此令人难以忘怀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但也正因為這樣，白天的衝擊才會如此令人難以忘懷。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00271",
		linknext = "0079_00273",
		line = 3570,
	},
	["0079_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Eso de veras pasó? ¿Fue solo mi ego desenfrenado el que me hizo alucinar?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那真的是现实吗？还是被压抑的自我让我看到的白日梦呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那真的是現實嗎？還是被壓抑的自我讓我看到的白日夢呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00272",
		linknext = "0079_00274",
		line = 3580,
	},
	["0079_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Creo que sí, pero...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我也曾这样想过——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我也曾這樣想過——",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00273",
		linknext = "0079_00275",
		line = 3590,
	},
	["0079_00275"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00102", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0572", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ya sé, tal vez me toque y rece cuando llegue a casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对了，今天回家来祈愿自慰一下吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對了，今天回家來祈願自慰一下吧……」",
					{"rt2"},
				},
			},
