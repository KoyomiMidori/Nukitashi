				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Oh, lo están haciendo! ¡Y además es un trío! Increíble, algo tan grande está entrando en ella... ¡¿Ohh?!”",
					{"rt2"},
