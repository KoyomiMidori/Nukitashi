	["0079_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca pensé que sería tan difícil comer mi almuerzo cuando lo único que escucho son los gemidos de mi compañera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一边听着同学娇喘的声音一边吃午饭——比想象中还要辛苦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一邊聽著同學嬌喘的聲音一邊吃午飯——比想像中還要辛苦。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00140",
		linknext = "0079_00142",
		line = 1856,
	},
	["0079_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me siento contaminado al aguantar esta mierda todo el tiempo, pero parece que los gemidos provienen de justo a mi lado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许是因为每天都听到太多娇声，我有一种娇喘是从身旁发出的错觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許是因為每天都聽到太多嬌喘，我有一種嬌喘是從身旁發出的錯覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00141",
		linknext = "0079_00143",
		line = 1866,
	},
	["0079_00143"] = {
