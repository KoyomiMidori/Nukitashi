	["0079_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los sonidos de nuestra comida cubren el salón que estaría vacío.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在只有两个人的空教室里，回荡着吃饭的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在只有兩個人的空教室裡，迴盪著吃飯的聲音。",
