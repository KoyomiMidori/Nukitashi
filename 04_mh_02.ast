		delay = {
			[10] = {
				{"fg", mode=-1, id=6, ch="美岬", lv=5, time=400, delay2=10},
			},
			[1000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1000, time=600, mode=3, x=0, y=100},
				{"fgact", ch="美岬", id=6, act="移動", x=0, y=-100, time=700, delay2=1000},
