					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Puedo entenderlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……」",
					{"rt2"},
				},
