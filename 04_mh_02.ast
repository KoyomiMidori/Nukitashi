				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al parecer, en lo que tardé en pestañear, se acabó esas enormes bolas de arroz.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我才稍微移开了目光，她就把那颗巨大的饭团全都吃掉了。",
