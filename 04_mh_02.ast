					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wasn't flattering you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是不是有点太低三下四了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
