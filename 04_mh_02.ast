					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No lo decía por eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是不是有点太低三下四了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是不是有點太低三下四了……？」",
