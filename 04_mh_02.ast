	["0079_00235"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a193"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La conversación se va apagando, haciendo que el ruido de la bicicleta de Hotori sea mucho más fuerte.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对话中断，畔推着自行车的声音听起来奇妙地大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對話中斷，畔推著自行車的聲音聽起來奇妙地大。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00234",
		linknext = "0079_00236",
		line = 3113,
	},
	["0079_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya acompañé a Nanase y Wata-chan, y ahora estoy solo con Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"送奈奈濑和渡酱回家后，现在只有我和畔两个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"送奈奈瀨和渡醬回家後，現在只有我和畔兩個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00235",
		linknext = "0079_00237",
		line = 3123,
	},
	["0079_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan siempre está buscando pelea con Hotori, así que la dejé en casa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为麻沙酱会乱咬畔，所以就让她留在家里了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為麻沙醬會亂咬畔，所以就讓她留在家裡了。",
					{"rt2"},
				},
