			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“一次射精就枯萎了，多么可怜的小鸡鸡啊……我得用我的花丸阴道来教训你们……起立！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「一次射精就軟掉了，多麼可憐的小雞雞啊……我得用我的花丸陰道來教訓你們……起立！」",
					{"rt2"},
				},
			},
		},
