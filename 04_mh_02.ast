		linkback = "0079_00249",
		linknext = "0079_00251",
		line = 3287,
	},
	["0079_00251"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你为什么笑呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你為什麼笑呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00250",
		linknext = "0079_00252",
		line = 3299,
	},
	["0079_00252"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00202", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0563", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, nothing. It's just... I feel like I've become a character in a story.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，没有……我总觉得自己好像成了故事里的人物，一不小心就。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，沒有……我總覺得自己好像成了故事裡的人物，一不小心就。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00251",
		linknext = "0079_00253",
		line = 3313,
	},
	["0079_00253"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00252",
		linknext = "0079_00254",
		line = 3325,
	},
	["0079_00254"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00301", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0564", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You always see things like bullying and rivalries in books! I've never been anything but a nameless background character, so this is my first time experiencing this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为被谁讨厌什么的，不是只会发生在书中的故事吗？我一直都是个无名的路人角色，所以这还是第一次被讨厌……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為被誰討厭什麼的，不是只會發生在書中的故事嗎？我一直都是個無名的路人角色，所以這還是第一次被討厭……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00253",
		linknext = "0079_00255",
		line = 3339,
	},
	["0079_00255"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, but... you're being bullied.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，可是……你可是被讨厌了哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，可是……你可是被討厭了哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00254",
		linknext = "0079_00256",
		line = 3351,
	},
	["0079_00256"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00126", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0565", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I'll take it over being ignored! At least she's aware of my existence, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那也比完全不被在意好！因为不管怎么说，这都表示我被别人注意到了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那也比完全不被在意好！因為不管怎麼說，這都表示我被別人注意到了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00255",
		linknext = "0079_00257",
		line = 3365,
	},
	["0079_00257"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That how it works?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是……那样的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是……那樣的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00256",
		linknext = "0079_00258",
		line = 3377,
	},
	["0079_00258"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
			[6000] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=6000},
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00118", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=6000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0566", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah! Plus, doesn't she bully you, too? Like calling you a v-virgin, or... impotent... pfft!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊。而且麻沙音酱不也对橘同学说得很过分吗？什么大处男啊，阳痿之类的……噗噗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊。而且麻沙音醬不也對橘同學說得很過分嗎？什麼大處男啊，陽痿之類的……噗噗……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00257",
		linknext = "0079_00259",
		line = 3397,
	},
	["0079_00259"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It cuts deep.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我心里受了很深的伤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我心裡受了很深的傷。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00258",
		linknext = "0079_00260",
		line = 3407,
	},
	["0079_00260"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That just, uh... shows how well we get along.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为……我们彼此都知道对方的心意啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是因為……我們彼此都知道對方的心意啊。」",
					{"rt2"},
				},
