					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo más caballeroso sería cambiar de tema. Ahora voy a preguntarle qué tipo de comida le gusta...",
					{"rt2"},
				},
			},
			cn = {
				{
