				},
			},
			en = {
				{
					"Según los eroges, cuando comes con alguien, tienes que hablarle de comida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"色情游戏这样告诉我——吃饭的时候，丢出的话题当然也该是食物。",
					{"rt2"},
				},
			},
			tw = {
				{
					"色情遊戲這樣告訴我——吃飯的時候，丟出的話題當然也該是食物。",
