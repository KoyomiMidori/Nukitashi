	["0079_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tras haber conquistado el campo de batalla que es la fila para los sándwiches, estoy recorriendo la escuela en busca de zonas libres para comer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在采购面包的争夺战中获胜的我在校内徘徊，寻找着没有人的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在採購麵包的爭奪戰中獲勝的我在校內徘徊，尋找著沒有人的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00001",
		linknext = "0079_00003",
		line = 28,
	},
	["0079_00003"] = {
		{"se", id=0, stop=1, time=1000},
		{"bgm", file="bgm08", vol=100},
		{"bg", id=2, file="bg15_1_1l_00000", x=100, y=-100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-205, y=-5, time=20000, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0248", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "ギャル女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante gyaru A"},
					"“¡Ah, es hora de comer! Muy bien, chicos, mi coño está hambriento, ¿alguno de ustedes tiene una polla rica y jugosa para que se la coma?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "辣妹女学生A"},
					"“啊～终于到中午了！下面真的超干的……好想先跟粗粗的鸡巴干一炮～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "辣妹女學生A"},
					"「啊～終於到中午了！下面真的超乾的……好想先跟粗粗的肉棒幹一炮～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00002",
		linknext = "0079_00004",
		line = 44,
	},
	["0079_00004"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tsk, ¿a estas horas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“糟了，都到这种时候了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「糟了，都到這種時候了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00003",
		linknext = "0079_00005",
		line = 56,
	},
	["0079_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estamos almorzando, pero lo único que veo es sexo por doquier, y ni un espacio para comer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是白天，但四周却都有人在做爱——这种情况根本吃不了饭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是白天，但四周卻都有人在做愛——這種情況根本吃不了飯。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00004",
		linknext = "0079_00006",
		line = 66,
	},
	["0079_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿En qué momento comen? ¿De verdad prefieren tragar polla que alimentarse bien?",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明都还没吃饭，做爱的优先顺序有那么高吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明都還沒吃飯，做愛的優先順序有那麼高嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00005",
		linknext = "0079_00007",
		line = 76,
	},
	["0079_00007"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0058", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "女子生徒B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Estudiante B"},
					"“¡Ay! ¡Perdí la oportunidad de comerme un sándwich y ahora me muero de hambre! ¡Lo único que podría satisfacer mi antojo sería tragarme una polla grande y dura!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "女学生B"},
					"“呀啊！因为没买到面包就把我当做泄愤对象啪啪啪地干了，弄得我空荡荡的肚子都鼓起来了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "女學生B"},
					"「呀啊！因為沒買到麵包就把我當做洩憤對象啪啪啪地操了，弄得我空蕩蕩的肚子都鼓起來了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00006",
		linknext = "0079_00008",
		line = 88,
	},
