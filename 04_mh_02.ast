	["0079_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después del fiasco de ayer, estudié a fondo cómo entablar conversación con alguien tan tímida como Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基于之前的反省，昨晚我又重新学习了对内向女孩专用的谈话技巧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"基於之前的反省，昨晚我又重新學習了對內向女孩專用的談話技巧——",
					{"rt2"},
				},
			},
		},
