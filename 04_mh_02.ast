	},
	["0079_00261"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[300] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=300},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0567", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Right, I can see that. It was a bit of a shock at first, but it means you get along so well that you don't need to pull your punches with each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，这我也知道。刚开始我还吓了一跳……不过你们是因为关系很好，所以才可以那样毫不客气地交谈呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯，這我也知道。剛開始我還嚇了一跳……不過你們是因為關係很好，所以才可以那樣毫不客氣地交談呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00260",
		linknext = "0079_00262",
		line = 3434,
	},
	["0079_00262"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I guess.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这倒也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這倒也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00261",
		linknext = "0079_00263",
		line = 3446,
	},
	["0079_00263"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00116", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0568", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“People talk a lot about being so close that you can argue, right? When I watch you two, it's easy to see how deeply you're connected. Honestly, it makes me a bit jealous.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“就像‘越吵关系越好’这句话吧。只要看着橘同学跟麻沙音酱，就会觉得你们真的感情很深，让我有点羡慕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就像『越吵關係越好』這句話吧。只要看著橘同學跟麻沙音醬，就會覺得你們真的感情很深，讓我有點羨慕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00262",
		linknext = "0079_00264",
		line = 3462,
	},
	["0079_00264"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0569", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sometimes I wish I had friends I was that close with, you know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“所以，我也会有点期待总有一天自己也能成为那种能够互骂的朋友。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「所以，我也會有點期待總有一天自己也能成為那種能夠互罵的朋友。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00263",
		linknext = "0079_00265",
		line = 3476,
	},
	["0079_00265"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fair enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00264",
		linknext = "0079_00266",
		line = 3488,
	},
	["0079_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, having her call me a stupid virgin like Asa does would kill me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果被畔骂说是混蛋处男我也许会原地去世。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果被畔罵說是混蛋處男我也許會原地去世。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00265",
		linknext = "0079_00267",
		line = 3498,
	},
	["0079_00267"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00126", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0570", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Besides, we're pretty similar, right? She's a crapulent homebody, and I'm a corpulent nobody!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且，我觉得仔细想想就会觉得自己跟她很合得来！因为麻沙音酱是宅女，而我是肥胖症嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且，我覺得仔細想想就會覺得自己跟她很合得來！因為麻沙音醬是宅女，而我是肥胖症嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00266",
		linknext = "0079_00268",
		line = 3512,
	},
	["0079_00268"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the hell...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那有关联吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那有關聯嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00267",
		linknext = "0079_00269",
		line = 3524,
	},
	["0079_00269"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I'm sure you'll be able to make things work with her. After all, we're all like-minded comrades.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，畔一定能成为她的好朋友的。毕竟我们是拥有相同志向的同伴嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，畔一定能成為她的好朋友的。畢竟我們是擁有相同志向的同伴嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00268",
		linknext = "0079_00270",
		line = 3536,
	},
	["0079_00270"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0571", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ehehe, thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……谢谢你，橘同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……謝謝你，橘同學。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00269",
		linknext = "0079_00271",
		line = 3550,
	},
	["0079_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Making small talk like this makes me realize that she's a regular girl, even if she is a bit of a weirdo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"向这样跟她对话——虽然有些奇怪的部份，但还是会让人觉得她就是个普通的女孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"向這樣跟她對話——雖然有些奇怪的部份，但還是會讓人覺得她就是個普通的女孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00270",
		linknext = "0079_00272",
		line = 3560,
	},
	["0079_00272"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That makes the shock of what she did at lunch stand out even more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但也正因为这样，白天的冲击才会如此令人难以忘怀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但也正因為這樣，白天的衝擊才會如此令人難以忘懷。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00271",
		linknext = "0079_00273",
		line = 3570,
	},
	["0079_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Did that really happen? Was it just my unrestrained ego making me daydream it?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那真的是现实吗？还是被压抑的自我让我看到的白日梦呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那真的是現實嗎？還是被壓抑的自我讓我看到的白日夢呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00272",
		linknext = "0079_00274",
		line = 3580,
	},
	["0079_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I do think that, but...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我也曾这样想过——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我也曾這樣想過——",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00273",
		linknext = "0079_00275",
		line = 3590,
	},
	["0079_00275"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00102", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0572", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I know, I might fap a prayer for it when I get home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对了，今天回家来祈愿自慰一下吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對了，今天回家來祈願自慰一下吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00274",
		linknext = "0079_00276",
		line = 3604,
	},
	["0079_00276"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Truth is stranger than fiction.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但现实并没有那么美好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但現實並沒有那麼美好。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00275",
