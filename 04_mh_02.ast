	["0079_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿En serio? ¿Sacó el pecho un poco y se le salió un botón?",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才是怎么回事——只是挺起胸膛纽扣就弹开飞走了？",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才是怎麼回事——只是挺起胸膛鈕扣就彈開飛走了？",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00033",
		linknext = "0079_00035",
		line = 461,
	},
	["0079_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¡¿Esas cosas pasan en la vida real?! ¡Pensé que solo pasaba en los eroges!",
					{"rt2"},
