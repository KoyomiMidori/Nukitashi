	["0079_00021"] = {
		{"bgm", file="bgm24", vol=100},
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00101", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0501", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, Tachibana? You startled me. I thought it was a poltergeist for a minute.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哎呀……橘同学？什么啊……吓了我一跳。一瞬间以为是灵异现象……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哎呀……橘同學？什麼啊……嚇了我一跳。一瞬間以為是靈異現象……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00020",
		linknext = "0079_00022",
		line = 295,
	},
	["0079_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry I startled you. I thought this room was empty.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思，我以为没人在……你吓了一跳吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思，我以為沒人在……你嚇了一跳吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00021",
		linknext = "0079_00023",
		line = 307,
	},
	["0079_00023"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0502", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, no, it's fine. It's my fault for being so nondescript that I even blend into the background in an empty room. I'm surprised you even noticed me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，不……是我太没存在感的错……话说你是怎么注意的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，不……是我太沒存在感的錯……話說你是怎麼注意的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00022",
		linknext = "0079_00024",
		line = 321,
	},
	["0079_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, I mean, there's no one else here, so anyone would've noticed you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果一个人呆在这种地方的话，任谁都会注意到的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果一個人待在這種地方的話，任誰都會注意到的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00023",
		linknext = "0079_00025",
		line = 332,
	},
	["0079_00025"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0503", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You'd think that, but you'd be surprised. Not that long ago, I was alone in the library reading a book after school. I lost track of time, and they ended up locking up the library while I was still inside.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那可不尽然……之前我在图书馆看书看到很晚，结果没被发现就被锁在了里面……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那可不盡然……之前我在圖書館看書看到很晚，結果沒被發現就被鎖在了裡面……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00024",
		linknext = "0079_00026",
		line = 346,
	},
	["0079_00026"] = {
