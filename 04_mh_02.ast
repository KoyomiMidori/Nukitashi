				{"vo", file="misaki0510", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, you came here to eat your lunch. Um, I don't want to disturb you, so I'll just go vanish into the crowd...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，你是来吃饭的是吗？呃……那么为了不妨碍你，我就在角落里当个称职的路人吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，你是來吃飯的是嗎？呃……那麼為了不妨礙你，我就在角落當個稱職的路人吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00044",
		linknext = "0079_00046",
		line = 602,
	},
	["0079_00046"] = {
		{"se", id=0, loop=0, file="se_a056"},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=600},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=400},
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
