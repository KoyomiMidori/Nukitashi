			},
		},
		text = {
			vo = {
				{"vo", file="misaki0515", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, es que cada vez que se me ocurría algo así, no tenía a quien contárselo. Si dices que es detallada, estás elogiando mi capacidad para expresarme, jejeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，没有……像这样的比喻，我即使想到了也没有对象可以说……所以被说很生动，就好像我的表现力被夸奖了一样……诶嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，沒有……像這樣的比喻，我即使想到了也沒有對象可以說……所以被說很生動，就好像我的表現力被誇獎了一樣……欸嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00055",
		linknext = "0079_00057",
		line = 756,
	},
	["0079_00057"] = {
