		linkback = "0079_00197",
		linknext = "0079_00199",
		line = 2610,
	},
	["0079_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Alguien descubrió algo sobre Kotoyose Fumino? Cualquier pista, por más pequeña que sea, nos sirve.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“关于‘琴寄文乃’，有明白的事吗？再小的线索都没关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「關於『琴寄文乃』，有明白的事嗎？再小的線索都沒關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00198",
		linknext = "0079_00200",
		line = 2621,
	},
	["0079_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rompo el hielo y consigo que todas piensen. Estoy tranquilo, sereno y calmado. Tal y como debe ser un líder.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我就像个领导者带领着大家，酷酷地开场。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我就像個領導者帶領著大家，酷酷地開場。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00199",
