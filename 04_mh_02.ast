		linkback = "0079_00190",
		linknext = "0079_00192",
		line = 2524,
	},
	["0079_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't say I've ever had a girl sit next to me and start fapping while I'm eating lunch.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么说，一起吃午饭的女生在自己旁边自慰这种事我这辈子还真没体验过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼說，一起吃午飯的女生在自己旁邊自慰這種事我這輩子還真沒體驗過。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00191",
		linknext = "0079_00193",
		line = 2534,
	},
	["0079_00193"] = {
		{"text"},
		text = {
