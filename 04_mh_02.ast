	["0079_00185"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00128", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1931", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Qué pasa, Jun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……淳？你怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……淳？你怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00184",
		linknext = "0079_00186",
		line = 2449,
	},
	["0079_00186"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estoy pensando en algunas cosas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没事——稍微想了点事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒事——稍微想了點事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00185",
		linknext = "0079_00187",
		line = 2461,
	},
	["0079_00187"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1932", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Qué maravilla. ¿Quién eres y qué hiciste con nuestro Jun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……又在做自己不习惯的事。你明明是直觉型的，不觉得那样很稀奇吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……又在做自己不習慣的事。你明明是直覺型的，不覺得那樣很稀奇嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00186",
		linknext = "0079_00188",
		line = 2475,
	},
	["0079_00188"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
