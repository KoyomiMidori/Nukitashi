					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hotori. Siento que hablaremos mucho de ahora en adelante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔……今后你想说多少都没关系……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔……今後你想說多少都沒關係……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00056",
