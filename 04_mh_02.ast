		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=-12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm finding myself overly conscious of Hotori after what happened at lunch.",
					{"rt2"},
