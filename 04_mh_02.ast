		{"text"},
		delay = {
			[2500] = {
				{"fg", file="hinami_02m_00001", file3="hinami_02m_00302", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=600, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=200, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1953", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Circunstancias especiales? ¡Quizás le pasó algo como se comió esa pequeña seta azul con manchas blancas y se encogió!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“特殊情况……啊，她吃到不可思议的蘑菇变小了之类的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「特殊情況……啊，她吃到不可思議的蘑菇變小了之類的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00220",
		linknext = "0079_00222",
		line = 2910,
	},
	["0079_00222"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No lo decía por eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这比我预想的特殊情况还要更特殊呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這比我預想的特殊情況還要更特殊呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00221",
		linknext = "0079_00223",
		line = 2922,
	},
	["0079_00223"] = {
		{"fg", file="hinami_02m_00001", file3="hinami_02m_00303", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1936", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lo único que se me ocurre es que probablemente esté escondida y por eso desapareció, o que alguien la esté protegiendo. ¿Es eso lo que querías decir?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“马上浮现在脑中的，就是躲避着别人的目光生活，或者是被人藏了起来——大概就这些吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「馬上浮現在腦中的，就是躲避著別人的目光生活，或者是被人藏了起來——大概就這些吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00222",
		linknext = "0079_00224",
		line = 2938,
	},
	["0079_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Además...",
					{"rt2"},
				},
			},
			cn = {
				{
					"或者——",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者——",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00223",
		linknext = "0079_00225",
		line = 2948,
	},
	["0079_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los defensores de la ley súperpervertida deben saber que su existencia supone una amenaza. Es posible que ya la hayan capturado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果“文乃”是能够颠覆变态条例的存在——那可能是被条例的支持者给逮住，幽禁了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果「文乃」是能夠顛覆變態條例的存在——那可能是被條例的支持者給逮住，幽禁了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00224",
		linknext = "0079_00226",
		line = 2958,
	},
	["0079_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De ser así, encontrarla por medios normales sería imposible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如此一来，仅仅通过普通的寻找是不可能找到的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如此一來，僅僅通過普通的尋找是不可能找到的。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00225",
		linknext = "0079_00227",
		line = 2968,
	},
	["0079_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En fin, todavía no tenemos nada que pueda considerarse una pista.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之，到今天为止确实是一个线索也没有得到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之，到今天為止確實是一個線索也沒有得到。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00226",
		linknext = "0079_00228",
		line = 2978,
	},
	["0079_00228"] = {
