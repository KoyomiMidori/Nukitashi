			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, Tachibana-san, esto no tiene nada que ver, pero ¿puedo preguntarte otra cosa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个，橘同学……虽然是无关紧要的事，但我能问你一个问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個，橘同學……雖然是無關緊要的事，但我能問你一個問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00237",
		linknext = "0079_00239",
		line = 3147,
	},
	["0079_00239"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Mmm? Sí, dime.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00238",
		linknext = "0079_00240",
		line = 3159,
	},
	["0079_00240"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0560", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, esto... ¿Asane-chan me odia?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……我是不是……被麻沙音酱讨厌了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……我是不是……被麻沙音醬討厭了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00239",
		linknext = "0079_00241",
		line = 3173,
	},
	["0079_00241"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……啊——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……啊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00240",
		linknext = "0079_00242",
		line = 3185,
	},
	["0079_00242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es obvio que se daría cuenta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然畔也察觉到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然畔也察覺到了。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00241",
		linknext = "0079_00243",
		line = 3195,
	},
	["0079_00243"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sería difícil no darse cuenta con la mierda que le tira.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么明显的敌意，应该谁都能察觉到吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼明顯的敵意，應該誰都能察覺到吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00242",
		linknext = "0079_00244",
		line = 3205,
	},
	["0079_00244"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No sé si te odia, o si solo te está molestando...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“该说是讨厌还是仇视呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「該說是討厭還是仇視呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00243",
		linknext = "0079_00245",
		line = 3217,
	},
	["0079_00245"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0561", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ya veo, eso pensaba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这样啊。果然啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這樣啊。果然啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00244",
		linknext = "0079_00246",
		line = 3231,
	},
	["0079_00246"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo siento, sé que no lo hace a propósito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起……不过，麻沙酱应该也不是怀着什么恶意才这么做的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起……不過，麻沙醬應該也不是懷著什麼惡意才這麼做的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00245",
		linknext = "0079_00247",
		line = 3243,
	},
	["0079_00247"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, sí lo hace. ¿Por qué otra razón lo haría?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不对，应该超级有——或者说根本就只有恶意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不對，應該超級有——或者說根本就只有惡意。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00246",
		linknext = "0079_00248",
		line = 3253,
	},
	["0079_00248"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca desarrolló por completo lo que la mayoría llamaría 'empatía', y su forma de tratar a los demás es un poco instintiva. Es despiadada cuando detecta que algo hostil invade su territorio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱很有野性，一旦侵犯了她的地盘，她就会变得非常无情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬很有野性，一旦侵犯了她的地盤，她就會變得非常無情。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00247",
		linknext = "0079_00249",
		line = 3263,
	},
	["0079_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuando llegue a casa, vamos a tener que hablar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回去之后还是稍微强硬点说说她比较好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回去之後還是稍微強硬點說說她比較好。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00248",
		linknext = "0079_00250",
		line = 3273,
	},
	["0079_00250"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00107", file2="misaki_02m_00201", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0562", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Jeje...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呵呵……”",
					{"rt2"},
				},
			},
			tw = {
