	["0079_00204"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1934", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Qué esperabas? Si ayer no sabíamos nada, eso no va a cambiar de la noche a la mañana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过，事到如今情报也不会那么轻易就出现吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過，事到如今情報也不會那麼輕易就出現吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00203",
		linknext = "0079_00205",
		line = 2678,
	},
	["0079_00205"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1950", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Esto es malo. Sin ninguna pista, no podemos buscarla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是真伤脑筋。什么线索都没有的话，要找也没办法找吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是真傷腦筋。什麼線索都沒有的話，要找也沒辦法找吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00204",
		linknext = "0079_00206",
		line = 2690,
	},
	["0079_00206"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0550", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hay que ver. Quizás sí tengamos algunas pistas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不……也不一定。说不定，也不是完全没有线索吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不……也不一定。說不定，也不是完全沒有線索吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00205",
		linknext = "0079_00207",
		line = 2704,
	},
	["0079_00207"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cómo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00206",
		linknext = "0079_00208",
		line = 2716,
	},
	["0079_00208"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0551", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Esto, um... pregunté por ella en mi vecindario. Nadie sabía nada. Pero ¿no es un poco raro eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，那个……我向邻居们打听了文乃的事……结果大家都异口同声地说‘不知道’……但是这很奇怪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，那個……我向鄰居們打聽了文乃的事……結果大家都異口同聲地說『不知道』……但是這很奇怪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00207",
		linknext = "0079_00209",
		line = 2730,
	},
	["0079_00209"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0552", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“En mi vecindario viven personas mayores que conocen a todos los demás habitantes de la isla. Incluso sabían que Tachibana-san acababa de mudarse a la antigua casa de sus abuelos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我家附近有很多年长的人，只要是住在岛上的人，他们大概都知道。祖父母也知道最近才搬来的橘家……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我家附近有很多年長的人，只要是住在島上的人，他們大概都知道。祖父母也知道最近才搬來的橘家……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00208",
		linknext = "0079_00210",
		line = 2744,
	},
	["0079_00210"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0553", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿No es un poco raro que ninguno de ellos reconociera ese nombre?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“可是，却连一个人都不知道‘琴寄文乃’这个名字……这是不是有点不自然呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「可是，卻連一個人都不知道『琴寄文乃』這個名字……這是不是有點不自然呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00209",
		linknext = "0079_00211",
		line = 2758,
	},
	["0079_00211"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1951", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, es verdad. Ahora que lo mencionas, es extraño. ¡Sí, ya veo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……确实，想想就觉得奇怪……嗯，原来如此原来如此！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……確實，想想就覺得奇怪……嗯，原來如此原來如此！」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00210",
		linknext = "0079_00212",
		line = 2772,
	},
	["0079_00212"] = {
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00301", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0554", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡¿Verdad?! ¡Quizás Fumino sea más personaje secundario que yo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对吧！难道是文乃——比我还要没有存在感！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對吧！難道是文乃——比我還要沒有存在感！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00211",
