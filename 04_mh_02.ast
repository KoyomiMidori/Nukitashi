				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa is always trying to pick a fight with Hotori so I left her at home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为麻沙酱会乱咬畔，所以就让她留在家里了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為麻沙醬會亂咬畔，所以就讓她留在家裡了。",
