	},
	["0079_00207"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00206",
		linknext = "0079_00208",
		line = 2716,
	},
	["0079_00208"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0551", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I, um... I asked around my neighborhood about her. None of them knew anything. But isn't that kinda weird?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，那个……我向邻居们打听了文乃的事……结果大家都异口同声地说‘不知道’……但是这很奇怪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，那個……我向鄰居們打聽了文乃的事……結果大家都異口同聲地說『不知道』……但是這很奇怪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00207",
		linknext = "0079_00209",
		line = 2730,
	},
	["0079_00209"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0552", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“My neighborhood is mostly elderly people who know pretty much everyone else on the island. They even knew that Tachibana just moved back into his grandparents' old house.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我家附近有很多年长的人，只要是住在岛上的人，他们大概都知道。祖父母也知道最近才搬来的橘家……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我家附近有很多年長的人，只要是住在島上的人，他們大概都知道。祖父母也知道最近才搬來的橘家……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00208",
		linknext = "0079_00210",
		line = 2744,
	},
	["0079_00210"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0553", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Isn't it a bit unusual that none of them would even know the name?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“可是，却连一个人都不知道‘琴寄文乃’这个名字……这是不是有点不自然呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「可是，卻連一個人都不知道『琴寄文乃』這個名字……這是不是有點不自然呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00209",
		linknext = "0079_00211",
		line = 2758,
	},
	["0079_00211"] = {
