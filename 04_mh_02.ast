	["0079_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy un poco sorprendido, pero esta es una isla donde la gente tiene sexo pervertido por doquier.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然有点傻眼——但这是个到处都有人在实况直播做爱的岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然有點傻眼——但這是個到處都有人在實況直播做愛的島。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00134",
		linknext = "0079_00136",
		line = 1791,
	},
	["0079_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Habiendo crecido aquí, incluso alguien dócil como Hotori debió de verse influenciada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这样的环境中长大，即便是老实的畔，多少也会受到影响吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這樣的環境中長大，即便是老實的畔，多少也會受到影響吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00135",
		linknext = "0079_00137",
		line = 1801,
	},
	["0079_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parte de acabar con la ley súperpervertida será poner en su lugar esos valores aberrantes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在废除变态条例的过程中，如果也能顺便纠正这些错误的价值观就好了——",
