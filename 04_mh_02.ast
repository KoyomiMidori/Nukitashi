					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿Hotori?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是畔吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是畔嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00019",
		linknext = "0079_00021",
		line = 281,
	},
	["0079_00021"] = {
		{"bgm", file="bgm24", vol=100},
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00101", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0501", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, ¿Tachibana-san? Me asusaste. Pensé que era un fantasma.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哎呀……橘同学？什么啊……吓了我一跳。一瞬间以为是灵异现象……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哎呀……橘同學？什麼啊……嚇了我一跳。一瞬間以為是靈異現象……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00020",
		linknext = "0079_00022",
		line = 295,
	},
	["0079_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Perdón por asustarte. Pensé que el lugar estaba vacío.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思，我以为没人在……你吓了一跳吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思，我以為沒人在……你嚇了一跳吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00021",
		linknext = "0079_00023",
		line = 307,
	},
	["0079_00023"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0502", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, no te preoocupes. Es culpa mía por ser tan invisible que hasta me mezclo con el fondo en una habitación vacía. Me sorprende que sintieras mi presencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，不……是我太没存在感的错……话说你是怎么注意的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，不……是我太沒存在感的錯……話說你是怎麼注意的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00022",
		linknext = "0079_00024",
		line = 321,
	},
	["0079_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, es que no hay nadie, cualquiera te habría visto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果一个人呆在这种地方的话，任谁都会注意到的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果一個人待在這種地方的話，任誰都會注意到的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00023",
		linknext = "0079_00025",
		line = 332,
	},
	["0079_00025"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0503", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Eso crees, pero ni te lo imaginas. Hace poquito, estaba en la biblioteca leyendo un libro después de clases. Perdí la noción del tiempo y cerraron la puerta con llave mientras yo seguía ahí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那可不尽然……之前我在图书馆看书看到很晚，结果没被发现就被锁在了里面……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那可不盡然……之前我在圖書館看書看到很晚，結果沒被發現就被鎖在了裡面……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00024",
		linknext = "0079_00026",
		line = 346,
	},
	["0079_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio? ¿Y no te pasó nada?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有那种事……不要紧吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有那種事……不要緊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00025",
		linknext = "0079_00027",
		line = 358,
	},
	["0079_00027"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
