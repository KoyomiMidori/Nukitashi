		linkback = "0079_00218",
		linknext = "0079_00220",
		line = 2882,
	},
	["0079_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Given what we know so far about Fumino, it's worth assuming there's some kind of special circumstances around her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果说到目前都得不到‘文乃’的情报，那就应该认为她的情况较为特殊吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果說到目前都得不到『文乃』的情報，那就應該認為她的情況較為特殊吧？」",
					{"rt2"},
				},
