			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……又在做自己不习惯的事。你明明是直觉型的，不觉得那样很稀奇吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
