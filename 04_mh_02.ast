			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Tranquilo, la abrí por dentro y me fui.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，我从内侧开锁回家了。”",
