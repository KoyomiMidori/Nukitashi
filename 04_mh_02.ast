		linkback = "0079_00274",
		linknext = "0079_00276",
		line = 3604,
	},
	["0079_00276"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La realidad supera a la ficción.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但现实并没有那么美好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但現實並沒有那麼美好。",
					{"rt2"},
				},
