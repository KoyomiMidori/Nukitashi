			cn = {
				{
					name = {"美岬"},
					"“啊啊……真的在啪啪耶……而且是3P啊！好厉害……那么大的东西插了进去……嗯嗯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊啊……真的在啪啪耶……而且是3P啊！好厲害……那麼大的東西插了進去……嗯嗯！？」",
					{"rt2"},
				},
			},
		},
