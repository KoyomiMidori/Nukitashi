	["0079_00032"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fgact", ch="美岬", id=6, act="移動", x=0, y=100, time=600},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=400},
		{"text"},
