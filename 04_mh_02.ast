	},
	["0079_00223"] = {
		{"fg", file="hinami_02m_00001", file3="hinami_02m_00303", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1936", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“All I can think is that she's probably either in hiding completely off-the-grid, or someone's sheltering her. That what you meant?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“马上浮现在脑中的，就是躲避着别人的目光生活，或者是被人藏了起来——大概就这些吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「馬上浮現在腦中的，就是躲避著別人的目光生活，或者是被人藏了起來——大概就這些吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00222",
		linknext = "0079_00224",
		line = 2938,
	},
	["0079_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Alternatively...",
					{"rt2"},
				},
			},
			cn = {
				{
					"或者——",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者——",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00223",
		linknext = "0079_00225",
		line = 2948,
	},
	["0079_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The backers of the perverted sex law must know her existence poses a threat to its existence. It's possible they've already apprehended her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果“文乃”是能够颠覆变态条例的存在——那可能是被条例的支持者给逮住，幽禁了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果「文乃」是能夠顛覆變態條例的存在——那可能是被條例的支持者給逮住，幽禁了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00224",
		linknext = "0079_00226",
		line = 2958,
	},
	["0079_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If that were true, then finding her via normal means would be impossible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如此一来，仅仅通过普通的寻找是不可能找到的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如此一來，僅僅通過普通的尋找是不可能找到的。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00225",
		linknext = "0079_00227",
		line = 2968,
	},
	["0079_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In any case, we don't have anything that remotely constitutes a lead yet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之，到今天为止确实是一个线索也没有得到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之，到今天為止確實是一個線索也沒有得到。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00226",
		linknext = "0079_00228",
