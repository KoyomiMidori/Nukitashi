		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=-12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy mirando mucho a Hotori después de lo que pasó en el almuerzo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为白天那件事，让我莫名地意识到畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為白天那件事，讓我莫名地意識到畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00190",
		linknext = "0079_00192",
		line = 2524,
	},
	["0079_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca me había pasado que una chica empezara a masturbarse a mi lado mientras yo comía.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么说，一起吃午饭的女生在自己旁边自慰这种事我这辈子还真没体验过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼說，一起吃午飯的女生在自己旁邊自慰這種事我這輩子還真沒體驗過。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00191",
		linknext = "0079_00193",
		line = 2534,
	},
	["0079_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, no es algo que se pueda experimentar normalmente en ningún otro lugar que no sea aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不对，应该说我不该有这样的经验啊。",
