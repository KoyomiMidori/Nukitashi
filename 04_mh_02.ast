					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque ya que me acordé, debería comer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不过差不多该吃饭了。”",
