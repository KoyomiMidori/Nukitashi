			cn = {
				{
					name = {"美岬"},
					"“不……也不一定。说不定，也不是完全没有线索吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不……也不一定。說不定，也不是完全沒有線索吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00205",
		linknext = "0079_00207",
