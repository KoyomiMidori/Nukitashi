					"“Cállate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……别管我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……別管我。」",
					{"rt2"},
				},
