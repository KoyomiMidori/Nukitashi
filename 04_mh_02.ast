					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……啊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00240",
		linknext = "0079_00242",
		line = 3185,
	},
	["0079_00242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Naturally she'd also notice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然畔也察觉到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然畔也察覺到了。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00241",
		linknext = "0079_00243",
		line = 3195,
	},
	["0079_00243"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hell, it'd be hard not to with all the shit she gives her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么明显的敌意，应该谁都能察觉到吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼明顯的敵意，應該誰都能察覺到吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00242",
		linknext = "0079_00244",
		line = 3205,
	},
	["0079_00244"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't know if she actually hates you, or if she's just bullying you, or what.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“该说是讨厌还是仇视呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「該說是討厭還是仇視呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00243",
		linknext = "0079_00245",
		line = 3217,
	},
	["0079_00245"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0561", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I see. I thought so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这样啊。果然啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這樣啊。果然啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00244",
		linknext = "0079_00246",
		line = 3231,
	},
	["0079_00246"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry. I'm sure she's not trying to be mean.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起……不过，麻沙酱应该也不是怀着什么恶意才这么做的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起……不過，麻沙醬應該也不是懷著什麼惡意才這麼做的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00245",
		linknext = "0079_00247",
		line = 3243,
	},
	["0079_00247"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, she definitely is. Why else would she be doing it?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不对，应该超级有——或者说根本就只有恶意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不對，應該超級有——或者說根本就只有惡意。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00246",
		linknext = "0079_00248",
		line = 3253,
	},
	["0079_00248"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She never fully developed what most would call 'empathy', and her way of dealing with others is somewhat animalistic. She's ruthless when she detects something potentially hostile infringing on her turf.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱很有野性，一旦侵犯了她的地盘，她就会变得非常无情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬很有野性，一旦侵犯了她的地盤，她就會變得非常無情。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00247",
		linknext = "0079_00249",
		line = 3263,
	},
	["0079_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I get home, she's getting a stern talking-to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回去之后还是稍微强硬点说说她比较好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回去之後還是稍微強硬點說說她比較好。",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00248",
		linknext = "0079_00250",
		line = 3273,
	},
	["0079_00250"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00107", file2="misaki_02m_00201", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
