		linkback = "0079_00218",
		linknext = "0079_00220",
		line = 2882,
	},
	["0079_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Con lo que sabemos hasta ahora sobre Fumino, vale la pena suponer que la rodean circunstancias especiales.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果说到目前都得不到‘文乃’的情报，那就应该认为她的情况较为特殊吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
