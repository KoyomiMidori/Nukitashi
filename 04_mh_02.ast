				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, ¿seguro? ¿No te molesta perder tu valioso momento de almuerzo conmigo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个，真的可以吗……在宝贵的吃饭时间还和我在一起……”",
