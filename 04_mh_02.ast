			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, Wata-chan. Ten unos dulces.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，渡酱。你愿意的话请吃糖。”",
					{"rt2"},
				},
			},
			tw = {
