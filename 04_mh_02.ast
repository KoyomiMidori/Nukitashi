			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, viniste a comer. No quiero molestarte, así que voy a desaparecer entre la multitud...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，你是来吃饭的是吗？呃……那么为了不妨碍你，我就在角落里当个称职的路人吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，你是來吃飯的是嗎？呃……那麼為了不妨礙你，我就在角落當個稱職的路人吧。」",
					{"rt2"},
				},
			},
		},
