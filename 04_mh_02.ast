		text = {
			vo = {
				{"vo", file="misaki0512", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, are you sure? You don't mind wasting your precious meal time with me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个，真的可以吗……在宝贵的吃饭时间还和我在一起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個，真的可以嗎……在寶貴的吃飯時間還和我在一起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00048",
		linknext = "0079_00050",
		line = 664,
	},
	["0079_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why not? Food tastes better when eaten with company, after all. Didn't we eat together at my house once, too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别客气。一起吃会更好吃，之前我们不也一起围着桌子吃饭过吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別客氣。一起吃會更好吃，之前我們不也一起圍著桌子吃飯過嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00049",
		linknext = "0079_00051",
		line = 676,
	},
	["0079_00051"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0513", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, but everyone was there then, so I thought that you just invited me as a courtesy even though we're not really friends because you didn't want to deal with what would happen if I found out you all ate together without me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“可是那时大家都在……我还以为我是虽然关系不好但是在同一个部门，如果不叫我的话之后会尴尬所以才被叫过去的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「可是那時大家都在……我還以為我是雖然關係不好但是在同一個部門，如果不叫我的話之後會尷尬所以才被叫過去的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00050",
		linknext = "0079_00052",
		line = 690,
	},
