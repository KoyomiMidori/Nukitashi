	["0123_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels like Seiran Island has returned to its former tranquility.",
					{"rt2"},
				},
			},
			cn = {
				{
					"静谧的青蓝岛，仿佛取回了原本的安宁。",
