	["0123_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe they had to stop wearing those uniforms, now that the organization's been effectively dissolved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算制度消失了，有必要换制服吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算制度消失了，有必要換制服嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00023",
		linknext = "0123_00025",
		line = 286,
	},
	["0123_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then, my eyes are drawn to a large poster near the exit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我正这么想着，突然看到出入口贴着一张大大的海报。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我正這麼想著，突然看到出入口貼著一張大大的海報。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00024",
		linknext = "0123_00026",
		line = 296,
	},
	["0123_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Special Repatriation Program for Recipients of OSS Special Scholarship Award...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘以领取SHO特别奖学金者为对象的特别返乡计划’……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『以領取SHO特別獎學金者為對象的特別返鄉計劃』……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00025",
		linknext = "0123_00027",
		line = 308,
	},
	["0123_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I take a closer look at it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"概括一下其内容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"概括一下其內容。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00026",
		linknext = "0123_00028",
		line = 318,
	},
	["0123_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In short, it says that all individuals who received financial support from the OSS scholarship are going to be sent back to their families.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以SHO的金钱为目的而勉强成为SHO奖学生的学生为对象，将施行可以回到家人身边的特别措施。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以SHO的金錢為目的而勉強成為SHO獎學生的學生為對象，將施行可以回到家人身邊的特別措施。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00027",
		linknext = "0123_00029",
		line = 328,
	},
	["0123_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They're planning to start carrying it out tomorrow evening.",
					{"rt2"},
				},
			},
			cn = {
				{
					"时间是明晚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"時間是明晚。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00028",
		linknext = "0123_00030",
		line = 338,
	},
	["0123_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For the initial repatriation, priority is being given to the numerous students working in the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第一梯次，以完成了许多FS任务的人为对象优先回家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第一梯次，以完成了許多FS任務的人為對象優先回家。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00029",
		linknext = "0123_00031",
		line = 348,
	},
	["0123_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is applicable to all SS members, and only those who were born on the island will be allowed to stay voluntarily.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对象是所有的FS，只有在岛上出生的人才可以自由使用的权利——",
					{"rt2"},
				},
			},
			tw = {
				{
					"對象是所有的FS，只有在島上出生的人才可以自由使用的權利——",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00030",
		linknext = "0123_00032",
		line = 358,
	},
	["0123_00032"] = {
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2298", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“In other words, it's a sugarcoated deportation order.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……也就是说，这是说法比较好听的放逐。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……也就是說，這是說法比較好聽的放逐。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00031",
		linknext = "0123_00033",
		line = 373,
	},
	["0123_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase stands beside me looking at the poster and mutters to herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在旁边盯着海报看的奈奈濑自言自语道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在旁邊盯著海報看的奈奈瀨自言自語道。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00032",
		linknext = "0123_00034",
		line = 383,
	},
	["0123_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This amounts to a forced eviction for SS members who have no home on the island, or no family to return to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟，这无疑是要把岛上没有家、没有家人的FS强制驱逐出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟，這無疑是要把島上沒有家、沒有家人的FS強制驅逐出去。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00033",
		linknext = "0123_00035",
		line = 393,
	},
	["0123_00035"] = {
