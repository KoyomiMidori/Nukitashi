	["0123_00131"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2222", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Say something, Tachibana! Where's all your confidence gone!? Where's your plan to save her!? We need you right now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“说点话啊橘君……！像往常那样炒热气氛，耍帅地命令我们啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「說點話啊橘君……！像往常那樣炒熱氣氛，耍帥地命令我們啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00130",
		linknext = "0123_00132",
		line = 1661,
	},
	["0123_00132"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2101", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Is this really what you want? Are you going to just let the chips fall where they may, as long as the perverted sex law is gone?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这样下去行吗……！？难道你觉得这是因为变态条例崩坏了，所以没有办法吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這樣下去行嗎……！？難道你覺得這是因為變態條例崩壞了，所以沒有辦法嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00131",
		linknext = "0123_00133",
		line = 1675,
	},
	["0123_00133"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
