					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did you sell your car?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“车卖了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「車賣了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00065",
		linknext = "0123_00067",
		line = 835,
	},
	["0123_00067"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0275", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The media came looking for a scoop, so I tried paying them off with most of my own money. Turned out to be about as much use as tits on a bull, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“为了支付前来采访的媒体的贿赂金，我几乎吐出了所有的私人财产。虽然也是杯水车薪……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「為了支付前來採訪的媒體的賄賂金，我幾乎吐出了所有的私人財產。雖然也是杯水車薪……」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00066",
		linknext = "0123_00068",
		line = 849,
	},
	["0123_00068"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0276", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But it was still better than doing nothing. Those vultures hanging around the school apparently decided to let up after I did.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不过总比不做要好多了。多亏这些钱，他们也算放弃了继续围堵在学校周围。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不過總比不做要好多了。多虧這些錢，他們也算放棄了繼續圍堵在學校周圍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00067",
		linknext = "0123_00069",
		line = 863,
	},
	["0123_00069"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00068",
		linknext = "0123_00070",
		line = 875,
	},
	["0123_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have nothing to say.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我什么都说不出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我什麼都說不出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00069",
		linknext = "0123_00071",
		line = 885,
	},
	["0123_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have no bone to pick with him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对这个男人，我没有任何辩解可以说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對這個男人，我沒有任何辯解可以說。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00070",
		linknext = "0123_00072",
		line = 895,
	},
	["0123_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't plan to apologize for what happened to him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对于自己所做的事情，我不打算道歉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對於自己所做的事情，我不打算道歉。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00071",
		linknext = "0123_00073",
		line = 905,
	},
	["0123_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just can't give him any excuses.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是，也没法找借口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是，也沒法找藉口。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00072",
		linknext = "0123_00074",
		line = 915,
	},
	["0123_00074"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00115", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0277", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“In the end, all I made was a house of cards.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……反正，我创造出的不过只是个纸糊玩偶罢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……反正，我創造出的不過只是個紙糊玩偶罷了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00073",
		linknext = "0123_00075",
		line = 930,
	},
	["0123_00075"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00111", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He grimaces. He's more talking at me than to me right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有嘲笑我，仁浦先生露出苦涩的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有嘲笑我，仁浦先生露出苦澀的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00074",
		linknext = "0123_00076",
		line = 942,
	},
	["0123_00076"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0278", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I always knew my daughter would become the object of a scandal. Destroying the illegal sex industry had already led to a severe tarnishing of the island's name. And those bastards saw a big opportunity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我本来就知道我的女儿会成为丑闻的对象。而且原本就已经为了破坏地下风俗，而让岛上的恶评浮出水面了。因为这样，各个机关的眼睛都在发亮。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我本來就知道我的女兒會成為醜聞的對象。而且原本就已經為了破壞地下風俗，而讓島上的惡評浮出水面了。因為這樣，各個機關的眼睛都在發亮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00075",
		linknext = "0123_00077",
		line = 954,
	},
	["0123_00077"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0279", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It's just like you said; I wanted to get ahold of Fumino and lock her away, out of sight in some deep, dark place, until all of this blew over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……就像你说的那样，我本来打算得到文乃，然后把她关在一个不显眼的地方。直到事件沉淀下来，一直让她待在黑暗的地下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……就像你說的那樣，我本來打算得到文乃，然後把她關在一個不顯眼的地方。直到事件沉澱下來，一直讓她待在黑暗的地下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00076",
		linknext = "0123_00078",
		line = 966,
	},
	["0123_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He continues his one-sided monologuing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生近乎独白的喃喃自语还在继续。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生近乎獨白的喃喃自語還在繼續。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00077",
		linknext = "0123_00079",
		line = 976,
	},
	["0123_00079"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0280", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But as long as she was under your care, the stalemate held. Well, I didn't mind that so much. I figured if the world would get bored of keeping their eyes on us that way, then I could live with it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是只要你手上握有文乃，状况就会持续胶着下去。不过那也不错，那样至少能在某种程度上争取到让世间的关注度下降的时间，我是这么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是只要你手上握有文乃，狀況就會持續膠著下去。不過那也不錯，那樣至少能在某種程度上爭取到讓世間的關注度下降的時間，我是這麼想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00078",
		linknext = "0123_00080",
		line = 988,
	},
	["0123_00080"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0281", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But obviously, that state of affairs was never going to go on forever. My actions led to her disappearing for real.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是，那样的状况绝对不可能长久持续下去——我终于因为那个孩子，而认不清现实了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是，那樣的狀況絕對不可能長久持續下去——我終於因為那個孩子，而認不清現實了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00079",
		linknext = "0123_00081",
		line = 1002,
	},
	["0123_00081"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0282", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“In the end, you've gotten everything you wished for. Haven't you, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“结果，事情就如你预想的那样进展了，是吧少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「結果，事情就如你預想的那樣進展了，是吧少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00080",
		linknext = "0123_00082",
		line = 1016,
	},
	["0123_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00081",
		linknext = "0123_00083",
		line = 1028,
	},
	["0123_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So that's why he left us alone when he knew Fumino was with me...",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明知道文乃在我身边，却一直置之不理的理由——原来是这样吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明知道文乃在我身邊，卻一直置之不理的理由——原來是這樣嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00082",
		linknext = "0123_00084",
		line = 1038,
	},
	["0123_00084"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“An ignorant lout like me went and destroyed something you spent years managing to establish.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你没有怨恨我的意思吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你沒有怨恨我的意思嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00083",
		linknext = "0123_00085",
		line = 1050,
	},
	["0123_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't you harbor any hatred towards me now for that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对我这个协同他人破坏了你多年来建起的东西，并且无知的我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對我這個協同他人破壞了你多年來建起的東西，並且無知的我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00084",
		linknext = "0123_00086",
		line = 1062,
	},
	["0123_00086"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00116", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0283", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Why would I? We fought like men, and to the victor went the spoils. Whose right is it to complain?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“为什么？那是你通过男人之间的战斗，最后赢得的。谁有权抱怨呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「為什麼？那是你通過男人之間的戰鬥，最後贏得的。誰有權抱怨呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00085",
		linknext = "0123_00087",
		line = 1077,
	},
	["0123_00087"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0284", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Your desired ambition to destroy the perverted sex law was fulfilled. And I know that it did not lead to the future you wished for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你实现了夙愿，成功摧毁了变态条例——并且，我明白现在这个未来，不是你所期望的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你實現了夙願，成功摧毀了變態條例——並且，我明白現在這個未來，不是你所期望的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00086",
		linknext = "0123_00088",
		line = 1091,
	},
	["0123_00088"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0285", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The same has proven true for me. I created this island, and managed to produce a steady income stream, with hopes of creating my own sovereign nation someday. But the masses had their way; such is what comes of running out of money.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这对我来说也是一样的。创造了岛，创造了钱的流动，接下来还打算创造国家——但却败给了大众，没了钱就变成这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這對我來說也是一樣的。創造了島，創造了錢的流動，接下來還打算創造國家——但卻敗給了大眾，沒了錢就變成這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00087",
		linknext = "0123_00089",
		line = 1105,
	},
	["0123_00089"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0286", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I could not even protect my only daughter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……就连唯一的女儿，也没能保护好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……就連唯一的女兒，也沒能保護好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00088",
		linknext = "0123_00090",
		line = 1119,
	},
	["0123_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That one emotional comment reveals his true character.",
					{"rt2"},
				},
			},
			cn = {
				{
					"充满感慨的一句话中，隐藏着这个男人的个人简介。",
					{"rt2"},
				},
			},
			tw = {
				{
					"充滿感慨的一句話中，隱藏著這個男人的個人簡介。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00089",
		linknext = "0123_00091",
		line = 1129,
	},
	["0123_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In spite of his warped values, his inhumane ways, and how they were all linked to his objective.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论是扭曲的形式，非人道主义的形式，还是作为目的一环。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論是扭曲的形式，非人道主義的形式，還是作為目的一環。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00090",
		linknext = "0123_00092",
		line = 1139,
	},
	["0123_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never seen him act like a father before now— and it is plain to see that he is being completely truthful here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他第一次流露出的父亲的表情——那绝对不是谎言。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他第一次流露出的父親的表情——那絕對不是謊言。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00091",
		linknext = "0123_00093",
		line = 1149,
	},
	["0123_00093"] = {
		{"bgm", stop=1},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0287", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Experience repeated hardships, overcome numerous difficulties, and finally attain the fulfillment of your goals through your trials and tribulations.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“尝过多重辛酸，克服无数苦难，在辛苦艰难的尽头，成就圆满夙愿——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嚐過多重辛酸，克服無數苦難，在辛苦艱難的盡頭，成就圓滿夙願——」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00092",
		linknext = "0123_00094",
		line = 1164,
	},
	["0123_00094"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0288", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I do not intend to throw in the towel now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我不会就此放弃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我不會就此放棄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00093",
		linknext = "0123_00095",
		line = 1178,
	},
	["0123_00095"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0289", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I'm going to make a sovereign nation out of this island. Even if it means taking extreme, unsightly measures. The game's not over yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我要得到自己的国家。因此，再悲惨也要继续挣扎。战斗还没有结束。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我要得到自己的國家。因此，再悲慘也要繼續掙扎。戰鬥還沒有結束。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00094",
		linknext = "0123_00096",
		line = 1190,
	},
	["0123_00096"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00095",
		linknext = "0123_00097",
		line = 1202,
	},
	["0123_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And then, he looks directly into my eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生率直地凝视着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生率直地凝視著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00096",
		linknext = "0123_00098",
		line = 1212,
	},
	["0123_00098"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0290", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00097",
		linknext = "0123_00099",
		line = 1226,
	},
	["0123_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He calls me by name.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，叫了我的名字。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，叫了我的名字。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00098",
		linknext = "0123_00100",
		line = 1236,
	},
	["0123_00100"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0291", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“What are you going to do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00099",
		linknext = "0123_00101",
		line = 1248,
	},
	["0123_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As if to acknowledge me as another man.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像在认同一位男人一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像在認同一名男人一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00100",
		linknext = "0123_00102",
		line = 1258,
	},
	["0123_00102"] = {
		{"se", id=3, stop=1, time=1000},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, time=100, alphadel=1, lv=5},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=100},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_033_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For now, the base still has electricity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基地的电还通着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"基地的電還通著。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00101",
		linknext = "0123_00103",
		line = 1303,
	},
	["0123_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this dimly lit enclosed underground space now feels stagnant, stuffy, and more than anything, gloomy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是昏暗的地下室内，就像反映出没有在流通的空气一样，非常沉重。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是昏暗的地下室內，就像反映出沒有在流通的空氣一樣，非常沉重。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00102",
		linknext = "0123_00104",
		line = 1313,
	},
	["0123_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's still a constant barrage of pathetic quote-unquote 'journalism' about Seiran Island and Fumino being aired on TV.",
					{"rt2"},
				},
			},
			cn = {
				{
					"电视上还在滑稽地报道着青蓝岛和文乃的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"電視上還在滑稽地報導著青藍島和文乃的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00103",
		linknext = "0123_00105",
		line = 1323,
	},
	["0123_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's been a few days since the story first broke, but the unease in the air is still thick enough to cut with a knife.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明已经过了好几天，但话题却奇妙地一点都没有冷却下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明已經過了好幾天，但話題卻奇妙地一點都沒有冷卻下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00104",
		linknext = "0123_00106",
		line = 1333,
	},
	["0123_00106"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2299", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, if it wasn't clear before, it is now. This was Sakimori's plan from the start.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……这下很清楚了。防人老人的目的，从一开始就是这个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……這下很清楚了。防人老人的目的，從一開始就是這個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00105",
		linknext = "0123_00107",
		line = 1348,
	},
	["0123_00107"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2098", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“He played the illegal sex industry like a puppet from the shadows, allowing public order to deteriorate and crime to skyrocket.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“首先在幕后操纵地下风俗，让治安恶化还有犯罪率上升……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「首先在幕後操縱地下風俗，讓治安惡化還有犯罪率上升……」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00106",
		linknext = "0123_00108",
		line = 1361,
	},
	["0123_00108"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2220", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Then he purposely set the yakuza against the OSS, and used that to appeal to the world at large.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“然后，故意让黑社会和SHO战斗，展示给世人看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「然後，故意讓黑社會和SHO戰鬥，展示給世人看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00107",
		linknext = "0123_00109",
		line = 1374,
	},
	["0123_00109"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", file2="asane_01m_00202", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1784", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Finally, he got ahold of Fumino. With Seiran Island heavily weakened, he struck out and managed to cause the collapse of the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“最终得到文乃。通过对虚弱的青蓝岛发出的最后一击，使变态条例崩溃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「最終得到文乃。通過對虛弱的青藍島發出的最後一擊，使變態條例崩潰……」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00108",
		linknext = "0123_00110",
		line = 1387,
	},
	["0123_00110"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2300", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“He would have been fine with anyone. Any child that met his criteria would have sufficed... His own fucking granddaughter just happened to be the perfect test case!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对那个男人来说，不管谁都可以。只要是同样条件的孩子，谁都可以……只不过，那偶然是自己的外孙女……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對那個男人來說，不管誰都可以。只要是同樣條件的孩子，誰都可以……只不過，那偶然是自己的外孫女……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00109",
		linknext = "0123_00111",
		line = 1401,
	},
	["0123_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ultimately, Sakimori's true nature is that of a man who intensely despises Seiran Island— and he'll do anything to destroy it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"强烈怨恨青蓝岛，不选择手段的男人。这就是防人老人的真实身份。",
					{"rt2"},
				},
			},
			tw = {
				{
					"強烈怨恨青藍島，不選擇手段的男人。這就是防人老人的真實身份。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00110",
		linknext = "0123_00112",
		line = 1411,
	},
	["0123_00112"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2099", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So this... is what our main objective... led to all along...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这就是……我们所冀望的发展……的结局，这实在是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這就是……我們所冀望的發展……的結局，這實在是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00111",
		linknext = "0123_00113",
		line = 1425,
	},
	["0123_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The search for Fumino has shown no signs of slowing down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大众对文乃的渴望，还没有降温的迹象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大眾對文乃的渴望，還沒有降溫的跡象。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00112",
		linknext = "0123_00114",
		line = 1435,
	},
	["0123_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if the situation is resolved completely, the whole country will know who she is by then.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使事态平息了，大部分的国民也都知道文乃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使事態平息了，大部分的國民也都知道文乃了。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00113",
		linknext = "0123_00115",
		line = 1445,
	},
	["0123_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She'll never be able to live a normal life this way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从此以后，她想过上正常的生活，已经不可能了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從此以後，她想過上正常的生活，已經不可能了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00114",
		linknext = "0123_00116",
		line = 1455,
	},
	["0123_00116"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2301", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We can't let him get away with it! Can we? Tell me we can't, Jun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样的事情……怎么可以被允许……！对吧！难道不是吗，淳——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣的事情……怎麼可以被允許……！對吧！難道不是嗎，淳——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00115",
		linknext = "0123_00117",
		line = 1467,
	},
	["0123_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00116",
		linknext = "0123_00118",
		line = 1479,
	},
	["0123_00118"] = {
		{"se", id=0, loop=0, file="se_a154"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00125", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=100, ease="easeinout_sine"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=4, size=2.5, time=50, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Finally losing the last of her patience, Nanase pounds her fist on the table.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑也终于开始不耐烦地敲打桌子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨也終於開始不耐煩地敲打桌子。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00117",
		linknext = "0123_00119",
		line = 1494,
	},
	["0123_00119"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2302", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“True, this is exactly what we wanted! We finally achieved our goal of abolishing the perverted sex law! But we never signed up for any of this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这确实这是我们所希望的！摧毁变态条例的夙愿实现了！但不该是这样的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這確實這是我們所希望的！摧毀變態條例的夙願實現了！但不該是這樣的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00118",
		linknext = "0123_00120",
		line = 1508,
	},
	["0123_00120"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00129", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2303", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“All she wanted was to finally live a normal life! But now she'll be a pariah until the day she dies!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那个孩子只是想过上一般的生活哦！？结果，她却被这样推到世人面前——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那個孩子只是想過上一般的生活哦！？結果，她卻被這樣推到世人面前——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00119",
		linknext = "0123_00121",
		line = 1523,
	},
	["0123_00121"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00129", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2304", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“She had a choice, and it got taken away from her! Can you live with that on your conscience?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“被这样轻易夺走，然后你还无所作为吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「被這樣輕易奪走，然後你還無所作為嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00120",
		linknext = "0123_00122",
		line = 1538,
	},
	["0123_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What Fumino desired has been taken away from her for all eternity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃所向往的东西，永远失去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃所嚮往的東西，永遠失去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00121",
		linknext = "0123_00123",
		line = 1548,
	},
	["0123_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her one wish, simple and trivial as it was... Now it's forever out of her grasp.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像个少女的，天真的，真的很微不足道的愿望，已经永久——",
					{"rt2"},
				},
			},
			tw = {
				{
