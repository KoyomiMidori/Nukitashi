				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你——！让文乃遭受那么大的痛苦，还要这样冷眼旁观吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你——！讓文乃遭受那麼大的痛苦，還要這樣冷眼旁觀嗎！？」",
					{"rt2"},
				},
			},
		},
