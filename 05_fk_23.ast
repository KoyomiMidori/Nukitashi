		linkback = "0123_00040",
		linknext = "0123_00042",
		line = 508,
	},
	["0123_00042"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0037", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Ms. Minase"},
					"“Um, so... We'll be starting class now... in spite of the circumstances.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“呃、呃……那么开始上课……不过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「呃、呃……那麼開始上課……不過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00041",
		linknext = "0123_00043",
		line = 520,
	},
	["0123_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The teachers are no different. With society having judged their teachings to be inappropriate, they've lost all authority.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这对班主任来说也是一样，被告知自己教的内容在世间上是错误的，所以失去了立场。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這對班導來說也是一樣，被告知自己教的內容在世間上是錯誤的，所以失去了立場。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00042",
		linknext = "0123_00044",
		line = 530,
	},
	["0123_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Op-eds and chat shows have squarely laid the blame for everything at the doorstep of Seiran Island's educational system, so maybe they've cracked down on things even more as a result.",
					{"rt2"},
				},
			},
			cn = {
				{
					"新闻节目上指责青蓝岛的教育是万恶的根源，因此才让批判变得更加强烈吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"新聞節目上指責青藍島的教育是萬惡的根源，因此才讓批判變得更加強烈吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00043",
		linknext = "0123_00045",
		line = 540,
	},
	["0123_00045"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0038", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
