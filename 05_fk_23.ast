	["0123_00006"] = {
		{"se", id=1, stop=1, time=1000},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg05_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bgm", file="bgm22", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0092", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“This is Seiran Island, now at the center of the world's attention.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“在这里，青蓝岛引起了世人的关注。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「在這裡，青藍島引起了世人的關注。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00005",
		linknext = "0123_00007",
		line = 78,
	},
	["0123_00007"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0093", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“This peaceful island has played host to a massive prostitution problem. Often nicknamed the 'paradise of perversion', its massive problems have now come to light.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“发生在这个幽静的岛上的卖春问题。被称为变态天堂的乐园遇到了很大的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「發生在這個幽靜的島上的賣春問題。被稱為變態天堂的樂園遇到了很大的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00006",
		linknext = "0123_00008",
		line = 90,
	},
	["0123_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Countless reporters are using the scenery of the beach as their visual backdrop.",
					{"rt2"},
				},
			},
			cn = {
				{
					"背景的海滩就像画出来的一样，许多媒体蜂拥而至。",
					{"rt2"},
				},
			},
			tw = {
				{
					"背景的海灘就像畫出來的一樣，許多媒體蜂擁而至。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00007",
		linknext = "0123_00009",
		line = 100,
	},
	["0123_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There seem to be more of them every day, and their broadcasting vans are lining the back streets.",
					{"rt2"},
				},
			},
			cn = {
				{
					"数量每天都在增加，用于报道的车辆在后街等地排成一排。",
