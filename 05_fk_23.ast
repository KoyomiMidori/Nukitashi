	["0123_00127"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2221", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“If nobody else is gonna take action, then we have to, Tachibana! We gotta go save Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“谁都不做的话就只有我们能做啊橘君！去帮助文乃酱吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「誰都不做的話就只有我們能做啊橘君！去幫助文乃醬吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00126",
		linknext = "0123_00128",
		line = 1605,
	},
	["0123_00128"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="美岬", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2100", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We're the ones who got her into this mess! That means we have to get her out of it somehow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我们是让那个孩子承担这么大责任的其中一个原因！那么，就应该由我们设法解决——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我們是讓那個孩子承擔這麼大責任的其中一個原因！那麼，就應該由我們設法解決——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00127",
		linknext = "0123_00129",
		line = 1620,
	},
	["0123_00129"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1785", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Come on, Bro! We're the only ones who can save her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥……我们想想办法吧……！只有我们才能帮助文乃啊……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥……我們想想辦法吧……！只有我們才能幫助文乃啊……！！」",
					{"rt2"},
				},
			},
		},
