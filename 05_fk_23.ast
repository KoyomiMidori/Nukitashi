	["0123_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I still have nothing to say.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是我只是沉默着，什么也没说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是我只是沉默著，什麼也沒說。",
