		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg14_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm21", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Classes are still officially carrying on as normal, but there's a thick air of unease among the student body.",
					{"rt2"},
				},
			},
			cn = {
				{
					"上课是以和过往同样的形式进行，但学生们的动摇无法隐藏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"上課是以和過往同樣的形式進行，但學生們的動搖無法隱藏。",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00036",
		linknext = "0123_00038",
		line = 460,
	},
	["0123_00038"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmoba0088", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男A", "人の良さそうな男子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男A", "All-Around Great Guy"},
					"“So, what the hell's gonna happen to us now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男A", "好像人很好的男学生"},
					"“我说，这样下去我们会变成怎样呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男A", "好像人很好的男學生"},
					"「我說，這樣下去我們會變成怎樣呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00037",
		linknext = "0123_00039",
		line = 472,
	},
	["0123_00039"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="genki0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"元気で明るい女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"元気で明るい女子生徒", "Bright-and-Cheery Girl"},
					"“Yeah... W-We were only having fun and enjoying sex, we've never hurt anybody...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"元気で明るい女子生徒", "开朗有精神的女学生"},
					"“是啊……我们……明明只是开心地做了爱而已……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"元気で明るい女子生徒", "開朗有精神的女學生"},
					"「是啊……我們……明明只是開心地做了愛而已……」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00038",
		linknext = "0123_00040",
		line = 484,
	},
	["0123_00040"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hikkomi0018", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"引っ込み思案な女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"引っ込み思案な女子生徒", "Timid Female Student"},
					"“Hanamaru's been absent from school for a while, too... I'm really worried about her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"引っ込み思案な女子生徒", "消极的女学生"},
					"“花丸委员长也一直没来学校……将来到底会变成什么样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"引っ込み思案な女子生徒", "消極的女學生"},
					"「花丸委員長也一直沒來學校……將來到底會變成什麼樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00039",
		linknext = "0123_00041",
		line = 496,
	},
	["0123_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
