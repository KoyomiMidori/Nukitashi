	["0126_00248"] = {
		{"bgm", file="bgm27", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks at me with those unusual eyes and gives me a kind of heated gaze.",
					{"rt2"},
