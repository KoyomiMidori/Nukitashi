	["0126_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It must be something born out of my desire to make Fumino mine for the rest of my life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是来自想要一辈子，把文乃当成自己的东西的想法吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是來自想要一輩子，把文乃當成自己的東西的想法嗎？",
