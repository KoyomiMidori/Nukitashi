	},
	["0126_00199"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00123", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0326", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Wasn't yer original goal t'destroy the perverted sex law an' save that li'l twist? Ya already done that, last I checked.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你的目的应该是摧毁变态条例，还有帮助那个小鬼吧。那不是已经实现了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你的目的應該是摧毀變態條例，還有幫助那個小鬼吧。那不是已經實現了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00198",
		linknext = "0126_00200",
		line = 2757,
	},
	["0126_00200"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00199",
		linknext = "0126_00201",
		line = 2769,
	},
	["0126_00201"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0327", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“The body responds to what the will demands of it. If ya ain't got a strong enough will, there's no point in trainin' ya. S'what my own master taught me, at least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“肉体与精神是互相呼应的。如果没有强烈的愿望，无论怎样修行都没有意义。这是出自我师傅说过的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「肉體與精神是互相呼應的。如果沒有強烈的願望，無論怎樣修行都沒有意義。這是出自我師傅說過的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00200",
		linknext = "0126_00202",
		line = 2783,
	},
	["0126_00202"] = {
		{"se", id=0, loop=0, file="se_a204"},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00124", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0328", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I just manipulated people to get ridiculous authority and money on my side... an' look where that shit got me to, huh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我的情况是操纵他人，掌握巨大的权力和金钱——虽然现在这么不堪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我的情況是操縱他人，掌握巨大的權力和金錢——雖然現在這麼不堪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00201",
		linknext = "0126_00203",
		line = 2798,
	},
	["0126_00203"] = {
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His self-deprecating comment is punctuated by his bitter smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"呵了一声，手嶋露出自嘲的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"呵了一聲，手嶋露出自嘲的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00202",
		linknext = "0126_00204",
		line = 2809,
	},
	["0126_00204"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00123", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0329", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“A man's gotta know just how strong he needs to be. If he ain't got the conviction, or a big goal, he's never gonna be strong.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“如果没有强烈的愿望和信念，男人就绝对不会变强。因为他不知道自己需要什么力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「如果沒有強烈的願望和信念，男人就絕對不會變強。因為他不知道自己需要什麼力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00203",
		linknext = "0126_00205",
		line = 2823,
	},
	["0126_00205"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0330", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“So, Tachibana. How strong d'you wanna be, and to what end?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“橘……你是为了什么，想要什么样的力量？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「橘……你是為了什麼，想要什麼樣的力量？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00204",
		linknext = "0126_00206",
		line = 2837,
	},
	["0126_00206"] = {
		{"fg", mode=-1, id=8, ch="手嶋", lv=5, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He puts me on the spot.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不知道怎么回答。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不知道怎麼回答。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00205",
		linknext = "0126_00207",
		line = 2849,
	},
	["0126_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What is it that I want?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我所希望的……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我所希望的……",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00206",
		linknext = "0126_00208",
		line = 2859,
	},
	["0126_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And what sort of strength do I want?",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有，我想要的",
					{"ruby", text="事物"},
					"力量",
					{"/ruby"},
					"是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有，我想要的",
					{"ruby", text="事物"},
					"力量",
					{"/ruby"},
					"是——",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00207",
		linknext = "0126_00209",
		line = 2869,
	},
	["0126_00209"] = {
		{"bgm", stop=1},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00123", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=400, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0331", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Meet me here tomorrow morning, 8:15 sharp. Alone. I ain't got patience for people who can't keep an appointment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……明天早上来这里。8点15分。一个人来。我不会原谅违背约定的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「……明天早上來這裡。8點15分。一個人來。我不會原諒違背約定的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00208",
		linknext = "0126_00210",
		line = 2884,
	},
	["0126_00210"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You really will train me, then!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你愿意训练我了吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你願意訓練我了嗎……！？」",
					{"rt2"},
				},
			},
