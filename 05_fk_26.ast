		{"fg", file="fumino_01m_00003", file1="fumino_01m_00111", file2="fumino_01m_00204", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
