	["0126_00293"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She had no living relatives and had not experienced the touch of another person from a young age.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无依无靠的她，从小就没有接触过别人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無依無靠的她，從小就沒有接觸過別人。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00292",
		linknext = "0126_00294",
		line = 4061,
	},
	["0126_00294"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There must have been times she yearned for the warmth of another's touch.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一定会有想与他人接触的时候吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一定會有想與他人接觸的時候吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00293",
		linknext = "0126_00295",
		line = 4071,
	},
	["0126_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To entrust herself to someone else.",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该会想要敞开心房，把一切托付给对方，互相触碰吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"應該會想要敞開心房，把一切託付給對方，互相觸碰吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00294",
		linknext = "0126_00296",
		line = 4081,
	},
	["0126_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, as the strong woman she was, she thought it was perfectly normal to live her life alone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是坚强的她，一直认为那种孤独对自己来说是理所当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是堅強的她，一直認為那種孤獨對自己來說是理所當然的。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00295",
		linknext = "0126_00297",
		line = 4091,
	},
	["0126_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, humans are not creatures made to live alone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是，人是绝对无法一个人活下去的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是，人是絕對無法一個人活下去的。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00296",
		linknext = "0126_00298",
		line = 4101,
	},
	["0126_00298"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This complete isolation she experienced...",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为一直很孤独——",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為一直很孤獨——",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00297",
		linknext = "0126_00299",
		line = 4111,
	},
	["0126_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It must have led her to desire something she could deeply love.",
					{"rt2"},
				},
			},
			cn = {
				{
					"才会想要更强烈的爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"才會想要更強烈的愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00298",
		linknext = "0126_00300",
		line = 4121,
	},
	["0126_00300"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why she sought to bind herself with me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此，文乃才希望与我的结合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此，文乃才希望與我的結合。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00299",
		linknext = "0126_00301",
		line = 4131,
	},
	["0126_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry I kept you waiting so long...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，让你久等了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，讓你久等了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00300",
		linknext = "0126_00302",
		line = 4142,
	},
	["0126_00302"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In a sense, my obsession with purity forced me to put it off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，我的洁癖——在某种意义上却使她远离了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，我的潔癖——在某種意義上卻使她遠離了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00301",
		linknext = "0126_00303",
		line = 4152,
	},
	["0126_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even while I knew she was a girl of age, I failed to acknowledge her nobility.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明知道她是和自己年龄相符的少女，却受到她的高贵氛围影响而忽略了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明知道她是和自己年齡相符的少女，卻受到她的高貴氛圍影響而忽略了。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00302",
		linknext = "0126_00304",
		line = 4162,
	},
	["0126_00304"] = {
		{"text"},
		text = {
