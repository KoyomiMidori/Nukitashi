				{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine", delay2=6500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1796", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yo, Bro... I'm starving, so can you nuke some of Nanase's vittles in the microwave for me? Hm, I see Fumino's here too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呐哥哥～……肚子饿了去用微波炉热一下奈奈濑同学的料理给我吃～……呜，什么啊文乃，下来了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「吶哥哥～……肚子餓了去用微波爐熱一下奈奈瀨同學的料理給我吃～……嗚，什麼啊文乃，下來了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00024",
		linknext = "0126_00026",
		line = 318,
	},
	["0126_00026"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00110", file4="fumino_02m_00402", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1114", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes. I apologize for being such a bother, Asane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……还是跟之前一样打扰您了，麻沙音同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……還是跟之前一樣打擾您了，麻沙音同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00025",
		linknext = "0126_00027",
		line = 334,
	},
	["0126_00027"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00116", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1797", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You keep monopolizing my Bro over here. As his sister, I'm the one he's supposed to be looking after... You goddamn nymphet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“一直独占我的哥哥……被哥哥照顾明明是妹妹的特权……你这个萝莉狐狸精……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「一直獨占我的哥哥……被哥哥照顧明明是妹妹的特權……你這個蘿莉狐狸精……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00026",
		linknext = "0126_00028",
		line = 348,
	},
	["0126_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's injured, you little shit. Watch your tone. And as for me, I'm just being her nurse. It's completely wholesome.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你怎么可以这样说病人，这可是健全护理哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你怎麼可以這樣說病人，這可是健全護理哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00027",
		linknext = "0126_00029",
		line = 360,
	},
	["0126_00029"] = {
