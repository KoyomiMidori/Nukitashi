		text = {
			vo = {
				{"vo", file="misaki2120", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We dragged a lot of stuff here, didn't we... I'm all sweaty and parched now. Old Man Kenzou! Get us some barley tea, would you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“带来了好多行李呢。又热又渴的……健藏爷爷！麻烦给我们麦茶——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「帶來了好多行李呢。又熱又渴的……健藏爺爺！麻煩給我們麥茶——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00131",
		linknext = "0126_00133",
		line = 1864,
	},
	["0126_00133"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2121", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No answer... Maybe he's gone senile on us? I'm gonna go check on him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没有回复呢……已经老糊涂了吗……我去去就来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒有答覆呢……已經老糊塗了嗎……我去去就來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00132",
		linknext = "0126_00134",
		line = 1878,
	},
	["0126_00134"] = {
