		linkback = "0126_00304",
		linknext = "0126_00306",
		line = 4187,
	},
	["0126_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She rubs her cheek against me and I feel our souls embrace.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃一边将脸颊贴近，一边打从心底感受着拥抱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃一邊將臉頰貼近，一邊打從心底感受著擁抱。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00305",
		linknext = "0126_00307",
		line = 4197,
	},
	["0126_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It appears the euphoria has made her forget the pain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像是幸福的感受，已经让她忘掉了一切疼痛。",
