		linkback = "0126_00083",
		linknext = "0126_00085",
		line = 1145,
	},
	["0126_00085"] = {
		{"bgm", file="bgm12", vol=100},
		{"se", id=0, loop=0, file="se_b032"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After some static, an old man's face appears.",
					{"rt2"},
				},
			},
			cn = {
				{
					"杂讯之后，一个老人出现了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雜訊之後，一個老人出現了。",
					{"rt2"},
				},
