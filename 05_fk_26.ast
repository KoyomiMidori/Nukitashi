		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Some days later. The swelling in my hand subsided, and also...",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后过了几天，我的手终于消肿了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那之後過了幾天，我的手終於消腫了。",
					{"rt2"},
				},
			},
		},
		linknext = "0126_00002",
		line = 18,
	},
	["0126_00002"] = {
		{"bgm", file="bgm06", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, you doing all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃，感觉怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃，感覺怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00001",
		linknext = "0126_00003",
		line = 31,
	},
	["0126_00003"] = {
		{"bg", id=1, file="bg18_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00101", file4="fumino_02m_00402", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1110", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes. I am in fine form, thanks to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……托您的福，恢复得很好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……托您的福，恢復得很好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00002",
		linknext = "0126_00004",
		line = 46,
	},
	["0126_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino's been receiving medical attention at home, so she's been making a good recovery.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是在我家疗养的关系吧，文乃的身体正在慢慢好转。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是在我家療養的關係吧，文乃的身體正在慢慢好轉。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00003",
		linknext = "0126_00005",
		line = 56,
	},
	["0126_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When we first got her home, she was in a hell of a state.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……那时的她真的伤得很严重。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……那時的她真的傷得很嚴重。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00004",
		linknext = "0126_00006",
		line = 66,
	},
	["0126_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So we asked the back-alley doctor from the settlement to see to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时，我们带她去给村落里一位自称以前是",
					{"ruby", text="・・・・"},
					"地下医生",
					{"/ruby"},
					"的老人看诊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時，我們帶她去給村落裡一位自稱以前是",
					{"ruby", text="・・・・"},
					"地下醫生",
					{"/ruby"},
					"的老人看診。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00005",
		linknext = "0126_00007",
		line = 76,
	},
	["0126_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She'd suffered trauma in 13 places, three fractured bones, internal bleeding, bruises, numerous cuts, and was missing several toenails.",
					{"rt2"},
				},
			},
			cn = {
				{
					"13处淤青、3处割伤、内脏破损、多处擦伤，脚趾甲也不见了几块。",
					{"rt2"},
				},
			},
			tw = {
				{
					"13處淤青、3處割傷、內臟破損、多處擦傷，腳趾甲也不見了幾塊。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00006",
		linknext = "0126_00008",
		line = 86,
	},
	["0126_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They must have targeted her back and legs specifically to keep her from escaping... She still can't walk properly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是为了防止她逃跑吧……她的腰和腿都受了伤，现在也无法好好地走路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是為了防止她逃跑吧……她的腰和腿都受了傷，現在也無法好好地走路。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00007",
		linknext = "0126_00009",
		line = 96,
	},
	["0126_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Plus, she took especially serious wounds to the head, particularly some lacerations to the scalp that needed at least 10 stitches.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其中，以头部为中心的损伤尤其严重，头皮缝了10针以上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其中，以頭部為中心的損傷尤其嚴重，頭皮縫了10針以上。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00008",
		linknext = "0126_00010",
		line = 106,
	},
	["0126_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her cheeks were bruised, presumably from being punched directly in them. The swelling took quite some time to subside.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有被狠狠打过脸颊的疤痕，消肿也花了很长时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有被狠狠打過臉頰的疤痕，消腫也花了很長時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00009",
		linknext = "0126_00011",
		line = 116,
	},
	["0126_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a good thing we got her medical attention when we did. There are no traces of scars on her, and her complexion has regained its normal color.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是用心的治疗很有效果，现在她全身各处的淤青都不见了，脸色也完全恢复了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是用心的治療很有效果，現在她全身各處的淤青都不見了，臉色也完全恢復了。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00010",
		linknext = "0126_00012",
		line = 126,
	},
