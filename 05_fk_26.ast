				{
					name = {"奈々瀬", "Nanase"},
					"“Jun, look at this. It's that cardboard box Asa always used to nap on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳你看这个，麻沙酱睡过的纸箱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳你看這個，麻沙醬睡過的紙箱。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00074",
		linknext = "0126_00076",
		line = 1032,
	},
	["0126_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh... I think we nicked that from the OSS's delivery depot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……这么说来，这是从SHO的材料搬运所拿来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……這麼說來，這是從SHO的材料搬運所拿來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00075",
		linknext = "0126_00077",
		line = 1044,
	},
	["0126_00077"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2319", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, it must have been the first thing we brought when we started to set up shop here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是啊，来到基地之后，第一个放得好像就是这个吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是啊，來到基地之後，第一個放得好像就是這個吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00076",
		linknext = "0126_00078",
		line = 1058,
	},
	["0126_00078"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2320", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“This place was like our home away from home for quite a while, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……我们也在这里很长一段时间了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……我們也在這裡很長一段時間了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00077",
		linknext = "0126_00079",
		line = 1072,
	},
	["0126_00079"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, no kidding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，是啊——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，是啊——」",
					{"rt2"},
				},
			},
