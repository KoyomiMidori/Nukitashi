	["0126_00022"] = {
		{"se", id=0, loop=0, file="se_a001"},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just looking at her for the first few days after we rescued her was painful enough.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真的，最初的几天，光看着她都很于心不忍。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真的，最初的幾天，光看著她都很於心不忍。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00021",
		linknext = "0126_00023",
		line = 278,
	},
	["0126_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her fever was through the roof, and she couldn't even eat from all the wounds inside her mouth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"由于口腔内的伤口，她连饭都没吃好，还持续高烧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"由於口腔內的傷口，她連飯都沒吃好，還持續高燒。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00022",
		linknext = "0126_00024",
		line = 288,
	},
	["0126_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Watching her steadily getting better day by day makes me really happy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着她这样一天天好转，我非常开心。",
