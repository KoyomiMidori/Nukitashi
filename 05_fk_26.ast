	["0126_00234"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="fumino_02l_00000", file1="fumino_02l_00101", file4="fumino_02l_00402", path=":fg/fumino_02l/", id=7, lv=5, head="fumino_02l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's kind of a nice change of pace to see Fumino allow herself to depend on me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"照顾一个口令一个动作的文乃，让我有种新鲜的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"照顧一個口令一個動作的文乃，讓我有種新鮮的感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00233",
		linknext = "0126_00235",
		line = 3260,
	},
	["0126_00235"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg18_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm enjoying myself quite a bit. Though not just because of that, of course.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不是因为这样，但我非常开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不是因為這樣，但我非常開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00234",
		linknext = "0126_00236",
		line = 3276,
	},
	["0126_00236"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00111", file4="fumino_02m_00402", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1124", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I've been indebted to you for so long already... And yet here I am, still depending on you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“以前明明……都是我在照顾您……现在反过来了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「以前明明……都是我在照顧您……現在反過來了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00235",
		linknext = "0126_00237",
		line = 3290,
	},
	["0126_00237"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, nothing wrong with doing that every once in a while. Mi casa es su casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“偶尔像这样把衣食住交给别人也不错吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「偶爾像這樣把衣食住交給別人也不錯吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00236",
		linknext = "0126_00238",
		line = 3302,
	},
	["0126_00238"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00107", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="fumino_01m_00003", file1="fumino_01m_00114", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino1125", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes... I do not find it suffocating at all... Maybe because it's you doing it for me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……感觉很自然，也不会觉得难受……可能是因为，是淳之介同学吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……感覺很自然，也不會覺得難受……可能是因為，是淳之介同學吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00237",
		linknext = "0126_00239",
		line = 3318,
	},
	["0126_00239"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
