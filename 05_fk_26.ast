					name = {"文乃", "Fumino"},
					"“Please forgive me for being such a burden... Would you permit me the luxury of being in your care once again?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“给您添麻烦了，对不起……我……还可以在这里受照顾吗……？”",
					{"rt2"},
				},
			},
			tw = {
