	},
	["0126_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They start whaling on the couple with their nightsticks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"警棍尖锐的攻击向情侣袭去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"警棍尖銳的攻擊向情侶襲去。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00055",
		linknext = "0126_00057",
		line = 770,
	},
	["0126_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"These guards are equipped with weapons for riot suppression, under the pretense of maintaining public order.",
					{"rt2"},
				},
			},
			cn = {
				{
					"警备兵们以治安管理为名，被允许使用暴徒镇压用装备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"警備兵們以治安管理為名，被允許使用暴徒鎮壓用裝備。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00056",
		linknext = "0126_00058",
		line = 780,
	},
	["0126_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, their punishment doesn't fit the crime. It's grotesquely excessive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而这远远超过了目的，给予的制裁极为残酷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而這遠遠超過了目的，給予的制裁極為殘酷。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00057",
		linknext = "0126_00059",
		line = 790,
	},
	["0126_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I don't see society raising a fuss about that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是对于这件事，社会上没有批判的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是對於這件事，社會上沒有批判的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00058",
		linknext = "0126_00060",
		line = 800,
	},
	["0126_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though it's not surprising they aren't. After all, Seiran Island is seen as a hive of perverts and criminals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为青蓝岛是变态和罪犯的巢穴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為青藍島是變態和罪犯的巢穴。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00059",
		linknext = "0126_00061",
		line = 810,
	},
	["0126_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They're so deathly afraid of a tidal wave of sex and crime reaching the mainland that they sent these assholes in here, armed to the teeth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"民众害怕变态和犯罪入侵到本岛，所以允许了过度的武装。",
					{"rt2"},
				},
			},
			tw = {
				{
					"民眾害怕變態和犯罪入侵到本島，所以允許了過度的武裝。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00060",
		linknext = "0126_00062",
		line = 820,
	},
