		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0319", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You sure ya ain't askin' the wrong guy, slick? In case ya forgot, I used t' be yer enemy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你他妈……找错人了吧？我可是你曾经的敌人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你他媽……找錯人了吧？我可是你曾經的敵人啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00168",
		linknext = "0126_00170",
		line = 2377,
	},
	["0126_00170"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
