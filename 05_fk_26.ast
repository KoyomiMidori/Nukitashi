	["0126_00250"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00113", file2="fumino_02m_00204", file4="fumino_02m_00402", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
