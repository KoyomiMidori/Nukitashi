		{"bg", id=18, file="fhcg020102-1", x=-5, y=-5, path=":cg/fhcg02/", lv=5, ev=1, time=500, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1142", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No, I couldn't possibly be more blessed than this... I'm very fortunate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不，文乃——已经无比幸福了……我是个知恩图报的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不，文乃——已經無比幸福了……我是個知恩圖報的人……」",
