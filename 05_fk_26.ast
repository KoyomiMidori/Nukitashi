			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So you say... Who knows what your unfuckable pedo ass is doing every time you escort her to the bathroom, huh? Hmph!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“谁知道呢……因为萝莉控处男总是带着她走去洗澡或者去上厕所之类的谁知道在干什么……哼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「誰知道呢……因為蘿莉控處男總是帶著她走去洗澡或者去上廁所之類的誰知道在幹什麼……哼……」",
					{"rt2"},
				},
			},
