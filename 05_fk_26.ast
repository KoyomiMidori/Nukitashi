			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If you were to bestow that privilege upon me... I...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……如果您愿意赐予我的话……我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……如果您願意賜予我的話……我……」",
