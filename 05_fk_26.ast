				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We step out into the corridor and find the old codger lying face down on the floor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一走到走廊上，便看到健藏老人趴在地上低着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一走到走廊上，便看到健藏老人趴在地上低著頭。",
