		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0320", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Fuck off with that shit, Tachibana! Yer the architect behind me fuckin' downfall! Ya think I'd've ended up in this sorry-ass state if it weren't for you...!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“烦死了橘！！你是让我变成这样的罪魁祸首吧！！如果没有你，我也不会沦落到这个地步……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「煩死了橘！！你是讓我變成這樣的罪魁禍首吧！！如果沒有你，我也不會淪落到這個地步……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00170",
		linknext = "0126_00172",
		line = 2406,
	},
	["0126_00172"] = {
		{"text"},
		text = {
