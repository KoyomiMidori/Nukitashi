		linkback = "0126_00250",
		linknext = "0126_00252",
		line = 3491,
	},
	["0126_00252"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00112", file2="fumino_02m_00204", file4="fumino_02m_00402", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1130", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Um, do you recall... our conversation on that last day... about continuing where we left off... when we met again?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那个，最后一天说的——下次见面后，要继续接下来的事情……您还记得吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那個，最後一天說的——下次見面後，要繼續接下來的事情……您還記得嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00251",
		linknext = "0126_00253",
		line = 3505,
	},
	["0126_00253"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是當然的。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00252",
		linknext = "0126_00254",
		line = 3515,
	},
	["0126_00254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How could I possibly forget?",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那之后，我就不曾忘记过。",
