		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1113", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I can manage... You need not go so far for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
