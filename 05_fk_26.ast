	},
	["0126_00126"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0050", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Wh-What's with you kids!? What on earth're ya... wait, aren't you Katagiri Nanase!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“你、你们干什么啊！这到底是……呃，你是……片桐奈奈濑酱……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「你、你們幹什麼啊！這到底是……呃，你是……片桐奈奈瀨醬……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00125",
		linknext = "0126_00127",
