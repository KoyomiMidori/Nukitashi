		linkback = "0126_00311",
		linknext = "0126_00313",
		line = 4268,
	},
	["0126_00313"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
