			},
		},
		text = {
			vo = {
				{"vo", file="fumino1119", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I shall most graciously accept... Phew... Delicious. I would expect no less of her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“谢谢，我收下了……嗯——很好吃……不愧是奈奈濑同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「謝謝，我收下了……嗯——很好吃……不愧是奈奈瀨同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00223",
		linknext = "0126_00225",
		line = 3117,
	},
	["0126_00225"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She wanted me to tell you that she hopes you get well soon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑也很期待你的康复哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨也很期待你的康復哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00224",
		linknext = "0126_00226",
		line = 3129,
	},
	["0126_00226"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Plus, she'd still love to teach you Western-style cooking sometime, as long as you can teach her Japanese-style in return.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她说想要快点告诉你西餐的做法，然后让你教她日式料理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她說想要快點告訴你西餐的做法，然後讓你教她日式料理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00225",
		linknext = "0126_00227",
		line = 3141,
	},
