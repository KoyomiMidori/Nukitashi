	["0126_00064"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0141", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "警備兵B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Guard B"},
					"“Let me make one thing crystal clear! All sexual activity is forbidden on this island!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "警备兵B"},
					"“听好了，记好了……！这个岛上禁止一切性行为！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "警備兵B"},
					"「聽好了，記好了……！這個島上禁止一切性行為！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00063",
		linknext = "0126_00065",
		line = 862,
	},
	["0126_00065"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0142", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "警備兵B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Guard B"},
					"“Don't even think of performing procreational actions ever again! If you try to do it indoors, we will find you, and you will be dealt with accordingly! Fucking criminal scum!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "警备兵B"},
					"“不要再想在这里进行性产行为了！即使是在建筑物里我们也会查出来，然后进行制裁！你们这些犯罪者……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "警備兵B"},
					"「不要再想在這裡進行性產行為了！即使是在建築物裡我們也會查出來，然後進行制裁！你們這些犯罪者……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00064",
		linknext = "0126_00066",
		line = 874,
	},
	["0126_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nothing's more frightening than those who trample on others in the name of 'justice' to maintain public order.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再也没有比打着正义名号进行自治的人更可怕了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再也沒有比打著正義名號進行自治的人更可怕了。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00065",
		linknext = "0126_00067",
		line = 884,
	},
	["0126_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The island is now being run by a bunch of two-bit fascist thugs who firmly believe they're in the right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"认为自己代表正确的义勇兵们统治了这个岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"認為自己代表正確的義勇兵們統治了這個島。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00066",
