					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You've transformed yourself physically! You've strengthened your entire body, and you're an immensely strong fighter!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是改造了自己肉体的男人！是强化了全身，获得战斗能力的人类！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是改造了自己肉體的男人！是強化了全身，獲得戰鬥能力的人類！」",
					{"rt2"},
				},
