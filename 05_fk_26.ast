		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I slowly begin to move my hips, bringing us even closer together.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后为了更用力抱住她，我慢慢地动了动腰。",
					{"rt2"},
				},
			},
