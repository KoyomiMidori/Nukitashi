		{"evset", file="fhcg020106-1", set="fhcg02010", path=":ev/fhcg02010/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="fhcg020106-1", x=-5, y=-5, path=":cg/fhcg02/", lv=5, ev=1, time=500, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1143", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Am I allowed to... desire greater joy than this...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我……还可以继续期待吗……还可以比这样更幸福吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我……還可以繼續期待嗎……還可以比這樣更幸福嗎……？」",
