		line = 1932,
	},
	["0126_00137"] = {
		{"cgact", file="cgact", id=1, act="stopact"},
		{"fgact", id=6, ch="美岬", act="stopact"},
		{"bg", id=1, file="bg04_1l_00000", x=0, y=0, path=":bg/", sync=0, time=400, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00109", file2="misaki_01l_00202", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=400, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="浮遊", loop=1, size=2.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0052", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Oh, no, no, girl. I ain't too old t'go on livin' just yet. Sigh... Never thought Seiran Island would be goin' through a tough spot like this again, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“不是不是，我还没有那么老……唉……没想到青蓝岛又变得这么落魄了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「不是不是，我還沒有那麼老……唉……沒想到青藍島又變得這麼落魄了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00136",
		linknext = "0126_00138",
		line = 1949,
	},
	["0126_00138"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0053", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Our savior, Mr. Hitoura, the chap who made this whole island come alive, got forced outta office... 'Tis the end 'a days now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“领导我们的仁浦大人竟然倒台了……这个岛要完蛋了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「領導我們的仁浦大人竟然倒臺了……這個島要完蛋了……」",
					{"rt2"},
				},
			},
		},
