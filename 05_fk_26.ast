					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You hate to see it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总觉得有点悲伤啊……”",
					{"rt2"},
