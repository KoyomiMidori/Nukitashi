				{"fgact", ch="美岬", id=6, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2122", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“A-Are you okay!? Did you finally succumb to your chronic illness!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不、不要紧吧健藏爷爷……！？老毛病？还是寿命终于到了吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不、不要緊吧健藏爺爺……！？老毛病？還是壽命終於到了嗎……！？」",
					{"rt2"},
				},
			},
		},
