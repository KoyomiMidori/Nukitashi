	["0126_00223"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=2.5, time=250, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I brought dinner for you. Though Nanase gets the credit for cooking it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“晚饭我带来了。不过是奈奈濑做的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「晚飯我帶來了。不過是奈奈瀨做的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00222",
		linknext = "0126_00224",
		line = 3098,
	},
	["0126_00224"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00110", file4="fumino_02m_00402", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
