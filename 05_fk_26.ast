				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“不只是我……村里的老人们也都有同样的想法……如果又回到以前那个既没钱又没活力的岛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「不只是我……村裡的老人們也都有同樣的想法……如果又回到以前那個既沒錢又沒活力的島……」",
					{"rt2"},
				},
			},
		},
