		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0321", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Just what kinda fuckin' worm bored through yer brain to make ya wanna ask me this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……你到底在想些什么，才会来拜托我那种事情？”",
