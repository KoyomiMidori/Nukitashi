		},
		linkback = "0126_00084",
		linknext = "0126_00086",
		line = 1157,
	},
	["0126_00086"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0183", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What is your progress?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“——情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00085",
		linknext = "0126_00087",
		line = 1170,
	},
	["0126_00087"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0184", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Heh... As if there is any further need to ask that. Good to see you again, boy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“呵……已经没有必要问了呢……好久不见啊，小鬼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「呵……已經沒有必要問了呢……好久不見啊，小鬼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00086",
		linknext = "0126_00088",
		line = 1183,
	},
	["0126_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sakimori...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“防人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「防人——」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00087",
		linknext = "0126_00089",
		line = 1195,
	},
	["0126_00089"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0185", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I see that you managed to get home safely. You have my congratulations.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“看来你平安逃回家了啊。这事我要先夸奖你一下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「看來你平安逃回家了啊。這事我要先誇獎你一下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00088",
		linknext = "0126_00090",
		line = 1207,
	},
	["0126_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This condescending boomer fuck.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论什么时候，都一副高高在上的样子，这个老头——",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論什麼時候，都一副高高在上的樣子，這個老頭——",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00089",
		linknext = "0126_00091",
		line = 1217,
	},
	["0126_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I find myself recalling when we first found her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想起发现那个孩子时的情景。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想起發現那個孩子時的情景。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00090",
		linknext = "0126_00092",
		line = 1227,
	},
	["0126_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can sense the anger welling up within me but manage to keep it in check.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自觉愤怒涌上心头的我，试图克制住情绪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自覺憤怒湧上心頭的我，試圖克制住情緒。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00091",
		linknext = "0126_00093",
		line = 1237,
	},
	["0126_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no point getting angry now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这里发怒也没有意义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這裡發怒也沒有意義。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00092",
		linknext = "0126_00094",
		line = 1247,
	},
	["0126_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's what he'd want.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为那才是老人希望看到的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為那才是老人希望看到的——",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00093",
		linknext = "0126_00095",
		line = 1257,
	},
	["0126_00095"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00110", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0186", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Oh? Not getting angry, I see. I figured you would let your grudge show openly here, but your restraint is nothing if not admirable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“哦，居然没有发怒……我以为你已经恨之入骨了，看来你的克制力还不错呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「哦，居然沒有發怒……我以為你已經恨之入骨了，看來你的克制力還不錯呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00094",
		linknext = "0126_00096",
		line = 1270,
	},
	["0126_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not interested in talking to a monitor. Especially not if the man on the other side is too cowardly to meet me face-to-face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有人会一天到晚只知道对着电视讲话吗？你这个连亲自面对我们都不敢的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有人會一天到晚只知道對著電視講話嗎？你這個連親自面對我們都不敢的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00095",
		linknext = "0126_00097",
		line = 1282,
	},
	["0126_00097"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0187", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“An admirable riposte. However, I am not here to play games with you. I have a just cause.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“挺会说的嘛。但我的目的不是和你们玩耍。是为了大义——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「挺會說的嘛。但我的目的不是和你們玩耍。是為了大義——」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00096",
		linknext = "0126_00098",
		line = 1294,
	},
	["0126_00098"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see. So everything that's happened is down to this just cause of yours, little man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大义的结果就是现在这样吗？胸襟狭隘的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大義的結果就是現在這樣嗎？胸襟狹隘的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00097",
		linknext = "0126_00099",
		line = 1306,
	},
	["0126_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shutting down Seiran Island, putting the screws on it economically, driving the unemployment rate through the roof— is this your way of taking revenge?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“摧毁青蓝岛，制裁经济，造成大量的失业者，这就是你的复仇是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「摧毀青藍島，制裁經濟，造成大量的失業者，這就是你的復仇是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00098",
		linknext = "0126_00100",
		line = 1317,
	},
	["0126_00100"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0188", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Naturally. Such is this old man's greatest desire. To destroy the law, as revenge towards Hitoura for laying his filthy hands on my beloved daughter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“没错。那就是老子的夙愿。是对让我最心爱的女儿怀上孩子的仁浦的复仇，还有摧毁其原因的条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「沒錯。那就是老子的夙願。是對讓我最心愛的女兒懷上孩子的仁浦的復仇，還有摧毀其原因的條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00099",
		linknext = "0126_00101",
		line = 1329,
	},
	["0126_00101"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0189", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“And if I'm not mistaken... that was what you wished for, was it not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“而且——小鬼，这些不也是你的夙愿吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「而且——小鬼，這些不也是你的夙願嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00100",
		linknext = "0126_00102",
		line = 1341,
	},
	["0126_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you think making your own granddaughter into a public pariah is just the means to that end? She's not going to be able to live a normal life anymore!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……为了这个目的，就算让自己的外孙女曝光在世人面前也没差是吗？害她无法过上正常的生活……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……為了這個目的，就算讓自己的外孫女曝光在世人面前也沒差是嗎？害她無法過上正常的生活……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00101",
		linknext = "0126_00103",
		line = 1353,
	},
	["0126_00103"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0190", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What about her? She's naught but the offspring of that abominable man. I care not one jot for what happens to her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“那又怎样？反正是继承了那个可恨男人血统的小女孩，不管怎样都无所谓。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「那又怎樣？反正是繼承了那個可恨男人血統的小女孩，不管怎樣都無所謂。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00102",
		linknext = "0126_00104",
		line = 1366,
	},
	["0126_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that's why you hurt her so badly, then! How was it, huh? Did you get your jollies torturing her like that, you sick fuck!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你才伤害她到那种程度吗——！单方面的虐待让你很满足是吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你才傷害她到那種程度嗎——！單方面的虐待讓你很滿足是嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00103",
		linknext = "0126_00105",
		line = 1378,
	},
	["0126_00105"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00110", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0191", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“It was not my intent to be sadistic with her, but... hm. She turned out to be quite a lovely dish, I would say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“虽然我不是个有嗜虐倾向的人——嗯，不过确实是个愉快的体验，你不这么觉得吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「雖然我不是個有嗜虐傾向的人——嗯，不過確實是個愉快的體驗，你不這麼覺得嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00104",
		linknext = "0126_00106",
		line = 1391,
	},
	["0126_00106"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, that settles it. You're so fucking dead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我懂了——我不会原谅你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我懂了——我不會原諒你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00105",
		linknext = "0126_00107",
		line = 1403,
	},
	["0126_00107"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You deserve to experience the pain you've inflicted on her a hundred times over. Mark my words, asshole... I'm going to fucking kill you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我一定要杀了你。也要让你尝尝那孩子尝到的痛苦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我一定要殺了你。也要讓你嚐嚐那孩子嚐到的痛苦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00106",
		linknext = "0126_00108",
		line = 1415,
	},
	["0126_00108"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0192", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Go ahead and try. You need to be taught your place nevertheless. I shall be taking her back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“试试看吧，反正我终归是要给你个教训。把外孙女还给我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「試試看吧，反正我終歸是要給你個教訓。把外孫女還給我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00107",
		linknext = "0126_00109",
		line = 1428,
	},
	["0126_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino's part of our family now. She's got nowhere else to go back to but our home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃是我们家的孩子。她该呆的地方，就只有我们家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃是我們家的孩子。她該待的地方，就只有我們家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00108",
		linknext = "0126_00110",
		line = 1440,
	},
	["0126_00110"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00110", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0193", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Do what you will, then. The chips are down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“那就随你便吧……你可不要后悔了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「那就隨你便吧……你可不要後悔了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00109",
		linknext = "0126_00111",
		line = 1453,
	},
	["0126_00111"] = {
		{"se", id=0, loop=0, file="se_b032"},
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With that final remark, the very last transmission we will ever receive in this base is cut off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"留下这句话，最后的基地通讯就结束了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"留下這句話，最後的基地通訊就結束了。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00110",
		linknext = "0126_00112",
		line = 1465,
	},
	["0126_00112"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", mode=-1, id=30, ch="防人老人", lv=5},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_033_00000"},
		{"se", id=0, loop=0, file="se_a018"},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=200, y=0, time=700},
		{"bgm", file="bgm02", vol=100},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami2260", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Upsie-daisy... So Jun, where do we set up shop now? Your place, I'm guessing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嘿咻……那么淳君，接下来要去哪里？果然还是淳君家吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嘿咻……那麼淳君，接下來要去哪裡？果然還是淳君家嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00111",
		linknext = "0126_00113",
		line = 1517,
	},
	["0126_00113"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, Fumino's laying low there right now. I figure we ought to find somewhere else, just to diffuse the risk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为文乃就在那里。虽然如果考虑到分散风险，别的地方也不错——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為文乃就在那裡。雖然如果考慮到分散風險，別的地方也不錯——」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00112",
		linknext = "0126_00114",
		line = 1529,
	},
	["0126_00114"] = {
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2115", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, then how about coming to our settlement? It's deep in the mountains and guards hardly ever go there. Right, August?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，那要不要到我们村子来？那里可是深山里，警备兵也很少来。对吧，Orgast酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，那要不要到我們村子來？那裡可是深山裡，警備兵也很少來。對吧，Orgast醬！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00113",
		linknext = "0126_00115",
		line = 1544,
	},
	["0126_00115"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="august0031", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“Precisely. You're right on the mark there, Master.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "Orgast"},
					"“没错。正如你所说，主人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "Orgast"},
					"「沒錯。正如你所說，主人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00114",
		linknext = "0126_00116",
		line = 1556,
	},
	["0126_00116"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1802", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh God, she's over here chatting with software that only gives canned responses...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哇，这个人在和只有定型文的软件讲话诶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哇，這個人在和只有定型文的軟體講話欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00115",
		linknext = "0126_00117",
		line = 1569,
	},
	["0126_00117"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00127", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2116", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“She's the only one who'll hear me out for everything I have to say... She's like my only friend, heh heh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“只有Orgast酱会好好听我说话……是我唯一的朋友哦，嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「只有Orgast醬會好好聽我說話……是我唯一的朋友哦，嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00116",
		linknext = "0126_00118",
		line = 1584,
	},
	["0126_00118"] = {
