	},
	["0126_00127"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=700},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=-600, y=0},
				{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine", delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2322", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uh, yes... Hi. Sorry for dropping in so suddenly like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊，是的……抱歉突然来打扰你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊，是的……抱歉突然來打擾你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00126",
		linknext = "0126_00128",
		line = 1764,
	},
	["0126_00128"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0051", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“N-Not at all! S'nothin' but th'greatest honor t'have the legendary preppy slut Nanase gracin' me abode with 'er presence! Come on in, sorry 'bout the mess... heh heh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“不、不不不！那个著名的辣妹婊奈奈濑酱能来我家实在是太高兴了！虽然家里很脏不过请进请进……诶嘿嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「不、不不不！那個著名的辣妹婊奈奈瀨醬能來我家實在是太高興了！雖然家裡很髒不過請進請進……欸嘿嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00127",
		linknext = "0126_00129",
		line = 1776,
	},
	["0126_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So even the old folks know you as that famous slut, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你是那种连老人都俘虏了的婊子吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你是那種連老人都俘虜了的婊子嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00128",
		linknext = "0126_00130",
		line = 1788,
	},
	["0126_00130"] = {
