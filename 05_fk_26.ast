		linkback = "0126_00078",
		linknext = "0126_00080",
		line = 1084,
	},
	["0126_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Staring around the base, we both feel oddly wistful.",
					{"rt2"},
				},
			},
			cn = {
				{
					"抱着奇妙的感慨，两人望着室内。",
					{"rt2"},
				},
			},
			tw = {
				{
					"抱著奇妙的感慨，兩人望著室內。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00079",
		linknext = "0126_00081",
		line = 1094,
	},
	["0126_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This was where it all began.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一切，都是从找到这里才开始的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一切，都是從找到這裡才開始的。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00080",
		linknext = "0126_00082",
		line = 1104,
	},
	["0126_00082"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Stumbling into this base was the catalyst for everything that's happened up until now...",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为发现了基地，才有了之后的一切——",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為發現了基地，才有了之後的一切——",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00081",
		linknext = "0126_00083",
		line = 1115,
	},
	["0126_00083"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a190"},
		{"ex", time=1000, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
