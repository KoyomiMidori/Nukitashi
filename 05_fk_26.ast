					"I was ostracized as a kid for it. It left deep emotional scars on me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为它，我被排斥在外，从小就受到了很深的伤害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為它，我被排斥在外，從小就受到了很深的傷害。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00428",
		linknext = "0126_00430",
		line = 5722,
	},
	["0126_00430"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So it's always been the source of an overwhelming inferiority complex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以才会形成强烈的自卑感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以才會形成強烈的自卑感。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00429",
		linknext = "0126_00431",
		line = 5732,
	},
	["0126_00431"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I wasn't so reluctant to show you this large penis of mine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是对文乃露出巨根这件事，我却不怎么感到抗拒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是對文乃露出巨根這件事，我卻不怎麼感到抗拒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00430",
		linknext = "0126_00432",
		line = 5744,
	},
	["0126_00432"] = {
		{"fg", file="fumino_02m_00000", file1="fumino_02m_00114", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=450, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1182", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I wonder... why that is?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那是……为什么呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那是……為什麼呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00431",
		linknext = "0126_00433",
		line = 5759,
	},
	["0126_00433"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Maybe it's because... I trust you from the bottom of my heart.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也许……是因为打从心底信任文乃也说不定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也許……是因為打從心底信任文乃也說不定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00432",
		linknext = "0126_00434",
		line = 5771,
	},
	["0126_00434"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I believe you'd never betray me, even if I laid open everything bare to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果是你，我一切都可以给你看——就算我把一切都摊开在你面前，你也绝对不会背叛我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果是你，我一切都可以給你看——就算我把一切都攤開在你面前，你也絕對不會背叛我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00433",
		linknext = "0126_00435",
		line = 5782,
	},
	["0126_00435"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Perhaps I believe that you'd accept come what may from me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我相信只有文乃，能接受我的一切……应该是因为这样吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我相信只有文乃，能接受我的一切……應該是因為這樣吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00434",
		linknext = "0126_00436",
		line = 5794,
	},
	["0126_00436"] = {
		{"fg", file="fumino_01m_00000", file1="fumino_01m_00110", file2="fumino_01m_00201", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1183", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00435",
		linknext = "0126_00437",
		line = 5808,
	},
	["0126_00437"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The puppy lying beside me puts her paw on my elbow.",
					{"rt2"},
				},
			},
			cn = {
				{
					"身旁的小狗轻轻靠在我的手肘上，",
					{"rt2"},
				},
			},
			tw = {
				{
					"身旁的小狗輕輕靠在我的手肘上，",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00436",
		linknext = "0126_00438",
		line = 5821,
	},
	["0126_00438"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It silently conveys how happy she is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像在默默地传达高兴的情绪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像在默默地傳達高興的情緒。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00437",
		linknext = "0126_00439",
		line = 5831,
	},
	["0126_00439"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel the small warm presence beside me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那小小的存在，让我感到温暖。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那小小的存在，讓我感到溫暖。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00438",
		linknext = "0126_00440",
		line = 5841,
	},
	["0126_00440"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a very soothing calm moment. It feels like my whole life's happiness is packed into this moment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"令人无比放松的平静时间。就像人生中的幸福都集中在了这个瞬间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"令人無比放鬆的平靜時間。就像人生中的幸福都集中在了這個瞬間。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00439",
		linknext = "0126_00441",
		line = 5851,
	},
	["0126_00441"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, Fumino... You've really gone through hell for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……抱歉了文乃，变成这种情况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……抱歉了文乃，變成這種情況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00440",
		linknext = "0126_00442",
		line = 5864,
	},
	["0126_00442"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It makes reality all the more obvious.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此，现实才会特别令人在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此，現實才會特別令人在意。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00441",
		linknext = "0126_00443",
		line = 5874,
	},
	["0126_00443"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She lost her mother, her father was an evil villain, and she was used as a tragic heroine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这名少女失去了母亲，父亲成了坏人，然后自己被当成悲剧的女主人公。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這名少女失去了母親，父親成了壞人，然後自己被當成悲劇的女主角。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00442",
		linknext = "0126_00444",
		line = 5884,
	},
	["0126_00444"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her face became known around the world, her past was invaded, and she lost virtually all hope for a future.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被世人知道了长相，过去被搞得乱七八糟，几乎失去了所有的未来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被世人知道了長相，過去被搞得亂七八糟，幾乎失去了所有的未來。",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00443",
		linknext = "0126_00445",
		line = 5894,
	},
	["0126_00445"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I hadn't sold you out to that old asshole, you wouldn't have—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我如果没送你去老人那里，就不会发生这种——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我如果沒送你去老人那裡，就不會發生這種——」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00444",
		linknext = "0126_00446",
		line = 5905,
	},
	["0126_00446"] = {
		{"bgm", file="bgm27", vol=100},
		{"fg", file="fumino_01m_00000", file1="fumino_01m_00107", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1184", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I do not think so. All this has allowed me to be with you... and to be bound with you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不是那样的……现在……我能一直陪在淳之介同学身边……然后可以合为一体……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不是那樣的……現在……我能一直陪在淳之介同學身邊……然後可以合為一體……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00445",
		linknext = "0126_00447",
		line = 5920,
	},
	["0126_00447"] = {
		{"fg", file="fumino_02m_00000", file1="fumino_02m_00107", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1185", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You have made me feel that I am no longer alone...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“已经——不是一个人了，我能感受到这一切……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「已經——不是一個人了，我能感受到這一切……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00446",
		linknext = "0126_00448",
		line = 5934,
	},
	["0126_00448"] = {
		{"fg", file="fumino_02m_00000", file1="fumino_02m_00126", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1186", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“There is nothing... that could make me happier.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“对文乃来说……没有比这更幸福的事了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「對文乃來說……沒有比這更幸福的事了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00447",
		linknext = "0126_00449",
		line = 5948,
	},
	["0126_00449"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1187", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“As long as I can be with you, I will follow you anywhere... By your side is where I am meant to be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“只要和你您一起……我在任何地方都一样……淳之介同学的身旁，就是我的容身之处……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「只要和你您一起……我在任何地方都一樣……淳之介同學的身旁，就是我的容身之處……」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00448",
		linknext = "0126_00450",
		line = 5960,
	},
	["0126_00450"] = {
		{"fg", file="fumino_02m_00000", file1="fumino_02m_00126", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1188", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
