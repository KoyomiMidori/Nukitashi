		{"extrans", sync=0, time=400, rule="eff_032_00000"},
		{"se", id=0, loop=0, file="se_a091"},
		{"ex", time=1000, func="wait"},
		{"bg", id=1, file="bg10_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2118", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Old Man Kenzou! You're home, right? I know you are! Old people don't have anything better to do!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“健蔵爷爷！在吗——？在呢——！毕竟老人很闲嘛——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「健蔵爺爺！在嗎——？在呢——！畢竟老人很閒嘛——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00121",
		linknext = "0126_00123",
		line = 1690,
	},
	["0126_00123"] = {
		{"bgm", file="bgm08", vol=100},
		{"se", id=0, loop=0, file="se_a081"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0049", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“What's all this racket out 'ere? Let a man drown in 'is solitude, will ya... Oh, well, if it ain't Misaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“在吵什么……我正在严肃地哀悼呢……什么啊是美岬酱吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「在吵什麼……我正在嚴肅地哀悼呢……什麼啊是美岬醬嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00122",
		linknext = "0126_00124",
		line = 1704,
	},
	["0126_00124"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2119", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“This house is more than big enough, plus it's got constant electricity, and it's not too far from the school, either!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这个房子又大又通着电，离学校也没有那么远！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這個房子又大又通著電，離學校也沒有那麼遠！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00123",
		linknext = "0126_00125",
		line = 1718,
	},
	["0126_00125"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=800, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
