		linkback = "0126_00209",
		linknext = "0126_00211",
		line = 2896,
	},
	["0126_00211"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00114", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0332", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Don't get the wrong idea! I'm just tryin' to get me own revenge on that senile old fuck. Yer nowt but th' means to me end.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“别误会了……！我只是想对防人死老头复仇。为此，我要利用你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「別誤會了……！我只是想對防人死老頭復仇。為此，我要利用你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00210",
		linknext = "0126_00212",
		line = 2911,
	},
	["0126_00212"] = {
