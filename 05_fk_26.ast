					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I'mma comin' in! Wow, smells just like my grandpa's house in here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“打扰了～！哇，是和爷爷家同样的味道呢～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「打擾了～！哇，是和爺爺家同樣的味道呢～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0126_00124",
		linknext = "0126_00126",
