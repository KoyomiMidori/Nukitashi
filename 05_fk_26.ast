					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I want to get stronger myself. But time isn't a luxury I have to do it at any normal pace.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想变得更强。但是，我没有时间再悠闲地进行训练了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想變得更強。但是，我沒有時間再悠閒地進行訓練了。」",
