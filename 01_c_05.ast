					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So anyway, what were you doing out here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那么片桐你究竟在那种地方做什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那麼片桐你究竟在那種地方做什麼？」",
					{"rt2"},
