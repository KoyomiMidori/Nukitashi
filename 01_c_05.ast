					"Normally a little retort like that from me would make her smile and laugh it off. But her expression doesn't change.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明平常会笑出来的，但妹妹的脸上依旧没有笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明平常會笑出來的，但妹妹的臉上依舊沒有笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00410",
		linknext = "0006_00412",
		line = 5118,
	},
	["0006_00412"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0273", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I just... The thought of being forced into it against your will... I can't deal with that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是……明明不想做，还要被强迫……太可怜了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是……明明不想做，還要被強迫……太可憐了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00411",
		linknext = "0006_00413",
		line = 5130,
	},
	["0006_00413"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What does she mean by that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"她是在说谁呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"她是在說誰呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00412",
		linknext = "0006_00414",
		line = 5140,
	},
	["0006_00414"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Could it be she's talking about herself, since she likes girls?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是在说喜欢女孩子的自己吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是在說喜歡女孩子的自己嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00413",
		linknext = "0006_00415",
		line = 5150,
	},
	["0006_00415"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tears still keep streaming out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的眼泪依旧不停落下。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的眼淚依舊不停落下。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00414",
		linknext = "0006_00416",
		line = 5160,
	},
	["0006_00416"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despite how she appears, she's always been a crybaby.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妹妹确实从小就很能哭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妹妹確實從小就很能哭。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00415",
		linknext = "0006_00417",
		line = 5170,
	},
	["0006_00417"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00108", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0274", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Really... I thought... Guh... you got hit by a car...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“其实……我本来……以为……你被……车撞了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「其實……我本來……以為……你被……車撞了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00416",
		linknext = "0006_00418",
		line = 5185,
	},
	["0006_00418"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She always hides behind her tears.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边隐忍着泪水，",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊隱忍著淚水，",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00417",
		linknext = "0006_00419",
		line = 5195,
	},
	["0006_00419"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But crying allows her to open up about what she'd normally never put into words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一边说出了平常说不出来的内心话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一邊說出了平常說不出來的內心話。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00418",
		linknext = "0006_00420",
		line = 5205,
	},
	["0006_00420"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She always says she doesn't want to go outside, but in actuality, it's not just because she doesn't want to go to school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妹妹不想出去的原因不仅仅是不想上学。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妹妹不想出去的原因不僅僅是不想上學。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00419",
		linknext = "0006_00421",
		line = 5215,
	},
	["0006_00421"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's because of what the shock of being in a car accident does to your mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还受到在我们面前发生的车祸的强烈影响。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還受到在我們面前發生的車禍的強烈影響。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00420",
		linknext = "0006_00422",
		line = 5225,
	},
	["0006_00422"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's barely even been two months since it happened.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后也仅过了两个月，仅两个月。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那之後也僅過了兩個月，僅兩個月。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00421",
		linknext = "0006_00423",
		line = 5235,
	},
	["0006_00423"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That more than likely isn't enough time for the wounds to have fully healed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这可能不足以让伤口愈合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這可能不足以讓傷口癒合。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00422",
		linknext = "0006_00424",
		line = 5245,
	},
	["0006_00424"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though she always puts on a brave face, she's scared too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然一直表现的很坚强，但妹妹也在害怕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然一直表現的很堅強，但妹妹也在害怕。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00423",
		linknext = "0006_00425",
		line = 5255,
	},
	["0006_00425"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
