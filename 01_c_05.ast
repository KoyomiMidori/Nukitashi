astver = 2.0
ast = {
	["0006_00001"] = {
		{"savetitle", text="射精の国～ハメドリの少女～", ja="射精の国～ハメドリの少女～", en="Shasei no Kuni: Hamedori no Shoujo", cn="射精之国～Hamedori-kun的少女～", tw="射精之國～Hamedori-kun的少女～"},
		{"eval", exp="g.01_c_05=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"bgm", file="bgm01", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La tortilla enrollada y recalentada se me deshace en la boca al masticarla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我将加热后的鸡蛋卷放进了嘴里，那口感就跟融化般蓬松。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我將加熱後的玉子燒放進了嘴裡，那口感就跟融化般蓬鬆。",
					{"rt2"},
				},
			},
		},
		linknext = "0006_00002",
		line = 18,
	},
	["0006_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El aroma del puerro y el caldo cosquillean mis fosas nasales, haciendo que desprenda un sabor sutil.",
					{"rt2"},
				},
			},
			cn = {
				{
					"里头的葱花和高汤香气刺激着鼻腔，味道非常精致。",
					{"rt2"},
				},
			},
			tw = {
				{
					"裡頭的蔥花和高湯香氣刺激著鼻腔，味道非常精緻。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00001",
		linknext = "0006_00003",
		line = 28,
	},
	["0006_00003"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00123", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=600, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0235", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aaah... hermanito...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊……哥哥。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊……哥哥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00002",
		linknext = "0006_00004",
		line = 43,
	},
	["0006_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan se lleva el mismo plato a la boca y lo mastica lentamente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"拿着一小碗炖菜的麻沙酱也慢慢地吃着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"拿著一小碗燉菜的麻沙醬也慢慢地吃著。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00003",
		linknext = "0006_00005",
		line = 53,
	},
	["0006_00005"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0236", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es un alivio tener una casa limpia y buena comida, ¿verdad...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……在干净的家里吃着美味的饭菜真是幸福……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……在乾淨的家裡吃著美味的飯菜真是幸福……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00004",
		linknext = "0006_00006",
		line = 65,
	},
	["0006_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por supuesto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得对〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得對〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00005",
		linknext = "0006_00007",
		line = 77,
	},
	["0006_00007"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0237", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Saber que Nanase-san hizo esto lo hace aún más sabroso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“而且一想到这是奈奈濑同学做的菜，味道就更好了〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「而且一想到這是奈奈瀨同學做的菜，味道就更好了〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00006",
		linknext = "0006_00008",
		line = 89,
	},
	["0006_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde ese día, Katagiri ha estado viniendo para hacer los quehaceres del hogar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那天起，片桐作为家务代理服务已经来我们家好几次了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從那天起，片桐作為家事代理服務已經來我們家好幾次了。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00007",
		linknext = "0006_00009",
		line = 99,
	},
	["0006_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Viene dos o tres veces por semana y siempre nos deja comida para varios días.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她大约一周会来2到3次。每次来都会帮我们做好几天的饭菜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一週大約會來2到3次。每次來都會幫我們做好幾天的飯菜。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00008",
		linknext = "0006_00010",
		line = 109,
	},
	["0006_00010"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0238", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿No sería genial que nos hiciera sopa de miso todo el tiempo...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“如果有她平常帮我们做的味增汤就更好了〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「如果有她平常幫我們做的味噌湯就完美了〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00009",
		linknext = "0006_00011",
		line = 123,
	},
	["0006_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues, no puede hacerla con antelación. La sopa de miso se estropea muy rápido en esta época del año.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她说这个时期味增汤容易变味，所以不能煮起来放呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她說這個時期味噌湯容易變味，所以不能煮起來放呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00010",
		linknext = "0006_00012",
		line = 135,
	},
	["0006_00012"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00123", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0239", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No sé, el tofu me parece mucho más sucio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——豆腐感觉会用100米10秒的速度坏掉呢〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊——豆腐感覺會用100米10秒的速度壞掉呢〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00011",
		linknext = "0006_00013",
		line = 149,
	},
	["0006_00013"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En lo personal, siento que el wakame no es de los que viven para el drama...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总觉得裙带菜给人很能长跑的形象呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總覺得海帶芽給人很能長跑的形象呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00012",
		linknext = "0006_00014",
		line = 161,
	},
	["0006_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En este tipo de ambiente relajado, puedo responder a las tontas ocurrencias de mi hermana sin esfuerzo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一旦内心有了余裕，就可以平静地回应妹妹的傻话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一旦內心有了余裕，就可以平靜地回應妹妹的傻話。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00013",
		linknext = "0006_00015",
		line = 171,
	},
	["0006_00015"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora que lo pienso, dijo que probablemente podríamos encargarnos de la sopa de miso por nuestra cuenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说，味增汤自己也可以做呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說，味噌湯自己也可以做呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00014",
		linknext = "0006_00016",
		line = 183,
	},
	["0006_00016"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0240", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí, pero ¿no la quemamos cuando intentamos prepararla nosotros mismos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“话是这么说，但是啊〜之前哥哥和我尝试做的时候，味增汤不是烧焦了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「話是這麼說，但是啊〜之前哥哥和我嘗試做的時候，味噌湯不是燒焦了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00015",
		linknext = "0006_00017",
		line = 197,
	},
	["0006_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La olla se incendió.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“锅子里好像还喷火了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「鍋子裡好像還噴火了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00016",
		linknext = "0006_00018",
		line = 208,
	},
	["0006_00018"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0241", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿La sopa de miso se puede quemar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“一般来说味增汤是会烧焦的食物吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「一般來說味噌湯是會燒焦的食物嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00017",
		linknext = "0006_00019",
		line = 222,
	},
	["0006_00019"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues, nos las arreglamos para quemarla. Encima, ¿no dijo hasta la propia Katagiri que ella también la quemó?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是肯定的，毕竟我们都烧焦了呢。片桐肯定也烧焦过一两次味增汤吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是肯定的，畢竟我們都燒焦了。片桐肯定也燒焦過一兩次味噌湯吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00018",
		linknext = "0006_00020",
		line = 234,
	},
	["0006_00020"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0242", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Supongo que convertirse en un maestro de la sopa de miso es un camino largo y arduo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“也对〜味噌汤大师的道路还很漫长呢〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「也對〜味噌湯大師的道路還很漫長呢〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00019",
		linknext = "0006_00021",
		line = 248,
	},
	["0006_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El arroz refrigerado está dividido en porciones individuales de distintos tamaños. Incluso están etiquetadas individualmente como 'Hermano' y 'Hermana'..",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷冻米饭不仅分成了一个人的分量，还分了“哥哥”和“妹妹”的分量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷凍米飯不僅分成了一個人的份量，還分了「哥哥」和「妹妹」的份量。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00020",
		linknext = "0006_00022",
		line = 258,
	},
	["0006_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pues entendió perfectamente la cantidad de arroz blanco que comemos cuando venimos a casa, ya que el tamaño de las raciones es el adecuado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她似乎在来的时候大致掌握了我们吃的白米量。量得刚刚好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她似乎在來的時候大致掌握了我們吃的米飯量。量得剛剛好。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00021",
		linknext = "0006_00023",
		line = 268,
	},
	["0006_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nada mal, Frau Katagiri.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真是感谢片桐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真是感謝片桐。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00022",
		linknext = "0006_00024",
		line = 278,
	},
	["0006_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con el impecable sabor de la sopa de miso, puedo entender por qué mi hermana querría tomarla todos los días.",
					{"rt2"},
				},
			},
			cn = {
				{
					"味道无可挑剔，我也理解妹妹每天都想喝味噌汤的心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"味道無可挑剔，我也理解妹妹每天都想喝味噌湯的心情。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00023",
		linknext = "0006_00025",
		line = 288,
	},
	["0006_00025"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0243", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Espera, hermano...! ¡Ahh...! ¡Se me ocurrió una idea aún mejor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“等等哥哥……！啊啊……！我想到了一个很厉害的事情……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「等等哥哥……！啊啊……！我想到了一個很厲害的事情……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00024",
		linknext = "0006_00026",
		line = 303,
	},
	["0006_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Por qué te ves como si te fueran a salir los ojos de la cabeza?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了？眼睛睁那么大。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了？眼睛睜那麼大。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00025",
		linknext = "0006_00027",
		line = 315,
	},
	["0006_00027"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0244", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Si te casaras con Nanase-san, podríamos comer así todos los días!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“如果奈奈濑嫁到我们家，那不是每天都可以吃好吃的饭菜吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「如果奈奈瀨嫁到我們家，那不是每天都可以吃好吃的飯菜嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00026",
		linknext = "0006_00028",
		line = 327,
	},
	["0006_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00027",
		linknext = "0006_00029",
		line = 339,
	},
	["0006_00029"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0245", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Hasta podría encargarse de la limpieza, y cada día sería celestial...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“然后她还会每天帮忙清扫家里，这样就能过上舒适的生活了不是吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「然後她還會每天幫忙清掃家裡，這樣就能過上舒適的生活了不是嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00028",
		linknext = "0006_00030",
		line = 351,
	},
	["0006_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
