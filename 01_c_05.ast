	},
	["0006_00054"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00112", file2="asane_02m_00202", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
