		linkback = "0006_00053",
		linknext = "0006_00055",
		line = 679,
	},
	["0006_00055"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si realmente no hay nada que pueda hacerte cambiar de opinión, no puedo obligarte...”",
					{"rt2"},
