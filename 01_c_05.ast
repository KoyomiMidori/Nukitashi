				{"vo", file="nanase0113", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uh, well, you see, um... You could say I'm hiding from all that ordinary island sex? Like, I'm after some more adventurous play, or something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那是，怎么说，为了逃避岛上的一般性爱？为了追求更刺激的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那是，怎麼說，為了逃避島上的一般性愛？為了追求更刺激的。」",
					{"rt2"},
				},
			},
