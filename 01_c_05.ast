		linkback = "0006_00045",
		linknext = "0006_00047",
		line = 579,
	},
	["0006_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi querida (pero tonta) hermana está teniendo otra de sus rabietas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像往常一样赖皮的可爱",
					{"ruby", text="笨蛋"},
					"妹妹",
					{"/ruby"},
					"。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像往常一樣賴皮的可愛",
					{"ruby", text="笨蛋"},
					"妹妹",
					{"/ruby"},
					"。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00046",
		linknext = "0006_00048",
		line = 589,
	},
	["0006_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero incluso en momentos así, el servicio de limpieza puede resultar útil.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，即使在这种时候，我们的家务代理服务也能帮上忙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，即使在這種時候，我們的家事代理服務也能幫上忙。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00047",
		linknext = "0006_00049",
		line = 599,
	},
	["0006_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hice nuestros almuerzos para hoy con las sobras de la cena de anoche. Pero supongo que no quieres comer eso, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天我做了一个放有昨天晚上配菜的便当，你不吃也可以哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天我做了一個放有昨天晚上配菜的便當，你不吃也可以哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00048",
		linknext = "0006_00050",
		line = 611,
	},
	["0006_00050"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00109", file2="asane_02m_00202", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0254", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Eh? ¡¿Hoy puedo almorzar lo que cocinó Nanase-san?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“咦，今天中午我也可以吃奈奈濑同学煮的饭菜吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「咦，今天中午我也可以吃奈奈瀨同學煮的飯菜嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00049",
		linknext = "0006_00051",
		line = 626,
	},
	["0006_00051"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hay suficiente hasta sobras.”",
