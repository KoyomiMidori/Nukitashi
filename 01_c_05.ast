	["0006_00039"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00106", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=4, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0250", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡No quiero! ¡No voy a volver a la escuela!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不——要——不——要——！我不上学……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不——要——不——要——！我不上學……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00038",
		linknext = "0006_00040",
		line = 488,
	},
	["0006_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Qué tan mal estás de la cabeza?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你情绪也太不稳定了吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你情緒也太不穩定了吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00039",
		linknext = "0006_00041",
		line = 500,
	},
	["0006_00041"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00103", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0251", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡No iré a la escuela hasta que te cases con Nanase-san y venga por la mañana temprano a despertar a su cuñada sacudiéndola suavemente para que luego se deje vencer por su lujuria y tome la virginidad de su cuñada!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“直到奈奈濑嫁到我们家成为嫂子来到我的房间在清晨的早些时候轻轻地摇我起来却突然对妹妹发情玩弄我然后夺走我的处女为止永远不会去学校！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「直到奈奈瀨嫁到我們家成為嫂子來到我的房間在清晨的早些時候輕輕地搖我起來卻突然對妹妹發情玩弄我然後奪走我的處女為止永遠不會去學校！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00040",
		linknext = "0006_00042",
		line = 514,
	},
	["0006_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si es por eso, me quedaré soltero de por vida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那我一辈子单身吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那我一輩子單身吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00041",
		linknext = "0006_00043",
		line = 526,
	},
	["0006_00043"] = {
