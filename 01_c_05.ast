	},
	["0006_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esa almohada me está dando problemas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“开始认真觉得这个枕头有点烦了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「開始認真覺得這個枕頭有點煩了……」",
					{"rt2"},
