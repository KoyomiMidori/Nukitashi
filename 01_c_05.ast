		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0091", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uff, qué alivio... Te caíste como un saco de patatas, por un momento pensé que estabas muerto...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呼，太好了……我看你突然倒下，还以为你死了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呼，太好了……我看你突然倒下，還以為你死了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00303",
		linknext = "0006_00305",
		line = 3743,
	},
	["0006_00305"] = {
