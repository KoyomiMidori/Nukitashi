	},
	["0006_00052"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00113", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=3, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0255", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“B-B-B-B-Bueno... En serio que no quiero ir, pero si puedo tener ese almuerzo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那那那那，那可以哦？虽然我真的不想去……但看在便当的份上……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那那那那，那可以哦？雖然我真的不想去……但看在便當的份上……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00051",
		linknext = "0006_00053",
		line = 653,
	},
	["0006_00053"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Realmente no quieres comer ese almuerzo, eh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊，不需要便当啊。”",
