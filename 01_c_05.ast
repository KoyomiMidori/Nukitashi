			vo = {
				{"vo", file="nanase0095", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pues sí era yo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“结果那是我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「結果那是我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00317",
		linknext = "0006_00319",
		line = 3913,
	},
	["0006_00319"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, pensé que podría ser un jabalí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我还以为是一头野猪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我還以為是一頭野豬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00318",
		linknext = "0006_00320",
		line = 3925,
	},
	["0006_00320"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0096", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Y-Y luego?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好吧，然后呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好吧，然後呢？」",
					{"rt2"},
				},
