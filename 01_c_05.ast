			},
		},
		text = {
			vo = {
				{"vo", file="nanase0111", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, well, you could say I'm a local, I guess? Though I was a transfer student too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，呃我毕竟也是当地人……？而且我也是转学生……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，呃我畢竟也是當地人……？而且我也是轉學生……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00354",
		linknext = "0006_00356",
		line = 4393,
	},
	["0006_00356"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
