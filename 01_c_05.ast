		{"text"},
		text = {
			vo = {
				{"vo", file="rei0017", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Muchachos, escúchenme! ¡Somos el comité disciplinario de la Academia Minotsuki! ¡A esta pareja la descubrimos violando las preciadas leyes de la isla!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“——学生们，听好了！我们是水乃月学园风纪委员会！这对情侣违反了我们岛上的重要条例！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「——學生們，聽好了！我們是水乃月學園風紀委員會！這對情侶違反了我們島上的重要條例！」",
					{"rt2"},
				},
			},
		},
