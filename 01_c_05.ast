		linkback = "0006_00319",
		linknext = "0006_00321",
		line = 3940,
	},
	["0006_00321"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Salté de inmediato.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我马上冲了上去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我馬上衝了上去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00320",
		linknext = "0006_00322",
		line = 3952,
	},
	["0006_00322"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0097", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Why would you even!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“为什么啊……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「為什麼啊……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00321",
		linknext = "0006_00323",
		line = 3968,
	},
	["0006_00323"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come on, I figured I could take it down if I struck first!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想我能先发制人的话就能打败牠……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想我能先發制人的話就能打敗牠……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00322",
		linknext = "0006_00324",
		line = 3980,
	},
	["0006_00324"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0098", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“That's insane!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么可能赢啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼可能贏啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00323",
		linknext = "0006_00325",
		line = 3992,
	},
	["0006_00325"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I drink protein shakes and work out every day...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我可是每天都吃蛋白质还有在锻炼哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我可是每天都吃蛋白質還有在鍛煉哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00324",
		linknext = "0006_00326",
		line = 4004,
	},
	["0006_00326"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00115", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0099", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Tachibana-kun, you think working out is going to make you invincible? Were you dropped?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“在橘君内心只要有锻炼就能变成无敌吗……？会不会太蠢了啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「在橘君內心只要有鍛煉就能變得無敵嗎……？會不會太蠢了啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00325",
		linknext = "0006_00327",
		line = 4018,
	},
	["0006_00327"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are wild boars really that strong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“野猪有那么强吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「野豬有那麼強嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00326",
		linknext = "0006_00328",
		line = 4030,
	},
	["0006_00328"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00103", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0100", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“There's injuries on this island caused by them every year. People get their limbs broken, their asses bitten, that sort of thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这个岛上每年都有人受伤哦？骨折或被咬屁股什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這個島上每年都有人受傷哦？骨折或被咬屁股什麼的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00327",
		linknext = "0006_00329",
		line = 4044,
	},
	["0006_00329"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought they were basically just hairy pigs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我以为只是毛茸茸的猪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我以為只是毛茸茸的豬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00328",
		linknext = "0006_00330",
		line = 4056,
	},
	["0006_00330"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0101", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“City slickers are so ignorant it's scary...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……城里人的无知真可怕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……都市人的無知真可怕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00329",
		linknext = "0006_00331",
		line = 4070,
	},
	["0006_00331"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hey, I used to live on this island before, you know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我以前有住过这个岛好吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我以前有住過這個島好嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00330",
		linknext = "0006_00332",
		line = 4080,
	},
	["0006_00332"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So yeah, I figured I'd try and land the first strike before what I thought was the boar could attack. And now we're here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，那就是我为了不给对方机会所以冲上去的后果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，那就是我為了不給對方機會所以衝上去的後果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00331",
		linknext = "0006_00333",
		line = 4092,
	},
	["0006_00333"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0102", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I see. So you went the whole hog, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“原来如此？对着猪猪突猛进是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「原來如此？對著豬豬突猛進是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00332",
		linknext = "0006_00334",
		line = 4106,
	},
	["0006_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00333",
		linknext = "0006_00335",
		line = 4117,
	},
	["0006_00335"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00204", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0103", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Come on, say something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……你倒是说些什么啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……你倒是說些什麼啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00334",
		linknext = "0006_00336",
		line = 4132,
	},
	["0006_00336"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm surprised a slut like you could be that much of a quick wit...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没想到婊子居然懂成语诶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒想到婊子居然懂成語欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00335",
		linknext = "0006_00337",
		line = 4144,
	},
	["0006_00337"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00204", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=200, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0104", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I'll kick you in the shins, asshole!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“踢飞你哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「踢飛你哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00336",
		linknext = "0006_00338",
		line = 4158,
	},
	["0006_00338"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'd welcome that, considering where you already kicked me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不是已经踢了我很重要的地方吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你不是已經踢了我很重要的地方嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00337",
		linknext = "0006_00339",
		line = 4170,
	},
	["0006_00339"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0105", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So let me get this straight. You thought I was a wild boar, so you decided to jump out and attack... How recklessly determined are you, anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话说一碰到野猪就马上选择战斗……你究竟下了多大决心啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話說一碰到野豬就馬上選擇戰鬥……你究竟下了多大決心啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00338",
		linknext = "0006_00340",
		line = 4184,
	},
	["0006_00340"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You sound a lot like my sister. She's always saying that I start doing crazy things at the last minute..”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我妹妹也经常这么说我。说我面临危机的时候经常会干一些不得了的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我妹妹也經常這麼說我。說我面臨危機的時候經常會幹一些不得了的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00339",
		linknext = "0006_00341",
		line = 4196,
	},
	["0006_00341"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0106", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, I ain't gonna disagree with that. You into doing that kinda stupid stuff all the time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对，就是那种感觉。突然就开始做蠢事的感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對，就是那種感覺。突然就開始做蠢事的感覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00340",
		linknext = "0006_00342",
		line = 4210,
	},
	["0006_00342"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've been told when my family got into a car accident, I seriously tried to lift the car up, thinking I could save my parents...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在我家人发生车祸的时候，我也真的想把车抬起来，去救我的父母……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在我家人發生車禍的時候，我也真的想把車抬起來，去救我的父母……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00341",
		linknext = "0006_00343",
		line = 4222,
	},
	["0006_00343"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0107", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, really... I'm sorry to hear that. I didn't expect this conversation to take such a dark turn...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊，这样啊……对不起……我对突如其来的沉重谈话感到有点动摇了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊，這樣啊……對不起……我對突如其來的沉重談話感到有點動搖了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00342",
		linknext = "0006_00344",
		line = 4238,
	},
	["0006_00344"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Damn. Here I thought a gyaru slut would be like “what the hell” and then laugh it off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"完了，我以为辣妹婊肯定会说“什么鬼啊真好笑”然后一笑而过的……",
					{"rt2"},
				},
			},
			tw = {
				{
					"完了，我以為辣妹婊肯定會說「什麼鬼啊真好笑」然後一笑而過的……",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00343",
		linknext = "0006_00345",
		line = 4249,
	},
	["0006_00345"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Guess that went down like a lead balloon. Better switch the topic.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我要改变一下话题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我要改變一下話題。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00344",
		linknext = "0006_00346",
		line = 4259,
	},
	["0006_00346"] = {
		{"bgm", file="bgm04", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, anyway. Before all that happened, I was totally lost. I don't know how to get back to the town.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之我会这样也是因为迷路了，不知道该怎么回镇上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之我會這樣也是因為迷路了，不知道該怎麼回鎮上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00345",
		linknext = "0006_00347",
		line = 4272,
	},
	["0006_00347"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6400] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=6400, time=1, mode=3, x=0, y=0},
			},
			[6500] = {
				{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=600, delay2=6500},
				{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=400, delay2=6500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0108", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, the town? Why didn't you say so? Go this way, you'll get there pretty quick.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊，什么嘛，你想去镇上啊？那从这边走马上就可以到了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊，什麼嘛，你想去鎮上啊？那從這邊走馬上就可以到了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00346",
		linknext = "0006_00348",
		line = 4291,
	},
	["0006_00348"] = {
		{"se", id=0, loop=0, file="se_a018"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That way?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这边……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這邊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00347",
		linknext = "0006_00349",
		line = 4304,
	},
	["0006_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I follow Katagiri.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我跟在片桐后面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我跟在片桐後面。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00348",
		linknext = "0006_00350",
		line = 4314,
	},
	["0006_00350"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Walking for a few minutes, I see the town come into view.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后走了几分钟后，很快就看到了小镇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後走了幾分鐘後，很快就看到了小鎮。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00349",
		linknext = "0006_00351",
		line = 4324,
	},
	["0006_00351"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0109", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“See? We're coming up on the residential area. It's pretty hard to find it from here if you don't know the area, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你看，这里靠住宅区还蛮近的对吧？不过如果不习惯的话还蛮难知道的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你看，這裡靠住宅區還蠻近的對吧？不過如果不習慣的話還蠻難知道的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00350",
		linknext = "0006_00352",
		line = 4337,
	},
	["0006_00352"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0110", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Anyway, see that road down there? you can follow that and you'll eventually reach Tachibana-kun's house.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你只要从这里沿着这条路走，就可以回到自己家了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你只要從這裡沿著這條路走，就可以回到自己家了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00351",
		linknext = "0006_00353",
		line = 4349,
	},
	["0006_00353"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh, so I see... I should write this down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的呢，我明白了……必须把它写下来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的呢，我明白了……必須把它寫下來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00352",
		linknext = "0006_00354",
		line = 4364,
	},
	["0006_00354"] = {
		{"se", id=0, loop=0, file="se_a142"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I'm surprised you know your way around here, considering there's no path. I doubt you'd find other people wandering around this forest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说你好熟悉啊，明明连路都算不上。平常不会经过这里吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說你好熟悉啊，明明連路都算不上。平常不會經過這裡吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00353",
		linknext = "0006_00355",
		line = 4377,
	},
	["0006_00355"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
