					name = {"淳之介", "Junnosuke"},
					"“There's no way I'd ever just disappear and leave you behind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——我不可能丢下妹妹消失吧？”",
