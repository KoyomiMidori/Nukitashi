		line = 4405,
	},
	["0006_00357"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought I heard that the rear gate isn't used because the locals don't come out this way, though...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我以为是因为当地人不怎么走这条路，所以后门才荒废的呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我以為是因為當地人不怎麼走這條路，所以後門才荒廢的呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00356",
		linknext = "0006_00358",
		line = 4415,
	},
	["0006_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
