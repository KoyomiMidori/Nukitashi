			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Eh? No, es en serio, es que estoy pensando que sí debería ir...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“咦？所以说……虽然没办法但我会去的……”",
