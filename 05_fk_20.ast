	},
	["0120_00697"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1083", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No matter what happens from now on... I will surely be fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“将来……不管我发生什么……都不会有事的。”",
