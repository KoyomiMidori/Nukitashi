		{"fg", mode=-1, id=30, ch="美岬", lv=5},
		{"fg", file="touka_01l_00001", file1="touka_01l_00115", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=1000, mode=3, x=-200, y=0},
		{"fgact", ch="桐香", id=8, act="移動", x=200, y=0, time=1200},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0849", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"非表示", "桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Touka"},
					"“Goodness... How did you find me out? I deliberately left my tablet behind to prevent such a thing, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "桐香"},
					"“哎呀……为什么会被发现呢……？我都把平板放着过来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "桐香"},
					"「哎呀……為什麼會被發現呢……？我都把平板放著過來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00250",
		linknext = "0120_00252",
		line = 4250,
	},
	["0120_00252"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
