	["0120_00414"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if it can get GPS locations, without cameras the IFF is useless.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然可以通过GPS取得位置信息，但由于没有摄像头，所以IFF无法使用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然可以通過GPS取得位置資訊，但由於沒有攝影機，所以IFF無法使用。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00413",
		linknext = "0120_00415",
		line = 7175,
	},
	["0120_00415"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It still can serve some purpose, but... There's nothing on the radar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过在某种程度上还是有用的……但是雷达并没有闪烁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過在某種程度上還是有用的……但是雷達並沒有閃爍。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00414",
		linknext = "0120_00416",
		line = 7185,
	},
	["0120_00416"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1743", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bro, I just picked up something from the OSS radio frequency. Patching us in so we can listen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥……收到SHO的无线电了……我播给你听……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥……收到SHO的無線電了……我播給你聽……」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00415",
		linknext = "0120_00417",
		line = 7198,
	},
	["0120_00417"] = {
		{"se", id=0, loop=0, file="se_b032"},
		{"fg", file="kouki_01f_00001", file1="kouki_01f_00103", path=":fg/kouki_01f/", id=30, ch="光姫", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0178", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“This is Senba Kouki! We're being attacked by the stragglers from an armed struggle on the shore! Our division's first platoon has been annihilated! We need backup, now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“——这里是仙波光姬！海岸那边有武斗联合的残党出没！治安维持部的1个小队全军覆没！赶快派援军——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「——這裡是仙波光姬！海岸那邊有武鬥聯合的殘黨出沒！治安維持部的1個小隊全軍覆沒！趕快派援軍——」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00416",
		linknext = "0120_00418",
		line = 7212,
	},
	["0120_00418"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Does this mean Teshima's made his move?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是手嶋的行动吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是手嶋的行動嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00417",
		linknext = "0120_00419",
		line = 7225,
	},
	["0120_00419"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00103", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2076", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Seems like it... But why now, of all times?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“看来是这样……可是，为什么偏偏在这个时候……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「看來是這樣……可是，為什麼偏偏在這個時候……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00418",
		linknext = "0120_00420",
		line = 7238,
	},
	["0120_00420"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's hard to believe this is purely coincidental.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有点难以想象是偶然——",
					{"rt2"},
				},
			},
			tw = {
				{
					"有點難以想像是偶然——",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00419",
		linknext = "0120_00421",
		line = 7248,
	},
	["0120_00421"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All the better for us, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是对我们来说，这反而帮了我们的忙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是對我們來說，這反而幫了我們的忙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00420",
		linknext = "0120_00422",
		line = 7260,
	},
	["0120_00422"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No need to split up into two groups, so let's get going! Nanase, lead the way!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没必要分成两队了。总之赶路吧！奈奈濑，你来带路！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒必要分成兩隊了。總之趕路吧！奈奈瀨，你來帶路！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00421",
		linknext = "0120_00423",
		line = 7272,
	},
	["0120_00423"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2270", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Roger. Man, didn't think the last time I infiltrated the OSS HQ would help me out this time!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“明白了。没想到以前侵入SHO总部的经验能派上用场——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「明白了。沒想到以前侵入SHO總部的經驗能派上用場——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00422",
		linknext = "0120_00424",
		line = 7286,
	},
