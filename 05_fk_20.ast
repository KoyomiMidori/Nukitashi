		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1746", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Subjects of unknown virginity status gathering on site. Assuming both OSS and SS. Two squads, total numbers of 19 entering building now. Approximately 162 seconds to engagement.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“处女躯不明器正往现在地集结中。预测是SHO以及FS。入侵建筑物的2个分队共19人。约162秒后接触。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「處女軀不明器正往現在地集結中。預測是SHO以及FS。入侵建築物的2個分隊共19人。約162秒後接觸。」",
					{"rt2"},
				},
			},
		},
