			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I can sense her. 10 o'clock, seventeen meters away. Alone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“有人……10点钟方向，距离17米。1名。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「有人……10點鐘方向，距離17米。1名。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00248",
		linknext = "0120_00250",
