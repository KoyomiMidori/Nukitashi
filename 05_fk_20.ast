	},
	["0120_00695"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She is seemingly hesitant to say something to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃犹豫着想说些什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃猶豫著想說些什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00694",
		linknext = "0120_00696",
		line = 11606,
	},
	["0120_00696"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00112", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But her expression remains the same.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，最后还是浮现出平时的面无表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，最後還是浮現出平時的面無表情。",
					{"rt2"},
