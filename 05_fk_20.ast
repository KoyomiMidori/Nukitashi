					name = {"桐香", "Touka"},
					"“You place too much stock in sexual acts. Are moans not just another form of popular music being played in public?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈太过重视性行为了。娇喘什么的，就跟听大众音乐没什么差别吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩太過重視性行為了。嬌喘什麼的，就跟聽大眾音樂沒什麼差別吧？」",
					{"rt2"},
				},
			},
