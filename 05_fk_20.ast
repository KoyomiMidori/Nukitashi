			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I anticipate the enemy is clustered together and planning to bust through as a group. If we encircle them... What!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
