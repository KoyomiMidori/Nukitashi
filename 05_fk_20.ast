		{"fgact", ch="桐香", id=16, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0861", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You don't hear the average person complaining when they hear a popular song played in public, do you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“有人会对街边传来的流行歌曲感到不满吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「有人會對街邊傳來的流行歌曲感到不滿嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00350",
		linknext = "0120_00352",
		line = 6108,
	},
	["0120_00352"] = {
