				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“My! I can hardly wait. You truly have given my life so many new and interesting firsts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀，那可真是期待。前辈给了我很多人生的第一次呢——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀，那可真是期待。前輩給了我很多人生的第一次呢——」",
					{"rt2"},
				},
			},
		},
