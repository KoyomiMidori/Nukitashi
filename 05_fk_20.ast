				},
			},
			cn = {
				{
					name = {"文乃"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00663",
		linknext = "0120_00665",
		line = 11161,
	},
	["0120_00665"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I gently tousle her hair. The look on her face as I do so is unusually childish and bashful.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我摸了摸文乃的头，结果她露出一副很孩子气的表情，非常舒服的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我摸了摸文乃的頭，結果她露出一副很孩子氣的表情，非常舒服的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00664",
		linknext = "0120_00666",
		line = 11171,
	},
	["0120_00666"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, did you find the meeting place?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个，找到汇合地点了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個，找到會合地點了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00665",
		linknext = "0120_00667",
		line = 11186,
	},
	["0120_00667"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file4="misaki_01m_00401", path=":fg/misaki_01m/", id=3, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2084", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, I located it with the Penile Investigator! It's some distance from here, so we'll have to run for it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“刚才用珍神发现了！因为有点距离，所以必须跑过去……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「剛才用珍神發現了！因為有點距離，所以必須跑過去……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00666",
		linknext = "0120_00668",
		line = 11200,
	},
	["0120_00668"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=2.5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're already out of time, so nothing new there. Let's go!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没问题。没有时间了，出发吧——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒問題。沒有時間了，出發吧——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00667",
		linknext = "0120_00669",
		line = 11214,
	},
	["0120_00669"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=3, ch="美岬", lv=5, time=100},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg25_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"se", id=3, loop=1, file="se_d016", vol=40},
		{"se", id=0, loop=0, file="se_a033", vol=60},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you guys Mr. Sakimori's helpers?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你们是防人老人派来的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你們是防人老人派來的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00668",
		linknext = "0120_00670",
		line = 11261,
	},
	["0120_00670"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0130", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "男A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Male A"},
					"“Yes, we're representatives of Mr. Sakimori. Is that girl Kotoyose Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "A男"},
					"“是的，我们是防人先生派来的代理人。那个少女就是琴寄文乃吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "A男"},
					"「是的，我們是防人先生派來的代理人。那個少女就是琴寄文乃嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00669",
		linknext = "0120_00671",
		line = 11273,
	},
	["0120_00671"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Where's Sakimori? Is he not coming himself?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“防人老人在哪里。没有来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「防人老人在哪裡。沒有來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00670",
		linknext = "0120_00672",
		line = 11284,
	},
	["0120_00672"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0131", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "男A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Male A"},
					"“He's on the mainland, waiting to receive her. It's not too far from here, so you can rest assured.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "A男"},
					"“他在本岛做好了迎接的准备，并在那里等候。放心吧，离这里没有多远的距离。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "A男"},
					"「他在本島做好了迎接的準備，並在那裡等候。放心吧，離這裡沒有多遠的距離。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00671",
		linknext = "0120_00673",
		line = 11296,
	},
	["0120_00673"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He doesn't look like he's lying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——看起来并不像在说谎。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——看起來並不像在說謊。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00672",
		linknext = "0120_00674",
		line = 11306,
	},
	["0120_00674"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once we hand her over to these men, our battle will be over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要交给这些男人——我的战斗，就全部结束了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要交給這些男人——我的戰鬥，就全部結束了。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00673",
		linknext = "0120_00675",
		line = 11316,
	},
	["0120_00675"] = {
		{"bgm", file="bgm26", vol=100},
		{"se", id=3, loop=1, file="se_d016", vol=20},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00674",
		linknext = "0120_00676",
		line = 11330,
	},
	["0120_00676"] = {
		{"bg", id=1, file="bg25_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1078", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes. Thank you all, for everything you have done for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……大家，至今承蒙关照了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……大家，至今承蒙關照了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00675",
		linknext = "0120_00677",
		line = 11345,
	},
	["0120_00677"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00108", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2209", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Fumino... Take care of yourself... Be sure to write us when you can...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“文乃酱……在那边也要健健康康的……偶尔也要写信给我哦……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「文乃醬……在那邊也要健健康康的……偶爾也要寫信給我哦……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00676",
		linknext = "0120_00678",
		line = 11359,
	},
	["0120_00678"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00108", path=":fg/misaki_01m/", id=3, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2085", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We'll be... sure to respond to you...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我们也会……给你回信……的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我們也會……給你回信……的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00677",
		linknext = "0120_00679",
		line = 11373,
	},
	["0120_00679"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00116", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1079", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Thank you both. Though I am not particularly good at writing, so it may take some time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“谢谢两位……虽然我不怎么会写信，也许要花点时间……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「謝謝兩位……雖然我不怎麼會寫信，也許要花點時間……」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00678",
		linknext = "0120_00680",
		line = 11387,
	},
	["0120_00680"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2277", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Fumino, take this. Some recipes for Western-style meals. I know I promised to teach you, but we never got the time. And sorry about my awful handwriting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“文乃，这个给你。这是西餐之类的食谱。本来约好了要教你，却找不到时间，所以只能以文字的形式，很抱歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「文乃，這個給你。這是西餐之類的食譜。本來約好了要教你，卻找不到時間，所以只能以文字的形式，很抱歉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00679",
		linknext = "0120_00681",
		line = 11402,
	},
	["0120_00681"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2278", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Whenever you come back, I'll be sure to teach you properly. I owe you one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……等你哪天回来了，我会好好教你的。这样我们就算实现了承诺吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……等你哪天回來了，我會好好教你的。這樣我們就算實現了承諾吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00680",
		linknext = "0120_00682",
		line = 11416,
	},
	["0120_00682"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1080", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“The thought is much appreciated. Thank you, Nanase. We will surely have the time again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……谢谢您的体贴，奈奈濑同学……一定会再……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……謝謝您的體貼，奈奈瀨同學……一定會再……」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00681",
		linknext = "0120_00683",
		line = 11430,
	},
	["0120_00683"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=3, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I have something for you myself. Here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我给你这个，拿着吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我給你這個，拿著吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00682",
		linknext = "0120_00684",
		line = 11451,
	},
	["0120_00684"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1081", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“What's... this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……这是……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……這是……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00683",
		linknext = "0120_00685",
		line = 11465,
	},
	["0120_00685"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's a photo of all of us. Asa printed it for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是照片，大家一起照的。麻沙酱帮我洗出来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是照片，大家一起照的。麻沙醬幫我洗出來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00684",
		linknext = "0120_00686",
		line = 11477,
	},
	["0120_00686"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00116", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"cgact", file="cgact", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1752", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ha! I only did that 'cos you asked me to...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哼，是你拜托我我才做的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哼，是你拜託我我才做的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00685",
		linknext = "0120_00687",
		line = 11491,
	},
	["0120_00687"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It probably won't take up much space. Can you take it with you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想这不会占用什么空间，能带走吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想這不會佔用什麼空間，能帶走嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00686",
		linknext = "0120_00688",
		line = 11503,
	},
	["0120_00688"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00107", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
