	["0120_00693"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a204"},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00119", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
