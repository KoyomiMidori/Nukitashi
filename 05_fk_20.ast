	["0120_00427"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The OSS should be on their way by now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明就算SHO已经聚集过来了也不奇怪——",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明就算SHO已經聚集過來了也不奇怪——",
					{"rt2"},
