		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=16, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=-300, y=0},
		{"cgact", file="cgact", id=15, act="移動", x=395, y=-5, time=50000, lv=5},
		{"cgact", file="cgact", id=15, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5, x=395, y=-5},
		{"fgact", ch="桐香", id=16, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0858", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But why? The object of your hatred is the islanders, not the law itself, is it not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“为什么？你恨的应该是岛上的人，而不是变态条例。到底为什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「為什麼？你恨的應該是島上的人，而不是變態條例。到底為什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00341",
		linknext = "0120_00343",
		line = 5940,
	},
	["0120_00343"] = {
		{"se", id=0, loop=0, file="se_a020"},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=17, file="bg08_3l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, style="blur", blurx=25, blury=1, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"bg", id=18, file="jci_m01030201", x=-305, y=-5, path=":cg/jci_m/", lv=5, ev=1, time=300, bx=800, by=450},
		{"cgact", file="cgact", id=17, act="移動", x=95, y=-5, time=10000, lv=5},
		{"cgact", file="cgact", id=17, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5, x=95, y=-5},
		{"cgact", file="cgact", id=18, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5, x=-305, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, the law's still crazy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为这是错误的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為這是錯誤的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00342",
		linknext = "0120_00344",
		line = 5959,
	},
	["0120_00344"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I still don't have an opening to score a decisive attack and claim victory.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是无法决出胜负。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是無法決出勝負。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00343",
		linknext = "0120_00345",
		line = 5969,
	},
	["0120_00345"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And given her counterattack, which she also used the last time I got near her, I can't carelessly close in on her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且如果勉强接近的话，还有刚才的反击技，我不能轻易靠近——",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且如果勉強接近的話，還有剛才的反擊技，我不能輕易靠近——",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00344",
		linknext = "0120_00346",
		line = 5979,
	},
	["0120_00346"] = {
		{"se", id=0, loop=0, file="se_a020"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgact", file="cgact", id=17, act="stopact", lv=5, x=95, y=-5},
		{"cgdel", id=17, lv=5, time=300, alphadel=1},
		{"cgact", file="cgact", id=18, act="stopact", lv=5, x=-305, y=-5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=18, file="pm3_00001", x=0, y=0, path=":cg/pm3/", ev=1, time=1, lv=5, ax=1250, ay=455, bx=-450, by=-5},
		{"cgact", file="cgact", id=15, act="stopact", lv=5, x=395, y=-5},
		{"cgdel", id=15, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"fgact", id=16, ch="桐香", act="stopact"},
