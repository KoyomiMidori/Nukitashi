	["0120_00610"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"bg", id=1, file="bg01_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0258", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I'll ask you once more, young man. Will you not become my right hand? We can rule the world together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我再问一次，少年。你想成为我的左右手吗？一起得到国家吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我再問一次，少年。你想成為我的左右手嗎？一起得到國家吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00609",
		linknext = "0120_00611",
		line = 10307,
	},
	["0120_00611"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Blow me. You don't speak for the majority! You're causing nothing but harm!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我拒绝。吵闹的少数派对你来说不过是危害罢了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我拒絕。吵鬧的少數派對你來說不過是危害罷了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00610",
		linknext = "0120_00612",
		line = 10319,
	},
	["0120_00612"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0259", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But are you not a minority in the eyes of this island yourself, seeking to do battle?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但你不是在战斗吗？作为这个岛上的少数群体。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但你不是在戰鬥嗎？作為這個島上的少數群體。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00611",
		linknext = "0120_00613",
		line = 10331,
	},
	["0120_00613"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When the tyranny of numbers is connected to sexual violence, protecting yourself is a matter of course!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然数量的暴力和性暴力扯上了关系，那保护自己是理所当然的事情吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然數量的暴力和性暴力扯上了關係，那保護自己是理所當然的事情吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00612",
		linknext = "0120_00614",
		line = 10343,
	},
	["0120_00614"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
