		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=16, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=-300, y=0},
		{"cgact", file="cgact", id=15, act="移動", x=395, y=-5, time=50000, lv=5},
		{"cgact", file="cgact", id=15, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5, x=395, y=-5},
		{"fgact", ch="桐香", id=16, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0859", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“How so? This island plies its trade on sex. What is so crazy about acknowledging the fact that men and women commit to such an act?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哪里有错呢？靠性来维持生计的岛。只是认可男女间的性行为，这样就是错误的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哪裡有錯呢？靠性來維持生計的島。只是認可男女間的性行為，這樣就是錯誤的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00345",
		linknext = "0120_00347",
		line = 6006,
	},
	["0120_00347"] = {
		{"se", id=0, loop=0, file="se_a020"},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="jci_m01030201", x=-405, y=-5, path=":cg/jci_m/", lv=5, ev=1, time=300, bx=800, by=450},
		{"bg", id=17, file="bg08_3l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, style="blur", blurx=25, blury=1, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=17, act="移動", x=95, y=-5, time=10000, lv=5},
		{"cgact", file="cgact", id=17, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5, x=95, y=-5},
		{"cgact", file="cgact", id=18, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5, x=-405, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What about gays and lesbians, huh? People who are oppressed and persecuted just for existing! Like my own sister!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么同性恋者会怎样呢——！？光是存在就会受到迫害的人，我的妹妹怎么办呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼同性戀者會怎樣呢——！？光是存在就會受到迫害的人，我的妹妹怎麼辦呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00346",
		linknext = "0120_00348",
		line = 6025,
	},
	["0120_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You assholes aren't doing anything but rejecting minorities and exploiting people in the name of your utilitarian fantasy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你们所做的，终究只是对少数群体的否定和功利主义的榨取！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你們所做的，終究只是對少數群體的否定和功利主義的榨取！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00347",
		linknext = "0120_00349",
		line = 6036,
	},
	["0120_00349"] = {
