		{"bg", id=13, file="system_sonar_00000", x=-660, y=38, lv=5, path=":bg/", sync=0, ev=1, time=300, clip="5,91,290,814", ax=145, ay=493, bx=655, by=-43},
		{"cgact", file="cgact", id=13, act="汎用アクション", rotate=360, time=3000, loop=-1, ease="none", lv=5},
		{"text"},
		text = {
			ja = {
