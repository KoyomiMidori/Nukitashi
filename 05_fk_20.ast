		{"fgact", ch="美岬", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2075", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Heh heh, I was told their locks were pretty much impossible to crack, so I figured, what the hell, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿，听说要解除保安锁几乎是不可能的，所以我就想说机会难得要试试看……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿，聽說要解除保安鎖幾乎是不可能的，所以我就想說機會難得要試試看……」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00406",
		linknext = "0120_00408",
		line = 7068,
	},
	["0120_00408"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1742", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well, once the security's down, every alarm in the place's gonna be going off anyway, so make all the noise you want, I guess...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“反正不管引起了怎样的骚动，也都跟解除安全系统后警报响起一样……这样也没差吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「反正不管引起了怎樣的騷動，也都跟解除安全系統後警報響起一樣……這樣也沒差吧……？」",
					{"rt2"},
				},
			},
		},
