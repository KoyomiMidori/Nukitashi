				{"bg", id=1, time=300, file="bg08_3_00000", path=":bg/", zone="0x919fab", ax=805, ay=455, bx=-5, by=-5},
				{"fg", ch="桐香", id=8, time=300, mode=3, path=":fg/touka_01m/", file="touka_01m_00001", size="m", file1="touka_01m_00110", head="touka_01m", lv=5},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just hope you weren't too bored waiting for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……让你久等了，无聊了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……讓你久等了，無聊了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00259",
		linknext = "0120_00261",
		line = 4382,
	},
	["0120_00261"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0851", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, no. I never dreamed waiting for you would be so much fun... I feel like I'm walking on cloud nine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“等待的时间居然如此快乐……这是多么幸福的事啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「等待的時間居然如此快樂……這是多麼幸福的事啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00260",
		linknext = "0120_00262",
		line = 4396,
	},
	["0120_00262"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, allow me to take your head out of the clouds. Prepare for the first defeat of your life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——那么，我就把人生第一次的失败作为礼物送给你吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——那麼，我就把人生第一次的失敗作為禮物送給你吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00261",
		linknext = "0120_00263",
		line = 4408,
	},
	["0120_00263"] = {
