					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you think for a second that extrapolating that analogy to what goes on in people's bedrooms is going to sit well with others!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“连做爱时的娇喘都能听到怎么可能受得了啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「連做愛時的嬌喘都能聽到怎麼可能受得了啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00351",
