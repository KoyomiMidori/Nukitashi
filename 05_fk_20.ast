		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn it... Nanase, head for a classroom! Jump out the window to get behind the school building, and we'll face them head-on once we reunite!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“切——奈奈濑！进教室！从窗户跳到教学楼后面，汇合后正面突破！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嘖——奈奈瀨！進教室！從窗戶跳到校舍後面，會合後正面突破！」",
					{"rt2"},
				},
			},
		},
