				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fuck outta here with that! You're just enforcing your own idea of what the mainstream is!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“强迫大家成为多数派的人是在说什么啊——！”",
