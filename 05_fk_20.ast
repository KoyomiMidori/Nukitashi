		{"bg", id=20, file="be4_00003", x=0, y=0, path=":cg/be4/", ev=1, time=100, rule="eff_008_00000", lv=5, ax=822, ay=465, bx=-22, by=-15},
		{"cgact", file="cgact", id=20, act="浮遊横", loop=4, size=15, time=50, ease="easeinout_sine", lv=5, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since my gun's been knocked down as well, we're fighting more or less as equals now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为我的手枪子弹也会被击落，所以作为招数几乎势均力敌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為我的手槍子彈也會被擊落，所以作為招數幾乎勢均力敵。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00340",
		linknext = "0120_00342",
		line = 5910,
	},
	["0120_00342"] = {
		{"se", id=0, loop=0, file="se_a020"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=20, time=100, alphadel=1, evmaskoff=1, lv=5},
