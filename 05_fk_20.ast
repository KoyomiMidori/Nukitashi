		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki, get a move on! I'll hold her off somehow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“美岬，快走！这里我来想办法——！”",
