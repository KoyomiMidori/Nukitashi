					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Aiming right for a vital point. Not bad. But you lose points for being too obvious. It seems Tadasugawa still has much to teach you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“毫不犹豫地对准要害是不错，但太显而易见要扣分。糺川的教育好像还差得远呢——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「毫不猶豫地對準要害是不錯，但太顯而易見要扣分。糺川的教育好像還差得遠呢——！」",
					{"rt2"},
				},
			},
		},
