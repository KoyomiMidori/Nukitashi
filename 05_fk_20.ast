		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2073", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“W-We've got a flat front tire! Where'd that shot come from!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“前、前轮爆胎了……！？从哪里来的攻击——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「前、前輪爆胎了……！？從哪裡來的攻擊——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00246",
		linknext = "0120_00248",
		line = 4186,
	},
	["0120_00248"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1740", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What? My radar's drawing a blank! We're too deep in the mountains to—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶？可是雷达什么反应都没有啊……！？在这样的深山里……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸？可是雷達什麼反應都沒有啊……！？在這樣的深山裡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00247",
		linknext = "0120_00249",
		line = 4200,
	},
	["0120_00249"] = {
