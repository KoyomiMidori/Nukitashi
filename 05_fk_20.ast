	["0120_00621"] = {
		{"bg", id=1, file="bg01_3l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0262", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“What a pity. You are overflowing with potential. Your hidden power is a gift that you could make good use of.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是很遗憾……你身上充满了可能性。才华横溢，还拥有隐藏的力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是很遺憾……你身上充滿了可能性。才華橫溢，還擁有隱藏的力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00620",
		linknext = "0120_00622",
		line = 10463,
	},
	["0120_00622"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0263", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Don't you want to be a real man, with power and dominion over the world?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“作为男人，难道不想得到世界吗，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「作為男人，難道不想得到世界嗎，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00621",
		linknext = "0120_00623",
		line = 10477,
	},
	["0120_00623"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And end up losing everyone I love in return, just like you!? Fuck that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不想为了那个……而成为失去重要家人的男人……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不想為了那個……而成為失去重要家人的男人……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00622",
		linknext = "0120_00624",
		line = 10489,
	},
	["0120_00624"] = {
