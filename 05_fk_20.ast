	["0120_00118"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1737", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Enemy genitals approaching from 12 o'clock. Eight in number, equipped with SS handguns. They have permission to fire. Assumed to be second squad, class two division.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“敌性器从12点钟方向接近中。数量8，装备FS式手枪。已获准开枪。预测是二队二班。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「敵性器從12點鐘方向接近中。數量8，裝備FS式手槍。已獲准開槍。預測是二隊二班。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00117",
		linknext = "0120_00119",
		line = 1878,
	},
	["0120_00119"] = {
