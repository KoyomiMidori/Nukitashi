			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Whatcha got, a new weapon!? Wait... it's just a wig... and a yukata?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦？是新武器吗！？呃，这是……假发和浴衣……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦？是新武器嗎！？呃，這是……假髮和浴衣……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00066",
		linknext = "0120_00068",
		line = 990,
	},
	["0120_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry to dash your expectations, but considering you and Fumino are pretty similar in height, they won't be able to tell you apart from afar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“抱歉是便宜的东西，渡酱和文乃的个子几乎一样，如果从远处看是不会被发现的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「抱歉是便宜的東西，渡醬和文乃的個子幾乎一樣，如果從遠處看是不會被發現的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00067",
		linknext = "0120_00069",
		line = 1002,
	},
	["0120_00069"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, should the need arise, we'll have you act as a decoy. Hope you can handle that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以……如果遇到了特殊情况，要请你充当诱饵。不好意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以……如果遇到了特殊情況，要請你充當誘餌。不好意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00068",
		linknext = "0120_00070",
		line = 1014,
	},
