					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Still hiding things from me? You are a most fascinating man!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你还藏着什么吗？真的是个非常有趣的人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你還藏著什麼嗎？真的是個非常有趣的人——」",
