		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Follow Nanase and Wata, they're leading! Take Fumino and Asa with you, by force if necessary! I'm gonna be running right behind you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑和渡酱已经走在前面了，即使逞强也要载着文乃和麻沙酱一起追上去！我用跑的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨和渡醬已經走在前面了，即使逞強也要載著文乃和麻沙醬一起追上去！我用跑的！」",
					{"rt2"},
				},
			},
		},
