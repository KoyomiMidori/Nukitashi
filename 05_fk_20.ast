	["0120_00691"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"se", id=1, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rushed as I am, I hold the photo out to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使被催促了，我还是把照片递给了文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使被催促了，我還是把照片遞給了文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00690",
		linknext = "0120_00692",
		line = 11558,
	},
	["0120_00692"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00113", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
