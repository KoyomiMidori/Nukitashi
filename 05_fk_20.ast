		linkback = "0120_00253",
		linknext = "0120_00255",
		line = 4294,
	},
	["0120_00255"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00112", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1741", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“B-Bro, you'd need a death wish to take her on yourself! You don't have any information coming through on her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可、可是哥哥，一个人对抗学生会长绝对很危险哦……！？几乎没有任何情报……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可、可是哥哥，一個人對抗學生會長絕對很危險哦……！？幾乎沒有任何情報……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00254",
		linknext = "0120_00256",
		line = 4307,
	},
	["0120_00256"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If she gets the other wheel on your bike, they'll catch up to you! Our primary objective is to deliver Fumino to extraction! Don't forget that, Asane!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果连后轮都被弄爆会被追上的！麻沙音，别忘记把文乃送出去才是最优先的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果連後輪都被弄爆會被追上的！麻沙音，別忘記把文乃送出去才是最優先的！」",
					{"rt2"},
				},
			},
		},
