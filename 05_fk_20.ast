		linknext = "0120_00166",
		line = 2670,
	},
	["0120_00166"] = {
		{"fg", file="ikuko_01l_00001", file1="ikuko_01l_00101", path=":fg/ikuko_01l/", id=10, lv=5, head="ikuko_01l", ch="郁子", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0628", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I always knew, actually! It was like, ding! Big lightbulb moment ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“其实一开始我就想起来了呢〜♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「其實一開始我就想起來了呢〜♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00165",
		linknext = "0120_00167",
		line = 2685,
	},
	["0120_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Some time for you to desert your team! You're supposed to be trying to capture Fumino, aren't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是了不起的忠诚心啊……！逮捕文乃应该是你的工作吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是了不起的忠誠心啊……！逮捕文乃應該是你的工作吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00166",
		linknext = "0120_00168",
		line = 2697,
	},
	["0120_00168"] = {
		{"fg", file="ikuko_01l_00001", file1="ikuko_01l_00121", path=":fg/ikuko_01l/", id=10, lv=5, head="ikuko_01l", ch="郁子", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0629", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Honestly, I don't really give a shit about that Fumino girl, you dig? I figure I'll just let the first squad strike team have their fun catching her, and I'll have mine ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“叫文乃的女孩子什么的，老实说郁并不怎么感兴趣。强袭一队的孩子们会帮我抓到吧〜♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「叫文乃的女孩子什麼的，老實說郁並不怎麼感興趣。強襲一隊的孩子們會幫我抓到吧〜♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00167",
		linknext = "0120_00169",
		line = 2711,
	},
