	["0120_00253"] = {
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
