		{"cgact", file="cgact", id=15, act="移動", x=395, y=-5, time=50000, lv=5},
		{"cgact", file="cgact", id=15, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5, x=395, y=-5},
		{"fgact", ch="桐香", id=16, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0860", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“From a commercial standpoint, you more or less need to start from the mainstream, do you not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“商业主义或大或小都是从主流的形成开始的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「商業主義或大或小都是從主流的形成開始的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00348",
		linknext = "0120_00350",
		line = 6063,
	},
	["0120_00350"] = {
