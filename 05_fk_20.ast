	["0120_00607"] = {
		{"fg", file="hitoura_01l_00001", file1="hitoura_01l_00116", path=":fg/hitoura_01l/", id=10, lv=5, head="hitoura_01l", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0257", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Crossing swords and pushing me back is certainly decent strategy. But you're not good enough to put me down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“剑术中存在着所谓的短兵相接。冲入怀中的想法很好，但知识不足。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「劍術中存在著所謂的短兵相接。衝入懷中的想法很好，但知識不足。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00606",
