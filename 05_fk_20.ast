	["0120_00425"] = {
		{"se", id=0, loop=0, file="se_a003"},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=50},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We encountered a handful of guards on the night watch, but they were no problem to deal with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然遇到了几名惊慌失措的夜班人员，但让他们无力化没花多少力气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然遇到了幾名驚慌失措的夜班人員，但讓他們無力化沒花多少力氣。",
					{"rt2"},
				},
			},
