				{"vo", file="touka0850", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Heh, good evening, Tachibana. I anticipated your arrival here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵！晚上好前辈，我在这里埋伏你了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵！晚上好前輩，我在這裡埋伏你了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00252",
		linknext = "0120_00254",
		line = 4279,
	},
	["0120_00254"] = {
