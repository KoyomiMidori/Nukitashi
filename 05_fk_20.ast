		{"bg", id=20, file="be0_00001", x=0, y=0, path=":cg/be0/", ev=1, time=200, rule="eff_017_00000", lv=5, ax=822, ay=465, bx=-22, by=-15},
		{"cgact", file="cgact", id=20, act="浮遊横", loop=6, size=12.5, time=50, ease="easeinout_sine", lv=5, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I keep that spot concealed, I can avoid blacking out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那只要保护好这里，我就能防止失去意识。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那只要保護好這裡，我就能防止失去意識。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00339",
