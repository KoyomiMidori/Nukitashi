				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“When battling a mobile opponent one on one, targeting their legs is effective. Remember that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果是和灵活的对手一对一，瞄准对方的腿也是很有效的。记住。”",
