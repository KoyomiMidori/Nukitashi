		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=700, rule="eff_033_00000"},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bgm", file="bgm16", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. First of all, let's go over your strategy, Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那么，现在就来复习奈奈濑的作战计划。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那麼，現在就來複習奈奈瀨的作戰計劃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00044",
		linknext = "0120_00046",
		line = 702,
	},
	["0120_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You'll be on standby until 1845 hours. Right before they close up the rear gate, you head for the OSS HQ.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从现在开始待机到18:45。等到后门快关门的时候，就直接去SHO总部。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從現在開始待機到18:45。等到後門快關門的時候，就直接去SHO總部。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00045",
		linknext = "0120_00047",
		line = 714,
	},
	["0120_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Once you're off the school grounds, head for the beach. It'll be just before dusk, so use the chance to commandeer a boat. Hotori, you'll be designated driver. Can you do that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“离开学校后就去海滩。傍晚的瞬间，在短时间内夺取小船，让畔操纵……办得到吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「離開學校後就去海灘。傍晚的瞬間，在短時間內奪取小船，讓畔操縱……辦得到吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00046",
		linknext = "0120_00048",
		line = 726,
	},
	["0120_00048"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=3, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="美岬", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2066", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes! My father taught me how to use one ages ago, but I never thought it'd come in handy now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的。以前爸爸教过我，没想到会在这种时候派上用场……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的。以前爸爸教過我，沒想到會在這種時候派上用場……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00047",
		linknext = "0120_00049",
		line = 741,
	},
	["0120_00049"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", file2="asane_01m_00202", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1733", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Still, Bro... Even if we make it to OSS HQ, getting in isn't exactly gonna be a walk in the park. There'll probably be guards everywhere... Is this gonna work?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是哥哥……即使到了SHO总部，也很难就那样入侵吧……？那里的人应该也很多……不要紧吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是哥哥……即使到了SHO總部，也很難就那樣入侵吧……？那裡的人應該也很多……不要緊吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00048",
		linknext = "0120_00050",
		line = 755,
	},
	["0120_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sakimori said he'd do something about that. Not sure what exactly, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“关于减少那里的人数，据说防人老人会帮点什么忙。虽然不知道他会怎么做——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「關於減少那裡的人數，據說防人老人會幫點什麼忙。雖然不知道他會怎麼做——」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00049",
		linknext = "0120_00051",
		line = 767,
	},
	["0120_00051"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, once we're in, we'll split into two teams. One team of me and Nanase, the other with everyone else.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们要在SHO总部里分成两队，我和奈奈濑的两队。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們要在SHO總部裡分成兩隊，我和奈奈瀨的兩隊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00050",
		linknext = "0120_00052",
		line = 779,
	},
	["0120_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're gonna scout on ahead and take them from behind and from the flanks. Cleanup duty for their remaining firepower, essentially.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑队先行，从后侧或侧面进行攻击。我们则负责收拾残存的敌人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨隊先行，從後側或側面進行攻擊。我們則負責收拾殘存的敵人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00051",
		linknext = "0120_00053",
		line = 790,
	},
	["0120_00053"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2197", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But Tachibana, complicated stuff aside, didn't you say it would be hard to fight with you and Nanase being apart?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是橘君，虽然对我来说有点难，所以不是很清楚，不过你不是说过橘君和奈奈濑酱分开的话，会很难战斗吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是橘君，雖然對我來說有點難，所以不是很清楚，不過你不是說過橘君和奈奈瀨醬分開的話，會很難戰鬥嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00052",
		linknext = "0120_00054",
		line = 804,
	},
	["0120_00054"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I haven't forgotten about that. We have a new weapon to make do with, no matter how far apart we are. Hotori, take these.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这一点我并没有看漏。不管我和奈奈濑的距离有多远，都有‘新型武器’……畔，你拿着这个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這一點我並沒有看漏。不管我和奈奈瀨的距離有多遠，都有『新型武器』……畔，你拿著這個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00053",
		linknext = "0120_00055",
		line = 817,
	},
	["0120_00055"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=3, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="美岬", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2200] = {
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00104", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=3, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=2200, time=300, mode=3, x=200, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2067", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“These glasses are...! Understood. I've mastered the practice! You can count on me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这个眼镜是……我知道了！训练方面没有问题，所以随时都可以交给我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這個眼鏡是……我知道了！訓練方面沒有問題，所以隨時都可以交給我！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00054",
		linknext = "0120_00056",
		line = 834,
	},
	["0120_00056"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Glad to hear it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你，期待你的表现。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你，期待你的表現。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00055",
		linknext = "0120_00057",
		line = 846,
	},
	["0120_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Given the nature of this operation, I'd like you to take Fumino with you. While she's a sniper, this time around you'll be providing intermediate-range support.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后由于这次作战的性质，还要带上文乃。虽然文乃本来是狙击手，但这次应该会以中距离的支援为主。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後由於這次作戰的性質，還要帶上文乃。雖然文乃本來是狙擊手，但這次應該會以中距離的支援為主。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00056",
		linknext = "0120_00058",
		line = 858,
	},
	["0120_00058"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Take these, Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有，文乃拿着这个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有，文乃拿著這個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00057",
		linknext = "0120_00059",
		line = 872,
	},
	["0120_00059"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_b056", vol=50},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hand her two packages of riot bullets for her sniper rifle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我递给文乃两种狙击用的防暴弹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我遞給文乃兩種狙擊用的防暴彈。",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00058",
		linknext = "0120_00060",
		line = 884,
	},
	["0120_00060"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“One of those boxes has your typical riot bullets. The other one... that's the pretty Betty. They're recovery bullets.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“攻击用防暴弹，还有另一种是——恢复用的子弹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「攻擊用防暴彈，還有另一種是——恢復用的子彈。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00059",
		linknext = "0120_00061",
		line = 896,
	},
	["0120_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They're filled with the same cocktail of painkillers as the recovery Eggs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“里面含有与‘Egg’相同的镇痛成分。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「裡面含有與『Egg』相同的鎮痛成分。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00060",
		linknext = "0120_00062",
		line = 907,
	},
	["0120_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They're tipped with a needle which retracts when fired, and the drugs are administered via injection that way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“结构是在发射后弹出针，向肌肉注射药物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「結構是在發射後彈出針，向肌肉注射藥物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00061",
		linknext = "0120_00063",
		line = 919,
	},
	["0120_00063"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They'll probably come in handy if one of us gets injured. Can I count on you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果我们受伤了……能拜托你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果我們受傷了……能拜託你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00062",
		linknext = "0120_00064",
		line = 931,
	},
	["0120_00064"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1062", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But of course. My divine orb of protection shall be with you all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……交给文乃吧。以宝珠的保佑之名，必将守护各位。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……交給文乃吧。以寶珠的保佑之名，必將守護各位。」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00063",
		linknext = "0120_00065",
		line = 946,
	},
	["0120_00065"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
