		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase, stay within the smoke screen and use your condoms to take out the guys in the rear! We'll split up here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑拿着安全套从烟雾中冲进去。把后排打倒，截断他们——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨拿著保險套從煙霧中衝進去。把後排打倒，截斷他們——！」",
					{"rt2"},
				},
			},
		},
