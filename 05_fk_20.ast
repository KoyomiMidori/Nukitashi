			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes, thank you... Junnosuke... Asane... truly...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……好的，谢谢……淳之介同学……麻沙音同学……真的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……好的，謝謝……淳之介同學……麻沙音同學……真的……」",
					{"rt2"},
				},
			},
		},
