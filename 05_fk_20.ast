	["0120_00197"] = {
		{"se", id=0, loop=0, file="se_b032"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0201", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "FS女学生D"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Female SS Student D"},
					"“This is second squad, teams B and C! Everyone save for me has been eliminated! What do I do!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "FS女学生D"},
					"“这里是二队B、C班！除了我以外全军覆没了！怎么办！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "FS女學生D"},
					"「這裡是二隊B、C班！除了我以外全軍覆沒了！怎麼辦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00196",
		linknext = "0120_00198",
		line = 3244,
	},
	["0120_00198"] = {
		{"se", id=0, loop=0, file="se_b032"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0306", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "FS女学生E"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female SS Student E"},
					"“C-Commander Onabuta's down! They did a number on her! Squad Commander, what should we do next!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "FS女学生E"},
					"“女、女部田中队长倒了！被打倒了！大队长怎么办！？",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "FS女學生E"},
					"「女、女部田中隊長倒了！被打倒了！大隊長怎麼辦！？",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00197",
		linknext = "0120_00199",
		line = 3257,
	},
	["0120_00199"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00103", file2="rei_01f_00202", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1146", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Both of you calm down! Support unit, go to assist teams B and C at once! Deputy commander, take charge of the strike force! All others, head for the courtyard!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你们冷静下来！支援部队，前去救援B、C班！强袭部队把指挥权移交给副队长！剩下的人快来操场！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你們冷靜下來！支援部隊，前去救援B、C班！強襲部隊把指揮權移交給副隊長！剩下的人快來操場！」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00198",
		linknext = "0120_00200",
		line = 3270,
	},
	["0120_00200"] = {
