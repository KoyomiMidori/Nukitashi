			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“More insolence. You're quite the pain in my ass, boy. Would you not agree, young lady?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“真能说啊。真是个难对付的小子……你一定也这么想吧，在那里的少女？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「真能說啊。真是個難對付的小子……你一定也這麼想吧，在那裡的少女？」",
					{"rt2"},
				},
			},
		},
