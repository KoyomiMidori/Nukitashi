		{"se", id=0, loop=0, file="se_a035"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Slowly turning to my left, who should step out of the shadows but...",
