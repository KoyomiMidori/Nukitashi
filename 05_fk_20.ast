			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So, your rights regarding freedom to engage in carnal activity how you like, when you like— you are content with having them taken away?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那么就可以允许自己失去权利吗，对自己的性，与性相关的自由呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那麼就可以允許自己失去權利嗎，對自己的性，與性相關的自由呢？」",
					{"rt2"},
				},
			},
		},
