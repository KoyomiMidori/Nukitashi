		{"cgact", file="cgact", id=1, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0627", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Gosh, it's been a while since I've pinned you down like this. The first time would've been during SS training... no, the battle at the hillside, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“好久没有这样压制你了〜……第一次不是在FS的训练……而是在后山战斗的时候吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「好久沒有這樣壓制你了〜……第一次不是在FS的訓練……而是在後山戰鬥的時候吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0120_00163",
