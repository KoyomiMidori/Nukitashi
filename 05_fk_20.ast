				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How'd you figure all that out?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你什么时候开始注意到的——？”",
