			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gonna help out the SS with work stuff. There's evidently a shortage of OSS guards on weekends, so they get the recruits to help out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天是去帮忙FS的工作。休息日SHO警卫的数量不足，所以训练生好像也出动了。”",
					{"rt2"},
				},
			},
