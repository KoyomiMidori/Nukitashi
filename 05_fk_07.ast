				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So, uh, what kind of business are you here for? Are you with some kind of tourism company or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃，手嶋先生是来青蓝岛做什么工作的……？旅游公司吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃，手嶋先生是來青藍島做什麼工作的……？旅遊公司嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00151",
		linknext = "0107_00153",
		line = 2086,
	},
	["0107_00153"] = {
