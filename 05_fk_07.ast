				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, this island is certainly crazy. But don't forget, people like us exist here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，这的确是个疯狂的岛，但也请不要忘记有像我们这样的人……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，這的確是個瘋狂的島，但也請不要忘記有像我們這樣的人……！」",
					{"rt2"},
				},
			},
		},
