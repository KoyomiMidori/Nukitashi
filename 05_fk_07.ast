					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「而且這樣的發言會引起性功能障礙歧視問題。作為FS要小心自己的言行……你快去跟她打個招呼，叫別的FS過來！」",
					{"rt2"},
				},
			},
		},
