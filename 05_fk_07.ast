		{"fg", file="jun_01f_00002", file1="jun_01f_00127", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Siiiigh... I'm beat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈啊啊啊啊啊啊啊……累死了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈啊啊啊啊啊啊啊……累死了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00191",
		linknext = "0107_00193",
		line = 2658,
	},
	["0107_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I spent half the day as the disciplinary committee president's dogbody, dealing with random violence and directing tourists and whatnot.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这半天受到了风纪委员长的任意指使，为了暴力事件或观光导览什么的忙得不可开交。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這半天受到了風紀委員長的任意指使，為了暴力事件或觀光導覽什麼的忙得不可開交。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00192",
		linknext = "0107_00194",
		line = 2668,
	},
	["0107_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sun had completely set by the time I was finally released.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直到夕阳完全西沉之后，才终于被解放了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直到夕陽完全西沉之後，才終於被解放了。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00193",
		linknext = "0107_00195",
		line = 2678,
	},
	["0107_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then I hurriedly ate dinner, and didn't even have time to sit and rest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后还要忙着吃晚饭，到现在连放松坐下的时间都没有。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後還要忙著吃晚飯，到現在連放鬆坐下的時間都沒有。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00194",
		linknext = "0107_00196",
		line = 2688,
	},
	["0107_00196"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So this is what the SS does every day... They're nothing if not a capable lot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS的家伙们，几乎每天都做这种事吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS的傢伙們，幾乎每天都做這種事嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00195",
		linknext = "0107_00197",
		line = 2700,
	},
	["0107_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm not surprised they're as strong as they are now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么一想，他们体力好是理所当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼一想，他們體力好是理所當然的。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00196",
		linknext = "0107_00198",
		line = 2710,
	},
	["0107_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then there's the person directing them — the disciplinary committee president — who manages to be cognizant of the whole squad at all times.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有指挥的人——风纪委员长——对所有部队的情况都了如指掌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有指揮的人——風紀委員長——對所有部隊的情況都瞭如指掌。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00197",
		linknext = "0107_00199",
		line = 2720,
	},
	["0107_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why they can act when confronted with sudden combat without their lines of communication being interrupted, and act in a systematic fashion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此，即使是在紧急的战斗中，联络系统也不会发生动摇，能够有组织地行动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此，即使是在緊急的戰鬥中，聯絡系統也不會發生動搖，能夠有組織地行動。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00198",
		linknext = "0107_00200",
		line = 2730,
	},
	["0107_00200"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right now, we aren't capable enough for that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们现在正是缺少这个啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們現在正是缺少這個啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00199",
		linknext = "0107_00201",
		line = 2742,
	},
	["0107_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I need to be able to divide up the roles and mobilize us as a team.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们必须分配好工作，作为团队行动起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們必須分配好工作，作為團隊行動起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00200",
		linknext = "0107_00202",
		line = 2752,
	},
	["0107_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My regular lifting isn't gonna cut it here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这不是我一个人锻炼肌肉就能办到的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這不是我一個人鍛煉肌肉就能辦到的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00201",
		linknext = "0107_00203",
		line = 2762,
	},
	["0107_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a lot I need to take into consideration about the NLNS for it to happen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，NLNS还有很多需要检讨的问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，NLNS還有很多需要檢討的問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00202",
		linknext = "0107_00204",
		line = 2772,
	},
	["0107_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pretty goddamn complicated shit, to be honest. It kind of gives me a headache thinking about it...",
					{"rt2"},
				},
			},
			cn = {
				{
					"光想想就头痛——",
					{"rt2"},
				},
			},
			tw = {
				{
					"光想想就頭痛——",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00203",
		linknext = "0107_00205",
		line = 2782,
	},
	["0107_00205"] = {
