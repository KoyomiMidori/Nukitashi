	["0107_00279"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She still remains an enigma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟吹子身上有太多谜团了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟吹子身上有太多謎團了——",
					{"rt2"},
