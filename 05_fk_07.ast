		linkback = "0107_00139",
		linknext = "0107_00141",
		line = 1931,
	},
	["0107_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I must ask you to be careful. Refusing requests for procreational acts on this island is generally not permitted.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请小心。因为岛上基本上是不能拒绝性产行为的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請小心。因為島上基本上是不能拒絕性產行為的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00140",
		linknext = "0107_00142",
		line = 1943,
	},
	["0107_00142"] = {
