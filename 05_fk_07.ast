	["0107_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, I'm so touched that a person who's on the same wavelength has shown up (and for some reason, so is Hotori).",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也（不知道为什么畔也）因为谈得来的人物突然出现而激动了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也（不知道為什麼畔也）因為談得來的人物突然出現而激動了。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00164",
		linknext = "0107_00166",
		line = 2258,
	},
	["0107_00166"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00102", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0236", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I've been really down ever since I set foot on this crazy island, but knowing there's kids like you here really brightens my spirits!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“来到这么奇怪的岛其实让我很不安……但如果有像你们这样的人在我就放心多了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「來到這麼奇怪的島其實讓我很不安……但如果有像你們這樣的人在我就放心多了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00165",
		linknext = "0107_00167",
		line = 2272,
	},
	["0107_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
