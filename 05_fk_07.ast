	["0107_00158"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0233", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Uh, yeah. The company said this is a sex island, so I came here to make sales pitches for our products, but... haha, the people here don't need them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嗯、嗯……公司跟我说因为这里是色情的岛，所以要我来这里创造需求……哈哈，但是这个岛的人好像都不需要吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嗯、嗯……公司跟我說因為這裡是色情的島，所以要我來這裡創造需求……哈哈，但是這個島的人好像都不需要吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00157",
		linknext = "0107_00159",
		line = 2165,
	},
	["0107_00159"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
