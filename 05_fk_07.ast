			},
		},
		text = {
			vo = {
				{"vo", file="teshima0228", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“Ahaha, well, pardon me... Uh, are the two of ya's OSS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“啊哈哈，真是不好意思……呃，你们是……SHO的人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「啊哈哈，真是不好意思……呃，你們是……SHO的人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00141",
		linknext = "0107_00143",
		line = 1960,
	},
	["0107_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My name's Tachibana Junnosuke. I'm part of the SS which is an organization that receives scholarship funding from the OSS. And this is...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我叫橘淳之介，是接受SHO奖学金的学生组织FS的人。呃……这位是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我叫橘淳之介，是接受SHO獎學金的學生組織FS的人。呃……這位是……」",
					{"rt2"},
				},
			},
		},
