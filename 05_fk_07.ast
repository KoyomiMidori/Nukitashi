		linkback = "0107_00311",
		linknext = "0107_00313",
		line = 4102,
	},
	["0107_00313"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=2, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0497", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I occasionally take a day off... but normally I go every day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“虽然偶尔也会休息一下……但平常、都有……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「雖然偶爾也會休息一下……但平常、都有……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00312",
		linknext = "0107_00314",
		line = 4116,
	},
	["0107_00314"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then you must go to the same school as me. Minotsuki Academy is the only school on the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那我们就是同一所学校咯？毕竟这个岛只有水乃月学园。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那我們就是同一所學校咯？畢竟這個島只有水乃月學園。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00313",
		linknext = "0107_00315",
		line = 4128,
	},
	["0107_00315"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=2, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0498", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“That's correct...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“是的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「是的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00314",
		linknext = "0107_00316",
		line = 4142,
	},
	["0107_00316"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There must be a story behind the SS chasing you and you saving me. Won't they recognize you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过吹子你为了救我有被FS追杀过吧？没暴露身份吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過吹子你為了救我有被FS追殺過吧？沒暴露身份嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00315",
		linknext = "0107_00317",
		line = 4154,
	},
	["0107_00317"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=2, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, delay2=1500, time=300, mode=2, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0499", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I don't think... that's a problem.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“这……应该没问题、吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「這……應該沒問題、吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00316",
		linknext = "0107_00318",
		line = 4171,
	},
	["0107_00318"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, I get it. The kimono you wear stands out, so it'd be hard to recognize you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，这样啊。身上的和服这么醒目，确实不容易认出脸来呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，這樣啊。身上的和服這麼醒目，確實不容易認出臉來呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00317",
		linknext = "0107_00319",
		line = 4183,
	},
	["0107_00319"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=2, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0500", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Perhaps.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“……也许吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……也許吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00318",
		linknext = "0107_00320",
		line = 4197,
	},
	["0107_00320"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The same as my goggles, then.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和我的护目镜是同样的理论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和我的護目鏡是同樣的理論。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00319",
		linknext = "0107_00321",
		line = 4207,
	},
	["0107_00321"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You look younger than my sister. How old are you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我觉得你比我妹妹小，几年级啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我覺得你比我妹妹小，幾年級啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00320",
		linknext = "0107_00322",
		line = 4219,
	},
	["0107_00322"] = {
		{"text"},
		delay = {
