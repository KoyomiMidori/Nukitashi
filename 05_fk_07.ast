		line = 3370,
	},
	["0107_00253"] = {
		{"fg", file="fumino_01ll_00001", file1="fumino_01ll_00112", path=":fg/fumino_01ll/", id=7, lv=5, head="fumino_01ll", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it's okay now... Yeah, I'm fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……已经没事了……嗯，没事的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……已經沒事了……嗯，沒事的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00252",
		linknext = "0107_00254",
		line = 3384,
	},
	["0107_00254"] = {
		{"se", id=0, loop=0, file="se_a035"},
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahem. Anyway, getting used to a conversation is pretty high-level stuff anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……咳咳，刚刚的是习惯聊天之后的高级技巧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……咳咳，剛剛的是習慣聊天之後的高級技巧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00253",
		linknext = "0107_00255",
		line = 3402,
	},
	["0107_00255"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00116", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0483", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“High-level...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“高级技巧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「高級技巧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00254",
		linknext = "0107_00256",
		line = 3416,
	},
	["0107_00256"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, they say it's normal for beginners to create a discussion from a topic.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错，初学者一般该从怎么制造话题开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯，初學者一般該從怎麼製造話題開始。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00255",
		linknext = "0107_00257",
		line = 3428,
	},
	["0107_00257"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But to be told to create a topic to begin a discussion is problematic. Don't you think so? 'Cos I do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是突然说要制造话题聊天会有点困扰对吧。会困扰吧？是我就会困扰。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是突然說要製造話題聊天會有點困擾對吧。會困擾吧？是我就會困擾。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00256",
		linknext = "0107_00258",
		line = 3440,
	},
	["0107_00258"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0484", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I would have to agree there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“确实如此……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「確實如此……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00257",
		linknext = "0107_00259",
		line = 3454,
	},
	["0107_00259"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“See? To be told out of the blue to talk casually with your classmates for 10 minutes is impossible for a normal person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对吧？如果突然要求说要跟同学们聊上10分钟，一般人通常是不可能做到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對吧？如果突然要求說要跟同學們聊上10分鐘，一般人通常是不可能做到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00258",
		linknext = "0107_00260",
		line = 3466,
	},
	["0107_00260"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“However, there's a method for coping with this. It's called the barrage of questions strategy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是我们有对策，名为……提问攻势作战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是我們有對策，名為……提問攻勢作戰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00259",
		linknext = "0107_00261",
		line = 3478,
	},
	["0107_00261"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00114", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0485", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Barrage... of questions? Asking the other person questions?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“提问、攻势……意思是问对方事情吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「提問、攻勢……意思是問對方事情嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00260",
		linknext = "0107_00262",
		line = 3492,
	},
	["0107_00262"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. If you ask a question, the other person is obliged to answer. You can use that as the link to creating further discussion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，只要提问，对方便不得不回答。之后再从中找出话题来，就能继续聊下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，只要提問，對方便不得不回答。之後再從中找出話題來，就能繼續聊下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00261",
		linknext = "0107_00263",
		line = 3504,
	},
	["0107_00263"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0486", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Indubitably.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“原来原来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「原來原來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00262",
		linknext = "0107_00264",
		line = 3520,
	},
	["0107_00264"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Indubi-what?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……原来？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……原來？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00263",
		linknext = "0107_00265",
		line = 3532,
	},
	["0107_00265"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00111", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0487", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Ah, well... that essentially means, 'I see.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“啊，不……原来如此，原来如此……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「啊，不……原來如此，原來如此……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00264",
		linknext = "0107_00266",
		line = 3547,
	},
	["0107_00266"] = {
		{"se", id=0, loop=0, file="se_a142"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She diligently writes down the details in her notepad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吹子在笔记本上认真记下我说的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吹子在筆記本上認真記下我說的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00265",
		linknext = "0107_00267",
		line = 3558,
	},
	["0107_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I take a peek and see she's written down the joke. I guess she didn't erase it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我偷偷看了一眼，上面还郑重地写着开个小玩笑。可以请你擦掉吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"我偷偷看了一眼，上面還鄭重地寫著開個小玩笑。可以請你擦掉嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00266",
		linknext = "0107_00268",
		line = 3568,
	},
	["0107_00268"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In other words, if you attack them with questions, it keeps the discussion from petering away, and you can seize the initiative. Get it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说通过提问攻势，就能让对话不冷场，还能握住主导权。明白吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說通過提問攻勢，就能讓對話不冷場，還能握住主導權。明白嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00267",
		linknext = "0107_00269",
		line = 3580,
	},
	["0107_00269"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00112", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0488", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“When you say questions... what kind of questions would suffice?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“您说提问……该问些什么比较好呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「您說提問……該問些什麼比較好呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00268",
		linknext = "0107_00270",
		line = 3594,
	},
	["0107_00270"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess... stuff that you can expand on easily, everyday stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……一些容易延伸的内容，比如日常的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……一些容易延伸的內容，比如日常的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00269",
		linknext = "0107_00271",
		line = 3606,
	},
	["0107_00271"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you know a few personal things about them, you can hit them with a barrage of questions and seize victory.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要能多少了解对方的个人资讯，接下来就是主动提问，这样就能掌握胜利。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要能多少了解對方的個人資訊，接下來就是主動提問，這樣就能掌握勝利。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00270",
		linknext = "0107_00272",
		line = 3618,
	},
	["0107_00272"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0489", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Indu... I see... Don't give them an opening, and press the attack...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“原……原来如此……不给反击的机会，封杀对方……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「原……原來如此……不給反擊的機會，封殺對方……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00271",
		linknext = "0107_00273",
		line = 3633,
	},
	["0107_00273"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right, it's a veritable question assault.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，这就是提问攻势。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，這就是提問攻勢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00272",
		linknext = "0107_00274",
		line = 3645,
	},
	["0107_00274"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Discussion is a contest. If you give them an opening, your delay will lead to your defeat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对话即胜负。让对方看到破绽就会败阵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對話即勝負。讓對方看到破綻就會敗陣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00273",
		linknext = "0107_00275",
		line = 3657,
	},
	["0107_00275"] = {
		{"se", id=0, loop=0, file="se_a142"},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=2, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She keeps making short notes and nodding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吹子一边写着笔记一边点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吹子一邊寫著筆記一邊點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00274",
		linknext = "0107_00276",
		line = 3671,
	},
	["0107_00276"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, now let me show you the question assault in action. I'm going to ask you loads of questions, and you answer them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，那我给你示范一下。我会不停地提问，吹子试着回答一下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好，那我給你示範一下。我會不停地提問，吹子試著回答一下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00275",
		linknext = "0107_00277",
		line = 3684,
	},
	["0107_00277"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is a perfect opportunity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对了……这正好是个机会不是吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"對了……這正好是個機會不是嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00276",
		linknext = "0107_00278",
		line = 3697,
	},
	["0107_00278"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are lots of things I want to ask her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我有很多想问她的问题。",
					{"rt2"},
				},
