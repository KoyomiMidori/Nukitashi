		linkback = "0107_00333",
		linknext = "0107_00335",
		line = 4392,
	},
	["0107_00335"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00117", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=4, size=5, time=1000, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0505", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I don't normally... talk to people... this much... so my mouth has gone dry... and I'm starved for oxygen...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“平时、不曾这样……和人说话……所以嘴巴、很干……缺氧……了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「平時、不曾這樣……和人說話……所以嘴巴、很乾……缺氧……了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00334",
		linknext = "0107_00336",
		line = 4407,
	},
	["0107_00336"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00117", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, is it my fault for pressing you with questions!? Let's get you some water!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因、因为我逼迫得太紧了吗——！？总之先喝水，喝水……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因、因為我逼迫得太緊了嗎——！？總之先喝水，喝水……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00335",
		linknext = "0107_00337",
		line = 4420,
	},
	["0107_00337"] = {
