	["0107_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Come to think of it, it's not like I'm particularly good at conversing myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……仔细想想，我也不是特别擅长说话。",
