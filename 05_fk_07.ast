		},
		linkback = "0107_00286",
		linknext = "0107_00288",
		line = 3818,
	},
	["0107_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks away and points somewhere.",
					{"rt2"},
				},
