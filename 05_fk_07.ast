		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, Bob! Do you know why my cucumber is so big?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嘿，鲍勃！你知道我们家的黄瓜为什么这么大吗？”",
