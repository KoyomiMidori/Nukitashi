	},
	["0107_00250"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm much too embarrassed to admit that my social skills are hardly anything to write home about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……现在突然要我坦白自己也是个沟通障碍人士，会让我感到异常羞耻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……現在突然要我坦白自己也是個溝通障礙人士，會讓我感到異常羞恥。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00249",
		linknext = "0107_00251",
		line = 3350,
	},
	["0107_00251"] = {
		{"text"},
		text = {
