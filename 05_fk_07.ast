	["0107_00235"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's because my wife waters it every day. In the nude! Ahahaha!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为我家老婆每天都浇水！用全裸的状态！AHAHAHAHA！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
