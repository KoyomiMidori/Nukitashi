	},
	["0107_00312"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you do at lunch time on weekdays? Do you go to school?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你平常白天都在干什么？有在上学吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你平常白天都在幹什麼？有在上學吧？」",
