				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I'd heard from the company the island was like this, but I guess it was wrong of me to try and run away when someone approached me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“明明公司已经跟我说了是这样的岛，但被邀请之后还是不知不觉跟过来了，真不应该啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「明明公司已經跟我說了是這樣的島，但被邀請之後還是不知不覺跟過來了，真不應該啊……」",
					{"rt2"},
				},
