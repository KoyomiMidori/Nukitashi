	["0107_00238"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, do not write that down. Please. Just forget I said it.”",
