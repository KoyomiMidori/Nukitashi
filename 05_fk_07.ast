			},
			cn = {
				{
					"……？奈奈濑为什么要生气呢……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……？奈奈瀨為什麼要生氣呢……？",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00017",
		linknext = "0107_00019",
		line = 241,
	},
	["0107_00019"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, what's your progress, Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么……情况怎么样，麻沙酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼……情況怎麼樣，麻沙醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00018",
		linknext = "0107_00020",
		line = 253,
	},
	["0107_00020"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00121", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-400, y=0, time=800},
		{"fg", file="asane_01m_00008", file1="asane_01m_00104", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="asane_01m_00008", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1584", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I think we got pretty much everything from them data-wise. But we're still drawing a blank on Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我觉得数据本身已经完全抽取出来了。只是……果然还是找不到‘文乃’的情报……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我覺得數據本身已經完全抽取出來了。只是……果然還是找不到『文乃』的情報……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00019",
		linknext = "0107_00021",
		line = 272,
	},
	["0107_00021"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So does the OSS not have data on everyone here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“SHO也没有居民的所有数据吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「SHO也沒有居民的所有數據嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00020",
		linknext = "0107_00022",
		line = 284,
	},
	["0107_00022"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00104", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1585", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, they do. Everything from current address to medical exam results. If you've set foot on the island even once, they've got a file on you. But...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不，有是有……从现居地到健康诊断的结果，有来过岛的人的数据全都有。只是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不，有是有……從現居地到健康診斷的結果，有來過島的人的數據全都有。只是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00021",
		linknext = "0107_00023",
		line = 299,
	},
	["0107_00023"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="nanase_02m_00007", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2125", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We can't find anyone by the name of Kotoyose Fumino in there. It's really strange, Jun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“在这里面找不到叫琴寄文乃的少女……淳，果然很奇怪啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「在這裡面找不到叫琴寄文乃的少女……淳，果然很奇怪啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00022",
		linknext = "0107_00024",
		line = 315,
	},
	["0107_00024"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So she practically doesn't exist, then... That definitely is strange.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不存在的少女是吗……这明显很奇怪啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不存在的少女是嗎……這明顯很奇怪啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00023",
		linknext = "0107_00025",
		line = 327,
	},
	["0107_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It would be ridiculous for that old man to have us search for a girl who isn't on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果不是在岛上的少女，那么那个老人拜托我们的调查本身就是无稽之谈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果不是在島上的少女，那麼那個老人拜託我們的調查本身就是無稽之談。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00024",
		linknext = "0107_00026",
		line = 337,
	},
	["0107_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, if the OSS don't have any information on her, then at the very least, she's not legally a resident of the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但如果连SHO都不知道的话，至少能确定那个少女不是通过正规的方法来岛上的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但如果連SHO都不知道的話，至少能確定那個少女不是通過正規的方法來島上的。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00025",
		linknext = "0107_00027",
		line = 347,
	},
	["0107_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why go to the trouble of bluffing us into searching for someone who doesn't exist?",
					{"rt2"},
				},
			},
			cn = {
				{
					"难道说让我们去找只不过是虚招，这行为本身就有所意义——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"難道說讓我們去找只不過是虛招，這行為本身就有所意義——？",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00026",
		linknext = "0107_00028",
		line = 357,
	},
	["0107_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At any rate, we're going to have to carefully rethink our search.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么说，有关寻找文乃一事有必要再好好考虑一下——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼說，有關尋找文乃一事有必要再好好考慮一下——",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00027",
		linknext = "0107_00029",
		line = 367,
	},
	["0107_00029"] = {
		{"fg", file="asane_01m_00008", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1586", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Also, remember how you talked about a system searching for enemies in multi-story buildings? I agree that we're gonna need that. It's a stumbling block for our current program.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“还有哥哥，你之前说过的多楼层搜索系统……我也觉得有必要……因为现在的装置对大楼和建筑物太弱了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「還有哥哥，你之前說過的多樓層搜索系統……我也覺得有必要……因為現在的裝置對大樓和建築物太弱了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00028",
		linknext = "0107_00030",
		line = 382,
	},
	["0107_00030"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I figured as much... Is it technically possible for you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，果然……技术上能做到吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，果然……技術上能做到嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00029",
		linknext = "0107_00031",
		line = 394,
	},
	["0107_00031"] = {
		{"fg", file="asane_01m_00008", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1587", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, for the system itself. But it's gonna be high-cost and resource-intensive. We'd have to decrease the GPS range or something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“系统本身是可以……但是负荷很重，有必要大量限制资源……像是缩小GPS的获取范围之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「系統本身是可以……但是負荷很重，有必要大量限制資源……像是縮小GPS的獲取範圍之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00030",
		linknext = "0107_00032",
		line = 408,
	},
	["0107_00032"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Does that mean we won't be able to use super search mode?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果是这样，超级搜索模式就不能用了是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果是這樣，超級搜索模式就不能用了是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00031",
		linknext = "0107_00033",
		line = 420,
	},
	["0107_00033"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00116", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1588", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Even if there is a GPS signal, it's useless to us without cameras in the area. Honestly, this is gonna be a pretty tricky mod.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不管怎么样不管GPS是否有反应只要那里没有设置摄像头的话就没有用……说实话修改的成效很微妙……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不管怎麼樣不管GPS是否有反應只要那裡沒有設置攝影機的話就沒有用……說實話修改的成效很微妙……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00032",
		linknext = "0107_00034",
		line = 434,
	},
	["0107_00034"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[1000] = {
				{"se", id=0, loop=0, file="se_a144", delay2=1000},
				{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=150, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess we'll need some kind of special hardware-based approach, then...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看来硬件方面这边如果不提些意见的话很难搞是吗……嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看來硬體方面如果不提些意見的話會很難搞嗎……嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00033",
		linknext = "0107_00035",
		line = 448,
	},
	["0107_00035"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2126", path=":vo/", ch="nanase"},
			},
			ja = {
