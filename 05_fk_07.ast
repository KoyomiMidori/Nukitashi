	["0107_00173"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hurry and go, quickly! I'll take care of things on my end!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请走吧，这里交给我了……！”",
					{"rt2"},
				},
			},
