		linkback = "0107_00278",
		linknext = "0107_00280",
		line = 3717,
	},
	["0107_00280"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did you do at lunch time, given it was the weekend?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“吹子白天做了什么呢？我想你应该休假吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「吹子白天做了什麼呢？我想你應該休假吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00279",
		linknext = "0107_00281",
		line = 3729,
	},
	["0107_00281"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0490", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Today I... slept at home... Besides that... I did the cooking, the cleaning... and various other things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“今天……我在家睡觉……还有……做饭、打扫……各种事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「今天……我在家睡覺……還有……做飯、打掃……各種事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00280",
		linknext = "0107_00282",
		line = 3743,
	},
	["0107_00282"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You did the household chores alone? Is there anyone besides you at home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一个人做家务……家里除了吹子没有其他人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一個人做家事……家裡除了吹子沒有其他人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00281",
		linknext = "0107_00283",
		line = 3755,
	},
	["0107_00283"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0491", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I'm the only one there. I take care of everything at home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“……只有我一个人在……家里的事，都是我自己……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……只有我一個人在……家裡的事，都是我自己……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00282",
		linknext = "0107_00284",
		line = 3769,
	},
	["0107_00284"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay, I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00283",
		linknext = "0107_00285",
		line = 3781,
	},
	["0107_00285"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had envisioned her surrounded by servants, but that doesn't seem to be the case.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……虽然在我的想象中她过着被佣人包围的生活，但好像不是那样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……雖然在我的想像中她過著被傭人包圍的生活，但好像不是那樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00284",
		linknext = "0107_00286",
		line = 3791,
	},
	["0107_00286"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So where is this house that you live alone in? Where do you live?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那你一个人住的房子在哪里？大概住在什么地方？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那你一個人住的房子在哪裡？大概住在什麼地方？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00285",
		linknext = "0107_00287",
		line = 3803,
	},
	["0107_00287"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
