	["0107_00246"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0481", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Tachibana? What's the matter? You're suddenly clutching your chest and squatting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“橘、大人……？怎么突然按住胸口蹲下来……？”",
