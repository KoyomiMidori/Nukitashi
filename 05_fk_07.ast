		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1080", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“So today, we're helping out with the OSS operations. Having said that, it's not much different from regular guard duty.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“——所以，今天的工作是SHO的业务辅佐。话虽这么说，但跟平时的警卫工作没什么两样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「——所以，今天的工作是SHO的業務輔佐。話雖這麼說，但跟平時的警衛工作沒什麼兩樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00040",
		linknext = "0107_00042",
		line = 577,
	},
	["0107_00042"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1081", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It's basically watching for incidents and accidents, patrolling, guidance, protecting children, and acting as sex partners.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“基本上是监视有没有发生事故、巡逻、带路、保护孩子，还有成为做爱对象等等。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「基本上是監視有沒有發生事故、巡邏、帶路、保護孩子，還有成為做愛對象等等。」",
					{"rt2"},
				},
			},
		},
