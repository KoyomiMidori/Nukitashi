				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The friendly looking man puts on a wry smile and puts his hand behind his head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"男人苦笑着露出老好人的表情，把手伸向后脑勺。",
					{"rt2"},
				},
			},
			tw = {
				{
					"男人苦笑著露出老好人的表情，把手伸向後腦勺。",
					{"rt2"},
				},
