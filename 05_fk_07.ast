					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“No, I work for a company that makes a particular type of product. I don't really enjoy showing them off, but... here they are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不，我在开发某种产品的公司工作，虽然拿给你们看有点不好意思……就是这个。”",
