		{"fg", file="fumino_01ll_00001", file1="fumino_01ll_00104", path=":fg/fumino_01ll/", id=7, lv=5, head="fumino_01ll", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
