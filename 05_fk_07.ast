		linknext = "0107_00341",
		line = 4472,
	},
	["0107_00341"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00125", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
