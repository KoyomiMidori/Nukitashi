			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Topical joke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“小玩笑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「小玩笑。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00230",
		linknext = "0107_00232",
		line = 3113,
	},
	["0107_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“For example...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“例如……”",
					{"rt2"},
				},
