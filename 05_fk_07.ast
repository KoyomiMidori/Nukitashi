	["0107_00160"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00109", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0234", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“R-Really!? Are you interested in them!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真、真的吗……！？橘君们有兴趣吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真、真的嗎……！？橘君們有興趣嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00159",
		linknext = "0107_00161",
		line = 2192,
	},
	["0107_00161"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00122", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[8500] = {
				{"fg", file="misaki_01m_00002", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1990", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You bet! Is this a double headed vibrator made with the latest high-tech material to stimulate anuses and vaginas simultaneously!? You can enjoy this with either hand! This is great work!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“当然！这是能同时刺激肛门和阴道的新素材双头按摩棒吗……！？这样的话一只手就够了！好棒的产品啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「當然！這是能同時刺激肛門和陰道的新素材雙頭按摩棒嗎……！？這樣的話一隻手就夠了！好棒的產品啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00160",
		linknext = "0107_00162",
		line = 2209,
	},
	["0107_00162"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And look at this, the latest stroking models... My God, you even have the Underage Poontang DX model, long out of production but designed to make any enthusiast drool!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且这是最新的模型……！居然还有狂热者垂涎的已经生产中止的萝莉小穴模型‘啪啪小穴DX’……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且這是最新的模型……！居然還有狂熱者垂涎的已經生產中止的蘿莉小穴模型『啪啪小穴DX』……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00161",
		linknext = "0107_00163",
		line = 2221,
	},
	["0107_00163"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00109", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0235", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Y-You even know about that! Oh my God, there's actually someone else on this island who understands! I'm so glad I came!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你、你竟然连这件事都知道……！呜呜呜，真没想到，在这里也有懂的人啊……！能来真是太好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你、你竟然連這件事都知道……！嗚嗚嗚，真沒想到，在這裡也有懂的人啊……！能來真是太好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00162",
		linknext = "0107_00164",
		line = 2238,
	},
	["0107_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's so stoked he's fighting off tears.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋先生因为感动而哭泣。",
