		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=700, mode=3, x=-200, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=1200},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0473", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Good evening, Tachibana. Is something the matter?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“晚上好，橘大人……您怎么了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「晚上好，橘大人……您怎麼了……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00204",
		linknext = "0107_00206",
		line = 2800,
	},
	["0107_00206"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it's nothing. Good evening, Fukiko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不，没什么吹子。晚上好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不，沒什麼吹子。晚上好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00205",
		linknext = "0107_00207",
		line = 2812,
	},
	["0107_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But seeing Fukiko's face causes the source of that headache to fade away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一看到吹子的脸，头痛的根源似乎就消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一看到吹子的臉，頭痛的根源似乎就消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00206",
		linknext = "0107_00208",
		line = 2822,
	},
	["0107_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm pleased to hear her greet me so normally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她能像这样普通地跟我打招呼让我很开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她能像這樣普通地跟我打招呼讓我很開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00207",
		linknext = "0107_00209",
		line = 2832,
	},
	["0107_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Guess I should just put that stuff on the back burner and think about what I can do right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之先把其他事放下，专注在现在能做的事情上吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之先把其他事放下，專注在現在能做的事情上吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00208",
		linknext = "0107_00210",
		line = 2842,
	},
	["0107_00210"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00114", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I walk beside the expressionless girl who looks at me quizzically.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我和面无表情地歪了歪小脑袋的她一起往前走。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我和麵無表情地歪了歪小腦袋的她一起往前走。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00209",
		linknext = "0107_00211",
		line = 2854,
	},
	["0107_00211"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a018"},
		{"se", id=1, loop=0, file="se_a205"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now, let's practice conversing while we're doing tonight's night watch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，关于巡逻……从今天开始也顺便进行对话训练吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，關於巡邏……從今天開始也順便進行對話訓練吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00210",
		linknext = "0107_00212",
		line = 2870,
	},
	["0107_00212"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was just a casual suggestion, but she gives me an earnest look and nods.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对我的邀约，吹子表情严肃地点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對我的邀約，吹子表情嚴肅地點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00211",
		linknext = "0107_00213",
		line = 2882,
	},
	["0107_00213"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0474", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“So that means... I'll become your apprentice. Thank you for your instruction, Master.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“……那么，我……就成了橘大人的弟子呢……请多关照，师傅……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……那麼，我……就成了橘大人的弟子呢……請多關照，師傅……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00212",
		linknext = "0107_00214",
		line = 2894,
	},
	["0107_00214"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's kinda embarrassing having you call me that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么叫我真不好意思……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼叫我真不好意思……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00213",
		linknext = "0107_00215",
		line = 2906,
	},
	["0107_00215"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00111", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0475", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Master... Instructor... Mentor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“师傅……老师……大师……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「師傅……老師……大師……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00214",
		linknext = "0107_00216",
		line = 2920,
	},
	["0107_00216"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't plan to make you my apprentice. I'd appreciate it if you just call me what you always do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我没有收你为徒的打算，麻烦你像以前那样就好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我沒有收你為徒的打算，麻煩你像以前那樣就好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00215",
		linknext = "0107_00217",
		line = 2932,
	},
	["0107_00217"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=450, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She acknowledges stiffly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“我知道了”吹子说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「我知道了」吹子說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00216",
		linknext = "0107_00218",
		line = 2945,
	},
	["0107_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's a stickler for formalities, even now... Definitely a conservative type.",
					{"rt2"},
				},
			},
			cn = {
				{
					"连这种时候都这样硬邦邦的……看来她确实是位很死板的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連這種時候都這樣硬梆梆的……看來她確實是個很死板的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00217",
		linknext = "0107_00219",
		line = 2955,
	},
	["0107_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wonder if she's had a rich young woman's upbringing, and her unusual behavior is a result of being isolated from the world at large.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是纯粹的大小姐不停保持着远离世俗的生活，结果才变成如此不可思议的存在吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是純粹的大小姐不停保持著遠離世俗的生活，結果才變成如此不可思議的存在吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00218",
		linknext = "0107_00220",
		line = 2965,
	},
	["0107_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It does sound like a feasible explanation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想想也不是不可能的事情——",
					{"rt2"},
				},
			},
			tw = {
				{
					"想想也不是不可能的事情——",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00219",
		linknext = "0107_00221",
		line = 2975,
	},
	["0107_00221"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When talking with someone, the most important thing is the topic. No discussion can progress without a topic.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要与对方交谈，最重要的是话题。如果没有话题，谈话就不成立。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要與對方交談，最重要的是話題。如果沒有話題，談話就不成立。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00220",
		linknext = "0107_00222",
		line = 2987,
	},
	["0107_00222"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", ch="文乃", id=7, mode=2, path=":fg/fumino_01m/", file="fumino_01m_00001", size="m", file1="fumino_01m_00104", head="fumino_01m", lv=5},
			},
			[1000] = {
				{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=25, time=300, ease="easeinout_sine"},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0476", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I see. I'm sorry, please wait a moment...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“这样啊……对不起，请稍等一下……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「這樣啊……對不起，請稍等一下……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00221",
		linknext = "0107_00223",
		line = 3004,
	},
	["0107_00223"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She pulls out a notepad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她从胸前取出类似记事本的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她從胸前取出類似記事本的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00222",
		linknext = "0107_00224",
		line = 3015,
	},
	["0107_00224"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A notepad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……记事本？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……記事本？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00223",
		linknext = "0107_00225",
		line = 3027,
	},
	["0107_00225"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=2, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0477", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I am taking notes. I thought it would be best to write important items on a notepad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“要点笔记本……我想重要的事情还是记下来比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「要點筆記本……我想重要的事情還是記下來比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00224",
		linknext = "0107_00226",
		line = 3042,
	},
	["0107_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's taking this preparation thing kinda seriously...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……她好像准备得非常认真。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……她好像準備得非常認真。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00225",
		linknext = "0107_00227",
		line = 3052,
	},
	["0107_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And it was just a casual remark on my part. Is this gonna be okay?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我其实只是随意说说的，这样真的没问题吗……",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我其實只是隨意說說的，這樣真的沒問題嗎……",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00226",
		linknext = "0107_00228",
		line = 3062,
	},
	["0107_00228"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, well even if you don't have a topic, there is a way to create conversation without one. You use it when you don't have any starting point with the other person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不、不过也有一种即使没有话题也能达成对话的方法，能在对方毫无头绪的时候使用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不、不過也有一種即使沒有話題也能達成對話的方法，能在對方毫無頭緒的時候使用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00227",
		linknext = "0107_00229",
		line = 3074,
	},
	["0107_00229"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's by saying something yourself the other person will have to listen to. It's a powerful way to ease the tension when the atmosphere is uncomfortable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就是‘让对方听我说’。这也有缓和沉闷空气的力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就是『讓對方聽我說』。這也有緩和沈悶空氣的力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00228",
		linknext = "0107_00230",
		line = 3086,
	},
	["0107_00230"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In other words, a topical joke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“简单来说就是讲个小玩笑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「簡單來說就是講個小玩笑。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00229",
		linknext = "0107_00231",
		line = 3098,
	},
	["0107_00231"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=2, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
