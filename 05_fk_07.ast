					"“嗯、嗯，抱歉，谢谢你……诶，刚来就马上被卷入了莫名其妙的事情中。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「嗯、嗯，抱歉，謝謝你……欸，剛來就馬上被捲入了莫名其妙的事情中。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00138",
		linknext = "0107_00140",
		line = 1921,
	},
	["0107_00140"] = {
		{"text"},
		text = {
