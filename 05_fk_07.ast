			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Weekend penalty rates will also apply! This will look good on your unofficial reports! Don't do a half-assed job out there! Got it!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“休息日上班会发放补贴！内部评价也会变好！别给我偷懒！明白了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「休息日上班會發放補貼！內部評價也會變好！別給我偷懶！明白了嗎！」",
					{"rt2"},
				},
			},
		},
