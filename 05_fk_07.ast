	["0107_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's pointing to somewhere in the mountains. It doesn't look like a place for a mansion where an upper-class girl lives.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手指指向的是山中，我不认为那里有大小姐住的房子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手指指向的是山中，我不認為那裡有大小姐住的房子。",
					{"rt2"},
