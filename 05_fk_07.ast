			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Mm... I'm enrolled... in the third year... of the B level classes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“嗯……我是B等部的……3年级学生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「嗯……我是B等部的……3年級學生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00321",
		linknext = "0107_00323",
		line = 4234,
	},
	["0107_00323"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So if I head to the third year B-level class area, I can see you at any time, huh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么只要去B等部的3年级，就可以随时见到吹子了。”",
