	},
	["0107_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I do feel like we had a certain understanding just now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便如此，我感觉我们彼此稍为敞开心胸了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便如此，我感覺我們彼此稍為敞開心胸了。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00306",
		linknext = "0107_00308",
		line = 4050,
	},
	["0107_00308"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was quite a piss-poor discussion, if I do say so myself. What's wrong with me?",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我也觉得谈话内容不怎么正向。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我也覺得談話內容不怎麼正向。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00307",
		linknext = "0107_00309",
		line = 4060,
	},
	["0107_00309"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she did cast off that strong outer shell of hers, and we did have a moment of mutual understanding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是她确实穿过了那个意志强烈的凛然外壳，与我小小地共享了心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是她確實穿過了那個意志強烈的凜然外殼，與我小小地共享了心情。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00308",
		linknext = "0107_00310",
		line = 4070,
	},
	["0107_00310"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I should be able to continue making small talk like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要能继续保持这种小小的对话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要能繼續保持這種小小的對話。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00309",
		linknext = "0107_00311",
		line = 4080,
	},
	["0107_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At some stage, we may really be able to open our hearts to each other.",
