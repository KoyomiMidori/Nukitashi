	},
	["0107_00305"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that's one thing we have in common. No parents.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“父母都不在了，这点你和我一样呢。”",
