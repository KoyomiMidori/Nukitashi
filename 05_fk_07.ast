	},
	["0107_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can converse with my classmates, but I don't really have many friends.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在班里和同学聊天还可以，但朋友并不多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在班裡和同學聊天還可以，但朋友並不多。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00239",
		linknext = "0107_00241",
		line = 3225,
	},
	["0107_00241"] = {
		{"text"},
		text = {
