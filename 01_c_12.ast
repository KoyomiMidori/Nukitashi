	["0013_00134"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00115", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0418", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Por qué? Si eso suena muy flojo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“为啥啊……那名字有点土诶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「為啥啊……那名字有點土欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00133",
		linknext = "0013_00135",
		line = 1655,
	},
	["0013_00135"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué? ¡¿Estás diciendo que mi nombre genial es flojo?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什……居然说这个帅气的称呼土……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什……居然說這個帥氣的稱呼土……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00134",
		linknext = "0013_00136",
		line = 1667,
	},
	["0013_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta zorra vive en otro mundo si no puede apreciar la genialidad de ese nombre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然无法理解这么帅气的名字，婊子果然了解不了这边的世界。",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然無法理解這麼帥氣的名字，婊子果然了解不了這邊的世界。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00135",
		linknext = "0013_00137",
		line = 1677,
	},
	["0013_00137"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Descarada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得真过分。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得真過分。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00136",
		linknext = "0013_00138",
		line = 1689,
	},
	["0013_00138"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“He puesto toda mi sangre, sudor y lágrimas en la creación de objetos funcionales camuflados como juguetes sexuales.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明明我这么努力完成各种机能，让它能拟态成成人玩具而努力着——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「明明我這麼努力完成各種機能，讓它能擬態成成人玩具而努力著——」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00137",
		linknext = "0013_00139",
		line = 1701,
	},
	["0013_00139"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00105", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
