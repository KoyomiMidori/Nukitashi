		linknext = "0013_00002",
		line = 18,
	},
	["0013_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Suelo tomarme todo en serio, pero no hay nada malo en relajarse hasta la hora del almuerzo el fin de semana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平常虽然过得很认真，但假日的中午就让我懒洋洋地过一下吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平常雖然過得很認真，但假日的中午就讓我懶洋洋地過一下吧",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00001",
		linknext = "0013_00003",
		line = 28,
	},
	["0013_00003"] = {
		{"se", id=0, loop=0, file="se_a122"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
