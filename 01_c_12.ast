				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啥……什麼事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00118",
		linknext = "0013_00120",
		line = 1471,
	},
	["0013_00120"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Te va a llevar a tu forma evolucionada definitiva.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让你变成了究极完全体……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「讓你變成了究極完全體……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00119",
		linknext = "0013_00121",
		line = 1483,
	},
	["0013_00121"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0413", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, no me molesta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“反正其实也没差……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「反正其實也沒差……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00120",
		linknext = "0013_00122",
		line = 1495,
	},
	["0013_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase no se sorprende porque siempre somos así de raros.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是看习惯了我们的怪异，奈奈濑不怎么在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是看習慣了我們的怪異，奈奈瀨不怎麼在意。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00121",
		linknext = "0013_00123",
		line = 1505,
	},
	["0013_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las virtudes acumuladas de nuestra rutina diaria han dado sus frutos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平日积累的功德总算生效了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平日積累的功德總算生效了。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00122",
		linknext = "0013_00124",
		line = 1515,
	},
	["0013_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero qué sudor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过你流了真多汗啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過你流了真多汗啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00123",
		linknext = "0013_00125",
		line = 1526,
	},
	["0013_00125"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00114", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0414", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hace muchísimo calor... Y es que hay mucha gente hablándome. Es difícil moverse.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“实在是太热了……而且人又多，又会被喊住，根本动不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「實在是太熱了……而且人又多，又會被喊住，根本動不了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00124",
		linknext = "0013_00126",
		line = 1540,
	},
	["0013_00126"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es que es el pico del verano. Pronto llegará el período más ajetreado de la isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也是，马上就要盛夏了。这个岛最热闹的时期马上就要来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也是，馬上就要盛夏了。這個島最熱鬧的時期馬上就要來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00125",
		linknext = "0013_00127",
		line = 1552,
	},
	["0013_00127"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0415", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“En días así, le tengo envidia a un hikikomori como tú.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这种日子最羡慕你这样的宅男了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這種日子最羨慕你這樣的宅男了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00126",
		linknext = "0013_00128",
		line = 1566,
	},
	["0013_00128"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque me la pase en casa, yo también he estado ocupado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然是在家里，但我也是很忙的哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然是在家裡，但我也是很忙的哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00127",
		linknext = "0013_00129",
		line = 1578,
	},
	["0013_00129"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00115", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
