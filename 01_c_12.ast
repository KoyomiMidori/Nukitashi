	["0013_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Solo puedo llevar juguetes sexuales porque es lo único que está permitido y que pasa los controles de seguridad de la SS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“想要逃过SS的突击检查，只能模仿可以随身携带的情趣玩具……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「想要逃過SS的突擊檢查，只能模仿可以隨身攜帶的情趣玩具……！」",
					{"rt2"},
