			en = {
				{
					"Acto seguido, Asa-chan le trae un vaso de agua y le da un sorbo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"喝完麻沙酱急忙拿来的水后，她才终于呼了一口气。",
					{"rt2"},
