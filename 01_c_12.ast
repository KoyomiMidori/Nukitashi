		linkback = "0013_00131",
		linknext = "0013_00133",
		line = 1628,
	},
	["0013_00133"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Llámalos por lo que son: ¡TAE!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是T-A-E！！”",
