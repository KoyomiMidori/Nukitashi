	["0013_00171"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00102", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0455", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Siempre me fascinan tus habilidades culinarias, Nanase-san... Serás una buena esposa...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不过……无论什么时候看到奈奈濑同学做饭的样子都会看得入迷……真是个好妻子呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不過……無論什麼時候看到奈奈瀨同學做飯的樣子都會看得入迷……真是個好妻子呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00170",
		linknext = "0013_00172",
		line = 2173,
	},
	["0013_00172"] = {
