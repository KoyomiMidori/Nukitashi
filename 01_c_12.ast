		{"bgm", file="bgm06", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hoy es un día libre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天是休息日。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天是休息日。",
					{"rt2"},
				},
