					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Además, solo una zorra como tú puede cargarlos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且只能让身为婊子的奈奈濑拿着——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
