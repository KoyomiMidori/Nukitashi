		{"fg", file="asane_01m_00002", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0452", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hermanito, ¿puedes calmarte? ¿Cuánto tiempo vas a seguir así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥，别生气了……你打算闹别扭到什么时候啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥，別生氣了……你打算鬧彆扭到什麼時候啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00162",
		linknext = "0013_00164",
		line = 2045,
	},
	["0013_00164"] = {
