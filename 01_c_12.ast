		linkback = "0013_00204",
		linknext = "0013_00206",
		line = 2658,
	},
	["0013_00206"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es la cantidad de veces que puedes decir que soy impotente. Tres veces al día.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可以说我是阳痿的次数，一天只能3次。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可以說我是陽痿的次數，一天只能3次。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00205",
		linknext = "0013_00207",
		line = 2670,
	},
	["0013_00207"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Si te llamo zorra, puedes llamarme impotente!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说因为我说你是婊子，所以你也可以说我是阳痿的意思啦！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說因為我說你是婊子，所以你也可以說我是陽痿的意思啦！！！」",
					{"rt2"},
				},
