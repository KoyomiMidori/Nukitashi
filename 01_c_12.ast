		},
		linkback = "0013_00164",
		linknext = "0013_00166",
		line = 2098,
	},
	["0013_00166"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00105", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0453", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Lamento que mi estúpido y descuidado hermano se haya ofendido...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对不起，让这位愚蠢又肮脏的哥哥弄糟了你的心情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對不起，讓這個愚蠢又骯髒的哥哥弄糟了你的心情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00165",
		linknext = "0013_00167",
		line = 2111,
	},
	["0013_00167"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿A quién le dices descuidado?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不肮脏！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不骯髒！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00166",
		linknext = "0013_00168",
		line = 2123,
	},
	["0013_00168"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0427", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jeje, bueno, también es que me pasé un poquito. Eres una buena chica, Asa-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵，不过这次我也有错……麻沙酱真是乖孩子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呵呵，不過這次我也有錯……麻沙醬真是乖孩子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00167",
		linknext = "0013_00169",
		line = 2135,
	},
	["0013_00169"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00113", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0454", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Jejeje, ¿de veras sí soy buena chica? No creo jejeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“咕嘿，乖孩子什么的咕嘿嘿嘿嘿嘿嗨哟。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「咕嘿，乖孩子什麼的咕嘿嘿嘿嘿嘿嗨喲。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00168",
		linknext = "0013_00170",
		line = 2148,
	},
	["0013_00170"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0428", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uh, aunque tu risa es un poco rara...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笑、笑的方式真奇怪……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笑、笑的方式真奇怪……」",
