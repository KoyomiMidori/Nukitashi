	["0013_00131"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No seas tonta, me la he pasado haciendo TAEs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在说什么傻话——我可是一直在制作T-A-E哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在說什麼傻話——我可是一直在製作T-A-E哦。」",
					{"rt2"},
				},
