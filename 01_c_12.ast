			cn = {
				{
					name = {"麻沙音"},
					"“真是的，哥哥……明明是你的错吧？一直说人家是婊子还辣妹还泪痣什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真是的，哥哥……明明是你的錯吧？一直說人家是婊子還辣妹還淚痣什麼的。」",
					{"rt2"},
				},
