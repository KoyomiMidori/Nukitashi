		},
		linkback = "0013_00130",
		linknext = "0013_00132",
		line = 1614,
	},
	["0013_00132"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
