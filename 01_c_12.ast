	},
	["0013_00109"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fgact", ch="麻沙音", id=3, act="移動", x=600, y=0, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase nos mira fijamente con una mirada perdida y se seca el sudor de las mejillas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑呆呆地看着我们，擦着脸上的汗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨呆呆地看著我們，擦著臉上的汗。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00108",
		linknext = "0013_00110",
		line = 1345,
	},
	["0013_00110"] = {
