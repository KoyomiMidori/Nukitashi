	["0013_00004"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0100", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "PC画面"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Pantalla de la PC"},
					"Siempre te he amado...",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "PC画面"},
					"“我……一直很喜欢你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "PC畫面"},
					"「我……一直很喜歡你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00003",
		linknext = "0013_00005",
		line = 53,
	},
	["0013_00005"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yo también... Por fin me di cuenta de lo importante que eres para mí, mi preciosa amiga de la infancia...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，我也是……我终于意识到青梅竹马的你有多么重要……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，我也是……我終於意識到青梅竹馬的你有多麼重要……」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00004",
		linknext = "0013_00006",
		line = 65,
	},
	["0013_00006"] = {
		{"se", id=0, loop=0, file="se_a121"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0101", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "PC画面"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Pantalla de la PC"},
					"¡¿En serio?! ¡Qué alegría! Te molestaría si te dijera... ¿que quiero abrazarte ahora mismo?",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "PC画面"},
					"“真的吗……！？我好开心……！那，如果我想要你现在马上拥抱我……你会生气吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "PC畫面"},
					"「真的嗎……！？我好開心……！那，如果我想要你現在馬上擁抱我……你會生氣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00005",
		linknext = "0013_00007",
		line = 78,
	},
	["0013_00007"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
