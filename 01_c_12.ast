	["0013_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que la veo así, no es una persona de muchas palabras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"实际上，奈奈濑没有看上去的样子话多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"實際上，奈奈瀨沒有看上去的樣子話多。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00199",
		linknext = "0013_00201",
		line = 2599,
	},
	["0013_00201"] = {
		{"text"},
		text = {
