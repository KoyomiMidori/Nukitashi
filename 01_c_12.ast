		linkback = "0013_00104",
		linknext = "0013_00106",
		line = 1287,
	},
	["0013_00106"] = {
		{"fgact", ch="麻沙音", id=3, act="移動", x=300, y=0, time=300},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=600, mode=3, x=-400, y=100},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=0, y=-100, time=700},
		{"fgact", ch="奈々瀬", id=4, act="浮遊横", loop=3, size=5, time=125, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0410", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jaa, fuu... ¿Eh? ¿Perdón? ¿Pasó algo, Asa-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哈啊……呼……什么？要说什么？怎么了麻沙酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哈啊……呼……什麼？要說什麼？怎麼了麻沙醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00105",
		linknext = "0013_00107",
		line = 1305,
	},
	["0013_00107"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00113", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="浮遊横", loop=5, size=7.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
