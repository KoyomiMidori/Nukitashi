			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Pero solo tres veces al día! ¡Si lo dices más veces, me deprimiré!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是1天只能3次哦！超过这个次数的话，我内心会逐渐开始黑化哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是1天只能3次哦！超過這個次數的話，我內心會逐漸開始黑化哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00208",
		linknext = "0013_00210",
		line = 2709,
	},
	["0013_00210"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0444", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Tontín, ya entendí. Señorito corazón de vidrio... Jeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨蛋，知道了啦，玻璃心先生……呵呵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨蛋，知道了啦，玻璃心先生……呵呵。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00209",
		linknext = "0013_00211",
		line = 2723,
	},
	["0013_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me muestra una sonrisa amable, de alguna manera tolerante, y asiente con la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑露出温柔且带有包容力的笑容点点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨露出溫柔且帶有包容力的笑容點點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00210",
		linknext = "0013_00212",
		line = 2733,
	},
	["0013_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En momentos así, se ve bastante madura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种时候的她，给人非常成熟的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種時候的她，給人非常成熟的感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00211",
		linknext = "0013_00213",
		line = 2743,
	},
	["0013_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, no solo se ve madura, probablemente lo sea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，或许可以说就是个成熟的大人——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，或許可以說就是個成熟的大人——",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00212",
		linknext = "0013_00214",
		line = 2753,
	},
	["0013_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al menos es más madura que yo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"至少，比我还成熟。",
					{"rt2"},
				},
			},
			tw = {
				{
					"至少，比我還成熟。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00213",
		linknext = "0013_00215",
		line = 2763,
	},
	["0013_00215"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0445", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oye, sobre Wata-chan...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……那个，有关渡酱的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……那個，有關渡醬的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00214",
		linknext = "0013_00216",
		line = 2778,
	},
	["0013_00216"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Mmm? ¿Qué pasa con ella?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯？怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯？怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00215",
		linknext = "0013_00217",
		line = 2790,
	},
	["0013_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Frunzo el ceño ante ese inesperado cambio de tema.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为话题突然转变，我皱了皱眉头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為話題突然轉變，我皺了皺眉頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00216",
		linknext = "0013_00218",
		line = 2800,
	},
	["0013_00218"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0446", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Salvaste a Wata-chan porque estaba en peligro? ¿Esa fue la única razón?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“帮助渡酱的理由……只是因为她处在危险之中？理由……只有这个吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「幫助渡醬的理由……只是因為她處在危險之中？理由……只有這個嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00217",
		linknext = "0013_00219",
		line = 2814,
	},
	["0013_00219"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tú misma lo viste. Casi la violan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不也看到了。那时不是千钧一发吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你不也看到了。那時不是千鈞一髮嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00218",
		linknext = "0013_00220",
		line = 2826,
	},
	["0013_00220"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué otra razón necesitas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……除此之外还需要什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……除此之外還需要什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00219",
		linknext = "0013_00221",
		line = 2838,
	},
	["0013_00221"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="nanase_01m_00002", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0447", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No, no me refiero a eso, pero... creo que sí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不，我不是这个意思——不过也对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不，我不是這個意思——不過也對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00220",
		linknext = "0013_00222",
		line = 2854,
	},
	["0013_00222"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0448", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Si vieras a otra chica en peligro, ¿también la salvarías?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“如果又发现有像那样遭遇危险的女孩，你会再帮忙吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「如果又發現有像那樣遭遇危險的女孩，你會再幫忙嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00221",
		linknext = "0013_00223",
		line = 2868,
	},
	["0013_00223"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Respondo a la pregunta hipotética de Nanase.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑婉转地向我询问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨婉轉地向我詢問。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00222",
		linknext = "0013_00224",
		line = 2878,
	},
	["0013_00224"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues... sí. Creo que sí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃——嗯，大概会帮忙吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃——嗯，大概會幫忙吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00223",
		linknext = "0013_00225",
		line = 2890,
	},
	["0013_00225"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tengo que luchar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我必须战斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我必須戰鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00224",
		linknext = "0013_00226",
		line = 2902,
	},
	["0013_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tengo amigos con los que puedo luchar. Compañeros con ideas afines que nunca me traicionarían.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了战斗，我想要同伴。想要拥有同样志向，永不背叛的同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了戰鬥，我想要同伴。想要擁有同樣志向，永不背叛的同伴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00225",
		linknext = "0013_00227",
		line = 2913,
	},
	["0013_00227"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0449", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí... es verdad. Esa es la clase de persona que eres.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样啊……嗯，也是……毕竟你就是那样的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣啊……嗯，也是……畢竟你就是那樣的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00226",
		linknext = "0013_00228",
		line = 2927,
	},
	["0013_00228"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase sonríe con algo de tristeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说完，奈奈濑露出有些悲伤的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說完，奈奈瀨露出有些悲傷的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00227",
		linknext = "0013_00229",
		line = 2939,
	},
	["0013_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero eso solo dura un breve momento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但，只有一瞬间。",
					{"rt2"},
				},
			},
