	["0013_00205"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0442", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
