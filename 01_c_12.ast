		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0438", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Siempre estás haciendo entrenamiento con pesas, así que me he esforzado por crear un menú que te ayude a ganar músculo. Todo ello, por supuesto, sin salirse del presupuesto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“因为他一直在锻炼，所以我努力做了个容易长肌肉的菜谱。当然是在预算之内。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為他一直在鍛煉，所以我努力做了個容易長肌肉的菜譜。當然是在預算之內。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00190",
		linknext = "0013_00192",
		line = 2453,
	},
	["0013_00192"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
