					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Listo. ¡Hoy hay filete de ternera especial, embutidos de cerdo, sopa de pollo al vapor y puerros con miso, sopa de almejas, tofu liofilizado y queso!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“来。今天特别做了牛里脊肉、冷涮猪肉、蒸鸡肉佐葱味噌、蛤蜊巧达浓汤和高野豆腐，还有奶酪！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「來。今天特別做了牛里肌肉排、冷涮豬肉、蒸雞肉佐蔥味噌、蛤蜊巧達濃湯和高野豆腐，還有起司！」",
					{"rt2"},
				},
			},
		},
