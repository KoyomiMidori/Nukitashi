					"「我的意思是很適合你啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00157",
		linknext = "0013_00159",
		line = 1944,
	},
	["0013_00159"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Puedes imaginarte a Wata-chan cargando esto?! ¡Eso sería un crimen!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你让渡酱拿这个试试？根本就是犯罪哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你讓渡醬拿這個試試？根本就是犯罪哦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00158",
		linknext = "0013_00160",
		line = 1956,
	},
	["0013_00160"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0424", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, sigue viéndose mejor que un impotente llevando un onahole.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样啊。不过也是，确实比让阳痿的人拿着飞机杯要好吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣啊。不過也是，確實比讓陽痿的人拿著飛機杯要好吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00159",
		linknext = "0013_00161",
		line = 1970,
	},
	["0013_00161"] = {
