	["0013_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No dice nada a menos que le hable primero.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果我不搭话，她就很少开口讲话。",
					{"rt2"},
				},
