					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué estás diciendo? Si tienes un lunar de lágrima en la posición típica de una zorra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从初期状态就把那样的泪痣装备在主张自己是婊子的位置上的人事到如今在说什么呢！”",
					{"rt2"},
				},
