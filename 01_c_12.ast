				{"vo", file="asane0448", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“N-N-N-N-No pasó nada, jeje...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“什什什、什么事都没有啦诶嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「什什什、什麼事都沒有啦欸嘿嘿……」",
