	["0013_00052"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡No pienses mal, solo estoy haciendo una simulación para estudiar a la lolis en su hábitat natural con el fin de fomentar una mejor comunicación con Wata-chan, ¿vale, Nanase?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是的这只是为了揭开洛丽塔生态以便日后跟渡酱进行顺畅的沟通的模拟练习啦奈奈濑！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是的這只是為了揭開蘿莉塔生態以便日後跟渡醬進行順暢的溝通的模擬練習啦奈奈瀨！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00051",
		linknext = "0013_00053",
		line = 607,
	},
	["0013_00053"] = {
