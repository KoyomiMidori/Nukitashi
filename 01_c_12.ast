					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué pasa si Nanase ingiere el Nanasenium?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果奈奈濑摄入奈奈濑分子会怎么样啊？”",
