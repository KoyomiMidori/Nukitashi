	["0013_00199"] = {
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No me habla más y caminamos en silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后就不再说任何话，安静地看着前方。",
