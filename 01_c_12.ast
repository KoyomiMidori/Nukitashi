				},
			},
			cn = {
				{
					"之前，我拿着道具的时候被风纪委员长深深地怀疑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之前，我拿著道具的時候被風紀委員長深深地懷疑了。",
					{"rt2"},
				},
