		linkback = "0013_00201",
		linknext = "0013_00203",
		line = 2619,
	},
	["0013_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es algo inesperado con esa apariencia, pero no es una persona que hable por hablar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然从她的外表看来有点令人意外，但她似乎本来就不是那种爱说废话的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然從她的外表看來有點令人意外，但她似乎本來就不是那種愛說廢話的人。",
					{"rt2"},
				},
