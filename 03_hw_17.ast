		{"bg", id=1, file="bg18_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm04", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de cenar, nos bañamos antes de relajarnos en la sala. En un parpadeo, ya son más de las 9.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吃完晚饭，洗完澡，我们三个人在客厅畅谈——就这样，一眨眼就过了9点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吃完晚飯，洗完澡，我們三個人在客廳暢談——就這樣，一眨眼就過了9點。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00216",
		linknext = "0067_00218",
		line = 2805,
	},
	["0067_00218"] = {
		{"bg", id=1, file="bg18_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00003", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1418", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Fwahhh... Tengo sueñito...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呼啊啊啊啊……发困了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呼啊啊啊啊……發困了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00217",
		linknext = "0067_00219",
		line = 2819,
	},
	["0067_00219"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fue un día muy ajetreado. Puedes usar mi cama.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天发生了很多事呢……请用我的床吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天發生了很多事呢……請用我的床吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00218",
		linknext = "0067_00220",
		line = 2831,
	},
	["0067_00220"] = {
		{"fg", file="hinami_02m_00003", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1419", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooh, gracias... Con permiso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……谢谢……那我就听你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……謝謝……那我就聽你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00219",
		linknext = "0067_00221",
		line = 2845,
	},
	["0067_00221"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a094"},
		{"bg", id=2, file="bg18_3l_00000", x=300, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tras frotarse los ojos para quitarse el sueño, se mete en la cama.",
					{"rt2"},
				},
			},
			cn = {
				{
					"揉着睡眼，渡酱慢腾腾地钻进被窝。",
					{"rt2"},
				},
			},
			tw = {
				{
					"揉著睡眼，渡醬慢騰騰地鑽進被窩。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00220",
		linknext = "0067_00222",
		line = 2859,
	},
	["0067_00222"] = {
		{"fg", file="hinami_02l_00003", file1="hinami_02l_00102", file2="hinami_02l_00201", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1420", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje... Huele como tú.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……是橘君的味道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……是橘君的味道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00221",
		linknext = "0067_00223",
		line = 2872,
	},
	["0067_00223"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? ¿A-Apesta...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……有，有什么异臭吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……有，有什麼異臭嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00222",
		linknext = "0067_00224",
		line = 2884,
	},
	["0067_00224"] = {
		{"text"},
		delay = {
			[4000] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=175, ease="easeinout_sine", delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1421", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ajaja, claro que no! Mmm... Es extraño, jeje, me hace sentir una especie de calor por dentro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈，才没有那种味道。嗅嗅……怎么说呢……嘿嘿，是种让胸口附近感到温暖的味道呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈，才沒有那種味道。嗅嗅……怎麼說呢……嘿嘿，是種讓胸口附近感到溫暖的味道呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00223",
		linknext = "0067_00225",
		line = 2897,
	},
	["0067_00225"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
