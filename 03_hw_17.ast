	},
	["0067_00031"] = {
		{"fg", file="ran_01f_00001", file1="ran_01f_00102", file2="ran_01f_00202", path=":fg/ran_01f/", id=30, ch="蘭", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0181", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“E-Esto... Cadetes, yo dirigiré el entrenamiento de hoy, así que síganme, por favor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“呃，诶……各位训练生，今天我来教你们，请跟我来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「呃，欸……各位訓練生，今天我來教你們，請跟我來。」",
