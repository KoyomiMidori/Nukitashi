		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1126", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Investigué un poco y parece que la Isla Seiran es un auténtico caos para las empresas, tanto así que ha empezado a perjudicar a las empresas legales del continente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我查了一下……因为受到能免费做爱的青蓝岛影响，本岛的风俗产业好像遭到了巨大打击……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我查了一下……因為受到能免費做愛的青藍島影響，本島的風俗產業好像遭到了巨大打擊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00056",
		linknext = "0067_00058",
		line = 730,
	},
	["0067_00058"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0426", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Entonces... ¿la yakuza quiere a Fumino-chan para acabar con la ley y provocar la recuperación económica de las empresas del continente?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这样的话，黑社会的人针对文乃酱是……想破坏条例使本岛的风俗产业复活吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這樣的話，黑社會的人針對文乃醬是……想破壞條例使本島的風俗產業復活嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00057",
		linknext = "0067_00059",
		line = 743,
	},
	["0067_00059"] = {
