	["0067_00204"] = {
		{"se", id=0, loop=0, file="se_a157"},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=0, y=-200, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se pone a cantar sobre la energía potencial mientras se sube a una silla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱一边唱着原创的位置能源歌，一边慢慢地站到椅子上。",
					{"rt2"},
				},
			},
			tw = {
