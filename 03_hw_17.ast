	["0067_00284"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a094", vol=60},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus manos me acarician el cabello, como si estuviera tranquilizando a un bebé.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小小的手掌像在哄婴儿一样抚摸着我的头发。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小小的手掌像在哄嬰兒一樣撫摸著我的頭髮。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00283",
		linknext = "0067_00285",
		line = 3621,
	},
	["0067_00285"] = {
		{"fg", file="hinami_01ll_00003", file1="hinami_01ll_00107", path=":fg/hinami_01ll/", id=5, lv=5, head="hinami_01ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1436", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Gracias por contarme todo esto... Me hace feliz saber esto, después de que hayas pasado tanto tiempo solo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“谢谢你告诉我……我很高兴。橘君……一直一个人在努力着呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「謝謝你告訴我……我很高興。橘君……一直一個人在努力著呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00284",
		linknext = "0067_00286",
		line = 3635,
	},
	["0067_00286"] = {
		{"fg", file="hinami_01ll_00003", file1="hinami_01ll_00102", path=":fg/hinami_01ll/", id=5, lv=5, head="hinami_01ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1437", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei-chan va a estar bien... Los quiero a los dos... así que podemos resolver esto juntos, ¿vale?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱……一定不会有事的……因为，我和橘君都喜欢礼酱……所以，我们一起努力想办法和她和好吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬……一定不會有事的……因為，我和橘君都喜歡禮醬……所以，我們一起努力想辦法和她和好吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00285",
		linknext = "0067_00287",
		line = 3649,
	},
	["0067_00287"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero ¿cómo? Después de lo que le hice...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是……那种事，办得到吗？我……明明对礼前辈做了那样的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是……那種事，辦得到嗎？我……明明對禮前輩做了那樣的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00286",
		linknext = "0067_00288",
		line = 3661,
	},
	["0067_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No podríamos habernos separado en peores condiciones. No puedo imaginar una situación en la que podamos volver a reírnos juntos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以最坏的形式分开——我打从心底觉得，再也不能和礼前辈开怀大笑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以最壞的形式分開——我打從心底覺得，再也不能和禮前輩開懷大笑了。",
					{"rt2"},
				},
			},
		},
