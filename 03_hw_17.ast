	["0067_00232"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1424", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Creo que esta vez no nos sorprenderá tanto, ¿verdad? ¿Por qué no vienes?”",
