	["0067_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Piensa. Si tengo energía para quejarme, tengo energía para pensar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"思考。有时间抱怨的话不如把时间用来思考。",
