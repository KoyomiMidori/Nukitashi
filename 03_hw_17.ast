	},
	["0067_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo, aunque logremos encontrar la base de la yakuza, no podemos atacarlos directamente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，就算得知了黑社会的所在地……要正面战斗实在太危险。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，就算得知了黑社會的所在地……要正面戰鬥實在太危險。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00121",
		linknext = "0067_00123",
		line = 1532,
	},
	["0067_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así que esta vez me infiltraré en la yakuza, y les daré información comprometedora de la SS. Estoy seguro de que también han tenido problemas con ellos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以这次，我要假借出卖FS的情报，潜入黑社会那边。他们也应该被FS折磨的不轻。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以這次，我要假借出賣FS的情報，潛入黑社會那邊。他們也應該被FS折磨的不輕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00122",
		linknext = "0067_00124",
		line = 1544,
	},
	["0067_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si logro entrar, tal vez pueda destruirlos desde adentro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要能进入内部，就会有很多瓦解他们的方法吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要能進入內部，就會有很多瓦解他們的方法吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00123",
		linknext = "0067_00125",
		line = 1556,
	},
	["0067_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué te parece Es una buena idea, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么样？你不觉得这样做会顺利吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼樣？你不覺得這樣做會順利嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00124",
		linknext = "0067_00126",
		line = 1568,
	},
	["0067_00126"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1383", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí, supongo que sí... Tal vez logres algo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……是啊……那样做的话，或许确实能达成目标。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……是啊……那樣做的話，或許確實能達成目標。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00125",
		linknext = "0067_00127",
		line = 1582,
	},
	["0067_00127"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1384", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Si nadie corre peligro, Fumino no tendrá que seguir luchando y esos niños estarán a salvo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我们也不会碰上危险的事，文乃酱也不用战斗，小孩子们也都有可能得救……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我們也不會碰上危險的事，文乃醬也不用戰鬥，小孩子們也都有可能得救……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00126",
		linknext = "0067_00128",
		line = 1594,
	},
	["0067_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, es lo mejor. Si funciona, nadie saldrá lastimado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……我觉得是最佳方案。这样的话，谁也不用受伤。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……我覺得是最佳方案。這樣的話，誰也不用受傷。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00127",
		linknext = "0067_00129",
		line = 1606,
	},
	["0067_00129"] = {
		{"se", id=1, stop=1, time=2000},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1385", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun... No me mientas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君……不可以说谎哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君……不可以說謊哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00128",
		linknext = "0067_00130",
		line = 1621,
	},
	["0067_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voz temblorosa me deja sin aliento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"颤抖的声音让我屏住了呼吸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"顫抖的聲音讓我屏住了呼吸。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00129",
		linknext = "0067_00131",
		line = 1631,
	},
	["0067_00131"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Mentir? No...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么说谎，我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼說謊，我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00130",
		linknext = "0067_00132",
		line = 1643,
	},
	["0067_00132"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1386", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Te vas a lastimar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君……会受伤吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君……會受傷吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00131",
		linknext = "0067_00133",
		line = 1657,
	},
	["0067_00133"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"ex", time=500, func="wait"},
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y qué pasa con...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00132",
		linknext = "0067_00134",
		line = 1671,
	},
	["0067_00134"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1387", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Dijiste que no querías que nadie saliera lastimado, ¿verdad? ¿Por qué propones un plan en el que va a pasar eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果你说不想伤害任何人的话……即使是橘君，也不能受伤啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果你說不想傷害任何人的話……即使是橘君，也不能受傷啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00133",
		linknext = "0067_00135",
		line = 1685,
	},
	["0067_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero es el plan perfecto para nuestro problema actual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……以现状来说，这是个最好的方案。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……以現狀來說，這是個最好的方案。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00134",
		linknext = "0067_00136",
		line = 1696,
	},
	["0067_00136"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00128", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1388", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Aunque lo fuera, no puedes sacrificarte de esa manera.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“即使是这样……为了他人而牺牲自己也太奇怪了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「即使是這樣……為了他人而犧牲自己也太奇怪了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00135",
		linknext = "0067_00137",
		line = 1710,
	},
	["0067_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero esto es mi...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，这事……本来就是我起的头……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，這事……本來就是我起的頭……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00136",
		linknext = "0067_00138",
		line = 1721,
	},
	["0067_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cierro los ojos y veo a Rei-senpai.",
					{"rt2"},
				},
			},
			cn = {
				{
					"闭上眼睛，眼里闪过礼前辈的身影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"閉上眼睛，眼裡閃過禮前輩的身影。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00137",
		linknext = "0067_00139",
		line = 1731,
	},
	["0067_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La traicioné, le apunté con su regalo, y temblaba de tristeza, como si todo su mundo se hubiera derrumbado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被背叛，被送我的枪对准时——她那在悲伤中颤抖，弱小的身影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被背叛，被送我的槍對準時——她那在悲傷中顫抖，弱小的身影。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00138",
		linknext = "0067_00140",
		line = 1741,
	},
	["0067_00140"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No quiero volver a lastimar a nadie más por mis propios objetivos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我已经——不想再为了达成自己的目的，而做出伤害他人的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我已經——不想再為了達成自己的目的，而做出傷害他人的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00139",
		linknext = "0067_00141",
		line = 1754,
	},
	["0067_00141"] = {
