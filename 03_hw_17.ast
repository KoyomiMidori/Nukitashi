	["0067_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fue mi decisión no entregar a Fumino. Además, desde que me fui de la SS, perdimos nuestra principal fuente de información.",
					{"rt2"},
				},
			},
			cn = {
				{
					"决定不交出文乃的也是我，主动脱离情报来源FS的也是我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"決定不交出文乃的也是我，主動脫離情報來源FS的也是我。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00099",
