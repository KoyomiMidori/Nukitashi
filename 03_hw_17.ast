	["0067_00024"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se queda quieta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"前辈突然停下了动作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"前輩突然停下了動作。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00023",
		linknext = "0067_00025",
		line = 304,
	},
	["0067_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Un pesado silencio se apodera de la habitación. Es tan opresivo que amenaza con asfixiarme.",
					{"rt2"},
				},
			},
			cn = {
				{
					"谁也开不了口。现场笼罩着连呼吸都忘记的沉重沉默。",
					{"rt2"},
				},
			},
			tw = {
				{
					"誰也開不了口。現場籠罩著連呼吸都忘記的沉重沉默。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00024",
		linknext = "0067_00026",
		line = 314,
	},
	["0067_00026"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"ex", time=700, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me mira, como si recordara algo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈——好像想起什么似的瞪着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩——好像想起什麼似的瞪著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00025",
		linknext = "0067_00027",
		line = 327,
	},
	["0067_00027"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0698", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué crees que haces al volver aquí...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你竟敢大摇大摆地来到这里……？”",
