		linkback = "0067_00034",
		linknext = "0067_00036",
		line = 428,
	},
	["0067_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Emociones que apenas puedo comprender se agitan dentro de mí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复杂的情绪混杂在一起，心脏开始不规则地跳动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"複雜的情緒混雜在一起，心臟開始不規則地跳動。",
