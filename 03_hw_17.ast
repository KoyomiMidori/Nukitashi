	["0067_00046"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0701", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Por qué...? ¿Que por qué? ¿Me estás preguntando por qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你说为什么……！？为什么……你是这么说的吗……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你說為什麼……！？為什麼……你是這麼說的嗎……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00045",
		linknext = "0067_00047",
		line = 558,
	},
	["0067_00047"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0702", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡¿Eres tan idiota que ni siquiera puedes comprender lo que hiciste?! ¡Ahora todos son tus enemigos! ¡La SS, la OSS, incluso la yakuza! ¡Todo es tu culpa!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你不知道自己干了什么吗！？SS、OSS，还有黑社会……你把所有人都转为敌人了！！混蛋！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你不知道自己幹了什麼嗎！？SS、OSS，還有黑社會……你把所有人都轉為敵人了！！混蛋！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00046",
		linknext = "0067_00048",
		line = 572,
	},
	["0067_00048"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0703", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hinami también es parte de tu grupito, ¿no? ¿Tienes idea de lo que le pasaría si te denunciara? ¿O es que eres tan tonto?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见是你的同伴吧……！如果我报告了你的事情的话，你觉得那孩子会遭遇到什么！？你连这点事情都不知道吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見是你的同伴吧……！如果我報告了你的事情的話，你覺得那孩子會遭遇到什麼！？你連這點事情都不知道嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00047",
		linknext = "0067_00049",
		line = 584,
	},
