	["0067_00211"] = {
		{"se", id=0, loop=0, file="se_a157"},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=0, y=200, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1416", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje... Me encantan los platos planos... Por alguna razón, me dan una sensación de déjà vu.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嘿嘿……真棒呢，我喜欢扁平的盘子……感觉很亲切。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嘿嘿……真棒呢，我喜歡扁平的盤子……感覺很親切。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00210",
		linknext = "0067_00212",
		line = 2691,
	},
	["0067_00212"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No son grandiosos? Son planos... y suavecitos...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，是啊……怎么说呢，挺平滑的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，是啊……怎麼說呢，挺平滑的。」",
