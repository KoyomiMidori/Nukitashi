		linkback = "0067_00028",
		linknext = "0067_00030",
		line = 359,
	},
	["0067_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las palabras se me atascan en la garganta y no puedo hablar.",
					{"rt2"},
