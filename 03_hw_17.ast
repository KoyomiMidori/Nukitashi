		linkback = "0067_00032",
		linknext = "0067_00034",
		line = 408,
	},
	["0067_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su mirada es hostil.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她锐利的眼光掩饰不住敌意。",
