	},
	["0067_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debido a eso, nuestras posibles vías de avance se han visto bastante limitadas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，我们才会想不出下一步该怎么走。",
					{"rt2"},
				},
