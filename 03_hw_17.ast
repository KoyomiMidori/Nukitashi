	},
	["0067_00208"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=-200},
		{"fg", file="asane_02m_00002", file1="asane_02m_00124", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=600, mode=3, x=-600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=800},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="asane_02m_00002", file1="asane_02m_00128", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1128", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Manito, tengo hambre... ¿Eh? Wata-chan está aquí. Pensaba que la habías llevado a casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥……我肚子饿了啊……咦？渡酱在……不是已经送走了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥……我肚子餓了啊……咦？渡醬在……不是已經送走了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00207",
		linknext = "0067_00209",
		line = 2648,
	},
	["0067_00209"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pasaron cosas, así que se quedará aquí esta noche. Nos está preparando una tortilla de arroz, así que espera un momento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为发生了很多事，所以让她今晚住下来。她好像要为我们做蛋包饭，再等一会儿吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為發生了很多事，所以讓她今晚住下來。她好像要為我們做蛋包飯，再等一下吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00208",
		linknext = "0067_00210",
		line = 2660,
	},
	["0067_00210"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00113", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
