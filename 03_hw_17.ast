	["0067_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si tanto me odias, ¿por qué no me has denunciado?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明明那么恨我……为什么你却对我们的事情保持沉默。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「明明那麼恨我……為什麼你卻對我們的事情保持沉默。」",
					{"rt2"},
