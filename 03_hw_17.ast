		},
		linkback = "0067_00026",
		linknext = "0067_00028",
		line = 339,
	},
	["0067_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La tensión incrementa.",
