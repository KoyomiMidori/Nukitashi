			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00020",
		linknext = "0067_00022",
		line = 268,
	},
	["0067_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0697", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Cómo has estado? ¿Te sientes mejor? No te sientas presionado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“最近怎么样？头的伤已经没事了吗？不要太勉强了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「最近怎麼樣？頭的傷已經沒事了嗎？不要太勉強了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00021",
		linknext = "0067_00023",
		line = 280,
	},
	["0067_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
