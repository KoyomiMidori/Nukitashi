	["0067_00061"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1375", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Estás bien? Hoy te veo muy deprimido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……没事吧？橘君，今天一直……露出悲伤的表情哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……沒事吧？橘君，今天一直……露出悲傷的表情哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00060",
		linknext = "0067_00062",
		line = 789,
	},
	["0067_00062"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, lo siento... Ayer conseguí un final muy deprimente en un eroge y estoy un poco deprimido por eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思……昨天玩的色情游戏是无可救药的忧郁剧本，所以被影响了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思……昨天玩的色情遊戲是無可救藥的憂鬱劇本，所以被影響了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00061",
		linknext = "0067_00063",
		line = 801,
	},
	["0067_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy seguro de que Wata-chan está más preocupada por Rei-senpai que yo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱应该比我更在意礼前辈吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬應該比我更在意禮前輩吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00062",
		linknext = "0067_00064",
		line = 811,
	},
	["0067_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No tengo energías para preocuparme por ella. Necesito concentrarme.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不能让她再为那件事增加多余的担心了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不能讓她再為那件事增加多餘的擔心了。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00063",
		linknext = "0067_00065",
		line = 821,
	},
	["0067_00065"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0427", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Por qué la yakuza busca a Fumino-chan? ¿Tienes alguna idea?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那么，橘同学怎么看呢？那些黑社会的人针对着文乃酱这事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那麼，橘同學怎麼看呢？那些黑社會的人針對著文乃醬這事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00064",
		linknext = "0067_00066",
		line = 834,
	},
	["0067_00066"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nunca podría perdonarlos. Se están ensañando con niños inocentes, así que hay que acabar con ellos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然是难以原谅。居然对小孩作出那样的事情……那样的家伙，我一定要打垮他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然是難以原諒。居然對小孩作出那樣的事情……那樣的傢伙，我一定要打垮他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00065",
		linknext = "0067_00067",
		line = 846,
	},
	["0067_00067"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
