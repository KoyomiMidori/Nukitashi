	["0067_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se ve chistosa, pero la calidad es increíble. Se le ha dedicado mucho trabajo.",
