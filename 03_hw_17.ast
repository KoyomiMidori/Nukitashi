	["0067_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El NLNS está rodeado de enemigos por todos lados, y aquí estoy yo enfadándome por una chica.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明NLNS在四面楚歌的情况下，没有闲情去管私情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明NLNS在四面楚歌的情況下，沒有閒情去管私情。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00072",
		linknext = "0067_00074",
		line = 935,
	},
	["0067_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Qué me pasa?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我怎么可以这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我怎麼可以這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00073",
		linknext = "0067_00075",
		line = 945,
	},
	["0067_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Soy el líder. Necesito poner mis cosas en orden.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是队长吧——不更加用心点可不行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是隊長吧——不更加用心點可不行。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00074",
		linknext = "0067_00076",
		line = 955,
	},
	["0067_00076"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Miro a Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把目光转向文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我把目光轉向文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00075",
		linknext = "0067_00077",
		line = 966,
	},
	["0067_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Técnicamente estamos en el campus, pero nadie más sabe nada de la base secreta del NLNS. Supongo que ella no ve la necesidad de hacerse pasar por un chico, así que lleva su ropa tradicional.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说是在学校内，但这里却是只有我们NLNS知道的秘密基地——没有必要女扮男装的她今天穿着习惯的和服。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說是在學校內，但這裡卻是只有我們NLNS知道的秘密基地——沒有必要女扮男裝的她今天穿著習慣的和服。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00076",
		linknext = "0067_00078",
		line = 976,
	},
	["0067_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, llevas mucho tiempo luchando contra la yakuza. ¿Tienes alguna idea de dónde podría estar su guarida?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃——你一直在和黑社会战斗吧？有关那些家伙的根据地在哪里……你有什么线索吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃——你一直在和黑社會戰鬥吧？有關那些傢伙的根據地在哪裡……你有什麼線索嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00077",
		linknext = "0067_00079",
		line = 988,
	},
	["0067_00079"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0243", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Nunca pude encontrarla. Lo siento mucho...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……非常抱歉，我也不知道具体地点……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……非常抱歉，我也不知道具體地點……」",
					{"rt2"},
				},
			},
