				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pase lo que pase, tenemos que encontrar el centro del comercio sexual ilegal... la base de la yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"地下风俗的所在地——光找出黑社会的窝是不行的。",
					{"rt2"},
