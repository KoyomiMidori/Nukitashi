		linknext = "0067_00038",
		line = 448,
	},
	["0067_00038"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0700", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Tan divertido te pareció todo el tiempo? ¡Debió ser muy gracioso ver a una oficial de la SS bailando en la palma de tu mano!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“骗我有那么开心吗？FS的队长在手心里跳舞的样子一定很滑稽吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「騙我有那麼開心嗎？FS的隊長在手心裡跳舞的樣子一定很滑稽吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00037",
		linknext = "0067_00039",
		line = 460,
	},
	["0067_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No tengo excusas ni argumentos que dar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我没有理由进行抗辩和辩解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沒有理由進行抗辯和辯解。",
					{"rt2"},
				},
