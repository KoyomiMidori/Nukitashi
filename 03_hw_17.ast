	["0067_00156"] = {
		{"evset", file="hcg03", set="hcg03", path=":ev/hcg03/"},
		{"evset", file="hcg03_00001", set="hcg03_000", path=":ev/hcg03_000/"},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="hcg03_00002", x=0, y=0, path=":cg/hcg03/", ev=1, time=500, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1400", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Y sé lo que vas a decir! Vas a decir que todo esto es culpa tuya y que tú nos metiste en esto, ¡pero yo nunca he pensado eso!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我从来不觉得自己是被卷进来的……！橘君说过的话，我现在非常明白……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我從來不覺得自己是被捲進來的……！橘君說過的話，我現在非常明白……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00155",
		linknext = "0067_00157",
		line = 1963,
	},
	["0067_00157"] = {
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No quiero que nadie salga lastimado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我——一边想着不能伤害到任何人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我——一邊想著不能傷害到任何人。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00156",
		linknext = "0067_00158",
		line = 1974,
	},
	["0067_00158"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1401", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No quiero vivir sin la persona que amo... Quiero estar al lado de la persona que amo... ¡Si la persona que amo está pasando por un mal momento, quiero ayudarla!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我想和喜欢的人在一起……我想待在喜欢的人身边……如果喜欢的人痛苦……我就想成为他的力量……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我想和喜歡的人在一起……我想待在喜歡的人身邊……如果喜歡的人痛苦……我就想成為他的力量……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00157",
		linknext = "0067_00159",
		line = 1986,
	},
