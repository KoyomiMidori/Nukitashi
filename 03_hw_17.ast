		linkback = "0067_00033",
		linknext = "0067_00035",
		line = 418,
	},
	["0067_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tiene el mismo tono de voz que cuando se dirige a un enemigo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那声音就像礼前辈攻击“逆贼”时那样。",
