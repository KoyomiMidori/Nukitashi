					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí... así es.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……原来是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……原來是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00254",
		linknext = "0067_00256",
		line = 3293,
	},
	["0067_00256"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Algunos eran raros, pero ninguno era malo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“SS……虽然有很多奇怪的家伙，但都不是坏人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「SS……雖然有很多奇怪的傢伙，但都不是壞人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00255",
		linknext = "0067_00257",
		line = 3305,
	},
	["0067_00257"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hice amigos mientras soportábamos juntos el entrenamiento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他们都是心地善良的人，还有一起接受高强度训练的同伴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他們都是心地善良的人，還有一起接受高強度訓練的同伴……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00256",
		linknext = "0067_00258",
		line = 3316,
	},
	["0067_00258"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1430", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mhmm.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00257",
		linknext = "0067_00259",
		line = 3328,
	},
	["0067_00259"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Especialmente... Rei-senpai. Siento... que le debo mucho a ella. Más que a cualquier otra persona.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“特别是……礼前辈比谁都照顾我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「特別是……禮前輩比誰都照顧我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00258",
		linknext = "0067_00260",
		line = 3340,
	},
	["0067_00260"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ella me enseñó el combate cuerpo a cuerpo y a cómo pelear.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“通过一对一的训练，教我战斗的诀窍……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「通過一對一的訓練，教我戰鬥的訣竅……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00259",
		linknext = "0067_00261",
		line = 3351,
	},
	["0067_00261"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me sentía desesperado, pero ella estuvo ahí para apoyarme... Cuando finalmente me felicitó por mi esfuerzo, me sentí muy feliz.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个人处处都照顾着不长进的我……被她表扬说很努力，我很高兴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個人處處都照顧著不長進的我……被她表揚說很努力，我很高興……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00260",
		linknext = "0067_00262",
		line = 3362,
	},
	["0067_00262"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En un abrir y cerrar de ojos, mi arduo trabajo ya no tenía nada que ver con ser espía. Aunque creo que en ese momento no me di cuenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等意识到的时候，我已经忘了间谍的身份，只觉得自己应该更加努力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等意識到的時候，我已經忘了間諜的身份，只覺得自己應該更加努力……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00261",
		linknext = "0067_00263",
		line = 3374,
	},
	["0067_00263"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1431", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00262",
		linknext = "0067_00264",
		line = 3386,
	},
	["0067_00264"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo... traicioné la confianza de Rei-senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，我……用最差劲的方式辜负了礼前辈的信任。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，我……用最差勁的方式辜負了禮前輩的信任。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00263",
		linknext = "0067_00265",
		line = 3398,
	},
	["0067_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuando recuerdo aquellos días, a los que nunca podré volver, se me llenan los ojos de lágrimas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我清楚地回忆起已经无法回去的日子——眼角发热。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我清楚地回憶起已經無法回去的日子——眼角發熱。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00264",
		linknext = "0067_00266",
		line = 3408,
	},
	["0067_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Usé lo que me enseñó... Lo usé en su contra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我……利用礼前辈教我的东西……欺骗了礼前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我……利用禮前輩教我的東西……欺騙了禮前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00265",
		linknext = "0067_00267",
		line = 3419,
	},
	["0067_00267"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00108", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El arma con el que le apunté fue un regalo que ella me dio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“用礼前辈送我的枪……对准了礼前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「用禮前輩送我的槍……對準了禮前輩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00266",
		linknext = "0067_00268",
		line = 3431,
	},
	["0067_00268"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1432", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……原来是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……原來是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00267",
		linknext = "0067_00269",
		line = 3443,
	},
	["0067_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Desde que decidí infiltrarme en la SS, sabía que esto pasaría.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从一开始……决定潜入FS时，我就知道总有一天会变成这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從一開始……決定潛入FS時，我就知道總有一天會變成這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00268",
		linknext = "0067_00270",
		line = 3454,
	},
	["0067_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero... yo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……我还是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……我還是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00269",
		linknext = "0067_00271",
		line = 3465,
	},
	["0067_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mis palabras están salpicadas de sollozos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"声音里夹杂着哽咽。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聲音裡夾雜著哽咽。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00270",
		linknext = "0067_00272",
		line = 3475,
	},
	["0067_00272"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No quería que esto terminara así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不想以那种形式……分开……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不想以那種形式……分開……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00271",
		linknext = "0067_00273",
		line = 3487,
	},
	["0067_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que estoy siendo terriblemente egoísta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我心底觉得这是自私的行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我心底覺得這是自私的行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00272",
		linknext = "0067_00274",
		line = 3497,
	},
	["0067_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fue el camino que elegí. Me infiltré entre ellos, le mentí, la usé, la traicioné... ¿y ahora estoy llorando por? ¿Cómo se puede ser tan egoísta?",
					{"rt2"},
				},
			},
			cn = {
				{
					"自己潜入，自己背叛她，伤害她，然后哭着说自己不愿意这样——实在是太自私了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自己潛入，自己背叛她，傷害她，然後哭著說自己不願意這樣——實在是太自私了。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00273",
		linknext = "0067_00275",
		line = 3507,
	},
	["0067_00275"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1433", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí... Fue bastante difícil, ¿cierto, Tachibana-kun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……真的很痛苦呢……橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……真的很痛苦呢……橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00274",
		linknext = "0067_00276",
		line = 3519,
	},
	["0067_00276"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A pesar de eso, Wata-chan no me critica. Solo me escucha y me abraza con ternura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，渡酱却一句都没有谴责我，用柔软温暖的手拥抱我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，渡醬卻一句都沒有譴責我，用柔軟溫暖的手擁抱我。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00275",
		linknext = "0067_00277",
		line = 3529,
	},
	["0067_00277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su calidez se filtra en las cicatrices de mi corazón.",
					{"rt2"},
				},
			},
