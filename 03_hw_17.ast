	["0067_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy seguro de que, incluso ahora, sigue pensando en Wata-chan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个人，现在也在意着渡酱。",
					{"rt2"},
