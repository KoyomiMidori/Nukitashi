		{"cgact", file="cgact", id=19, act="移動", x=0, y=60, time=7000, lv=5},
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1389", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Pero qué hay de ti, Tachibana-kun?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那也不是橘君可以受伤的理由啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那也不是橘君可以受傷的理由啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00140",
		linknext = "0067_00142",
		line = 1773,
	},
	["0067_00142"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1390", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No quiero eso... ¡No quiero verte sufrir!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我也不愿意啊……我也不想看到橘君受伤啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我也不願意啊……我也不想看到橘君受傷啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00141",
		linknext = "0067_00143",
		line = 1785,
	},
	["0067_00143"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1391", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Dijiste que no querías sacrificar a Fumino... ¡¿Cómo puedes decir todo eso y sacrificarte en su lugar?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你对文乃说不可以牺牲自己……但是却为什么不珍惜自己呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你對文乃說不可以犧牲自己……但是卻為什麼不珍惜自己呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00142",
		linknext = "0067_00144",
		line = 1797,
	},
	["0067_00144"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=19, time=700, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"evset", file="hcg03", set="hcg03", path=":ev/hcg03/"},
		{"evset", file="hcg03_00001", set="hcg03_000", path=":ev/hcg03_000/"},
		{"bg", id=18, file="hcg03_00001", x=0, y=0, path=":cg/hcg03/", ev=1, time=1, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			ja = {
