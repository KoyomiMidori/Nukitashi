					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……总之不管他们的目的是什么，我们要做的事情都不会改变……对吧，淳？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……總之不管他們的目的是什麼，我們要做的事情都不會改變……對吧，淳？」",
					{"rt2"},
				},
			},
