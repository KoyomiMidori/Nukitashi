		line = 349,
	},
	["0067_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Recuerdo la expresión desgarradora que tenía en el rostro cuando le apunté con mi arma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怒气逼人的表情，让我想起把枪瞄准前辈的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"怒氣逼人的表情，讓我想起把槍瞄準前輩的時候。",
					{"rt2"},
				},
			},
