	},
	["0067_00114"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1380", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Se te ocurrió algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你想到什么了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你想到什麼了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00113",
		linknext = "0067_00115",
		line = 1435,
	},
	["0067_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Creo que sí. No te preocupes, no voy a sugerir que te vuelvas a unir a la SS como la última vez.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的——没关系，请不要担心。我不会像之前那样说我要回到FS。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的——沒關係，請不要擔心。我不會像之前那樣說我要回到FS。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00114",
		linknext = "0067_00116",
		line = 1446,
	},
	["0067_00116"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1381", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Qué alivio. ¿Qué tienes pensado?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……所以，该怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……所以，該怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00115",
		linknext = "0067_00117",
		line = 1458,
	},
	["0067_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Primero, necesito reunir toda la información la base de operaciones del comercio sexual ilegal. Iba a preguntarle a Rei-senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先，有必要打听出关于地下风俗的所在地……我想去问问礼前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先，有必要打聽出關於地下風俗的所在地……我想去問問禮前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00116",
		linknext = "0067_00118",
		line = 1470,
	},
	["0067_00118"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1382", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿A Rei-chan? Aunque lo supiera, ¿te lo diría...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱……？但是……就算她知道，会告诉我们吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬……？但是……就算她知道，會告訴我們嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00117",
		linknext = "0067_00119",
		line = 1484,
	},
	["0067_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Va a hablar. Sabe que tenemos a Fumino, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要让她告诉我们。礼前辈知道我们拥有文乃的事情对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要讓她告訴我們。禮前輩知道我們擁有文乃的事情對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00118",
		linknext = "0067_00120",
		line = 1496,
	},
	["0067_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si usamos a Fumino para amenazar al gobernador... ella, que es la presidenta del comité de moral pública, tendrá que hacernos caso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跟她说我要用文乃去威胁仁浦先生的话……作为风纪委员长的她应该就不得不说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跟她說我要用文乃去威脅仁浦先生的話……作為風紀委員長的她應該就不得不說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00119",
		linknext = "0067_00121",
		line = 1507,
	},
