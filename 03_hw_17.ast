	["0067_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan nos lanza una extraña mirada de reojo, asintiendo con complicidad mientras murmura para sí misma.",
					{"rt2"},
				},
			},
			cn = {
