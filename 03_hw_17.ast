	["0067_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras tanto, aunque tenemos más miembros con Fumino, no hemos logrado ningún avance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而——文乃加入我们之后，事情却一直停滞不前。",
