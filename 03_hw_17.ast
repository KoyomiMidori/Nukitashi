		{"se", id=0, loop=0, file="se_a078"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Con permiso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“打扰了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「打擾了。」",
					{"rt2"},
				},
			},
		},
		linknext = "0067_00002",
		line = 21,
	},
	["0067_00002"] = {
		{"bg", id=2, file="bg23_1_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="ran_01m_00001", file1="ran_01m_00109", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="蘭", id=8, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="ran0177", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Sí, sí... ¿Eh? ¡¿Tachibana-kun?! ¿Qué pasa? ¡¿Viniste a integrarte otra vez?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“嗯嗯……诶？橘君！？怎、怎么了……你要回FS了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「嗯嗯……欸？橘君！？怎、怎麼了……你要回FS了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00001",
		linknext = "0067_00003",
		line = 38,
	},
	["0067_00003"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, no. Solo dejé algunas cosas aquí y vine a recogerlas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……我还有私人物品，来取的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……我還有私人物品，來取的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00002",
		linknext = "0067_00004",
		line = 50,
	},
	["0067_00004"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00106", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0178", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Ah, ya veo... Qué lástima. ¿Seguro que no quieres volver? Oí que te sientes responsable por haber perdido a Fumino, pero no tienes que renunciar por eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“啊，是这样啊……很遗憾。现在也不想回来吗？就算让文乃跑了，也没必要不干啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「啊，是這樣啊……很遺憾。現在也不想回來嗎？就算讓文乃跑了，也沒必要不幹啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00003",
		linknext = "0067_00005",
		line = 64,
	},
	["0067_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Creen que me fui por la culpa de no haber rescatado a Fumino?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我之所以放弃FS，好像被认为是因为出于让文乃跑掉的责任感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我之所以放棄FS，好像被認為是因為出於讓文乃跑掉的責任感。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00004",
		linknext = "0067_00006",
		line = 74,
	},
	["0067_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, no me fui por eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“并不是因为那么帅的理由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「並不是因為那麼帥的理由。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00005",
		linknext = "0067_00007",
		line = 86,
	},
	["0067_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me temblaban las rodillas al manejar armas de verdad, así que no estoy hecho para la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被真枪对准的时候，我的双脚发抖……我不适合FS。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被真槍對準的時候，我的雙腳發抖……我不適合FS。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00006",
		linknext = "0067_00008",
		line = 98,
	},
	["0067_00008"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0179", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Ya veo... Desde que renunciaste, Rei-senpai se ha vuelto muy reservada. Intenta ocultarlo, pero se nota.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“是吗……自从橘君离开FS之后，礼前辈也自闭了……虽然没表现出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「是嗎……自從橘君離開FS之後，禮前輩也自閉了……雖然沒表現出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00007",
		linknext = "0067_00009",
		line = 110,
	},
	["0067_00009"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00008",
		linknext = "0067_00010",
		line = 123,
	},
	["0067_00010"] = {
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0012", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Está como que ausente durante los entrenamientos. Se queda mirando al cielo, se muerde el labio...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“她训练的时候偶尔会心不在焉哦。总是仰望天空，咬着下唇。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「她訓練的時候偶爾會心不在焉哦。總是仰望天空，咬著下唇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00009",
		linknext = "0067_00011",
		line = 137,
	},
	["0067_00011"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Sí. Quién hubiera pensado que nuestra instructora podría actuar así... Esa posibilidad nunca apareció en mis datos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“是啊。教官竟然会露出那种表情……在我的数据里没有……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「是啊。教官竟然會露出那種表情……在我的數據裡沒有……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00010",
		linknext = "0067_00012",
		line = 149,
	},
	["0067_00012"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="obekka0009", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"おべっか"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"おべっか", "Lamebotas"},
					"“Su tono también se ha suavizado mucho. Es como si se le hubiera apagado el fuego cuando habla... Extraño que me golpee con sus tormentas de insultos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"おべっか", "马屁精"},
					"“骂人也不神气了呢……只会说非常普通的话……我明明很喜欢的，喜欢教官的痛骂。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"おべっか", "馬屁精"},
					"「罵人也不神氣了呢……只會說非常普通的話……我明明很喜歡的，喜歡教官的痛罵。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00011",
		linknext = "0067_00013",
		line = 161,
	},
	["0067_00013"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00012",
		linknext = "0067_00014",
		line = 174,
	},
	["0067_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No me sorprende.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也难怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也難怪。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00013",
		linknext = "0067_00015",
		line = 184,
	},
	["0067_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aparenta ser fuerte, pero es mucho más débil de lo que todos piensan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈的精神面并没有她给旁人的印象般那么强大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩的精神面並沒有她給旁人的印象般那麼強大。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00014",
		linknext = "0067_00016",
		line = 194,
	},
	["0067_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Actúa como una jefa estoica, a la que nada le afecta, pero solo es humana. Por dentro es como cualquier otra chica de su edad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然作为风纪委员长在众人面前不动声色，但她的言行举止却和其他人一样，是个与年龄相符的女孩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然作為風紀委員長在眾人面前不動聲色，但她的言行舉止卻和其他人一樣，是個與年齡相符的女孩。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00015",
		linknext = "0067_00017",
		line = 204,
	},
	["0067_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Ser traicionada por alguien en quien confiaba en un momento así, además de verse obligada a considerar a una vieja amiga como enemiga? Esas heridas debieron de ser muy profundas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那种困境中被同伴背叛，发现旧友也是敌人——她并没有强大到这样都不受伤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那種困境中被同伴背叛，發現舊友也是敵人——她並沒有強大到這樣都不受傷。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00016",
		linknext = "0067_00018",
		line = 214,
	},
	["0067_00018"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="礼", id=9, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0695", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ran, sobre los cadetes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“兰，关于训练生们之后的事情——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「蘭，關於訓練生們之後的事情——」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00017",
		linknext = "0067_00019",
		line = 229,
	},
	["0067_00019"] = {
		{"fg", file="ran_01f_00001", file1="ran_01f_00109", file2="ran_01f_00202", path=":fg/ran_01f/", id=30, ch="蘭", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0180", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Ah... Rei-senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“啊……礼前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「啊……禮前輩……」",
