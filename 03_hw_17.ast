		linkback = "0067_00102",
		linknext = "0067_00104",
		line = 1314,
	},
	["0067_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si me hubiera quedado en la SS y hubiera conservado su confianza, no estaríamos en estas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……要是我能好好地待在FS里面，就没必要这样烦恼了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……要是我能好好地待在FS裡面，就沒必要這樣煩惱了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00103",
		linknext = "0067_00105",
		line = 1326,
	},
	["0067_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No puedo aceptar nuestra situación actual, o no podremos ir a ningún lado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了采取下一步，我不能安于现状。",
					{"rt2"},
				},
