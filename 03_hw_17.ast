	["0067_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi ritmo cardíaco y mi respiración se han disparado más allá de los límites normales.",
					{"rt2"},
				},
			},
			cn = {
				{
					"呼吸也不规律起来。",
					{"rt2"},
				},
