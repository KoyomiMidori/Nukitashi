		line = 382,
	},
	["0067_00032"] = {
		{"se", id=0, loop=0, file="se_a058"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hanamaru desaparece en el pasillo con los cadetes, mirándonos un par de veces antes de desaparecer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸委员长和训练生一边尴尬地窥探着这边的情况，一边朝走廊方向消失。",
					{"rt2"},
				},
			},
			tw = {
				{
					"花丸委員長和訓練生一邊尷尬地窺探著這邊的情況，一邊朝走廊方向消失。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00031",
		linknext = "0067_00033",
		line = 393,
	},
	["0067_00033"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0699", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué quieres? ¿Viniste a traicionarme otra vez?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你有什么事？又要来骗我了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你有什麼事？又要來騙我了？」",
