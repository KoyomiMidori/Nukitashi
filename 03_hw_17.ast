			tw = {
				{
					"那個人，現在也在意著渡醬。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00298",
		linknext = "0067_00300",
		line = 3800,
	},
	["0067_00300"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras tenga esa correa, estoy seguro de que podremos llenar el agujero que se ha cavado entre nosotros.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要有那个挂件，总有一天还能重新将羁绊连接起来……我有那种感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要有那個挂件，總有一天還能重新將羈絆連接起來……我有那種感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00299",
		linknext = "0067_00301",
		line = 3810,
	},
	["0067_00301"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gracias, Wata-chan-senpai... Me siento más tranquilo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……谢谢你，渡酱前辈。总觉得……身体轻松多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……謝謝你，渡醬前輩。總覺得……身體輕鬆多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00300",
		linknext = "0067_00302",
		line = 3822,
	},
	["0067_00302"] = {
		{"fg", file="hinami_02ll_00003", file1="hinami_02ll_00122", file2="hinami_02ll_00201", path=":fg/hinami_02ll/", id=5, lv=5, head="hinami_02ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=50},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1440", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tranquilo, no dudes en hablar conmigo cuando te sientas perdido. Si estás pasando por un mal momento o te sientes triste...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事……痛苦的时候随时都可以跟我说哦。为难的时候也是，悲伤的时候也是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒事……痛苦的時候隨時都可以跟我說哦。為難的時候也是，悲傷的時候也是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00301",
		linknext = "0067_00303",
		line = 3836,
	},
	["0067_00303"] = {
		{"fg", file="hinami_02ll_00003", file1="hinami_02ll_00129", file2="hinami_02ll_00201", path=":fg/hinami_02ll/", id=5, lv=5, head="hinami_02ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=50},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1441", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, pero puedes hablar conmigo en otras ocasiones. Quiero saber todo lo que sea divertido o lo que te haga feliz... Todo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，但是……不止这些哦……高兴和快乐的事情……什么事情我都希望你能跟我说呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，但是……不止這些哦……高興和快樂的事情……什麼事情我都希望你能跟我說呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00302",
		linknext = "0067_00304",
		line = 3850,
	},
	["0067_00304"] = {
