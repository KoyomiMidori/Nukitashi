	["0067_00230"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00110", file2="hinami_01l_00201", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
