					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那……是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那……是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00143",
		linknext = "0067_00145",
		line = 1814,
	},
	["0067_00145"] = {
		{"cgdel", id=19, time=100, alphadel=1, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1392", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Waaah... Recuerdo lo feliz que te veías la primera vez que nos contaste que Rei-chan te felicitó.. Recuerdo tu sonrisa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜呜……橘君你跟我说自己被礼酱夸奖的时候，看起来非常开心……还笑了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚嗚……橘君你跟我說自己被禮醬誇獎的時候，看起來非常開心……還笑了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00144",
		linknext = "0067_00146",
		line = 1828,
	},
	["0067_00146"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1393", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero... te dispararon en la cabeza y ahora Rei-chan te odia... Desde entonces, no has dejado de hacer sugerencias absurdas. ¡Sé que estás exagerando!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是……被击中头部，被礼酱讨厌……橘君，从那之后就一直很奇怪……我知道你在勉强自己……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是……被擊中頭部，被禮醬討厭……橘君，從那之後就一直很奇怪……我知道你在勉強自己……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00145",
		linknext = "0067_00147",
		line = 1840,
	},
	["0067_00147"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1394", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Crees que eres el único que ha estado sufriendo? ¡La quería como amiga, pero ahora me ignora, como si ni siquiera existiera! No quiero que las cosas sigan así para siempre...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“而且，我也很痛苦啊……被最喜欢的礼酱无视，不愿跟我说话，以后可能会一直这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「而且，我也很痛苦啊……被最喜歡的禮醬無視，不願跟我說話，以後可能會一直這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00146",
		linknext = "0067_00148",
		line = 1852,
	},
	["0067_00148"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1395", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero... pero... sé que te has esforzado mucho. Te estás exigiendo demasiado y estás haciendo esto por nosotras. Soy testigo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是……可是，我也知道橘君在努力……勉强自己，为了大家而努力，我都知道……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是……可是，我也知道橘君在努力……勉強自己，為了大家而努力，我都知道……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00147",
		linknext = "0067_00149",
		line = 1864,
	},
	["0067_00149"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1396", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Quiero ayudarte... Quiero salvarte... Por favor, solo dime si necesitas a alguien...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我觉得我要帮助橘君……如果你觉得痛苦的话，就好好跟我说啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我覺得我要幫助橘君……如果你覺得痛苦的話，就好好跟我說啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00148",
		linknext = "0067_00150",
		line = 1876,
	},
	["0067_00150"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1397", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Por favor, apóyate en mí... confía en mí... ¡y no me digas que te parece bien sacrificarte!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对我撒娇啊……依靠我啊……我不希望听到你说自己受伤也没关系之类的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對我撒嬌啊……依靠我啊……我不希望聽到你說自己受傷也沒關係之類的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00149",
		linknext = "0067_00151",
		line = 1888,
	},
	["0067_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wata-chan-senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱、前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬、前輩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00150",
		linknext = "0067_00152",
		line = 1899,
	},
	["0067_00152"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1398", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahh... ¿Recuerdas lo que te dije cuando me invitaste al equipo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜呜……橘君……你还记得……邀请我成为同伴的时候，说了什么吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚嗚……橘君……你還記得……邀請我成為同伴的時候，說了什麼嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00151",
		linknext = "0067_00153",
		line = 1911,
	},
	["0067_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Que querías... ayudar a tus kouhais...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……希望你当成在帮助后辈……加入进来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……希望你當成在幫助後輩……加入進來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00152",
		linknext = "0067_00154",
		line = 1922,
	},
	["0067_00154"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1399", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ughh... ¡Si lo recuerdas, déjame hacerlo! Lo estás pasando tan mal que no soporto la idea de que vayas allá y te maten... Por favor, déjame ayudarte...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯唔……那就让我来帮你啊……！明明你那么痛苦，不要再想着一个人努力好吗……我也想成为你的力量啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯唔……那就讓我來幫你啊……！明明你那麼痛苦，不要再想著一個人努力好嗎……我也想成為你的力量啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00153",
		linknext = "0067_00155",
		line = 1934,
	},
	["0067_00155"] = {
		{"ex", time=500, func="wait"},
