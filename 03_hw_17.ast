	["0067_00206"] = {
		{"fg", file="hinami_02l_00002", file1="hinami_02l_00102", file2="hinami_02l_00201", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=-200},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1415", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, gracias! Jeje... ¡esto es trabajo en equipo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇啊，谢谢！诶嘿嘿……是共同合作啊！”",
