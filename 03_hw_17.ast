	["0067_00213"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00120", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1417", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vaya que sí. ¡Muy bien! ¡Voy a esforzarme al máximo para preparar esta esponjosa y sabrosa tortilla de arroz, tal y como la hacía mamá! Aunque bueno, aún la sigue preparando...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯，橘君真能讲啊……好！敬请期待妈妈亲自传授的超级好吃软乎乎蛋包饭吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯，橘君真能講啊……好！敬請期待媽媽親自傳授的超級好吃軟乎乎蛋包飯吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00212",
		linknext = "0067_00214",
		line = 2720,
	},
	["0067_00214"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1130", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah... Ya veo, así es como es... No se diga más.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——原来是这样的感觉啊……怪不得……嗯……变成这样了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊——原來是這樣的感覺啊……怪不得……嗯……變成這樣了啊……」",
					{"rt2"},
				},
