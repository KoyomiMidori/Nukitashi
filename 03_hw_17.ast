	["0067_00081"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00114", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1127", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pero aunque lo supiéramos, ¿de qué nos serviría? Estamos hablando de la yakuza. Están armados hasta los dientes con armas de verdad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是，就算知道了，你要怎么办……？对手是黑社会啊……？用真正的枪哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是，就算知道了，你要怎麼辦……？對手是黑社會啊……？用真正的槍哦……？」",
					{"rt2"},
				},
			},
		},
