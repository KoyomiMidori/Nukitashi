			},
		},
		text = {
			vo = {
				{"vo", file="nanase1893", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No lo sé. Son una organización criminal, así que tiene que haber alguna razón más turbia. ¿Qué opinas, Jun...? ¿Jun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“到底是怎样呢。毕竟是干地下风俗的人，也许在想更加邪恶的事情吧……淳怎么想？……淳？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「到底是怎樣呢。畢竟是幹地下風俗的人，也許在想更加邪惡的事情吧……淳怎麼想？……淳？」",
					{"rt2"},
				},
			},
		},
