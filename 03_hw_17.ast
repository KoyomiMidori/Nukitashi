					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uff, ahh... Mírame, ahora estoy llorando de alivio. Aaaah... No debería... Una senpai no debería llorar así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呼……唔啊，唔……一安心，就又哭出来了。咦唔……不行啊，真难看……我可是前辈啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呼……唔啊，唔……一安心，就又哭出來了。咦唔……不行啊，真難看……我可是前輩啊……」",
					{"rt2"},
				},
			},
		},
