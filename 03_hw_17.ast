				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, eso no significa que podamos dejarlos actuar. Eso pondría en peligro a niños inocentes. Incluso Wata-chan podría convertirse en uno de sus objetivos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是如果让他们逃走的话，不知道什么时候又会有无辜的孩子受到伤害——渡酱也会成为他们的目标吧。",
					{"rt2"},
				},
			},
			tw = {
				{
