					{"rt2"},
				},
			},
		},
		linkback = "0067_00205",
		linknext = "0067_00207",
		line = 2618,
	},
	["0067_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es adorable lo feliz que se pone por algo tan pequeño como esto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为小事动不动就高兴这一点很可爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為小事動不動就高興這一點很可愛。",
