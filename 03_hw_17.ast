			tw = {
				{
					"為了採取下一步，我不能安於現狀。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00104",
		linknext = "0067_00106",
		line = 1336,
	},
	["0067_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya que hemos decidido no aprovecharnos de Fumino, nuestro as en la manga, necesitaremos dar un gran salto para despejar el camino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然决定不交出能破坏条例的底牌“文乃”，就有必要迈出很大的一步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然決定不交出能破壞條例的底牌「文乃」，就有必要邁出很大的一步。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00105",
		linknext = "0067_00107",
		line = 1346,
	},
	["0067_00107"] = {
		{"text"},
		text = {
