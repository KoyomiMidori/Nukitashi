				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa chica tiene el poder de atrapar la atención del público con su voz.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女孩张开嘴时，似乎有种让大家不约而同侧耳倾听的力量。",
					{"rt2"},
				},
			},
			tw = {
