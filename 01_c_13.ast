				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Suelo verla en las asambleas, pero siempre está sola.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“偶尔在集会上看到过，好像一直都是一个人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「偶爾在集會上看到過，好像一直都是一個人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00048",
		linknext = "0014_00050",
		line = 732,
	},
	["0014_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No llama mucho la atención cuando se le echa un breve vistazo a la muchedumbre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是放眼望去是看不到的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是放眼望去是看不到的。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00049",
		linknext = "0014_00051",
		line = 742,
	},
	["0014_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero al concentrarse más, se puede divisar a una chica apoyada en un poste del gimnasio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有仔细看，才能发现倚在体育馆柱子旁边的女孩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有仔細看，才能發現倚靠在體育館柱子旁的女孩。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00050",
		linknext = "0014_00052",
		line = 752,
	},
	["0014_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es bastante sencilla y está encorvada. Definitivamente no es una chica que llame la atención.",
					{"rt2"},
				},
			},
			cn = {
				{
					"朴素又有点驼背的不起眼少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"樸素又有點駝背的不起眼少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00051",
		linknext = "0014_00053",
		line = 762,
	},
	["0014_00053"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00109", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0276", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yo ni siquiera la vi. Uuurgh, pero tiene unas tetazas... ¡Malditas tetas grandes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，是那里啊，我完全没发现……呜呜呜……那个人的胸也好大……可恶的巨乳……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，是那裡啊，我完全沒發現……嗚嗚嗚……那個人的胸也好大……可惡的巨乳……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00052",
		linknext = "0014_00054",
		line = 775,
	},
	["0014_00054"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio son tan grandes como para mencionarlas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有那么巨吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有那麼巨嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00053",
		linknext = "0014_00055",
		line = 787,
	},
	["0014_00055"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00118", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0277", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Son enormes! ¡Muerte a las tetazas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“很大啊！巨乳去死！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「很大啊！巨乳去死！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00054",
		linknext = "0014_00056",
		line = 800,
	},
	["0014_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esta loli está tirando amenazas de muerte.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个萝莉居然直接要别人去死。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個蘿莉居然直接要別人去死。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00055",
		linknext = "0014_00057",
		line = 811,
	},
	["0014_00057"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00103", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0469", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wata-chan, eres una chica mala. Los lolis no deberían desearle la muerte a los demás...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不行啊渡酱，明明是个萝莉，怎么能叫别人去死呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不行啊渡醬，明明是個蘿莉，怎麼能叫別人去死呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00056",
		linknext = "0014_00058",
		line = 824,
	},
	["0014_00058"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00118", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0278", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero no soy una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00057",
		linknext = "0014_00059",
		line = 837,
	},
	["0014_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me concentro y fuerzo la vista.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我集中意识，仔细看着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我集中意識，仔細看著。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00058",
		linknext = "0014_00060",
		line = 847,
	},
	["0014_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Posee algo especial que te hará perderla si no le prestas toda tu atención.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像如果不这样的话，她马上就会从视野中消失——她有着这样奇妙的气质。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像如果不這樣的話，她馬上就會從視野中消失——她有著這樣奇妙的氣質。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00059",
		linknext = "0014_00061",
		line = 857,
	},
	["0014_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero también tiene un aire bastante sereno de elegancia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她还是平静且娴静地站在那里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她還是平靜且嫻靜地站在那裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00060",
		linknext = "0014_00062",
		line = 867,
	},
	["0014_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Desde aquí, no parece alguien que tenga mucho pecho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但我完全看不出是巨乳诶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但我完全看不出是巨乳欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00061",
		linknext = "0014_00063",
		line = 879,
	},
	["0014_00063"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00103", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0279", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Eso es solo porque mucha gente en esta isla las tiene grandes! ¡Han arruinado tus estándares!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那是因为这个岛上有很多胸大的人，橘君的标准变奇怪了啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那是因為這個島上有很多胸大的人，橘君的標準變奇怪了啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00062",
		linknext = "0014_00064",
		line = 892,
	},
	["0014_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oye, tampoco culpes al mundo porque eres una tabla de planchar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不能因为自己是飞机场就扭曲世界的基准吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你不能因為自己是飛機場就扭曲世界的基準吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00063",
		linknext = "0014_00065",
		line = 903,
	},
	["0014_00065"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00118", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0280", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¡Ese no es el punto!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不是这样的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不是這樣的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00064",
		linknext = "0014_00066",
		line = 916,
	},
	["0014_00066"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00104", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0281", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tampoco soy tan plana! Consulté en internet y dicen que no es natural que todo el mundo tenga tetas normas. ¡Lo que está mal es esta isla!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我才没有那么贫乳呢！因为我在网上提问的时候，他们说正常不会有那么多大胸的人哦！？是这个岛奇怪啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我才沒有那麼貧乳呢！因為我在網上提問的時候，他們說正常不會有那麼多大胸的人哦！？是這個島奇怪啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00065",
		linknext = "0014_00067",
		line = 929,
	},
	["0014_00067"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tu complejo por ser plana era tan grande que tuviste que comentarlo en internet...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来你在意贫乳在意到要去网上提问啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來你在意貧乳在意到要去網上提問啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00066",
		linknext = "0014_00068",
		line = 941,
	},
	["0014_00068"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00114", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0282", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, es que... ¡Tampoco me preocupaba tanto!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“虽然我也不是想说自己不是贫乳……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「雖然我也不是想說自己不是貧乳……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00067",
		linknext = "0014_00069",
		line = 954,
	},
	["0014_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se enoja y mira con rabia a la chica tetona.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她噘起小嘴，狠狠地盯着巨乳女孩。",
