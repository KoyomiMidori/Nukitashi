		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=400, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg050101", x=-5, y=-5, path=":cg/kcg05/", lv=5, ev=1, time=400, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0019", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Veo que están practicando sexo pervertido de forma diligente y saludable. Su querida presidenta está muy contenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“今天大家也在努力做着健康的性爱。作为学生会长，我感到非常高兴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「今天大家也在努力做著健康的性愛。作為學生會長，我感到非常高興。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00076",
		linknext = "0014_00078",
		line = 1064,
	},
	["0014_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Toda la atención del gimnasio se centra en ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我马上意识到，在体育馆里的所有人一下子都被她吸引了。",
