	},
	["0014_00105"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0452", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Este evento al que llaman “Rey del Tiroteo” es un evento en el que se fomenta el sexo más de lo normal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这个活动——通称‘击坠王’的活动，是学生会加强鼓励做爱的活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這個活動——通稱『擊墜王』的活動，是學生會加強鼓勵做愛的活動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00104",
		linknext = "0014_00106",
		line = 1435,
	},
	["0014_00106"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0453", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“A partir de mañana, de martes a viernes, habrá restricciones en cuanto al sexo sin protección y el sexo con juguetes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“从明天周二到周五的四天里，使用道具或者不带套的做爱将会被限制。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「從明天週二到週五的四天裡，使用道具或者不戴套的做愛將會被限制。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00105",
		linknext = "0014_00107",
		line = 1447,
	},
	["0014_00107"] = {
