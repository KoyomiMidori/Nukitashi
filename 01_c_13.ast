	["0014_00013"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"bg", id=18, file="kcg010101-1", x=-5, y=-5, path=":cg/kcg01/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0266", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hm? You guys all right? What's with that 'pigeon-staring-deeply-into-lightbulb' expression?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯？怎么了你们两个？表情怎么像只鸽子点亮了灯泡一样啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯？怎麼了你們兩個？表情怎麼像隻鴿子點亮了燈泡一樣啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00012",
		linknext = "0014_00014",
		line = 211,
	},
	["0014_00014"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
