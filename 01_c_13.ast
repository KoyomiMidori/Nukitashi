			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“P-Pero hay gente de la SS en la puerta principal, ¿no? ¿En serio podemos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但、但是正门有SS的人吧……？做得到吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但、但是正門有SS的人吧……？做得到嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00138",
		linknext = "0014_00140",
		line = 1842,
	},
	["0014_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
