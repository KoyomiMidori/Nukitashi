	["0014_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Little Wata-chan gestures furiously at us, her cowlick bobbing to and fro the whole time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小渡酱生气地挥舞着自己的呆毛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小渡醬生氣地揮舞著自己的呆毛。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00030",
		linknext = "0014_00032",
		line = 476,
	},
	["0014_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's a sight for sore eyes at this hour of the morning.",
