	["0014_00027"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"evset", file="kcg01", set="kcg01", path=":ev/kcg01/"},
		{"evset", file="kcg01010301", set="kcg010103", path=":ev/kcg010103/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"bg", id=18, file="kcg01010301", x=-5, y=-5, path=":cg/kcg01/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0272", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"非表示", "ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Hinami"},
					"“¡¿De qué se ríen?! ¡Soy su senpai!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "雏见"},
					"“为什么要笑？我可是前辈哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "雛見"},
					"「為什麼要笑？我可是前輩哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00026",
		linknext = "0014_00028",
		line = 429,
	},
	["0014_00028"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00102", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0467", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hermanito, ¿no crees que esta niñita es lo más lindo que has visto en tu vida?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥，我好喜欢这个小小的生物……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥，我好喜歡這個小小的生物……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00027",
		linknext = "0014_00029",
		line = 442,
	},
	["0014_00029"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Verdad? Es una loli muy tiernita...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯我也是，多么可爱的萝莉啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯我也是，多麼可愛的蘿莉啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00028",
		linknext = "0014_00030",
		line = 454,
	},
	["0014_00030"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0273", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"非表示", "ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Hinami"},
					"“¡Antes que nada, no estoy chiquita, y no soy una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "雏见"},
					"“我不小也不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "雛見"},
					"「我不小也不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00029",
		linknext = "0014_00031",
		line = 466,
	},
	["0014_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La pequeña Wata-chan nos hace gestos enfurecidos mientras su mechón se mueve de un lado a otro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小渡酱生气地挥舞着自己的呆毛。",
					{"rt2"},
				},
			},
			tw = {
				{
