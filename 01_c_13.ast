	},
	["0014_00015"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0463", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Was the pigeon's name Edison...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“鸽子的名字是爱迪生吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「鴿子的名字是愛迪生嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00014",
		linknext = "0014_00016",
		line = 235,
	},
	["0014_00016"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“More importantly, though...”",
