	["0014_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debido al intenso calor, algunas personas parecían haber enloquecido y comenzaron a imitar el comportamiento de las cigarras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也不知道是不是因为炽热的夏天把脑袋烤坏了，居然有把自己当成蝉做爱的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也不知道是不是因為嚴夏把腦袋烤壞了，居然有把自己當成蟬做愛的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00043",
