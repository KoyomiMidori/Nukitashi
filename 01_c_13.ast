					name = {"奈々瀬", "奈奈濑"},
					"“但他们会给女孩子发一种特殊的安全套，比赛谁可以收集到最多被射过精的安全套。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但他們會給女孩子發一種特殊的保險套，比賽誰可以收集到最多被射過精的保險套。」",
					{"rt2"},
				},
