	["0014_00017"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"evset", file="kcg01", set="kcg01", path=":ev/kcg01/"},
		{"evset", file="kcg01010101", set="kcg010101", path=":ev/kcg010101/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"bg", id=18, file="kcg01010101", x=-5, y=-5, path=":cg/kcg01/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0464", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"淳之介＆麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介＆麻沙音", "Junnosuke & Asane"},
					"“¿Para qué es esa silla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介＆麻沙音"},
					"“你为什么要站在钢管椅上？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介＆麻沙音"},
					"「你為什麼要站在鋼管椅上？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00016",
		linknext = "0014_00018",
		line = 270,
	},
	["0014_00018"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"evset", file="kcg01", set="kcg01", path=":ev/kcg01/"},
		{"evset", file="kcg01010201", set="kcg010102", path=":ev/kcg010102/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"bg", id=18, file="kcg01010201", x=-5, y=-5, path=":cg/kcg01/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"fg", ch="ヒナミ", time=0, sync=0, mode=-1, lv=5, id=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0267", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, ¿esto? Mi casillero está muy arriba, así que necesito para sacar mis zapatos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦这个吗？我的鞋箱太高了，没有它我就拿不出我的鞋子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦這個嗎？我的鞋箱太高了，沒有它我就拿不出我的鞋子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00017",
		linknext = "0014_00019",
		line = 295,
	},
	["0014_00019"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0268", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Por alguna estúpida razón, mi casillero siempre ha estado demasiado alto para que pueda alcanzarlo desde que era niña, así que me acostumbré a llevar una silla a todas partes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不知道为什么，从小我的鞋箱都在我够不到的地方，所以从以前开始我就一直带着钢管椅。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不知道為什麼，從小我的鞋箱都在我搆不到的地方，所以從以前開始我就一直帶著鋼管椅。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00018",
		linknext = "0014_00020",
		line = 307,
	},
	["0014_00020"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0465", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah... Con razón lo cargas siempre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊……所以才一直带着钢管椅啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊……所以才一直帶著鋼管椅啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00019",
		linknext = "0014_00021",
		line = 320,
	},
	["0014_00021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Siempre me pregunté por qué llevabas eso a todas partes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我还一直想着为什么你总是拿着那样的东西……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我還一直想著為什麼你總是拿著那樣的東西……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00020",
		linknext = "0014_00022",
		line = 332,
	},
	["0014_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0269", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"非表示", "ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Hinami"},
					"“Así es. ¡Esta silla es muy útil! ¡Mientras la tengo, no hay nada que no pueda alcanzar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "雏见"},
					"“是的，这把椅子非常有用哦！只要有它，我就能够到很高的地方！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "雛見"},
					"「是的，這把椅子非常有用哦！只要有它，我就能搆到很高的地方！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00021",
		linknext = "0014_00023",
		line = 344,
	},
	["0014_00023"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"bg", id=18, file="kcg01010201", x=-5, y=-5, path=":cg/kcg01/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0270", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hasta puedo usarla cuando el terreno no es muy bueno. Mira, incluso puedo abrir puertas y cosas así usando la parte trasera.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“比如地面不平的时候还可以这样使用。你看，我还可以用椅子的背部打开门呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「比如地面不平的時候還可以這樣使用。你看，我還可以用椅子的背部打開門呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00022",
		linknext = "0014_00024",
		line = 359,
	},
	["0014_00024"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"bg", id=18, file="kcg01010101", x=-5, y=-5, path=":cg/kcg01/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0271", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"非表示", "ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Hinami"},
					"“¡Ah, ya sé! ¿Puedo traerles sus zapatos? ¡Jeje, dejen que su onee-san se encargue!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "雏见"},
					"“啊，对了！要不然我也帮你们两个拿鞋子吧？哼哼，包在姐姐身上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "雛見"},
					"「啊，對了！要不然我也幫你們兩個拿鞋子吧？哼哼，包在姐姐身上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00023",
		linknext = "0014_00025",
		line = 379,
	},
	["0014_00025"] = {
		{"bgm", stop=1},
		{"fg", file="asane_01f_00001", file1="asane_01f_00113", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0466", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Tranquila yo puedo sola jejejejeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不用没事的呼呼呼呼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不用的沒關係呼呼呼呼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00024",
		linknext = "0014_00026",
		line = 393,
	},
	["0014_00026"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oye, no te rías.. Jajaja..”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂别笑呼呼呼呼呼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂別笑呼呼呼呼呼。」",
