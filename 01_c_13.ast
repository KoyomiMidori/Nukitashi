			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sex seekers? Is that some new police procedural show?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“圣祝者……？神父吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「聖祝者……？神父嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00120",
		linknext = "0014_00122",
		line = 1631,
	},
	["0014_00122"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0457", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's a term for locals who are neither SS nor SHO members, but still requesting perverted sex in accordance with the law. Jun came up with it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不是SS或SHO，而是符合变态条例的镇上的普通人。算是淳发明的单词。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不是SS或SHO，而是符合變態條例的鎮上的普通人。算是淳發明的單詞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00121",
		linknext = "0014_00123",
		line = 1645,
	},
	["0014_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The effect that sex seekers will have on this event is they'll be all over the place requesting sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果说这次的活动会对性触者产生什么样的影响……那就是到处都将有人在做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果說這次的活動會對性觸者產生什麼樣的影響……那就是到處都將有人在做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00122",
		linknext = "0014_00124",
		line = 1657,
	},
	["0014_00124"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0289", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So apart from using condoms, everything else is just business as usual, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那不就除了使用安全套外，和以往都一样吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那不就除了使用保險套外，和以往都一樣嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00123",
		linknext = "0014_00125",
		line = 1671,
	},
	["0014_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, not exactly... It just takes longer for people to get off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，只是……做爱时间会变长，在这个‘击坠王’期间。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，只是……做愛時間會變長，在這個『擊墜王』期間。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00124",
		linknext = "0014_00126",
		line = 1683,
	},
	["0014_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sex with condoms tends to take longer than when done raw.",
					{"rt2"},
				},
			},
			cn = {
				{
					"使用安全套，意味着会比不带套还要持久。",
					{"rt2"},
				},
			},
			tw = {
				{
					"使用保險套，意味著會比不戴套還要持久。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00125",
		linknext = "0014_00127",
		line = 1693,
	},
	["0014_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Taking longer means the number of people lingering inside the school increases and the number of observers also increases.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而滞留的人一出现，就意味着学校中将充斥更多人，周围的视线也会变多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而滯留的人一出現，就意味著學校中將充斥更多人，周圍的視線也會變多。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00126",
		linknext = "0014_00128",
		line = 1703,
	},
	["0014_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In concert with that, the number of SS also increases, as does the intensity of their surveillance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随之而来的是SS人数的增加，以及更加严格的监视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨之而來的是SS人數的增加，以及更加嚴格的監視。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00127",
		linknext = "0014_00129",
		line = 1713,
	},
	["0014_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The number of people that would normally be having sex out of school after hours increases inside, and if sex takes longer, what do you think will happen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你想想平常在放学后，在学校外面做爱的人如果变多，并且做爱时间变长的话，会怎样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你想想平常在放學後，在學校外面做愛的人如果變多，並且做愛時間變長的話，會怎樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00128",
		linknext = "0014_00130",
		line = 1724,
	},
	["0014_00130"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0290", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hmm... They'll spill out of the school building?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……教学楼会容不下他们？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……校舍會容不下他們？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00129",
		linknext = "0014_00131",
		line = 1738,
	},
	["0014_00131"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. so, we'll have students from the courtyard to the back of the school building that way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，也就是说——会有学生来到操场，或者教学楼后面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，也就是說——會有學生來到操場，或者校舍後面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00130",
		linknext = "0014_00132",
		line = 1750,
	},
	["0014_00132"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0291", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see, so the SS will have surveillance extended to there... Which would mean, using the rear gate to get out is a not gonna work?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对诶，这样的话，SS的监视也会去到那里……后门路线会无法使用是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對欸，這樣的話，SS的監視也會去到那裡……後門路線會無法使用是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00131",
		linknext = "0014_00133",
		line = 1765,
	},
	["0014_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's correct.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对，正是这样——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對，正是這樣——」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00132",
		linknext = "0014_00134",
		line = 1776,
	},
	["0014_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This will create a rather inconvenient situation for us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这意味着情况将对我们不利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這意味著情況將對我們不利。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00133",
		linknext = "0014_00135",
		line = 1786,
	},
	["0014_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So as long as the event is going on, it's best to avoid that at all costs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以这个定期活动是一个鬼门关。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以這個定期活動是一個鬼門關。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00134",
		linknext = "0014_00136",
		line = 1796,
	},
	["0014_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having said that, I've survived it once already.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只不过，我已经克服过一次了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只不過，我已經克服過一次了。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00135",
		linknext = "0014_00137",
		line = 1806,
	},
	["0014_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was basically hell on earth... but damn if I didn't get out of it unscathed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然那时是九死一生——但确实拿出了成果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然那時是九死一生——但確實拿出了成果。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00136",
		linknext = "0014_00138",
		line = 1816,
	},
	["0014_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, with the rear gate a no-go, we only have one option— bursting through the front gate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当后门路线不行时，除了从正门突破之外别无他法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當後門路線不行時，除了從正門突破之外別無他法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00137",
		linknext = "0014_00139",
		line = 1828,
	},
	["0014_00139"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0292", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“B-But they've got SS people at the front gate, right? Would you even be able to do that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但、但是正门有SS的人吧……？做得到吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但、但是正門有SS的人吧……？做得到嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00138",
		linknext = "0014_00140",
		line = 1842,
	},
	["0014_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not normally, no. But I have a cunning and subtle plan...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“通常不可能，但我们也有秘计——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「通常不可能，但我們也有密技——」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00139",
		linknext = "0014_00141",
		line = 1854,
	},
	["0014_00141"] = {
