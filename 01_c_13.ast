	},
	["0014_00080"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0020", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“El sexo pervertido es conectar con otra persona. Conectar genera comprensión. Y la comprensión... es la forma más pura de las relaciones humanas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“性爱，是和对方的联系。所谓联系，即是理解。理解——是纯粹的人际关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「性愛，是和對方的聯繫。所謂聯繫，即是理解。理解——是純粹的人際關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00079",
		linknext = "0014_00081",
		line = 1096,
	},
	["0014_00081"] = {
