					name = {"ヒナミ", "雏见"},
					"“也、也不是没有……只是跟我没什么缘分而已……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「也、也不是沒有……只是跟我沒什麼緣分而已……」",
