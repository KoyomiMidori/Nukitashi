		linkback = "0014_00125",
		linknext = "0014_00127",
		line = 1693,
	},
	["0014_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuanto más tiempo hay, mayor es el número de personas que permanecen dentro de la escuela, y también aumenta el número de observadores.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而滞留的人一出现，就意味着学校中将充斥更多人，周围的视线也会变多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而滯留的人一出現，就意味著學校中將充斥更多人，周圍的視線也會變多。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00126",
		linknext = "0014_00128",
		line = 1703,
	},
	["0014_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En paralelo a ello, también aumenta el número de la SS, al igual que la intensidad de su vigilancia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随之而来的是SS人数的增加，以及更加严格的监视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨之而來的是SS人數的增加，以及更加嚴格的監視。",
