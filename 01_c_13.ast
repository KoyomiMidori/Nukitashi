	["0014_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El número de personas que normalmente tendrían sexo después del horario escolar aumenta dentro de la escuela, y si el sexo dura más tiempo, ¿qué crees que pasará?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你想想平常在放学后，在学校外面做爱的人如果变多，并且做爱时间变长的话，会怎样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你想想平常在放學後，在學校外面做愛的人如果變多，並且做愛時間變長的話，會怎樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00128",
		linknext = "0014_00130",
		line = 1724,
	},
	["0014_00130"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0290", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm... ¿Se saldrán del edificio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……教学楼会容不下他们？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……校舍會容不下他們？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00129",
		linknext = "0014_00131",
		line = 1738,
	},
	["0014_00131"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien. Los estudiantes estarán en el patio y la parte trasera del edificio escolar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，也就是说——会有学生来到操场，或者教学楼后面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，也就是說——會有學生來到操場，或者校舍後面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00130",
		linknext = "0014_00132",
		line = 1750,
	},
	["0014_00132"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0291", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Entiendo, la SS ampliará la vigilancia hasta allí... ¿Así que no podremos salir por atrás?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对诶，这样的话，SS的监视也会去到那里……后门路线会无法使用是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對欸，這樣的話，SS的監視也會去到那裡……後門路線會無法使用是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00131",
		linknext = "0014_00133",
		line = 1765,
	},
	["0014_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así es.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对，正是这样——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對，正是這樣——」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00132",
		linknext = "0014_00134",
		line = 1776,
	},
	["0014_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esto creará una situación bastante incómoda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这意味着情况将对我们不利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這意味著情況將對我們不利。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00133",
		linknext = "0014_00135",
		line = 1786,
	},
	["0014_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras dure el evento, es mejor evitarlo a como dé lugar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以这个定期活动是一个鬼门关。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以這個定期活動是一個鬼門關。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00134",
		linknext = "0014_00136",
		line = 1796,
	},
	["0014_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Habiendo dicho eso, ya sobreviví una vez.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只不过，我已经克服过一次了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只不過，我已經克服過一次了。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00135",
		linknext = "0014_00137",
		line = 1806,
	},
	["0014_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fue todo un infierno... pero pude salir intacto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然那时是九死一生——但确实拿出了成果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然那時是九死一生——但確實拿出了成果。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00136",
		linknext = "0014_00138",
		line = 1816,
	},
	["0014_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Como la puerta trasera estará rodeada, solo nos queda una opción: salir por la puerta principal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当后门路线不行时，除了从正门突破之外别无他法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當後門路線不行時，除了從正門突破之外別無他法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00137",
		linknext = "0014_00139",
		line = 1828,
	},
	["0014_00139"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
