	},
	["0014_00207"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00303", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jajaja... ¡¿Quién habría dicho que había semejante tienda en esta isla?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈哈……没想到这个岛上居然有那种店——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈哈……沒想到這個島上居然有那種店——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00206",
		linknext = "0014_00208",
		line = 2725,
	},
	["0014_00208"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Un paraíso de todas las cosas que no puedes conseguir en la Isla Seiran...",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛得不到的东西——",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島得不到的東西——",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00207",
		linknext = "0014_00209",
		line = 2736,
	},
	["0014_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En pocas palabras, onaholes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是飞机杯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是飛機杯。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00208",
		linknext = "0014_00210",
		line = 2746,
	},
	["0014_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como los habitantes de esta isla pueden follar sin usar onaholes, hay gente que ni siquiera sabe que existen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个岛上的人们因为可以做爱，所以用不到飞机杯，有些人甚至不知道它的存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個島上的人們因為可以做愛，所以用不到飛機杯，有些人甚至不知道它的存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00209",
		linknext = "0014_00211",
		line = 2756,
	},
	["0014_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero hay un rincón de la Membrana Mutable que está repleto de ellos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，那家店——一时的皮膜的各个角落里都摆满了飞机杯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，那家店——一時的皮膜的各個角落裡都擺滿了飛機杯。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00210",
		linknext = "0014_00212",
		line = 2766,
	},
	["0014_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde los clásicos de siempre hasta los diseños más modernos, de todo hay allí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从怀旧经典到新上市的产品一应俱全。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從懷舊經典到新上市的產品一應俱全。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00211",
		linknext = "0014_00213",
		line = 2776,
	},
	["0014_00213"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Los nuevos serán muy útiles para mi investigación... Y dicen que las compras impulsivas no dan beneficios.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“新作对我的艺术研究也很有帮助——当然要买买买。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「新作對我的藝術研究也很有幫助——當然要買買買。」",
					{"rt2"},
				},
