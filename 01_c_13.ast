		},
		linkback = "0014_00124",
		linknext = "0014_00126",
		line = 1683,
	},
	["0014_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El sexo con condones suele durar más que cuando no se usa protección.",
					{"rt2"},
				},
			},
			cn = {
				{
					"使用安全套，意味着会比不带套还要持久。",
					{"rt2"},
				},
			},
			tw = {
				{
					"使用保險套，意味著會比不戴套還要持久。",
