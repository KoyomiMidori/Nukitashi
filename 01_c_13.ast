		linknext = "0014_00111",
		line = 1501,
	},
	["0014_00111"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0470", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Ni siquiera te veían como una chica?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“甚至都不被当成是女生了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「甚至都不被當成是女生了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00110",
		linknext = "0014_00112",
		line = 1514,
	},
	["0014_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vaya forma tienes de unirte a la conversación después de despertarte, ¿eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你别一起来就说些有的没的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你別一起來就說些有的沒的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00111",
		linknext = "0014_00113",
		line = 1526,
	},
	["0014_00113"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0456", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“En otras pocas palabras, la chica de la escuela que recoja más condones usados será la ganadora. Por cierto, si el número es el mismo, el ganador se determinará por el volumen del semen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“在学校收集到最多安全套的女生就是获胜者。顺带一提，如果数量相同，似乎会用精液量来决定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「在學校收集到最多保險套的女生就是獲勝者。順帶一提，如果數量相同，似乎會用精液量來決定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00112",
		linknext = "0014_00114",
		line = 1540,
	},
	["0014_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Durante ese periodo se distribuirán afrodisíacos por toda la escuela, y cualquier alimento con propiedades potentes se venderá con descuento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在此期间，学校将分发精力剂，学校食堂中的补阳料理也会降价。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在此期間，學校將分發精力劑，學校食堂中的補陽料理也會降價。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00113",
		linknext = "0014_00115",
		line = 1550,
	},
	["0014_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En pocas palabras, toda la escuela fomentará el sexo con condones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，整个学校都将鼓励使用安全套做爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，整個學校都將鼓勵使用保險套做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00114",
		linknext = "0014_00116",
		line = 1560,
	},
	["0014_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Este evento suele celebrarse cada dos meses.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个活动基本上每两个月举办一次。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個活動基本上每兩個月舉辦一次。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00115",
		linknext = "0014_00117",
		line = 1572,
	},
	["0014_00117"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero el mes pasado, Asa-chan y yo tuvimos que pasar por el 'Súper Rapidín ",
					{"gaiji", text="①"},
					" Campeonato del Rey Tiroteador que se Viene de la Nada'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是我和麻沙酱都在一个月前经历过了‘突然来一发",
					{"gaiji", text="①"},
					"击坠王锦标赛〜王牌的登场总是突如其来〜’活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是我和麻沙醬都在一個月前經歷過了『突然來一發",
					{"gaiji", text="①"},
					"擊墜王錦標賽〜王牌的登場總是突如其來〜』活動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00116",
		linknext = "0014_00118",
		line = 1585,
	},
	["0014_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya hemos pasado por esta estupidez antes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以这种严酷的环境也已经有了一次经验。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以這種嚴酷的環境也已經有了一次經驗。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00117",
		linknext = "0014_00119",
		line = 1595,
	},
	["0014_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso claro si el evento normal como el evento repentino...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果常规活动和突发活动的内容一样的话……",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果常規活動和突發活動的內容一樣的話……",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00118",
		linknext = "0014_00120",
		line = 1605,
	},
	["0014_00120"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya tenemos bastante con la SS, pero en momentos así, los que buscan sexo son el verdadero problema.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然SS的人也很烦人，但在这种情况下，最麻烦的还是‘性触者’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然SS的人也很煩人，但在這種情況下，最麻煩的還是『性觸者』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00119",
		linknext = "0014_00121",
		line = 1617,
	},
	["0014_00121"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
