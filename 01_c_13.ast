				},
			},
			tw = {
				{
					"我馬上意識到，在體育館裡的所有人一下子都被她吸引了。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00077",
		linknext = "0014_00079",
		line = 1074,
	},
	["0014_00079"] = {
		{"text"},
		text = {
