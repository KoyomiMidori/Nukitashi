	["0014_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta isla nunca duerme. Pero los turistas sí que duermen mucho con cualquier cosa que se mueva, sin importar la hora del día.",
					{"rt2"},
				},
			},
			cn = {
