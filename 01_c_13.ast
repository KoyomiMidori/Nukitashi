		linknext = "0014_00108",
		line = 1461,
	},
	["0014_00108"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0454", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“En su lugar, se distribuirán condones especiales a las chicas, y se trata de un concurso para ver quién llena más condones con su eyaculación.”",
					{"rt2"},
				},
			},
			cn = {
