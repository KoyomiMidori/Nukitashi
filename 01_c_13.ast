		line = 1631,
	},
	["0014_00122"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0457", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Es un término que se utiliza para referirse a los lugareños que no son miembros de la SS ni de la SHO, pero que siguen solicitando sexo pervertido de acuerdo con la ley. Jun los llama así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不是SS或SHO，而是符合变态条例的镇上的普通人。算是淳发明的单词。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不是SS或SHO，而是符合變態條例的鎮上的普通人。算是淳發明的單詞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00121",
		linknext = "0014_00123",
		line = 1645,
	},
	["0014_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El efecto que tendrán los buscadores de sexo en este evento es que estarán de calientes por todas partes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果说这次的活动会对性触者产生什么样的影响……那就是到处都将有人在做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果說這次的活動會對性觸者產生什麼樣的影響……那就是到處都將有人在做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00122",
		linknext = "0014_00124",
		line = 1657,
	},
	["0014_00124"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0289", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Aparte de usar condones, todo sigue igual, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那不就除了使用安全套外，和以往都一样吗……？”",
					{"rt2"},
