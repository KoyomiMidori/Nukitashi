	},
	["0014_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Given the people of this island can have sex without needing to use onaholes, there are people who don't even know they exist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个岛上的人们因为可以做爱，所以用不到飞机杯，有些人甚至不知道它的存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個島上的人們因為可以做愛，所以用不到飛機杯，有些人甚至不知道它的存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00209",
		linknext = "0014_00211",
		line = 2756,
	},
	["0014_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there's one corner of the Mutable Membrane shop which is absolutely stocked with them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，那家店——一时的皮膜的各个角落里都摆满了飞机杯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，那家店——一時的皮膜的各個角落裡都擺滿了飛機杯。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00210",
		linknext = "0014_00212",
		line = 2766,
	},
	["0014_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From the standard classics all the way up to the latest designs, you name it, they've got it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从怀旧经典到新上市的产品一应俱全。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從懷舊經典到新上市的產品一應俱全。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00211",
		linknext = "0014_00213",
		line = 2776,
	},
	["0014_00213"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The new ones will be especially useful for my own research... And they say impulse buys don't pay dividends.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“新作对我的艺术研究也很有帮助——当然要买买买。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「新作對我的藝術研究也很有幫助——當然要買買買。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00212",
		linknext = "0014_00214",
		line = 2788,
	},
	["0014_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could order them online, but there's the issue of delivery time and shipping costs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然也可以在线订购，但是需要支付额外的运费，而且来得很慢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然也可以在網路上訂購，但是需要支付額外的運費，而且來得很慢。",
					{"rt2"},
				},
