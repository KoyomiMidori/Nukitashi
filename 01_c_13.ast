			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No hay nada en el calendario. Tampoco veo nada en la lista anual de eventos escolares.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没有这个安排呢……在一整年的校园行事表里面也没有……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒有這個安排呢……在一整年的校園行事曆裡面也沒有……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00035",
		linknext = "0014_00037",
		line = 552,
	},
	["0014_00037"] = {
