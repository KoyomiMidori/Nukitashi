	["0014_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The atmosphere in the base is somehow tense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"房间里充满了紧张的气息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"房間裡充滿了緊張的氛圍。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00143",
		linknext = "0014_00145",
		line = 1906,
	},
	["0014_00145"] = {
		{"bgm", file="bgm14", vol=100},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0026", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Let us start with the matter of the current situation. What is your progress?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——先问问你们的现状吧。情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——先問問你們的現狀吧。情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00144",
		linknext = "0014_00146",
		line = 1920,
	},
	["0014_00146"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The 'Shootdown King' SS event is starting tomorrow. We are currently having a strategic meeting in regard to that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从明天开始将举行SS的活动‘击坠王’，我们正就此进行着作战会议。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從明天開始將舉行SS的活動『擊墜王』，我們正就此進行著作戰會議。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00145",
		linknext = "0014_00147",
		line = 1932,
	},
	["0014_00147"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0027", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Hm. And the girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“嗯——那少女的事怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「嗯——那少女的事怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00146",
		linknext = "0014_00148",
		line = 1945,
	},
	["0014_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We are still looking for her. With that said, I do believe it would be wise to guarantee our personal safety over the next four days.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“目前正在调查——但首先，重要的是确保这4天的安全。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「目前正在調查——但首先，重要的是確保這4天的安全。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00147",
		linknext = "0014_00149",
		line = 1957,
	},
	["0014_00149"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0028", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Very well. I shall allocate some funds for that purpose. Be sure to check the usual account. Continue your investigation to the best of your abilities during the event. That's all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“可以——我会准备这次的资金。用我之前说的账户吧。在此期间也要尽可能地进行调查。就这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「可以——我會準備這次的資金。用我之前說的帳戶吧。在此期間也要盡可能地進行調查。就這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00148",
		linknext = "0014_00150",
		line = 1970,
	},
	["0014_00150"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="防人老人", lv=5},
