					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues normalmente no. Pero tengo un plan ingenioso y sutil...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“通常不可能，但我们也有秘计——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「通常不可能，但我們也有密技——」",
					{"rt2"},
				},
