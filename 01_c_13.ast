		{"bg", id=6, file="bg12_1l_00000", x=-200, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=6, act="移動", x=395, y=-5, time=10000, lv=5},
		{"se", id=0, loop=0, file="se_a190"},
		{"text"},
		text = {
