		line = 1987,
	},
	["0014_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The tension in the room finally begins to dissipate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"气氛稍微缓和了一点。",
					{"rt2"},
				},
			},
