	["0014_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debieron haberla ignorado, así que no entendería la idea básica de este evento en particular.",
