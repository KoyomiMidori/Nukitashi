		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0293", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Jaaa! Estaba aguantando la respiración... ¿Quién era ese viejo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哈啊啊啊啊……！我、我都不敢呼吸了……刚刚的老爷爷是……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哈啊啊啊啊……！我、我都不敢呼吸了……剛剛的老爺爺是……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00151",
		linknext = "0014_00153",
		line = 2013,
	},
	["0014_00153"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es nuestro benefactor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们的出资者。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們的出資者。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00152",
		linknext = "0014_00154",
		line = 2025,
	},
	["0014_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Necesitamos dinero para nuestros planes de huida, y también tenemos que crear artículos. Ese dinero sale de sus bolsillos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无论是逃亡活动，还是制作道具，我们都需要钱。那位老人愿意为我们出资。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無論是逃亡活動，還是製作道具，我們都需要錢。那位老人願意為我們出資。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00153",
		linknext = "0014_00155",
		line = 2036,
	},
	["0014_00155"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0294", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, pero qué genial! ¡Tenemos un patrocinador! Ahora sí me siento como parte de un equipo hecho y derecho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶，好厉害！我们有出资者呢！好像专业的团队呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸，好厲害！我們有出資者呢！好像專業的團隊呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00154",
		linknext = "0014_00156",
		line = 2051,
	},
	["0014_00156"] = {
