		{"se", id=0, loop=0, file="se_a139"},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"ex", time=600, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0108", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "アナウンス"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Anunciante"},
					"“Esta mañana habrá una asamblea para toda la escuela. Queridos alumnos, interrumpan inmediatamente sus actividades y retomen sus actividades en el gimnasio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "广播"},
					"“全校集会将于今天早上举行。同学们，请立即停止性活动，并在体育馆重新开始——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "廣播"},
					"「全校集會將於今天早上舉行。同學們，請立即停止性行為，並在體育館重新開始——」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00032",
		linknext = "0014_00034",
		line = 511,
	},
	["0014_00034"] = {
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0274", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? Dijo que toda la escuela. ¿Había una asamblea planeada para hoy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦？全校集会诶。今天是有晨会的日子吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦？全校集會欸。今天是有晨會的日子嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00033",
		linknext = "0014_00035",
		line = 526,
	},
	["0014_00035"] = {
