		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0283", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sé que todas las chicas aquí tienen unas tetas enormes, pero... ¡Esa chica debe ser de las más grandes en cuanto a tamaño se refiere!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“虽然这里都是大胸的女孩子……但那个女孩，估计连在岛里都算是顶级的巨乳……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「雖然這裡都是大胸的女孩子……但那個女孩，估計連在島裡都算是頂級的巨乳……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00069",
		linknext = "0014_00071",
		line = 977,
	},
	["0014_00071"] = {
