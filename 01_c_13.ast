ast = {
	["0014_00001"] = {
		{"savetitle", text="エイジ・オブ・ユートピア", ja="エイジ・オブ・ユートピア", en="Age of Utopia", cn="乌托邦年代", tw="烏托邦年代"},
		{"eval", exp="g.01_c_13=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg17_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"bgm", file="bgm02", vol=100},
		{"se", id=0, loop=0, file="se_a015"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just listen, all right? According to eroge, luscious thighs and huge breasts are common physical traits of virgin women.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……所以说，色情游戏里的美腿和大胸部是基于它们的处女性才成立的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……所以說，色情遊戲裡的美腿和大胸部是基於它們的處女性才成立的。」",
					{"rt2"},
				},
			},
		},
		linknext = "0014_00002",
		line = 21,
	},
	["0014_00002"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0459", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, come on. They're just exaggerating the most desirable parts of the female characters for commercial appeal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶——那不是商业主义下女性角色被夸大的部分吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸——那不是商業主義下女性角色被誇大的部分嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00001",
		linknext = "0014_00003",
		line = 35,
	},
	["0014_00003"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But the apparent contradiction between eroticism and virginity is proof of its own appeal, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“色情主义和处女性，这两个彼此矛盾的要素才是证明其魅力的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「色情主義和處女性，這兩個彼此矛盾的要素才是證明其魅力的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00002",
		linknext = "0014_00004",
		line = 47,
	},
	["0014_00004"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0460", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, no. Virginity's just a buzzword mechanically used to add a sense of purity to their sexuality. The format demands it as a standard trope. A slutty heroine wouldn't be any different in terms of physical appeal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不不，这只是在性之中加入了名为清洁感的配件，名为处女的符号。这只不过是一种形式。就算是婊子，肉体的魅力还是一样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不不，這只是在性之中加入了名為清潔感的配件，名為處女的符號。這只不過是一種形式。就算是婊子，肉體的魅力還是一樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00003",
		linknext = "0014_00005",
		line = 59,
	},
	["0014_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If it's just a buzzword, doesn't that make it another kind of exaggeration? Are you saying they use it to add contradiction to the character as well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果说是符号，那夸大不也一样吗？让其拥有相反的要素难道也是符号吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果說是符號，那誇大不也一樣嗎？讓其擁有相反的要素難道也是符號嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00004",
		linknext = "0014_00006",
		line = 71,
	},
	["0014_00006"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0461", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Why d'you think tsunderes are a thing? The seemingly contradictory personality traits of that character archetype are precisely what give it such broad appeal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那就类似于傲娇这类要素……将傲和娇两个相反的要素作为其魅力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那就類似於傲嬌這類要素……將傲和嬌兩個相反的要素作為其魅力……」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00005",
		linknext = "0014_00007",
		line = 83,
	},
	["0014_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But still, it's a widely known term, and it already insinuates a contradiction, so it's not the same as what I'm talking about. Basically, the importance of virginity is...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那只是产生的差异发生渗透，结果变成了符号而已，和这次的论述不同。也就是说，处女性的重要性在于——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那只是產生的差異發生滲透，結果變成了符號而已，和這次的論述不同。也就是說，處女性的重要性在於——」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00006",
		linknext = "0014_00008",
		line = 95,
	},
	["0014_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We walk to school having our normal cordial sibling discussions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们和以往一样一边兄妹间温馨地聊着天，一边来到了学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們和以往一樣一邊兄妹間溫馨地聊著天，一邊來到了學校。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00007",
		linknext = "0014_00009",
		line = 105,
	},
