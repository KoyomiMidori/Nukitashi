		line = 5089,
	},
	["0060_00413"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't deny that we've become somewhat close lately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，两人的关系比以前更亲密是事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，兩人的關係比以前更親密是事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00412",
		linknext = "0060_00414",
		line = 5099,
	},
	["0060_00414"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I'm just doing that to gain her trust.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，这只是作为间谍刻意为之而已————",
					{"rt2"},
				},
