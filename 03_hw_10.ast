		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1150", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I'm not sure... I hate the idea of being enemies with Rei...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“怎么说呢……我当然不喜欢做类似和礼酱吵架的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「怎麼說呢……我當然不喜歡做類似和禮醬吵架的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00394",
		linknext = "0060_00396",
		line = 4877,
	},
	["0060_00396"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1151", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But... even if it weren't for the NLNS, I'd be a criminal anyway since I've never had sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是我一次都没做过爱……就算没和橘君们在一起，不管怎么样都还是犯罪者啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是我一次都沒做過愛……就算沒和橘君們在一起，不管怎麼樣都還是犯罪者啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00395",
		linknext = "0060_00397",
		line = 4891,
	},
	["0060_00397"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
