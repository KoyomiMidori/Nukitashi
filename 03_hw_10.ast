		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since Wata coincidentally came by to keep Asa company, the house is unusually lively today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且来照顾麻沙酱的渡酱也在，今天我们家比任何时候都热闹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且來照顧麻沙醬的渡醬也在，今天我們家比任何時候都熱鬧。",
					{"rt2"},
