		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg060122", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0485", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Uh... um... no, well... wh-what, you got a problem with that!? It's the weekend! Who cares if I wanna be lazy and sleep in!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔……啊……不，这……你有什么意见吗！？今天是休假日哦！想懒惰地睡到中午也是我的自由啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔……啊……不，這……你有什麼意見嗎！？今天是休假日哦！想懶惰地睡到中午也是我的自由啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00194",
		linknext = "0060_00196",
		line = 2492,
	},
	["0060_00196"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No problem... Just chill a bit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么意见……不用这么急着生气吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼意見……不用這麼急著生氣吧。」",
					{"rt2"},
				},
