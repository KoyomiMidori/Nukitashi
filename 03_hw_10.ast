		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why even bother waiting for her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那为什么要等渡酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那為什麼要等渡醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00060",
		linknext = "0060_00062",
		line = 772,
	},
	["0060_00062"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00113", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1084", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well, like... no matter what I do, she always has some sort of compliment for me. So it makes me feel like a million bucks whenever she watches me play.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为……无论我做什么渡酱都会夸奖我，所以在她身边玩的时候感觉非常好呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為……無論我做什麼渡醬都會誇獎我，所以在她身邊玩的時候感覺非常好呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00061",
		linknext = "0060_00063",
		line = 786,
	},
	["0060_00063"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
