			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Those shows are so nostalgic... They remind me of how simple things used to be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要看看那些作品，就会想起以前一起开心玩耍的时光呢——”",
