	["0060_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Such a nice day today, and here I am pondering over my tablet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在和平的日子里，我表情面带困倦地瞪着平板。",
