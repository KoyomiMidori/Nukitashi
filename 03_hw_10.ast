	["0060_00422"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Suddenly she's ruffling my hair with her tiny hands in a childish rage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱瞬间就变得像个小孩子，用两只小手在我的头发上乱抓乱扯。",
					{"rt2"},
