	["0060_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After yesterday's incident, there's no way I can see it going well if I meet her face-to-face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，和礼前辈面对面——加上昨天的事，我丝毫没有可以平安无事的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，和禮前輩面對面——加上昨天的事，我絲毫沒有可以平安無事的感覺。",
					{"rt2"},
				},
			},
		},
