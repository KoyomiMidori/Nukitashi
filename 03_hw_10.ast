			},
		},
		linkback = "0060_00341",
		linknext = "0060_00343",
		line = 4206,
	},
	["0060_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's almost overwhelming, but I can't back down now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"差点要被气氛所吞噬——但不能在这里退缩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"差點要被氣氛所吞噬——但不能在這裡退縮。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00342",
		linknext = "0060_00344",
		line = 4216,
	},
	["0060_00344"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's just that I've heard of a lot of incidents involving children lately, and was wondering if your siblings were all right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——最近，听说有很多小孩被卷入的事件，所以有些担心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——最近，聽說有很多小孩被捲入的事件，所以有些擔心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00343",
		linknext = "0060_00345",
		line = 4227,
	},
	["0060_00345"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The silence is even heavier than before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"比刚才更沉重的沉默。",
					{"rt2"},
				},
			},
			tw = {
				{
					"比剛才更沉重的沉默。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00344",
		linknext = "0060_00346",
		line = 4237,
	},
	["0060_00346"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She has her mouth shut tight and looks to be considering her next words carefully.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈紧紧闭着嘴，似乎在斟酌接下来要说的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩緊緊閉著嘴，似乎在斟酌接下來要說的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00345",
		linknext = "0060_00347",
		line = 4247,
	},
	["0060_00347"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Has the SS not taken countermeasures?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS有提出什么对策吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS有提出什麼對策嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00346",
		linknext = "0060_00348",
		line = 4259,
	},
	["0060_00348"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06019-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0518", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“As I said, the SS is spread thin at the moment. You're still a cadet, so that's all I can tell you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我说过人才不足吧……关于那件事，对训练生的你无话可说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我說過人才不足吧……關於那件事，對訓練生的你無話可說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00347",
		linknext = "0060_00349",
		line = 4274,
	},
	["0060_00349"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0519", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There are SS resources allocated towards the problem, yes. But it's not our jurisdiction.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“首先，那个问题SHO已经在应对了。不是我们的管辖。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「首先，那個問題SHO已經在應對了。不是我們的管轄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00348",
		linknext = "0060_00350",
		line = 4286,
	},
	["0060_00350"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But, the issue hasn't been resolved yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……还没解决对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……還沒解決對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00349",
		linknext = "0060_00351",
		line = 4298,
	},
	["0060_00351"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0520", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If it could be resolved so quickly, it wouldn't be a problem. It needs time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果是一朝一夕能解决的问题，从一开始就不用这么费力了。如果想要尽善尽美，无论如何都需要时间。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果是一朝一夕能解決的問題，從一開始就不用這麼費力了。如果想要盡善盡美，無論如何都需要時間。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00350",
		linknext = "0060_00352",
		line = 4310,
	},
	["0060_00352"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if it takes too long, more people will be hurt. Your siblings could be targeted...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，花的时间越多，受害者也会越来越多……你的妹妹们也可能成为——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，花的時間越多，受害者也會越來越多……你的妹妹們也可能成為——」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00351",
		linknext = "0060_00353",
		line = 4321,
	},
	["0060_00353"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg060110-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0521", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hey, Tachibana... Think carefully before you speak.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂，橘……好好想想再发言哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂，橘……好好想想再發言哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00352",
		linknext = "0060_00354",
		line = 4337,
	},
	["0060_00354"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I'm sorry. That was out of line.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……对不起。失言了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……對不起。失言了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00353",
		linknext = "0060_00355",
		line = 4349,
	},
	["0060_00355"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I got carried away, didn't I?",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才确实说得太过了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才確實說得太過了。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00354",
		linknext = "0060_00356",
		line = 4359,
	},
	["0060_00356"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm definitely being too hasty.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自己也知道自己在着急。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自己也知道自己在著急。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00355",
		linknext = "0060_00357",
		line = 4369,
	},
	["0060_00357"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've been in the SS for a while now, but I still haven't been able to learn anything about the public order or about Fumino. It's frustrating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然进入FS已经过了一段时间，但有关治安问题和“文乃”的事都还不知道——这让我太焦虑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然進入FS已經過了一段時間，但有關治安問題和「文乃」的事都還不知道——這讓我太焦慮了。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00356",
		linknext = "0060_00358",
		line = 4379,
	},
	["0060_00358"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0522", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“As disciplinary committee president, my job is to enact my superiors' orders and manage the SS. I can't be rash and act on my own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我是风纪委员长——服从上头的命令，管束FS是我的工作。我不会独断采取轻率的行动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我是風紀委員長——服從上頭的命令，管束FS是我的工作。我不會獨斷採取輕率的行動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00357",
		linknext = "0060_00359",
		line = 4391,
	},
	["0060_00359"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0523", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Our orders are to counter the Anti-Copulation Front. We are to smoke the terrorists out, suppress them, and enact their punishment!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“眼下，我们应该做的事情是反交尾势力的对策。一定要逼出反抗条例的家伙们……给予制裁……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「眼下，我們應該做的事情是反交尾勢力的對策。一定要逼出反抗條例的傢伙們……給予制裁……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00358",
		linknext = "0060_00360",
		line = 4403,
	},
	["0060_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes are glimmering, like she's talking about getting revenge against someone who killed her family.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仿佛看着杀父仇人的眼神。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彷彿看著殺父仇人的眼神。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00359",
		linknext = "0060_00361",
		line = 4413,
	},
	["0060_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't get it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00360",
		linknext = "0060_00362",
		line = 4423,
	},
	["0060_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How can she be so vehemently opposed to the Anti-Copulation Front, while still accepting my own reservations?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么她能认同我，却对反交尾势力如此敌视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼她能認同我，卻對反交尾勢力如此敵視。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00361",
		linknext = "0060_00363",
		line = 4433,
	},
	["0060_00363"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I carefully choose my words to not say something thoughtless.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我斟酌着词语，尽量不说错话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我斟酌著詞語，盡量不說錯話——",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00362",
		linknext = "0060_00364",
		line = 4443,
	},
	["0060_00364"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Understood. From now on, I'll also direct all my energy towards bringing down the Anti-Copulation Front.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我明白了。那我……现在也全心致力于反交尾势力的对策。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我明白了。那我……現在也全心致力於反交尾勢力的對策。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00363",
		linknext = "0060_00365",
		line = 4455,
	},
	["0060_00365"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0524", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That's right. We cannot allow them to continue living the way they do. We'll show them there's no place on this island for that lifestyle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……不能认同他们的存在方式。这个岛上，绝不能允许那种生活方式。我要让他们知道这点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……不能認同他們的存在方式。這個島上，絕不能允許那種生活方式。我要讓他們知道這點。」",
