	["0060_00068"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1085", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Look here look listen that is BULLSHIT right there you fuckin' chud yank I'm the one who's capable of whoopin' your fuckin' ass you fuckin' dipshit real talk you wanna fuckin' go!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不不不怎么能不防范就随便开大招啊这家伙是小混混吗就算那样赢了也不会变强好吗这样应该算是我赢吧别开玩笑了小心我去肉搜你……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不不不怎麼能不防範就隨便開大招啊這傢伙是小混混嗎就算那樣贏了也不會變強好嗎這樣應該算是我贏吧別開玩笑了小心我去肉搜你……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00067",
		linknext = "0060_00069",
		line = 852,
	},
	["0060_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Claiming to be better than someone who kicked her ass? Prime scrubquotes material, right here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然输了但仍然坚持自己比别人强，这是她的厉害之处。",
