		{"bg", id=18, file="hcg06012-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0483", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“D-Don't look around so much... it's kinda rude.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别、别死盯着别人的房间看……太失礼了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別、別死盯著別人的房間看……太失禮了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00186",
		linknext = "0060_00188",
		line = 2391,
	},
	["0060_00188"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sorry. I just got curious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，不好意思……我忍不住。”",
