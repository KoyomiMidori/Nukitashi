		linkback = "0060_00312",
		linknext = "0060_00314",
		line = 3863,
	},
	["0060_00314"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All I wanted was an excuse for claiming I was impotent.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明明只是想说明勃起障碍的理由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明明只是想說明勃起障礙的理由。",
