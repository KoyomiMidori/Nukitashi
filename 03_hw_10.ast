				{
					name = {"ヒナミ", "Hinami"},
					"“There, there... Thanks, Tachibana. You're so kind for worrying about me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好乖好乖……谢谢你，橘君。橘君好温柔啊……你在担心我呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好乖好乖……謝謝你，橘君。橘君好溫柔啊……你在擔心我呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00401",
		linknext = "0060_00403",
		line = 4972,
	},
	["0060_00403"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She embraces my head, stroking it with her small, soft hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱像拥抱一样抱住我的头，用柔软的手抚摸我的脑袋。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬像擁抱一樣抱住我的頭，用柔軟的手撫摸我的腦袋。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00402",
		linknext = "0060_00404",
		line = 4982,
	},
	["0060_00404"] = {
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00107", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1156", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No matter what, I'm sure I'll be fine. I'm sure Rei would understand, since she lends me a lot of wonderful, romantic shoujo manga.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过，你不用担心。我想礼酱一定也会理解的。因为她经常借我有爱的少女漫画呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過，你不用擔心。我想禮醬一定也會理解的。因為她經常借我有愛的少女漫畫呀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00403",
		linknext = "0060_00405",
		line = 4996,
	},
	["0060_00405"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, Rei was the friend who lent you those manga.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——啊。把漫画借给你的朋友，就是礼前辈吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——啊。把漫畫借給你的朋友，就是禮前輩嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00404",
		linknext = "0060_00406",
		line = 5008,
	},
	["0060_00406"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn't notice any shoujo manga in her room when I was there, but it must've just been somewhere else.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然好像在房间里一本少女漫画都没看到——或许是放在别的架子上了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然好像在房間裡一本少女漫畫都沒看到——或許是放在別的架子上了。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00405",
		linknext = "0060_00407",
		line = 5018,
	},
	["0060_00407"] = {
		{"fg", file="hinami_02l_00002", file1="hinami_02l_00102", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1157", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah! So there's no need to worry about either of us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！所以嘛，我们两个什么都不用担心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！所以嘛，我們兩個什麼都不用擔心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00406",
		linknext = "0060_00408",
		line = 5032,
	},
	["0060_00408"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Either?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我们两个？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我們兩個？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00407",
		linknext = "0060_00409",
		line = 5044,
	},
	["0060_00409"] = {
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00112", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1158", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah! Aren't you friends with Rei, too? That's why you're worried about her. Isn't that why you asked?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……？因为橘君和礼酱也是好朋友，所以才很在意吧？所以你才会突然问起礼酱的事情不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……？因為橘君和禮醬也是好朋友，所以才很在意吧？所以你才會突然問起禮醬的事情不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00408",
		linknext = "0060_00410",
		line = 5058,
	},
	["0060_00410"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, no, I was just wondering your thoughts...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……我只是想知道渡酱的想法——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……我只是想知道渡醬的想法——」",
					{"rt2"},
				},
