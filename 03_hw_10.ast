	},
	["0060_00321"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So what does that mean?",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说————",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說————",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00320",
		linknext = "0060_00322",
		line = 3952,
	},
	["0060_00322"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to ask her to explain, but I stop and hold my tongue.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然想继续催促，但我还是犹豫了一下咽了口唾沫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然想繼續催促，但我還是猶豫了一下嚥了口唾沫。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00321",
		linknext = "0060_00323",
		line = 3962,
	},
	["0060_00323"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06013-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0511", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I'm sure you know that the SS is spread very thin at the moment. Given the situation, we can't afford to abandon trainees who have been surviving the selection training.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如你所知，FS又忙人员又不够。在这种情况下，我不想为内部带来问题，而且也没有余裕在现在放弃能撑得住选拔训练的学生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如你所知，FS又忙人員又不夠。在這種情況下，我不想為內部帶來問題，而且也沒有餘裕在現在放棄能撐得住選拔訓練的學生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00322",
		linknext = "0060_00324",
		line = 3977,
	},
	["0060_00324"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg060110-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0512", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Plus, if it were discovered that we created the impotence quota for someone who wasn't really impotent, it would make the SS look bad. Do you see where I'm going with this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“而且，如果被发现特别设置的位置上采用的人名不符实的话——有伤FS之名。明白吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「而且，如果被發現特別設置的保障名額採用的人名不符實的話——有傷FS之名。明白嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00323",
		linknext = "0060_00325",
		line = 3992,
	},
	["0060_00325"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00324",
		linknext = "0060_00326",
		line = 4004,
	},
	["0060_00326"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0513", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“So, for now, I want you to continue as before. Pretend to be impotent, as you have been. Got it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以……目前就继续对外说自己是阳痿。知道吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以……目前就繼續對外說自己是陽痿。知道嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00325",
		linknext = "0060_00327",
		line = 4016,
	},
	["0060_00327"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. Thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……謝謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00326",
		linknext = "0060_00328",
		line = 4027,
	},
	["0060_00328"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06011-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0514", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don't misunderstand. This is an emergency measure to deal with a critical staff shortage. Once things settle down, we'll revisit the issue and figure out what to do with you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你可不要误会。这只不过是暂时的特别措施……你的处分……等事态平稳之后我会再另外考虑……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你可不要誤會。這只不過是暫時的特別措施……你的處分……等事態平穩之後我會再另外考慮……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00327",
		linknext = "0060_00329",
		line = 4042,
	},
	["0060_00329"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't know how far I trust her, but it seems like I'm safe for now, at least.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道礼前辈的话到底有几分是真实的——但好像还能平安一段时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道禮前輩的話到底有幾分是真實的——但好像還能平安一段時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00328",
		linknext = "0060_00330",
		line = 4052,
	},
	["0060_00330"] = {
		{"evset", file="hcg06", set="hcg06", path=":ev/hcg06/"},
		{"evset", file="hcg060193", set="hcg060193", path=":ev/hcg060193/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg060193", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0515", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Plus... I'm sorry about yesterday... about losing my composure... That must have been unpleasant.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“然后……不好意思，昨天……那个，我有点没沉住气了……让你不开心了吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「然後……不好意思，昨天……那個，我有點沒沉住氣了……讓你不開心了吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00329",
		linknext = "0060_00331",
		line = 4070,
	},
	["0060_00331"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, no... well... I'm also sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，没事……那个……我才觉得不好意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，沒事……那個……我才覺得不好意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00330",
		linknext = "0060_00332",
		line = 4082,
	},
	["0060_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I couldn't think straight at the time, and I was scared that I'd be exposed, so I didn't really consider what I was doing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为今天都在担心事情会不会暴露，所以几乎没有意识到——",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為今天都在擔心事情會不會暴露，所以幾乎沒有意識到——",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00331",
		linknext = "0060_00333",
		line = 4092,
	},
	["0060_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now, though, I can look back rationally on what I did to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仔细想想，我和礼前辈做了呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仔細想想，我和禮前輩做了呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00332",
		linknext = "0060_00334",
		line = 4102,
	},
	["0060_00334"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06017-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0516", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I'm sure you find all this painful, but I hope that one day you'll be able to get past your trauma.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“现在还很痛苦吧……希望你有一天，也能发自内心去做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「現在還很痛苦吧……希望你有一天，也能發自內心去做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00333",
		linknext = "0060_00335",
		line = 4117,
	},
	["0060_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is this the same disciplinary committee president who acts as judge, jury, and executioner on anyone suspected of avoiding sex?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不由分说地把非性产者送上断头台的残忍风纪委员长这么说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不由分說地把非性產者送上斷頭臺的殘忍風紀委員長這麼說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00334",
		linknext = "0060_00336",
		line = 4127,
	},
	["0060_00336"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's like a totally different person.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真的就像变了一个人似的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真的就像變了一個人似的。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00335",
		linknext = "0060_00337",
		line = 4137,
	},
	["0060_00337"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't say anything, simply nodding in agreement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我这样想着，默默地点了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我這樣想著，默默地點了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00336",
		linknext = "0060_00338",
		line = 4147,
	},
	["0060_00338"] = {
		{"se", id=1, loop=1, file="se_a199", vol=70},
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sound of the TV dominates the otherwise silent room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一沉默，电视的声音便显得有些吵杂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一沉默，電視的聲音便顯得有些吵雜。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00337",
		linknext = "0060_00339",
		line = 4159,
	},
	["0060_00339"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I still have the other reason I came here, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有一件必须要问的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有一件必須要問的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00338",
		linknext = "0060_00340",
		line = 4169,
	},
	["0060_00340"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei... are your siblings of legal age? Does the law apply to them yet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈……前辈的弟弟和妹妹，已经到了性人——条例对象的年龄了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩……前輩的弟弟和妹妹，已經到了性人——條例對象的年齡了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00339",
		linknext = "0060_00341",
		line = 4181,
	},
	["0060_00341"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg060110-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0517", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No, not yet. Why do you ask?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……不，还没有。怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……不，還沒有。怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00340",
		linknext = "0060_00342",
		line = 4196,
	},
	["0060_00342"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her tone hardened suddenly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的语气突然变冷了。",
					{"rt2"},
				},
