	},
	["0060_00421"] = {
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00118", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
