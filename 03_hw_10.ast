		{"bg", id=18, file="hcg06017-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0510", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I see. If you become an official SS member and start receiving scholarship funds, that should make things easier.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是吗……如果能成为正式FS的一员，得到奖学金的话，就能过得更轻松了。”",
					{"rt2"},
				},
