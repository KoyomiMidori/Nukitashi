	},
	["0060_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can imagine that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个景象仿佛浮现在眼前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個景象彷彿浮現在眼前。",
					{"rt2"},
				},
			},
