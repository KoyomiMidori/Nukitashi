	},
	["0060_00391"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei's your friend. What do you think about her hostility against the NLNS, and by extension, you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是关于身在NLNS，实际上就是和FS的礼前辈互相敌对的事情……你是怎么想的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是關於身在NLNS，實際上就是和FS的禮前輩互相敵對的事情……你是怎麼想的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00390",
		linknext = "0060_00392",
		line = 4819,
	},
	["0060_00392"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've been avoiding bringing it up, but it's been bothering me for a while.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然到现在为止没有特别提及——但我实在很在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然到現在為止沒有特別提及——但我實在很在意。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00391",
