				{"vo", file="hinami1153", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So yeah! It's not wrong to want to be with you! I want to help you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……嗯！我果然不认为和橘君们在一起是不对的！因为我想要帮助大家！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……嗯！我果然不認為和橘君們在一起是不對的！因為我想要幫助大家！」",
					{"rt2"},
				},
			},
		},
