	},
	["0060_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can only guess that it was funding was a product of the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且基本上都是单人房——这也都是通过变态条例得到的资金建设吗？",
					{"rt2"},
				},
			},
			tw = {
				{
