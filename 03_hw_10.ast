	},
	["0060_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For a student dorm, the facilities are quite impressive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但作为学生宿舍，这实在是太豪华了。",
					{"rt2"},
				},
