	["0060_00031"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0000", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "???"},
					"“To suppress our instincts, to resist our sexual desires, is to deny our nature as animals and as humans. Humanity needed a savior—one willing to speak up in the name of sexual freedom, and to stand up to pressure from our closed-minded neighbors.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦", "？ ？ ？"},
					"“若压抑性欲本能，将无法完全发挥作为一个人的力量。所以我才要发声，我不会输给压力，我将呼吁性的自由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦", "？？？"},
					"「若壓抑性慾本能，將無法完全發揮作為一個人的力量。所以我才要發聲，我不會輸給壓力，我將呼籲性的自由。」",
					{"rt2"},
				},
			},
		},
