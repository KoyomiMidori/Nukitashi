	},
	["0060_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So this is where the disciplinary committee president lives.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不用说，对象是风纪委员长——也就是礼前辈的房间。",
