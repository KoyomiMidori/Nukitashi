		line = 321,
	},
	["0060_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a documentary, outlining the path that Seiran Island took to become what it is now—the establishment of the law, becoming a haven for sex tourism and all that.",
