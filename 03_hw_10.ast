		linkback = "0060_00410",
		linknext = "0060_00412",
		line = 5079,
	},
	["0060_00412"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Am I worried about Rei?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我很在意礼前辈吗——",
					{"rt2"},
				},
