	},
	["0060_00415"] = {
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00102", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1159", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“There there. You're so nice, Tachibana. You were worried about me and Rei. What a good boy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好乖好乖……很了不起啊橘君。不仅关心我的事情，还关心礼酱的事情。好孩子好孩子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好乖好乖……很了不起啊橘君。不僅關心我的事情，還關心禮醬的事情。好孩子好孩子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00414",
		linknext = "0060_00416",
		line = 5123,
	},
	["0060_00416"] = {
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00107", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1160", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“It's nothing to worry about. I'm your senior... I'm much muuuch stronger than you think I am.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是不需要那么不安哦。因为我是前辈……比橘君认为的，要更更强大。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是不需要那麼不安哦。因為我是前輩……比橘君認為的，要更更強大。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00415",
		linknext = "0060_00417",
		line = 5137,
	},
	["0060_00417"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her gentle stroking makes me needless worries and hesitation melt away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被温暖的手温柔地抚摸着，多余的烦恼逐渐消失。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被溫暖的手溫柔地撫摸著，多餘的煩惱逐漸消失。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00416",
		linknext = "0060_00418",
		line = 5147,
	},
	["0060_00418"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Somehow... you really do seem like a big sister when you do this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是太不可思议了……一被你这样做，真的会觉得渡酱是姐姐……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是太不可思議了……一被你這樣做，真的會覺得渡醬是姐姐……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00417",
		linknext = "0060_00419",
		line = 5159,
	},
	["0060_00419"] = {
		{"fg", file="hinami_01l_00002", file1="hinami_01l_00102", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1161", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahaha. You always just treat me as a child, but I'm always the big sister here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈。那是因为你一直把我当小孩子看……我平常就是个姐姐哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈。那是因為你一直把我當小孩子看……我平常就是個姐姐哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00418",
		linknext = "0060_00420",
		line = 5173,
	},
	["0060_00420"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
