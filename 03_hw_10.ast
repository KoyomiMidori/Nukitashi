	["0060_00398"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1152", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Plus, I wouldn't want to have sex with someone I didn't love... not to mention how hard you've all been fighting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“而且如果要做爱，我果然还是想和喜欢的人一起……橘君们也都很困扰……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「而且如果要做愛，我果然還是想和喜歡的人一起……橘君們也都很困擾……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00397",
