		{"bg", id=18, file="hcg06013-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0484", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, uh, yeah. I thought I'd get a few games in after waking...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔……嗯，对啊。起床后想先打场比赛……”",
