	["0060_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What's this unprovoked venting?",
					{"rt2"},
				},
			},
			cn = {
				{
					"完全是把气撒在我身上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"完全是把氣撒在我身上。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00198",
		linknext = "0060_00200",
		line = 2544,
	},
	["0060_00200"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I didn't expect that, though. You're so good at handling guns, I thought you'd be good at shooters.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，真是意外……你平时都是用枪，所以我以为你会玩FPS。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，真是意外……你平時都是用槍，所以我以為你會玩FPS。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00199",
		linknext = "0060_00201",
		line = 2556,
	},
	["0060_00201"] = {
		{"evset", file="hcg06", set="hcg06", path=":ev/hcg06/"},
		{"evset", file="hcg06015-1", set="hcg06015-", path=":ev/hcg06015-/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06015-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0487", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, shut up. Just because I use guns in real life, I can't play games as an outlet when I'm pissed off? This isn't work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“算了吧……为什么连放松用的游戏里都要拿枪啊……又不是工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「算了吧……為什麼連放鬆用的遊戲裡都要拿槍啊……又不是工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00200",
		linknext = "0060_00202",
		line = 2574,
	},
	["0060_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She snaps at me, taking me aback.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一副真的很讨厌的表情，让我不知所措。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一副真的很討厭的表情，讓我不知所措。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00201",
		linknext = "0060_00203",
		line = 2584,
	},
	["0060_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's such a stickler for regulations, and always super focused in training and instruction. I never thought of her as having hobbies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平时那么严格地指导我们要遵守纪律，训练中也丝毫不放水——让我以为她一定是个工作狂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平時那麼嚴格地指導我們要遵守紀律，訓練中也絲毫不放水——讓我以為她一定是個工作狂。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00202",
		linknext = "0060_00204",
		line = 2594,
	},
