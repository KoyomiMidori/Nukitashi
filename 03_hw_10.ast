		linkback = "0060_00187",
		linknext = "0060_00189",
		line = 2403,
	},
	["0060_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her words say 'I see', but her tone and expression say 'stop looking'.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着礼前辈这样说时，感觉又会被骂说不要一直盯看着她看。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著禮前輩這樣說時，感覺又會被罵說不要一直盯看著她看。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00188",
		linknext = "0060_00190",
		line = 2413,
	},
	["0060_00190"] = {
		{"text"},
		text = {
