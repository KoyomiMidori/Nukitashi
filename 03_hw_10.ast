		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=500},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since Wata's been coming here, Nanase hasn't been stopping by as much, but today was a scheduled housework service day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然自从渡酱开始来之后，次数就减少了——但今天是奈奈濑家务代理的日子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然自從渡醬開始來之後，次數就減少了——但今天是奈奈瀨家事代理的日子。",
					{"rt2"},
				},
