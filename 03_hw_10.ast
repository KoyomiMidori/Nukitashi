			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is there anything else here that I can talk about? Trying to hide my distress, I look around the room again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有没有可以作为话题的东西？我装出平静的样子，让视线在房间里游移——",
					{"rt2"},
				},
			},
			tw = {
				{
					"有沒有可以作為話題的東西？我裝出平靜的樣子，讓視線在房間裡游移——",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00226",
		linknext = "0060_00228",
		line = 2869,
	},
	["0060_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Target acquired.",
					{"rt2"},
				},
			},
			cn = {
				{
					"找到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"找到了。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00227",
		linknext = "0060_00229",
		line = 2879,
	},
	["0060_00229"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh, I didn't know you were into that stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——礼前辈有在看这些东西吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——禮前輩有在看這些東西嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00228",
		linknext = "0060_00230",
		line = 2892,
	},
	["0060_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On the shelf, I catch sight of some children's anime and tokusatsu show DVDs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在书柜里发现了儿童动画和特摄作品的影像光盘。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在書櫃裡發現了兒童動畫和特攝作品的光碟片。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00229",
		linknext = "0060_00231",
		line = 2902,
	},
	["0060_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They aren't Seiran Island parodies. They're actually just mainstream shows from the mainland.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那不是青蓝岛特有的疯狂恶搞作品，而是在星期天早晨播出的本岛的正规品。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那不是青藍島特有的瘋狂惡搞作品，而是在星期天早晨播出的本島的正規品。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00230",
		linknext = "0060_00232",
		line = 2912,
	},
	["0060_00232"] = {
		{"evset", file="hcg06", set="hcg06", path=":ev/hcg06/"},
		{"evset", file="hcg06017-1", set="hcg06017-", path=":ev/hcg06017-/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06017-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"bgm", file="bgm01", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0493", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, yeah, my little sister and brother love them. I'm so busy with SS work that I don't get to talk to them much, but I wanted to have something to talk about when we can.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊，那是……我弟弟和妹妹喜欢。当上风纪委员长后，就没什么机会和他们聊天……所以想找些共同的话题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊，那是……我弟弟和妹妹喜歡。當上風紀委員長後，就沒什麼機會和他們聊天……所以想找些共同的話題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00231",
		linknext = "0060_00233",
		line = 2931,
	},
	["0060_00233"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00232",
		linknext = "0060_00234",
		line = 2943,
	},
	["0060_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I recall Wata saying that she works hard in the SS for her family's sake.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈在FS尽心尽力都是为了家人——我想起以前渡酱这么说过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩在FS盡心盡力都是為了家人——我想起以前渡醬這麼說過。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00233",
		linknext = "0060_00235",
		line = 2953,
	},
	["0060_00235"] = {
		{"evset", file="hcg06", set="hcg06", path=":ev/hcg06/"},
		{"evset", file="hcg06018-1", set="hcg06018-", path=":ev/hcg06018-/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06018-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0494", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Lately, they seem like they'd rather spend time with kids their own age than with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过，最近与其跟我聊天，他们还比较喜欢跟同龄的朋友们一起玩的样子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不過，最近與其跟我聊天，他們還比較喜歡跟同齡的朋友們一起玩的樣子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00234",
		linknext = "0060_00236",
		line = 2971,
	},
	["0060_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's smiling, but her tone is a bit sad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"表情虽然在笑，但那句话却显得有些落寞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"表情雖然在笑，但那句話卻顯得有些落寞。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00235",
		linknext = "0060_00237",
		line = 2981,
	},
	["0060_00237"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0495", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Once, I could just pose and yell 'Transform!' and that would make them happy... but, before I knew it, they'd outgrown that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“以前……只要我摆出姿势说‘变身’，他们就会很高兴……但不知不觉中，他们好像已经不吃这一套了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「以前……只要我擺出姿勢說『變身』，他們就會很高興……但不知不覺中，他們好像已經不吃這一套了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00236",
		linknext = "0060_00238",
		line = 2993,
	},
	["0060_00238"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0496", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Still, though, I can't stop watching them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但就算是这样——我还是会忍不住继续看下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但就算是這樣——我還是會忍不住繼續看下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00237",
		linknext = "0060_00239",
		line = 3005,
	},
