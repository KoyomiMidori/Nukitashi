		linkback = "0060_00313",
		linknext = "0060_00315",
		line = 3873,
	},
	["0060_00315"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I ended up spilling all my deepest secrets to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但却在不知不觉间，把内心深处隐藏的一切都告诉了礼前辈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但卻在不知不覺間，把內心深處隱藏的一切都告訴了禮前輩。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00314",
		linknext = "0060_00316",
		line = 3883,
	},
	["0060_00316"] = {
		{"text"},
		text = {
