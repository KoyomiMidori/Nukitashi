		linkback = "0060_00063",
		linknext = "0060_00065",
		line = 808,
	},
	["0060_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If Wata were a pony, she'd probably have a cutie mark for giving compliments. She's just that good at it sometimes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱很擅长表扬别人，有时会让人觉得真有那么回事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬很擅長表揚別人，有時會讓人覺得真有那麼回事。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00064",
		linknext = "0060_00066",
		line = 818,
	},
	["0060_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And so, Asa decides to start playing an online game without waiting for her.",
					{"rt2"},
