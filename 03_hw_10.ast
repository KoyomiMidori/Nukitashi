		{"se", id=1, loop=1, file="se_d030", vol=60},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS dormitory is right beside the school building.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS的宿舍附属于教学楼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS的宿舍附屬於校舍。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00134",
		linknext = "0060_00136",
		line = 1724,
	},
	["0060_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While the school gates are locked on weekends, the dorm remains open.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一到休息日，正门和后门就会被锁上，所以一般学生无法出入，但宿舍却可以正常出入。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一到休息日，正門和後門就會被鎖上，所以一般學生無法出入，但宿舍卻可以正常出入。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00135",
		linknext = "0060_00137",
		line = 1734,
	},
	["0060_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In most places, a guy normally wouldn't be allowed to enter female dorms, but this isn't most places.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通常情况下，男生未经许可进入女生宿舍会成为问题吧——但这里是青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通常情況下，男生未經許可進入女生宿舍會成為問題吧——但這裡是青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00136",
		linknext = "0060_00138",
		line = 1744,
	},
	["0060_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Naturally, there's no problem with it on Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，那种事情是不被在乎的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，那種事情是不被在乎的。",
