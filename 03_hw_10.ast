				},
			},
			cn = {
				{
					"顿时间不知如何是好的我，把目光转向了电视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"頓時間不知如何是好的我，把目光轉向了電視。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00189",
		linknext = "0060_00191",
		line = 2423,
	},
	["0060_00191"] = {
