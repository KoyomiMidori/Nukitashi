				{"vo", file="rei0506", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That's nothing to be criticized about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那样的……不是该被谴责的事情吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那樣的……不是該被譴責的事情吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00297",
		linknext = "0060_00299",
		line = 3696,
	},
	["0060_00299"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Maybe so... But that didn't matter to them, back then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样说也没错……不过，说是这样说……但被人谴责是事实。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣說也沒錯……不過，說是這樣說……但被人譴責是事實。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00298",
		linknext = "0060_00300",
		line = 3708,
	},
	["0060_00300"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels like I'm talking about someone else.",
					{"rt2"},
				},
			},
			cn = {
				{
					"简直就像在说别人的事情一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"簡直就像在說別人的事情一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00299",
		linknext = "0060_00301",
		line = 3718,
	},
	["0060_00301"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In reality, it was probably just because they generally hated me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“事实上，说我很大很恶心之类的可能也只是借口……其实只是单纯不喜欢我而已吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「事實上，說我很大很噁心之類的可能也只是藉口……其實只是單純不喜歡我而已吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00300",
		linknext = "0060_00302",
		line = 3730,
	},
	["0060_00302"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They just wanted to bully me for something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不喜欢我，想要欺负我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不喜歡我，想要欺負我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00301",
		linknext = "0060_00303",
		line = 3741,
	},
	["0060_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So they found something about me that was different and zeroed in on it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可能只是偶然",
					{"ruby", text="・・"},
					"那个",
					{"/ruby"},
					"与其他人不同，所以成为了被攻击的理由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可能只是偶然",
					{"ruby", text="・・"},
					"那個",
					{"/ruby"},
					"與其他人不同，所以成為了被攻擊的理由。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00302",
		linknext = "0060_00304",
		line = 3752,
	},
	["0060_00304"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, though, to this day, whenever I take out my dick, I can't help being reminded of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，就算到了现在……只要这个被看到，我就会想起那时候的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，就算到了現在……只要這個被看到，我就會想起那時候的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00303",
		linknext = "0060_00305",
		line = 3764,
	},
	["0060_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just want it to stop...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，我怎样都无法忍受……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，我怎樣都無法忍受……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00304",
		linknext = "0060_00306",
		line = 3775,
	},
	["0060_00306"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0507", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Really...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是嗎……」",
					{"rt2"},
				},
