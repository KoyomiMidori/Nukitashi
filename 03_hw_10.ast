		linkback = "0060_00385",
		linknext = "0060_00387",
		line = 4754,
	},
	["0060_00387"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00111", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1147", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I still can't get over how she sees us as so evil. They're such good people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是……礼酱把我们看得那么坏啊……嗯，我很在意。大家明明都是好孩子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是……禮醬把我們看得那麼壞啊……嗯，我很在意。大家明明都是好孩子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00386",
		linknext = "0060_00388",
		line = 4768,
	},
	["0060_00388"] = {
