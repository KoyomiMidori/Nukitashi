	["0060_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While I did cringe at that title, judging from the opening, this program seems to have fairly respectable content.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然心里有些抗拒，但一看内容，却是蛮认真的节目。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然心裡有些抗拒，但一看內容，卻是蠻認真的節目。",
