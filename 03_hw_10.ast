	["0060_00318"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0509", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You live alone with your sister, right? Are you able to make ends meet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你现在和妹妹两个人生活对吧……生活上有不足吗？”",
