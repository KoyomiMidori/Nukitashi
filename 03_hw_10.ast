	["0060_00197"] = {
		{"evset", file="hcg06", set="hcg06", path=":ev/hcg06/"},
		{"evset", file="hcg06014-1", set="hcg06014-", path=":ev/hcg06014-/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg06014-1", x=-5, y=-5, path=":cg/hcg06/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0486", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Chill!? You waltz in when I'm in the middle of getting my ass kicked and you have the fucking nerve ask me to chill!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“有很急吗！我本来就很恼火了！才第一场比赛就被狠狠地挑衅还输了……然后你还恬不知耻地来了！明白吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「有很急嗎！我本來就很惱火了！才第一場比賽就被狠狠地挑釁還輸了……然後你還恬不知恥地來了！明白嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00196",
		linknext = "0060_00198",
		line = 2522,
	},
	["0060_00198"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
