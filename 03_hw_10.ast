	["0060_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know I said I'd go to Rei's place today, but after what happened yesterday, I'm not really sure what to say to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然下决心要去拜访礼前辈，但发生那种事之后，不知该怎么打招呼才好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然下決心要去拜訪禮前輩，但發生那種事之後，不知該怎麼打招呼才好。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00004",
		linknext = "0060_00006",
		line = 62,
	},
	["0060_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I honestly half-expected her to reach out to me, but that hasn't happened so far.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明就算对方先跟我联络也不奇怪，但却到现在都完全没有消息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明就算對方先跟我聯絡也不奇怪，但卻到現在都完全沒有消息。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00005",
		linknext = "0060_00007",
		line = 72,
	},
	["0060_00007"] = {
		{"text"},
		text = {
