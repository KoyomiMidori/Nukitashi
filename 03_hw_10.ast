	["0060_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The hero on the TV sends a monster flying with a kick before mercilessly assaulting it with a rain of punches.",
					{"rt2"},
				},
			},
			cn = {
				{
					"电视中，正义的英雄踢飞了恶心的怪人，毫不留情地出拳挥打着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"電視中，正義的英雄踢飛了噁心的怪人，毫不留情地出拳揮打著。",
