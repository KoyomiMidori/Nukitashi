			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……啊，这样啊……说的也是。和橘君们在一起的话，就是这种意思吧……嗯……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……啊，這樣啊……說的也是。和橘君們在一起的話，就是這種意思吧……嗯……」",
