		},
		linkback = "0060_00305",
		linknext = "0060_00307",
		line = 3787,
	},
	["0060_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She squints, and her gaze is distant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈眯起了眼睛，像是在凝视着远方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩瞇起了眼睛，像是在凝視著遠方。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00306",
		linknext = "0060_00308",
		line = 3797,
	},
	["0060_00308"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe she's thinking about what happened yesterday, or maybe about the entrance examination.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是想起了昨天，还是想起了入队考试的事吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"是想起了昨天，還是想起了入隊考試的事嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00307",
		linknext = "0060_00309",
		line = 3807,
	},
	["0060_00309"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe there's something else she's recalling, that doesn't even involve me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或者说，那双眼睛，在看着我也不知道的遥远的过去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者說，那雙眼睛，在看著我也不知道的遙遠的過去。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00308",
		linknext = "0060_00310",
		line = 3817,
	},
	["0060_00310"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The bullying... had a deep effect on me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被欺负时的我……几乎变得自暴自弃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被欺負時的我……幾乎變得自暴自棄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00309",
		linknext = "0060_00311",
		line = 3829,
	},
	["0060_00311"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“For a while, it made me despise sex as a whole. I don't think I ever fully recovered from that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有一段时间我开始厌恶性行为——然后，还做了无可挽回的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有一段時間我開始厭惡性行為——然後，還做了無可挽回的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00310",
		linknext = "0060_00312",
		line = 3841,
	},
	["0060_00312"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0508", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Okay, that's enough. Tachibana... I'm sorry for bringing up painful memories.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“知道了，够了……对不起橘，让你想起讨厌的事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「知道了，夠了……對不起橘，讓你想起討厭的事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00311",
		linknext = "0060_00313",
		line = 3853,
	},
	["0060_00313"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her voice is gentle and kind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"温柔的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"溫柔的聲音。",
					{"rt2"},
				},
			},
