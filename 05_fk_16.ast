	["0116_00019"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-300, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2219", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Fumino? I hate to interrupt your fun, but do you have a minute? Jun over here wants us to clean up after his wounded pride or some shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“文乃——？不好意思打扰你了，你有空吗？能替淳辩解的就只有你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「文乃——？不好意思打擾你了，你有空嗎？能替淳辯解的就只有你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00018",
		linknext = "0116_00020",
		line = 289,
	},
	["0116_00020"] = {
