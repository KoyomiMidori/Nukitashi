			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Clearly, you do not despise non-virgins. There has to be another reason. I just can't put my finger on it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈绝对不是讨厌非处女吧？应该还有其他的事情。虽然不知道是什么——”",
