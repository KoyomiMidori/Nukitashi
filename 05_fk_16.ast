				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I guess so. I wonder why? I get tired of waiting for someone. It's a new experience for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊，为什么呢……竟然会等你。等待某个人，这是我生平第一次的经历。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊，為什麼呢……竟然會等你。等待某個人，這是我生平第一次的經歷。」",
					{"rt2"},
				},
			},
		},
