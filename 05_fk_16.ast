			},
		},
		linkback = "0116_00256",
		linknext = "0116_00258",
		line = 3760,
	},
	["0116_00258"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I do understand what fun it is doing something for someone else.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过为了某人做事而感到开心，这也不是无法理解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過為了某人做事而感到開心，這也不是無法理解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00257",
		linknext = "0116_00259",
		line = 3772,
	},
	["0116_00259"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0869", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Mother often said... that not just anyone would do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“并不是谁都可以……我妈妈，经常这样说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「並不是誰都可以……我媽媽，經常這樣說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00258",
		linknext = "0116_00260",
		line = 3787,
	},
	["0116_00260"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She suddenly casts her eyes down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃突然垂下视线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃突然垂下視線。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00259",
		linknext = "0116_00261",
		line = 3801,
	},
	["0116_00261"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She seems to be looking at her kimono.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像凝视着自己的和服一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像凝視著自己的和服一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00260",
		linknext = "0116_00262",
		line = 3811,
	},
	["0116_00262"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0870", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“She told me, 'devote yourself to a person you trust. Doing so will guarantee that person will stay with you and bring you happiness.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“她说过‘要对信赖的人尽心尽力。那样的话，他一定会把你一直留在身边，给你幸福的’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「她說過『要對信賴的人盡心盡力。那樣的話，他一定會把你一直留在身邊，給你幸福的』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00261",
		linknext = "0116_00263",
		line = 3823,
	},
	["0116_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was only one of the things her mother taught her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲明确地教育了她的，好像只有这一点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親明確地教育了她的，好像只有這一點。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00262",
		linknext = "0116_00264",
		line = 3833,
	},
	["0116_00264"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I remember last night, when she said she felt she was being 'indulgent.'",
					{"rt2"},
				},
			},
			cn = {
				{
					"昨晚的文乃……对我说那是件奢侈的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"昨晚的文乃……對我說那是件奢侈的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00263",
		linknext = "0116_00265",
		line = 3843,
	},
	["0116_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's all because her mother wasn't able to do any of this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为她母亲并没有做到——",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為她母親並沒有做到——",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00264",
		linknext = "0116_00266",
		line = 3853,
	},
	["0116_00266"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0871", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“However, not everyone will be able to find a person they can devote themselves to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是，不是谁都能找到……想要尽心尽力的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是，不是誰都能找到……想要盡心盡力的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00265",
		linknext = "0116_00267",
		line = 3867,
	},
	["0116_00267"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00107", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0872", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“That's why I'm so fortunate to have met you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以……能遇到淳之介同学，文乃真是个幸福的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以……能遇到淳之介同學，文乃真是個幸福的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00266",
		linknext = "0116_00268",
		line = 3882,
	},
	["0116_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her mother was a woman named Fumika, born of the old man, Sakimori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃的母亲——防人老人称之为“文歌”的女性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃的母親——防人老人稱之為「文歌」的女性。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00267",
		linknext = "0116_00269",
		line = 3892,
	},
	["0116_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Although she passed away, she evidently never found someone she honestly wanted to devote herself to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是已故之人了，但她为什么没找到真心想服侍的人呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是已故之人了，但她為什麼沒找到真心想服侍的人呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00268",
		linknext = "0116_00270",
		line = 3902,
	},
	["0116_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't bring myself to ask about her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……我应该不能问这种问题吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……我應該不能問這種問題吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00269",
		linknext = "0116_00271",
		line = 3912,
	},
	["0116_00271"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You must respect your mother a lot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你很尊敬妈妈呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你很尊敬媽媽呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00270",
		linknext = "0116_00272",
		line = 3924,
	},
	["0116_00272"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00107", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0873", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes... She was quite terribly kind. Never harbored hatred for anyone. She was such a gentle mother...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……她非常温柔……谁都不恨……真的是个温柔的母亲……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……她非常溫柔……誰都不恨……真的是個溫柔的母親……」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00271",
		linknext = "0116_00273",
		line = 3939,
	},
	["0116_00273"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0874", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This kimono... It is the lone memento she left for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这件和服——是母亲唯一的遗物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這件和服——是母親唯一的遺物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00272",
		linknext = "0116_00274",
		line = 3954,
	},
	["0116_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino has a wistfulness and tenderness in her voice when speaking about her mother.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然说起母亲的文乃，能露出如此温柔的表情，",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然說起母親的文乃，能露出如此溫柔的表情，",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00273",
		linknext = "0116_00275",
		line = 3964,
	},
	["0116_00275"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must have been a truly kind woman.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那她一定真的是个很温柔的人吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那她一定真的是個很溫柔的人吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00274",
		linknext = "0116_00276",
		line = 3974,
	},
	["0116_00276"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“By the way, what kind of person is your father?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“顺便问一下……你父亲是什么样的人呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「順便問一下……你父親是什麼樣的人呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00275",
		linknext = "0116_00277",
		line = 3987,
	},
	["0116_00277"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0876", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Worthless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“没用的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「沒用的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00276",
		linknext = "0116_00278",
		line = 4002,
	},
	["0116_00278"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00277",
		linknext = "0116_00279",
		line = 4014,
	},
	["0116_00279"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00128", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0877", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“A worthless human being. No mistaking it. Yes, I am sure of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“他是个没用的人。一定是这样没错。嗯，一定是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「他是個沒用的人。一定是這樣沒錯。嗯，一定是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00278",
		linknext = "0116_00280",
		line = 4028,
	},
	["0116_00280"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Whoa... That sure came out quick...",
					{"rt2"},
				},
			},
			cn = {
				{
					"少见地立刻断定了……",
					{"rt2"},
				},
			},
			tw = {
				{
					"少見地立刻斷定了……",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00279",
		linknext = "0116_00281",
		line = 4038,
	},
	["0116_00281"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, given he caused her mother undue suffering, it's only natural she wouldn't think highly of him, I suppose.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过对于让自己的母亲落入不幸的人，确实不太可能有什么好印象……",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過對於讓自己的母親落入不幸的人，確實不太可能有什麼好印象……",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00280",
		linknext = "0116_00282",
		line = 4048,
	},
	["0116_00282"] = {
		{"bgm", file="bgm23", vol=100},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0878", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Mother took good care of me in my father's stead. That's why I believe in my mother's words.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“就算爸爸不在……妈妈也对我很好……所以我相信妈妈的嘱咐……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「就算爸爸不在……媽媽也對我很好……所以我相信媽媽的囑咐……」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00281",
		linknext = "0116_00283",
		line = 4064,
	},
	["0116_00283"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00121", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0879", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“So it is an honor for me to devote myself to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“因此——能对您尽心尽力，是琴寄文乃的光荣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「因此——能對您盡心盡力，是琴寄文乃的光榮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00282",
		linknext = "0116_00284",
		line = 4080,
	},
	["0116_00284"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hands me something.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃悄悄递了某个东西给我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃悄悄遞了某個東西給我。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00283",
		linknext = "0116_00285",
		line = 4090,
	},
	["0116_00285"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is this a wristband?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是——腕带吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是——腕帶嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00284",
		linknext = "0116_00286",
		line = 4102,
	},
	["0116_00286"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0880", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You mentioned you had an issue with sweating... so I made this rather simple one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“因为您说过流汗的事……我试着做了一下，虽然不是什么大工程……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「因為您說過流汗的事……我試著做了一下，雖然不是什麼大工程……」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00285",
		linknext = "0116_00287",
		line = 4116,
	},
	["0116_00287"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's been scrupulously constructed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"制作得非常精细。",
					{"rt2"},
				},
			},
			tw = {
				{
					"製作得非常精細。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00286",
		linknext = "0116_00288",
		line = 4126,
	},
	["0116_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What's more, it's double-layered and it will absorb sweat well, so doesn't look like it'll stop working.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且是双层构造，能很好地吸收汗，也不太会轻易脱落。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且是雙層構造，能很好地吸汗，也不太會輕易脫落。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00287",
		linknext = "0116_00289",
		line = 4136,
	},
	["0116_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She probably tried making it numerous times over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概试作了好几次吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概試作了好幾次吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00288",
		linknext = "0116_00290",
		line = 4146,
	},
	["0116_00290"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can tell how painstakingly carefully she made it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可以看出是非常用心的成品。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可以看出是非常用心的成品。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00289",
		linknext = "0116_00291",
		line = 4156,
	},
	["0116_00291"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It conveys well just how much she was thinking of the person she was going to give it to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可以看出，对想要赠与的人的心意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可以看出，對想要贈與的人的心意。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00290",
		linknext = "0116_00292",
		line = 4166,
	},
	["0116_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's what she was concentrating on all that time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃集中精力了那么长的时间，就是为了做这个——",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃集中精力了那麼長的時間，就是為了做這個——",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00291",
		linknext = "0116_00293",
		line = 4176,
	},
	["0116_00293"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00112", file2="fumino_02m_00203", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0881", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It's a little unshapely, but... will you accept it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“虽然有点不好看……但您能收下吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「雖然有點不好看……但您能收下嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00292",
		linknext = "0116_00294",
		line = 4191,
	},
	["0116_00294"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course I will. I'll never take it off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是当然。我会无时无刻佩戴的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是當然。我會無時無刻佩戴的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00293",
		linknext = "0116_00295",
		line = 4203,
	},
	["0116_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Surely that's not just what her mother taught her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一定不仅仅是母亲的教诲。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一定不僅僅是母親的教誨。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00294",
		linknext = "0116_00296",
		line = 4213,
	},
	["0116_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must really trust me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而是真的很信任我吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"而是真的很信任我吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00295",
		linknext = "0116_00297",
		line = 4223,
	},
	["0116_00297"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thank you so much, Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真的谢谢你了，文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真的謝謝你了，文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00296",
		linknext = "0116_00298",
		line = 4236,
	},
	["0116_00298"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yeah, that's right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"嗯——是啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"嗯——是啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00297",
		linknext = "0116_00299",
		line = 4246,
	},
	["0116_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There was nothing for me to worry about in the first place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从一开始就没什么好烦恼的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從一開始就沒什麼好煩惱的。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00298",
		linknext = "0116_00300",
		line = 4256,
	},
	["0116_00300"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It has nothing to do with the student council president, the SS, Senator Hitoura, nor the OSS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长、SS、仁浦先生和SHO都没有关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長、SS、仁浦先生和SHO都沒有關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00299",
		linknext = "0116_00301",
		line = 4266,
	},
	["0116_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter what anyone tells me, there's no need to bend my convictions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论听到什么，我都没有必要动摇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論聽到什麼，我都沒有必要動搖。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00300",
		linknext = "0116_00302",
		line = 4276,
	},
	["0116_00302"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just want to make this girl happy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我只是希望这孩子能幸福。",
					{"rt2"},
				},
			},
