		line = 2655,
	},
	["0116_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hers is a mature face befitting her age, unlike Fumino's.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与文乃不同，那是一张与年龄不相称的成熟面孔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與文乃不同，那是一張與年齡不相稱的成熟面孔。",
