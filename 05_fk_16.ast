	["0116_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Almost four hours had passed that I mostly have no recollection of, as I fell asleep before I knew it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想知道她什么时候会发现，但在超过4个小时之后就没有记忆了。我不知不觉睡着了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想知道她什麼時候會發現，但在超過4個小時之後就沒有記憶了。我不知不覺睡著了。",
					{"rt2"},
				},
