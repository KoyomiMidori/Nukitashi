					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“She didn't even notice us, did she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……大家都站成一排了，她也完全没有注意到呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……大家都站成一排了，她也完全沒有注意到呢。」",
					{"rt2"},
