		{"fg", file="touka_01l_00001", file1="touka_01l_00113", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0785", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And that is why I want to find out the reason, so very badly... Ah, this unyielding yearning to know could drive a girl mad...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以，我很想知道那是什么……非常非常……啊啊，想到都快不正常了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以，我很想知道那是什麼……非常非常……啊啊，想到都快不正常了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00181",
		linknext = "0116_00183",
		line = 2645,
	},
	["0116_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
