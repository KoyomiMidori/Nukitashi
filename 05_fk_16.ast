					name = {"淳之介", "Junnosuke"},
					"“Well, obviously it's my complete and utter virginfaggotry and obsession with purity that—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事，肯定是我的洁癖处女厨魂让我这么说的——”",
