			},
		},
		linkback = "0116_00190",
		linknext = "0116_00192",
		line = 2751,
	},
	["0116_00192"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just answer me this. Why are you buying time for me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——为什么。为什么要给我时间？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——為什麼。為什麼要給我時間？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00191",
		linknext = "0116_00193",
		line = 2763,
	},
	["0116_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Surely you must know that you'll lose the upper hand by doing this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你应该明白吧……即使那样做，也只会拉低你的优势。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你應該明白吧……即使那樣做，也只會拉低你的優勢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00192",
		linknext = "0116_00194",
		line = 2775,
	},
	["0116_00194"] = {
