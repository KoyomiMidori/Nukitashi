		linkback = "0116_00077",
		linknext = "0116_00079",
		line = 1267,
	},
	["0116_00079"] = {
		{"bgm", file="bgm11", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“'FOUR DAYS FROM TODAY, COME TO OSS HQ AT 2012 HOURS. ARRIVING BY SEA. MAKE SURE SEA GATE IS OPEN'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天起四天后，二〇：一二之时刻，前来SHO总部大楼。将在海上迎接。切记，解放海门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天起四天後，二〇：一二之時刻，前來SHO總部大樓。將在海上迎接。切記，解放海門。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00078",
		linknext = "0116_00080",
		line = 1280,
	},
	["0116_00080"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Looks like these are our directions from Sakimori... Make sure the sea gate is open, it says.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是防人老人的命令吗？解放海门——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是防人老人的命令嗎？解放海門——」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00079",
		linknext = "0116_00081",
		line = 1292,
	},
	["0116_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You can only get into the island via the OSS HQ, since they control the sea gate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛的唯一入口，有着SHO总部管理的海门。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島的唯一入口，有著SHO總部管理的海門。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00080",
		linknext = "0116_00082",
		line = 1302,
	},
	["0116_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If a small boat were to come here, it would have to be opened.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果引渡的小船要来，就有必要打开它。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果引渡的小船要來，就有必要打開它。",
					{"rt2"},
