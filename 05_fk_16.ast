	},
	["0116_00167"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0779", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“With your enormous phallus, you could get most women to do your bidding, including those in the SS. So why don't you use that power?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“只要你使用你那巨大的男根，包括FS在内的大部分女人应该都会唯命是从。既然如此，为什么还不使用那种力量呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「只要你使用你那巨大的男根，包括FS在內的大部分女人應該都會唯命是從。既然如此，為什麼還不使用那種力量呢？」",
					{"rt2"},
				},
			},
