	},
	["0116_00083"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So he's basically saying that we have to infiltrate the OSS building, and take over the control room...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，有必要潜入SHO总部大楼，完全压制住控制室吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，有必要潛入SHO總部大樓，完全壓制住控制室嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00082",
		linknext = "0116_00084",
		line = 1326,
	},
	["0116_00084"] = {
