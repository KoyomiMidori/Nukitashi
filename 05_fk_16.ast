				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Here is dessert as well. Nanase helped me with ingredients, so I was able to make all sorts of traditional sweets.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“也请用点心……我从奈奈濑同学那里拿到了材料……所以就试着制作了和式点心……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「也請用點心……我從奈奈瀨同學那裡拿到了材料……所以就試著製作了和式點心……」",
					{"rt2"},
				},
