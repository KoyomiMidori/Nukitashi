	["0116_00189"] = {
		{"fg", file="touka_01l_00001", file1="touka_01l_00111", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0786", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe. I'll give you a little more time to think about it. Will you come back to our side, for Fumino's safety?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵……我再给你一点考虑的时间。为了文乃同学的安全，前辈会不会回到我身边呢——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵……我再給你一點考慮的時間。為了文乃同學的安全，前輩會不會回到我身邊呢——」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00188",
		linknext = "0116_00190",
		line = 2722,
	},
	["0116_00190"] = {
