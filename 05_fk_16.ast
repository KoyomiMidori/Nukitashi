		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="ncg06_l_00001", x=0, y=0, path=":cg/ncg06_l/", ev=1, lv=5, ax=1290, ay=730, bx=-490, by=-280},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"bgm", file="bgm09.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0768", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe, don't be so tense. Make yourself at home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，不用那么紧张……可以把这里当成自己家一样放松哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，不用那麼緊張……可以把這裡當成自己家一樣放鬆哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00132",
		linknext = "0116_00134",
		line = 2073,
	},
	["0116_00134"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like hell I will. I'm in enemy territory right now. The goddamn lion's den.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我怎么可能做得到——毕竟，这里可是敌人的根据地。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我怎麼可能做得到——畢竟，這裡可是敵人的根據地。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00133",
		linknext = "0116_00135",
		line = 2086,
	},
	["0116_00135"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0769", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And also a former haunt of yours. You were with the SS for some time, were you not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“同时，这也是你的老家。你不也曾经隶属于FS吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「同時，這也是你的老家。你不也曾經隸屬於FS嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00134",
		linknext = "0116_00136",
		line = 2098,
	},
	["0116_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gets me where it hurts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被说到痛处了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被說到痛處了。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00135",
		linknext = "0116_00137",
		line = 2108,
	},
	["0116_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's definitely a weight on my conscience.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对我而言，这是我的弱点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對我而言，這是我的弱點。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00136",
		linknext = "0116_00138",
		line = 2118,
	},
	["0116_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Both the disciplinary committee president and the first squad commander were good to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长也好，一队队长也好，大家都对我很好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員長也好，一隊隊長也好，大家都對我很好。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00137",
		linknext = "0116_00139",
		line = 2128,
	},
	["0116_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And honestly, I'm grateful to them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然也有感谢的心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然也有感謝的心情。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00138",
		linknext = "0116_00140",
		line = 2138,
	},
	["0116_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But that doesn't change the fact that they're my enemies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——即便如此，她们果然还是我们的敌人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——即便如此，她們果然還是我們的敵人。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00139",
		linknext = "0116_00141",
		line = 2148,
	},
	["0116_00141"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0770", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Do not worry. I have not yet informed the OSS about Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“请放心，关于文乃同学的事情，SHO好像还没有发现。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「請放心，關於文乃同學的事情，SHO好像還沒有發現。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00140",
		linknext = "0116_00142",
		line = 2160,
	},
	["0116_00142"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You mean... that she comes to this school?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是指……在这个学校上学的事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是指……在這個學校上學的事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00141",
		linknext = "0116_00143",
		line = 2172,
	},
	["0116_00143"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0771", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. I'm the only one who knows. I haven't told anyone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的。毕竟只有我知道——我也没有报告。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的。畢竟只有我知道——我也沒有報告。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00142",
		linknext = "0116_00144",
		line = 2184,
	},
	["0116_00144"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you're being disloyal to the OSS... Why the hell would the SS have a Judas running the show?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这对SHO来说是背信弃义的行为。表里不一的家伙为什么会站在FS的顶端……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這對SHO來說是背信棄義的行為。表裡不一的傢伙為什麼會站在FS的頂端……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00143",
		linknext = "0116_00145",
		line = 2196,
	},
	["0116_00145"] = {
		{"text"},
		text = {
