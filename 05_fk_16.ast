				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Secret... I guess, if you enjoy it... then anyone can do this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“诀窍，嗯……对了，只要觉得快乐……一定谁都能办到的……”",
					{"rt2"},
				},
			},
			tw = {
