					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You say that, but you still give him the space to think, don't you? You're really kind to your bro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话是这么说，但他每次思考的时候你都让他一个人待着，麻沙酱对哥哥真是温柔呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話是這麼說，但他每次思考的時候你都讓他一個人待著，麻沙醬對哥哥真是溫柔呢。」",
					{"rt2"},
				},
			},
		},
