					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wha— That's the famous finishing move commonly heard in all fine R-18 binaural audios! The blow in the ear! They're kind of a polarizing thing, but personally I'm all for them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那、那是……！在R-18立体声道声音作品中看到的终结吹耳朵〜！？虽然赞成和反对意见各不相同，但我是属于赞成派……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那、那是……！在R-18立體聲道聲音作品中看到的終結吹耳朵〜！？雖然贊成和反對意見各不相同，但我是屬於贊成派……！」",
