		},
		linkback = "0116_00162",
		linknext = "0116_00164",
		line = 2407,
	},
	["0116_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She asks with almost genuine bafflement.",
					{"rt2"},
				},
			},
			cn = {
				{
