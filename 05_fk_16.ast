				},
			},
		},
		linkback = "0116_00163",
		linknext = "0116_00165",
		line = 2417,
	},
	["0116_00165"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0778", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Through the power of your junk, escape, or attacking if necessary, would be a cinch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果有你的鸡巴的力量，不管是逃跑还是攻击，应该都易如反掌。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「如果有你的肉棒的力量，不管是逃跑還是攻擊，應該都易如反掌。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00164",
		linknext = "0116_00166",
		line = 2429,
	},
	["0116_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
