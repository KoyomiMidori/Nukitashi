				{"vo", file="touka0772", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As I've told you already, I could not possibly care less about the OSS, the SS, or the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我之前也说了，这对我来说是无所谓的事情。OSS，SS，还有变态条例也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我之前也說了，這對我來說是無所謂的事情。OSS，SS，還有變態條例也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00144",
		linknext = "0116_00146",
		line = 2208,
	},
	["0116_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her icy grin betrays no hint of lying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她凉爽的笑容里不带虚假。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她涼爽的笑容裡不帶虛假。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00145",
		linknext = "0116_00147",
		line = 2218,
	},
	["0116_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She probably means what she says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她那对SHO不感兴趣的言论，应该也是真心的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她那對SHO不感興趣的言論，應該也是真心的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00146",
		linknext = "0116_00148",
		line = 2228,
	},
	["0116_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Especially when it comes to her interest in me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后大概，对我有兴趣的发言也是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後大概，對我有興趣的發言也是——",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00147",
		linknext = "0116_00149",
		line = 2238,
	},
	["0116_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How come you know about my junk?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——为什么，你会知道我的鸡巴的事情？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——為什麼，你會知道我的肉棒的事情？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00148",
		linknext = "0116_00150",
		line = 2250,
	},
	["0116_00150"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0773", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I am the leader of the SS, which governs this school. Not one fact about the student body escapes me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我是学校与FS的领导人。学生的事情，我怎么会不知道呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我是學校與FS的領導人。學生的事情，我怎麼會不知道呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00149",
		linknext = "0116_00151",
		line = 2262,
	},
	["0116_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's not what I'm asking. How exactly did you get that information?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不是在问那种事情。我想知道你是如何具体知道的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不是在問那種事情。我想知道你是如何具體知道的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00150",
		linknext = "0116_00152",
		line = 2274,
	},
	["0116_00152"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0774", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“By inference, and by gathering supporting evidence. Like that time Senba lost her memory and was wallowing in ecstasy. And after your little tangle with Ikuko, it was a snap to figure out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“推理，然后收集旁证。失去了记忆，然后一度沉浸在快感中的仙波小姐。还有——看了你和郁子的",
					{"ruby", text="・・"},
					"战斗",
					{"/ruby"},
					"后，自然就会明白了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「推理，然後收集旁證。失去了記憶，然後一度沉浸在快感中的仙波小姐。還有——看了你和郁子的",
					{"ruby", text="・・"},
					"戰鬥",
					{"/ruby"},
					"後，自然就會明白了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00151",
		linknext = "0116_00153",
		line = 2286,
	},
	["0116_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She saw that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"被看到了吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"被看到了嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00152",
		linknext = "0116_00154",
		line = 2296,
	},
	["0116_00154"] = {
		{"se", id=0, loop=0, file="se_a204"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I subtly bite my lip.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我悄悄咬了咬下唇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我悄悄咬了咬下唇。",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00153",
		linknext = "0116_00155",
		line = 2307,
	},
	["0116_00155"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You saw all that, and yet you didn't do anything? Some disgrace of a leader you are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看到了还没有插手，真是个不称职的领导者呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看到了還沒有插手，真是個不稱職的領導者呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00154",
		linknext = "0116_00156",
		line = 2319,
	},
	["0116_00156"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0775", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sex has never killed anyone. And I trusted Ikuko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“毕竟做爱不会死……而且我相信郁子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「畢竟做愛不會死……而且我相信郁子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00155",
		linknext = "0116_00157",
		line = 2331,
	},
	["0116_00157"] = {
		{"text"},
		text = {
