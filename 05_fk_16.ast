					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You're welcome. Um, how was the taste?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“献丑了……请问，味道怎么样……？”",
