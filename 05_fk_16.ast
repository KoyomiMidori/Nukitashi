		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm not sure if I'm surprised by the sweetness, or if the sweetness is just going to my head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……不知道是因为被意料外的甜点吓了一跳，还是糖分进入了头脑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……不知道是因為被意料外的甜點嚇了一跳，還是糖分進入了頭腦。",
