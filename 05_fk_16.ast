		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2166", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's amazing! She's purring like a pussy cat!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好厉害！发出了像小猫一样的声音……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好厲害！發出了像小貓一樣的聲音……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00044",
		linknext = "0116_00046",
		line = 746,
	},
	["0116_00046"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=3, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=300, y=0},
		{"fgact", ch="美岬", id=3, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2041", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“There are various theories as to why cats purr, but it conveys they really don't want you to leave them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“关于猫的喉咙发出声音，虽然有各种各样的说法，但似乎是在强烈表达‘请不要离开我’的意思呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「關於貓的喉嚨發出聲音，雖然有各種各樣的說法，但似乎是在強烈表達『請不要離開我』的意思呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00045",
		linknext = "0116_00047",
		line = 761,
	},
	["0116_00047"] = {
