		line = 1340,
	},
	["0116_00085"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1702", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I won't be able to jack the cams, so IFF's a no-go, and the radar won't function in a multi-story building. This is gonna be tough as shit, Bro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为无法黑进摄像头所以不能使用IFF，现在的雷达在多楼层也不起作用……很糟糕啊，哥哥……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為無法黑進攝影機所以不能使用IFF，現在的雷達在多樓層也不起作用……很糟糕啊，哥哥……」",
					{"rt2"},
