	["0116_00163"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0777", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Why don't you use 'that'?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的——前辈为什么不使用",
					{"ruby", text="・・"},
