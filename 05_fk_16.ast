	},
	["0116_00168"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=18, act="浮遊横", loop=4, size=2.5, time=50, ease="easeinout_sine", lv=5, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why d'you fuckin' think? I'm a member of the anti-copulation front! No way I could do that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那还用说——！我们可是反交尾势力哦！怎么可能做那种事情！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那還用說——！我們可是反交尾勢力哦！怎麼可能做那種事情！」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00167",
		linknext = "0116_00169",
		line = 2467,
	},
	["0116_00169"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0780", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“What you profess is an ideal, but reality will force you to compromise on that ideal. Am I mistaken?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“标榜的是理想，但应行使的是现实。不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「標榜的是理想，但應行使的是現實。不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00168",
		linknext = "0116_00170",
		line = 2479,
	},
	["0116_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I am not some fucking might-makes-right zealot!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那不过是偏激者的过激手段——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那不過是偏激者的過激手段——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00169",
		linknext = "0116_00171",
		line = 2490,
	},
	["0116_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not having sex is my principle! If I yielded on that, our organization couldn't exist!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不做爱是我的信念！扭曲了这点就没有我们组织！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不做愛是我的信念！扭曲了這點就沒有我們組織！」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00170",
		linknext = "0116_00172",
		line = 2501,
	},
	["0116_00172"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0781", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sex is merely like a handshake. Using that to communication allows one to understand themselves. I don't believe it is evil to use it for support.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“做爱，就像握手一样。我不认为通过这种交流来让别人理解自己，进而得到别人的支持是不好的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「做愛，就像握手一樣。我不認為通過這種交流來讓別人理解自己，進而得到別人的支持是不好的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00171",
		linknext = "0116_00173",
		line = 2513,
	},
	["0116_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll have you know that we're not politicians fishing for votes! We are like-minded companions with a common goal!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们不是执着票数的政治家，我们要的是志同道合的同伴！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們不是執著票數的政治家，我們要的是志同道合的同伴！」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00172",
		linknext = "0116_00174",
		line = 2524,
	},
	["0116_00174"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And having sex with all those non-virgins I despise isn't necessary to achieve that goal!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以没有必要为此和最讨厌的非处女做爱——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以沒有必要為此和最討厭的非處女做愛——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00173",
		linknext = "0116_00175",
		line = 2536,
	},
	["0116_00175"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0782", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Why do you hate non-virgins so much?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈为什么那么讨厌非处女呢？”",
