			},
			ja = {
				{
					name = {"非表示", "桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Touka"},
					"“I'll let you consider my request, so please mull it over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "桐香"},
					"“深思熟虑之后，再决定是否接受我的请求吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "桐香"},
					"「深思熟慮之後，再決定是否接受我的請求吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0116_00189",
		linknext = "0116_00191",
		line = 2741,
	},
	["0116_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She abruptly returns to where she was standing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回过神时，学生会长已经又回到了原位。",
