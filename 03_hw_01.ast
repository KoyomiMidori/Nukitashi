				{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0624", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿AHHHHH?! Ah, Misaki-chan... ¡Me asustes! ¿Cuándo llegaste?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哎呀！？美、美岬酱……吓我一跳。从什么时候开始在的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哎呀！？美、美岬醬……嚇我一跳。從什麼時候開始在的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00018",
		linknext = "0051_00020",
		line = 275,
	},
	["0051_00020"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0365", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Fui la primera en llegar... ¿Eh? ¿No dijiste que ya estábamos todos aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我是第一个来的……诶？我最一开始不是有说大家都到齐了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我是第一個來的……欸？我最一開始不是有說大家都到齊了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00019",
		linknext = "0051_00021",
		line = 289,
	},
	["0051_00021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Si te sirve de algo, yo sí te vi.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我有好好注意到你哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我有好好注意到你哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00020",
		linknext = "0051_00022",
		line = 301,
	},
	["0051_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En realidad no la vi sino hasta ahorita... pero mejor me callo y no quedo como el malo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其实一直到刚刚都没察觉……还是保持沉默吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其實一直到剛剛都沒察覺……還是保持沉默吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00021",
		linknext = "0051_00023",
		line = 311,
	},
	["0051_00023"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0625", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uuugh... pero Misaki-chan también hizo algo... ¡como ir a toda velocidad con su bicicleta para despejar el camino! Fui la única que se quedó sin hacer nada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……不过美岬也很努力呢……骑着自行车把大家都引走……果然只有我什么都没做到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……不過美岬也很努力呢……騎著自行車把大家都引走……果然只有我什麼都沒做到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00022",
		linknext = "0051_00024",
		line = 325,
	},
	["0051_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tú también hiciste algo, Wata-chan. Golpeaste a alguien de la SS con tu silla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱也努力了啊。用钢管椅子打倒FS之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬也努力了啊。用鋼管椅打倒FS之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00023",
		linknext = "0051_00025",
		line = 337,
	},
	["0051_00025"] = {
