					name = {"淳之介", "Junnosuke"},
					"“What you call coincidence is really just an unconscious instinct. And that, Wata-chan-senpai, is proof that you've got it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“偶然……也就是无意识中做出的事——这就是前辈‘有点东西’的证据。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「偶然……也就是無意識中做出的事——這就是前輩『有點東西』的證據。」",
