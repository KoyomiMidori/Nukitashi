			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“El sexo romántico es muy lindo... Leo esos mangas y siempre pienso que me encantaría tener esa clase de sexo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“有爱情的做爱真棒……看了少女漫画后，我也会想体验一下这种美妙的做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「有愛情的做愛真棒……看了少女漫畫後，我也會想體驗一下這種美妙的做愛。」",
					{"rt2"},
				},
