			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Esto... ¿Qué quieres decirme...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃……怎么说呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃……怎麼說呢……？」",
					{"rt2"},
				},
