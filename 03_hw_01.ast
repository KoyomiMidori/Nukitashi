	["0051_00110"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0647", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tachibana-kun! Ese anciano dijo que Fumino es mayor que yo, ¿verdad?! ¡¿VERDAD?!”",
					{"rt2"},
				},
			},
			cn = {
				{
