					"“橘君！那个爷爷说文乃比我年长对吧！？是不是，说过吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君！那個爺爺說文乃比我年長對吧！？是不是，說過吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00109",
		linknext = "0051_00111",
		line = 1500,
	},
	["0051_00111"] = {
