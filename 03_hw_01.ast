		{"fg", file="nanase_02f_00001", file1="nanase_02f_00104", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
