				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't think anyone short of a master in the art of chair wielding could take down an opponent just by chance.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一般来说，要用椅子打倒别人，不是高手的话是不可能做到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一般來說，要用椅子打倒別人，不是高手的話是不可能做到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00033",
		linknext = "0051_00035",
		line = 470,
	},
	["0051_00035"] = {
