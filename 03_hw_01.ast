	["0051_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Un líder no debe permitir que la moral de uno de sus miembros decaiga así. ¡Tengo que animarla para alcanzar la victoria...!",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为队长，不能放任士气下降。来鼓舞一下她——",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為隊長，不能放任士氣下降。來鼓舞一下她——",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00029",
		linknext = "0051_00031",
		line = 420,
	},
	["0051_00031"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Wata-chan-senpai! Dijiste que golpeaste a esa chica del SS por accidente, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱前辈。刚才，你说用椅子打倒FS是偶然……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬前輩。剛才，你說用椅子打倒FS是偶然……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00030",
