	["0051_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es cierto que se ve bastante deprimida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，她似乎真的一蹶不振了。",
