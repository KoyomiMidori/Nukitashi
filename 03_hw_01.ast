	["0051_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase tenía que ocuparse de algunos asuntos familiares y Hotori llegó mucho antes que nosotros porque tiene su bici.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑好象有家务事，畔也骑脚踏车回去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨好像家裡有事，畔也騎腳踏車回去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00103",
		linknext = "0051_00105",
		line = 1432,
	},
	["0051_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me preocupan un poco los buscadores de sexo, pero se la han arreglado solas durante años y hemos enfrentado problemas más graves. Sé que estarán bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然担心性触者，但是几年来她们两人一直都在躲避性行为，还克服了击坠王。应该不用担心吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然擔心性觸者，但是幾年來她們兩人一直都在躲避性行為，還克服了擊墜王。應該不用擔心吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00104",
		linknext = "0051_00106",
		line = 1442,
	},
	["0051_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan y Wata-chan me están siguiendo. Aunque...",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此，我和麻沙酱和渡酱三个人踏上了归途……",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此，我和麻沙醬和渡醬三個人踏上了歸途……",
					{"rt2"},
				},
			},
		},
