					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱前辈也看少女漫画之类的啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬前輩也看少女漫畫之類的啊。」",
					{"rt2"},
