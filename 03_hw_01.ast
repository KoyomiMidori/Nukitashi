			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Solo nos dijo que buscáramos a una chica llamada Kotoyose Fumino, lo cual no nos sirve de mucho...”",
					{"rt2"},
				},
			},
			cn = {
