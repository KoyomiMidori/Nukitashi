			},
		},
		text = {
			vo = {
				{"vo", file="hinami0656", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero no soy una ni—! N-No me voy a preocupar... ¡No me voy a preocupar! Soy una adulta...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不是小孩子——不在意……我可不在意哦？因为是姐姐嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不是小孩子——不在意……我可不在意哦？因為是姐姐嘛……」",
					{"rt2"},
				},
