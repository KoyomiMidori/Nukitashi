	["0051_00016"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=7.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0622", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Of course I do! Asane-chan's spouting sciency mumbo-jumbo all day, and Nanase-chan's throwing eggs around, looking all cool and stuff...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“有啊！麻沙音会说很多难懂的话，奈奈濑狂扔类似鸡蛋的东西实在是太帅了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「有啊！麻沙音會說很多難懂的話，奈奈瀨狂扔類似雞蛋的東西實在是太帥了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00015",
		linknext = "0051_00017",
		line = 211,
	},
	["0051_00017"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00116", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0623", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun took down a pretty tough SS lady, didn't you? I'm the only one that does nothing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君还把SS厉害的人打倒了吧？只有我什么都没做到……”",
