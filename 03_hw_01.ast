	["0051_00112"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0648", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero cuando le preguntaste su edad, resultó que es como tres años menor que yo! ¡¿Qué significa eso?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是！问实际年龄的时候！文乃又比我小三岁！这是什么意思！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是！問實際年齡的時候！文乃又比我小三歲！這是什麼意思！？」",
					{"rt2"},
				},
			},
		},
