			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……是這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00151",
		linknext = "0051_00153",
		line = 2085,
	},
	["0051_00153"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, a mí también me da vergüenza. Nanase es una puta, así que es un caso aparto, pero me imagino que Hotori sentiría lo mismo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，就算是我也会害羞……虽然奈奈濑是婊子所以不太清楚，不过畔一定也会吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，就算是我也會害羞……雖然奈奈瀨是婊子所以不太清楚，不過畔一定也會吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00152",
		linknext = "0051_00154",
		line = 2097,
	},
	["0051_00154"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0665", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo... ¡Tenemos más en común de lo que pensaba! Menos mal...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊……原来大家都是一样的！太好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊……原來大家都是一樣的！太好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00153",
		linknext = "0051_00155",
		line = 2111,
	},
	["0051_00155"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a053"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El hecho de que Wata-chan creciera con esa mentalidad a pesar de vivir en esta isla probablemente se deba a que el manga la ayudó.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛长大的渡酱能有这样的感性，或许是受到漫画的影响吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島長大的渡醬能有這樣的感性，或許是受到漫畫的影響吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00154",
		linknext = "0051_00156",
		line = 2124,
	},
	["0051_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso una chica inocente como ella quiere tener sexo con amor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是这样天真无邪的女孩子，也会说想要做爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是這樣天真無邪的女孩子，也會說想要做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00155",
		linknext = "0051_00157",
		line = 2134,
	},
	["0051_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cualquier ley que nos obligue a tener relaciones sexuales sin amor es una injusticia. Tenemos que destruirla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然允许没有爱的性爱的条例是错误的……无论如何都必须破坏掉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然允許沒有愛的性愛的條例是錯誤的……無論如何都必須破壞掉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00156",
		linknext = "0051_00158",
		line = 2146,
	},
	["0051_00158"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0666", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Si encontramos a Fumino, podremos darle la vuelta a la ley, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“只要有那个叫文乃酱的孩子在，就可以推翻条例对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「只要有那個叫文乃醬的孩子在，就可以推翻條例對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00157",
		linknext = "0051_00159",
		line = 2160,
	},
	["0051_00159"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Se supone que sí. Ahora que sabemos cuántos años tiene, podremos empezar con esta búsqueda mañana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是这么一回事，‘文乃’的年龄也已经知道了，我们明天就去搜查吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是這麼一回事，『文乃』的年齡也已經知道了，我們明天就去搜查吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00158",
		linknext = "0051_00160",
		line = 2172,
	},
	["0051_00160"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=450, ease="easeinout_sine", delay2=4000},
			},
			[6500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0667", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Si es tres años menor que yo... Uno, dos... Sería una estudiante de tercero en los grados de nivel B, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……比我小三岁的话……一、二……大概是B等部的3年级生吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……比我小三歲的話……一、二……大概是B等部的3年級生吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00159",
		linknext = "0051_00161",
		line = 2189,
	},
	["0051_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Los niveles B tienen su propia sección en la escuela. Deberíamos buscarla durante el día.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“B等部的话，就在同一所学校里——白天也可以去找吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「B等部的話，就在同一所學校裡——白天也可以去找吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00160",
		linknext = "0051_00162",
		line = 2201,
	},
	["0051_00162"] = {
