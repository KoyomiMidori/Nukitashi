		{"fg", file="nanase_02f_00001", file1="nanase_02f_00104", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1827", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sobre nuestro próximo plan... ¿No creen que ya es hora de que atendamos la petición de nuestro patrocinador?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以，关于今后的方针……差不多要完成出资者的要求了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以，關於今後的方針……差不多要完成出資者的要求了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00060",
		linknext = "0051_00062",
		line = 856,
	},
	["0051_00062"] = {
