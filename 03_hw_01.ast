		line = 2097,
	},
	["0051_00154"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0665", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see... We've got more in common than I thought! Thank goodness...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊……原来大家都是一样的！太好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊……原來大家都是一樣的！太好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00153",
		linknext = "0051_00155",
		line = 2111,
	},
	["0051_00155"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a053"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The fact Wata-chan grew up with those sensibilities despite living on this island must mean that manga influenced her in a big way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛长大的渡酱能有这样的感性，或许是受到漫画的影响吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島長大的渡醬能有這樣的感性，或許是受到漫畫的影響吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00154",
		linknext = "0051_00156",
		line = 2124,
	},
	["0051_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even an innocent girl like her is saying that she wishes for sex with love.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是这样天真无邪的女孩子，也会说想要做爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是這樣天真無邪的女孩子，也會說想要做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00155",
		linknext = "0051_00157",
		line = 2134,
	},
	["0051_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Any law that makes sex without love mandatory is definitely unjust. We have to bring it down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然允许没有爱的性爱的条例是错误的……无论如何都必须破坏掉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然允許沒有愛的性愛的條例是錯誤的……無論如何都必須破壞掉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00156",
		linknext = "0051_00158",
		line = 2146,
	},
	["0051_00158"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0666", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“If we find this Fumino-chan girl, we can turn the law around, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“只要有那个叫文乃酱的孩子在，就可以推翻条例对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「只要有那個叫文乃醬的孩子在，就可以推翻條例對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00157",
		linknext = "0051_00159",
		line = 2160,
	},
	["0051_00159"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's the deal. Now that we know how old she is, the search can start in earnest tomorrow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是这么一回事，‘文乃’的年龄也已经知道了，我们明天就去搜查吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是這麼一回事，『文乃』的年齡也已經知道了，我們明天就去搜查吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00158",
		linknext = "0051_00160",
		line = 2172,
	},
	["0051_00160"] = {
