					"“Aun así, te agradecemos que nos hayas ayudado a descubrir la edad de Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，能知道‘文乃’的年龄都是托了渡酱的福。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，能知道『文乃』的年齡都是託了渡醬的福。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00119",
		linknext = "0051_00121",
		line = 1626,
	},
	["0051_00121"] = {
		{"bgm", file="bgm02", vol=100},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0651", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh...? ¿D-De verdad? ¿No lo logramos porque eres bueno hablando?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……？是吗？那不是因为橘君努力了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……？是嗎？那不是因為橘君努力了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00120",
		linknext = "0051_00122",
		line = 1641,
	},
	["0051_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No. Estoy seguro de que decidió contárnoslo al ver la sinceridad en tus ojos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不。那个人一定也是被渡酱笔直的目光打动了才告诉我们的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不。那個人一定也是被渡醬筆直的目光打動了才告訴我們的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00121",
		linknext = "0051_00123",
		line = 1653,
	},
	["0051_00123"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0652", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, mi abuelo siempre dice que cuando me mira a los ojos le dan ganas de hablar de cualquier cosa. ¿Será por eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……这么说来，我的爷爷也常说看到雏见就会忍不住什么都想说呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……這麼說來，我的爺爺也常說看到雛見就會忍不住什麼都想說呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00122",
		linknext = "0051_00124",
		line = 1667,
	},
	["0051_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estoy seguro de que ven el amor de una madre en tus ojos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然……那一定是渡酱所拥有的母性使然。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然……那一定是渡醬所擁有的母性使然。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00123",
		linknext = "0051_00125",
		line = 1679,
	},
	["0051_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cuando un hombre habla con una mujer que percibe como una mujer adulta, sentirá muchas ganas de desahogarse con ella.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所谓的男人……是什么都想对大姐姐说的生物……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所謂的男人……是什麼都想對大姐姐說的生物……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00124",
		linknext = "0051_00126",
		line = 1691,
	},
	["0051_00126"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[2200] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=2200, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0653", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Una mujer adulta...! Sí, sí, lo entiendo. ¡Ese viejo de la tele también me vio como una adulta, ¿verdad?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“大姐姐……！是这样啊……原来如此。那么，电视里的爷爷也把我当作大姐姐看待呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「大姐姐……！是這樣啊……原來如此。那麼，電視裡的爺爺也把我當作大姐姐看待呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00125",
		linknext = "0051_00127",
		line = 1707,
	},
	["0051_00127"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0654", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? Pero si dijo que Fumino era mayor que yo, ¿qué quería decir con eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦？可是他又说文乃比我年长，这是怎么回事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦？可是他又說文乃比我年長，這是怎麼回事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00126",
		linknext = "0051_00128",
		line = 1721,
	},
	["0051_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um, pues...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个……怎么说呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個……怎麼說呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00127",
		linknext = "0051_00129",
		line = 1733,
	},
	["0051_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No creo que debas darles tantas vueltas a cosas insignificantes. Se supone que una mujer adulta debe mostrar un carácter indulgente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不用在意那样的细节吧？大姐姐的肚量不是很大吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不用在意那樣的細節吧？大姐姐的肚量不是很大嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00128",
		linknext = "0051_00130",
		line = 1745,
	},
	["0051_00130"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
