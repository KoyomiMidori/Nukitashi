		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0657", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Gracias por acompañarme. Mi casa está un poquito lejos...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“谢谢你，橘君，我家很远，你还特意送我回家……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「謝謝你，橘君，我家很遠，你還特意送我回家……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00133",
		linknext = "0051_00135",
		line = 1854,
	},
	["0051_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tras dejar a Asa-chan en casa, nos quedamos caminando bajo el resplandor anaranjado del atardecer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把麻沙酱送到家后，我和渡酱走在傍晚的路上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把麻沙醬送到家後，我和渡醬走在傍晚的路上。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00134",
		linknext = "0051_00136",
		line = 1864,
	},
	["0051_00136"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No te preocupes, lo hago porque me gusta. No quiero que te pase algo malo otra vez.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，只是我想这么做而已。如果再发生以前那种事，我会很担心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，只是我想這麼做而已。如果再發生以前那種事，我會很擔心的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00135",
		linknext = "0051_00137",
		line = 1876,
	},
	["0051_00137"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00115", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0658", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm... Me siento un poco mal por hacerle hacer esto a mi kouhai, pero... ¡Jejeje, que un chico me acompañe a casa me hace sentir como si estuviera en un manga shoujo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……作为前辈我有点不好意思……唉，让男孩送我回家就像少女漫画一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……作為前輩我有點不好意思……唉，讓男孩送我回家就像少女漫畫一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00136",
		linknext = "0051_00138",
		line = 1891,
	},
	["0051_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Te gustan esas cosas, Wata-chan-senpai?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱前辈也看少女漫画之类的啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬前輩也看少女漫畫之類的啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00137",
		linknext = "0051_00139",
		line = 1903,
	},
	["0051_00139"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0659", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Sí, me encantan! Las cosas románticas son muy buenas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，很喜欢！很浪漫……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，很喜歡！很浪漫……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00138",
		linknext = "0051_00140",
		line = 1918,
	},
	["0051_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por cierto, los mangas que lees... ¿son extremos? Como estamos en la Isla Seiran, siempre me pregunto si sus mangas tienen a los personajes follando como locos con cualquiera.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“顺便问一下……那是青蓝岛设定中和谁都可以随意做爱的内容吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「順便問一下……那是青藍島設定中和誰都可以隨意做愛的內容嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00139",
		linknext = "0051_00141",
		line = 1930,
	},
	["0051_00141"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0660", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? No, he leído algunos en los que hay sexo... pero los personajes lo hacen porque se aman.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？不，虽然我也读过做爱的场景，不过……大家都只做有爱的性爱哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？不，雖然我也讀過做愛的場景，不過……大家都只做有愛的性愛哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00140",
		linknext = "0051_00142",
		line = 1944,
	},
	["0051_00142"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya veo... Conque sí venden mangas auténticos en esta isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是哦……青蓝岛也有那么正规的少女漫画啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是哦……青藍島也有那麼正規的少女漫畫啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00141",
		linknext = "0051_00143",
		line = 1956,
	},
	["0051_00143"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0661", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“También tengo amigos que son muy aficionados a los mangas del continente, así que me los piden prestados. Por eso entiendo todo lo que dices.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我有个喜欢本岛漫画的朋友，经常借给我看。所以橘君说的话我很明白哦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我有個喜歡本島漫畫的朋友，經常借給我看。所以橘君說的話我很明白哦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00142",
		linknext = "0051_00144",
		line = 1970,
	},
	["0051_00144"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
