		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me refiero a que tienes lo necesario para ser alguien extraordinaria... ¡Una joven maravillosa que rebosa de un potencial único!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是渡酱前辈有，但普通人没有的……只有姐姐才有的特殊能力的证明。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是渡醬前輩有，但普通人沒有的……只有姐姐才有的特殊能力的證明。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00037",
		linknext = "0051_00039",
		line = 525,
	},
	["0051_00039"] = {
