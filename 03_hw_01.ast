			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah. But do you think we can pull that off? We're in the A level grades, so we might look suspicious walking around in there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……不过，不要紧吗？如果A等部的我们在B等部来回走动的话，会不会被怀疑呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……不過，不要緊嗎？如果A等部的我們在B等部來回走動的話，會不會被懷疑呢？」",
					{"rt2"},
				},
