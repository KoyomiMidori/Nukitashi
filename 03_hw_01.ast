	["0051_00139"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0659", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, I love it! The romantic stuff's soooo good...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，很喜欢！很浪漫……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，很喜歡！很浪漫……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00138",
		linknext = "0051_00140",
		line = 1918,
	},
	["0051_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“By the way, are the mangas you read... extreme? You know, this is Seiran Island and all, so I can't help but wonder if all the manga here has people fucking their brains out with whoever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“顺便问一下……那是青蓝岛设定中和谁都可以随意做爱的内容吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「順便問一下……那是青藍島設定中和誰都可以隨意做愛的內容嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00139",
		linknext = "0051_00141",
		line = 1930,
	},
	["0051_00141"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0660", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Nah, I've read a few that have sex in them... but the people in those do it because they love each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？不，虽然我也读过做爱的场景，不过……大家都只做有爱的性爱哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？不，雖然我也讀過做愛的場景，不過……大家都只做有愛的性愛哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00140",
		linknext = "0051_00142",
		line = 1944,
	},
	["0051_00142"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Interesting... So they do sell proper mangas on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是哦……青蓝岛也有那么正规的少女漫画啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是哦……青藍島也有那麼正規的少女漫畫啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00141",
		linknext = "0051_00143",
		line = 1956,
	},
	["0051_00143"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0661", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I've got friends who are big into manga from the mainland too, so they borrow from me a lot. That's why I really get what Tachibana-kun's always talking about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我有个喜欢本岛漫画的朋友，经常借给我看。所以橘君说的话我很明白哦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我有個喜歡本島漫畫的朋友，經常借給我看。所以橘君說的話我很明白哦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00142",
		linknext = "0051_00144",
		line = 1970,
	},
	["0051_00144"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0662", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Lovey-dovey sex is sooo nice... I read manga like that and I always think that I'd love to have sex just like they do in these.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“有爱情的做爱真棒……看了少女漫画后，我也会想体验一下这种美妙的做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「有愛情的做愛真棒……看了少女漫畫後，我也會想體驗一下這種美妙的做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00143",
		linknext = "0051_00145",
		line = 1984,
	},
	["0051_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
