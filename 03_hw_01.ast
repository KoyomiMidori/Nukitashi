		line = 1792,
	},
	["0051_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De alguna manera, parece aún más infantil cuando intenta dárselas de adulta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么看，那副硬要装大人的样子都和小孩子一模一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼看，那副硬要裝大人的樣子都和小孩子一模一樣。",
