		linkback = "0051_00003",
		linknext = "0051_00005",
		line = 60,
	},
	["0051_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Good response, I like the efficiency.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你的回复。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你的回答。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00004",
		linknext = "0051_00006",
		line = 72,
	},
	["0051_00006"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0620", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Leave it to me! It's the elder's job to be efficient around here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“交给我吧，这可是我这个姐姐的工作啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「交給我吧，這可是我這個姐姐的工作啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00005",
		linknext = "0051_00007",
		line = 86,
	},
	["0051_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now then. As you all know, the Shootdown King event concluded last week.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，‘击坠王’活动到上周末结束了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，『擊墜王』活動到上週末結束了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00006",
		linknext = "0051_00008",
		line = 98,
	},
	["0051_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We all had our share of hardships, but we persevered the entire time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然是痛苦而艰难的战斗，但是大家在上一周都非常努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然是痛苦而艱難的戰鬥，但是大家在上一周都非常努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00007",
		linknext = "0051_00009",
		line = 110,
	},
	["0051_00009"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1823", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We sure made a mess by the end, though... the SS didn't find us out, but I can't stop feeling chills all day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“真的，最后实在是太乱来了……我今天一天都一直提心吊胆，害怕是否暴露给SS了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「真的，最後實在是太亂來了……我今天一天都一直提心吊膽，害怕是否暴露給SS了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00008",
		linknext = "0051_00010",
		line = 124,
	},
	["0051_00010"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0992", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Doesn't seem like we'll have too much trouble on that front. The class president didn't seem to notice it was us, either...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“关于那个好像没什么问题……学生会长和我是同班……不过也没有说什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「關於那個好像沒什麼問題……學生會長和我是同班……不過也沒有說什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00009",
		linknext = "0051_00011",
		line = 136,
	},
	["0051_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. I don't see us being called for questioning or anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们也没有被叫出去谈话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們也沒有被叫出去談話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00010",
		linknext = "0051_00012",
		line = 148,
	},
	["0051_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I always make a point of wearing my goggles, and everyone else has one way or another of obscuring their faces.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来我就有辨识阻碍护镜，其他人也有很难被发现身份的特性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來我就有辨識阻礙護鏡，其他人也有很難被發現身份的特性。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00011",
		linknext = "0051_00013",
		line = 158,
	},
	["0051_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Looks like we made it through this mess without too much hassle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这次好像也没有暴露。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這次好像也沒有暴露。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00012",
		linknext = "0051_00014",
		line = 168,
	},
	["0051_00014"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4600] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=4600, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0621", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You all did your best. I've got some amazing kouhai! But I wasn't that useful myself... I'm not being a very good senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“大家真的都很努力了呢。好厉害啊……但是，只有我没帮上什么忙……虽然我是大家的前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「大家真的都很努力了呢。好厲害啊……但是，只有我沒幫上什麼忙……雖然我是大家的前輩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00013",
		linknext = "0051_00015",
		line = 184,
	},
	["0051_00015"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00128", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
