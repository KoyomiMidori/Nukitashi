		},
		linkback = "0051_00032",
		linknext = "0051_00034",
		line = 458,
	},
	["0051_00034"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No creo que nadie que no sea un maestro en el arte de manejar sillas pueda derrotar a un oponente por accidente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一般来说，要用椅子打倒别人，不是高手的话是不可能做到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一般來說，要用椅子打倒別人，不是高手的話是不可能做到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00033",
		linknext = "0051_00035",
		line = 470,
	},
	["0051_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo que llamas coincidencia es en realidad un instinto inconsciente. Y eso, Wata-chan-senpai, es prueba de que tienes lo que necesitamos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“偶然……也就是无意识中做出的事——这就是前辈‘有点东西’的证据。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「偶然……也就是無意識中做出的事——這就是前輩『有點東西』的證據。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00034",
		linknext = "0051_00036",
		line = 482,
	},
	["0051_00036"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
