					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wata-chan-senpai! You said you beat that SS with your chair by pure chance, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱前辈。刚才，你说用椅子打倒SS是偶然……”",
