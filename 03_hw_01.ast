			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Solo fue un accidente... ¡Si estuviera usando esa cosa de verdad, estaría matando a la SS como si fueran moscas! Es lo mínimo que podría hacer... Habrase visto a esta senpai...”",
					{"rt2"},
