				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=450, ease="easeinout_sine", delay2=4000},
			},
			[6500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0667", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So, if she's three years younger than me, then... One, two... She'd be a student in year 3 of the B level grades, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……比我小三岁的话……一、二……大概是B等部的3年级生吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……比我小三歲的話……一、二……大概是B等部的3年級生吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00159",
		linknext = "0051_00161",
		line = 2189,
	},
	["0051_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The B levels have their own section in the school. So we should be able to search for her during the day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“B等部的话，就在同一所学校里——白天也可以去找吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「B等部的話，就在同一所學校裡——白天也可以去找吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00160",
		linknext = "0051_00162",
