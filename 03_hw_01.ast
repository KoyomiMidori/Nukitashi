			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A mí me pareces una niña que se traga cualquier cuento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……我只看到一个什么都当真的小孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……我只看到一個什麼都當真的小孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00130",
		linknext = "0051_00132",
		line = 1776,
	},
	["0051_00132"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
