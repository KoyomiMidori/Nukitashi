				{
					name = {"ヒナミ", "雛見"},
					"「可以組成戰隊呢！琴寄戰隊文乃戰士——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00066",
		linknext = "0051_00068",
		line = 932,
	},
	["0051_00068"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00101", file2="nanase_01f_00202", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1828", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I'm fairly certain our big-shot sponsor would rather we didn't go rounding up every person named Fumino, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我想，出资者并不是要聚集很多叫琴寄文乃的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我想，出資者並不是要聚集很多叫琴寄文乃的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00067",
		linknext = "0051_00069",
		line = 945,
	},
	["0051_00069"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If he went out of his way to ask us to look for her, that must mean the girl we want lives on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“特地叫我们找的话——一定是这个岛上的‘琴寄文乃’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「特地叫我們找的話——一定是這個島上的『琴寄文乃』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00068",
		linknext = "0051_00070",
		line = 957,
	},
	["0051_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But right now, we've hit a wall when it comes to leads. It's gonna take forever to track her down with only a name to go on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是现在的信息太少也是事实。只通过名字和性别来找，会花多少时间呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是現在的資訊太少也是事實。只通過名字和性別來找，會花多少時間呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00069",
		linknext = "0051_00071",
		line = 969,
	},
	["0051_00071"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00101", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0639", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“How about we ask the old man from the big screen next time he calls in?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“下次电视上的老爷爷打电话过来时问问他怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「下次電視上的老爺爺打電話過來時問問他怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00070",
		linknext = "0051_00072",
		line = 982,
	},
	["0051_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... We'll need all the info on Fumino we can possibly get.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得也是……为了今后的打算，有必要打听文乃的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得也是……為了今後的打算，有必要打聽文乃的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00071",
		linknext = "0051_00073",
		line = 993,
	},
	["0051_00073"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00104", file2="nanase_01f_00202", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1829", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You sure about that? If he smells anything fishy, it could blow up in our face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不要紧吧？如果因为说了太奇怪的话而引起他的反感……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不要緊吧？如果因為說了太奇怪的話而引起他的反感……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00072",
		linknext = "0051_00074",
		line = 1006,
	},
	["0051_00074"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know that. But I'm sure he wants to find and safeguard Fumino as soon as possible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我知道，可是他应该也想早点保护好文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我知道，可是他應該也想早點保護好文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00073",
		linknext = "0051_00075",
		line = 1018,
	},
	["0051_00075"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't know why he's being so vague, but asking us to pin her down with so little info is just unreasonable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然不知道他为什么不愿意提供信息——但是这样就要让我们快点找出来，未免也太勉强了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然不知道他為什麼不願意提供資訊——但是這樣就要讓我們快點找出來，未免也太勉強了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00074",
		linknext = "0051_00076",
		line = 1030,
	},
	["0051_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know it's risky, but we need to just ask about Fumino if we want to move forward.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算要承担风险，也要再往前走一步，必须若无其事地把‘文乃’的情报套出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算要承擔風險，也要再往前走一步，必須若無其事地把『文乃』的情報套出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00075",
		linknext = "0051_00077",
		line = 1042,
	},
	["0051_00077"] = {
		{"fg", file="hinami_02f_00001", file3="hinami_02f_00302", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0640", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooooh, Tachibana-kun, you're so cool! But do we even know when he'll call next?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦……橘君好帅啊！不过，下次会是什么时候打电话来呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦……橘君好帥啊！不過，下次會是什麼時候打電話來呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00076",
		linknext = "0051_00078",
		line = 1055,
	},
	["0051_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We let him know about the Shootdown King stuff. Since that's over now, I imagine our next little chat with him isn't far off...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘击坠王’的事对方也掌握了。因为活动结束了，所以差不多该来了吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『擊墜王』的事對方也掌握了。因為活動結束了，所以差不多該來了吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00077",
		linknext = "0051_00079",
		line = 1066,
	},
	["0051_00079"] = {
		{"bgm", stop=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=0, loop=0, file="se_a190"},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Speak of the devil.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就在这时，那个警报声响了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就在這時，那個警報聲響了。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00078",
		linknext = "0051_00080",
		line = 1083,
	},
	["0051_00080"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We all stand up and take position in front of the monitor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"全体人员挺直脊背，吞了一口气站在中央显示器前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"全體人員挺直脊背，吞了一口氣站在中央顯示器前。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00079",
		linknext = "0051_00081",
		line = 1099,
	},
	["0051_00081"] = {
		{"bg", id=2, file="bg12_1l_00000", x=0, y=100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sure enough, his image materializes on the screen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果——屏幕上出现了那个老人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結果——螢幕上出現了那個老人。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00080",
		linknext = "0051_00082",
		line = 1110,
	},
	["0051_00082"] = {
		{"bgm", file="bgm04.5", vol=100},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0062", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“What is your progress?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00081",
		linknext = "0051_00083",
		line = 1124,
	},
	["0051_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir. The Shootdown King event has concluded. We managed to successfully weather it, thanks to your support.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是——上周‘击坠王’活动结束。全体人员平安无事。这一切都多亏了老爷爷你的支援。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是——上週『擊墜王』活動結束。全體人員平安無事。這一切都多虧了老爺爺你的支援。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00082",
		linknext = "0051_00084",
		line = 1136,
	},
	["0051_00084"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0063", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Very well. How is your search for Fumino progressing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“这样吗——文乃的事怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「這樣嗎——文乃的事怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00083",
		linknext = "0051_00085",
		line = 1149,
	},
	["0051_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're in the process of coming up with a search plan. To that end, we'd like your guidance...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我正在研究找到她的策略，如果你能给出指示的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我正在研究找到她的策略，如果你能給出指示的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00084",
		linknext = "0051_00086",
		line = 1161,
	},
	["0051_00086"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0064", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Oh? Would you care to explain why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“哦？说一下理由吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「哦？說一下理由吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00085",
		linknext = "0051_00087",
		line = 1174,
	},
	["0051_00087"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We have no leads on the whereabouts of Fumino yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们还没有找到文乃的线索。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們還沒有找到文乃的線索。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00086",
		linknext = "0051_00088",
		line = 1186,
	},
	["0051_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know you have made a large investment in us, so I deeply apologize for having wasted this much time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明明得到了大笔出资，如果要再继续浪费时间下去，我也很难过——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「明明得到了大筆出資，如果要再繼續浪費時間下去，我也很難過——」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00087",
		linknext = "0051_00089",
		line = 1197,
	},
	["0051_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But with all due respect, I do not want to run any operations which could potentially prove fruitless, so I would like to ask for your thoughts first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因此——对文乃的调查方针，我们需要你的意见，这样也比较能合你的意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因此——對文乃的調查方針，我們需要你的意見，這樣也比較能合你的意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00088",
		linknext = "0051_00090",
		line = 1209,
	},
	["0051_00090"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0065", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Hm. You can be quite roundabout. What you mean to say is, you are lacking sufficient information on Fumino, and you want me to give it to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“嗯……看来你还蛮会说话的。简而言之，就是因为‘文乃’的情报不够，叫我给你们更多的情报……你是想这么说吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「嗯……看來你還蠻會說話的。簡而言之，就是因為『文乃』的情報不夠，叫我給你們更多的情報……你是想這麼說吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00089",
		linknext = "0051_00091",
		line = 1222,
	},
	["0051_00091"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00113", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0641", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“H-He saw through us...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“暴、暴露了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「暴、暴露了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00090",
		linknext = "0051_00092",
		line = 1237,
	},
	["0051_00092"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0066", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“I suspected as much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“果然是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「果然是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00091",
		linknext = "0051_00093",
		line = 1250,
	},
	["0051_00093"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0642", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Eh... Ah! Sorry Tachibana-kun! Slip of the tongue, I'm just real nervous right now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……啊！对不起，橘君！吓得我说溜嘴了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……啊！對不起，橘君！嚇得我說溜嘴了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00092",
		linknext = "0051_00094",
		line = 1265,
	},
	["0051_00094"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0643", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“B-But still, sir! We're all working as hard as we can, but it's incredibly difficult to track down someone with only a name to go on. So if you had any more information on this Fumino individual, we figured that could help us...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是……虽然大家都很努力，但是光靠名字和性别是很难找到的。所以我希望能再告诉我们一些关于文乃的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是……雖然大家都很努力，但是光靠名字和性別是很難找到的。所以我希望能再告訴我們一些關於文乃的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00093",
		linknext = "0051_00095",
		line = 1279,
	},
	["0051_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She uncharacteristically loses her cool in front of the old man, and trails off once she realizes what she's said.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在面无表情的老人面前，就连渡酱也变得口齿不清，句尾声音越来越小。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在面無表情的老人面前，就連渡醬也變得口齒不清，句尾聲音越來越小。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00094",
		linknext = "0051_00096",
		line = 1289,
	},
	["0051_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For a moment, the uncomfortable silence permeates the room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"令人发窘的沉默持续了数秒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"令人發窘的沉默持續了數秒。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00095",
		linknext = "0051_00097",
		line = 1299,
	},
	["0051_00097"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0067", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Very well. If it expedites Fumino's safety, I shall not hold my tongue. It should be sufficient to inform you of her age.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——好吧。为了保护文乃也没办法。如果只是年龄的话，我可以告诉你们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——好吧。為了保護文乃也沒辦法。如果只是年齡的話，我可以告訴你們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00096",
		linknext = "0051_00098",
		line = 1312,
	},
	["0051_00098"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0644", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Really? How old is she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……真的吗！请问她几岁了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……真的嗎！請問她幾歲了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00097",
		linknext = "0051_00099",
		line = 1326,
	},
	["0051_00099"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0068", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“She is almost certainly older than you are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“比你年纪大一点吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「比你年紀大一點吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00098",
		linknext = "0051_00100",
		line = 1339,
	},
	["0051_00100"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0645", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Older than me... Hmmm... There isn't a university on this island, is there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“比我年纪大……这么说，不在学校吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「比我年紀大……這麼說，不在學校嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00099",
		linknext = "0051_00101",
		line = 1353,
	},
	["0051_00101"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00100",
		linknext = "0051_00102",
		line = 1365,
	},
	["0051_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
