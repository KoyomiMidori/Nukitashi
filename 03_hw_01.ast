		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien... ¿estamos todos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，大家都到齐了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好，大家都到齊了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00002",
		linknext = "0051_00004",
		line = 45,
	},
	["0051_00004"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=3, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2700] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=2700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0619", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uno, dos, tres... ¡Sip, ya estamos todos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“一、二、三……嗯，都到齐了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「一、二、三……嗯，都到齊了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00003",
		linknext = "0051_00005",
		line = 60,
	},
	["0051_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Buena respuesta, me gusta la eficiencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你的回复。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你的回答。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00004",
		linknext = "0051_00006",
		line = 72,
	},
	["0051_00006"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0620", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Yo me encargo! ¡El trabajo de la mayor es ser eficiente!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“交给我吧，这可是我这个姐姐的工作啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「交給我吧，這可是我這個姐姐的工作啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00005",
		linknext = "0051_00007",
		line = 86,
	},
	["0051_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, como ya sabrán, el evento del Rey del Lanzamiento concluyó la semana pasada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，‘击坠王’活动到上周末结束了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，『擊墜王』活動到上週末結束了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00006",
		linknext = "0051_00008",
		line = 98,
	},
	["0051_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tuvimos nuestras dificultades, pero nos mantuvimos firmes hasta el final.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然是痛苦而艰难的战斗，但是大家在上一周都非常努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然是痛苦而艱難的戰鬥，但是大家在上一周都非常努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00007",
		linknext = "0051_00009",
		line = 110,
	},
	["0051_00009"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1823", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pero al final hicimos un desastre... La SS no nos descubrió, pero no dejo de sentirme como que asustada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“真的，最后实在是太乱来了……我今天一天都一直提心吊胆，害怕是否暴露给FS了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「真的，最後實在是太亂來了……我今天一天都一直提心吊膽，害怕是否暴露給FS了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00008",
		linknext = "0051_00010",
		line = 124,
	},
	["0051_00010"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0992", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No creo que tengamos muchos problemas por eso. La presidente de la clase tampoco se dio cuenta de que éramos nosotros...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“关于那个好像没什么问题……学生会长和我是同班……不过也没有说什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「關於那個好像沒什麼問題……學生會長和我是同班……不過也沒有說什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00009",
		linknext = "0051_00011",
		line = 136,
	},
	["0051_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No creo que nos llamen para interrogarnos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们也没有被叫出去谈话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們也沒有被叫出去談話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00010",
		linknext = "0051_00012",
		line = 148,
	},
	["0051_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siempre me aseguro de llevar mis gafas protectoras, y las chicas tienen formas de ocultar sus rostros.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来我就有辨识阻碍护镜，其他人也有很难被发现身份的特性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來我就有辨識阻礙護鏡，其他人也有很難被發現身份的特性。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00011",
		linknext = "0051_00013",
		line = 158,
	},
	["0051_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que hemos salido de este lío sin demasiados problemas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这次好像也没有暴露。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這次好像也沒有暴露。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00012",
		linknext = "0051_00014",
		line = 168,
	},
	["0051_00014"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4600] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=4600, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0621", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Lo hicieron de maravilla. ¡Tengo unos kouhais increíbles! Pero yo casi no hice nada... No estoy siendo la mejor senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“大家真的都很努力了呢。好厉害啊……但是，只有我没帮上什么忙……虽然我是大家的前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「大家真的都很努力了呢。好厲害啊……但是，只有我沒幫上什麼忙……雖然我是大家的前輩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00013",
		linknext = "0051_00015",
		line = 184,
	},
	["0051_00015"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00128", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1824", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pues yo no creo eso... ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没有那种事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒有那種事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00014",
		linknext = "0051_00016",
		line = 198,
	},
	["0051_00016"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=7.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0622", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero es la verdad! Asane-chan está todo el día soltando palabrería científica sin sentido, y Nanase-chan está tirando huevos por doquier mientras se ve genial...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“有啊！麻沙音会说很多难懂的话，奈奈濑狂扔类似鸡蛋的东西实在是太帅了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「有啊！麻沙音會說很多難懂的話，奈奈瀨狂扔類似雞蛋的東西實在是太帥了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00015",
		linknext = "0051_00017",
		line = 211,
	},
	["0051_00017"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00116", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0623", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Y tú derrotaste a una mujer de la SS bastante fuerte, ¿no? Yo soy la única que no está haciendo nada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君还把FS厉害的人打倒了吧？只有我什么都没做到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君還把FS厲害的人打倒了吧？只有我什麼都沒做到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00016",
		linknext = "0051_00018",
		line = 225,
	},
	["0051_00018"] = {
