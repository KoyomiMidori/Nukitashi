	["0051_00147"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"bg", id=2, file="bg09_2l_00000", x=50, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-105, y=-5, time=20000, lv=5},
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00102", file2="hinami_02l_00201", path=":fg/hinami_02l/", id=6, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=50, y=0},
		{"fgact", ch="ヒナミ", id=6, act="移動", x=-50, y=0, time=20000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero... ver a alguien con su apariencia hablando de sexo parece ilegal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——看着她这样的外形再听她说出理想的性爱，会让我感受到强烈的犯罪气息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——看著她這樣的外形再聽她說出理想的性愛，會讓我感受到強烈的犯罪氣息。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00146",
		linknext = "0051_00148",
		line = 2022,
	},
	["0051_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es precisamente anormal que una chica que nunca ha tenido relaciones sexuales busque representaciones del sexo en la ficción.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还不能做爱的少女对性爱充满憧憬，在这里也不是什么稀奇的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還不能做愛的少女對性愛充滿憧憬，在這裡也不是什麼稀奇的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00147",
		linknext = "0051_00149",
		line = 2032,
	},
	["0051_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero viniendo de ella, me produce una sensación muy extraña... Probablemente porque es una loli legal y es mayor que yo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，这话从渡酱口中说出就会有一种很真实的感觉——因为她是比我年长的合法萝莉吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，這話從渡醬口中說出就會有一種很真實的感覺——因為她是比我年長的合法蘿莉嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00148",
		linknext = "0051_00150",
		line = 2042,
	},
	["0051_00150"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=6, ch="ヒナミ", lv=5, time=300},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00110", file2="hinami_02m_00204", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0663", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero con solo pensarlo me pongo nerviosa... Es raro. Todos parecen divertirse cuando lo hacen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是我一想像做爱的场景，就会害羞得不得了……好奇怪啊，大家明明都很开心的样子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是我一想像做愛的場景，就會害羞得不得了……好奇怪啊，大家明明都很開心的樣子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00149",
		linknext = "0051_00151",
		line = 2059,
	},
	["0051_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, no tiene nada de raro. Lo que piensas es lo correcto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——这不奇怪。应该说这才是正常的感受。”",
