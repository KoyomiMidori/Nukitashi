					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Deja de tomarle fotos a escondidas! ¿Y por qué es mi culpa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要边拍照边说啊……这难道是我的错？”",
