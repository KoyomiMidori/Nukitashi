	["0051_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A leader mustn't allow the morale of one of his troops to drop like this. I have to rally her to victory...!",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为队长，不能放任士气下降。来鼓舞一下她——",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為隊長，不能放任士氣下降。來鼓舞一下她——",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00029",
