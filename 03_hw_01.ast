				{"fg", file="hinami_02m_00001", file1="hinami_02m_00110", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0668", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí. Pero ¿crees que podremos hacerlo? Estamos en el nivel A, así que llamaríamos la atención si nos ven por allí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……不过，不要紧吗？如果A等部的我们在B等部来回走动的话，会不会被怀疑呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……不過，不要緊嗎？如果A等部的我們在B等部來回走動的話，會不會被懷疑呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00161",
		linknext = "0051_00163",
		line = 2218,
	},
	["0051_00163"] = {
