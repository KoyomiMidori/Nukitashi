				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……？是吗？那不是因为橘君努力了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……？是嗎？那不是因為橘君努力了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00120",
		linknext = "0051_00122",
		line = 1641,
	},
	["0051_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No. I'm sure he decided to tell us after seeing the honesty in your eyes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不。那个人一定也是被渡酱笔直的目光打动了才告诉我们的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不。那個人一定也是被渡醬筆直的目光打動了才告訴我們的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00121",
		linknext = "0051_00123",
		line = 1653,
	},
	["0051_00123"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0652", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, my grandpa always says that he feels like talking about anything when he looks at my eyes, maybe it's something like that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……这么说来，我的爷爷也常说看到雏见就会忍不住什么都想说呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……這麼說來，我的爺爺也常說看到雛見就會忍不住什麼都想說呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00122",
		linknext = "0051_00124",
		line = 1667,
	},
	["0051_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure that's because they see the love of a mother in your eyes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然……那一定是渡酱所拥有的母性使然。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然……那一定是渡醬所擁有的母性使然。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00123",
		linknext = "0051_00125",
		line = 1679,
	},
	["0051_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whenever a guy's talking to a woman he perceives as a full-grown, mature lady, he'll feel compelled to spill his guts in front of her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所谓的男人……是什么都想对大姐姐说的生物……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所謂的男人……是什麼都想對大姐姐說的生物……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00124",
		linknext = "0051_00126",
		line = 1691,
	},
	["0051_00126"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[2200] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=2200, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0653", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Full-grown mature lady...! I see, I see. I get it now. So that old guy on the TV saw me as a lady too, right!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“大姐姐……！是这样啊……原来如此。那么，电视里的爷爷也把我当作大姐姐看待呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「大姐姐……！是這樣啊……原來如此。那麼，電視裡的爺爺也把我當作大姐姐看待呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00125",
		linknext = "0051_00127",
		line = 1707,
	},
	["0051_00127"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0654", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Wait, but if he said Fumino-chan was probably older than me, what was that supposed to mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦？可是他又说文乃比我年长，这是怎么回事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦？可是他又說文乃比我年長，這是怎麼回事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00126",
		linknext = "0051_00128",
		line = 1721,
	},
	["0051_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, well... Um...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个……怎么说呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個……怎麼說呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00127",
		linknext = "0051_00129",
		line = 1733,
	},
	["0051_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't think you need to get so bothered about things like that. A lady's supposed to have a forgiving disposition.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不用在意那样的细节吧？大姐姐的肚量不是很大吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不用在意那樣的細節吧？大姐姐的肚量不是很大嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00128",
		linknext = "0051_00130",
		line = 1745,
	},
	["0051_00130"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00120", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=-400, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0655", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah... I see! Right, I won't worry about it! I'm a mature lady!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……是啊！嗯，我不会在意的！因为是大姐姐嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……是啊！嗯，我不會在意的！因為是大姐姐嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00129",
		linknext = "0051_00131",
		line = 1762,
	},
	["0051_00131"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0996", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You look a lot more like a kid who'll swallow any tall tale to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……我只看到一个什么都当真的小孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……我只看到一個什麼都當真的小孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00130",
		linknext = "0051_00132",
		line = 1776,
	},
	["0051_00132"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[1200] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00120", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1200, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0656", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But I'm not—! N-Not gonna worry... Not gonna worry about it! I'm a lady...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不是小孩子——不在意……我可不在意哦？因为是姐姐嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不是小孩子——不在意……我可不在意哦？因為是姐姐嘛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00131",
		linknext = "0051_00133",
		line = 1792,
	},
	["0051_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Somehow, she seems even more childish than usual when trying to act mature.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么看，那副硬要装大人的样子都和小孩子一模一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼看，那副硬要裝大人的樣子都和小孩子一模一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00132",
		linknext = "0051_00134",
		line = 1802,
	},
	["0051_00134"] = {
		{"bgm", stop=1},
		{"se", id=1, stop=1, time=1500},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=100},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_012_00000"},
		{"ex", time=500, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_012_00000"},
		{"bgm", file="bgm03", vol=100},
		{"se", id=1, loop=1, file="se_d031", vol=60},
		{"se", id=0, loop=0, file="se_a053"},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0657", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Thanks Tachibana-kun for going this far with me. It's kind of a long walk to my house...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“谢谢你，橘君，我家很远，你还特意送我回家……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「謝謝你，橘君，我家很遠，你還特意送我回家……」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00133",
		linknext = "0051_00135",
		line = 1854,
	},
	["0051_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After leaving Asa-chan home, we're left walking down under the orange glow of dusk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把麻沙酱送到家后，我和渡酱走在傍晚的路上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把麻沙醬送到家後，我和渡醬走在傍晚的路上。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00134",
		linknext = "0051_00136",
		line = 1864,
	},
	["0051_00136"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's fine, I felt like it. I worry about you getting into trouble again like last time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，只是我想这么做而已。如果再发生以前那种事，我会很担心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，只是我想這麼做而已。如果再發生以前那種事，我會很擔心的。」",
					{"rt2"},
