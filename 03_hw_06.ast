			cn = {
				{
					"不管怎么说妹妹都怕寂寞。一定是渡酱代替了姐姐的位置吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼說妹妹都怕寂寞。一定是渡醬代替了姐姐的位置吧。",
					{"rt2"},
