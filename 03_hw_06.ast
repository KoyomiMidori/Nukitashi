			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I'm sure you don't want to deal with that shame, but I don't think Tachibana-kun needs to worry about that. I can plainly see how hard it's already been on you.”",
					{"rt2"},
				},
			},
			cn = {
