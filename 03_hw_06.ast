		{"text"},
		delay = {
			[1000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00113", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", delay2=1000},
			},
			[2700] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=2700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1037", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Oh wow, it's really late, isn't it? I told mom I'd be a bit late, but I'd better get going before she starts to worry...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……？啊，已经这么晚了！虽然我有说可能会晚些，但是妈妈会担心的，该回去了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……？啊，已經這麼晚了！雖然我有說可能會晚些，但是媽媽會擔心的，該回去了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00245",
		linknext = "0056_00247",
		line = 3268,
	},
	["0056_00247"] = {
