		{"fgact", ch="蘭", id=8, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0150", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I was surprised to hear Tachibana-kun was impotent, but his willpower is really something. Never would've guessed that someone who can't even have sex could get this far on his first day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“听说橘君是阳痿的时候吓了一跳……但你真的很有毅力呢。连做爱都不会的人，居然第一天就能跟到这里来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「聽說橘君是陽痿的時候嚇了一跳……但你真的很有毅力呢。連做愛都不會的人，居然第一天就能跟到這裡來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00140",
		linknext = "0056_00142",
		line = 1855,
	},
	["0056_00142"] = {
