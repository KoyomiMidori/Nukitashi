		linkback = "0056_00253",
		linknext = "0056_00255",
		line = 3372,
	},
	["0056_00255"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's been almost assaulted twice now, so I can't in good conscience let her go home alone this late.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱差点被袭击两次了……不能让她一个人回去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬差點被襲擊兩次了……不能讓她一個人回去。」",
					{"rt2"},
				},
			},
		},
