	["0056_00262"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The scene is heartwarming just to think about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"光是想想就让人露出微笑的光景。",
					{"rt2"},
				},
			},
			tw = {
