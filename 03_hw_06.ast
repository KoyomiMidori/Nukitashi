	},
	["0056_00261"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe she had her mother teach her how to make those, so she could make me this bear.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许，我的熊是渡酱一边让妈妈教导她，一边认真制作的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許，我的熊是渡醬一邊讓媽媽教導她，一邊認真製作的。",
					{"rt2"},
