				{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1013", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Roped...? Oh, it's fine. I'm the senpai! Helping underclassmen feel better is a senpai's duty!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“奇怪的事情……？没事没事。跟后辈玩是前辈本来就该做的事吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「奇怪的事情……？沒事沒事。跟後輩玩是前輩本來就該做的事吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00169",
		linknext = "0056_00171",
		line = 2291,
	},
	["0056_00171"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She proudly puffs out her non-existent chest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她得意地挺胸拍拍平坦的胸口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她得意地挺胸拍拍平坦的胸口。",
					{"rt2"},
