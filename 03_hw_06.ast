				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「SS的訓練程度，對我來說就像兒戲。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00155",
		linknext = "0056_00157",
		line = 2114,
	},
	["0056_00157"] = {
		{"text"},
