					"“你可能会觉得很丢脸……但不会的哦？因为我一直都知道橘君很努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你可能會覺得很丟臉……但不會的哦？因為我一直都知道橘君很努力。」",
					{"rt2"},
