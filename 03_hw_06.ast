		line = 3334,
	},
	["0056_00252"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks for keeping her here until I got home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……也谢谢你，麻沙酱。谢谢你帮我挽留渡酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……也謝謝你，麻沙醬。謝謝你幫我挽留渡醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00251",
		linknext = "0056_00253",
		line = 3346,
	},
	["0056_00253"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1065", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Eh, I was just playing games with her, so whatever. You're probably tired, though. You even escorted her home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……没什么，我只是跟她一起玩了游戏……不过没事吧……？哥哥也累了吧……接下来还要送她回去的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……沒什麼，我只是跟她一起玩了遊戲……不過沒事吧……？哥哥也累了吧……接下來還要送她回去的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00252",
		linknext = "0056_00254",
		line = 3360,
	},
	["0056_00254"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
