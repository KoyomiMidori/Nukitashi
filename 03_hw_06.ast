		linkback = "0056_00023",
		linknext = "0056_00025",
		line = 305,
	},
	["0056_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You sure?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的没关系吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的沒關係嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00024",
		linknext = "0056_00026",
		line = 317,
	},
	["0056_00026"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1860", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Maybe just worry about yourself for now. I've heard about the SS screening process. I've seen a lot of people give up partway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“担心别人还不如担心自己。SS的选拔训练听说相当辛苦啊？我们班也有放弃的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「擔心別人還不如擔心自己。SS的選拔訓練聽說相當辛苦啊？我們班也有放棄的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00025",
		linknext = "0056_00027",
		line = 331,
	},
	["0056_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hah. What do you take me for?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈。不要把我和那些人混为一谈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈。不要把我和那些人混為一談。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00026",
		linknext = "0056_00028",
		line = 343,
	},
	["0056_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Training for some student organization will be nothing for someone who trains as much as I do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我平时都有在锻炼身体——学生的训练程度，我根本不放在眼里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我平時都有在鍛煉身體——學生的訓練程度，我根本不放在眼裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00027",
		linknext = "0056_00029",
		line = 354,
	},
	["0056_00029"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I could demolish whatever records they've got. That'll take them by surprise.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不如我在选拔阶段把精英们的纪录都给他改写一下，吓吓他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不如我在選拔階段把精英們的紀錄都給他改寫一下，嚇嚇他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00028",
		linknext = "0056_00030",
		line = 366,
	},
	["0056_00030"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00110", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1057", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh yeah, they'll get a guy who's all, 'Did I do that?' while glaring daggers at the speechless SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……是对着惊讶的SS们说‘我又做错了什么吗？’的剧情啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……是對著驚訝的SS們說『我又做錯了什麼嗎？』的劇情啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00029",
		linknext = "0056_00031",
		line = 379,
	},
	["0056_00031"] = {
