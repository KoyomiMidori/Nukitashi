				{
					"要求尚未达到条例对象年龄的少女进行性行为，就等同于强奸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要求尚未達到條例對象年齡的少女進行性行為，就等同於強姦。",
					{"rt2"},
				},
			},
		},
