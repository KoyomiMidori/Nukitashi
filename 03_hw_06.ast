			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun, you're really stiff. How's that feel?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君也很僵硬呢……觉得怎么样？”",
