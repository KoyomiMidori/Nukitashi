					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There's probably some shadow council running things behind the scenes, and hopefully the SS will already have intel on them.”",
					{"rt2"},
