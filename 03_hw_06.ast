		linkback = "0056_00221",
		linknext = "0056_00223",
		line = 2976,
	},
	["0056_00223"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, no... I'm just having trouble wrapping my head around the idea that you're friends with that drill sergeant from Hell.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，不……我到现在都无法相信那个魔鬼教官是你的朋友……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，不……我到現在都無法相信那個魔鬼教官是你的朋友……」",
