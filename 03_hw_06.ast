					name = {"淳之介", "Junnosuke"},
					"“That's just how fired up I am. Now, I hope you haven't been making problems for Wata-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这是兴奋的发抖。麻沙酱才是，你有没有给渡酱添麻烦？”",
