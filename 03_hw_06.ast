			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hehe... what did I tell you? Pancakes are best when you're exhausted. I still have some left, so here you go... Aaahn~”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵……可以理解……累的时候吃松饼很棒吧，味道超赞的。还没吃完呢……啊——♪”",
