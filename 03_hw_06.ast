			},
		},
		linkback = "0056_00170",
		linknext = "0056_00172",
		line = 2302,
	},
	["0056_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn't seem to get it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她好像不太清楚状况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她好像不太清楚狀況。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00171",
		linknext = "0056_00173",
		line = 2312,
	},
	["0056_00173"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1014", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, that's right. Tachibana-kun, you must be tired from your training! Come, look, look! I bought all this stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，对了对了。橘君，你训练得很累吧？你看你看！我买了很多东西来哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，對了對了。橘君，你訓練得很累吧？你看你看！我買了很多東西來哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00172",
		linknext = "0056_00174",
		line = 2326,
	},
	["0056_00174"] = {
		{"se", id=0, loop=0, file="se_a184"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1015", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sweets are best for when you're tired! I got marshmallows, chewy candies, pancakes, and this big pudding!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“累的时候吃甜品最好了！棉花糖、汽水糖、大大的布丁，连松饼都有哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「累的時候吃甜品最好了！棉花糖、汽水糖、大大的布丁，連鬆餅都有哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00173",
		linknext = "0056_00175",
		line = 2339,
	},
	["0056_00175"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a184"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her excitement as she takes out the various types of candy remind me of a child showing off her toys.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她兴奋地取出零食的动作，就像从箱子里拿出玩具的孩子一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她興奮地取出零食的動作，就像從箱子裡拿出玩具的孩子一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00174",
		linknext = "0056_00176",
		line = 2351,
	},
	["0056_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm not as addicted to her as Nanase is, but her presence is still soothing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我不是奈奈濑，只真的只要看着就很疗愈……",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我不是奈奈瀨，只真的只要看著就很療愈……",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00175",
		linknext = "0056_00177",
		line = 2361,
	},
	["0056_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Considering she went out of her way to buy them for me, it would be rude to refuse. It's not dinnertime yet, anyway.",
					{"rt2"},
				},
			},
			cn = {
				{
					"难得给我买的，虽然还没吃晚饭，但还是吃些什么吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"難得給我買的，雖然還沒吃晚飯，但還是吃些什麼吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00176",
		linknext = "0056_00178",
		line = 2371,
	},
	["0056_00178"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
