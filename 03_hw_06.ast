				{"vo", file="rei0232", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hmm... Hm? What the hell is this!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……呃？这是什么……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……呃？這是什麼……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00057",
		linknext = "0056_00059",
		line = 799,
	},
	["0056_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My testing results have clearly left Tadasugawa-senpai at a loss for words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看了适性检查结果，风纪委员长——糺川前辈不禁语塞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看了適性檢查結果，風紀委員長——糺川前輩不禁語塞。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00058",
		linknext = "0056_00060",
		line = 809,
	},
	["0056_00060"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did I screw up again?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我又做错了什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我又做錯了什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00059",
		linknext = "0056_00061",
		line = 821,
	},
	["0056_00061"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0233", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If only! Endurance, combat capability, hidden potential, secret intelligence capability, intelligence, cooperation—in all these areas you're below average! How does that happen!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么做错了什么了！持久力格斗能力躲藏能力谍报能力情报能力智力协调性——在所有方面都没有出色的地方！最多只到平均水平，大部份都低于平均水平！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼做錯了什麼了！持久力格鬥能力躲藏能力諜報能力情報能力智力協調性——在所有方面都沒有出色的地方！最多只到平均水平，大部份都低於平均水平！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00060",
		linknext = "0056_00062",
		line = 835,
	},
	["0056_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? That's fucking stupid!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什……怎么会有这种事————！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什……怎麼會有這種事————！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00061",
		linknext = "0056_00063",
		line = 847,
	},
	["0056_00063"] = {
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1800] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00113", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0234", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The stupid one here is yourself! Sigh... Of all the trainees I've worked with in my time, you truly do stand out in the worst possible way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就是有这种事！唉……我到目前为止也训练了很多学生，但第一次碰到这样的家伙啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就是有這種事！唉……我到目前為止也訓練了很多學生，但第一次碰到這樣的傢伙啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00062",
		linknext = "0056_00064",
		line = 862,
	},
	["0056_00064"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00105", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0235", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“At least you've got a fairly rugged build, and your ability to make snap decisions is quite far above average. I guess you'd be suited for a position like squad leader.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊——身体还挺结实的。然后，瞬间的判断能力也比其他高……如果要说适合什么的话——大概是分队长吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊——身體還挺結實的。然後，瞬間的判斷能力也比其他高……如果要說適合什麼的話——大概是分隊長吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00063",
		linknext = "0056_00065",
		line = 876,
	},
	["0056_00065"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Squad leader!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“分队长————！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「分隊長————！」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00064",
		linknext = "0056_00066",
		line = 888,
	},
	["0056_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Was I not able to hide my natural charisma and leadership skills!?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是——我隐藏不住的“领导能力”显露出来了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是——我隱藏不住的「領導能力」顯露出來了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00065",
		linknext = "0056_00067",
		line = 898,
	},
	["0056_00067"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0236", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What the hell are you so happy about, dumbass!? Ran, teach this idiot what it really means to be suited to be a squad leader!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“傻瓜！你在高兴什么！？兰，告诉这个男人适合分队长是什么意思！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「傻瓜！你在高興什麼！？蘭，告訴這個男人適合分隊長是什麼意思！」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00066",
		linknext = "0056_00068",
		line = 912,
	},
	["0056_00068"] = {
		{"fgact", ch="礼", id=9, act="移動", x=-400, y=0, time=500},
		{"fg", file="ran_01m_00001", file1="ran_01m_00104", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="蘭", id=8, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0149", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Yes, ma'am! When it comes to new recruits, 'suitable for squad leader' is essentially a way of saying they aren't suited for any particular role. They pose a particular problem for us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“是的！适合分队长是对新人训练生最大限度的关怀表现，总之就是所有职位都不适合的意思！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「是的！適合分隊長是對新人訓練生最大限度的關懷錶現，總之就是所有職位都不適合的意思！」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00067",
		linknext = "0056_00069",
		line = 927,
	},
	["0056_00069"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0237", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Exactly! In other words, someone who's antisocial, uncooperative, and unmotivated is better off getting a 'creative' job! File that in your mind palace!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错！通常大家都会对既没有社会性也没有协调性，或者说根本就不适合劳动的人说‘你适合当创作者’对吧！就跟这是同样的道理！给我记住！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯！通常大家都會對既沒有社會性也沒有協調性，或者說根本就不適合勞動的人說『你適合當創作者』對吧！就跟這是同樣的道理！給我記住！」",
					{"rt2"},
				},
			},
