		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1059", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Welcome home, Bro. You're looking pretty worn out... are you okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你回来啦哥哥……看起来破破烂烂的……没事吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你回來啦哥哥……看起來破破爛爛的……沒事吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00153",
		linknext = "0056_00155",
		line = 2090,
	},
	["0056_00155"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... I just got my clothes dirty. No big deal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……衣服虽然脏了，但没什么大不了的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……衣服雖然髒了，但沒什麼大不了的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00154",
		linknext = "0056_00156",
		line = 2102,
	},
	["0056_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“For someone who trains as much as I do, the SS training is childs play.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“SS的训练程度，对我来说就像儿戏。”",
