	["0056_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After finishing the pancake, Wata-chan offered to give me a shoulder massage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吃完松饼后，过了一会儿让渡酱帮忙捶肩膀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吃完鬆餅後，過了一會讓渡醬幫忙捶肩膀。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00206",
		linknext = "0056_00208",
		line = 2789,
	},
	["0056_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The feel of her soft, tiny hands on my shoulders is wonderful. With every move she makes, I can feel myself becoming reenergized.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她小巧柔软的手的触感绝妙，每次被敲打时，身体的疲劳就会减轻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她小巧柔軟的手的觸感絕妙，每次被敲打時，身體的疲勞就會減輕。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00207",
		linknext = "0056_00209",
		line = 2799,
	},
	["0056_00209"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1026", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ehehe, I've always been good at this. Grandpa and Grandma would be delighted whenever I gave them shoulder massage coupons.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……我从以前开始就很擅长捶肩膀了，给了爷爷和奶奶捶捶肩膀劵他们也非常高兴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……我從以前開始就很擅長捶肩膀了，給了爺爺和奶奶搥搥肩膀劵他們也非常高興。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00208",
		linknext = "0056_00210",
		line = 2813,
	},
