	},
	["0056_00179"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1016", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah yes, an excellent choice. That blissful sweetness, the fluffy texture... here, say 'aaah'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦哦，好选择。松饼不错啊，有幸福的味道……那我喂给你吃，来，张嘴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦哦，好選擇。鬆餅不錯啊，有幸福的味道……那我餵給你吃，來，張嘴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00178",
		linknext = "0056_00180",
		line = 2397,
	},
	["0056_00180"] = {
