				{"vo", file="asane1056", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Don't worry about me. I've got a decoy if I need one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“反正就算有个万一也有个诱饵在……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「反正就算有個萬一也有個誘餌在……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00022",
		linknext = "0056_00024",
		line = 291,
	},
	["0056_00024"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
