	["0056_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The first training session is a general aptitude examination, usually referred to as the 'sports test'.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第一天首先看个人的适性，虽然说是适性检查，但其实跟体育测试一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第一天首先看個人的適性，雖然說是適性檢查，但其實跟體育測試一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00054",
		linknext = "0056_00056",
		line = 757,
	},
	["0056_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The test covers endurance, hand-to-hand combat, hidden potential, intelligence, judgment, cooperation—pretty much anything that could impact our performance going forward.",
					{"rt2"},
				},
			},
			cn = {
				{
					"耐力、格斗能力、躲藏能力、智力、判断力、协调性等——好像要等他们掌握各项数值之后，才能进入选拔训练。",
					{"rt2"},
				},
			},
			tw = {
				{
					"耐力、格鬥能力、躲藏能力、智力、判斷力、協調性等——好像要等他們掌握各項數值之後，才能進入選拔訓練。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00055",
		linknext = "0056_00057",
		line = 767,
	},
	["0056_00057"] = {
		{"bg", id=1, file="bg17_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00109", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0148", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Uh, umm... Rei-senpai, here... these are the results of Tachibana-kun's aptitude assessment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“呃……礼前辈，请……这是橘君的适性检查结果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「呃……禮前輩，請……這是橘君的適性檢查結果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00056",
		linknext = "0056_00058",
		line = 781,
	},
	["0056_00058"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=300},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00112", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
