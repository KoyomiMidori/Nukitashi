	["0056_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You know it. I can't stand idly by and allow crime to run rampant on this island. People must not be forced to have sex without consent.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然。在岛上发生的犯罪行为——强迫性行为等，是绝对不能原谅的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然。在島上發生的犯罪行為——強迫性行為等，是絕對不能原諒的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00010",
		linknext = "0056_00012",
		line = 147,
	},
	["0056_00012"] = {
		{"text"},
		text = {
