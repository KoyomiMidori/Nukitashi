			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“All right, all right, that's enough. They say confidence is the most important thing, so maybe just act like you belong and you won't stand out too much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好了好了适可而止吧……不过既然首先想获得信任的话，就以不要太引人注目的程度努力吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好了好了適可而止吧……不過既然首先想獲得信任的話，就以不要太引人注目的程度努力吧。」",
					{"rt2"},
				},
			},
		},
