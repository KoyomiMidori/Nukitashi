	["0056_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Believe it or not, she gets lonely really easily. Maybe Wata-chan is like a big sister for her.",
