			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“It's nothing. Tachibana-kun worked so hard that I want to give you a reward. Say aah ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事没事。要好好给努力的橘君奖励。来，啊——♪”",
