					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was no big deal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么大不了的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼大不了的。」",
