			},
		},
		linkback = "0056_00017",
		linknext = "0056_00019",
		line = 229,
	},
	["0056_00019"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Starting tomorrow, I'll be doing SS training after school.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……今后，我要接受SS的训练，所以回家时间会很晚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……今後，我要接受SS的訓練，所以回家時間會很晚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00018",
		linknext = "0056_00020",
		line = 241,
	},
	["0056_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We won't be able to all go home together like we normally do. Will you guys be all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以就不能像之前一样跟大家一起放学了……没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以就不能像之前一樣跟大家一起放學了……沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00019",
		linknext = "0056_00021",
		line = 253,
	},
	["0056_00021"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00112", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1859", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Idiot, you don't have to worry about us. I've been running away for a much longer time than you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨——蛋，不需要担心别人。我逃的时间可是比新来的你要更久……没什么问题的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨——蛋，不需要擔心別人。我逃的時間可是比新來的你要更久……沒什麼問題的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00020",
		linknext = "0056_00022",
		line = 267,
	},
	["0056_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess... Asa-chan, you think you'll be okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也是呢……麻沙酱你呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也是呢……麻沙醬你呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00021",
		linknext = "0056_00023",
		line = 278,
	},
	["0056_00023"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00120", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
