	["0056_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan can be pretty introverted, so you don't see her playing with someone IRL that often.",
					{"rt2"},
				},
			},
			cn = {
				{
					"家里蹲的麻沙酱在现实和人玩游戏真是少见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"家裡蹲的麻沙醬在現實和人玩遊戲真是少見。",
					{"rt2"},
				},
