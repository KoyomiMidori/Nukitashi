		{"bg", id=1, file="bg19_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1066", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I thought that bear would be like the squirrel she's got, but that one's way fancier.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那个，我以为和渡酱挂在书包上的松鼠是一样的……但松鼠做得比较好呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那個，我以為和渡醬掛在書包上的松鼠是一樣的……但松鼠做得比較好呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00258",
		linknext = "0056_00260",
		line = 3438,
	},
	["0056_00260"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It really is. Maybe her mom made it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“确实……那应该是她妈妈给她做的东西吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「確實……那應該是她媽媽給她做的東西吧？」",
