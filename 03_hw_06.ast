		{"text"},
		text = {
			vo = {
				{"vo", file="asane1062", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Heh, I was losing my shit yesterday when my rank dropped, but killing noobs is always good stress release.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……嘿嘿……虽然昨天汇率暴跌差点疯了，但是好久没有狩猎了，感觉真棒……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……嘿嘿……雖然昨天匯率暴跌差點瘋了，但是好久沒有狩獵了，感覺真棒……」",
					{"rt2"},
				},
