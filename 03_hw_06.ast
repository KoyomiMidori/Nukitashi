		{"text"},
		text = {
			vo = {
				{"vo", file="rei0250", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Did he snuff it? Geez. What an ideal combo of willing spirit and weak flesh he's turned out to be. Relief squad, take care of him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“晕倒了吗……真是的，只有气势还算可以，但离实战还很远……救护班，去照看他。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「暈倒了嗎……真是的，只有氣勢還算可以，但離實戰還很遠……救護班，去照顧他。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00139",
		linknext = "0056_00141",
		line = 1838,
	},
	["0056_00141"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
