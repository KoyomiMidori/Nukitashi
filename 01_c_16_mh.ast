		{"bg", id=18, file="khcg06_00006", x=0, y=0, path=":cg/khcg06/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0136", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
