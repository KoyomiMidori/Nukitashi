	},
	["0019_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori se sonroja tanto que iguala al rojo del cielo vespertino. Me saluda con la mano mientras la miro con recelo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着脸红程度堪比夕阳的畔挥舞着双手，我困惑地歪头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著臉紅程度堪比夕陽的畔揮舞著雙手，我困惑地歪頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00172",
