	},
	["0019_00160"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No... no te preocupes. Fue bastante antipático que me pusiera tan nervioso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……别在意。我才是，让你看到那么惊慌失措的样子，真是太逊了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……別在意。我才是，讓你看到那麼驚慌失措的樣子，真是太遜了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00159",
		linknext = "0019_00161",
		line = 2065,
	},
	["0019_00161"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0177", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, yo también andaba mal...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，我那时候也不淡定……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，我那時候也不淡定……」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00160",
		linknext = "0019_00162",
		line = 2079,
	},
	["0019_00162"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora que lo pienso, dijiste cosas bastante descabelladas y estabas nerviosa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说跟日常的畔相比，那时用的词汇确实都比较粗暴呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說跟日常的畔相比，那時用的詞彙確實都比較粗暴呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00161",
		linknext = "0019_00163",
		line = 2091,
	},
	["0019_00163"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0178", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“L-Lo siento... No sé si me invadió el deseo... o si no quería perder mi oportunidad... Mmmm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对、对不起……应该是欲望出来了……或者该说是看到眼前的机会而失去了自我……呜呜……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對、對不起……應該是慾望出來了……或者該說是看到眼前的機會而失去了自我……嗚嗚……」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00162",
		linknext = "0019_00164",
		line = 2106,
	},
	["0019_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No escuché lo que dijo, pero en ese momento, no poseía nada básico ni elegante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我虽然听不太清楚，但当时的畔不是平常那个安静又不起眼的她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我雖然聽不太清楚，但當時的畔不是平常那個安靜又不起眼的她。",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00163",
		linknext = "0019_00165",
		line = 2116,
	},
	["0019_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debió sentirse muy nerviosa al estar atada de esa manera. La hice pasar por algo imperdonable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被那样拘束一定很慌张吧。对她做了不好的事情呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被那樣拘束一定很慌張吧。對她做了不好的事情呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00164",
		linknext = "0019_00166",
		line = 2126,
	},
	["0019_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero ¿cómo es que se desbloqueó cuando leíste ese libro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，那时候为什么只是读书锁就解开了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，那時候為什麼只是讀書鎖就解開了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00165",
		linknext = "0019_00167",
		line = 2138,
	},
	["0019_00167"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0179", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Eh? En pocas palabras, era una herramienta para amplificar mi poder.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯？那个简单的来说就是一个增强力量的道具。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯？那個簡單的來說就是一個增強力量的道具。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00166",
		linknext = "0019_00168",
		line = 2152,
	},
	["0019_00168"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Herramienta...? ¿Qué es ese libro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“道具……？那本书到底是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「道具……？那本書到底是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00167",
		linknext = "0019_00169",
		line = 2164,
	},
	["0019_00169"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0180", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Ese libro es la mejor obra literaria que puedes encontrar en la editorial de la Isla Seiran!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那本书，是青蓝岛出版社的出版物，就算将格局放大来看，也是部伟大的文学作品……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那本書，是青藍島出版社的出版物，就算將格局放大來看，也是部偉大的文學作品……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00168",
		linknext = "0019_00170",
		line = 2178,
	},
	["0019_00170"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿El cierre se deshizo porque leíste una obra literaria...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要读了文学作品就能解锁吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要讀了文學作品就能解鎖嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00169",
		linknext = "0019_00171",
		line = 2190,
	},
	["0019_00171"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0181", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sí, ahora puedo... absorberme tanto en la lectura y levantarme sin usar la mano...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯嗯，那是因为……在经过多次阅读之后，我已经达到连手不需要用的境界了……嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯嗯，那是因為……在經過多次閱讀之後，我已經達到連手不需要用的境界了……嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00170",
		linknext = "0019_00172",
		line = 2205,
	},
	["0019_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Mm?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00171",
