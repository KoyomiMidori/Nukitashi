					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Estoy pensando que si toco estas tetazas, las de Wata-chan me parecerán bidimensionales para siempre!”",
