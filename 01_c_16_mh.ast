	},
	["0019_00161"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0177", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, I was quite out of sorts too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，我那时候也不淡定……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，我那時候也不淡定……」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00160",
		linknext = "0019_00162",
		line = 2079,
	},
	["0019_00162"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come to think of it, you said some pretty wild things and were quite flustered.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说跟日常的畔相比，那时用的词汇确实都比较粗暴呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說跟日常的畔相比，那時用的詞彙確實都比較粗暴呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00161",
		linknext = "0019_00163",
		line = 2091,
	},
	["0019_00163"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0178", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“S-Sorry... I don't know if I was overcome by desire... or didn't want to lose my chance, or something... Mumble mumble...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对、对不起……应该是欲望出来了……或者该说是看到眼前的机会而失去了自我……呜呜……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對、對不起……應該是慾望出來了……或者該說是看到眼前的機會而失去了自我……嗚嗚……」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00162",
		linknext = "0019_00164",
		line = 2106,
	},
	["0019_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn't really hear what she said, but there was nothing plain or graceful about her at the time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我虽然听不太清楚，但当时的畔不是平常那个安静又不起眼的她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我雖然聽不太清楚，但當時的畔不是平常那個安靜又不起眼的她。",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00163",
		linknext = "0019_00165",
		line = 2116,
	},
	["0019_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must have been flustered about being bound like that. I put her through something unforgivable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被那样拘束一定很慌张吧。对她做了不好的事情呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被那樣拘束一定很慌張吧。對她做了不好的事情呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00164",
		linknext = "0019_00166",
		line = 2126,
	},
	["0019_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But how come it unlocked when you read that book back there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，那时候为什么只是读书锁就解开了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，那時候為什麼只是讀書鎖就解開了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00165",
		linknext = "0019_00167",
		line = 2138,
	},
	["0019_00167"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0179", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Putting it simply, that was a tool for amplifying my power.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯？那个简单的来说就是一个增强力量的道具。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯？那個簡單的來說就是一個增強力量的道具。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00166",
		linknext = "0019_00168",
		line = 2152,
	},
	["0019_00168"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tool...? What on earth is that book?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“道具……？那本书到底是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「道具……？那本書到底是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00167",
		linknext = "0019_00169",
		line = 2164,
	},
	["0019_00169"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0180", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That book is the greatest literary work of all time to come out of the Seiran Island publisher!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那本书，是青蓝岛出版社的出版物，就算将格局放大来看，也是部伟大的文学作品……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那本書，是青藍島出版社的出版物，就算將格局放大來看，也是部偉大的文學作品……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00168",
		linknext = "0019_00170",
		line = 2178,
	},
	["0019_00170"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The lock came undone from you reading a work of literature...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要读了文学作品就能解锁吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要讀了文學作品就能解鎖嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00169",
		linknext = "0019_00171",
		line = 2190,
	},
	["0019_00171"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0181", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, now I can... just get so absorbed in reading it that I can push myself over without my hand...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯嗯，那是因为……在经过多次阅读之后，我已经达到连手不需要用的境界了……嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯嗯，那是因為……在經過多次閱讀之後，我已經達到連手不需要用的境界了……嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00170",
		linknext = "0019_00172",
		line = 2205,
	},
	["0019_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00171",
		linknext = "0019_00173",
		line = 2216,
	},
	["0019_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori blushes so much she's a match for the reddening evening sky. She waves at me while I look at her doubtfully.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着脸红程度堪比夕阳的畔挥舞着双手，我困惑地歪头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著臉紅程度堪比夕陽的畔揮舞著雙手，我困惑地歪頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00172",
