		{"bg", id=18, file="khcg06_00007", x=0, y=0, path=":cg/khcg06/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0139", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡¿Estoy sudando tanto que se te resbalan los dedos?! ¡Perdón por intentar imitar una sopa de miso con cerdo salado!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“还是说我流的汗太多会让手指打滑吗……！？对不起，我就像个一直流猪汤还给自己撒盐的人……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「還是說我流的汗太多會讓手指打滑嗎……！？對不起，我就像個一直流豬湯還給自己撒鹽的人……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00054",
