		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg18_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm11", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right, we need to review our current combat ability in order to decide what kinds of TAEs to develop.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，为了开发T-A-E——还是先整理一下目前的战斗力比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，為了開發T-A-E——還是先整理一下目前的戰鬥力比較好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00135",
		linknext = "0112_00137",
		line = 1975,
	},
	["0112_00137"] = {
		{"se", id=0, loop=0, file="se_a122"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I boot up my computer and go into the database.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我打开电脑，访问数据库。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我打開電腦，訪問數據庫。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00136",
		linknext = "0112_00138",
		line = 1986,
	},
	["0112_00138"] = {
		{"se", id=0, loop=0, file="se_a118"},
		{"bg", id=1, file="bg18_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2165", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Personally, I'm not too concerned about that... Our enemy search capability is the bigger issue, I'd say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我在考虑的虽然不是战斗方面……主要是索敌能力的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我在考慮的雖然不是戰鬥方面……主要是索敵能力的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00137",
		linknext = "0112_00139",
		line = 2002,
	},
	["0112_00139"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The multi-story limitation, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道是多楼层那件事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道是多樓層那件事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00138",
		linknext = "0112_00140",
		line = 2014,
	},
	["0112_00140"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2166", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah. I heard from Asa when we infiltrated the OSS headquarters, but doesn't my role often consist of being the advance guard and creating confusion?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯。我想你应该从麻沙酱那里听说过潜入SHO总部的事了吧……我的工作大多都是打头阵扰乱敌人不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯。我想你應該從麻沙醬那裡聽說過潛入SHO總部的事了吧……我的工作大多都是打頭陣擾亂敵人不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00139",
		linknext = "0112_00141",
		line = 2029,
	},
	["0112_00141"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2167", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Like, I can plan it all out in my head, so it's no problem for me, but there's gonna a delay involved in getting it through to you. It's not so bad when you've got your goggles, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“因为那是我自己脑子里的想法所以没问题，但是要告诉接下来跟过来的淳们，还是会有时间差出现。有护目镜的时候倒是没什么问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為那是我自己腦子裡的想法所以沒問題，但是要告訴接下來跟過來的淳們，還是會有時間差出現。有護目鏡的時候倒是沒什麼問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00140",
		linknext = "0112_00142",
		line = 2041,
	},
	["0112_00142"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's true. What's more, you take independent action and create confusion of your own volition...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得也是。如果你为了搅乱敌方而单独行动的话——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得也是。如果你為了攪亂敵方而單獨行動的話——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00141",
		linknext = "0112_00143",
		line = 2053,
	},
	["0112_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's fair to say our combat capability is extremely low.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的战斗力将会极端地下降。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的戰鬥力將會極端地下降。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00142",
		linknext = "0112_00144",
		line = 2063,
	},
	["0112_00144"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2168", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“If I expand on that, when I've been in the lead and fighting broke out, I needed to move to the rear or a flanking position.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“还有就是，如果是在我打头阵的情况下开始战斗，那我就必须移动到边锋位置进行从背后或侧面的挟撃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「還有就是，如果是在我打頭陣的情況下開始戰鬥，那我就必須移動到邊鋒位置進行從背後或側面的挾撃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00143",
		linknext = "0112_00145",
		line = 2078,
	},
	["0112_00145"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“However, once you're fighting, our enemy search capability drops, and then you'll have to return to your designated advance guard position.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，现状是如果奈奈濑战斗的话，索敌能力就会下降，所以就必须回到我们的前方是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，現狀是如果奈奈瀨戰鬥的話，索敵能力就會下降，所以就必須回到我們的前方是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00144",
		linknext = "0112_00146",
		line = 2090,
	},
	["0112_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That means we need Ariadne Protocol to be functional at all times for Nanase to operate at her maximum capability.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了让奈奈濑完美地发挥作用，“Ariadne协议”必须随时有效……",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了讓奈奈瀨完美地發揮作用，「Ariadne協議」必須隨時有效……",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00145",
		linknext = "0112_00147",
		line = 2100,
	},
	["0112_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why it's urgent we improve the software functionality, as Nanase says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，正如奈奈濑所说，软件的改良是迫在眉睫的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，正如奈奈瀨所說，軟體的改良是迫在眉睫的。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00146",
		linknext = "0112_00148",
		line = 2110,
	},
	["0112_00148"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The hardware is currently unable to keep up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……从目前来看，硬件方面是跟不上的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……從目前來看，硬體方面是跟不上的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00147",
		linknext = "0112_00149",
		line = 2122,
	},
	["0112_00149"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How are the goggles meant to function in places where there are no GPS signals or cameras?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在没有GPS跟摄像头的地方，该如何让护目镜起作用……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在沒有GPS跟攝影機的地方，該如何讓護目鏡起作用……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00148",
		linknext = "0112_00150",
		line = 2134,
	},
	["0112_00150"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2169", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I guess we need to implement something equivalent to the camera input in an ergonomic way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“也就是说，要用更没有违和感的形式安装上与摄像头相同的东西，这应该是当务之急吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「也就是說，要用更沒有違和感的形式安裝上與攝影機相同的東西，這應該是當務之急吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00149",
		linknext = "0112_00151",
		line = 2148,
	},
	["0112_00151"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2170", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“If we intend to take on an organization which so greatly outnumbers us, we can't let the battle info get through to them. Which would mean...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“如果我们这种少人数的队伍想战胜巨大组织的话，就需要对方无法将战斗情报传递到后方。也就是说——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「如果我們這種少人數的隊伍想戰勝巨大組織的話，就需要對方無法將戰鬥情報傳遞到後方。也就是說——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00150",
		linknext = "0112_00152",
		line = 2162,
	},
	["0112_00152"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We need to bring our battles to a conclusion as quickly as possible, i.e., we need to increase the speed of our attacks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“马上结束战斗并突破——战斗的高速化是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「馬上結束戰鬥並突破——戰鬥的高速化是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00151",
		linknext = "0112_00153",
		line = 2174,
	},
	["0112_00153"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It looks like we need to rethink our battle movements, particularly when it comes to the division of labor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“团队的战斗行动也需要重新考虑呢……特别是分工的部份。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「團隊的戰鬥行動也需要重新考慮呢……特別是分工的部份。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00152",
		linknext = "0112_00154",
		line = 2186,
	},
	["0112_00154"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2171", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah yes, the whole positions thing you brought up before... You're probably right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，就是之前也有说过的有关位置的事吧……嗯，确实是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，就是之前也有說過的有關位置的事吧……嗯，確實是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00153",
		linknext = "0112_00155",
		line = 2203,
	},
	["0112_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The only current roles set out are Nanase as scout, and Asa in ops.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在可以说有固定作用的，只有相当于侦察员的奈奈濑和担任引导员的麻沙酱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在可以說有固定作用的，只有相當於偵察員的奈奈瀨和擔任引導員的麻沙醬。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00154",
		linknext = "0112_00156",
		line = 2213,
	},
	["0112_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There aren't any allocated roles or positions for the other members.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其他成员并没有固定的工作和定位。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其他成員並沒有固定的工作和定位。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00155",
		linknext = "0112_00157",
		line = 2223,
	},
	["0112_00157"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I learned the value of battle formations from my SS training. The shortest route to success is understanding each individual's capabilities.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在FS接受训练后，我更深切地体会到了编队行动的重要性。在此基础上还要让每个人都对战术有相当程度的理解，这才是走向胜利的捷径。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在FS接受訓練後，我更深切地體會到了編隊行動的重要性。在此基礎上還要讓每個人都對戰術有相當程度的理解，這才是走向勝利的捷徑。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00156",
		linknext = "0112_00158",
		line = 2235,
	},
	["0112_00158"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if we do that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，这样的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，這樣的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00157",
		linknext = "0112_00159",
		line = 2247,
	},
	["0112_00159"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2172", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“What's wrong? Is there some big problem with that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么了，有什么大问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼了，有什麼大問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00158",
		linknext = "0112_00160",
		line = 2261,
	},
	["0112_00160"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There won't be any role for me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样的话，我就真的没有能做的工作了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣的話，我就真的沒有能做的工作了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00159",
		linknext = "0112_00161",
		line = 2273,
	},
	["0112_00161"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00160",
		linknext = "0112_00162",
		line = 2286,
	},
	["0112_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's surprisingly little I can do.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我竟然意外地什么都做不了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我竟然意外地什麼都做不了。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00161",
		linknext = "0112_00163",
		line = 2296,
	},
	["0112_00163"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2173", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“H-Hey, you still do a lot for us. I mean, directing us in battle is pretty much your role? You're making yourself stronger, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你、你不也有很多事要做吗……像是作战指挥什么的，都是你的工作啊……？而且还变得更强了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你、你不也有很多事要做嗎……像是作戰指揮什麼的，都是你的工作啊……？而且還變得更強了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00162",
		linknext = "0112_00164",
		line = 2311,
	},
	["0112_00164"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just a little bit! It's too half-assed... it won't be worth a damn sight when I'm going on the offensive!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是有些变强了！但是每一项都马马虎虎……不太能参加进攻——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是有些變強了！但是每一項都馬馬虎虎……不太能參加進攻——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00163",
		linknext = "0112_00165",
		line = 2323,
	},
	["0112_00165"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00115", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2174", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No, directing is a fine job to have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不，指示也是了不起的工作啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不，指示也是了不起的工作啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00164",
		linknext = "0112_00166",
		line = 2338,
	},
	["0112_00166"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wanna be useful on the frontlines too, dammit!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想在前线派上用场！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想在前線派上用場！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00165",
		linknext = "0112_00167",
		line = 2350,
	},
	["0112_00167"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are too few of us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"实际上，我们的人数绝对算不上多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"實際上，我們的人數絕對算不上多。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00166",
		linknext = "0112_00168",
		line = 2360,
	},
	["0112_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So even if I'm the commander, I can't avoid battle myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便是身为指挥官，也不能无所事事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便是身為指揮官，也不能無所事事。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00167",
		linknext = "0112_00169",
		line = 2370,
	},
	["0112_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, my combat capability is unbelievably half-assed, and I don't excel at anything in particular.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是我现在的战斗力，可以说是非常不成熟……没有什么特别突出的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是我現在的戰鬥力，可以說是非常不成熟……沒有什麼特別突出的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00168",
		linknext = "0112_00170",
		line = 2380,
	},
	["0112_00170"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If we had a specialist in each field, that would advance our superiority.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有各种专家的话应该会更有优势吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有各種專家的話應該會更有優勢吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00169",
		linknext = "0112_00171",
		line = 2392,
	},
	["0112_00171"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2175", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pretty much. But what exactly are we currently lacking in?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是没错……但是，如果要说现在还欠缺什么的话，那到底是什么呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是沒錯……但是，如果要說現在還欠缺什麼的話，那到底是什麼呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00170",
		linknext = "0112_00172",
		line = 2406,
	},
	["0112_00172"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I dunno. Our capability in confrontations is lacking. Our specialty is escaping.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……我们在形式上对僵持状态很脆弱。因为我们的专常就是逃跑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……我們在形式上對僵持狀態很脆弱。因為我們的專常就是逃跑。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00171",
		linknext = "0112_00173",
		line = 2418,
	},
	["0112_00173"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can advance and spread out, but that just lowers our combat capability further.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然可以分散前进，但这样战斗力就会下降。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然可以分散前進，但這樣戰鬥力就會下降。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00172",
		linknext = "0112_00174",
		line = 2430,
	},
	["0112_00174"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If only there was a person who could take the role that would allow everyone to advance...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以说如果这种时候，有人能起到即使手段粗暴，也能带领整个队伍前进的作用的话——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以說如果這種時候，有人能起到即使手段粗暴，也能帶領整個隊伍前進的作用的話——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00173",
		linknext = "0112_00175",
		line = 2442,
	},
	["0112_00175"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a140"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……？请进。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……？請進。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00174",
		linknext = "0112_00176",
		line = 2458,
	},
	["0112_00176"] = {
		{"se", id=0, loop=0, file="se_a079"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=700},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=400, y=0, time=900},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0636", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Apologies for interrupting your discussion. Do you mind?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“打扰二位了……有时间吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「打擾二位了……有時間嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00175",
		linknext = "0112_00177",
		line = 2474,
	},
	["0112_00177"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not at all, Fumino. What is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，文乃，怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，文乃，怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00176",
		linknext = "0112_00178",
		line = 2486,
	},
	["0112_00178"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0637", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If you wouldn't mind... I have prepared dinner for you all... I wanted to inform you of that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“在下……准备了晚餐……前来告诉您们……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「在下……準備了晚餐……前來告訴您們……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00177",
		linknext = "0112_00179",
		line = 2501,
	},
	["0112_00179"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
