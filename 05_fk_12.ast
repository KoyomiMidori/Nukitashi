	},
	["0112_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I escorted Hotori and Wata close to their homes, and the rest of us that live in the residential area are left — myself, Asa, Nanase, and now Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把畔和渡酱安全送到家附近后，剩下的是住在住宅区的我、麻沙酱、奈奈濑以及文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把畔和渡醬安全送到家附近後，剩下的是住在住宅區的我、麻沙醬、奈奈瀨以及文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00071",
		linknext = "0112_00073",
		line = 1066,
	},
	["0112_00073"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00101", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0626", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“So you have been escaping from the law in this manner?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……就是这样逃过条例的呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……就是這樣逃過條例的呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00072",
		linknext = "0112_00074",
		line = 1080,
	},
	["0112_00074"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Our activities basically revolve around getting home. Think of us getting home safely as the central point.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们主要的活动基本是‘回家’。所以重点在安全到家这件事上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們主要的活動基本是『回家』。所以重點在安全到家這件事上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00073",
		linknext = "0112_00075",
		line = 1092,
	},
	["0112_00075"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00110", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0627", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Indubitably... That explains why you handled everything so well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“原来原来……所以才会这么熟练……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「原來原來……所以才會這麼熟練……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00074",
		linknext = "0112_00076",
		line = 1107,
	},
	["0112_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, but considering how long you've been experiencing real battles for, this must look like child's play.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，虽然对长时间在实际战斗的文乃来说，也许会觉得是在玩——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，雖然對長時間在實際戰鬥的文乃來說，也許會覺得是在玩——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00075",
		linknext = "0112_00077",
		line = 1119,
	},
	["0112_00077"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00121", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0628", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Oh no, not in the slightest... I am most terribly impressed, in fact.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不，怎么会……文乃很佩服……不愧是橘大人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不，怎麼會……文乃很佩服……不愧是橘大人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00076",
		linknext = "0112_00078",
		line = 1134,
	},
	["0112_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
