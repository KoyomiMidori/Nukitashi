		linkback = "0112_00123",
		linknext = "0112_00125",
		line = 1793,
	},
	["0112_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“One day, I'll become stronger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我总有一天会变强的。”",
