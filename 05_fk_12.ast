	["0112_00197"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00121", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0642", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It would be my pleasure to serve the master of the household... so please allow me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“能侍奉作为主人的您，是文乃的荣耀……所有还请……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「能侍奉作為主人的您，是文乃的榮耀……所有還請……」",
					{"rt2"},
				},
