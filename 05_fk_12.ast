		line = 508,
	},
	["0112_00036"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2139", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hi, Fumino! So, my name's Watarai Hinami. I'm the oldest one here, a third-year student, and everyone's big sis, so if you have any questions, feel free to ask!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“文乃酱！呃，我的名字叫渡会雏见。是我们里面最年长的3年级的大姐姐，有什么不懂的都可以问我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「文乃醬！呃，我的名字叫渡會雛見。是我們裡面最年長的3年級的大姐姐，有什麼不懂的都可以問我！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00035",
		linknext = "0112_00037",
		line = 523,
	},
	["0112_00037"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00109", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="fumino_01m_00007", file1="fumino_01m_00101", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=400, y=0},
				{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0622", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Huh? I-Indubitably... I would appreciate that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“诶？啊……原来……请多关照。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「欸？啊……原來……請多關照。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00036",
		linknext = "0112_00038",
		line = 541,
	},
	["0112_00038"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00114", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2140", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Indubi-wha? She had some weird pauses in there, too. What's indubi-whatever mean, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“原来……？有奇怪的间隔呢，原来是什么意思呢，橘君……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「原來……？有奇怪的間隔呢，原來是什麼意思呢，橘君……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00037",
		linknext = "0112_00039",
		line = 556,
	},
	["0112_00039"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Indubitably. Just think of it like, she's acknowledging that she understands, so keep that in mind when she says it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是虽然同时发现了很多事情，但是理解了之后却没有说出口时的效果音吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是雖然同時發現了很多事情，但是理解了之後卻沒有說出口時的效果音吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00038",
		linknext = "0112_00040",
		line = 568,
	},
	["0112_00040"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00120", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2141", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I-I see... You know your stuff, Tachibana. I'm a grown-up 'lay-dee' too, so I get it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……原、原来如此，真懂啊橘君，我也因为是大人的淑女所以才明白的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……原、原來如此，真懂啊橘君，我也因為是大人的淑女所以才明白的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00039",
		linknext = "0112_00041",
		line = 583,
	},
	["0112_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She totally doesn't. If anything, Fumino's a lot more mature than she is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱根本没有明白吧，我反而觉得文乃才是大人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬根本沒有明白吧，我反而覺得文乃才是大人。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00040",
		linknext = "0112_00042",
		line = 593,
	},
	["0112_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At any rate, all of our team members seem to have opened up to her without problem.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之，她似乎能和我们的成员融洽相处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之，她似乎能和我們的成員融洽相處。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00041",
		linknext = "0112_00043",
		line = 603,
	},
	["0112_00043"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right, now the important part is what we do going forward.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么——重要的是接下来的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼——重要的是接下來的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00042",
		linknext = "0112_00044",
		line = 620,
	},
	["0112_00044"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino won't be attending class from the get-go. She'll be coming right to the base.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃从今天开始不能去教室，会直接来基地。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃從今天開始不能去教室，會直接來基地。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00043",
		linknext = "0112_00045",
		line = 633,
	},
	["0112_00045"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We don't really know how much info the OSS has on her, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为我不知道SHO掌握了多少信息——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為我不知道SHO掌握了多少資訊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00044",
		linknext = "0112_00046",
		line = 645,
	},
	["0112_00046"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2142", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So the next course of action would be to find her room and board, huh? She's been in that run-down shrine for a while now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那么，接下来必须考虑的是住的地方吧？到现在为止都住在古老的神社对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那麼，接下來必須考慮的是住的地方吧？到現在為止都住在古老的神社對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00045",
		linknext = "0112_00047",
		line = 659,
	},
	["0112_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can't keep her there, obviously. It's not secure at all, so we can't leave her out there all on her own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是那里不行。不能让她一个人住在没有安全保障的神社里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是那裡不行。不能讓她一個人住在沒有安全保障的神社裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00046",
		linknext = "0112_00048",
		line = 671,
	},
	["0112_00048"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It wouldn't be unfeasible for her to just reside here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从现实角度考虑，一直待在这里會比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從現實角度考慮，一直待在這裡會比較好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00047",
		linknext = "0112_00049",
		line = 683,
	},
	["0112_00049"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she's been all alone up until now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——但是，文乃迄今为止一直是一个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——但是，文乃迄今為止一直是一個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00048",
		linknext = "0112_00050",
		line = 695,
	},
	["0112_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And now that she's joined our team, are we really going to go back to leaving her on her own again?",
					{"rt2"},
				},
			},
			cn = {
				{
					"現在都加入队伍了，还要让她一个人待着吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在都加入隊伍了，還要讓她一個人待著嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00049",
		linknext = "0112_00051",
		line = 705,
	},
	["0112_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not a chance. We can't have her cooped up in here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把她关在这么漆黑的地方——這樣不好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把她關在這麼漆黑的地方——這樣不好。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00050",
		linknext = "0112_00052",
		line = 715,
	},
	["0112_00052"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is probably our best bet, then... Fumino, you'll be under my roof from now on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然，应该这样做才对……文乃，从今天开始你就是我们家的孩子了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然，應該這樣做才對……文乃，從今天開始你就是我們家的孩子了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00051",
		linknext = "0112_00053",
		line = 727,
	},
	["0112_00053"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00109", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0623", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“诶……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「欸……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00052",
		linknext = "0112_00054",
		line = 741,
	},
	["0112_00054"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00112", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1621", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What!? Hold your horses, Bro! Do you know what you're on about? You're gonna let this complete stranger live under our roof?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶……！？等等等一下，哥哥……！？你突然说什么呢，要收养一个素不相识的孩子……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸……！？等等等一下，哥哥……！？你突然說什麼呢，要收養一個素不相識的孩子……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00053",
		linknext = "0112_00055",
		line = 755,
	},
	["0112_00055"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I decided I would protect her. Please, Asa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我决定要保护这孩子了。麻沙酱，拜托了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我決定要保護這孩子了。麻沙醬，拜託了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00054",
		linknext = "0112_00056",
		line = 767,
	},
	["0112_00056"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1622", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“She's got other options, doesn't she!? Like that pig Hotori's house!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“除了我们还有很多其他的候补吧……！！像是猪……畔同学的家……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「除了我們還有很多其他的候補吧……！！像是豬……畔同學的家……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00055",
		linknext = "0112_00057",
		line = 782,
	},
	["0112_00057"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2007", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, my eldest sister moved out after getting married, so I've got a spare room at home! It'll probably be rowdy, but she won't have to worry about loneliness...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，我们家的话姐姐出嫁了，所以有个房间……虽然有点吵闹，但绝对不会寂寞——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，我們家的話姐姐出嫁了，所以有個房間……雖然有點吵鬧，但絕對不會寂寞——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00056",
		linknext = "0112_00058",
		line = 796,
	},
	["0112_00058"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can't trust her with you, she'll get fat! It's gotta be our place! Come on, Asa, do me a solid here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔家是不行的，会胖。所以只能是我们家。这是哥哥一生的请求，拜托了麻沙酱——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔家是不行的，會胖。所以只能是我們家。這是哥哥一生的請求，拜託了麻沙醬——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00057",
		linknext = "0112_00059",
		line = 808,
	},
	["0112_00059"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
