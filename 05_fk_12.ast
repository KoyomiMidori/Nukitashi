		linknext = "0112_00008",
		line = 97,
	},
	["0112_00008"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2150", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, it only took this long because a certain somebody is slow on the uptake. Nothing for you to worry about, though, Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“说起来，费时间的原因也是因为某个人太迟钝吧？文乃没必要在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「說起來，費時間的原因也是因為某個人太遲鈍吧？文乃沒必要在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00007",
		linknext = "0112_00009",
		line = 111,
	},
	["0112_00009"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
