		line = 1254,
	},
	["0112_00087"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2157", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yo, Jun? If you're going to be taking Fumino in to live with you, how are you going to explain her to the neighbors?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂淳？接下来文乃要和你一起生活了，你打算怎么对邻居说明？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂淳？接下來文乃要和你一起生活了，你打算怎麼對鄰居說明？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00086",
		linknext = "0112_00088",
		line = 1268,
	},
	["0112_00088"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00112", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0629", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Would it be problematic to call me a servant?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果说是佣人会有什么不方便吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果說是傭人會有什麼不方便嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00087",
		linknext = "0112_00089",
		line = 1282,
	},
	["0112_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haha, we're hardly living in the kind of place that needs a servant. That'd just sound suspicious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈，我们家不是那种有佣人的豪宅哦。更会让人起疑心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈，我們家不是那種有傭人的豪宅哦。更會讓人起疑心的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00088",
		linknext = "0112_00090",
		line = 1294,
	},
	["0112_00090"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00113", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0630", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Is that so...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00089",
		linknext = "0112_00091",
		line = 1308,
	},
	["0112_00091"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's see, something plausible... Guess it'd be too sus to say I've got another little sis.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但如果说是多了个妹妹，也会被人怀疑的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但如果說是多了個妹妹，也會被人懷疑的吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00090",
		linknext = "0112_00092",
		line = 1320,
	},
	["0112_00092"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00115", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2158", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, neither her face nor her hair color would match up with you. Probably not a good idea to say she's here on a homestay, either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“脸完全不像，头发的颜色也是……也不能说是来留宿的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「臉完全不像，頭髮的顏色也是……也不能說是來留宿的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00091",
		linknext = "0112_00093",
		line = 1337,
	},
	["0112_00093"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1628", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Heh, I say we tell 'em she was abandoned in a cardboard box nearby. It's close enough to reality and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哼，说是路边纸箱子里捡来的不就好了吗……本来就差不多是这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哼，說是路邊紙箱子裡撿來的不就好了嗎……本來就差不多是這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00092",
		linknext = "0112_00094",
		line = 1352,
	},
	["0112_00094"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How about you shut the fuck up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这也太乱说话了吧你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這也太亂說話了吧你。」",
					{"rt2"},
