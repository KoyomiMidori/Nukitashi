	["0112_00097"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00109", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1629", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Th... The bitch shows her true colors! So that's how she's gonna ensnare Bro, she's an actual witch, come on, hurry up and kick her outta here before she melts your brain!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“露、露出本性了啊这家伙……！？你看她想这样笼络哥哥也就是说她是个魔女，来，不趁现在赶出去的话大脑会被融化掉的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「露、露出本性了啊這傢伙……！？你看她想這樣籠絡哥哥也就是說她是個魔女，來，不趁現在趕出去的話大腦會被融化掉的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00096",
		linknext = "0112_00098",
		line = 1413,
	},
	["0112_00098"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're delusional.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不会融化的。”",
					{"rt2"},
				},
			},
			tw = {
