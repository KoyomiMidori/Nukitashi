	["0112_00116"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2160", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Just try not to fight too much... not like they can help it. Well, see you tomorrow, Jun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“别太常吵架就好了……唉，那也是没办法的事。那么淳，明天见——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「別太常吵架就好了……唉，那也是沒辦法的事。那麼淳，明天見——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00115",
		linknext = "0112_00117",
		line = 1685,
	},
	["0112_00117"] = {
		{"bgm", file="bgm03", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase, sorry to drop this on you, but could you maybe stay here for the day?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不好意思奈奈濑，今天可以请你来我家一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不好意思奈奈瀨，今天可以請你來我家一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00116",
		linknext = "0112_00118",
		line = 1698,
	},
	["0112_00118"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00109", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=5500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2161", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? I wouldn't mind, but what for? Oh, it's about feeding Fumino, isn't it? Well, I'm not getting paid for that, but I suppose—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“咦？是没关系……不过怎么了？啊，文乃的饭是吗？真没办法，那我就当一下志愿者——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「咦？是沒關係……不過怎麼了？啊，文乃的飯是嗎？真沒辦法，那我就當一下義工——」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00117",
		linknext = "0112_00119",
		line = 1716,
	},
	["0112_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, I don't mean that. I just need your help.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，不是的，我想借助你的力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，不是的，我想借用你的力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00118",
		linknext = "0112_00120",
		line = 1728,
	},
	["0112_00120"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When I was fighting Teshima and the others, I came to a realization.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“上次和手嶋战斗，还有和其他人对峙后我才知道的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「上次和手嶋戰鬥，還有和其他人對峙後我才知道的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00119",
		linknext = "0112_00121",
		line = 1742,
	},
	["0112_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've gotten quite a few skills from my SS training. It's probably enough to confront the SS and OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“的确，通过FS的训练，我已经掌握了技术。应该已经具备了一定程度上对抗FS和SHO的能力了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「的確，通過FS的訓練，我已經掌握了技術。應該已經具備了一定程度上對抗FS和SHO的能力了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00120",
		linknext = "0112_00122",
		line = 1754,
	},
	["0112_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But it's nowhere near enough to tackle each person who has a special skill, or a powerful conviction.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，这还远远不及只钻研一个技能的人，和拥有坚定信念的人的力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，這還遠遠不及只鑽研一個技能的人，和擁有堅定信念的人的力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00121",
		linknext = "0112_00123",
		line = 1766,
	},
	["0112_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What I'm saying is, I'm still weak.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说——我还很弱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說——我還很弱。」",
					{"rt2"},
