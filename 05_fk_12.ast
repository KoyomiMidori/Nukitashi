			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No, Fumino. My name is Nanase. We're comrades now, so we have to be on first-name terms. Isn't that right, Jun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不对吧，文乃？我的名字是奈奈濑哦。要成为同伴的话，就得叫下面的名字。对吧，淳？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不對吧，文乃？我的名字是奈奈瀨哦。要成為同伴的話，就得叫下面的名字。對吧，淳？」",
					{"rt2"},
