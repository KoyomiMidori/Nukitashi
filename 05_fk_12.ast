			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Whaaat... Uuurgh... Well, I guess under these circumstances it'd work... But still... Sigh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶诶诶……呜呜呜……情况确实是比较特殊……但是……唉……”",
					{"rt2"},
