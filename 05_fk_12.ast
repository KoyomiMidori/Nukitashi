	["0112_00108"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=100},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00112", file2="fumino_01m_00204", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_01m_00001", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At any rate, I think we can pass her off as my cousin. That's the safest option, so we'll run with that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之——说是我表姐妹的孩子应该就没什么问题了。就这么决定吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之——說是我表姐妹的孩子應該就沒什麼問題了。就這麼決定吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00107",
		linknext = "0112_00109",
		line = 1577,
	},
	["0112_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I manage to change the topic smoothly, in order to divert the feeling of malice towards her from certain other parties.",
					{"rt2"},
				},
			},
			cn = {
				{
					"必须巧妙地掩饰。为了保护她不受周围人的恶意侵害。",
					{"rt2"},
				},
			},
			tw = {
				{
