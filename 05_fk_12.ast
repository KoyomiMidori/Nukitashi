		linknext = "0112_00080",
		line = 1161,
	},
	["0112_00080"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2156", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Heh. Looks like somebody's upset about having her bro stolen away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵，哥哥被抢走了很寂寞吧，麻沙酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呵呵，哥哥被搶走了很寂寞吧，麻沙醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00079",
		linknext = "0112_00081",
		line = 1175,
	},
	["0112_00081"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00112", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="asane_01m_00001", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1626", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“L-Like hell I'm upset about this crazy mixed-up virginfag his pedophilia's so strong at this point the police'd be able to find him and throw him in the slammer with just a damn Geiger counter!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎、怎么可能没有那种事情的那种处女厨扭曲LO男最好拿着放射线指数器时让警察看到然后被逮捕……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎、怎麼可能沒有那種事情的那種處女廚扭曲LO男最好拿著放射線指數器時讓警察看到然後被逮捕……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00080",
		linknext = "0112_00082",
		line = 1192,
	},
	["0112_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, shut up. I'm right here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂麻沙酱我都听见了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂麻沙醬我都聽見了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00081",
		linknext = "0112_00083",
		line = 1204,
	},
	["0112_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And how long are you gonna keep that up, anyway? You could at least try to get along with her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种态度要持续到什么时候啊。你也友好一点啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這種態度要持續到什麼時候啊。你也友好一點啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00082",
		linknext = "0112_00084",
		line = 1216,
	},
	["0112_00084"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00116", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1627", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hmph, she's just boring to talk to anyway. She hardly says anything, it's all stiff and formal, and no fun...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哼……因为跟文乃讲话也很无聊啊……话少，死板，又无趣……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哼……因為跟文乃講話也很無聊啊……話少，死板，又無趣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00083",
		linknext = "0112_00085",
		line = 1231,
	},
	["0112_00085"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00115", file2="fumino_01m_00202", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet she's always worried about talking shit in the presence of a totally different person...",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然在她本人面前说这么尖酸的话，她一直都很在意才对……",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然在她本人面前說這麼尖酸的話，她一直都很在意才對……",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00084",
		linknext = "0112_00086",
		line = 1244,
	},
	["0112_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm gonna have to give this little shit a good talking-to later.",
					{"rt2"},
				},
			},
			cn = {
				{
					"等一下必须好好教训她一番。",
					{"rt2"},
				},
			},
			tw = {
				{
					"等一下必須好好教訓她一番。",
					{"rt2"},
