		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So from now on, I'll take Fumino home with me. In the mornings, I'll bring her here to the base. It'd be dangerous to leave her at home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
