					name = {"ヒナミ", "Hinami"},
					"“Wow, we finally get to meet. I'm so glad!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“终于见到你了，太好了，好高兴啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「終於見到你了，太好了，好高興啊……！」",
