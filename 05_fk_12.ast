			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You are allowing me to stay here... so could you allow me to take care of your needs from now on?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……因为接下来，我要住在这里……今后能不能把您身边的照顾，交给文乃呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……因為接下來，我要住在這裡……今後能不能把您身邊的照顧，交給文乃呢？」",
