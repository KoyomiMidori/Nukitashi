	["0112_00099"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2159", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“F-Fumino? Uh, how to put this... If someone your age is the lover of someone who's Jun's age, well... It could, uh, get you some unwarranted attention?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“文、文乃？呃，怎么说呢，淳这个年龄的男人有你这个年龄的女朋友的话，怎么说呢，会在其他意义上受到注目……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「文、文乃？呃，怎麼說呢，淳這個年齡的男人有你這個年齡的女朋友的話，怎麼說呢，會在其他意義上受到注目……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00098",
		linknext = "0112_00100",
		line = 1440,
	},
	["0112_00100"] = {
