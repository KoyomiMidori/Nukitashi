				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? I could've sworn you two were saying awful things about me just now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……咦？我刚刚是不是差点要听到橘兄妹说过的最难听的话了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
