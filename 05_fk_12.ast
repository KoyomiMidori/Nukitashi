		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With everyone assembled in the NLNS underground base, I clear my throat respectfully.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在全体成员集合的NLNS地下基地中，我怀着敬畏的心情清了清嗓子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在全體成員集合的NLNS地下基地中，我懷著敬畏的心情清了清嗓子。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00002",
		linknext = "0112_00004",
		line = 42,
	},
	["0112_00004"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'd like you all to meet our new team member— Kotoyose Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是我们队的新成员——琴寄文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是我們隊的新成員——琴寄文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00003",
		linknext = "0112_00005",
		line = 54,
	},
	["0112_00005"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00113", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0619", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It is my pleasure to meet you all. My name is Kotoyose Fumino. I humbly look forward to working with you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“初次见面，大家……我叫琴寄文乃……请多关照……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「初次見面，大家……我叫琴寄文乃……請多關照……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00004",
		linknext = "0112_00006",
		line = 69,
	},
	["0112_00006"] = {
