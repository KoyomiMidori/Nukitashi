		linkback = "0112_00124",
		linknext = "0112_00126",
		line = 1805,
	},
	["0112_00126"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I need strength now. I need something to make up the deficit, so I can win in battles even while I'm still weak.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是现在就需要力量了。就算弱小也要想在战斗中取胜的话，就必须用某种东西来弥补。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是現在就需要力量了。就算弱小也要想在戰鬥中取勝的話，就必須用某種東西來彌補。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00125",
		linknext = "0112_00127",
		line = 1817,
	},
	["0112_00127"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And in my case, that'd be our little spy items — TAEs, that is. I need new ones to be able to take them on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对我来说，那就是间谍道具——T-A-E。为了与他们对抗，需要新的道具。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對我來說，那就是間諜道具——T-A-E。為了與他們對抗，需要新的道具。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00126",
		linknext = "0112_00128",
		line = 1829,
	},
	["0112_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're better at using them than me, so I'm gonna need your input.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我需要更擅长操作的你的意见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我需要更擅長操作的你的意見。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00127",
		linknext = "0112_00129",
		line = 1841,
	},
	["0112_00129"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She stares at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑窥探着我的脸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨窺探著我的臉。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00128",
		linknext = "0112_00130",
		line = 1854,
	},
	["0112_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She seems to be looking for something. It's like she's scoping out my inner emotions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像是在探索什么。仿佛在无意中汲取我内心深处的感情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像是在探索什麼。彷彿在無意中汲取我內心深處的感情。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00129",
		linknext = "0112_00131",
		line = 1864,
	},
	["0112_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there's only one thing on my mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我心中只有一个想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我心中只有一個想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00130",
		linknext = "0112_00132",
		line = 1874,
	},
	["0112_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to do whatever it takes to protect that girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了保护那个孩子，必要的事情什么都必须做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了保護那個孩子，必要的事情什麼都必須做。",
					{"rt2"},
				},
			},
