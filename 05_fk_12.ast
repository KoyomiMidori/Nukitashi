	},
	["0112_00183"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We can see a spread of lovely food upon the dining table.",
					{"rt2"},
				},
			},
			cn = {
				{
					"走到餐桌一看，那里摆满了各种美丽的菜肴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"走到餐桌一看，那裡擺滿了各種美麗的菜餚。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00182",
		linknext = "0112_00184",
		line = 2597,
	},
	["0112_00184"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00112", file2="fumino_02m_00202", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="asane_01m_00003", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0638", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Are you all... not accustomed to Japanese-style cuisine?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……各位……日本菜……不怎么吃吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……各位……日本菜……不怎麼吃嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00183",
		linknext = "0112_00185",
		line = 2612,
	},
	["0112_00185"] = {
		{"se", id=0, loop=0, file="se_a157"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, no, that's not what we're surprised about...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，我并不是在惊讶那个……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，我並不是在驚訝那個……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00184",
		linknext = "0112_00186",
		line = 2625,
	},
	["0112_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The dishes are so numerous and magnificent-looking that we're at a loss for words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是眼前这些称得上豪华绚烂的料理，让我们说不出话来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是眼前這些稱得上豪華絢爛的料理，讓我們說不出話來。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00185",
		linknext = "0112_00187",
		line = 2635,
	},
	["0112_00187"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2177", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? What the heck, this is really good! And the presentation is exceptional, too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶……这是什么，味道好极了……！而且外观也很漂亮……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸……這是什麼，味道好極了……！而且外觀也很漂亮……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00186",
		linknext = "0112_00188",
		line = 2653,
	},
	["0112_00188"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're right, the dashi seasoning is perfect. It's subtle, yet tasty. I don't think anything will be left over!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的，汤汁味道完美……明明很淡，但却有香味……完全不觉得是剩饭……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的，湯汁味道完美……明明很淡，但卻有香味……完全不覺得是剩飯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00187",
		linknext = "0112_00189",
		line = 2665,
	},
	["0112_00189"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00116", file2="fumino_02m_00203", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0639", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I am delighted... to hear your praise.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“承蒙夸奖……我感到非常高兴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「承蒙誇獎……我感到非常高興……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00188",
		linknext = "0112_00190",
		line = 2680,
	},
	["0112_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino puts her hand to her chest, looking relieved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃像是松了一口气，把手放在了胸前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃像是鬆了一口氣，把手放在了胸前。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00189",
		linknext = "0112_00191",
		line = 2690,
	},
	["0112_00191"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2178", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“This is no ordinary home cooking. The taste is that out of some kind of culinary training. Where'd you learn to do this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这不是一般的家常菜……比较像是在某个地方进行过烹饪修行的味道……文乃，你是怎么学会的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這不是一般的家常菜……比較像是在某個地方進行過烹飪修行的味道……文乃，你是怎麼學會的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00190",
		linknext = "0112_00192",
		line = 2704,
	},
	["0112_00192"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0640", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“All of the cooking... I learned from Mother when I was young... Mother said she learned from my grandmother as well...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所有料理……都是小时候母亲的教育……我的母亲小时候则是受到祖母的教育……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所有料理……都是小時候母親的教育……我的母親小時候則是受到祖母的教育……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00191",
		linknext = "0112_00193",
		line = 2719,
	},
	["0112_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wonder if they had a family restaurant?",
					{"rt2"},
				},
			},
			cn = {
				{
					"该不会是厨师世家吧？",
					{"rt2"},
				},
			},
			tw = {
				{
					"該不會是廚師世家吧？",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00192",
		linknext = "0112_00194",
		line = 2729,
	},
	["0112_00194"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I feel bad for having you do this as soon as you came here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是对不住，第一天就让你这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是對不住，第一天就讓你這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00193",
		linknext = "0112_00195",
		line = 2741,
	},
	["0112_00195"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
