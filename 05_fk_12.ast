			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The hell you gettin' all bashful with this little brat for my bro's totally into the itty bitty titty...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么对小鬼害羞成这样啊那个洛丽塔自卑哥哥……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼對小鬼害羞成這樣啊那個蘿莉塔自卑哥哥……」",
					{"rt2"},
				},
			},
		},
