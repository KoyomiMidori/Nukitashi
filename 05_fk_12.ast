				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, really? Phew, it doesn't feel so bad hearing you say that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……我也不讨厌被这么说就是了……”",
