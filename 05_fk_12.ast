			},
		},
		text = {
			vo = {
				{"vo", file="nanase2180", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, nothing... Right, Fumino, let's get this cleaned up. I don't think you'd know where to find the cleaning stuff, so I'll show you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不，没什么……来吧文乃，差不多该收拾餐具了。你不知道日用品在哪里吧？我告诉你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不，沒什麼……來吧文乃，差不多該收拾餐具了。你不知道日用品在哪裡吧？我告訴你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00206",
		linknext = "0112_00208",
		line = 2913,
	},
	["0112_00208"] = {
