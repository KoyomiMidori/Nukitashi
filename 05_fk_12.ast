	["0112_00062"] = {
		{"fg", file="fumino_02m_00007", file1="fumino_02m_00121", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0624", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Of course... I do not have any objection... I do not know of anything that could be more fortunate than being with you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“当然……文乃对您说的话没有异议……没有比待在您身边更幸运的事情了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「當然……文乃對您說的話沒有異議……沒有比待在您身邊更幸運的事情了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00061",
		linknext = "0112_00063",
		line = 867,
	},
	["0112_00063"] = {
