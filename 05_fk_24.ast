		{"se", id=3, loop=1, file="se_d016", vol=50},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despite it being nighttime, there is a long queue at the port near the beach.",
					{"rt2"},
				},
			},
			cn = {
				{
					"海滩附近的港口，即使是晚上，也排了长长的队伍。",
					{"rt2"},
				},
			},
			tw = {
				{
					"海灘附近的港口，即使是晚上，也排了長長的隊伍。",
