	["0124_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After I respond to the transmission, I turn back to look in front of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到她的回答后，我挂断电话，再次将视线投向眼前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到她的回答後，我掛斷電話，再次將視線投向眼前。",
