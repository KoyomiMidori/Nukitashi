		linkback = "0124_00051",
		linknext = "0124_00053",
		line = 657,
	},
	["0124_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I, blaming myself for dragging her into this mess, was resolved to save her on my own.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把害她落入绝境当做自己的罪过，试图独自前往救援的我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把害她落入絕境當做自己的罪過，試圖獨自前往救援的我。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00052",
		linknext = "0124_00054",
		line = 667,
	},
	["0124_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps it is precisely because we're so fundamentally alike that I want to rescue her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许正是因为根本的部分很相似，所以我才一直想要拯救她吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許正是因為根本的部分很相似，所以我才一直想要拯救她吧。",
					{"rt2"},
				},
			},
		},
