		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0135", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "警備兵B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Guard B"},
					"“Interior ship unit here. We've discovered some suspicious individuals. Requesting backup at once!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "警备兵B"},
					"“……这里是船内警卫班。发现了可疑人物。请求支援——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "警備兵B"},
					"「……這裡是船內警衛班。發現了可疑人物。請求支援——！」",
