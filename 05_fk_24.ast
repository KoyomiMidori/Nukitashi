					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now then. I'm a registered SS member, and I've put in an application for repatriation. I can take one other person with me as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
