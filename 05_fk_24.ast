		},
		text = {
			vo = {
				{"vo", file="rei1167", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sigh, what a mess! Now what do we do? Maybe we'll go looking for some other scholarship... Miss Touka? Is something the matter?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈啊啊，真是的……！接下来该怎么办……要不要去找其他的奖学金……桐香大人？你怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈啊啊，真是的……！接下來該怎麼辦……要不要去找其他的獎學金……桐香大人？你怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00252",
		linknext = "0124_00254",
		line = 3645,
	},
