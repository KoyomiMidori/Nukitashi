		line = 1663,
	},
	["0124_00125"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0154", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "警備兵A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guard A"},
					"“We need to verify the identity of each passenger coming on board. That also entails searching your belongings. We've had some disturbances recently, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "警备兵A"},
					"“我们现在正在一一检查搭乘的人。顺便检查行李。毕竟最近人心惶惶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "警備兵A"},
					"「我們現在正在一一檢查搭乘的人。順便檢查行李。畢竟最近人心惶惶。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00124",
		linknext = "0124_00126",
		line = 1675,
	},
	["0124_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Two men stand in our way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"两个男人站在我面前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"兩個男人站在我面前。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00125",
		linknext = "0124_00127",
		line = 1685,
	},
	["0124_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shit. Didn't plan for this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"切，没想到会做到这一步——",
					{"rt2"},
				},
			},
			tw = {
				{
					"嘖，沒想到會做到這一步——",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00126",
		linknext = "0124_00128",
		line = 1695,
	},
	["0124_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My name is Tachibana Junnosuke. I'm a second year at Minotsuki Academy, so yeah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的名字是橘淳之介，水乃月学园2年级，然后——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的名字是橘淳之介，水乃月學園2年級，然後——」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00127",
		linknext = "0124_00129",
		line = 1707,
	},
	["0124_00129"] = {
		{"se", id=0, loop=0, file="se_a185", vol=70},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My pockets are absolutely stuffed with TAEs right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的胸口，还有两个口袋里，存放着大量的T-A-E。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的胸口，還有兩個口袋裡，存放著大量的T-A-E。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00128",
		linknext = "0124_00130",
		line = 1718,
	},
	["0124_00130"] = {
		{"text"},
		delay = {
			[500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine", delay2=500},
			},
		},
		text = {
			vo = {
				{"vo", file="bmobb0134", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "警備兵B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Guard B"},
					"“All right, you're good to go. I'm guessing this is your younger sister?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "警备兵B"},
					"“嗯，这样就没问题了。那么，那位是妹妹吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "警備兵B"},
					"「嗯，這樣就沒問題了。那麼，那位是妹妹嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00129",
		linknext = "0124_00131",
		line = 1732,
	},
	["0124_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They wouldn't be confiscated on Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是在青蓝岛的话，并不会被没收。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是在青藍島的話，並不會被沒收。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00130",
		linknext = "0124_00132",
		line = 1742,
	},
	["0124_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But these guys are from the mainland.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但对方是本岛的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但對方是本島的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00131",
		linknext = "0124_00133",
		line = 1752,
	},
	["0124_00133"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, of course. You think a teeny little girl like her would be the same age as me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……嗯，对啊。这么小的孩子怎么会是同学呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……嗯，對啊。這麼小的孩子怎麼會是同學呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00132",
		linknext = "0124_00134",
		line = 1767,
	},
	["0124_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"An ordinary student walking around with these things would absolutely be cause for suspicion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一般学生如果有这种东西，一定会被怀疑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一般學生如果有這種東西，一定會被懷疑。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00133",
		linknext = "0124_00135",
		line = 1777,
	},
	["0124_00135"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like, if this Nabokov novel titular character wannabe was actually older than me, they'd have to put her in suspended animation to preserve her as a scientific marvel and make her sarcophagus a World Heritage Site.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果有这样萝莉的大人应该立刻登录世界遗产为了防止老化让她进入休眠状态。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果有這樣蘿莉的大人應該立刻登錄世界遺產為了防止老化讓她進入休眠狀態。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00134",
		linknext = "0124_00136",
		line = 1792,
	},
	["0124_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I gotta stall for time and get rid of my TAEs, somehow.",
					{"rt2"},
				},
			},
			cn = {
				{
					"必须争取时间，设法处理好T-A-E。",
					{"rt2"},
				},
			},
			tw = {
				{
					"必須爭取時間，設法處理好T-A-E。",
					{"rt2"},
				},
			},
		},
