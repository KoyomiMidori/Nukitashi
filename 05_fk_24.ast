					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seriously, look at her. This short-bodied, washboard-chested, babyfaced little girl clearly has to be my little sister, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么小又这么贫乳童颜的女孩子，怎么可能不是我妹妹——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼小又這麼貧乳童顏的女孩子，怎麼可能不是我妹妹——」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00136",
		linknext = "0124_00138",
		line = 1817,
	},
	["0124_00138"] = {
