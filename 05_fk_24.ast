	["0124_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all, that girl kept fighting on alone, taking everything upon herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把一切都当做自己的责任，一个人战斗的她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把一切都當做自己的責任，一個人戰鬥的她。",
