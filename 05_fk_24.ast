		linkback = "0124_00014",
		linknext = "0124_00016",
		line = 211,
	},
	["0124_00016"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You think I've just been sitting on my hands about this? Also, I could do without the insults.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你以为我什么都没做就沉默着吗……还有不要那么自然地骂我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你以為我什麼都沒做就沉默著嗎……還有不要那麼自然地罵我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00015",
		linknext = "0124_00017",
		line = 223,
	},
	["0124_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not like I've been wasting these past few days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也不是白白度过了这几天。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也不是白白度過了這幾天。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00016",
		linknext = "0124_00018",
		line = 233,
	},
	["0124_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've been weighing up my opportunities.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而是在等待时机。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而是在等待時機。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00017",
		linknext = "0124_00019",
		line = 243,
	},
	["0124_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Refining my plan more thoroughly, for when the time was right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一边规划一边等待迟早会来的机会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一邊規劃一邊等待遲早會來的機會。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00018",
		linknext = "0124_00020",
		line = 253,
	},
	["0124_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though I guess my big declaration of war kinda brought an end to that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然已经因为宣战的关系没办法再等了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然已經因為宣戰的關係沒辦法再等了。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00019",
		linknext = "0124_00021",
		line = 263,
	},
	["0124_00021"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look at this. They're handing this flyer out now. Even saw it at school.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你们看，这是贴在学校的传单。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你們看，這是貼在學校的傳單。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00020",
		linknext = "0124_00022",
		line = 282,
	},
	["0124_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the poster that was up on the wall.",
					{"rt2"},
				},
			},
			cn = {
				{
					"海报也贴出来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"海報也貼出來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00021",
		linknext = "0124_00023",
		line = 292,
	},
	["0124_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"“Special Repatriation Program for Recipients of OSS Special Scholarship Award.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"“SHO特别奖学金获得者特别返乡计划”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「SHO特別獎學金獲得者特別返鄉計劃」。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00022",
		linknext = "0124_00024",
		line = 302,
	},
	["0124_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This applies to any individual who's ever been registered with the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所有有在FS待过的人都是对象。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所有有在FS待過的人都是對象。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00023",
		linknext = "0124_00025",
		line = 314,
	},
	["0124_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I.E., me included.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说——我也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說——我也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00024",
		linknext = "0124_00026",
		line = 326,
	},
	["0124_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Plus, in my case, participation is voluntary. So it wouldn't be impossible for me to get on the boat that's supposed to be taking everyone back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是可以任意选择的。所以我也可以坐这艘船。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是可以任意選擇的。所以我也可以坐這艘船。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00025",
		linknext = "0124_00027",
		line = 338,
	},
	["0124_00027"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00103", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2310", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hold on, they're gonna be splitting this up into multiple groups, right? The top-ranking SS officials have priority for this. If you're a retired member, wouldn't you be on the last—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“等一下，这分为第一梯和第二梯吧？优先顺序不是依照FS的阶级从上往下排吗？那么退伍的淳不就是最后一个吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「等一下，這分為第一梯和第二梯吧？優先順序不是依照FS的階級從上往下排嗎？那麼退伍的淳不就是最後一個嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00026",
		linknext = "0124_00028",
		line = 353,
	},
	["0124_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually, I did some research. Apparently, I've never been formally discharged from active service.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——经调查，我好像没有正式从FS退伍。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——經調查，我好像沒有正式從FS退伍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00027",
		linknext = "0124_00029",
		line = 365,
	},
	["0124_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I definitely recall submitting my letter of resignation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的确提交了退伍申请书。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的確提交了退伍申請書。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00028",
		linknext = "0124_00030",
		line = 375,
	},
	["0124_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So it must have gotten tied up in all the red tape. Or someone up high deliberately ignored it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，有人在某个地方将它拦了下来。或许是想耍奸计吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，有人在某個地方將它攔了下來。或許是想耍奸計吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00029",
		linknext = "0124_00031",
		line = 385,
	},
	["0124_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Whichever it is, that'll work to my advantage here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但这次却因此受惠了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但這次卻因此受惠了。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00030",
		linknext = "0124_00032",
		line = 395,
	},
	["0124_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And of course, I have shutting down the illegal sex industry and rescuing Senator Hitoura on my resume with them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且我有摧毁地下风俗和救出仁浦先生的业绩。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且我有摧毀地下風俗和救出仁浦先生的業績。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00031",
		linknext = "0124_00033",
		line = 406,
	},
	["0124_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those unaware of the situation are likely to want to be allowed to go home first.",
					{"rt2"},
				},
			},
			cn = {
				{
					"比起什么都不知道的人，我一定会成为优先回家的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"比起什麼都不知道的人，我一定會成為優先回家的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00032",
		linknext = "0124_00034",
		line = 416,
	},
	["0124_00034"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1789", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“All right, so you'll get on the ship... and then what?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那么，哥哥坐上这艘船……然后打算干什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那麼，哥哥坐上這艘船……然後打算幹什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00033",
		linknext = "0124_00035",
		line = 429,
	},
	["0124_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll commandeer it and take a little detour over to Sakimori's residence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“夺船。然后直接去防人老人的家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奪船。然後直接去防人老人的家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00034",
		linknext = "0124_00036",
		line = 441,
	},
	["0124_00036"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2106", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You know where he lives...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你知道防人老人的家在哪吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你知道防人老人的家在哪嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00035",
		linknext = "0124_00037",
		line = 456,
	},
	["0124_00037"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Teshima told me. We ran into each other yesterday, so I asked him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我和手嶋见了面，问出来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我和手嶋見了面，問出來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00036",
		linknext = "0124_00038",
		line = 468,
	},
	["0124_00038"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's in the Kanto region, near Yokohama, so not far from the ocean. He's evidently got a real pimp-ass crib up in the mountains that really stands out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“关东横滨，离大海也不远。据说是位于山上的气派宅邸。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「關東橫濱，離大海也不遠。據說是位於山上的氣派宅邸。」",
					{"rt2"},
				},
			},
		},
