					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I should be sorry to you too, Jun. I screwed everything up back there... I just had to go and open my dumb mouth...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“淳君也是，对不起……刚才给你添麻烦了……说了多余的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「淳君也是，對不起……剛才給你添麻煩了……說了多餘的話……」",
					{"rt2"},
				},
			},
		},
