					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, what's done is done. No sense dwelling on it. We have bigger problems now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
