	["0124_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The ship that used to transport tourists to and from the island isn't even in active use now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平时载着游客，飘着“欢迎来到性乱岛”的旗帜的这里，也已经不再被使用了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平時載著遊客，飄著「歡迎來到性亂島」的旗幟的這裡，也已經不再被使用了。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00091",
		linknext = "0124_00093",
		line = 1201,
	},
	["0124_00093"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0152", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "警備兵A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guard A"},
					"“This is the ship for special scholarship students of Minotsuki Academy! The general public are not allowed on board!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "警备兵A"},
					"“这是以在水乃月学园上学的特别奖学金获得者为对象的船！普通人无法利用！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "警備兵A"},
					"「這是以在水乃月學園上學的特別獎學金獲得者為對象的船！普通人無法利用！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00092",
		linknext = "0124_00094",
		line = 1213,
	},
	["0124_00094"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a012"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The former SS students line up obediently, with all the life drained out of their faces.",
					{"rt2"},
				},
			},
			cn = {
				{
					"排队的前FS学生们脸上都失去了精神，乖乖地排成了好几列。",
					{"rt2"},
				},
			},
			tw = {
				{
					"排隊的前FS學生們臉上都失去了精神，乖乖地排成了好幾列。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00093",
		linknext = "0124_00095",
		line = 1225,
	},
	["0124_00095"] = {
		{"se", id=3, loop=1, file="se_d016", vol=25},
		{"bgm", file="bgm14", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, senior of the year. It looks like things have fallen right into place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……成功混进来了呢，渡酱前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……成功混進來了呢，渡醬前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00094",
		linknext = "0124_00096",
		line = 1239,
	},
	["0124_00096"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		delay = {
