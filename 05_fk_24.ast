				{
					name = {"礼", "Rei"},
					"“You expect us to just take you at your word? You're a traitor to us, Tachibana!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……你以为我会轻易相信你说的话吗！？你可是个叛徒，橘！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……你以為我會輕易相信你說的話嗎！？你可是個叛徒，橘！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00189",
		linknext = "0124_00191",
		line = 2641,
	},
	["0124_00191"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I won't deny that. But I was only trying to save Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我不否认。不过，这也是我想帮助文乃所造成的结果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我不否認。不過，這也是我想幫助文乃所造成的結果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00190",
		linknext = "0124_00192",
		line = 2653,
	},
	["0124_00192"] = {
		{"fg", file="rei_01m_00007", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1159", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Do you think I give a damn about that? It's all thanks to you that we're in this situation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“关我什么事！把我们逼到这种境地的人是你！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「關我什麼事！把我們逼到這種境地的人是你！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00191",
		linknext = "0124_00193",
		line = 2668,
	},
	["0124_00193"] = {
		{"fg", file="rei_01m_00007", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1160", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You ought to be satisfied! You've betrayed your companions, stuck to your guns, destroyed the perverted sex law— and THIS is the fruit of your labor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你一定很满足吧！背叛了过去的同伴，贯彻了你的矜持，破坏了变态条例，结果变成现在这样！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你一定很滿足吧！背叛了過去的同伴，貫徹了你的矜持，破壞了變態條例，結果變成現在這樣！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00192",
		linknext = "0124_00194",
		line = 2682,
	},
	["0124_00194"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=2, file="bg20_3l_00000", x=-300, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=10000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She points to the ship's interior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"糺川前辈指着船内。",
					{"rt2"},
				},
			},
			tw = {
				{
					"糺川前輩指著船內。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00193",
		linknext = "0124_00195",
		line = 2703,
	},
	["0124_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Standing there are countless SS members who used to have a livelihood on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那里——有着曾经充满活力，待在青蓝岛上的FS成员们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那裡——有著曾經充滿活力，待在青藍島上的FS成員們。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00194",
		linknext = "0124_00196",
		line = 2713,
	},
	["0124_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They're just standing there, vacantly staring into space.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在他们却都疲惫地望着天空。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在他們卻都疲憊地望著天空。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00195",
		linknext = "0124_00197",
		line = 2723,
	},
	["0124_00197"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=400, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2249", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Umm... what happened to all the SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那个……FS的大家都怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那個……FS的大家都怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00196",
		linknext = "0124_00198",
		line = 2739,
	},
	["0124_00198"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00124", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0640", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Once they announced the abolition of the SS, everybody ended up with random odd jobs, had to prepare to move, got harassed by the media, had their names dragged through the mud, and so on... Not only that, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“宣布FS解散的发表结束后，处理杂务、搬家的准备、媒体的追问、诽谤……发生了很多事……不过比起这些……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「宣布FS解散的發表結束後，處理雜務、搬家的準備、媒體的追問、誹謗……發生了很多事……不過比起這些……」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00197",
		linknext = "0124_00199",
		line = 2753,
	},
	["0124_00199"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00123", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0641", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Plenty of them originally came from troubled homes, just like us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……郁的FS同伴们啊，很多原本家庭里就有问题的孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……郁的FS同伴們啊，很多原本家庭裡就有問題的孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00198",
		linknext = "0124_00200",
		line = 2767,
	},
	["0124_00200"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0642", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Kids who had no parents, who lived in poverty, who suffered physical abuse in orphanages, who were rejected by their families, who couldn't go to school... The SS took them all in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没有父母的孩子、贫穷的孩子、在设施受到暴力的孩子、家族中的眼中钉、在学校没有立足之地的孩子……聚集了一群这样的孩子们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒有父母的孩子、貧窮的孩子、在設施受到暴力的孩子、家族中的眼中釘、在學校沒有立足之地的孩子……聚集了一群這樣的孩子們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00199",
		linknext = "0124_00201",
		line = 2779,
	},
	["0124_00201"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00107", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0643", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hell, I used to live in a run-down dojo myself. I barely had any food as a child... And I've never forgotten the beatings, either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我也是，家里是破破烂烂的道场……小时候几乎连饭都吃不上……经常被揍得稀巴烂……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我也是，家裡是破破爛爛的道場……小時候幾乎連飯都吃不上……經常被揍得稀巴爛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00200",
		linknext = "0124_00202",
		line = 2793,
	},
	["0124_00202"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00125", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hugs herself slightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女部田轻轻地抱住了自己。",
					{"rt2"},
				},
			},
			tw = {
				{
					"女部田輕輕地抱住了自己。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00201",
		linknext = "0124_00203",
		line = 2807,
	},
	["0124_00203"] = {
		{"text"},
		delay = {
			[9500] = {
				{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00128", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=9500, time=300, mode=3, x=-400, y=0},
				{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine", delay2=9500},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0644", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“After we get off this ship... Once we're done swallowing our pride in front of those mass media animals, we'll have to go back to where we came from... Screw that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“等一下下船后……还必须面对很多媒体的闪光灯……好讨厌啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「等一下下船後……還必須面對很多媒體的閃光燈……好討厭啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00202",
		linknext = "0124_00204",
		line = 2822,
	},
	["0124_00204"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=500},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The rest of the SS are in much the same position as her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"坐在那里的FS们也都是一样的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"坐在那裡的FS們也都是一樣的。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00203",
		linknext = "0124_00205",
		line = 2836,
	},
	["0124_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not unreasonable to assume that wherever each of them is being made to return to now, it would not be a place of safety for them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们现在要回去的地方，绝对不得安宁——",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們現在要回去的地方，絕對不得安寧——",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00204",
		linknext = "0124_00206",
		line = 2846,
	},
	["0124_00206"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2250", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jun...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……淳、君……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……淳、君……？」",
					{"rt2"},
