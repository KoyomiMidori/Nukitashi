				{"vo", file="hinami2236", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Eh, I dunno about that either... Say, why not just do Hinami, then? No frills or anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“感觉那个也不太喜欢啊……叫我雏见看看吧？啊，还有不要用敬语哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「感覺那個也不太喜歡啊……叫我雛見看看吧？啊，還有不要用敬語哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00097",
		linknext = "0124_00099",
		line = 1287,
	},
	["0124_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
