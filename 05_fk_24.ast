	},
	["0124_00221"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"bg", id=1, file="bg20_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00002", file1="touka_01m_00109", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2252", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? I mean, look, everyone keeps saying you're gifted and superhuman, but no one knows anything more than that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦？因为你想想，桐香酱一直被大家说成是天才或超人，所以没有人知道更多你的事情对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦？因為你想想，桐香醬一直被大家說成是天才或超人，所以沒有人知道更多你的事情對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00220",
		linknext = "0124_00222",
		line = 3078,
	},
	["0124_00222"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2253", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So you're all sad and frustrated about that, and you want everyone to understand the real you, and stuff...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“所以觉得寂寞难受的桐香酱，才会想让大家知道真正的自己，是这样吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「所以覺得寂寞難受的桐香醬，才會想讓大家知道真正的自己，是這樣吧……？」",
					{"rt2"},
				},
			},
		},
