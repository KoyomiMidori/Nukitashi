	["0124_00100"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2237", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's the spirit, Jun! Heh heh, I was gettin' kinda jealous not being on first name terms with you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，淳君！诶嘿嘿，因为你都喊大家下面的名字，所以我很羡慕呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，淳君！欸嘿嘿，因為你都喊大家下面的名字，所以我很羨慕呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00099",
		linknext = "0124_00101",
		line = 1314,
	},
	["0124_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata... Er, excuse me, Hinami puts on an award-winning smile, seeming oddly happy about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知道在高兴什么，渡酱——雏见露出了满分的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道在高興什麼，渡醬——雛見露出了滿分的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00100",
		linknext = "0124_00102",
		line = 1324,
	},
	["0124_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Brought the chair along again, I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那把椅子，这次也带来了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那把椅子，這次也帶來了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00101",
		linknext = "0124_00103",
		line = 1336,
	},
	["0124_00103"] = {
		{"se", id=0, loop=0, file="se_a155"},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3200] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine", delay2=3200},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami2238", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“With this thing on me, I can take on an army! Like, boom-boom! There's no one whose butt I can't kick with it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“拿着这个的时候，我可是一人抵百人哦！哼哼两声，我就能打败嚣张的敌人……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「拿著這個的時候，我可是一人抵百人哦！哼哼兩聲，我就能打敗囂張的敵人……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00102",
		linknext = "0124_00104",
		line = 1352,
	},
	["0124_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ridiculous though it sounds, I've definitely seen with my own eyes how well she can fight with that chair on her person.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然听起来像是胡扯，但拿着钢管椅的渡酱确实表现出了无比的活跃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然聽起來像是胡扯，但拿著鋼管椅的渡醬確實表現出了無比的活躍。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00103",
		linknext = "0124_00105",
		line = 1362,
	},
	["0124_00105"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2239", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Besides, I figured it'd just be a pain if I didn't have it. Like, all those high-up windows on the ship, or the times when I need to be lookout!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“而且，如果没有这个的话，会有很多困扰的事情吧。你看，船的高处有窗户，所以要警戒的时候能用上！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「而且，如果沒有這個的話，會有很多困擾的事情吧。你看，船的高處有窗戶，所以要警戒的時候能用上！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00104",
		linknext = "0124_00106",
		line = 1376,
	},
	["0124_00106"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I suppose little girls standing on platforms to look out at the sea is a thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，经常有些小女孩会站在上面看海呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，經常有些小女孩會站在上面看海呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00105",
