		},
		linkback = "0124_00185",
		linknext = "0124_00187",
		line = 2586,
	},
	["0124_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS Big Three stand there, waiting to hear the whole story of what's been going on from me.",
