				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2103", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I brought you some ice! Wait, whoa! Look at how swollen that is! Are you all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我拿冰来了——！哇！淳之介同学肿得好厉害啊……！？不要紧吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我拿冰來了——！哇！淳之介同學腫得好厲害啊……！？不要緊吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00005",
		linknext = "0124_00007",
		line = 87,
	},
	["0124_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks to the massive adrenaline rush, I can't feel any pain. Hell, I feel fantastic.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可能是现在肾上腺素分泌过多的缘故吧，完全不会痛，反而状况绝佳。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可能是現在腎上腺素分泌過多的緣故吧，完全不會痛，反而狀況絕佳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00006",
		linknext = "0124_00008",
		line = 99,
	},
	["0124_00008"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00105", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
