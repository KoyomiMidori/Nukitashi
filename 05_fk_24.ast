	["0124_00058"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2107", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Please, don't try to shoulder the entire burden yourself! We're a team, so we're all in this together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“请不要再想着要一个人背负一切了……！要一起同甘共苦，因为我们是一个团队。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
