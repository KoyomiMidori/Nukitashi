				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry. And thanks again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，謝謝你。」",
					{"rt2"},
				},
			},
