		{"fg", file="touka_01m_00002", file1="touka_01m_00110", path=":fg/touka_01m/", id=7, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0884", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now, the rest of the members, you tend to the tied-up guards, attend to the wounded, and be mindful of your safety while we're at sea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“其他可以行动的成员，请负责监视被拘留的警备兵、照顾受伤人员，还有进行海上的警戒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「其他可以行動的成員，請負責監視被拘留的警備兵、照顧受傷人員，還有進行海上的警戒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00238",
		linknext = "0124_00240",
		line = 3379,
	},
	["0124_00240"] = {
