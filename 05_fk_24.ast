			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It is kind of our fault for getting you so worked up, too... So, do you have a plan to rescue Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“煽动他的我们也有错……那么淳，为了夺回文乃，有什么作战计划吗？”",
