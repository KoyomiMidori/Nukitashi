		{"fgact", ch="桐香", id=8, act="移動", x=-400, y=0, time=1000},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2251", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see... So what you want is for people to understand you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊……桐香酱希望别人能好好理解自己呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊……桐香醬希望別人能好好理解自己呢……」",
					{"rt2"},
				},
			},
