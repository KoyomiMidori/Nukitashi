				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, play it down all you want, that looks broken bone-level serious...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，怎么看都是骨头会裂开的重伤哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，怎麼看都是骨頭會裂開的重傷哦……？」",
					{"rt2"},
				},
