			en = {
				{
					name = {"桐香", "Touka"},
					"“I, Reizeiin Touka, through my authority as representative of the SS and student council president... declare that as my final order.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这个任务是FS代表兼学生会长冷泉院桐香的——最后一次命令。”",
