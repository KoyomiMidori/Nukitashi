	["0124_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was my decision to turn Fumino over to him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"决定把文乃送到防人老人那里的人是我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"決定把文乃送到防人老人那裡的人是我。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00042",
		linknext = "0124_00044",
		line = 546,
	},
	["0124_00044"] = {
