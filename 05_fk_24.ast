				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「煽動他的我們也有錯……那麼淳，為了奪回文乃，有什麼作戰計劃嗎？」",
					{"rt2"},
				},
			},
		},
