		linkback = "0124_00205",
		linknext = "0124_00207",
		line = 2859,
	},
	["0124_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami looks at me with unease, and I nod.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见不安地抬头看着我，我点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見不安地抬頭看著我，我點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00206",
		linknext = "0124_00208",
		line = 2869,
	},
	["0124_00208"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki. Forget about the initial SS disembarkation site. Can you take us somewhere else?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——美岬。这艘船的目的地，能改成不是原本FS要下船地点，而是别的目的地吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——美岬。這艘船的目的地，能改成不是原本FS要下船地點，而是別的目的地嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00207",
		linknext = "0124_00209",
		line = 2881,
	},
	["0124_00209"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00114", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2111", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Uh, yes, that's doable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶？啊，可以，那种程度应该不成问题吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸？啊，可以，那種程度應該不成問題吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00208",
		linknext = "0124_00210",
		line = 2894,
	},
	["0124_00210"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="rei_01m_00007", file1="rei_01m_00109", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="rei_01m_00007", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=-400, y=0},
				{"se", id=0, loop=0, file="se_a098", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1161", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And now you throw yourself on the altar of atonement? The gall of you, when you've already taken the only place we belonged away from us! Why should we accept charity from a turncoat like yourself?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你是想要赎罪吗……！？你夺走了我们的容身之处，竟然还这么不要脸！我怎么可能接受叛徒的施舍！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你是想要贖罪嗎……！？你奪走了我們的容身之處，竟然還這麼不要臉！我怎麼可能接受叛徒的施捨！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00209",
		linknext = "0124_00211",
		line = 2913,
	},
	["0124_00211"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00210",
		linknext = "0124_00212",
		line = 2925,
	},
	["0124_00212"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They can say what they like. But this is all I can do for now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管她怎么说，我也只能做到这种程度。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管她怎麼說，我也只能做到這種程度。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00211",
		linknext = "0124_00213",
		line = 2939,
	},
	["0124_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then, the student council prez, having remained quiet for a while now, finally turns to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于是沉默的学生会长，终于抬起了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"於是沉默的學生會長，終於抬起了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00212",
		linknext = "0124_00214",
		line = 2949,
	},
	["0124_00214"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0876", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm not ready to give up on you just yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我也还没打算放弃前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我也還沒打算放棄前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00213",
		linknext = "0124_00215",
		line = 2963,
	},
	["0124_00215"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0877", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“With the kind of good looks you have, whatever happens to the island, I firmly believe you can bring everyone under your control through that junk of yours.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我相信只要有你的器量，无论岛变成什么样子，你也能用那个鸡巴掌握所有人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我相信只要有你的器量，無論島變成什麼樣子，你也能用那個肉棒掌握所有人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00214",
		linknext = "0124_00216",
		line = 2975,
	},
	["0124_00216"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0878", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“When it comes to the communication tool known as sex, it is my hope that people around you will not misunderstand you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因此，我希望你能用做爱这个沟通工具，让周围毫无误解地理解你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因此，我希望你能用做愛這個溝通工具，讓周圍毫無誤會地理解你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00215",
		linknext = "0124_00217",
		line = 2989,
	},
	["0124_00217"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0879", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“After all, my desire is a world where we may all understand each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为我想要的，是个能够互相理解的世界——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為我想要的，是個能夠互相理解的世界——」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00216",
		linknext = "0124_00218",
		line = 3003,
	},
	["0124_00218"] = {
		{"bgm", stop=1},
		{"se", id=3, loop=1, file="se_d016", vol=30},
