			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Aah, I've never had a good laugh like that in all my life! So I'll repay the favor... Rei, round up all our members on this ship and have them follow along with Tachibana here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“啊啊，这是我有生以来第一次这么笑……！作为报答……礼，把能操纵船的队员召集起来，纳入前辈麾下吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「啊啊，這是我有生以來第一次這麼笑……！作為報答……禮，把能操縱船的隊員召集起來，納入前輩麾下吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00229",
		linknext = "0124_00231",
		line = 3220,
	},
