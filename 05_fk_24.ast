				{"vo", file="asane1788", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Seriously, you hit that table so hard you broke the damn thing in two... You're acting like a Z-grade villain now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“话说用尽全力把桌子拍成两半……哥哥，你做的事竟然已经如此像反派角色了吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「話說用盡全力把桌子拍成兩半……哥哥，你做的事竟然已經如此像反派角色了嗎……」",
					{"rt2"},
				},
			},
