	["0124_00041"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00125", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2312", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Get a grip! There's no way you can carry out a plan like that yourself! If you really want to save Fumino, you're gonna have to have a more feasible approach than that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“先想清楚。那样的计划，不可能单独完成吧……！就算想要帮助文乃，不寻求实现的可能性也毫无意义。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「先想清楚。那樣的計劃，不可能單獨完成吧……！就算想要幫助文乃，不尋求實現的可能性也毫無意義。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00040",
		linknext = "0124_00042",
		line = 524,
	},
	["0124_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
