	["0124_00078"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2313", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So Misaki's going to sneak on board with you, then? Wouldn't a big girl like her look suspicious trying to pass as your sister, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那入侵的是美岬？但这么大的妹妹会被怀疑吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那入侵的是美岬？但這麼大的妹妹會被懷疑吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00077",
		linknext = "0124_00079",
		line = 980,
	},
	["0124_00079"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00125", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki, chill out. She doesn't mean 'big' as in 'fat'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是胖的意思所以别情绪低落美岬。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是胖的意思所以別情緒低落美岬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00078",
		linknext = "0124_00080",
		line = 995,
	},
	["0124_00080"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The ship is entirely staffed by Sakimori's cronies. I doubt the passenger list has trickled all the way down to the rank and file, but it may be tricky.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“统筹者都是受雇于防人老人的人。虽然我不认为连基层都能完全掌握信息，但——应该很难吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「統籌者都是受僱於防人老人的人。雖然我不認為連基層都能完全掌握資訊，但——應該很難吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00079",
		linknext = "0124_00081",
		line = 1009,
	},
	["0124_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That said, though, Asane's not coming with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但就算是这样，我也不能把麻沙音带去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但就算是這樣，我也不能把麻沙音帶去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00080",
		linknext = "0124_00082",
		line = 1021,
	},
	["0124_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Her role is to manage all my intel. If she gets put out of commission, that's the end of the team.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“管理情报的妹妹是作战的关键。麻沙音被击溃的瞬间，我们的队伍就崩溃了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「管理情報的妹妹是作戰的關鍵。麻沙音被擊潰的瞬間，我們的隊伍就崩潰了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00081",
		linknext = "0124_00083",
		line = 1033,
	},
	["0124_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So it'll have to be Wata this time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……所以这次我要带渡酱去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……所以這次我要帶渡醬去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00082",
		linknext = "0124_00084",
		line = 1045,
	},
	["0124_00084"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2232", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？我吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？我嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00083",
		linknext = "0124_00085",
		line = 1060,
	},
	["0124_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You can pass for my fake sister, you're able to get around well enough, and in all honesty, as my senior, you're the most ideal person for the job. Can you do this for me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“容易被误认成妹妹，有一定程度的机动能力，能帮助我的人才，除了渡酱前辈以外没有别人——能拜托你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「容易被誤認成妹妹，有一定程度的機動能力，能幫助我的人才，除了渡醬前輩以外沒有別人——能拜託你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00084",
		linknext = "0124_00086",
		line = 1072,
	},
	["0124_00086"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami2233", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Y... Yes, leave it to me! Don't you worry, I'm stronger than I look!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……嗯，交给我吧……！没问题，别看我这样，我可是很强哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……嗯，交給我吧……！沒問題，別看我這樣，我可是很強哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00085",
		linknext = "0124_00087",
		line = 1090,
	},
	["0124_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I nod. There's nothing more reassuring than a confident ally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我点头。没有比有自信的同伴更令人感觉踏实的了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我點頭。沒有比有自信的同伴更令人感覺踏實的了。",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00086",
