	["0124_00229"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0882", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm sorry, that was just too funny...! To think that a little girl like this would understand exactly how I felt, when I didn't quite understand myself... Heh heh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不好意思，总觉得很好笑……！我自己都不明白的内心，竟然被这样的少女说中了……呵呵……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不好意思，總覺得很好笑……！我自己都不明白的內心，竟然被這樣的少女說中了……呵呵……」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00228",
		linknext = "0124_00230",
		line = 3202,
	},
	["0124_00230"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00128", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
