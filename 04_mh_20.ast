		},
		linkback = "0097_00130",
		linknext = "0097_00132",
		line = 2002,
	},
	["0097_00132"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00114", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1800", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? There's something sticking out of Fumino's pocket... I think this is a letter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……咦？文乃酱，怀里有什么东西……嗯……这是信吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……咦？文乃醬，懷裡有什麼東西……嗯……這是信嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00131",
		linknext = "0097_00133",
		line = 2015,
	},
	["0097_00133"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A letter? Sounds like something we need to read.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“信……？你能读一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「信……？你能讀一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00132",
		linknext = "0097_00134",
		line = 2027,
	},
	["0097_00134"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1801", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Let's see... 'I know who you kids are. You've always been acting to try and change the workings of the island. So I only ask that you hear me out.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……我也知道你们的存在。你们从很久以前就在为了改变岛的现状而努力。那么，能听我说吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……我也知道你們的存在。你們從很久以前就在為了改變島的現狀而努力。那麼，能聽我說嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00133",
		linknext = "0097_00135",
		line = 2044,
	},
	["0097_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Clearly it's from someone who knew about us all along.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很久以前就知道我们的事情了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"很久以前就知道我們的事情了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00134",
		linknext = "0097_00136",
		line = 2054,
	},
	["0097_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And if it's talking about 'changing the workings of the island', that must mean our subversion of the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想要改变岛的现状——是指对抗变态条例的我们？",
					{"rt2"},
				},
			},
			tw = {
				{
					"想要改變島的現狀——是指對抗變態條例的我們？",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00135",
		linknext = "0097_00137",
		line = 2064,
	},
	["0097_00137"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1802", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“'Please keep Fumino safe. If you are able to shield her from all this mayhem, then I will accept any demands you have.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“——请你们保护文乃。如果能保护文乃到最后的话，我什么要求都能接受。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「——請你們保護文乃。如果能保護文乃到最後的話，我什麼要求都能接受。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00136",
		linknext = "0097_00138",
		line = 2076,
	},
	["0097_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This letter...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個人——",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00137",
		linknext = "0097_00139",
		line = 2086,
	},
	["0097_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As unlikely as it seems, there's only one person who could have written it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"写这封信的人，难道是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"寫這封信的人，難道是。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00138",
		linknext = "0097_00140",
		line = 2096,
	},
	["0097_00140"] = {
