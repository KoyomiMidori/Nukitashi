	["0097_00007"] = {
		{"bgm", file="bgm02", vol=100},
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1779", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yup. I've hardly seen anyone who still favors the new law lately. Seems like our petition's making the rounds!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊。最近很少看到推动新・变态条例的人了。签名运动的上升趋势好像也很不错！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊。最近很少看到推動新・變態條例的人了。簽名運動的上升趨勢好像也很不錯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00006",
		linknext = "0097_00008",
		line = 204,
	},
	["0097_00008"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's a good sign. The winds of change are coming.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是不错的倾向——开始起风了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是不錯的傾向——開始起風了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00007",
		linknext = "0097_00009",
		line = 216,
	},
	["0097_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just a matter of time, really. At the same time Teshima and his goons have their hooks in the OSS, they're also keeping Fumino hostage in order to coerce Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也是理所当然的——手嶋一边让黑社会和SHO协力，一边将文乃作为人质操纵着仁浦先生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也是理所當然的——手嶋一邊讓黑社會和SHO協力，一邊將文乃作為人質操縱著仁浦先生。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00008",
		linknext = "0097_00010",
		line = 226,
	},
	["0097_00010"] = {
		{"text"},
		text = {
			ja = {
				{
