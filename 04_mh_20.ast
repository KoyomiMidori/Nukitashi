		linknext = "0097_00115",
		line = 1783,
	},
	["0097_00115"] = {
		{"fg", file="ikuko_01m_00002", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0544", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Eeee! Darling, you chicken inspector, you ♪ How's about a little quickie?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呀——亲爱的迷上我了♪要和郁来一发吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呀——親愛的迷上我了♪要和郁來一發嗎？」",
					{"rt2"},
				},
