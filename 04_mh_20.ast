	["0097_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While she's wounded all over, her eye definitely seems to be the most serious.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然全身都有伤，但最严重的还是眼睛的伤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然全身都有傷，但最嚴重的還是眼睛的傷。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00118",
		linknext = "0097_00120",
		line = 1847,
	},
	["0097_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't say for sure myself, but I have no reason to assume Onabuta is lying about her eye...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我对这些事情并不了解——但如果女部田这么说的话，文乃的眼睛或许已经……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我對這些事情並不了解——但如果女部田這麼說的話，文乃的眼睛或許已經……",
					{"rt2"},
				},
			},
