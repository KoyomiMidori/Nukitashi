		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"bg", id=2, file="bg19_1l_00000", x=0, y=-200, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00122", file4="fumino_01l_00402", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Illegitimate child of the governor or not, she doesn't deserve to have this happen to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算文乃是县知事的私生女，也不能让她遭受这样的不幸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算文乃是縣知事的私生女，也不能讓她遭受這樣的不幸。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00129",
		linknext = "0097_00131",
		line = 1992,
	},
	["0097_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's never done anything wrong herself, and yet...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个少女明明没有一点罪过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個少女明明沒有一點罪過。",
					{"rt2"},
