	["0097_00055"] = {
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then, Misaki floors the pedal, and we're off for a little test drive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"踩下油门，开始试运行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"踩下油門，開始試運行。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00054",
		linknext = "0097_00056",
		line = 942,
	},
	["0097_00056"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, she's definitely a smooth ride. Misaki, how's things on your end?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“乘坐的感觉没有问题……美岬，车况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「乘坐的感覺沒有問題……美岬，車況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00055",
		linknext = "0097_00057",
		line = 954,
	},
	["0097_00057"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00102", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1793", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Heh heh, perfect! Handling and steering's like butter. Almost makes me wanna grind those gears and deliver some tofu!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呵呵，非常棒！振动和方向盘的握感都非常出色，让人想乱挂挡呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呵呵，非常棒！振動和方向盤的握感都非常出色，讓人想亂挂擋呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00056",
		linknext = "0097_00058",
		line = 967,
	},
	["0097_00058"] = {
		{"bg", id=3, file="mci_s31", x=-5, y=-5, path=":cg/mci_s/", lv=5, ev=1, time=300, bx=800, by=450},
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", file2="asane_01m_00202", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1519", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So we've gone from speedy speed boy to fatty fat crazy bitch...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“她好像在说非常令人不安的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「她好像在說非常令人不安的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00057",
		linknext = "0097_00059",
		line = 981,
	},
	["0097_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, so far, so good. Just keep your eye on the outside scenery. Never know if we'll run into another puppet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之应该没什么问题吧……别忘了在外面站岗。说不定还有傀儡。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之應該沒什麼問題吧……別忘了在外面站崗。說不定還有傀儡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00058",
		linknext = "0097_00060",
		line = 992,
	},
	["0097_00060"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00114", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1794", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, at this time of day, there's probably not gonna be many people out here... oh? Hmmm? I think I see someone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这个时间的话这一带也变得人烟稀少了……咦？嗯嗯嗯——？那里有人诶……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這個時間的話這一帶也變得人煙稀少了……咦？嗯嗯嗯——？那裡有人欸……？」",
					{"rt2"},
				},
			},
		},
