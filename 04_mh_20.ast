		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00104", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks so much. We owe you one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢……多亏了你，帮大忙了。”",
