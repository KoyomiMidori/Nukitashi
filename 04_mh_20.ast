	},
	["0097_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How'd you pick this skill up? Clearly you're no amateur.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你以前发生过什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你以前發生過什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00107",
		linknext = "0097_00109",
		line = 1695,
	},
	["0097_00109"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00111", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[8000] = {
				{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00129", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0542", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hmm? Well, y'know, I used to get hurt all the time when I was younger. Plus, everyone gets hurt at least once in the SS. So this stuff's like second nature to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯——？就只是以前经常受伤。而且FS的大家也都经常受伤……所以我就学会了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯——？就只是以前經常受傷。而且FS的大家也都經常受傷……所以我就學會了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00108",
		linknext = "0097_00110",
		line = 1711,
	},
	["0097_00110"] = {
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
