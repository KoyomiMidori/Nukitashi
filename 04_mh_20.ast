			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, even assuming she had help... Clearly it didn't go the way they planned.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“就算有人帮忙……照这个样子看来，应该是在哪里走散了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「就算有人幫忙……照這個樣子看來，應該是在哪裡走散了吧。」",
					{"rt2"},
				},
			},
		},
