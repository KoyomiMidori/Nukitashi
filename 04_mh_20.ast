		text = {
			vo = {
				{"vo", file="misaki1789", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hee hee... Shucks, I can't help but get a little bashful about all this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……诶——这就有点不好意思了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……欸——這就有點不好意思了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00039",
		linknext = "0097_00041",
		line = 727,
	},
	["0097_00041"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=17, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="mcg03_l012", x=-630, y=-480, path=":cg/mcg03_l/", lv=5, ev=1, time=1, bx=800, by=450},
		{"cgact", file="cgact", id=17, act="移動", x=-100, y=350, time=10000, lv=5},
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00102", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2069", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You made it, Misaki! I've never had a friend end up on an armored fighting vehicle before. Oh, but Tachibana's always got the coolest equipment!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“美岬酱真厉害啊！我还是第一次有朋友变成装甲战斗车呢。啊，上面还装有很多橘君常用的很酷的武器！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「美岬醬真厲害啊！我還是第一次有朋友變成裝甲戰鬥車呢。啊，上面還裝有很多橘君常用的很酷的武器！」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00040",
		linknext = "0097_00042",
		line = 746,
	},
	["0097_00042"] = {
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's a full-blown combat vehicle, too. Able to shoot her shot when it's needed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在可以发射出去了，因为是战斗车。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在可以發射出去了，因為是戰鬥車。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00041",
		linknext = "0097_00043",
		line = 760,
	},
	["0097_00043"] = {
		{"bg", id=18, file="mcg03_l012", x=-230, y=-480, path=":cg/mcg03_l/", lv=5, ev=1, time=500, bx=800, by=450},
		{"cgact", file="cgact", id=18, act="移動", x=120, y=0, time=10000, lv=5},
		{"fg", file="ikuko_01f_00002", file1="ikuko_01f_00102", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0533", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Kenny was all like, 'if ya aim fer they backs, the shot'll go right threw 'er clothes and up 'er asshole!' He seemed pretty hyped, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“如果瞄准后背就能穿过衣服贯穿肛门——健酱兴致勃勃地这么说过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「如果瞄准後背就能穿過衣服貫穿肛門——健醬興致勃勃地這麼說過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00042",
		linknext = "0097_00044",
		line = 775,
	},
	["0097_00044"] = {
		{"fg", file="misaki_02f_00001", file1="misaki_02f_00118", file2="misaki_02f_00203", path=":fg/misaki_02f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1790", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“G-Goodness... Maybe there's danger in not testing it out beforehand! Want me to be your guinea pig!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那、那个……如果不事先确认它的威力有多大，会很危险的吧！？我来实验一下吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那、那個……如果不事先確認它的威力有多大，會很危險的吧！？我來實驗一下吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00043",
		linknext = "0097_00045",
		line = 788,
	},
	["0097_00045"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=17, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="mcg03012", x=-5, y=-5, path=":cg/mcg03/", lv=5, ev=1, time=1, bx=800, by=450},
		{"fg", file="ikuko_01f_00002", file1="ikuko_01f_00102", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0534", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Already took care of that. That Tsujimoto codger a few doors over wanted to try it out. He ended up passing out for a bit, and when he woke up he was all like, 'Fer a moment I saw me wife agin!'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“已经实验过了。听说三丁目的辻本爷爷想试试。结果他昏迷了一阵子，还说自己见到了好久不见的老婆……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「已經實驗過了。聽說三丁目的辻本爺爺想試試。結果他昏迷了一陣子，還說自己見到了好久不見的老婆……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00044",
		linknext = "0097_00046",
		line = 806,
	},
	["0097_00046"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00118", file2="misaki_01f_00202", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1791", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But I'm pretty sure he's been a bachelor all his life...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个人应该也一直都是单身吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個人應該也一直都是單身吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00045",
		linknext = "0097_00047",
		line = 819,
	},
	["0097_00047"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00114", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1516", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Are you quite sure we have to get in this... thing? Quite frankly, I'd rather kill myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我们一定要搭这辆车吗……？我死都不想坐啊……死了还比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我們一定要搭這輛車嗎……？我死都不想坐啊……死了還比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00046",
		linknext = "0097_00048",
		line = 832,
	},
	["0097_00048"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come on, don't be a killjoy. Okay, so it's kinda gaudy, it shoots dildos, we can stay inside the cabin while it drives itself and jump out, and it's reinforced so bullets won't even put a dent in it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别这么说。虽然外表上看起来有点夸张可以射模拟鸡巴炮还可以从单间里弹出自动驾驶的自行车还有可以抵挡炮击的装甲……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別這麼說。雖然外表上看起來有點誇張可以射模擬肉棒炮還可以從單間裡彈出自動駕駛的自行車還有可以抵擋砲擊的裝甲……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00047",
		linknext = "0097_00049",
		line = 844,
	},
	["0097_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But intrinsically, it's the same as any other Magical Mirror.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但其他地方都只是普通的魔镜号。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但其他地方都只是普通的魔鏡號。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00048",
		linknext = "0097_00050",
		line = 856,
	},
	["0097_00050"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1517", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, this is more like a Cringical Mirror.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不，这已经是疯魔镜号了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不，這已經是瘋魔鏡號了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00049",
		linknext = "0097_00051",
		line = 869,
	},
	["0097_00051"] = {
		{"fg", file="misaki_01f_00001", file2="misaki_01f_00201", file3="misaki_01f_00301", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1792", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Touche! Well, you know what they say, home's where you hang your hat and bat your wang! Once you give it a ride, I'm sure you'll find it comfy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“说得好！不是有句话叫久居则安，久操则鸡嘛……说不定坐上去就觉得意外地舒适呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「說得好！不是有句話叫久居則安，久操則雞嘛……說不定坐上去就覺得意外地舒適呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00050",
		linknext = "0097_00052",
		line = 882,
	},
	["0097_00052"] = {
		{"fg", file="nanase_02f_00001", file1="nanase_02f_00114", file2="nanase_02f_00202", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2067", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sigh. Well, if this is our transportation, I guess we'll just have to grin and bear it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“唉……如果说这就是爱机的话……看来只能坐了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「唉……如果說這就是愛機的話……看來只能坐了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00051",
		linknext = "0097_00053",
		line = 895,
	},
	["0097_00053"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00116", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1518", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What the fuck did we do wrong in our past lives...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我们上辈子都干过那么多坏事吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我們上輩子都幹過那麼多壞事嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00052",
		linknext = "0097_00054",
		line = 908,
	},
	["0097_00054"] = {
		{"bgm", stop=1},
		{"se", id=1, loop=1, file="se_b061", vol=50},
		{"fg", mode=-1, id=30, ch="麻沙音", lv=5},
		{"cgdel", id=17, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=3, file="mci_s31", x=-5, y=-5, path=":cg/mci_s/", lv=5, ev=1, bx=800, by=450},
		{"bg", id=16, file="apstart6_00000", x=0, y=0, lv=5, path=":cg/apstart6/", sync=0, ev=1, time=300, alpha=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"cgact", file="cgact", id=3, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine", lv=5, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everyone gets on board, kvetching all the way to their seats.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管说了一大堆，所有人还是都乘上了爱风。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管說了一大堆，所有人還是都乘上了愛風。",
					{"rt2"},
				},
			},
		},
