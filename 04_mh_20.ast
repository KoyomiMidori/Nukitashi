				},
			},
			en = {
				{
					"Even as she jokes about it, there's no argument to be made about her dexterity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使一边开玩笑，她的手依然十分稳定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使一邊開玩笑，她的手依然十分穩定。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00106",
		linknext = "0097_00108",
