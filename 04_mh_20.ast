	["0097_00123"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=7, time=50, x=0, y=0, alphadel=1, style="reset"},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2068", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But what was she doing out there? I thought she was Teshima's ace in the hole.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是……为什么文乃会在那种地方……她不是手嶋的王牌吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是……為什麼文乃會在那種地方……她不是手嶋的王牌嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00122",
		linknext = "0097_00124",
		line = 1895,
	},
	["0097_00124"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00111", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0546", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hmm... She couldn't have gotten out of there on her own. Maybe somebody helped her out?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯……要一个人从那里逃出来应该是不可能的。是有人帮了忙吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯……要一個人從那裡逃出來應該是不可能的。是有人幫了忙嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00123",
		linknext = "0097_00125",
		line = 1909,
	},
	["0097_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Someone? Like who?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你说有人？”",
					{"rt2"},
				},
			},
