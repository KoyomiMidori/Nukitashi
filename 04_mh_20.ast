				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So which one of them's after her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是说她被其中一方追杀吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是說她被其中一方追殺嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00089",
		linknext = "0097_00091",
		line = 1427,
	},
	["0097_00091"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0537", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Probably both. I don't have any idea how she managed to get out here, but... if she's on the lam with this many injuries, they'll probably be anticipating her at the hospital.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“或许是被这两方——我不知道文乃酱是怎么逃到这里的……但既然把捕捉对象弄成这样了，那医院一定已经被监控住了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「或許是被這兩方——我不知道文乃醬是怎麼逃到這裡的……但既然把捕捉對象弄成這樣了，那醫院一定已經被監控住了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00090",
		linknext = "0097_00092",
		line = 1439,
	},
	["0097_00092"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So if we take her there, she'll just get captured again... Fuck!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是说去了医院又会被抓吗……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是說去了醫院又會被抓嗎……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00091",
		linknext = "0097_00093",
		line = 1451,
	},
	["0097_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now what? Do we storm the hospital and go ham on the goons lying in wait for her?",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么办。要不要打倒那些在医院里等着的人————",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼辦。要不要打倒那些在醫院裡等著的人————",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00092",
		linknext = "0097_00094",
		line = 1461,
	},
	["0097_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, that won't work. That'll just cause us even bigger problems.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，如果引起那么大的骚动，根本就没办法治疗了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，如果引起那麼大的騷動，根本就沒辦法治療了。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00093",
		linknext = "0097_00095",
		line = 1471,
	},
	["0097_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Right now, our utmost priority is to get her somewhere safe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在最该考量的是文乃的安全。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在最該考量的是文乃的安全。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00094",
		linknext = "0097_00096",
		line = 1481,
	},
	["0097_00096"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0538", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We can't stick around here either way. Darling, you've got first-aid stuff at home, right? How about we just take her there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“总之就这样留在这里很危险……亲爱的那里有急救箱吧？先回去吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「總之就這樣留在這裡很危險……親愛的那裡有急救箱吧？先回去吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00095",
		linknext = "0097_00097",
		line = 1493,
	},
	["0097_00097"] = {
