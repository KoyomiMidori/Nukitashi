					{"rt2"},
				},
			},
			en = {
				{
					"She glosses over the question and continues tending to Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随随便便把话题岔开后，女部田继续处理着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨隨便便把話題岔開後，女部田繼續處理著。",
