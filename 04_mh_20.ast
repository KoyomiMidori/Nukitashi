	["0097_00117"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00114", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0545", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Meanie... But in all seriousness, she probably would be better off in a hospital. Most of these injuries should heal in time, but I can't say the same for her eye...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“真坏心眼……其实最好还是带她去医院会比较好。看她这个样子，别的先不说，但眼睛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「真壞心眼……其實最好還是帶她去醫院會比較好。看她這個樣子，別的先不說，但眼睛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00116",
		linknext = "0097_00118",
		line = 1825,
	},
	["0097_00118"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
