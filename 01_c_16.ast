		line = 841,
	},
	["0017_00068"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Walking alongside a girl while she's riding a bike... That's like, a major fictional trope.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和骑自行车的女孩并排走路……这还真是俗套的情景呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和騎自行車的女孩並排走路……這還真是俗套的情景呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00067",
		linknext = "0017_00069",
		line = 853,
	},
	["0017_00069"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg03010103", x=-5, y=-5, path=":cg/kcg03/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0067", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，是這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00068",
		linknext = "0017_00070",
		line = 869,
	},
	["0017_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... Seeing a girl riding a bike kinda makes me think of my mom when she was younger, God rest her soul.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……骑自行车的女孩，长得很像很久以前去世的妈妈年轻时的样子之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……騎自行車的女孩，長得很像很久以前去世的媽媽年輕時的樣子之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00069",
		linknext = "0017_00071",
		line = 881,
	},
	["0017_00071"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg03010101", x=-5, y=-5, path=":cg/kcg03/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
