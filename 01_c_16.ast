	["0017_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I look at it again, it's just like that d10o that Asa-chan mentioned.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仔细一看，这好像和之前麻沙酱说的d10o是相同的构造。",
