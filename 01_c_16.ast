					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Agravar no es la palabra adecuada! ¡¿Te estás burlando de los vírgenes, maldita?!”",
