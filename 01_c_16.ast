	},
	["0017_00350"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00106", file2="misaki_01f_00202", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0121", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Th-This position is weird... Is my chubbiness the reason why it kinda hurts!? Even this tacky modern artwork is rejecting me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“姿、姿势有些奇怪……感觉有点疼是因为我太胖了吗……！？甚至连尻壁体都拒绝我的存在……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「姿、姿勢有些奇怪……感覺有點痛是因為我太胖了嗎……！？甚至連尻壁體都拒絕我的存在……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00349",
		linknext = "0017_00351",
		line = 4618,
	},
	["0017_00351"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, I struggled with this thing myself last night too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我昨天也因为这东西陷入苦战——”",
					{"rt2"},
				},
			},
			tw = {
