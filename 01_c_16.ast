	["0017_00290"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0534", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“This is Null base. Was napping, but you're coming in loud and clear. Over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这里是Null基地，虽然在午睡但能听到。over。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這裡是Null基地，雖然在午睡但能聽到。over。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00289",
		linknext = "0017_00291",
		line = 3791,
	},
	["0017_00291"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since your lazy ass is skipping class, I've got another makeup assignment for you. Get us a route home!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请一边自习今天翘课的学科，一边提示回家路线。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請一邊自習今天翹課的學科，一邊提示回家路線。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00290",
		linknext = "0017_00292",
		line = 3803,
	},
	["0017_00292"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0535", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Second half acknowledged. Beginning search now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“一部分了解，立即进行搜索。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「一部分了解，立即進行搜索。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00291",
		linknext = "0017_00293",
		line = 3815,
	},
	["0017_00293"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0536", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hmm... Both the school grounds and the school building are packed like sardines. The Shootdown King event seems to have given us even bigger numbers than usual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……嗯，校内外都很热闹啊，这是……‘击坠王’活动，似乎比之前的任何时候都要盛况空前……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……嗯，校內外都很熱鬧啊，這是……『擊墜王』活動，似乎比之前的任何時候都要盛況空前……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00292",
		linknext = "0017_00294",
		line = 3828,
	},
	["0017_00294"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's that bad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“人潮有那么多吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「人潮有那麼多嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00293",
		linknext = "0017_00295",
		line = 3840,
	},
	["0017_00295"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0537", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yep. There's sex seekers pretty much everywhere. Not to mention a correlated rise in the numbers of SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……应该说没有不存在性触者的地方……加上SS的数量也很多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……應該說沒有不存在性觸者的地方……加上SS的數量也很多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00294",
		linknext = "0017_00296",
		line = 3852,
	},
	["0017_00296"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0538", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Since we're close to the end of this event, things are just following the trend of increased participation. Tomorrow's the last day, so you might wanna be ready for that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“基本上活动后半期会有增加的趋势，所以最后一天的明天还是先做好心理准备比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「基本上活動後半期會有增加的趨勢，所以最後一天的明天還是先做好心理準備比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00295",
		linknext = "0017_00297",
		line = 3864,
	},
	["0017_00297"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0112", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, um, excuse me... can I ask something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊！对不起……可以说句话吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊！對不起……可以說句話嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00296",
		linknext = "0017_00298",
		line = 3880,
	},
	["0017_00298"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What is it, Hotori? Ask away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了畔，你说说看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了畔，你說說看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00297",
		linknext = "0017_00299",
		line = 3892,
	},
	["0017_00299"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0113", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“All of the NLNS members have been repeatedly running away, so how come the SS and SHO don't know your faces...? There's spycams all around the island, after all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“NLNS的各位逃亡了那么多次，脸不会被SS和SHO记住吗？岛上也有针孔摄像机……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「NLNS的各位逃亡了那麼多次，臉不會被SS和SHO記住嗎？島上也有針孔攝影機……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00298",
		linknext = "0017_00300",
		line = 3906,
	},
	["0017_00300"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure they've seen us, but it's not a problem.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想应该是被照到了，不过没关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想應該是被照到了，不過沒關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00299",
		linknext = "0017_00301",
		line = 3918,
	},
	["0017_00301"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0114", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“How so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎、怎么说……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「怎、怎麼說……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00300",
		linknext = "0017_00302",
		line = 3932,
	},
	["0017_00302"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I built recognition blocking into these goggles.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我这个护目镜進行過辨识阻碍加工……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我這個護目鏡進行過辨識阻礙加工……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00301",
		linknext = "0017_00303",
		line = 3944,
	},
	["0017_00303"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0115", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“R-Recognition blocking!? How on earth does that work!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“辨识阻碍……！？那是什么樣的技术……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「辨識阻礙……！？那是什麼樣的技術……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00302",
		linknext = "0017_00304",
		line = 3959,
	},
	["0017_00304"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0559", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Don't lie, silly. He calls it recognition blocking, but it's really Asa-chan's jamming which confuses the cameras installed in the town.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨——蛋，别骗人。虽说是辨识阻碍，但也只是让麻沙酱对街上设置的摄像头进行电波干扰罢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨——蛋，別騙人。雖說是辨識阻礙，但也只是讓麻沙醬對街上設置的攝影機進行電波干擾罷了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00303",
		linknext = "0017_00305",
