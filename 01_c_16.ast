	["0017_00238"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00109", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
