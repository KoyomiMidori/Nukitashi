				{"vo", file="misaki0082", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“V-Voy a entrar... Ahhh... ¡Este lugar siempre me asombra!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“打扰了……啊啊啊啊……这里果然是个厉害的地方……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「打擾了……啊啊啊啊……這裡果然是個厲害的地方……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00132",
		linknext = "0017_00134",
		line = 1698,
	},
	["0017_00134"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0523", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Tenemos todas estas instalaciones especiales e incluso un buen surtido de productos de primera necesidad. Creo que podrías sobrevivir una semana entera sin ninguna preparación previa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“除了特殊的设备之外，还有一整套日用品。一个星期左右的话，应该没有准备也能住进来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「除了特殊的設備之外，還有一整套日用品。一個星期左右的話，應該沒有準備也能住進來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00133",
		linknext = "0017_00135",
		line = 1712,
	},
	["0017_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hotori, gracias por lo de esta mañana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你好畔，今天早上多亏你帮了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你好畔，今天早上多虧你幫了我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00134",
		linknext = "0017_00136",
		line = 1724,
	},
	["0017_00136"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0083", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, Tachibana-san. No te preocupes, me alegra haberte ayudado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，橘同学，没事没事，能帮上你的忙真是太好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，橘同學，沒事沒事，能幫上你的忙真是太好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00135",
		linknext = "0017_00137",
		line = 1739,
	},
	["0017_00137"] = {
