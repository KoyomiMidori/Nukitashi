	},
	["0017_00252"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Qué lástima me dan esos idiotas. Vienen a esta isla y se corren dentro de putas como Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真令人叹息……来到这个岛，居然还要对奈奈濑这种婊子射精什么的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真令人嘆息……來到這個島，居然還要對奈奈瀨這種婊子射精什麼的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00251",
		linknext = "0017_00253",
		line = 3236,
	},
	["0017_00253"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00120", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0548", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oye, al menos no son unos cobardes abstemios que no se corren en ningún coño que no sea de silicona, ¿eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“毕竟大家跟你这个需要用飞机杯排解的禁欲阳痿不一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「畢竟大家跟你這個需要用飛機杯排解的禁慾陽痿不一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00252",
		linknext = "0017_00254",
		line = 3249,
	},
	["0017_00254"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Cuánto turnos te dije que tenías?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你知道人的忍耐是有限度的吗喂！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你知道人的忍耐是有限度的嗎喂！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00253",
		linknext = "0017_00255",
		line = 3261,
	},
	["0017_00255"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00102", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0347", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ya me acordé! ¡Solo le puedes decir pito flacido tres veces al día.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我知道！只能说三次阳痿对吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我知道！只能說三次陽痿對吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00254",
		linknext = "0017_00256",
		line = 3274,
	},
	["0017_00256"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00122", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Sí, pero eso no es todo! ¡Le dije que si seguía así, me sentiría muy decepcionado conmigo mismo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然没错，但也不能那样！你一直说我会很伤心的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然沒錯，但也不能那樣！你一直說我會很傷心的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00255",
		linknext = "0017_00257",
		line = 3286,
	},
	["0017_00257"] = {
