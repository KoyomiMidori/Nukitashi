		},
		linkback = "0017_00328",
		linknext = "0017_00330",
		line = 4354,
	},
	["0017_00330"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course not. I used my quick wits to evade them and get out of there unscathed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然，我立刻机智地击退对方，巧妙地逃了出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然，我立刻機智地擊退對方，巧妙地逃了出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00329",
		linknext = "0017_00331",
		line = 4366,
	},
	["0017_00331"] = {
