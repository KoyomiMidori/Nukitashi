		linkback = "0017_00347",
		linknext = "0017_00349",
		line = 4595,
	},
	["0017_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Does that mean it's something developed on Seiran Island?",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，那是从青蓝岛传来的东西吗——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，那是從青藍島傳來的東西嗎——？",
