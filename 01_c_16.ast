				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Eso no tiene nada que ver! ¡Por cierto, te quedan dos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跟阳痿没有关系吧！还有两次哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跟陽痿沒有關係吧！還有兩次哦！」",
