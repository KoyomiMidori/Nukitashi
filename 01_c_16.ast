			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh, I completely forgot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……啊，完全忘了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……啊，完全忘了。」",
					{"rt2"},
