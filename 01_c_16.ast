		linkback = "0017_00350",
		linknext = "0017_00352",
		line = 4630,
	},
	["0017_00352"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A thought suddenly strikes me. I was able to subdue that girl after she dropped her knife, but what made her do that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来，为什么那时候，女人手上的菜刀会掉下来呢——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，為什麼那時候，女人手上的菜刀會掉下來呢——？",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00351",
