		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque se trata de un artículo sexual bastante común, un enemigo podría utilizarlo, como me ocurrió a mí. Eso podría suponer un problema.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这只是变态做爱用的道具，但如果像上次一样被敌人拿来使用的话会很麻烦。",
					{"rt2"},
				},
			},
			tw = {
