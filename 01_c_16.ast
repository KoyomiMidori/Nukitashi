		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Once you're stuck in this, it's hard to get out. You need a bit of luck on your side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一旦被这东西拘束住就很难逃脱，会需要点运气。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一旦被這東西拘束住就很難逃脫，會需要點運氣。」",
					{"rt2"},
