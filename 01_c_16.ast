		linknext = "0017_00329",
		line = 4340,
	},
	["0017_00329"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0352", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Tachibana-kun got caught in this thing? You didn't have too much trouble, did you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？橘君被这个抓住了？没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？橘君被這個抓住了？沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00328",
		linknext = "0017_00330",
		line = 4354,
	},
	["0017_00330"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course not. I used my quick wits to evade them and get out of there unscathed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然，我立刻机智地击退对方，巧妙地逃了出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然，我立刻機智地擊退對方，巧妙地逃了出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00329",
		linknext = "0017_00331",
		line = 4366,
	},
	["0017_00331"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0564", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sounds more like you ran away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“说是那么说，我看你是用了卑鄙的手法才逃掉的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「說是那麼說，我看你是用了卑鄙的手法才逃掉的吧。」",
