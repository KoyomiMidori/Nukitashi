	},
	["0017_00339"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00116", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0353", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“The last time I thought about trying one out, an SHO lady told me they aren't for little kids to play with...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我之前想试着靠近，可是SHO的姐姐却对我说‘这对小孩子还太早了’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我之前想試著靠近，可是SHO的姐姐卻對我說『這對小孩子還太早了』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00338",
		linknext = "0017_00340",
		line = 4474,
	},
	["0017_00340"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00109", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0565", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I'm as good as a virgin with these myself. What's the idea behind these things, anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我也没有。话说，这是用什么原理来让屁股陷在墙里的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我也沒有。話說，這是用什麼原理來讓屁股陷在牆裡的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00339",
		linknext = "0017_00341",
		line = 4488,
	},
	["0017_00341"] = {
