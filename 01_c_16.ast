		linkback = "0017_00311",
		linknext = "0017_00313",
		line = 4076,
	},
	["0017_00313"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase, we're gonna do the low tide route today. I'm guessing we can just barely make it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……奈奈濑，今天也要通过退潮路线。应该勉强还可以走吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……奈奈瀨，今天也要通過退潮路線。應該勉強還可以走吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00312",
		linknext = "0017_00314",
		line = 4088,
	},
	["0017_00314"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0562", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, we should be fine, but we're really gonna be cutting it close. The water's gonna be up to our knees, so be mindful of that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，应该可以……但今天真的有点勉强了。水会淹到膝盖所以小心点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，應該可以……但今天真的有點勉強了。水會淹到膝蓋所以小心點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00313",
		linknext = "0017_00315",
		line = 4102,
	},
	["0017_00315"] = {
