	},
	["0017_00150"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0529", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah, ya veo.... Esa respuestaa fue muy virgen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哦。那就好……但你这反应真够处男的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哦。那就好……但你這反應真夠處男的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00149",
		linknext = "0017_00151",
		line = 1934,
	},
	["0017_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Si de la nada alguien te llamara por tu nombre de pila, pensarías que le gustas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“突然被喊下面的名字当然会觉得可能被喜欢吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「突然被喊下面的名字當然會覺得可能被喜歡吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00150",
		linknext = "0017_00152",
		line = 1946,
	},
	["0017_00152"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00107", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0087", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Esto, Junnosuke--kun... ¿tú también podrías llamarme por mi nombre, por favor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃，淳之介、君也……用名字叫我看看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃，淳之介、君也……用名字叫我看看。」",
					{"rt2"},
