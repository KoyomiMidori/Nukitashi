	["0017_00061"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0063", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
