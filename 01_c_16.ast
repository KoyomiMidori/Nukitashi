		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg10_00003", x=0, y=0, path=":cg/kcg10/", ev=1, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"bgm", file="bgm07", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin, sentémonos y relajémonos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好了，大家先坐椅子上冷静一下吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好了，大家先坐椅子上冷靜一下吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00177",
		linknext = "0017_00179",
		line = 2339,
	},
	["0017_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La parte que hay más allá de la sala de estrategia tiene un lugar donde podemos sentarnos y relajarnos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作战室内部的门后面，是能让所有人坐下的休息室。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作戰室內部的門後面，是能讓所有人坐下的休息室。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00178",
		linknext = "0017_00180",
		line = 2349,
	},
	["0017_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hay un sofá ahí, y está conectado directamente con la cocina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"里面摆着沙发，和厨房直接相连。",
					{"rt2"},
				},
			},
			tw = {
				{
					"裡面擺著沙發，和廚房直接相連。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00179",
		linknext = "0017_00181",
		line = 2359,
	},
	["0017_00181"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00113", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0093", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Esto, ¿dónde me siento?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃，我应该坐哪里好呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃，我應該坐哪裡好呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00180",
		linknext = "0017_00182",
		line = 2372,
	},
	["0017_00182"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00101", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0536", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Donde quieras sentarte, pero nosotros nos sentamos donde siempre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“只要是空着的地方，哪里都可以。虽然我的位置固定的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「只要是空著的地方，哪裡都可以。雖然我的位置固定的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00181",
		linknext = "0017_00183",
		line = 2385,
	},
	["0017_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan está metida en esta caja de cartón, así que el resto del espacio está libre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱是这边的纸箱，后面到处都是空着的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬是這邊的紙箱，後面到處都是空著的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00182",
		linknext = "0017_00184",
		line = 2396,
	},
	["0017_00184"] = {
		{"se", id=0, loop=0, file="se_a104"},
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00102", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0094", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Entonces me sentaré aquí. Me impresiona este lugar, hasta tienen un sofá y todas las comodidades...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那我就在这附近……连放松的沙发都有，真是个不得了的地方啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那我就在這附近……連放鬆的沙發都有，真是個不得了的地方啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00183",
		linknext = "0017_00185",
		line = 2410,
	},
	["0017_00185"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00101", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0337", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Solía ser una base del Ejército Imperial Japonés, pero ha sido renovada. Fue más bien obra del antiguo benefactor, nosotros no hicimos mucho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这里原来是旧日本军的基地，后来翻修的。不过，翻修的并不是我们，而是出资的爷爷。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這裡原來是舊日本軍的基地，後來翻修的。不過，翻修的並不是我們，而是出資的爺爺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00184",
		linknext = "0017_00186",
		line = 2423,
	},
	["0017_00186"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0095", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Genial, sabes muchas cosas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好厉害啊，你说得真好呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好厲害啊，你說得真好呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00185",
		linknext = "0017_00187",
		line = 2435,
	},
	["0017_00187"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00115", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0338", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ejeje, si hay algo que no sepas, pregúntame!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿，有什么不懂的就尽管问！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿，有什麼不懂的就儘管問！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00186",
		linknext = "0017_00188",
		line = 2448,
	},
	["0017_00188"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00111", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0537", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Es tan linda cuando no se da cuenta de que se están burlando de ella... ¡Quiero llevármela a casa y encerrarla...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“渡酱居然没发现自己被嘲笑了，真是可爱……好想把她养在家里……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「渡醬居然沒發現自己被嘲笑了，真是可愛……好想把她養在家裡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00187",
		linknext = "0017_00189",
		line = 2461,
	},
	["0017_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ni se te ocurra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你性格也真好呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你性格也真好呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00188",
		linknext = "0017_00190",
		line = 2473,
	},
	["0017_00190"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0096", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ahora que lo mencionan, ese benefactor— ¿cuál es su objetivo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“话说回来，你们说的出资者……他的目的是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「話說回來，你們說的出資者……他的目的是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00189",
		linknext = "0017_00191",
		line = 2486,
	},
	["0017_00191"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00109", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0339", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? Umm, bueno... ¡Tachibana-kun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？那个……那是……橘君！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？那個……那是……橘君！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00190",
		linknext = "0017_00192",
		line = 2499,
	},
	["0017_00192"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nuestro benefactor — ese viejo — nos dio una única condición.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们的出资者……那个‘老人’所提出的条件只有一个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們的出資者……那個『老人』所提出的條件只有一個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00191",
		linknext = "0017_00193",
		line = 2511,
	},
	["0017_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Quiere que encontremos a una chica llamada Kotoyose Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“琴寄文乃……他希望我们找到这个女孩——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「琴寄文乃……他希望我們找到這個女孩——」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00192",
		linknext = "0017_00194",
		line = 2523,
	},
	["0017_00194"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00114", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0097", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Kotoyose... Fumino? ¿Cómo es ella?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“琴寄、文乃……？她是什么样的女孩子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「琴寄、文乃……？她是什麼樣的女孩子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00193",
		linknext = "0017_00195",
		line = 2536,
	},
	["0017_00195"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00105", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0538", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No tenemos ni idea. No sabemos nada de su pasado, ni cómo es, ni por qué su empresa quiere protegerla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这一点我们也不清楚。无论是身分还是外貌，还有为什么希望保护那个女孩。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這一點我們也不清楚。無論是身分還是外貌，還有為什麼希望保護那個女孩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00194",
		linknext = "0017_00196",
		line = 2549,
	},
	["0017_00196"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero tenemos que buscarla para que nos siga ayudando.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，不能不找——如果被停止出资，那就麻烦了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，不能不找——如果被停止出資，那就麻煩了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00195",
		linknext = "0017_00197",
		line = 2561,
	},
	["0017_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Necesitamos el dinero que nos da, para escapar y para luchar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了逃跑，还有战斗，不管怎样都需要资金。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了逃跑，還有戰鬥，不管怎樣都需要資金。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00196",
		linknext = "0017_00198",
		line = 2571,
	},
	["0017_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por fin contamos con suficientes personas para tomar cartas en el asunto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"终于聚集了可以进行作战行动的人数。",
					{"rt2"},
				},
			},
			tw = {
				{
					"終於聚集了可以進行作戰行動的人數。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00197",
		linknext = "0017_00199",
		line = 2581,
	},
	["0017_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No podemos perder su ayuda económica.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么可以在这个时机被中断资金——",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼可以在這個時機被中斷資金——",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00198",
		linknext = "0017_00200",
		line = 2591,
	},
	["0017_00200"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vamos a aguantar esta mierda del Rey Tiroteador y luego la buscaremos. La chica podría estar sola.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“尽快度过此次‘击坠王’，然后去找这个女孩吧。说不定她也很孤独——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「盡快度過此次『擊墜王』，然後去找這個女孩吧。說不定她也很孤獨——」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00199",
		linknext = "0017_00201",
		line = 2603,
	},
	["0017_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además, no podemos permitir que se sacrifique a más personas en nombre de las no-vírgenes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且不能再增加名为非处女的牺牲者了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且不能再增加名為非處女的犧牲者了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00200",
		linknext = "0017_00202",
		line = 2614,
	},
	["0017_00202"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00104", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
