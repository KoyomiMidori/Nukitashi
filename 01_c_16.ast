			},
		},
		linkback = "0017_00011",
		linknext = "0017_00013",
		line = 158,
	},
	["0017_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El Mural de Arte de Culos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就是尻壁体。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就是尻壁體。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00012",
		linknext = "0017_00014",
		line = 168,
	},
	["0017_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"También conocido como Murales de Culos, han sido erigidos (?) en toda la isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"设立在岛上的尻壁体。或者称为壁尻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"設立在島上的尻壁體。或者稱為壁尻。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00013",
		linknext = "0017_00015",
		line = 178,
	},
	["0017_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, en lo que respecta a la documentación sobre ellos, no existe un patrón coherente en todos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这东西的名字有出入，在岛屿上也不怎么统一。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這東西的名字有出入，在島嶼上也不怎麼統一。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00014",
		linknext = "0017_00016",
		line = 188,
	},
	["0017_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por lo generala, cualquier cosa relacionada con la SHO o la Isla Seiran tendría una documentación tan extensa como una guía telefónica, pero estas cosas son la excepción.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来只有青蓝岛，以及SHO明记的东西才可以被称为官方，但这物体似乎没有那个限制。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來只有青藍島，以及SHO明記的東西才可以被稱為官方，但這物體似乎沒有那個限制。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00015",
		linknext = "0017_00017",
		line = 198,
	},
	["0017_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hace años, se produjo un conflicto que ahora es muy conocido. Se trataba de una disputa entre quienes estaban a favor de la instalación de Murales de Culos y el movimiento NEMT (No en mis muros traseros), el cual se oponía a ellos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"几年前，“除‘壁尻’外决不容许”派和“不管怎么想，‘尻壁’都更色情”派之间发生的大规模抗争实在是太有名了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"幾年前，「除『壁尻』外決不容許」派和「不管怎麼想，『尻壁』都更色情」派之間發生的大規模抗爭實在是太有名了。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00016",
		linknext = "0017_00018",
		line = 208,
	},
	["0017_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al final, ambas partes lograron reconciliarse y acordaron su ubicación tras un largo debate sobre el tema. Pero los vestigios de la disputa aún perduran.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果，两派阀的代表虽然被固定在墙上进行了协议和解互奸，但依然存在着祸根。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結果，兩派閥的代表雖然被固定在牆上進行了協議和解互姦，但依然存在著禍根。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00017",
		linknext = "0017_00019",
		line = 218,
	},
	["0017_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En fin...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这姑且不论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這姑且不論。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00018",
		linknext = "0017_00020",
		line = 228,
	},
	["0017_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La parte principal está hecha de gel y se solidifica una vez que te metes dentro y pulsas el cierre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"中央是特殊的胶状，放入身体锁定之后会被固定。",
					{"rt2"},
				},
			},
			tw = {
