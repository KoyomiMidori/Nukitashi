				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“有什么好在意的嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
