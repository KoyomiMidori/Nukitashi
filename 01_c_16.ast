	},
	["0017_00144"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0085", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh yeah... umm, Junnosuke--kun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，对了……诶，淳之介、君？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，對了……欸，淳之介、君？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00143",
		linknext = "0017_00145",
		line = 1852,
	},
	["0017_00145"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wh-What is that out of the blue!? Do you like me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎、怎么突然！你喜欢我吗……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎、怎麼突然！你喜歡我嗎……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00144",
		linknext = "0017_00146",
		line = 1865,
	},
	["0017_00146"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00110", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0086", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, no. Nanase-san said that I should reform myself or something... and that I should call my class level teammates from their first name so we could fight together as one...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，不是，应该说是意识改革……？‘为了作为队伍团结战斗，首先同年级的同学之间，要用名字来称呼’奈奈濑同学是这么说的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，不是，應該說是意識改革……？『為了作為隊伍團結戰鬥，首先同年級的同學之間，要用名字來稱呼』奈奈瀨同學是這麼說的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00145",
		linknext = "0017_00147",
		line = 1880,
	},
	["0017_00147"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A-Ah, so that's why... Ahaha, why're you doing that, Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什，什么啊，原来如此……啊哈哈，为什么要干这种事啊奈奈濑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什，什麼啊，原來如此……啊哈哈，為什麼要幹這種事啊奈奈瀨。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00146",
		linknext = "0017_00148",
		line = 1892,
	},
	["0017_00148"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00112", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=5000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0528", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You'd normally do that when working within sports teams together to strengthen your bonds... Don't you look pretty happy about it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“因为运动社之类的都是这样，好像可以提高队伍内的团结力……你这不是很开心吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為運動社之類的都是這樣，好像可以提高隊伍內的團結力……你這不是很開心嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00147",
		linknext = "0017_00149",
		line = 1908,
	},
	["0017_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wouldn't say that. I was just surprised...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哪、哪有。只是吓了一跳……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哪、哪有。只是嚇了一跳……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00148",
		linknext = "0017_00150",
		line = 1920,
	},
	["0017_00150"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0529", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, I see.... that's quite a virgin's response.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哦。那就好……但你这反应真够处男的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哦。那就好……但你這反應真夠處男的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00149",
		linknext = "0017_00151",
		line = 1934,
	},
	["0017_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If someone suddenly starts calling you by your first name, of course you'd think they like you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“突然被喊下面的名字当然会觉得可能被喜欢吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「突然被喊下面的名字當然會覺得可能被喜歡吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00150",
		linknext = "0017_00152",
		line = 1946,
	},
	["0017_00152"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00107", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0087", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, Junnosuke--kun... can you try calling me by my first name too please?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃，淳之介、君也……用名字叫我看看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃，淳之介、君也……用名字叫我看看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00151",
		linknext = "0017_00153",
		line = 1960,
	},
	["0017_00153"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mi...saki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“美……美——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「美……美——」",
					{"rt2"},
