					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I-I guess, Hotori...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是、是啊，畔……”",
					{"rt2"},
