				{"vo", file="nanase0540", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Tienes mucho valor acusando de no-vírgenes y zorras a los demás solo porque te fijas mucho en el aspecto, virgen de cuerpo entero!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我说你这样看到别人就张口啥非处女还婊子的是在发什么神经啊你这个全身处男！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我說你這樣看到別人就張口啥非處女還婊子的是在發什麼神經啊你這個全身處男！」",
					{"rt2"},
