		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg03010103", x=-5, y=-5, path=":cg/kcg03/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"bgm", file="bgm02", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Ah, Hotori?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哇哦，畔……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哇哦，畔……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00031",
		linknext = "0017_00033",
		line = 404,
	},
	["0017_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me giro sorprendido y veo a Hotori, la lectora empedernida habitual, montada en su bicicleta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边摆好架势一边回头，结果发现跨在自行车上的文学少女畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊擺好架勢一邊回頭，結果發現跨在自行車上的文學少女畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00032",
		linknext = "0017_00034",
		line = 414,
	},
	["0017_00034"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En qué momento... Digo, ¿qué haces aquí en medio de la nada?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么时候……你在这里干什么？这可是森林里啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼時候……你在這裡幹什麼？這可是森林裡啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00033",
		linknext = "0017_00035",
		line = 426,
	},
	["0017_00035"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg03010101", set="kcg030101", path=":ev/kcg030101/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg03010101", x=-5, y=-5, path=":cg/kcg03/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0055", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Mi casa está por este camino, así que, eh, estaba atravesando el bosque para evitar a la SHO... y te encontré de casualidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为我家就在这方向，啊，还有为了不被SHO看到，所以正经过森林……然后橘同学正好在这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為我家就在這方向，啊，還有為了不被SHO看到，所以正經過森林……然後橘同學正好在這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00034",
		linknext = "0017_00036",
		line = 446,
	},
	["0017_00036"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya veo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，是这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，是這樣啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00035",
		linknext = "0017_00037",
		line = 458,
	},
	["0017_00037"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yo vine a eliminar unos obstáculos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我是为了排除障碍才来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我是為了排除障礙才來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00036",
		linknext = "0017_00038",
		line = 470,
	},
	["0017_00038"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Como líder del NLNS, tengo que mantener mi información actualizada. Así que vine aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“作为NLNS的队长，我有需要调查的事情，所以绕了个远路。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「作為NLNS的隊長，我有需要調查的事情，所以繞了個遠路。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00037",
		linknext = "0017_00039",
		line = 482,
	},
	["0017_00039"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg03010103", x=-5, y=-5, path=":cg/kcg03/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0056", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Eh? ¿Hay algo que nos cause problemas en lo profundo del bosque? ¿Como jabalíes o algo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦，这种森林里有什么吗？野猪什么的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦，這種森林裡有什麼嗎？野豬什麼的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00038",
		linknext = "0017_00040",
		line = 498,
	},
	["0017_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sí. Una vez, un jabalí salió de entre los arbustos en pleno celo, así que me abalancé sobre él con valentía y lo ahuyenté.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，以前疯狂淫乱的野猪从草丛里出现的时候，我勇敢地扑上去击退了它。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，以前瘋狂淫亂的野豬從草叢裡出現的時候，我勇敢地撲上去擊退了它。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00039",
		linknext = "0017_00041",
		line = 509,
	},
	["0017_00041"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg03010101", x=-5, y=-5, path=":cg/kcg03/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0057", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“V-Vaya, genial... ¡Sí que tienes el talento de un líder!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“原、原来如此……能成为队长的人果然很厉害啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「原、原來如此……能成為隊長的人果然很厲害啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00040",
		linknext = "0017_00042",
		line = 525,
	},
	["0017_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bueh, el jabalí era Nanase... pero en mi defensa, eso que dije es como una verdad a medias.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是奈奈濑，不过也不算说谎吧……而且她也先回去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是奈奈瀨，不過也不算說謊吧……而且她也先回去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00041",
		linknext = "0017_00043",
		line = 535,
	},
	["0017_00043"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, ya casi termino. Tengo toda la información al día. ¿Nos vamos juntos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“调查已经差不多结束了，一起走吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「調查已經差不多結束了，一起走吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00042",
		linknext = "0017_00044",
		line = 547,
	},
	["0017_00044"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0058", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Estaba pensando lo mismo. No querría que te quedaras aquí parado y llegaras tarde.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊，毕竟这样下去可能会迟到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊，畢竟這樣下去可能會遲到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00043",
		linknext = "0017_00045",
		line = 559,
	},
	["0017_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bueno, mientras la siga, al menos llegaré a la escuela.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果就这样一直跟着畔走，一定能到学校吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果就這樣一直跟著畔走，一定能到學校吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00044",
		linknext = "0017_00046",
		line = 569,
	},
	["0017_00046"] = {
		{"se", id=0, loop=0, file="se_a193"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pedalea hacia adelante, despacio pero con pericia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她灵巧地骑着自行车，缓缓前进。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她靈巧地騎著自行車，緩緩前進。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00045",
		linknext = "0017_00047",
		line = 580,
	},
	["0017_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Se te da bien montar la bici. Una máquina de dos ruedas sería bastante inestable a esa velocidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“骑得很棒啊，毕竟双轮车在速度慢的时候会不稳定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「騎得很棒啊，畢竟雙輪車在速度慢的時候會不穩定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00046",
		linknext = "0017_00048",
		line = 592,
	},
	["0017_00048"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg03010102", set="kcg030101", path=":ev/kcg030101/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg03010102", x=-5, y=-5, path=":cg/kcg03/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0059", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Jeje, Tengo mucha confianza en la fuerza de mis piernas... Además, ¿quieres saber algo de mi bicicleta? Nos conocemos desde hace muchos años.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嘿嘿，我对脚力有些信心……再说，这孩子是我常年以来的同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嘿嘿，我對腳力有些信心……再說，這孩子是我常年以來的同伴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00047",
		linknext = "0017_00049",
		line = 611,
	},
	["0017_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eso veo. Dijiste que la usas para huir, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，你有说过你都骑着它到处逃跑对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，你有說過你都騎著它到處逃跑對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00048",
		linknext = "0017_00050",
		line = 623,
	},
	["0017_00050"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0060", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sí. Y también tiene un truco. Si te pones de pie mientras pedaleas y te inclinas hacia delante, consigues mucha más estabilidad...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的，而且需要诀窍。一边站着骑，一边保持前倾的状态的话就会很安定……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的，而且需要訣竅。一邊站著騎，一邊保持前傾的狀態的話就會很安定……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00049",
		linknext = "0017_00051",
		line = 635,
	},
	["0017_00051"] = {
		{"bg", id=19, file="kcg03_l010102", x=-480, y=-280, path=":cg/kcg03_l/", lv=5, ev=1, time=500, bx=800, by=450},
		{"cgact", file="cgact", id=19, act="移動", x=-400, y=0, time=6000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La forma en que se inclina hacia delante resalta el tamaño de su pecho.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔往前探出身子，那对巨大的乳房被更加强调了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔往前探出身子，那對巨大的乳房被更加強調了。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00050",
		linknext = "0017_00052",
		line = 647,
	},
	["0017_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque rápidamente me siento un poco cohibido por estar mirando algo que no debería, así que aparto la mirada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感觉看到了不该看的东西，我移开视线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感覺看到了不該看的東西，我移開視線。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00051",
		linknext = "0017_00053",
		line = 657,
	},
	["0017_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Acto seguido, mis ojos se fijan en un objeto de aspecto siniestro que está sobre la silla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，又看到了被装在自行车坐垫上的那邪恶的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，又看到了被裝在自行車坐墊上的那邪惡的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00052",
		linknext = "0017_00054",
		line = 667,
	},
	["0017_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La Bicicleta del Clímax... Si quieres hablar de bicicletas en la Isla Seiran, sin duda alguna, será una de estas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"高潮自行车——说到青蓝岛的自行车，肯定是指这东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"高潮自行車——說到青藍島的自行車，肯定是指這東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00053",
		linknext = "0017_00055",
		line = 677,
	},
	["0017_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya me acostumbré a verlas, pero la idea de que Hotori, tan tranquila como es, ande en una de estas como si nada... me hace sentir avergonzado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我虽然也看习惯了，不过一想到平时老实的畔骑着它……就会不自觉地在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我雖然也看習慣了，不過一想到平時老實的畔騎著它……就會不自覺地在意。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00054",
		linknext = "0017_00056",
		line = 687,
	},
	["0017_00056"] = {
