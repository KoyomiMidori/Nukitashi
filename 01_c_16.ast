					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Eh? ¿Cómo así? Uff... Pero mira que con ese evento es todo un viaje llegar aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃，什么……？唉……比起这个，活动期间来这里真的是件很辛苦的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃，什麼……？唉……比起這個，活動期間來這裡真的是件很辛苦的事。」",
