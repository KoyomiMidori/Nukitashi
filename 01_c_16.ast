	},
	["0017_00354"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"bg", id=1, file="bg08_1l_00000", x=0, y=-200, path=":bg/", sync=0, style="blur", blurx=11, blury=11, ax=1280, ay=730, bx=-480, by=-280},
		{"extrans", sync=0, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I see something lying on the ground that I didn't notice in the dark yesterday.",
					{"rt2"},
				},
			},
			cn = {
