				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“En internet he visto que usa el término “Virgen de Seiran”.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我虽然没听说过外行处男，不过，我有在网上看到过青蓝处男。”",
					{"rt2"},
				},
