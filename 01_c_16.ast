				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How many strikes did I say you get, you fucker!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你知道人的忍耐是有限度的吗喂！？”",
