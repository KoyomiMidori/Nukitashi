					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Th-That's impressive enough. So what about your faces being seen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“即、即使是那样也好厉害啊……那么，还需不需要担心被看到脸呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「即、即使是那樣也好厲害啊……那麼，還需不需要擔心被看到臉呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00304",
		linknext = "0017_00306",
		line = 3986,
	},
	["0017_00306"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
