		linkback = "0017_00289",
		linknext = "0017_00291",
		line = 3791,
	},
	["0017_00291"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since your lazy ass is skipping class, I've got another makeup assignment for you. Get us a route home!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请一边自习今天翘课的学科，一边提示回家路线。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請一邊自習今天翹課的學科，一邊提示回家路線。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00290",
		linknext = "0017_00292",
		line = 3803,
	},
	["0017_00292"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0535", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Second half acknowledged. Beginning search now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“一部分了解，立即进行搜索。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「一部分了解，立即進行搜索。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00291",
		linknext = "0017_00293",
		line = 3815,
	},
	["0017_00293"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0536", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hmm... Both the school grounds and the school building are packed like sardines. The Shootdown King event seems to have given us even bigger numbers than usual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……嗯，校内外都很热闹啊，这是……‘击坠王’活动，似乎比之前的任何时候都要盛况空前……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……嗯，校內外都很熱鬧啊，這是……『擊墜王』活動，似乎比之前的任何時候都要盛況空前……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00292",
		linknext = "0017_00294",
		line = 3828,
	},
	["0017_00294"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's that bad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“人潮有那么多吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「人潮有那麼多嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00293",
		linknext = "0017_00295",
		line = 3840,
	},
	["0017_00295"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0537", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yep. There's sex seekers pretty much everywhere. Not to mention a correlated rise in the numbers of SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……应该说没有不存在性触者的地方……加上SS的数量也很多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……應該說沒有不存在性觸者的地方……加上SS的數量也很多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00294",
		linknext = "0017_00296",
		line = 3852,
	},
	["0017_00296"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0538", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Since we're close to the end of this event, things are just following the trend of increased participation. Tomorrow's the last day, so you might wanna be ready for that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“基本上活动后半期会有增加的趋势，所以最后一天的明天还是先做好心理准备比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「基本上活動後半期會有增加的趨勢，所以最後一天的明天還是先做好心理準備比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00295",
		linknext = "0017_00297",
		line = 3864,
	},
	["0017_00297"] = {
