					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No diría eso. Solo estaba sorprendido...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哪、哪有。只是吓了一跳……”",
