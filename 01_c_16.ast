		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_001_00000"},
		{"bgm", file="bgm07", vol=100},
		{"se", id=0, loop=0, file="se_a112"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then, after school. I'm doing some modeling work on the strategy room PC, when the door suddenly opens.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后。我用作战室的电脑做模型时，门突然打开了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後。我用作戰室的電腦做模型時，門突然打開了。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00128",
		linknext = "0017_00130",
		line = 1639,
	},
	["0017_00130"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0521", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun. I brought Misaki along.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂，淳，我带美岬来了哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂，淳，我帶美岬來了哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00129",
		linknext = "0017_00131",
		line = 1653,
	},
	["0017_00131"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, rude. Maybe knock next time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么嘛，口气那么差。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼嘛，口氣那麼差。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00130",
		linknext = "0017_00132",
		line = 1665,
	},
	["0017_00132"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00114", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0522", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? How? Phew... But man, with this event going on, it's a hell of an effort to make it here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃，什么……？唉……比起这个，活动期间来这里真的是件很辛苦的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃，什麼……？唉……比起這個，活動期間來這裡真的是件很辛苦的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00131",
		linknext = "0017_00133",
		line = 1682,
	},
	["0017_00133"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=-200, y=0, time=700},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=400, y=0, time=500},
		{"text"},
		delay = {
			[3500] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0082", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I-I'm coming in... Whoaaaa... This place never ceases to amaze me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“打扰了……啊啊啊啊……这里果然是个厉害的地方……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「打擾了……啊啊啊啊……這裡果然是個厲害的地方……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00132",
		linknext = "0017_00134",
		line = 1698,
	},
	["0017_00134"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0523", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We've got all these special facilities, and even a decent stock of daily necessities. I bet you could survive down here a week without any prior preparation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“除了特殊的设备之外，还有一整套日用品。一个星期左右的话，应该没有准备也能住进来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「除了特殊的設備之外，還有一整套日用品。一個星期左右的話，應該沒有準備也能住進來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00133",
		linknext = "0017_00135",
		line = 1712,
	},
	["0017_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, Hotori. Thanks again for this morning.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你好畔，今天早上多亏你帮了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你好畔，今天早上多虧你幫了我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00134",
		linknext = "0017_00136",
		line = 1724,
	},
	["0017_00136"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0083", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, Tachibana-san. Don't even mention it, I'm just glad I could be of help.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，橘同学，没事没事，能帮上你的忙真是太好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，橘同學，沒事沒事，能幫上你的忙真是太好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00135",
		linknext = "0017_00137",
		line = 1739,
	},
	["0017_00137"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0524", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“This morning? Did something happen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“早上……发生什么事了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「早上……發生什麼事了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00136",
		linknext = "0017_00138",
		line = 1753,
	},
	["0017_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Kinda, yeah. We ran into each other, and I wound up riding on the back of her bike.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……偶然遇到……然后让她载了一程……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……偶然遇到……然後讓她載了一程……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00137",
		linknext = "0017_00139",
		line = 1765,
	},
	["0017_00139"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0525", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Idiot. Why can't you do the pedaling?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨蛋，为什么不是你骑车啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨蛋，為什麼不是你騎車啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00138",
		linknext = "0017_00140",
		line = 1780,
	},
	["0017_00140"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0084", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh no, I'm quite happy to do it myself...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没事没事，因为我喜欢自己骑车……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒事沒事，因為我喜歡自己騎車……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00139",
		linknext = "0017_00141",
		line = 1794,
	},
	["0017_00141"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0526", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh. How about I hitch a ride on there next time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哎，那下次也载我一程吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哎，那下次也載我一程吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00140",
		linknext = "0017_00142",
		line = 1808,
	},
	["0017_00142"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
