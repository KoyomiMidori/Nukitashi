	["0017_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Also known as just Ass Walls, they've been erected (heh) all over this island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"设立在岛上的尻壁体。或者称为壁尻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"設立在島上的尻壁體。或者稱為壁尻。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00013",
		linknext = "0017_00015",
		line = 178,
	},
	["0017_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though when it comes to the documentation on them, there's no consistent pattern across all of them everywhere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这东西的名字有出入，在岛屿上也不怎么统一。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這東西的名字有出入，在島嶼上也不怎麼統一。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00014",
		linknext = "0017_00016",
		line = 188,
	},
	["0017_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normally anything SHO or Seiran Island-related would have a phone book's worth of documentation behind it, but these things are the exception.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来只有青蓝岛，以及SHO明记的东西才可以被称为官方，但这物体似乎没有那个限制。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來只有青藍島，以及SHO明記的東西才可以被稱為官方，但這物體似乎沒有那個限制。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00015",
		linknext = "0017_00017",
		line = 198,
	},
	["0017_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Some years ago, there was a now-notorious conflict which took place. It was between those who were in favor of the placement of Ass Walls, and the NIMBW (Not In My Back Walls) movement opposed to them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"几年前，“除‘壁尻’外决不容许”派和“不管怎么想，‘尻壁’都更色情”派之间发生的大规模抗争实在是太有名了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"幾年前，「除『壁尻』外決不容許」派和「不管怎麼想，『尻壁』都更色情」派之間發生的大規模抗爭實在是太有名了。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00016",
		linknext = "0017_00018",
		line = 208,
	},
	["0017_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ultimately, both sides managed to reconcile and agree to the placement of them, after a lengthy intercourse over the issue. But the memories of the dispute still linger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果，两派阀的代表虽然被固定在墙上进行了协议和解互奸，但依然存在着祸根。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結果，兩派閥的代表雖然被固定在牆上進行了協議和解互姦，但依然存在著禍根。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00017",
		linknext = "0017_00019",
		line = 218,
	},
	["0017_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Anyway...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这姑且不论。",
