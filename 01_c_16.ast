		linkback = "0017_00350",
		linknext = "0017_00352",
		line = 4630,
	},
	["0017_00352"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A thought suddenly strikes me. I was able to subdue that girl after she dropped her knife, but what made her do that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来，为什么那时候，女人手上的菜刀会掉下来呢——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，為什麼那時候，女人手上的菜刀會掉下來呢——？",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00351",
		linknext = "0017_00353",
		line = 4640,
	},
	["0017_00353"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a034"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look down at the grass, searching for an answer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像是在寻找这个疑问的答案一般，我将视线投向了脚下的草丛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像是在尋找這個疑問的答案一般，我將視線投向了腳下的草叢。",
					{"rt2"},
				},
			},
