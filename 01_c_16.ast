	["0017_00236"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00114", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0544", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Misaki, no me gusta ser tan directa, pero... está así por culpa de su impotencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“美岬，对不起啊这话绕的……毕竟这人阳痿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「美岬，對不起啊這話繞的……畢竟這人陽痿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00235",
		linknext = "0017_00237",
		line = 3035,
	},
	["0017_00237"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
