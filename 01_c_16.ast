	["0017_00303"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0115", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“R-Recognition blocking!? How on earth does that work!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“辨识阻碍……！？那是什么樣的技术……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「辨識阻礙……！？那是什麼樣的技術……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00302",
		linknext = "0017_00304",
		line = 3959,
	},
	["0017_00304"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0559", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Don't lie, silly. He calls it recognition blocking, but it's really Asa-chan's jamming which confuses the cameras installed in the town.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨——蛋，别骗人。虽说是辨识阻碍，但也只是让麻沙酱对街上设置的摄像头进行电波干扰罢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨——蛋，別騙人。雖說是辨識阻礙，但也只是讓麻沙醬對街上設置的攝影機進行電波干擾罷了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00303",
		linknext = "0017_00305",
		line = 3972,
	},
	["0017_00305"] = {
		{"text"},
		delay = {
			[500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0116", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Th-That's impressive enough. So what about your faces being seen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“即、即使是那样也好厉害啊……那么，还需不需要担心被看到脸呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「即、即使是那樣也好厲害啊……那麼，還需不需要擔心被看到臉呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00304",
		linknext = "0017_00306",
		line = 3986,
	},
	["0017_00306"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Half of my face is covered by the goggles, so no problems there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的护目镜遮住了一半的脸，所以不要紧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的護目鏡遮住了一半的臉，所以不要緊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00305",
		linknext = "0017_00307",
		line = 3998,
	},
	["0017_00307"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0560", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Asa-chan hides behind Jun, so they basically don't see her face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“麻沙酱总是黏在淳后面，所以基本上看不到她的脸。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「麻沙醬總是黏在淳後面，所以基本上看不到她的臉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00306",
		linknext = "0017_00308",
		line = 4012,
	},
	["0017_00308"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0561", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“As for me, like, I'm a famous slut and all, so... everyone thinks it's someone that looks like me but isn't the real Katagiri Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“还有我，因为我是有名的婊子……所以大家只会认为是相似的人，不会觉得是片桐奈奈濑本人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「還有我，因為我是有名的婊子……所以大家只會認為是相似的人，不會覺得是片桐奈奈瀨本人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00307",
		linknext = "0017_00309",
		line = 4026,
	},
	["0017_00309"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00114", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
