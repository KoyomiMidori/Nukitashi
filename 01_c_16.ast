	},
	["0017_00337"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Have any of you used the Ass Wall before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你们之间，有没有人用过尻壁体？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你們之間，有沒有人用過尻壁體？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00336",
		linknext = "0017_00338",
		line = 4447,
	},
	["0017_00338"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0119", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I've seen them from afar a few times before, but... definitely not this up-close and personal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我有从很远的地方看过它……在这么近的地方看还是第一次呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我有從很遠的地方看過它……在這麼近的地方看還是第一次呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00337",
		linknext = "0017_00339",
		line = 4460,
	},
	["0017_00339"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00116", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0353", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“The last time I thought about trying one out, an SHO lady told me they aren't for little kids to play with...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我之前想试着靠近，可是SHO的姐姐却对我说‘这对小孩子还太早了’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我之前想試著靠近，可是SHO的姐姐卻對我說『這對小孩子還太早了』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00338",
		linknext = "0017_00340",
		line = 4474,
	},
	["0017_00340"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00109", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0565", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I'm as good as a virgin with these myself. What's the idea behind these things, anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我也没有。话说，这是用什么原理来让屁股陷在墙里的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我也沒有。話說，這是用什麼原理來讓屁股陷在牆裡的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00339",
		linknext = "0017_00341",
		line = 4488,
	},
	["0017_00341"] = {
