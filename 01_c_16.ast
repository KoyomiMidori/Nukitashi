				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I, uh... don't remotely appear to be of age for any sexual activity anyway... but I'm not a loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我、我是……那个，本来就被认为是条例对象外，所以……不过我不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我、我是……那個，本來就被認為是條例對象外，所以……不過我不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00308",
		linknext = "0017_00310",
		line = 4042,
	},
	["0017_00310"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0117", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, I see... Then I should be fine as well... given my lack of presence and all... haha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，原来如此……那我也没关系吧……毕竟存在感很薄弱……哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，原來如此……那我也沒關係吧……畢竟存在感很薄弱……哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00309",
		linknext = "0017_00311",
		line = 4056,
	},
	["0017_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, when you consider what our activities are, they're undoubtedly useful characteristics.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是考虑到我们的活动内容，这无疑是一种有利的特性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是考慮到我們的活動內容，這無疑是一種有利的特性。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00310",
		linknext = "0017_00312",
		line = 4066,
	},
	["0017_00312"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We have to make the most of everyone's strengths in order to make it home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们需要利用各自的强项，安全回家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們需要利用各自的強項，安全回家。",
					{"rt2"},
				},
