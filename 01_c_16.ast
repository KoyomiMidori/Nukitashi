	["0017_00154"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=100, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡No, no puedo! ¡Me da mucha vergüenza llamar a alguien del sexo opuesto por su nombre de pila!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不，不行！要我用名字称呼异性……太紧张了办不到！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不，不行！要我用名字稱呼異性……太緊張了辦不到！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00153",
		linknext = "0017_00155",
		line = 1986,
	},
	["0017_00155"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0530", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Por qué te da tanta pena?”",
