		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por lo tanto, en el momento en que un hombre eyacula desde el alma, deja de ser virgen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，男人在‘发自真心的射精’的瞬间——才会成为非处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，男人在『發自真心的射精』的瞬間——才會成為非處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00233",
		linknext = "0017_00235",
		line = 3007,
	},
	["0017_00235"] = {
