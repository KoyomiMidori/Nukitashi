	},
	["0017_00320"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From here on it gets convoluted, so I'll get Asa-chan to mark the destination instead of direct us verbally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再往前走的道路错综复杂，所以接下来我要麻沙酱不再依靠声音，而是通过标识指示路线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再往前走的道路錯綜複雜，所以接下來我要麻沙醬不再依靠聲音，而是通過標識指示路線。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00319",
		linknext = "0017_00321",
		line = 4190,
	},
	["0017_00321"] = {
