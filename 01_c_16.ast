	["0017_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"An awkward silence falls between us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后两个人之间，一阵尴尬的沉默。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後兩個人之間，一陣尷尬的沉默。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00057",
		linknext = "0017_00059",
		line = 729,
	},
	["0017_00059"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0062", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, uh, so... I wanted to say...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……嗯，有点，那个呢……”",
