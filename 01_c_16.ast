		{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0552", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Like, without a leader to depend on, we'd be in hot water, you know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好了啦，如果失去了可靠的队长，大家会很困扰的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好了啦，如果失去了可靠的隊長，大家會很困擾的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00268",
		linknext = "0017_00270",
		line = 3480,
	},
	["0017_00270"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? You need me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真的吗？需要我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真的嗎？需要我嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00269",
		linknext = "0017_00271",
		line = 3492,
	},
	["0017_00271"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0553", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“When have we ever not needed you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我们当然需要淳呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我們當然需要淳呀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00270",
		linknext = "0017_00272",
		line = 3506,
	},
	["0017_00272"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? Heh heh... really...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……呵呵……是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……呵呵……是嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00271",
		linknext = "0017_00273",
		line = 3518,
	},
	["0017_00273"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0110", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wow, I can see his mood transforming before my very eyes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好厉害，心情一下就变好了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好厲害，心情一下就變好了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00272",
		linknext = "0017_00274",
		line = 3532,
	},
	["0017_00274"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0348", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Nanase-chan's just that good at reining in Tachibana-kun and Asane-chan, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“奈奈濑酱对橘君和麻沙音酱都很有一套。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「奈奈瀨醬對橘君和麻沙音醬都很有一套。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00273",
		linknext = "0017_00275",
		line = 3545,
	},
	["0017_00275"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0554", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Come on. We'll hear you out, so just tell us something on your mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那我就听你一个愿望吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那我就聽你一個願望吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00274",
		linknext = "0017_00276",
		line = 3559,
	},
	["0017_00276"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Will anything do!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么都可以吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼都可以嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00275",
		linknext = "0017_00277",
		line = 3571,
	},
	["0017_00277"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0555", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I figured that'd be your reaction. Hence why I said 'something,' not 'anything'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我就知道你会这样问我，所以才没说什么都可以。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我就知道你會這樣問我，所以才沒說什麼都可以。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00276",
		linknext = "0017_00278",
		line = 3585,
	},
	["0017_00278"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“W-Well then! You believe that I, perfect gentleman that I am, would have something uncalled for to say? And here I thought you trusted me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你、你对我这位绅士警惕什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你、你對我這位紳士警惕什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00277",
		linknext = "0017_00279",
		line = 3597,
	},
	["0017_00279"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, I have something I want to ask.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，既然这样我有件事想拜托她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，既然這樣我有件事想拜託她。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00278",
		linknext = "0017_00280",
		line = 3607,
	},
	["0017_00280"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There is something I want to ask of everyone, not just Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不只是奈奈濑一个人……我有件事想拜托大家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不只是奈奈瀨一個人……我有件事想拜託大家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00279",
		linknext = "0017_00281",
		line = 3619,
	},
	["0017_00281"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0349", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“What is it, then? We'll help you with anything as long as we can do it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“什么什么？只要是我们能做的，什么事都会帮忙哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「什麼什麼？只要是我們能做的，什麼事都會幫忙哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00280",
		linknext = "0017_00282",
		line = 3634,
	},
	["0017_00282"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0556", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wata-chan, I'll have to ask you to not use the word anything!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“渡酱，不能说‘什么事’是原则哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「渡醬，不能說『什麼事』是原則哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00281",
		linknext = "0017_00283",
		line = 3648,
	},
	["0017_00283"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0350", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, sorry. We would like to offer as much assistance as possible, but would appreciate your understanding if we are unable to fulfill your requirements.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊我说错了。我将尽我最大的努力，如果不能如愿以偿，希望你能谅解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊我說錯了。我將盡我最大的努力，如果不能如願以償，希望你能諒解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00282",
		linknext = "0017_00284",
		line = 3664,
	},
	["0017_00284"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0557", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hey, no need to go all legalese on us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“也不需要用那么商务邮件式的感觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「也不需要用那麼商務郵件式的感覺……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00283",
		linknext = "0017_00285",
		line = 3678,
	},
	["0017_00285"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, anyway... there's a place I want investigated.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是那个……我有个想调查的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是那個……我有個想調查的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00284",
		linknext = "0017_00286",
		line = 3690,
	},
	["0017_00286"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0111", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
