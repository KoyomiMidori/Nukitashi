					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Más o menos. Nos encontramos y me monté en la parte trasera de su bicicleta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……偶然遇到……然后让她载了一程……”",
