	["0017_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Entre nosotros hay un silencio incómodo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后两个人之间，一阵尴尬的沉默。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後兩個人之間，一陣尷尬的沉默。",
					{"rt2"},
				},
			},
