		linkback = "0017_00068",
		linknext = "0017_00070",
		line = 869,
	},
	["0017_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí... Ver a una chica montando en bicicleta me hace pensar en mi madre cuando era joven. Que en paz descanse.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……骑自行车的女孩，长得很像很久以前去世的妈妈年轻时的样子之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……騎自行車的女孩，長得很像很久以前去世的媽媽年輕時的樣子之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00069",
		linknext = "0017_00071",
		line = 881,
	},
	["0017_00071"] = {
