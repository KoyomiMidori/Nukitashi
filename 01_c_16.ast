		},
		linkback = "0017_00010",
		linknext = "0017_00012",
		line = 148,
	},
	["0017_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y como no llevaba mucho conmigo, decidí dirigirme hacia un objeto que me dio curiosidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为少了那位大型行李，所以我前去调查在意的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為少了那位大型行李，所以我前去調查在意的東西。",
					{"rt2"},
