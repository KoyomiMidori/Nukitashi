		{"se", id=1, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh, se me olvidó.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……啊，完全忘了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……啊，完全忘了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00022",
		linknext = "0017_00024",
		line = 272,
	},
	["0017_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi sentido de la orientación sigue siendo pésimo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是个路痴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是個路痴。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00023",
		linknext = "0017_00025",
		line = 282,
	},
	["0017_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Qué raro... Solo estaba caminando por la ruta de senderismo. ¿Cómo me adentré tanto en el bosque?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奇怪，我明明走在散步路线上，现在怎么在森林里……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奇怪，我明明走在散步路線上，現在怎麼在森林裡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00024",
		linknext = "0017_00026",
		line = 294,
	},
	["0017_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Todo lo que veo frente a mí son árboles, árboles y más árboles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一带的森林看起来都差不多，无法区别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一帶的森林看起來都差不多，無法區別。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00025",
		linknext = "0017_00027",
		line = 304,
	},
	["0017_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si hablo con Asa-chan, puede solucionarlo inmediatamente, pero no puedo hacer eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果和麻沙酱联络的话可能一下子就解决了，但不能这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果和麻沙醬聯絡的話可能一下子就解決了，但不能這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00026",
		linknext = "0017_00028",
		line = 314,
	},
	["0017_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seguramente siga enfadada conmigo por haberle hecho una llave de brazo de judo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那家伙肯定还很在意刚刚被我手臂十字勒的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那傢伙肯定還很在意剛剛被我手臂十字勒的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00027",
		linknext = "0017_00029",
		line = 324,
	},
	["0017_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y todavía me duele el golpe que me dio antes con el hacha. Además, odio la idea de ceder ante ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而我刚刚吃了她的斧头拳现在还在疼。再说总感觉不想屈服于妹妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而我剛剛吃了她的斧頭拳現在還在痛。再說總感覺不想屈服於妹妹。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00028",
		linknext = "0017_00030",
		line = 334,
	},
	["0017_00030"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Agh... Pero si me pongo a perder el tiempo aquí, llegaré tarde...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，这样下去会迟到的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，這樣下去會遲到的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00029",
		linknext = "0017_00031",
		line = 347,
	},
	["0017_00031"] = {
		{"se", id=0, loop=0, file="se_a192"},
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0054", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "???"},
					"“Um... ¿Sucede algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬", "？ ？ ？"},
					"“请问……你怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬", "？？？"},
					"「請問……你怎麼了？」",
