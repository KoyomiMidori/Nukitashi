				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En todo caso, no hice que Hotori se uniera a nuestro equipo para eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我并不是因为这个才把畔拉进队伍里的。",
