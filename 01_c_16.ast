					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, but that's not all! I said, any more than that and I'll feel really dejected with myself!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然没错，但也不能那样！你一直说我会很伤心的！”",
