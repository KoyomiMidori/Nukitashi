	["0017_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así es como terminé yéndome solo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，我决定今天一个人去学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，我決定今天一個人去學校。",
					{"rt2"},
				},
