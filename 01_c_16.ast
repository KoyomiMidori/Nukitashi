	["0017_00240"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00104", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0545", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Como decía... Según la definición de Jun, el agravamiento de sus delirios es lo que le convierte en virgen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“也就是说淳的标准是，精神扭曲的话就是处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「也就是說淳的標準是，精神扭曲的話就是處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00239",
		linknext = "0017_00241",
		line = 3085,
	},
	["0017_00241"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
