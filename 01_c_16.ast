			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero con Hotori, la discusión se prolonga interminablemente sin llegar a ninguna parte.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知为什么和畔完全聊不起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知為什麼和畔完全聊不起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00082",
		linknext = "0017_00084",
		line = 1048,
	},
	["0017_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Será porque es 100 % mi tipo?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是因为她总体上来说是我喜欢的类型吗……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是因為她總體上來說是我喜歡的類型嗎……？",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00083",
		linknext = "0017_00085",
		line = 1058,
	},
	["0017_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Creo que sí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"應該是。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00084",
		linknext = "0017_00086",
		line = 1068,
	},
	["0017_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como dijo mi hermana, es mi tipo ideal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像妹妹说的，我非常喜欢这种女孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像妹妹說的，我非常喜歡這種女孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00085",
		linknext = "0017_00087",
		line = 1078,
	},
	["0017_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Reservada, dócil, ligeramente pasiva y básica. Por no hablar de su forma modesta de vestir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"低调、老实，有点消极且土里土气的女孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"低調、老實，有點消極且土裡土氣的女孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00086",
		linknext = "0017_00088",
		line = 1088,
	},
	["0017_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿No es eso una receta para la casi perfección? Sería aún mejor si fuera una amiga de la infancia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"清纯系，简直太棒了。最好还是青梅竹马。",
					{"rt2"},
				},
			},
			tw = {
				{
					"清純系，簡直太棒了。最好還是青梅竹馬。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00087",
		linknext = "0017_00089",
		line = 1098,
	},
	["0017_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi idea de la perfección es alguien que quedaría en tercer lugar en una encuesta de popularidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是在人气投票中排名第三的话更好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是在人氣投票中排名第三的話更好。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00088",
		linknext = "0017_00090",
		line = 1108,
	},
	["0017_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero los humanos son criaturas extrañas... Cada vez que estamos solos, las palabras no me salen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但人类真是不可思议的生物，和这样的女孩子一独处，话就说不出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但人類真是不可思議的生物，和這樣的女孩子一獨處，話就說不出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00089",
		linknext = "0017_00091",
		line = 1118,
	},
	["0017_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, esperen... Tal vez sea mejor así.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——但是，没关系。",
					{"rt2"},
				},
			},
			tw = {
