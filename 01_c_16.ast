	["0017_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My sense of direction still sucks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是个路痴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是個路痴。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00023",
		linknext = "0017_00025",
		line = 282,
	},
	["0017_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Strange... I was only walking on the hiking trail. How'd I end up this deep in the woods?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奇怪，我明明走在散步路线上，现在怎么在森林里……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奇怪，我明明走在散步路線上，現在怎麼在森林裡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00024",
		linknext = "0017_00026",
		line = 294,
	},
	["0017_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All I can see in front of me are trees, trees and more trees.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一带的森林看起来都差不多，无法区别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一帶的森林看起來都差不多，無法區別。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00025",
		linknext = "0017_00027",
		line = 304,
	},
	["0017_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I contact Asa-chan she can sort it out for me immediately, but I can't very well do that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果和麻沙酱联络的话可能一下子就解决了，但不能这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果和麻沙醬聯絡的話可能一下子就解決了，但不能這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00026",
		linknext = "0017_00028",
		line = 314,
	},
	["0017_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's probably still pissed off at me for getting her into a judo armlock earlier.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那家伙肯定还很在意刚刚被我手臂十字勒的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那傢伙肯定還很在意剛剛被我手臂十字勒的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00027",
		linknext = "0017_00029",
		line = 324,
	},
	["0017_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I'm still hurting from the axe bomber she gave me earlier. Plus, I hate the thought of conceding to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而我刚刚吃了她的斧头拳现在还在疼。再说总感觉不想屈服于妹妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而我剛剛吃了她的斧頭拳現在還在痛。再說總感覺不想屈服於妹妹。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00028",
		linknext = "0017_00030",
		line = 334,
	},
	["0017_00030"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But damn... If I keep standing around wasting time like this, I'm really gonna be late...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，这样下去会迟到的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，這樣下去會遲到的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00029",
		linknext = "0017_00031",
		line = 347,
	},
	["0017_00031"] = {
