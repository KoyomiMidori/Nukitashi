	["0017_00154"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=100, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, I can't do it! I'm too anxious to call someone of the opposite sex by their first name!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不，不行！要我用名字称呼异性……太紧张了办不到！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不，不行！要我用名字稱呼異性……太緊張了辦不到！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00153",
		linknext = "0017_00155",
		line = 1986,
	},
	["0017_00155"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0530", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Why are you so self-conscious about it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“有什么好在意的嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「有什麼好在意的嘛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00154",
		linknext = "0017_00156",
		line = 2000,
	},
	["0017_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don't do that until you've been dating and or living together for at LEAST three years! That's basic shit, ain't it!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种事不交往同居个3年左右怎么行！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這種事不交往同居個3年左右怎麼行！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00155",
		linknext = "0017_00157",
		line = 2012,
	},
	["0017_00157"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0088", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ahaha... if you can't call me by name then our sense of solidarity is probably too low, so let's go back to how we were calling each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊哈哈哈……连名字都喊不了的话，团结力反而会下降呢，所以我们还是改回之前的方式吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊哈哈哈……連名字都喊不了的話，團結力反而會下降呢，所以我們還是改回之前的方式吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00156",
		linknext = "0017_00158",
		line = 2026,
	},
	["0017_00158"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
