	["0017_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al parecer, sufrió una dura derrota en su juego online y se niega a rendirse hasta que recupere su puntuación de 3500.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她似乎在网游上被人狠狠地虐了一顿，在今天汇率恢复3500点之前，打算绝对不放弃的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她似乎在網游上被人狠狠地虐了一頓，在今天匯率恢復3500點之前，打算絕對不放棄的樣子。",
					{"rt2"},
				},
			},
