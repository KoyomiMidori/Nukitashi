			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I, uh... don't remotely appear to be of age for any sexual activity anyway... but I'm not a loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我、我是……那个，本来就被认为是条例对象外，所以……不过我不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我、我是……那個，本來就被認為是條例對象外，所以……不過我不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00308",
		linknext = "0017_00310",
		line = 4042,
	},
	["0017_00310"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0117", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, I see... Then I should be fine as well... given my lack of presence and all... haha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，原来如此……那我也没关系吧……毕竟存在感很薄弱……哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，原來如此……那我也沒關係吧……畢竟存在感很薄弱……哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00309",
		linknext = "0017_00311",
		line = 4056,
	},
	["0017_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, when you consider what our activities are, they're undoubtedly useful characteristics.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是考虑到我们的活动内容，这无疑是一种有利的特性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是考慮到我們的活動內容，這無疑是一種有利的特性。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00310",
		linknext = "0017_00312",
		line = 4066,
	},
	["0017_00312"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We have to make the most of everyone's strengths in order to make it home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们需要利用各自的强项，安全回家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們需要利用各自的強項，安全回家。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00311",
		linknext = "0017_00313",
		line = 4076,
	},
	["0017_00313"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase, we're gonna do the low tide route today. I'm guessing we can just barely make it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……奈奈濑，今天也要通过退潮路线。应该勉强还可以走吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……奈奈瀨，今天也要通過退潮路線。應該勉強還可以走吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00312",
		linknext = "0017_00314",
		line = 4088,
	},
	["0017_00314"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0562", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, we should be fine, but we're really gonna be cutting it close. The water's gonna be up to our knees, so be mindful of that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，应该可以……但今天真的有点勉强了。水会淹到膝盖所以小心点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，應該可以……但今天真的有點勉強了。水會淹到膝蓋所以小心點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00313",
		linknext = "0017_00315",
		line = 4102,
	},
	["0017_00315"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. I guess we should assume using it tomorrow is a no gonna work, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——从这个时间点的状况看来，最好先做好明天无法使用的打算……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯——從這個時間點的狀況看來，最好先做好明天無法使用的打算……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00314",
		linknext = "0017_00316",
		line = 4113,
	},
	["0017_00316"] = {
		{"se", id="0水", loop=0, file="se_a024"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In fact, it shouldn't really be a consideration in the first place. It is our last-resort method, after all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不禁觉得很不巧……因为这条路线本来就已经是最终手段了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不禁覺得很不巧……因為這條路線本來就已經是最終手段了。",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00315",
		linknext = "0017_00317",
		line = 4124,
	},
	["0017_00317"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We'll have to think of something better for tomorrow.",
					{"rt2"},
				},
			},
			cn = {
				{
