		{"bg", id=1, file="bg19_1l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="asane_01m_00007", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0532", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡No pasa nada, todo va a salir bien! Me quedaré aquí, trabajaré un poco, haré algunas campañas... O sea, ya tenemos todo lo que necesito en casa, así que estoy lista...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你放心，巡逻和引导都在家里做……应该说我们家的设备更齐全，反而能做得更完美……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你放心，巡邏和引導都在家裡做……應該說我們家的設備更齊全，反而能做得更完美……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00007",
		linknext = "0017_00009",
		line = 103,
	},
	["0017_00009"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0533", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A ver, que tengo que controlar todo desde mi silla gamer, es lo normal, ¿así que pa qué te acompaño? Intenta metértelo en tu dura cabeza maldito insensible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“而且引导员一般都是坐在安乐椅上下达命令的像这样特地出门搞才奇怪呢多嘴的混蛋处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「而且引導員一般都是坐在安樂椅上下達命令的像這樣特地出門搞才奇怪呢多嘴的混蛋處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00008",
		linknext = "0017_00010",
		line = 117,
	},
	["0017_00010"] = {
