	["0017_00061"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0063", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, it's... pretty nice weather we're having today, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“今天……天气，真好啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「今天……天氣，真好啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00060",
		linknext = "0017_00062",
		line = 765,
	},
	["0017_00062"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Harder to tell when you're in the middle of the woods... But yeah, it is pretty nice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然在森林中不太清楚，不过的确是好天气……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然在森林中不太清楚，不過的確是好天氣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00061",
		linknext = "0017_00063",
		line = 777,
	},
	["0017_00063"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0064", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
