	["0017_00319"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's near where I saved you, actually. We're getting pretty close.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我救畔的地方也在这附近。所以，这里离目的地很近。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我救畔的地方也在這附近。所以，這裡離目的地很近。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00318",
