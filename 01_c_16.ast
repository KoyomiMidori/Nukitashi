	["0017_00068"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Caminar al lado de una chica mientras ella va en bicicleta... Es como un tropo ficticio muy común.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和骑自行车的女孩并排走路……这还真是俗套的情景呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和騎自行車的女孩並排走路……這還真是俗套的情景呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00067",
		linknext = "0017_00069",
		line = 853,
	},
	["0017_00069"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
