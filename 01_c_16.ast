			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“完全没察觉到小萝莉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「完全沒察覺到小蘿莉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00175",
		linknext = "0017_00177",
