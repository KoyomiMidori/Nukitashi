				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0118", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's so bright here... Ah, is this where we come out? I often pass by here on my bike, and my house is close by!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好耀眼……啊，可以从这里出来呢！我骑自行车时经常通过，而且离我家很近……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好耀眼……啊，可以從這裡出來呢！我騎自行車時經常通過，而且離我家很近……！」",
					{"rt2"},
				},
			},
