		linkback = "0017_00154",
		linknext = "0017_00156",
		line = 2000,
	},
	["0017_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡No se hace eso hasta que no hayan estado saliendo o viviendo juntos durante al menos tres años! ¡Es algo básico, ¿no?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种事不交往同居个3年左右怎么行！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這種事不交往同居個3年左右怎麼行！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00155",
		linknext = "0017_00157",
		line = 2012,
	},
	["0017_00157"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0088", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ajaja... Si no puedes llamarme por mi nombre, es posible que nuestro sentido de la solidaridad sea demasiado bajo, así que volvamos a llamarnos como antes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊哈哈哈……连名字都喊不了的话，团结力反而会下降呢，所以我们还是改回之前的方式吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊哈哈哈……連名字都喊不了的話，團結力反而會下降呢，所以我們還是改回之前的方式吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00156",
		linknext = "0017_00158",
		line = 2026,
	},
	["0017_00158"] = {
