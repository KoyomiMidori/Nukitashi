					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're just gonna weather this 'Shootdown King' shit and then search for her. This girl could be alone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“尽快度过此次‘击坠王’，然后去找这个女孩吧。说不定她也很孤独——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「盡快度過此次『擊墜王』，然後去找這個女孩吧。說不定她也很孤獨——」",
					{"rt2"},
				},
			},
