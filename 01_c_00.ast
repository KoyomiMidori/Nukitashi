			},
			tw = {
				{
					"和從入島審查所到目的地的距離是差不多的時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00077",
		linknext = "0001_00079",
		line = 1299,
	},
	["0001_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nos estaba insinuando a entregarnos a una indulgencia sexual sin límites.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了之后让我们没日没夜沉溺在做爱中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了之後讓我們沒日沒夜沉溺在做愛中。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00078",
		linknext = "0001_00080",
		line = 1309,
	},
	["0001_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El sonido de las olas resuena a nuestro alrededor, mientras el barco atraviesa el agua.",
					{"rt2"},
				},
			},
			cn = {
				{
					"飞溅到船上的浪花，混杂着海浪的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"飛濺到船上的浪花，混雜著海浪的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00079",
		linknext = "0001_00081",
		line = 1319,
	},
	["0001_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A medida que disminuye su velocidad, las olas comienzan a cambiar su forma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随着船的减速，破浪的形状发生了变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨著船的減速，破浪的形狀發生了變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00080",
		linknext = "0001_00082",
		line = 1329,
	},
	["0001_00082"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0000a", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"船内放送"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"船内放送", "Anunciante del barco"},
					"“Pronto llegaremos a la Isla Seiran. Rogamos a los pasajeros con vehículos que permanezcan en ellos por ahora.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"船内放送", "船内广播"},
					"“——很快就要到达青蓝岛了。驾车的乘客请在车内等候——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"船内放送", "船內廣播"},
					"「——很快就要到達青藍島了。駕車的乘客請在車內等候——」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00081",
		linknext = "0001_00083",
		line = 1341,
	},
	["0001_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Gritos de alegría se oyen en su interior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可以从船内听到欢呼声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可以從船內聽到歡呼聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00082",
		linknext = "0001_00084",
		line = 1351,
	},
	["0001_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La vibrante energía de este lugar también es palpable para los que estamos en cubierta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在我们所在的甲板上，也感受到了岛上充满生气的能量。",
