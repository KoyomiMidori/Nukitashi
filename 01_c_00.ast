		linknext = "0001_00059",
		line = 1051,
	},
	["0001_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De sus ojos desaparece la luz. Tiene la mirada hambrienta de una depredadora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使两眼无神，那也是猎人一般的“眼睛”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使兩眼無神，那也是獵人一般的「眼睛」。",
					{"rt2"},
				},
