				{"vo", file="touka0007", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Jeje... Por fin te atrapé, senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“呜呼呼……终于抓住你了，前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「嗚呼呼……終於抓住你了，前輩。」",
					{"rt2"},
				},
