	["0001_00062"] = {
		{"se", id=0, loop=0, file="se_b047"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Intento liberarme, pero estoy completamente inmovilizado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想要挣扎，却办不到。身体被什么固定住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想要掙扎，卻辦不到。身體被什麼固定住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00061",
		linknext = "0001_00063",
		line = 1098,
	},
	["0001_00063"] = {
		{"fg", file="touka_01l_00001", file1="touka_01l_00110", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0009", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Por más que lo intentes, no vas a escapar. Ahora eres mi prisionero. Nada más que una marioneta para ser manipulada y utilizada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“想要逃跑是没有用的，你已经是笼中鸟。现在只需要在这个用蓝染的线编织而成的舞台上跳舞——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「想要逃跑是沒有用的，你已經是籠中鳥。現在只需要在這個用藍染的線編織而成的舞臺上跳舞——」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00062",
		linknext = "0001_00064",
		line = 1112,
	},
	["0001_00064"] = {
