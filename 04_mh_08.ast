	["0085_00244"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1345", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You're sleeping in the same room, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为她可是会和哥哥睡在同一个房间哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為她可是會和哥哥睡在同一個房間哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00243",
		linknext = "0085_00245",
		line = 3299,
	},
	["0085_00245"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you take me for? I'll have you know I'm a gentleman. Hotori can have my bed, and I'll sleep out here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你认为我会做出这种没有自豪感的事吗？畔睡我的床——而我睡在这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你認為我會做出這種沒有自豪感的事嗎？畔睡我的床——而我睡在這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00244",
