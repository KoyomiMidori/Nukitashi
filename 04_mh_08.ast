		linkback = "0085_00344",
		linknext = "0085_00346",
		line = 4629,
	},
	["0085_00346"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What was it like before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是什么感想啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是什麼感想啊。」",
					{"rt2"},
