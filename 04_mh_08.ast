			},
		},
		text = {
			vo = {
				{"vo", file="asane1330", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“0120... then, uh... f-i-r-e, so 3473, right? Then... Bro, how do you spell 'department'?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“0120……那之后……因为是消防车，‘消’是7吧……然后……啊，哥哥……‘防’是几号……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「0120……那之後……因為是消防車，『消』是7吧……然後……啊，哥哥……『防』是幾號……！？」",
					{"rt2"},
				},
