		{"fg", file="misaki_01m_00002", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"bgm", file="bgm21", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was bullied.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我被霸凌了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我被霸凌了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00413",
		linknext = "0085_00415",
		line = 5459,
	},
	["0085_00415"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00117", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I said it in a low voice, but I can tell that Hotori seized up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我用轻松的语气说道，然后马上察觉畔的身体僵硬了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我用輕鬆的語氣說道，然後馬上察覺畔的身體僵硬了。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00414",
		linknext = "0085_00416",
		line = 5471,
	},
	["0085_00416"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was when I used to live here when I was little. They kept teasing me, saying things like, 'it's so big, it's disgusting'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在我还是孩子……还在青蓝岛的时候。被说‘你的好大好恶心’欺负了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在我還是孩子……還在青藍島的時候。被說『你的好大好噁心』欺負了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00415",
		linknext = "0085_00417",
		line = 5483,
	},
	["0085_00417"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0995", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But why would they do that? That's not something anyone should be teased for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那种事……真奇怪。那应该不是会被欺负的事情才对……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那種事……真奇怪。那應該不是會被欺負的事情才對……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00416",
		linknext = "0085_00418",
		line = 5497,
	},
	["0085_00418"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess. Looking back on it, yeah, it's kinda weird.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……现在回想起来或许有点奇怪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……現在回想起來或許有點奇怪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00417",
		linknext = "0085_00419",
		line = 5511,
	},
	["0085_00419"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But we were kids. You see it all the time, kids will pick on people for anything that's different.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，那时候的我还是个孩子……被责备和别人不一样，并不是什么稀罕事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，那時候的我還是個孩子……被責備和別人不一樣，並不是什麼稀罕事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00418",
		linknext = "0085_00420",
		line = 5523,
	},
	["0085_00420"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, as kids, I guess. It just still bothers me a lot today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反正就是小时候常有的事。只是到现在——我还放不下。仅此而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「反正就是小時候常有的事。只是到現在——我還放不下。僅此而已。」",
