	},
	["0085_00158"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0933", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, does salt count? I drank water, too. Water with a side of salt. Sometimes I'd eat the salt first and then drink the water as a side, to mix things up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，我有摄取盐和水。有时把盐当成配菜喝水……有时则把水当配菜舔盐，就这样变来变去……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，我有攝取鹽和水。有時把鹽當成配菜喝水……有時則把水當配菜舔鹽，就這樣變來變去……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00157",
		linknext = "0085_00159",
		line = 2183,
	},
	["0085_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm at a loss for words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无语了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無語了。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00158",
		linknext = "0085_00160",
		line = 2193,
	},
	["0085_00160"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the fuck, Hotori...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔，你啊……唉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔，你啊……唉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00159",
		linknext = "0085_00161",
		line = 2205,
	},
	["0085_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unable to put how I feel about that into words, I just sigh.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无可奈何地说不出话来，最后只能叹了一口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無可奈何地說不出話來，最後只能嘆了一口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00160",
		linknext = "0085_00162",
		line = 2215,
	},
	["0085_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that she mentions it, I don't remember seeing her eat anything for the last week.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想起来，的确有段时间没有看到畔吃东西的记忆了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回想起來，的確有段時間沒有看到畔吃東西的記憶了。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00161",
		linknext = "0085_00163",
		line = 2225,
	},
	["0085_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I assumed she was just restraining herself because she was on a diet, but I didn't think she was fasting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为知道她正在减肥所以才没有特别留心——但没想到她居然在绝食。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為知道她正在減肥所以才沒有特別留心——但沒想到她居然在絕食。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00162",
		linknext = "0085_00164",
		line = 2235,
	},
	["0085_00164"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know you're trying to lose as much weight as possible, but working out like you have been while also fasting is way too much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管怎么想瘦，绝食、仰卧起坐，再加上骑自行车……也太勉强了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管怎麼想瘦，絕食、仰臥起坐，再加上騎自行車……也太勉強了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00163",
		linknext = "0085_00165",
		line = 2247,
	},
	["0085_00165"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[7700] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=7700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0934", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sorry... I looked up information on dieting and that was all the rage. Something about dosex?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对不起……我调查了一下关于减肥的事，结果这样的好像很流行……好像是叫……排遗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對不起……我調查了一下關於減肥的事，結果這樣的好像很流行……好像是叫……排遺？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00164",
		linknext = "0085_00166",
		line = 2263,
	},
	["0085_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Detox.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是排毒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是排毒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00165",
		linknext = "0085_00167",
		line = 2275,
	},
	["0085_00167"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00112", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1334", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“How the hell'd you get that so fast?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“为什么哥哥瞬间就知道了……真可怕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「為什麼哥哥瞬間就知道了……真可怕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00166",
		linknext = "0085_00168",
		line = 2288,
	},
	["0085_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't help but understand the way Hotori works now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这点事，只要和畔在一起不想明白也会明白。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這點事，只要和畔在一起不想明白也會明白。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00167",
		linknext = "0085_00169",
		line = 2298,
	},
	["0085_00169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I remember correctly, detoxing is mostly pseudoscientific bullshit. I know you're desperate, but if you collapsed like that mid-mission, everything would've been pointless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算是排毒也不会做到那么极端吧。我知道你很焦躁……但如果倒下了就没有用了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算是排毒也不會做到那麼極端吧。我知道你很焦躁……但如果倒下了就沒有用了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00168",
		linknext = "0085_00170",
		line = 2310,
	},
	["0085_00170"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0935", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I'm deeply ashamed...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我很惭愧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我很慚愧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00169",
		linknext = "0085_00171",
		line = 2324,
	},
	["0085_00171"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I'm sorry I didn't pick up on it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过没注意到的我也有不对的地方……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過沒注意到的我也有不對的地方……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00170",
		linknext = "0085_00172",
		line = 2336,
	},
	["0085_00172"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In any case, you're all right now, and we're both at fault. Just don't overdo it like that ever again, okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然没发生什么大问题，这次就先这样了……不过，今后你可别再这么胡来哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然沒發生什麼大問題，這次就先這樣了……不過，今後你可別再這麼胡來哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00171",
		linknext = "0085_00173",
		line = 2348,
	},
	["0085_00173"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0936", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes. I swear on my mother's grave. Sorry for intruding so late. I should get going.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好的……我会铭记在五脏六腑的。那么……打搅到这么晚真是对不起，我该告辞了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好的……我會銘記在五臟六腑的。那麼……打攪到這麼晚真是對不起，我該告辭了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00172",
		linknext = "0085_00174",
		line = 2365,
	},
	["0085_00174"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait. How do you plan to get home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等等——你打算怎么回去？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等等——你打算怎麼回去？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00173",
		linknext = "0085_00175",
		line = 2377,
	},
	["0085_00175"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0937", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“On my bike, as usual. After eating so much, I should probably exercise...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“和往常一样骑自行车……因为吃得很饱，就顺便当成运动……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「和往常一樣騎自行車……因為吃得很飽，就順便當成運動……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00174",
		linknext = "0085_00176",
		line = 2391,
	},
	["0085_00176"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did I just tell you about overdoing it? Does swearing on your mother's grave not count if your mom's still alive?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我刚才才说不要乱来哦……五脏六腑没在工作吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我剛才才說不要亂來哦……五臟六腑沒在工作嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00175",
		linknext = "0085_00177",
		line = 2403,
	},
	["0085_00177"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0938", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I... I guess... then how do I get home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没在工作就不在这个世上了啦〜……但如果是这样的话……我该怎么办好呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒在工作就不在這個世上了啦〜……但如果是這樣的話……我該怎麼辦好呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00176",
		linknext = "0085_00178",
		line = 2419,
	},
	["0085_00178"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Can't you get a family member to come get you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没办法让家人来接你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒辦法讓家人來接你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00177",
		linknext = "0085_00179",
		line = 2431,
	},
	["0085_00179"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0939", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I don't think so. My dad is working on the mainland, and my mom and sisters can't drive.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我觉得很难。爸爸一个人在本岛出差，妈妈和姐姐们也都不会开车……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我覺得很難。爸爸一個人在本島出差，媽媽和姐姐們也都不會開車……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00178",
		linknext = "0085_00180",
		line = 2445,
	},
	["0085_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could walk her home, but since she just collapsed, it's probably too much to ask for her to get up the hill.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我可以送她回去，但是要让倒下的她走回山那边的家，应该又会成为很大的负担吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我可以送她回去，但是要讓倒下的她走回山那邊的家，應該又會成為很大的負擔吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00179",
		linknext = "0085_00181",
		line = 2455,
	},
	["0085_00181"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I guess that leaves me no other choice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话——没办法了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話——沒辦法了。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00180",
		linknext = "0085_00182",
		line = 2466,
	},
	["0085_00182"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess it'd be best for you to stay the night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔——今天就住在我家吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔——今天就住在我家吧。」",
					{"rt2"},
				},
			},
		},
