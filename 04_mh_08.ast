		text = {
			vo = {
				{"vo", file="misaki0972", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wow, i-it's beautiful! It's so sparkly!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“唔哇——！好、好厉害……一切看起来都那么耀眼……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「唔哇——！好、好厲害……一切看起來都那麼耀眼……！」",
