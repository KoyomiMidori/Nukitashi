	["0085_00067"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1322", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Since you put me on comms, I thought it'd be a good chance to get into the swing of things, you know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“毕竟我负责通讯支援，我想必须让她现在先习惯一下……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「畢竟我負責通訊支援，我想必須讓她現在先習慣一下……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00066",
		linknext = "0085_00068",
		line = 876,
	},
	["0085_00068"] = {
