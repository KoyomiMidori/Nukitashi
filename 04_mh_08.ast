	["0085_00325"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00119", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="misaki_02m_00002", file1="misaki_02m_00106", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0966", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Have you finally calmed down? Don't scare me like that. Does this kind of thing happen a lot?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呼……终于平静下来了……突然说出奇怪的话吓了我一跳……你经常这样吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呼……終於平靜下來了……突然說出奇怪的話嚇了我一跳……你經常這樣嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00324",
		linknext = "0085_00326",
		line = 4330,
	},
	["0085_00326"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The fuck do you think I am? Never. I thought you were already asleep, so when you started talking, I thought it was just a hallucination, so I thought talking back would help me get to sleep.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“经常这样还得了……这是我的第一次。我以为畔早就睡着了，所以误以为是幻听，不知不觉就说了那些话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「經常這樣還得了……這是我的第一次。我以為畔早就睡著了，所以誤以為是幻聽，不知不覺就說了那些話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00325",
		linknext = "0085_00327",
		line = 4342,
	},
	["0085_00327"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00118", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0967", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, sometimes it feels like my existence itself is a hallucination, so I can see how you'd think that, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我的存在本身就有点虚无缥缈，所以其实也能把我说的话全当成幻听……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我的存在本身就有點虛無縹緲，所以其實也能把我說的話全當成幻聽……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00326",
		linknext = "0085_00328",
		line = 4356,
	},
	["0085_00328"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please don't get depressing on me now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别用那么悲伤的思考方式啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別用那麼悲傷的思考方式啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00327",
		linknext = "0085_00329",
		line = 4368,
	},
	["0085_00329"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00106", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0968", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Okay, but why were you thinking so much about me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好的……但是，你为什么这么想我呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好的……但是，你為什麼這麼想我呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00328",
		linknext = "0085_00330",
		line = 4382,
	},
	["0085_00330"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh... uh, you know... just thinking about the mission, and how important you are for it, that's all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是……啊，是那个……在考虑作战计划，才不小心……毕竟畔是关键嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是……啊，是那個……在考慮作戰計劃，才不小心……畢竟畔是關鍵嘛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00329",
		linknext = "0085_00331",
		line = 4394,
	},
	["0085_00331"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00109", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="misaki_02m_00002", file1="misaki_02m_00102", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0969", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, yes... o-of course! Sorry, I seem to have misunderstood...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，是这样啊……说、说的也是！对不起，我可能误会了什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，是這樣啊……說、說的也是！對不起，我可能誤會了什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00330",
		linknext = "0085_00332",
		line = 4411,
	},
	["0085_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I really want to know what she thought I meant, but I try to keep my cool.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我非常在意那个误解和实际情况，但我努力摆出一脸清爽的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我非常在意那個誤解和實際情況，但我努力擺出一臉清爽的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00331",
		linknext = "0085_00333",
		line = 4421,
	},
	["0085_00333"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
