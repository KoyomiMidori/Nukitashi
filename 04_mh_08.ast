		linkback = "0085_00120",
		linknext = "0085_00122",
		line = 1652,
	},
	["0085_00122"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00121", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1326", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“H-How the fuck would I know!? H-How did this happen!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你、你问我怎么办……为……为什么会突然这样……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你、你問我怎麼辦……為……為什麼會突然這樣……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00121",
		linknext = "0085_00123",
		line = 1666,
	},
	["0085_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't fucking know! It just kinda happened out of nowhere, but since we were close by I just brought her here. I was hoping she'd wake up on the way, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也不知道！总之太突然了……因为家很近，就先把她带过来了……但是畔还是完全不醒来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也不知道！總之太突然了……因為家很近，就先把她帶過來了……但是畔還是完全不醒來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00122",
		linknext = "0085_00124",
		line = 1678,
	},
	["0085_00124"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00108", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1327", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Y-You think this is my fault!? Maybe I stressed her out by shittalking her all the time!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“难、难道是我的错……？因为我总是对畔同学说一些坏话，所以她因为压力而……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「難、難道是我的錯……？因為我總是對畔同學說一些壞話，所以她因為壓力而……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00123",
		linknext = "0085_00125",
		line = 1692,
	},
	["0085_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Doesn't matter! Just do something—her life is on the line!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么可能！总之得赶快想想办法……再这样下去畔就要死了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼可能！總之得趕快想想辦法……再這樣下去畔就要死了！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00124",
		linknext = "0085_00126",
		line = 1704,
	},
	["0085_00126"] = {
		{"fg", file="asane_02l_00001", file1="asane_02l_00109", file2="asane_02l_00202", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1328", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“W-We need to call one of those... you know, those cars... what were they called... uh, a h-hearse!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“总之就是那个……要叫车，车……呃……是灵车吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「總之就是那個……要叫車，車……呃……是靈車嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00125",
		linknext = "0085_00127",
		line = 1718,
	},
	["0085_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You idiot! That comes later! First we call... a, uh... fire engine! That's the one!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“笨蛋！灵车是之后才要叫的吧！要先叫那个……呃……消防车！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「笨蛋！靈車是之後才要叫的吧！要先叫那個……呃……消防車！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00126",
		linknext = "0085_00128",
		line = 1729,
	},
	["0085_00128"] = {
		{"fg", file="asane_02l_00001", file1="asane_02l_00105", file2="asane_02l_00202", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1329", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“W-We just need to calm the fuck down! Let's do that ASAP... Shit, what was the fire department's number again!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“也、也对，得先冷静一下脑袋……那我马上去叫……咦……消防车的电话号码是多少来着……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「也、也對，得先冷靜一下腦袋……那我馬上去叫……咦……消防車的電話號碼是多少來著……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00127",
		linknext = "0085_00129",
		line = 1743,
	},
	["0085_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was... fuck, I forgot, too!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好像是——可恶！这个时候突然忘了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好像是——可惡！這個時候突然忘了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00128",
		linknext = "0085_00130",
		line = 1755,
	},
	["0085_00130"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was a toll-free number, right? I think it started with 0120...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该是免费电话……所以一定是从0120开始的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該是免費電話……所以一定是從0120開始的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00129",
		linknext = "0085_00131",
		line = 1767,
	},
	["0085_00131"] = {
