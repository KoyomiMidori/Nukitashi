		linkback = "0085_00048",
		linknext = "0085_00050",
		line = 612,
	},
	["0085_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since you have to participate in a swimsuit, she'll have to put her personal belongings in her locker.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为有穿泳衣参加这个原则，所以随身物品必须要放进柜子里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為有穿泳衣參加這個原則，所以隨身物品必須要放進櫃子裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00049",
		linknext = "0085_00051",
		line = 622,
	},
	["0085_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Naturally, that should include her SS keycard.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，FS的IC卡也包括在随身物品里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，FS的IC卡也包括在隨身物品裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00050",
		linknext = "0085_00052",
		line = 632,
	},
	["0085_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Assuming everything goes according to plan tomorrow, getting the card is virtually guaranteed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要明天如期举行的话，几乎肯定可以得到卡。",
