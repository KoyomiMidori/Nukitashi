					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, why are you awake? Did you sleep at all?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个……畔才是，你为什么还醒着？睡不着吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個……畔才是，你為什麼還醒著？睡不著嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00332",
		linknext = "0085_00334",
		line = 4433,
	},
