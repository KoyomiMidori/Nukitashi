			},
		},
		text = {
			vo = {
				{"vo", file="asane1325", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What!? Th-That's... Hotori!? Is... Is she dead!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶……那、那是……难道是、畔同学……！？啊、啊、哥哥……杀掉了她吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸……那、那是……難道是、畔同學……！？啊、啊、哥哥……殺掉了她嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00118",
		linknext = "0085_00120",
		line = 1624,
	},
	["0085_00120"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fuck off! I was just spotting her as she rode her bike around for her diet, when she suddenly fell over, crashed, and wouldn't wake up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不对！我本来是为了帮助她减肥而看着她骑自行车，但她突然‘哇’的一声跌倒了，我冲上去接住她后……就怎么样都不起来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不對！我本來是為了幫助她減肥而看著她騎自行車，但她突然『哇』的一聲跌倒了，我衝上去接住她後……就怎麼樣都不起來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00119",
		linknext = "0085_00121",
		line = 1636,
	},
	["0085_00121"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fgact", ch="美岬", id=6, act="移動", x=0, y=100, time=600},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=400},
		{"fg", file="jun_01f_00001", file1="jun_01f_00122", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
