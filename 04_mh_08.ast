		linkback = "0085_00047",
		linknext = "0085_00049",
		line = 602,
	},
	["0085_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was always planned to be tomorrow during the olympiad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正式行动本来就是明天的体欲节。",
