		linknext = "0085_00239",
		line = 3222,
	},
	["0085_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not like we're bathing together or something, so why should it be a problem?",
					{"rt2"},
				},
			},
			cn = {
				{
					"说到底之前就一起泡过温泉了，现在还有什么好在意的——",
