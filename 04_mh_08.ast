			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Okay, fire department's out, so what the fuck do we do!? A-At this rate, Hotori's gonna diiiiieee!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么办，这样就叫不了消防车了！这、这样下去畔同学就要死了啊啊啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼辦，這樣就叫不了消防車了！這、這樣下去畔同學就要死了啊啊啊……！」",
					{"rt2"},
				},
			},
		},
