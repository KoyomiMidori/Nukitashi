	["0085_00360"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0981", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Do you ever find yourself wishing that everything, all that included, was all a dream?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“橘同学……包括这些事在内，你也觉得这是梦就好了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「橘同學……包括這些事在內，你也覺得這是夢就好了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00359",
		linknext = "0085_00361",
		line = 4819,
	},
	["0085_00361"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess not. I'm glad that you, Wata, and Nanase are real.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不……畔和渡酱……还有奈奈濑你们的事……我也觉得那不是梦真是太好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不……畔和渡醬……還有奈奈瀨你們的事……我也覺得那不是夢真是太好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00360",
		linknext = "0085_00362",
		line = 4831,
	},
	["0085_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though I'm just saying how I feel, it's weirdly embarrassing to say it out loud.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这是我毫不掩饰的真心，但说出口却莫名地害羞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這是我毫不掩飾的真心，但說出口卻莫名地害羞。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00361",
		linknext = "0085_00363",
		line = 4841,
	},
	["0085_00363"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nonetheless, Hotori just smiles happily and stuffs a tuna and mayo rice ball into her mouth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过畔看起来并不在意，而是高兴地微笑着吃着金枪鱼饭团。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過畔看起來並不在意，而是高興地微笑著吃著金槍魚飯糰。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00362",
		linknext = "0085_00364",
		line = 4854,
	},
	["0085_00364"] = {
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0982", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Munch, munch... This brings back memories. When I was little, I'd come to this beach all the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嚼嚼嚼……好怀念啊……小时候我经常来这里的沙滩哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嚼嚼嚼……好懷念啊……小時候我經常來這裡的沙灘哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00363",
		linknext = "0085_00365",
		line = 4867,
	},
	["0085_00365"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You played here often?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“经常在这里玩吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「經常在這裡玩嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00364",
		linknext = "0085_00366",
		line = 4879,
	},
	["0085_00366"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0983", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, we did morning radio calisthenics here. The only ones who lived up in the hills were old folks, so they did them here. Every morning I rode down here on my bike.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不……是早上的广播体操。山的那边因为都是老爷爷们所以没有，所以我就每天早上骑着自行车来到这里……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不……是早上的廣播體操。山的那邊因為都是老爺爺們所以沒有，所以我就每天早上騎著自行車來到這裡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00365",
		linknext = "0085_00367",
		line = 4891,
	},
	["0085_00367"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you've been riding a long time? No wonder you're so fast.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你以前就骑吗？难怪会这么快。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你以前就騎嗎？難怪會這麼快。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00366",
		linknext = "0085_00368",
		line = 4903,
	},
	["0085_00368"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually, now that you mention it... I think I remember doing them here, too. A long time ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来……我也记得以前在这里做过广播体操。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來……我也記得以前在這裡做過廣播體操。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00367",
		linknext = "0085_00369",
		line = 4915,
	},
	["0085_00369"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0984", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, incredible. Do you think... maybe we met here once when we were little?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“什么！这么说来……我们小时候可能见过面吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「什麼！這麼說來……我們小時候可能見過面吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00368",
		linknext = "0085_00370",
		line = 4931,
	},
	["0085_00370"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Could be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也许吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也許吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00369",
		linknext = "0085_00371",
		line = 4943,
	},
	["0085_00371"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I put a yakisoba sandwich into my mouth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们一边闲聊，一边吃着炒面面包。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們一邊閒聊，一邊吃著炒麵麵包。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00370",
		linknext = "0085_00372",
		line = 4953,
	},
	["0085_00372"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bg", id=2, file="bg25_3l_00000", x=150, y=270, lv=5, path=":bg/", sync=0, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=45, y=-5, time=15000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The conversation ends, and the only sound is the waves gently lapping at the shore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对话结束后，夜晚的海边响起平静的海浪声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對話結束後，夜晚的海邊響起平靜的海浪聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00371",
		linknext = "0085_00373",
		line = 4967,
	},
	["0085_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, even though the silence is continuing on, it somehow doesn't feel uncomfortable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过就算只是默默听着海浪的声音，也奇妙地感到舒适。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過就算只是默默聽著海浪的聲音，也奇妙地感到舒適。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00372",
		linknext = "0085_00374",
		line = 4977,
	},
	["0085_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were so awkward together when we first met. When did we get so comfortable with each other?",
					{"rt2"},
				},
			},
			cn = {
				{
					"两人刚刚相遇的时候，光是待着就很放不开，是什么时候开始变得这么熟悉了呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"兩人剛剛相遇的時候，光是待著就很放不開，是什麼時候開始變得這麼熟悉了呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00373",
		linknext = "0085_00375",
		line = 4987,
	},
	["0085_00375"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori also doesn't seem bothered by it, as she stares up at the moon in the starry sky.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔也不在意沉默的样子，一直凝视着浮在夜空中的满月。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔也不在意沉默的樣子，一直凝視著浮在夜空中的滿月。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00374",
		linknext = "0085_00376",
		line = 4997,
	},
	["0085_00376"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0985", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
