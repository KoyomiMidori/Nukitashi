	},
	["0085_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I still need to make it work faster and more quietly. Ideally it'd be able to work on everything, not just the school lockers, but I can't do something like that on my own.",
					{"rt2"},
				},
			},
			cn = {
				{
					"消音和时间短缩——在这之上，我还想作出除了学校的储物柜以外也能用的道具。但如果想做到这一点，时间和技术都很不足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"消音和時間短縮——在這之上，我還想作出除了學校的儲物櫃以外也能用的道具。但如果想做到這一點，時間和技術都很不足。",
					{"rt2"},
