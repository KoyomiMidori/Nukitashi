			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The moon is beautiful.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“今晚的月色真美。”",
					{"rt2"},
