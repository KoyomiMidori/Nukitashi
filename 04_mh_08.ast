		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's a cheeky bookworm, but once on a bike she has one million horsepower. If she wasn't born on Seiran Island, she probably would have developed a future based on that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"卑微温顺的文学少女骑上自行车就有百万马力——如果不是出生在青蓝岛，她或许能在这条路上闯出一番名堂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"卑微溫順的文學少女騎上自行車就有百萬馬力——如果不是出生在青藍島，她或許能在這條路上闖出一番名堂。",
					{"rt2"},
				},
			},
