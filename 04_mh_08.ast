		{"bgm", file="bgm04", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"bg", id=1, file="bg19_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The bath water's hot. Asa, can you let Hotori go in first?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“洗澡水热好了——麻沙酱，能带畔去洗澡吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「洗澡水熱好了——麻沙醬，能帶畔去洗澡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00182",
		linknext = "0085_00184",
		line = 2525,
	},
	["0085_00184"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1335", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You making soup?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你要煮汤吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你要煮湯嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00183",
		linknext = "0085_00185",
		line = 2537,
	},
	["0085_00185"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, she was so tired that she passed out while she was working out. She needs this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是要让她消除疲劳啦。锻炼肌肉骑自行车还摔倒在地——畔应该也累积了很多疲劳。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是要讓她消除疲勞啦。鍛煉肌肉騎自行車還摔倒在地——畔應該也累積了很多疲勞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00184",
		linknext = "0085_00186",
		line = 2549,
	},
	["0085_00186"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I also want you to get in with her, just in case of the off-chance that she collapses again in the bath.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果畔倒在浴室里就不好了吧？你就跟她一起洗顺便看着她吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果畔倒在浴室裡就不好了吧？你就跟她一起洗順便看著她吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00185",
		linknext = "0085_00187",
		line = 2561,
	},
	["0085_00187"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1336", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What are you, her mom? Hell, I'm the one you should be worrying about. I kinda hate to tell you this, but I can barely get in and out of the bath myself. If anyone needs to be looked after here, it's me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是不是保护过度了……不是我在炫耀，但麻沙酱连一个人洗澡都很不容易……我倒是希望她能照顾我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是不是保護過度了……不是我在炫耀，但麻沙醬連一個人洗澡都很不容易……我倒是希望她能照顧我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00186",
		linknext = "0085_00188",
		line = 2573,
	},
	["0085_00188"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0940", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, in that case, I could help you take your bath!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……如果是那样的话，我来给麻沙音酱洗澡吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……如果是那樣的話，我來給麻沙音醬洗澡吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00187",
		linknext = "0085_00189",
		line = 2588,
	},
	["0085_00189"] = {
