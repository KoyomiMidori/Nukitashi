			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? I-I can't let you do that! Please sleep in your own bed! I can sleep out here, or even in the bathroom, if you'd prefer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……这样真是太不好意思了！让我睡在这里吧……要不然我也可以去厕所睡觉，所以橘同学请好好睡在床上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸……這樣真是太不好意思了！讓我睡在這裡吧……要不然我也可以去廁所睡覺，所以橘同學請好好睡在床上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00245",
		linknext = "0085_00247",
		line = 3325,
	},
	["0085_00247"] = {
