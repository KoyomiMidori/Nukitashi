	["0085_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Considering I kinda threw it together, it works about as well as can be expected, but I'm painfully aware of its many limitations.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然因为是即兴制作的工具所以无可奈何，但我深深觉得自己的技术力不足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然因為是即興製作的工具所以無可奈何，但我深深覺得自己的技術力不足。",
					{"rt2"},
				},
			},
		},
