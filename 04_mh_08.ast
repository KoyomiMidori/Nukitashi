	["0085_00391"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00204", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0987", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's a little embarrassing to talk about, but... when I was little, I used to dream about a rabbit eating the mochi on the moon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“现在说有点害羞……但小时候我梦到自己吃到了月亮上的兔子敲的年糕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「現在說有點害羞……但小時候我夢到自己吃到了月亮上的兔子敲的年糕。」",
					{"rt2"},
				},
			},
		},
