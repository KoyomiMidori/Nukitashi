			},
		},
		text = {
			vo = {
				{"vo", file="misaki0975", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yay! Time to eat. *Nom* *nom*... aah... it feels good to chew again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“太好了！我要吃了……哈唔哈唔……啊啊……真有嚼劲……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「太好了！我要吃了……哈唔哈唔……啊啊……真有嚼勁……！」",
