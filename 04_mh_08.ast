	["0085_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, that works. Hotori, do you mind helping her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——也对。畔，可以帮忙替麻沙酱洗澡吗？”",
