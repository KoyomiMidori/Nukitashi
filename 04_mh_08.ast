		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0992", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes, if I eat too much then there wasn't any point in dieting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，吃太多的话减肥就没有意义了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯，吃太多的話減肥就沒有意義了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00404",
		linknext = "0085_00406",
		line = 5347,
	},
	["0085_00406"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even after she passed out like that, she's still worried about her figure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来她即使晕倒了，也还是很在意体型的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來她即使暈倒了，也還是很在意體型的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00405",
		linknext = "0085_00407",
		line = 5357,
	},
	["0085_00407"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It still really bothers you, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然……还是那么在意吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然……還是那麼在意嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00406",
		linknext = "0085_00408",
		line = 5369,
	},
	["0085_00408"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've asked her that before, but I can't help but broach the topic again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道已经是第几次了，我还是忍不住这么问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道已經是第幾次了，我還是忍不住這麼問。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00407",
		linknext = "0085_00409",
		line = 5379,
	},
	["0085_00409"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00110", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0993", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I guess... You'll probably be mad at me for lumping the two together, but it's probably similar to how you feel about people seeing your, uh... crotch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，是啊……也许并为一谈会被骂……但就和橘同学不喜欢被别人看到下半身……是一样的感觉吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯，是啊……也許並為一談會被罵……但就和橘同學不喜歡被別人看到下半身……是一樣的感覺吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00408",
		linknext = "0085_00410",
		line = 5393,
	},
	["0085_00410"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fair enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00409",
		linknext = "0085_00411",
		line = 5404,
	},
	["0085_00411"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0994", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Umm... you don't have to answer me if you don't want to, but why does it bother you that it's so big?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……如果你讨厌的话，就不用回答……橘同学，为什么那么在意很大这件事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……如果你討厭的話，就不用回答……橘同學，為什麼那麼在意很大這件事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00410",
		linknext = "0085_00412",
		line = 5418,
	},
	["0085_00412"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bg", id=2, file="bg25_3l_00000", x=400, y=-100, lv=5, path=":bg/", sync=0, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-55, y=-5, time=10000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look at the sea for a little.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我看了一会儿海。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我看了一下海。",
					{"rt2"},
