					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So that means we go ahead with the original plan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这样的话……要按照当初的计划行动吗？”",
					{"rt2"},
