	["0085_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Master of stealth Hotori will be the one to take it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而实行这一计划的——正是畔。",
					{"rt2"},
