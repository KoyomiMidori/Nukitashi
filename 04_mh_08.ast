	["0085_00323"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't know if her words make any sense at all, but at least now I can think clearly and no longer want to throw myself out the window.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不知道畔说的是否正确……但瞬间冷静地思考了一下后，就完全丧失了跳楼的勇气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不知道畔說的是否正確……但瞬間冷靜地思考了一下後，就完全喪失了跳樓的勇氣。",
					{"rt2"},
				},
