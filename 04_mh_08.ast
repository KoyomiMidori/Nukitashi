				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呼啊啊啊……那我也要为了明天去做各种调整了……之后就拜托了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「呼啊啊啊……那我也要為了明天去做各種調整了……之後就拜託了……」",
