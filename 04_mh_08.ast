		linkback = "0085_00376",
		linknext = "0085_00378",
		line = 5024,
	},
	["0085_00378"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The great author Natsume Souseki once opined that the English phrase “I love you” was best translated into Japanese as “the moon is beautiful”.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——那位文豪，夏目漱石好像把“I love you”翻译成了“今晚的月色真美”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——那位文豪，夏目漱石好像把「I love you」翻譯成了「今晚的月色真美」。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00377",
		linknext = "0085_00379",
		line = 5034,
	},
	["0085_00379"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Surely someone as well-read as Hotori would know that... right?",
					{"rt2"},
				},
			},
			cn = {
				{
					"眼前这位少女——畔美岬，好歹也是个文学少女，我不认为她不知道那个故事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"眼前這個少女——畔美岬，好歹也是個文學少女，我不認為她不知道那個故事。",
					{"rt2"},
				},
			},
