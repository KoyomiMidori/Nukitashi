	},
	["0085_00349"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never seen the beach this deserted and quiet. Even this island can be peaceful sometimes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一到深夜，连青蓝岛都充满了静寂，完全见不到有人在狂欢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一到深夜，連青藍島都充滿了靜寂，完全見不到有人在狂歡。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00348",
		linknext = "0085_00350",
		line = 4679,
	},
	["0085_00350"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Considering how it's normally swarming with sex seekers during the day, it's kind of surreal to be here late at night when it's completely still.",
					{"rt2"},
				},
			},
			cn = {
				{
					"白天到处都是性触者，所以这个海滩很难接近，但到了深夜就不一样了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"白天到處都是性觸者，所以這個海灘很難接近，但到了深夜就不一樣了。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00349",
		linknext = "0085_00351",
		line = 4689,
	},
	["0085_00351"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The waves quietly lap on the shore in the moonlight. It's a perfectly ordinary beach.",
					{"rt2"},
				},
			},
			cn = {
				{
					"月光下，平静的波涛不断冲上海滩——就是这样，没有任何奇特之处的普通沙滩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"月光下，平靜的波濤不斷衝上海灘——就是這樣，沒有任何奇特之處的普通沙灘。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00350",
		linknext = "0085_00352",
		line = 4699,
	},
	["0085_00352"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having been on the island for a while makes this otherwise normal spectacle somehow seem special.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛待久了，连这种普通的光景也会觉得特别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島待久了，連這種普通的光景也會覺得特別。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00351",
		linknext = "0085_00353",
		line = 4709,
	},
	["0085_00353"] = {
		{"bgm", stop=1},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0977", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hehe... This almost feels like a dream.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呵呵……总觉得好像在做梦呢。”",
