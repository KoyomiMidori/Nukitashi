		linkback = "0085_00345",
		linknext = "0085_00347",
		line = 4641,
	},
	["0085_00347"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0976", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You mean living off just salt and water? Fasting for a diet just felt wrong. Eating is truly amazing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“一直只靠盐和水生存下来的感想……绝食减肥什么的，果然是错的……吃东西真是太棒了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「一直只靠鹽和水生存下來的感想……絕食減肥什麼的，果然是錯的……吃東西真是太棒了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00346",
		linknext = "0085_00348",
		line = 4655,
	},
	["0085_00348"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——是吗。”",
					{"rt2"},
