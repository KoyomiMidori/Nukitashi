	},
	["0085_00248"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I need you to be in tip-top shape for then, so you really should be sleeping in a proper bed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了让你发挥出最好的状态，今天一定要好好睡我的床……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了讓你發揮出最好的狀態，今天一定要好好睡我的床……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00247",
		linknext = "0085_00249",
		line = 3349,
	},
	["0085_00249"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0949", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, come on. It's just for one night. Don't you think you're making a pregnancy out of a cumshot, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那种事情……才一天没关系的。橘同学，你也让孕妇外出得太频繁了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那種事情……才一天沒關係的。橘同學，你也讓孕婦外出得太頻繁了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00248",
		linknext = "0085_00250",
		line = 3363,
	},
	["0085_00250"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's the worst idiom I've ever heard, so could you not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种说法太难听了可以停下来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種說法太難聽了可以停下來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00249",
		linknext = "0085_00251",
		line = 3375,
	},
	["0085_00251"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I do at least know what she means by that—she's telling me not to sweat the small stuff.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说我无所谓的事情担心太多了——的意思。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說我無所謂的事情擔心太多了——的意思。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00250",
		linknext = "0085_00252",
		line = 3385,
	},
	["0085_00252"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It still hasn't been that long since you collapsed, you know. You should get a decent night's rest. So what if I'm not in the best shape? You don't need to worry about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，畔刚刚不是晕倒了吗？还是好好让身体休息一下比较好。我的话就算状态稍微差一点也不要紧的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，畔剛剛不是暈倒了嗎？還是好好讓身體休息一下比較好。我的話就算狀態稍微差一點也不要緊的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00251",
		linknext = "0085_00253",
		line = 3397,
	},
	["0085_00253"] = {
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="misaki_01m_00002", file1="misaki_01m_00104", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0950", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But I am worried... I mean, wh-what if... something happened to me? Who's supposed to come and save me then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不行啊……要是……如果……我遇到危险的话……那谁来救我啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不行啊……要是……如果……我遇到危險的話……那誰來救我啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00252",
		linknext = "0085_00254",
		line = 3411,
	},
	["0085_00254"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who? Well, we'll support you so that doesn't happen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你问谁……为了不让这种事情发生，我们当然会支援你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你問誰……為了不讓這種事情發生，我們當然會支援你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00253",
		linknext = "0085_00255",
		line = 3425,
	},
	["0085_00255"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00117", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0951", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
