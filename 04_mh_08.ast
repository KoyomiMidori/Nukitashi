	},
	["0085_00054"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry. I know we've already got you infiltrating the student council room, and here I am dumping even more on you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思，明明还要你潜入学生会室……这让你的负担更重了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思，明明還要你潛入學生會室……這讓你的負擔更重了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00053",
		linknext = "0085_00055",
		line = 664,
	},
	["0085_00055"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
