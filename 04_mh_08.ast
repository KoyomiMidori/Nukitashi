			},
			en = {
				{
					"She hangs her head apologetically, and doesn't touch on it any further.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔好像很抱歉地低着头，没有再多说什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔好像很抱歉地低著頭，沒有再多說什麼。",
