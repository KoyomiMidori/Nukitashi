	["0085_00293"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In my head, I counted sheep into four digits, but at some point they started turning into Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"脑海中的羊早已达到了4位数——而且不知不觉中从数羊变成了数畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"腦海中的羊早已達到了4位數——而且不知不覺中從數羊變成了數畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00292",
		linknext = "0085_00294",
		line = 3896,
	},
	["0085_00294"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wasn't I counting sheep? How'd they turn into Hotoris?",
					{"rt2"},
				},
			},
			cn = {
				{
					"最初确实一直是数羊，是什么时候开始变成畔了……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"最初確實一直是數羊，是什麼時候開始變成畔了……？",
