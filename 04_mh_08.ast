				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是你居然會餓到連意識都沒了……到底少吃了多少？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00151",
		linknext = "0085_00153",
		line = 2103,
