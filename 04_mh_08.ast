	["0085_00238"] = {
		{"cgdel", id=2, lv=5, time=300, alphadel=1},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00128", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_01m_00007", file1="asane_01m_00115", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I shake my head to straighten my thoughts. Any more of this and I'll turn into Asa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我摇了摇头，让脑袋恢复正常。由于不太习惯，害我的思考方式逐渐麻沙酱化了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我搖了搖頭，讓腦袋恢復正常。由於不太習慣，害我的思考方式逐漸麻沙醬化了。",
					{"rt2"},
				},
			},
		},
