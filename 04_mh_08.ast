	["0085_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since this is Onabuta's locker, I thought she might leave it here during sex class, but I guess not.",
					{"rt2"},
