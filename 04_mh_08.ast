		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0915", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Perfectly. I'm supposed to check this locker again tomorrow, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没问题。明天再次来这里打开置物柜就好了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒問題。明天再次來這裡打開置物櫃就好了對吧？」",
