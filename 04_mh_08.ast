					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, I was planning to do a ton of exercise today, so I was ready. Never thought I'd use it like this, though. Ah, why don't you go in now? It was lovely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为今天打算大量运动，所以有带衣服来换掉沾到汗的衣服……但没想到却以意外的形式帮上忙了。橘同学也请去洗澡吧。热水很棒哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為今天打算大量運動，所以有帶衣服來換掉沾到汗的衣服……但沒想到卻以意外的形式幫上忙了。橘同學也請去洗澡吧。熱水很棒哦！」",
					{"rt2"},
				},
			},
		},
