	["0085_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori was in real bad shape, but after she ate everything we had in the house, she suddenly recovered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明刚刚完全无计可施，但当我们把家里所有的食物都给了畔之后，她很快就恢复了健康。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明剛剛完全無計可施，但當我們把家裡所有的食物都給了畔之後，她很快就恢復了健康。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00148",
		linknext = "0085_00150",
		line = 2069,
	},
	["0085_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently she just passed out from hunger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"昏厥的原因似乎只是空腹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"昏厥的原因似乎只是空腹。",
					{"rt2"},
