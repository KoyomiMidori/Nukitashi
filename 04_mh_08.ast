			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Don't worry about it. It's just a little bit more work. If anything, it's an honor that I can be useful.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“请不要在意。只是增加了一点工作……应该说我能帮上忙真是太荣幸了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「請不要在意。只是增加了一點工作……應該說我能幫上忙真是太榮幸了。」",
					{"rt2"},
				},
			},
		},
