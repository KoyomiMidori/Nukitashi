					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I knew the chances were a bit slim, but it's still kinda depressing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然还想着如果有就赚到了……不过猜错了还是蛮受打击的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然還想著如果有就賺到了……不過猜錯了還是蠻受打擊的。」",
					{"rt2"},
