		linkback = "0085_00337",
		linknext = "0085_00339",
		line = 4539,
	},
	["0085_00339"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We went to the convenience store to stock up on food, and then headed to the beach on a whim.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在便利店买了食物的我们，随便来到了夜晚的海滩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在便利店買了食物的我們，隨便來到了夜晚的海灘。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00338",
		linknext = "0085_00340",
		line = 4549,
	},
	["0085_00340"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0973", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Thank you, Tachibana. You're going out of your way to keep me company.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“谢谢你，橘同学，还特地陪我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「謝謝你，橘同學，還特地陪我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00339",
		linknext = "0085_00341",
		line = 4564,
	},
	["0085_00341"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's fine. I couldn't sleep, and I needed to get supplies for Asa anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没事。反正也睡不着觉……负责支援的麻沙酱也需要食物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒事。反正也睡不著覺……負責支援的麻沙醬也需要食物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00340",
		linknext = "0085_00342",
		line = 4576,
	},
	["0085_00342"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00120", file2="misaki_02m_00201", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0974", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, umm... I can't wait any longer. Do you mind if I eat? Can I eat?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那、那个……我已经迫不及待了。可以吃吗？可以吃吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那、那個……我已經迫不及待了。可以吃嗎？可以吃嗎？」",
