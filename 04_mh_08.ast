	["0085_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's almost scary how not-tired I am.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可怕的是我还不困。",
