		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sigh... fucking hell... Well, whatever. At least you're feeling better.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈……真是的……不管怎么说，平安无事真是太好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈……真是的……不管怎麼說，平安無事真是太好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00150",
		linknext = "0085_00152",
		line = 2091,
	},
	["0085_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
