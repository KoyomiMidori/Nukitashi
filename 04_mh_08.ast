		{"fg", file="misaki_01l_00002", file1="misaki_01l_00107", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A freshly bathed Hotori is in my living room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚洗完澡的畔就在我们家的起居室里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛洗完澡的畔就在我們家的起居室裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00230",
		linknext = "0085_00232",
		line = 3145,
	},
	["0085_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her moist, shiny hair reflects the overhead light, and her cheeks are slightly flushed from her bath. She looks way hotter than usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她湿润又充满光泽的头发被灯照着，脸上微微有些红晕——比平时看起来更性感妩媚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她濕潤又充滿光澤的頭髮被燈照著，臉上微微有些紅暈——比平時看起來更性感嫵媚。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00231",
		linknext = "0085_00233",
		line = 3155,
	},
	["0085_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shit, just looking at her has my pulse picking up. I gotta take a bath and calm down a bit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……不好，光是看着，脉搏的跳动就变得很奇怪。快去泡个澡放松一下。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……不好，光是看著，脈搏的跳動就變得很奇怪。快去泡個澡放鬆一下。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00232",
		linknext = "0085_00234",
		line = 3165,
	},
	["0085_00234"] = {
		{"fg", file="misaki_01l_00002", file1="misaki_01l_00128", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hold up. I just realized that I'm about to get into the same water that Hotori was just in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但，等等——仔细想想，我现在要泡洗澡水，是刚刚畔泡过的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但，等等——仔細想想，我現在要泡洗澡水，是剛剛畔泡過的。",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00233",
		linknext = "0085_00235",
		line = 3177,
	},
	["0085_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The water in the bath now is Hotori's bathwater. Is it socially acceptable for me to use it, too?",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，现在我家的浴室里的热水是畔泡过的热水———进到那些水里的行为会被社会接受吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，現在我家的浴室裡的熱水是畔泡過的熱水———進到那些水裡的行為會被社會接受嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00234",
		linknext = "0085_00236",
		line = 3187,
	},
	["0085_00236"] = {
