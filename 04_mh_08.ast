		linknext = "0085_00413",
		line = 5432,
	},
	["0085_00413"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The moonlight reflected on the sea looks like it's creating a path on the water's surface.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在亮晃晃的满月月光照耀下，水面上就像出现了光之路一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在亮晃晃的滿月月光照耀下，水面上就像出現了光之路一樣。",
					{"rt2"},
				},
