	["0085_00355"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00306", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0978", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah. All my life I've felt like a faceless background character, but now here I am, friends with you and walking along the beach...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的……一直作为路人的我，和橘同学们变得很熟……还这样，晚上在沙滩上吃饭什么的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的……一直作為路人的我，和橘同學們變得很熟……還這樣，晚上在沙灘上吃飯什麼的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00354",
		linknext = "0085_00356",
		line = 4750,
	},
	["0085_00356"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0979", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It feels like I've stumbled into a young adult novel. It still doesn't really feel real.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“真的，就像走进青春小说里一样……这是现实吗？现在偶尔也会觉得不敢相信。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「真的，就像走進青春小說裡一樣……這是現實嗎？現在偶爾也會覺得不敢相信。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00355",
		linknext = "0085_00357",
		line = 4764,
	},
	["0085_00357"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This crazy-ass island never quite feels real to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这种疯狂的岛的存在，我有时也会觉得如果是梦就好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這種瘋狂的島的存在，我有時也會覺得如果是夢就好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00356",
		linknext = "0085_00358",
		line = 4776,
	},
	["0085_00358"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0980", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Haha, I'm glad it is, though. If it weren't, then I never would've met you, talked to you, or done any of the things we've done together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊哈哈……但是，我觉得幸好是现实。如果是梦的话，以前的事，还有像这样说话的事……都会全部消失。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊哈哈……但是，我覺得幸好是現實。如果是夢的話，以前的事，還有像這樣說話的事……都會全部消失。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00357",
		linknext = "0085_00359",
		line = 4793,
	},
	["0085_00359"] = {
