			cn = {
				{
					name = {"淳之介"},
					"“我、我该怎么办！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我、我該怎麼辦！？」",
					{"rt2"},
