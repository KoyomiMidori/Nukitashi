		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since this is her last opportunity to lose some weight before the olympiad, on the way home she bowed her head to me and asked her to join her for one last training session.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔似乎非常在意自己的体型，所以在回家的路上低头对我说“请和我一起进行最后的特训吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔似乎非常在意自己的體型，所以在回家的路上低頭對我說「請和我一起進行最後的特訓吧。」",
					{"rt2"},
				},
