				{"fg", file="asane_01m_00007", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1344", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, yeah. And Hotori, I'd say don't try anything with Bro in the night, but... I'm a pure slut myself who's always on the verge of 'trying something' with Bro every night, so...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……畔同学……你敢半夜爬上哥哥的床你就灭了你……虽然我想这么说，但也无法否定觉得这种时候夜袭的清纯婊子也不错的自己……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……畔同學……你敢半夜爬上哥哥的床你就滅了你……雖然我想這麼說，但也無法否定覺得這種時候夜襲的清純婊子也不錯的自己……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00241",
		linknext = "0085_00243",
		line = 3273,
	},
	["0085_00243"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
