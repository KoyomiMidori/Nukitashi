					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Gah, fuck! I'm sorry, okay? I never wanted it to turn out like this, I just didn't want a three-way with her! Don't die on me, dammit!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哇啊啊啊啊啊！对不起啦……我并没有这样的打算……我只是不想和畔同学3P……请你成佛吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哇啊啊啊啊啊！對不起啦……我並沒有這樣的打算……我只是不想和畔同學3P……請你成佛吧……！」",
					{"rt2"},
				},
			},
		},
