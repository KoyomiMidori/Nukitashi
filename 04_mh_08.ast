					name = {"美岬", "Misaki"},
					"“How many times have we tried something and NOT run into unexpected circumstances? What'll happen to me if things go wrong and you aren't feeling well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“像以前那样的意外也可能发生不是吗……如果那种时候橘同学状况不好的话……那我该怎么办才好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「像以前那樣的意外也可能發生不是嗎……如果那種時候橘同學狀況不好的話……那我該怎麼辦才好……」",
					{"rt2"},
				},
