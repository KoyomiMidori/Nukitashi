	},
	["0085_00423"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What about you? Did something happen for you to be so worried about your figure?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……畔也有什么吗？这么在意体型的理由……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……畔也有什麼嗎？這麼在意體型的理由……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00422",
		linknext = "0085_00424",
		line = 5571,
	},
	["0085_00424"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00113", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0997", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, people have never really interacted with me at all, so it's not like I got teased over it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我……原本就没有被人理睬过，所以也没有被欺负过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我……原本就沒有被人理睬過，所以也沒有被欺負過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00423",
		linknext = "0085_00425",
		line = 5585,
	},
	["0085_00425"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00116", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0998", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's just that... long ago I wondered why no one interacted with me, and when I looked in the mirror I realized I was fatter than everyone else...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“只是……以前的我还是很在意没有人理睬我，想着为什么去照了镜子，结果发现自己比大家都胖……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「只是……以前的我還是很在意沒有人理睬我，想著為什麼去照了鏡子，結果發現自己比大家都胖……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00424",
		linknext = "0085_00426",
		line = 5599,
	},
	["0085_00426"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00113", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0999", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“After that, whenever I looked at myself in the mirror, I'd get more and more disgusted with my body. It wasn't long before I hated looking at myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“想找办法解决的我每天都照镜子……结果却越来越觉得自己的身体恶心……注意到的时候，已经看都不想再看了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「想找辦法解決的我每天都照鏡子……結果卻越來越覺得自己的身體噁心……注意到的時候，已經看都不想再看了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00425",
		linknext = "0085_00427",
		line = 5613,
	},
	["0085_00427"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00204", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1000", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That's not the first time I've collapsed from hunger. After that, I got really angry with myself and just started eating... Haha, I guess I didn't learn my lesson, did I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个时候，我也有一次因为肚子饿而倒下。所以被骂说要好好吃饭……啊哈哈，我真是没有学习能力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個時候，我也有一次因為肚子餓而倒下。所以被罵說要好好吃飯……啊哈哈，我真是沒有學習能力……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00426",
		linknext = "0085_00428",
		line = 5627,
	},
	["0085_00428"] = {
