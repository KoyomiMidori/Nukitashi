		linkback = "0055_00589",
		linknext = "0055_00591",
		line = 7372,
	},
	["0055_00591"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0196", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Discriminación contra los impotentes. Es un tema delicado hoy en día. Hay quienes tratan a personas como Tachibana como ciudadanos inferiores solo porque no pueden tener sexo por distintos motivos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“性功能障碍者……以像橘一样的阳痿为首，由于种种理由而不能做爱的人——对他们的歧视，最近成为了问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「性功能障礙者……以像橘一樣的陽痿為首，由於種種理由而不能做愛的人——對他們的歧視，最近成為了問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00590",
		linknext = "0055_00592",
		line = 7386,
	},
	["0055_00592"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En una isla donde el sexo lo es todo, tiene sentido que algunas personas menosprecien a quienes no pueden tener relaciones sexuales.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这里是做爱至上主义的青蓝岛——岛上的人瞧不起无法做爱的人是很正常的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這裡是做愛至上主義的青藍島——島上的人瞧不起無法做愛的人是很正常的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00591",
		linknext = "0055_00593",
		line = 7396,
	},
	["0055_00593"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0197", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ahora que lo mencionas, recuerdo que la OSS emitió un comunicado. Decía que había que tener cuidado para no incitar a las personas impotentes a organizar protestas a gran escala.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样说来，SHO也有传令……说要注意不要让性障碍者团体进行大规模抗议……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣說來，SHO也有傳令……說要注意不要讓性障礙者團體進行大規模抗議……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00592",
		linknext = "0055_00594",
		line = 7410,
	},
	["0055_00594"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0583", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Teniendo eso en cuenta, negarle la entrada a este hombre no hará más que echarle leña al fuego.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“在这种情况下，如果因为性障碍就拒绝前辈入队的话……会是火上加油吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「在這種情況下，如果因為性障礙就拒絕前輩入隊的話……會是火上加油吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00593",
		linknext = "0055_00595",
		line = 7424,
	},
	["0055_00595"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=-600, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0198", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí, tiene toda la razón. Sin embargo, sigo teniendo mis dudas... Si permitimos que un hombre que no puede tener relaciones sexuales se una a nuestras filas, ¿no provocaría cierto rechazo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是，你说得对……但是，让这个男人加入的话……无法做爱的FS，这不会招来反感吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是，你說得對……但是，讓這個男人加入的話……無法做愛的FS，這不會招來反感嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00594",
		linknext = "0055_00596",
		line = 7439,
	},
	["0055_00596"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0584", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“¿Qué tal esto...? Sugiero que establezcamos una cuota para esas personas dentro de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“既然如此……就在FS中设置专门聘用这些人的‘位置’吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「既然如此……就在FS中設置專門聘用這些人的『保障名額』吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00595",
		linknext = "0055_00597",
		line = 7453,
	},
	["0055_00597"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00112", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0199", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Se refieres a lo que llaman... acción afirmativa? ¿Quiere establecer una cuota para los impotentes en la SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那也就是说……制定平权法案吗？在FS里加入阳痿的位置……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那也就是說……制定平權法案嗎？在FS裡加入陽痿保障名額……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00596",
		linknext = "0055_00598",
		line = 7467,
	},
	["0055_00598"] = {
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=7.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0585", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sí. Es que ya estamos faltos de personal. Aceptarlo matará dos pájaros de un tiro... Evitaremos quejas por discriminación y resolveremos el problema de la falta de personal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。反正人手也不够……前辈的入队还能成为歧视问题的抑制力，同时也消除了人手不足的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。反正人手也不夠……前輩的入隊還能成為歧視問題的抑制力，同時也消除了人手不足的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00597",
		linknext = "0055_00599",
		line = 7480,
	},
	["0055_00599"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um... ¿entonces sí me aceptaron...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃……那也就是说，我……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃……那也就是說，我……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00598",
		linknext = "0055_00600",
		line = 7492,
	},
	["0055_00600"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0200", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Por ahora, has sido aceptado como aprendiz. A partir de mañana, espero que te esfuerces para convertirte en un miembro hecho y derecho de la SS. ¿Entendido?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……先作为训练生录用，明天开始要作为FS的成员努力学习。知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……先作為訓練生錄用，明天開始要作為FS的成員努力學習。知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00599",
		linknext = "0055_00601",
		line = 7506,
	},
	["0055_00601"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
