		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0877", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
