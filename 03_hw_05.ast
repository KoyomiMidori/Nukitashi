	["0055_00557"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Vuelve a temblar violentamente. Incapaz de soportarlo, vuelve a orinarse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱激烈痉挛，无法忍受再次失禁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬激烈痙攣，無法忍受再次失禁。",
