	["0055_00598"] = {
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=7.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0585", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. We are already short-staffed as it is. Accepting him will kill two birds with one stone—we avoid complaints of discrimination, and we solve the issue of our staff shortage.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。反正人手也不够……前辈的入队还能成为歧视问题的抑制力，同时也消除了人手不足的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。反正人手也不夠……前輩的入隊還能成為歧視問題的抑制力，同時也消除了人手不足的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00597",
		linknext = "0055_00599",
		line = 7480,
	},
	["0055_00599"] = {
