		linkback = "0055_00070",
		linknext = "0055_00072",
		line = 902,
	},
	["0055_00072"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No... Espera. Solo necesitamos que uno entre. No tienes que...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……请等一下。只要一个人潜入就够了，渡酱不需要进去……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……請等一下。只要一個人潛入就夠了，渡醬不需要進去……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00071",
		linknext = "0055_00073",
		line = 914,
	},
	["0055_00073"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3800] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=3800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0879", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tranquilo! Soy tu senpai, y además soy amiga de Rei-chan. ¡No puedo permitir que nadie más sienta lo que sufrí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没关系的！我是前辈，和礼酱关系也很好……而且，我也绝对不希望再发生像之前那样的事情！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒關係的！我是前輩，和禮醬關係也很好……而且，我也絕對不希望再發生像之前那樣的事情！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00072",
		linknext = "0055_00074",
		line = 930,
	},
	["0055_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No sé si me parece bien, pero a Wata-chan la veo con ganas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真困扰，渡酱超级有干劲。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真困擾，渡醬超級有幹勁。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00073",
		linknext = "0055_00075",
		line = 940,
	},
	["0055_00075"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
