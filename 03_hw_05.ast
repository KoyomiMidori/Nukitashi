		linkback = "0055_00153",
		linknext = "0055_00155",
		line = 1953,
	},
	["0055_00155"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0175", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡¿Quieres unirte a la SS a pesar de que eres impotente?! ¡¿Es una broma?! ¡¿Crees que un hombre que nunca ha podido follar con una mujer pertenece a la SS?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“志愿做FS，却是个阳痿……开玩笑也要适可而止！你以为我会让进不去小穴的男人加入FS吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「志願做FS，卻是個陽痿……開玩笑也要適可而止！你以為我會讓進不去小穴的男人加入FS嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00154",
		linknext = "0055_00156",
		line = 1965,
	},
	["0055_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
