	["0055_00094"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me llamo Tachibana Junnosuke, soy estudiante de segundo año de la clase uno. Me enteré de la campaña de reclutamiento de la SS, así que decidí inscribirme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“2年1班，橘淳之介。听说FS在招募新的人员，所以前来入队。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「2年1班，橘淳之介。聽說FS在招募新的人員，所以前來入隊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00093",
		linknext = "0055_00095",
		line = 1225,
	},
	["0055_00095"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0163", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Qué raro. Pensé que aún no se había hecho ninguna declaración oficial.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……我们应该还没有对外公开吧？”",
