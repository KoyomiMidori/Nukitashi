	["0055_00143"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0571", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Given that our purpose is to maintain public order, it's essential that all our members be proficient at sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我们的活动目的基本上只是维持治安……为此，性爱能力可是不可缺少的一部分。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我們的活動目的基本上只是維持治安……為此，性愛能力可是不可缺少的一部分。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00142",
