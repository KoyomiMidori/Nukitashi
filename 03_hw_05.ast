	["0055_00106"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0165", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It's good that you're so gung-ho, but you're already in third year, remember? Even if you're able to join the SS, you won't get a chance to get much done.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然你的心意很好……可是雏见已经是3年级生了。现在进也太迟了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然你的心意很好……可是雛見已經是3年級生了。現在進也太遲了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00105",
		linknext = "0055_00107",
		line = 1369,
	},
	["0055_00107"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0885", path=":vo/", ch="hinami"},
