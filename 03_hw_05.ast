	["0055_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me mira con una intensidad ardiente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"锐利的目光刺向我，强度仿佛能烧穿黑纸一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"銳利的目光刺向我，強度彷彿能燒穿黑紙一樣。",
