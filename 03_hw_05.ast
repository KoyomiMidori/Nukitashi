					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oye, cálmate. No se te entiende nada de lo mal que hablas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“冷静些渡酱前辈……话都说得乱七八糟了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「冷靜些渡醬前輩……話都說得亂七八糟了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00615",
		linknext = "0055_00617",
		line = 7754,
	},
	["0055_00617"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
