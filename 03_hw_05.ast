					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey. Take a chill pill. Your syntax is absolutely horrific right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“冷静些渡酱前辈……话都说得乱七八糟了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「冷靜些渡醬前輩……話都說得亂七八糟了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00615",
		linknext = "0055_00617",
		line = 7754,
