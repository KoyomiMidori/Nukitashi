	["0055_00560"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se queja, pero por la expresión de éxtasis en su rostro, parece que lo disfrutó.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边这样说着，一边恍惚地笑着——看起来很舒服的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊這樣說著，一邊恍惚地笑著——看起來很舒服的樣子。",
					{"rt2"},
				},
			},
		},
