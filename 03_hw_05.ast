	["0055_00133"] = {
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The president nods as Rei explains. She seems like she has a lot on her plate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长一边听着一边随声附和——但她心里到底在想什么？",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長一邊聽著一邊隨聲附和——但她心裡到底在想什麼？",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00132",
		linknext = "0055_00134",
		line = 1697,
	},
	["0055_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her affable smile makes it hard to judge her intentions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从表情读不出她真正的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從表情讀不出她真正的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00133",
		linknext = "0055_00135",
		line = 1707,
	},
	["0055_00135"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0568", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I understand now. You came here to enlist in the ranks of the SS, is that correct?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“原来如此……也就是说你们俩想加入FS，所以才来到这里吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「原來如此……也就是說你們倆想加入FS，所以才來到這裡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00134",
		linknext = "0055_00136",
		line = 1719,
	},
	["0055_00136"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
