				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……我們應該還沒有對外公開吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00094",
		linknext = "0055_00096",
		line = 1239,
	},
	["0055_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? Ah, pues... Wata... Mi senpai me lo dijo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……啊，那是……从渡……渡会前辈那里听说的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……啊，那是……從渡……渡會前輩那裡聽說的。」",
					{"rt2"},
