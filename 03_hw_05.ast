					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wata-chan-senpai, esta fue mi decisión. Oigan, ¿no pueden decir algo para convencerla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱前辈，这是我决定的事情……喂，大家也来阻止她一下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬前輩，這是我決定的事情……喂，大家也來阻止她一下。」",
					{"rt2"},
				},
