				{"vo", file="hinami0914", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I'm sure things will be tough for you come tomorrow. Thanks for working so hard for everyone's sake.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君，明天开始一定会很辛苦吧……谢谢你，为了大家这么努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君，明天開始一定會很辛苦吧……謝謝你，為了大家這麼努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00647",
		linknext = "0055_00649",
		line = 8203,
	},
	["0055_00649"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her tone is soothing, almost maternal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那声音比平时更加温柔，更加包容一切。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那聲音比平時更加溫柔，更加包容一切。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00648",
		linknext = "0055_00650",
		line = 8213,
	},
	["0055_00650"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I haven't even done anything yet, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么……我还没努力呢，现在才要开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼……我還沒努力呢，現在才要開始。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00649",
		linknext = "0055_00651",
		line = 8224,
	},
	["0055_00651"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0915", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, you're working hard. You're our leader at school, and a reliable older brother at home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，你努力了。在学校是大家的队长，在家里是可靠的哥哥呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，你努力了。在學校是大家的隊長，在家裡是可靠的哥哥呀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00650",
		linknext = "0055_00652",
		line = 8236,
	},
	["0055_00652"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="hcg01_00003", x=0, y=0, path=":cg/hcg01/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0916", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Just remember that as your senior, you can lean on me sometimes. Come on, there, there... Aren't you a hard worker... there, there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这种时候可以跟前辈撒娇哦……来，好乖好乖……橘君真是个努力的人啊……好乖好乖……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這種時候可以跟前輩撒嬌哦……來，好乖好乖……橘君真是個努力的人啊……好乖好乖……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00651",
		linknext = "0055_00653",
		line = 8251,
	},
	["0055_00653"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata has an oddly nostalgic smell to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱身上散发着令人怀念的味道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬身上散發著令人懷念的味道。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00652",
		linknext = "0055_00654",
		line = 8261,
	},
	["0055_00654"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a wonderful fragrance—gentle but vibrant, like summertime flower petals moist with early-morning dew.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像早晨被水濡湿的夏之花所散发出的清新柔软且不可思议的香气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像早晨被水濡濕的夏之花所散發出的清新柔軟且不可思議的香氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00653",
		linknext = "0055_00655",
		line = 8271,
	},
	["0055_00655"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's like it's a smell I remember from my childhood.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小时候我经常闻到这种味道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小時候我經常聞到這種味道。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00654",
		linknext = "0055_00656",
		line = 8281,
	},
	["0055_00656"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know I'm always teasing her for being a cutting board loli, but I find myself feeling strangely homesick as I let her stroke my head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明平时都戏弄她是萝莉、是飞机场——但现在心情却奇妙地充满了乡愁，被随心所欲地抚摸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明平時都戲弄她是蘿莉、是飛機場——但現在心情卻奇妙地充滿了鄉愁，被隨心所欲地撫摸。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00655",
		linknext = "0055_00657",
		line = 8291,
	},
	["0055_00657"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="hcg01_00001", x=0, y=0, path=":cg/hcg01/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0917", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I'm sure SS training will be tough, but don't be shy to come to me whenever you feel like you can't go on. I'll always be there to pet you like this, whenever you need me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“FS的训练，想必会有很多辛苦……如果痛苦的话随时告诉我。我是橘君的同伴，随时都可以这样给你摸摸头哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「FS的訓練，想必會有很多辛苦……如果痛苦的話隨時告訴我。我是橘君的同伴，隨時都可以這樣給你摸摸頭哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00656",
		linknext = "0055_00658",
		line = 8306,
	},
	["0055_00658"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haha... that's really reassuring.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈……真让人放心啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈……真讓人放心啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00657",
		linknext = "0055_00659",
		line = 8317,
	},
	["0055_00659"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't really have any choice but to do my best now, do I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被你这么一说……我只能努力了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被你這麼一說……我只能努力了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00658",
		linknext = "0055_00660",
		line = 8328,
