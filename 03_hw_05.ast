			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana, I'm sure you're very excited to enlist, but I don't think I'm getting across just how intense the SS training is. You don't look like you've got the stamina for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘……志愿入队的事情——我刚才说了，FS的训练是不容小觑的。我看不出你有能够承受的体力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘……志願入隊的事情——我剛才說了，FS的訓練是不容小覷的。我看不出你有能夠承受的體力。」",
					{"rt2"},
				},
