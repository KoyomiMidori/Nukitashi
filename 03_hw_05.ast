			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Es como, uh... cuando suceden dos cosas y sientes que debe haber alguna conexión entre ellas, así no haya ninguna.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“后此谬误……就是马上把连续发生的两件事，作为原因和结果联系起来……大概是这种感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「後此謬誤……就是馬上把連續發生的兩件事，作為原因和結果聯繫起來……大概是這種感覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00016",
		linknext = "0055_00018",
		line = 230,
	},
	["0055_00018"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0870", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Si un grupo de personas con tetas murieran de un resfriado, ¿todos pensarían que es culpa de las tetas? Dirían, “¡fuera a las tetas! ¡Exterminen a las tetas grandes!” ¿Podemos hacerlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃，如果有人看到巨乳后突然感冒死掉的话，感冒的原因就是巨乳！巨乳不好！铲除巨乳！是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃，如果有人看到巨乳後突然感冒死掉的話，感冒的原因就是巨乳！巨乳不好！剷除巨乳！是這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00017",
		linknext = "0055_00019",
		line = 244,
	},
	["0055_00019"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00105", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1049", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pero qué imaginación la tuya...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“渡酱好像说出了不得了的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「渡醬好像說出了不得了的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00018",
		linknext = "0055_00020",
		line = 257,
	},
	["0055_00020"] = {
		{"fg", file="hinami_01m_00001", file3="hinami_01m_00302", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0871", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Eso significa que... ¡Puedo hacer que todos se den cuenta de que esas tetas no son más que sacos de carne llenos de maldad pura que debe ser eliminada! ¡Tenemos que hacer una limpieza!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我想到一件很厉害的事情哦！只要用这招，大家就会发现巨乳不好，就能打败巨乳了！打败巨乳吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我想到一件很厲害的事情哦！只要用這招，大家就會發現巨乳不好，就能打敗巨乳了！打敗巨乳吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00019",
		linknext = "0055_00021",
		line = 271,
	},
	["0055_00021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues no va a quedar nadie en esta isla...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果在这个岛上做了那种事，活下来的大概就只剩渡酱吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果在這個島上做了那種事，活下來的大概就只剩渡醬吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00020",
		linknext = "0055_00022",
		line = 283,
	},
	["0055_00022"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"ex", time=700, func="wait"},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1852", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Los medios siempre están haciendo este tipo de cosas, inventando una postura pública para poder atraer a la gente a su lado. Tienes que darte cuenta de ello o siempre caerás en la trampa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是，实际上经常会有不好的媒体为了捏造对自己有利的情报而使用这个谬误……如果作为着眼点来看，在某种意义上是没有错的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是，實際上經常會有不好的媒體為了捏造對自己有利的情報而使用這個謬誤……如果作為著眼點來看，在某種意義上是沒有錯的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00021",
		linknext = "0055_00023",
		line = 301,
	},
	["0055_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así es. Wata-chan, hay que tener cuidado a la hora de creer lo que dicen los medios de comunicación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……渡酱，请小心不要被媒体的信息战欺骗了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……渡醬，請小心不要被媒體的資訊戰欺騙了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00022",
		linknext = "0055_00024",
		line = 313,
	},
	["0055_00024"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0872", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ajaja, no se preocupen. Soy la mayor aquí, ¿vale? ¡No me van a engañar tan fácilmente!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈，不用担心。我比大家都年长哦？没那么容易被骗的啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈，不用擔心。我比大家都年長哦？沒那麼容易被騙的啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00023",
		linknext = "0055_00025",
		line = 327,
	},
	["0055_00025"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1050", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“En mi caso, me empezaron a crecer las tetas cuando comencé a derrotar a un montón de novatos extranjeros en mis FPS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我的胸是从在FPS游戏中不停地怼不会玩游戏的外国人才开始变大的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我的胸是從在FPS遊戲中不停地懟不會玩遊戲的外國人才開始變大的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00024",
		linknext = "0055_00026",
		line = 340,
	},
	["0055_00026"] = {
		{"fg", file="hinami_02m_00001", file3="hinami_02m_00302", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0873", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Bueno, ¡voy a ponerme a jugar esos FPS y empezar a ganarles a esos malditos novatos extranjeros también!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“今后我要每天在FPS游戏里怼不会玩游戏的外国人！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「今後我要每天在FPS遊戲裡懟不會玩遊戲的外國人！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00025",
		linknext = "0055_00027",
		line = 354,
	},
	["0055_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y tanto que decías que no te iban a engañar...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不能滥用刚学会的知识去玩弄渡酱哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不能濫用剛學會的知識去玩弄渡醬哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00026",
		linknext = "0055_00028",
		line = 366,
	},
	["0055_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿De qué estábamos hablando?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……刚才说到哪里了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……剛才說到哪裡了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00027",
		linknext = "0055_00029",
		line = 378,
	},
	["0055_00029"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1853", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Te distraes mucho... Debemos pensar si los problemas de orden público y nuestro fracaso en encontrar a esta chica llamada Fumino están relacionados.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“总是马上就聊歪掉……说到治安的恶化和‘文乃’的问题要联系起来可能有点勉强。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「總是馬上就聊歪掉……說到治安的惡化和『文乃』的問題要聯繫起來可能有點勉強。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00028",
		linknext = "0055_00030",
		line = 392,
	},
	["0055_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, cierto...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，说得对……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，說得對……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00029",
		linknext = "0055_00031",
		line = 404,
	},
	["0055_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quizás Nanase tiene razón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，也许正如奈奈濑所说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，也許正如奈奈瀨所說。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00030",
		linknext = "0055_00032",
		line = 414,
	},
	["0055_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quizás solo esté creando conexiones entre dos cosas que nada tienen que ver.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的道理，只是把知道的东西硬联系在一起而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的道理，只是把知道的東西硬聯繫在一起而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00031",
		linknext = "0055_00033",
		line = 424,
	},
	["0055_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y suponer que obtendremos una pista sobre la ubicación de Fumino al centrar nuestra atención en el problema del orden público es... una idea descabellada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把目光转向治安问题，想藉此得到文乃的线索——老实说确实很不合理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把目光轉向治安問題，想藉此得到文乃的線索——老實說確實很不合理。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00032",
		linknext = "0055_00034",
		line = 434,
	},
	["0055_00034"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así... no puedo dejarlo pasar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，我……即使这样，我也无法忽视现在的状况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，我……即使這樣，我也無法忽視現在的狀況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00033",
		linknext = "0055_00035",
		line = 446,
	},
	["0055_00035"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Todos los buscadores de sexo en esta isla hacen lo que quieren.",
					{"rt2"},
				},
			},
			cn = {
				{
					"成为性人的岛民们都在各自热闹着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"成為性人的島民們都在各自熱鬧著。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00034",
		linknext = "0055_00036",
		line = 462,
	},
	["0055_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es precisamente contra lo que lucho, y sigo queriendo cambiarlo. Aun así, por imperfecta que sea, estoy de acuerdo en que la ley tiene sus razones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这当然也是需要被矫正的状况，但最起码他们都有取得彼此的同意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這當然也是需要被矯正的狀況，但最起碼他們都有取得彼此的同意。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00035",
		linknext = "0055_00037",
		line = 472,
	},
	["0055_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero la cosa cambia si los niños corren peligro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但对象如果是小孩子，那就另当别论了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但對象如果是小孩子，那就另當別論了。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00036",
		linknext = "0055_00038",
		line = 482,
	},
	["0055_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Obligar a alguien a tener sexo sin su consentimiento... Sé que a eso se le llama violación, y no es más que otra forma de agresión violenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有取得共识的性爱——就和暴力一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有取得共識的性愛——就和暴力一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00037",
		linknext = "0055_00039",
		line = 493,
	},
	["0055_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No puedo quedarme sentado sin hacer nada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我无法在知道发生了这种事后，还置之不理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我無法在知道發生了這種事後，還置之不理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00038",
		linknext = "0055_00040",
		line = 504,
	},
	["0055_00040"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1854", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Esperaba que dijeras algo así. A decir verdad, no creo que sea bueno fingir que no pasa nada cuando sí está pasando algo malo... Aunque eso suponga romper las reglas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……嗯，你就是这种人吧。老实说，我也不愿意对坏事视而不见……虽然我自己也违反条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……嗯，你就是這種人吧。老實說，我也不願意對壞事視而不見……雖然我自己也違反條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00039",
		linknext = "0055_00041",
		line = 518,
	},
	["0055_00041"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0385", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Pero ¿ese no es el trabajo de la SS y la OSS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是但是……那些事情不是FS和SHO的工作吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是但是……那些事情不是FS和SHO的工作嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00040",
		linknext = "0055_00042",
		line = 532,
	},
	["0055_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Debería ser así, pero parece que no pueden manejarlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“本来应该是如此，但事实上他们无法做到完全管控。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「本來應該是如此，但事實上他們無法做到完全管控。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00041",
		linknext = "0055_00043",
		line = 543,
	},
	["0055_00043"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0874", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hace unos días, Rei-chan mencionó que la SS está corta de personal. Al parecer, van a hacer una gran campaña de reclutamiento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那个……礼酱说他们人手不足。所以，听说要增加FS的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那個……禮醬說他們人手不足。所以，聽說要增加FS的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00042",
		linknext = "0055_00044",
		line = 557,
	},
	["0055_00044"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio? Eso es malo para nosotros...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……真麻烦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……真麻煩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00043",
		linknext = "0055_00045",
		line = 569,
	},
	["0055_00045"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Como si no tuviéramos bastante con buscar a Fumino y lidiar con este problema de orden público, ahora también tendremos que preocuparnos por más enemigos...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“寻找‘文乃’，还要对治安问题进行调查，在这种时候敌人还增员……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「尋找『文乃』，還要對治安問題進行調查，在這種時候敵人還增員……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00044",
		linknext = "0055_00046",
		line = 582,
	},
	["0055_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, cuando pensé eso, me di cuenta de algo que casi me dejó sin palabras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这时——我脑中浮现出了我自己也会惊讶的点子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這時——我腦中浮現出了我自己也會驚訝的點子。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00045",
		linknext = "0055_00047",
		line = 592,
	},
	["0055_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La SS es una rama de la OSS, así que su trabajo es mantener el orden público, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS是SHO的底层组织……当然，维持治安也是他们的工作……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS是SHO的底層組織……當然，維持治安也是他們的工作……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00046",
		linknext = "0055_00048",
		line = 604,
	},
	["0055_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La SS probablemente tenga más información de lo que está pasando.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，FS内部有关于治安问题的资料——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，FS內部有關於治安問題的資料——」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00047",
		linknext = "0055_00049",
		line = 615,
	},
	["0055_00049"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00109", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1855", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Seguramente... Espera, ¿estás pensando lo mismo que yo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那肯定是有——你，难道……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那肯定是有——你，難道……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00048",
		linknext = "0055_00050",
		line = 631,
	},
	["0055_00050"] = {
		{"bgm", file="bgm14", vol=100},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si logramos infiltrarnos en la SS, podremos obtener información con más facilidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果我可以加入FS——就可以得到那些情报了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果我可以加入FS——就可以得到那些情報了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00049",
		linknext = "0055_00051",
		line = 643,
	},
	["0055_00051"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=1, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0875", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí... ¡¿Sí?! ¡¿Eh?! ¿V-Vas a unirte a la SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……嗯！！？诶！？橘、橘君要加入FS吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……嗯！！？欸！？橘、橘君要加入FS嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00050",
		linknext = "0055_00052",
		line = 659,
	},
	["0055_00052"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00113", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1856", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Espera! ¡Piénsalo bien, Jun! ¿Lo dices en serio? ¿Acaso entiendes lo que estás diciendo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“等一下等一下……！冷静点淳……你认真的……？你知道自己在说什么吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「等一下等一下……！冷靜點淳……你認真的……？你知道自己在說什麼嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00051",
		linknext = "0055_00053",
		line = 673,
	},
	["0055_00053"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Acaso tartamudeé? Que sepas que lo digo en serio. Piénsalo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然是认真的，你想想看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然是認真的，你想想看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00052",
		linknext = "0055_00054",
		line = 685,
	},
	["0055_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Formamos el NLNS hace mucho, pero aún no sabemos nada de Fumino aparte de su nombre y su edad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然NLNS已经成立很久了——但现在只知道文乃的名字和年龄。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然NLNS已經成立很久了——但現在只知道文乃的名字和年齡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00053",
		linknext = "0055_00055",
		line = 696,
	},
	["0055_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y si la SS va a aumentar sus cifras de reclutamiento... no podremos ocultar nuestras identidades por mucho tiempo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，FS却越来越多……我不认为能永远隐瞒我们的身份。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，FS卻越來越多……我不認為能永遠隱瞞我們的身份。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00054",
		linknext = "0055_00056",
		line = 707,
	},
	["0055_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cuanto más tardemos en encontrar a Fumino, mayor será el riesgo de que nos veamos afectados. Esta situación no puede seguir así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要找不到文乃，情况就会越来越糟，我们不能再这样下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要找不到文乃，情況就會越來越糟，我們不能再這樣下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00055",
		linknext = "0055_00057",
		line = 718,
	},
	["0055_00057"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por eso quiero entrar en la SS como espía. Así podremos investigar el problema del orden público y vigilar sus movimientos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，作为间谍潜入FS内部。这样就能得到治安问题情报，也能了解到他们的动向。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，作為間諜潛入FS內部。這樣就能得到治安問題情報，也能了解到他們的動向。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00056",
		linknext = "0055_00058",
		line = 730,
	},
	["0055_00058"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0876", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, serás un espía de verdad! ¡Genial!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇……那是真正的间谍啊，太帅了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇……那是真正的間諜啊，太帥了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00057",
		linknext = "0055_00059",
		line = 744,
	},
	["0055_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No solo podremos saber más sobre lo que está pasando, también podríamos saber más sobre Fumino. Serán dos pájaros de un tiro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。而且，FS应该还有其他不能外流的情报——或许可以找到有关文乃的线索。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。而且，FS應該還有其他不能外流的情報——或許可以找到有關文乃的線索。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00058",
		linknext = "0055_00060",
		line = 756,
	},
	["0055_00060"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00122", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1051", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Entiendo tu idea, manito... pero es una locura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我明白哥哥说的……但是，太危险了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我明白哥哥說的……但是，太危險了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00059",
		linknext = "0055_00061",
		line = 769,
	},
	["0055_00061"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si queremos acabar con esta maldita ley pervertida, no llegaremos a ninguna parte hasta que dejemos de tenerle miedo al cambio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们的目的是摧毁变态条例……如果害怕冒险的话，能做到的事情就都会办不到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們的目的是摧毀變態條例……如果害怕冒險的話，能做到的事情就都會辦不到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00060",
		linknext = "0055_00062",
		line = 781,
	},
	["0055_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además, si hago esto, estarán a salvo porque siempre podremos seguir los movimientos de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且——如果我潜入成功的话，麻沙酱们反而会更安全。因为可以得到FS的动向。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且——如果我潛入成功的話，麻沙醬們反而會更安全。因為可以得到FS的動向。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00061",
		linknext = "0055_00063",
		line = 793,
	},
	["0055_00063"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00122", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1052", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Supongo, pero... no me parece bien que lo hagas tú solo. ¿Podrías no hacerlo, por favor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“话是这样说……可是一个人做那样的事情不好吧……还是不要吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「話是這樣說……可是一個人做那樣的事情不好吧……還是不要吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00062",
		linknext = "0055_00064",
		line = 806,
	},
	["0055_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan está muy angustiada por esto, y entiendo perfectamente por qué.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然麻沙酱比以往任何时候都要不安，但是她的心情我非常理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然麻沙醬比以往任何時候都要不安，但是她的心情我非常理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00063",
		linknext = "0055_00065",
		line = 816,
	},
	["0055_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por mucho que discutamos, somos los únicos de nuestra familia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平时不管吵得多兇，我们都是对方唯一的家人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平時不管吵得多兇，我們都是對方唯一的家人。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00064",
		linknext = "0055_00066",
		line = 826,
	},
	["0055_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Precisamente por eso tengo que hacerlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——也因此我必须这么做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——也因此我必須這麼做。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00065",
		linknext = "0055_00067",
		line = 836,
	},
	["0055_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As long as that perverted sex law stands, my sister and friends will keep being in danger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要变态条例还在，妹妹，这些朋友们……所有人都会一直处在危险之中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要變態條例還在，妹妹，這些朋友們……所有人都會一直處在危險之中。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00066",
		linknext = "0055_00068",
		line = 846,
	},
	["0055_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan, por favor. Lo estoy haciendo por ti.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱请你理解我，这也是为了你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬請你理解我，這也是為了你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00067",
		linknext = "0055_00069",
		line = 858,
	},
	["0055_00069"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0877", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Entonces iré contigo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那么，我也一起去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那麼，我也一起去！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00068",
		linknext = "0055_00070",
		line = 873,
	},
	["0055_00070"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00119", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿Qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……啥？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……啥？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00069",
		linknext = "0055_00071",
		line = 887,
	},
	["0055_00071"] = {
		{"bgm", file="bgm02", vol=100},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0878", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Te sentirás mejor si entro a la SS con él, ¿verdad? ¡Después de todo, dos cabezas piensan mejor que una!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果不仅仅是橘君，我也一起加入FS的话，麻沙音酱也能安心了吧？两个人的话比较让人安心嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果不僅僅是橘君，我也一起加入FS的話，麻沙音醬也能安心了吧？兩個人的話比較讓人安心嘛！」",
					{"rt2"},
				},
			},
