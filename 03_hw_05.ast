		linkback = "0055_00580",
		linknext = "0055_00582",
		line = 7247,
	},
	["0055_00582"] = {
		{"bgm", stop=1},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0192", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Ya basta! ¡Te presentaste a las pruebas y fallaste! ¡Acéptalo o cállate!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“闭嘴！你们参加了考试后，结果是不及格！你们要接受现实。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「閉嘴！你們參加了考試後，結果是不及格！你們要接受現實。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00581",
		linknext = "0055_00583",
		line = 7261,
	},
	["0055_00583"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No tengo argumentos para discutir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被这么一说，就什么都没法反驳了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被這麼一說，就什麼都沒法反駁了。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00582",
		linknext = "0055_00584",
		line = 7273,
	},
	["0055_00584"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"bgm", file="bgm04.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0580", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, Rei. Basándonos en este resultado, me atrevo a decir que lo consideramos un éxito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，礼，这样的结果，算他们合格也可以吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，禮，這樣的結果，算他們合格也可以吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00583",
		linknext = "0055_00585",
		line = 7288,
	},
	["0055_00585"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0193", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Eh? Touka-sama, ¿qué acaba de decir...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么……？桐香大人，你刚刚说了什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼……？桐香大人，你剛剛說了什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00584",
		linknext = "0055_00586",
		line = 7304,
	},
	["0055_00586"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0581", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sus resultados en el salto en largo con erección son inigualables. ¿No debería determinarse el resultado final a partir de la suma de cada prueba? Tachibana-senpai habría obtenido justo la calificación mínima para aprobar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“勃起跳远的纪录远远超出了合格的标准值。本考试是依照各个项目的合计进行判断的，前辈应该刚好过了合格线吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「勃起跳遠的紀錄遠遠超出了合格的標準值。本考試是依照各個項目的合計進行判斷的，前輩應該剛好過了合格線吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00585",
		linknext = "0055_00587",
		line = 7316,
	},
	["0055_00587"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00124", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0194", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Es posible, pero este hombre es impotente, y mejor ni hablemos de su potencial sexual. Si alguien no puede tener una erección sin ayuda, ¿qué lugar tiene en la SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“确实是这样……但这个男人是阳痿，性能力本身就有问题。要让无法靠自己勃起的阳痿进入FS实在是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「確實是這樣……但這個男人是陽痿，性能力本身就有問題。要讓無法靠自己勃起的陽痿進入FS實在是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00586",
		linknext = "0055_00588",
		line = 7330,
	},
	["0055_00588"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00104", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0582", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei, tienes que cambiar un poco tu actitud. Estás al tanto del problemita de la discriminación contra los impotentes, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“礼，请更正你的发言。性功能障碍者的歧视问题你也是知道的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「禮，請更正你的發言。性功能障礙者的歧視問題你也是知道的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00587",
		linknext = "0055_00589",
		line = 7344,
	},
	["0055_00589"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0195", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Ah...! ¡Discúlpeme por mi imprudencia...!”",
