					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yep, just leave it to your senior! Hehe... what a sweet big brother you are.”",
					{"rt2"},
				},
			},
			cn = {
