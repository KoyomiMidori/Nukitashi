	["0055_00448"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0963", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Whaa? Rei? What are you going to do to me...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔啊……？礼酱……？这是……要对我做什么呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔啊……？禮醬……？這是……要對我做什麼呢……？」",
