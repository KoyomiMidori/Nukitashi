					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ven, respira hondo. Respira... y exhala...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“来，深呼吸，深呼吸……吸——哈——”",
