		linkback = "0055_00657",
		linknext = "0055_00659",
		line = 8317,
	},
	["0055_00659"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya no me queda de otra que dar lo mejor de mí, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被你这么一说……我只能努力了呢。”",
