	},
	["0055_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the woman who shot through the ranks of the SS, becoming their leader within a year.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是1年级，却站在FS顶端的女人。",
					{"rt2"},
				},
