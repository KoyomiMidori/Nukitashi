		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=500, mode=3, x=800, y=0},
		{"fgact", ch="桐香", id=8, act="移動", x=-200, y=0, time=700},
		{"text"},
		delay = {
			[700] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
