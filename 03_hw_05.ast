				{"vo", file="touka0565", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei, ¿estás ocupada? ¿Oh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“礼，有空吗……咦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「禮，有空嗎……咦？」",
