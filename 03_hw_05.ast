			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Basta! Si un hombre no puede tener una erección, ¿para qué sirve? ¡Hemos terminado! ¡Llévate a Hinami y desaparece de mi vista!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“闭嘴！硬不起来的男人有用才怪！算了，我话说完了！带着雏见赶快出去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「閉嘴！硬不起來的男人有用才怪！算了，我話說完了！帶著雛見趕快出去！」",
					{"rt2"},
				},
			},
