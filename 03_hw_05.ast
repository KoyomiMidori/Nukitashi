			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh my, please forgive me, I was unaware you had visitors. Now that's surprising! Hehe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“真是失礼了，没想到有客人。呵呵，还真是稀奇呢。”",
