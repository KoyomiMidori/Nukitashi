				{"vo", file="touka0567", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, no me tomaría el atrevimiento. Ahora mismo son nuestros invitados. ¿Me puedes informar sobre su consulta?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不能这样哦。他们难得来到这里……也能详细告诉我是什么情况吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不能這樣哦。他們難得來到這裡……也能詳細告訴我是什麼情況嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00130",
		linknext = "0055_00132",
		line = 1672,
	},
	["0055_00132"] = {
