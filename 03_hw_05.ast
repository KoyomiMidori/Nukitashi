	["0055_00133"] = {
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La presidenta asiente con la cabeza mientras Rei le explica. Parece que tiene mucho entre manos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长一边听着一边随声附和——但她心里到底在想什么？",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長一邊聽著一邊隨聲附和——但她心裡到底在想什麼？",
					{"rt2"},
				},
