					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? No... ¡P-Pero nos esforzamos mucho!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……怎么这样……我、我们都很努力了！”",
					{"rt2"},
