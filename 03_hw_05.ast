			},
		},
		text = {
			vo = {
				{"vo", file="hinami0886", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Aunque sea muy intenso, estoy segura de que será divertido mientras esté con ustedes dos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……或许真的会很辛苦……但是，如果和橘君还有礼酱在一起的话，一定会成为很开心的回忆的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……或許真的會很辛苦……但是，如果和橘君還有禮醬在一起的話，一定會成為很開心的回憶的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00108",
		linknext = "0055_00110",
		line = 1409,
	},
	["0055_00110"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei cierra los ojos y piensa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长闭目静默了数秒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員長閉目靜默了數秒。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00109",
		linknext = "0055_00111",
		line = 1421,
	},
	["0055_00111"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me mira fijamente, juzgándome con la mirada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后又睁眼用锐利的目光盯着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後又睜眼用銳利的目光盯著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00110",
		linknext = "0055_00112",
		line = 1433,
	},
	["0055_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seguramente piensa que fui yo quien instigó esto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就好像在说——是你唆使的吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"就好像在說——是你唆使的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00111",
		linknext = "0055_00113",
		line = 1443,
	},
	["0055_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su energía es intensa, pero no puedo dejar que me gane.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然差点被她的气势压倒，但我不能输。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然差點被她的氣勢壓倒，但我不能輸。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00112",
		linknext = "0055_00114",
		line = 1453,
	},
	["0055_00114"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0167", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana, sé que estás muy emocionado por ayudarnos, pero no creo que entiendas lo intenso que es el entrenamiento de la SS. No pareces tener la resistencia necesaria.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘……志愿入队的事情——我刚才说了，FS的训练是不容小觑的。我看不出你有能够承受的体力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘……志願入隊的事情——我剛才說了，FS的訓練是不容小覷的。我看不出你有能夠承受的體力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00113",
		linknext = "0055_00115",
		line = 1465,
	},
	["0055_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Confío en mi resistencia!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，我对体力很有自信！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，我對體力很有自信！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00114",
		linknext = "0055_00116",
		line = 1477,
	},
	["0055_00116"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0168", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“También eres lento para entender las cosas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“脑袋看起来也不灵光。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「腦袋看起來也不靈光。」",
					{"rt2"},
				},
			},
