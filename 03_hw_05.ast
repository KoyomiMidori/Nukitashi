				{"vo", file="nanase1849", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wow, that sounds rough. Wata, did you get out okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“发生过那种事……渡酱，你没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「發生過那種事……渡醬，你沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00002",
		linknext = "0055_00004",
		line = 50,
	},
	["0055_00004"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=10, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0868", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, it was a little bit scary, but I'm fine. Tachibana saved me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，虽然有点害怕……不过没关系的，因为橘君救了我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，雖然有點害怕……不過沒關係的，因為橘君救了我！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00003",
		linknext = "0055_00005",
		line = 65,
	},
	["0055_00005"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1047", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I had a thought... is this anything to do with that time you almost got assaulted, back when we met you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“说不定……这跟上次渡酱被人盯上的事情有关吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「說不定……這跟上次渡醬被人盯上的事情有關嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00004",
		linknext = "0055_00006",
		line = 78,
	},
	["0055_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
