		linkback = "0055_00126",
		linknext = "0055_00128",
		line = 1622,
	},
	["0055_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never met her up close like this before. Her aura is overwhelming.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是第一次这么近距离看她——她身上有着令人不由自主地屏住呼吸的不可思议气场。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是第一次這麼近距離看她——她身上有著令人不由自主地屏住呼吸的不可思議氣場。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00127",
		linknext = "0055_00129",
		line = 1632,
	},
	["0055_00129"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
