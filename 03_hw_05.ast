	},
	["0055_00621"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This goes on for a while before we naturally returned to our usual give and take.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样——注意到时，已经在不知不觉间，像平时那样变回了傻傻的对话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣——注意到時，已經在不知不覺間，像平時那樣變回了傻傻的對話。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00620",
		linknext = "0055_00622",
		line = 7826,
	},
	["0055_00622"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I feel like I gotta apologize to you, though. It was my stupid idea to join the SS that made you go through all that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，真的很抱歉。都是因为我说要加入FS，才让渡酱前辈遇到那样的事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，真的很抱歉。都是因為我說要加入FS，才讓渡醬前輩遇到那樣的事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00621",
		linknext = "0055_00623",
		line = 7838,
	},
	["0055_00623"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00121", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0905", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Nah, it was my choice. I feel like I should be the one saying sorry... I couldn't help you... I'm such a hopeless failure of a senior.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，这是我想做的。但是……结果没能帮上忙，对不起……我真是没用，没资格当前辈啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，這是我想做的。但是……結果沒能幫上忙，對不起……我真是沒用，沒資格當前輩啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00622",
		linknext = "0055_00624",
		line = 7854,
	},
	["0055_00624"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Failure... that's not true.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“才没有那种事呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「才沒有那種事呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00623",
		linknext = "0055_00625",
		line = 7866,
	},
	["0055_00625"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I tell her that, but there's only so much I can say to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算我试着这样说，渡酱还是十分沮丧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算我試著這樣說，渡醬還是十分沮喪。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00624",
		linknext = "0055_00626",
		line = 7876,
	},
	["0055_00626"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Personally, I think it's for the best that she couldn't join.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对我来说，不如说渡酱没有加入真是太好了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"對我來說，不如說渡醬沒有加入真是太好了——",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00625",
		linknext = "0055_00627",
		line = 7886,
	},
	["0055_00627"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In that case, would you be able to look after Asa going forward?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……既然这样。渡酱前辈，可以从明天开始替我照顾好麻沙酱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……既然這樣。渡醬前輩，可以從明天開始替我照顧好麻沙醬嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00626",
		linknext = "0055_00628",
		line = 7898,
	},
	["0055_00628"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0906", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Asane?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……麻沙音酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……麻沙音醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00627",
		linknext = "0055_00629",
		line = 7912,
	},
	["0055_00629"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. As an SS trainee there'll be times when I can't look after her. Do you mind?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。既然我成为了FS的训练生，就可能有照顾不到她的部分出现……可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。既然我成為了FS的訓練生，就可能有照顧不到她的部分出現……可以嗎？」",
					{"rt2"},
				},
			},
		},
