	["0055_00007"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0383", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Agh... Things have sure gotten hairy around here lately...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊呜呜……总觉得最近哪里都很可怕啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊嗚嗚……總覺得最近哪裡都很可怕啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00006",
		linknext = "0055_00008",
		line = 104,
	},
	["0055_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Come to think of it, Hotori ended up in our group after I saved her from being assaulted, too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想起来，畔会在这里也是因为她被袭击的时候救了她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想起來，畔會在這裡也是因為她被襲擊的時候救了她。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00007",
		linknext = "0055_00009",
		line = 114,
	},
	["0055_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't put my finger on why... but perhaps order on the entire island is collapsing. And not just for children.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道原因是什么——不只是小孩子，岛上的治安可能在很多方面都恶化了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道原因是什麼——不只是小孩子，島上的治安可能在很多方面都惡化了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00008",
		linknext = "0055_00010",
		line = 124,
	},
	["0055_00010"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Could this have anything to do with us not being able to dig up any info on Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说不定——完全得不到文乃的情报一事，会不会也和这个有关呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說不定——完全得不到文乃的情報一事，會不會也和這個有關呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00009",
		linknext = "0055_00011",
		line = 136,
	},
	["0055_00011"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
