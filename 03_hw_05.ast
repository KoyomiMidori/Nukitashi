	["0055_00619"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", file2="hinami_01m_00204", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0904", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jaaa... Ya estoy tranquilita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呼啊……冷静总算下来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呼啊……冷靜總算下來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00618",
		linknext = "0055_00620",
		line = 7804,
	},
	["0055_00620"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No estás tranquila...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“根本还没冷静下来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「根本還沒冷靜下來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00619",
		linknext = "0055_00621",
		line = 7816,
	},
	["0055_00621"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esto duró un tiempo hasta que volvimos a nuestra relación habitual de dar y recibir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样——注意到时，已经在不知不觉间，像平时那样变回了傻傻的对话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣——注意到時，已經在不知不覺間，像平時那樣變回了傻傻的對話。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00620",
		linknext = "0055_00622",
		line = 7826,
	},
	["0055_00622"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así, siento que tengo que pedirte perdón. Fue mi idea estúpida de unirme a la SS lo que te obligó a sufrir así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，真的很抱歉。都是因为我说要加入FS，才让渡酱前辈遇到那样的事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，真的很抱歉。都是因為我說要加入FS，才讓渡醬前輩遇到那樣的事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00621",
		linknext = "0055_00623",
		line = 7838,
	},
	["0055_00623"] = {
