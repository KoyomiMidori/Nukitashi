					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Es cierto que no puedo tener sexo, pero puedo ser útil de otras maneras!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然我不能做爱，但会在其他方面帮上忙的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然我不能做愛，但會在其他方面幫上忙的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00155",
		linknext = "0055_00157",
		line = 1977,
	},
	["0055_00157"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
