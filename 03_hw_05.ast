	["0055_00565"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras la llamo, me invade una repentina sensación de mareo y pierdo el equilibrio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一发出声音，我也突然一阵晕眩，脚也不稳了。",
