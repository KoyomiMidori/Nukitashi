	["0055_00558"] = {
		{"se", id=0, stop=1, time=2000},
		{"evset", file="hhcg02", set="hhcg02", path=":ev/hhcg02/"},
		{"evset", file="hhcg020707611", set="hhcg02070", path=":ev/hhcg02070/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hhcg020707611", x=-5, y=-5, path=":cg/hhcg02/", lv=5, ev=1, time=500, bx=800, by=450},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus caderas se sacuden y se contraen mientras el líquido transparente brota a chorros. El piso, que acababa de limpiarse, vuelve a mancharse de orina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后一边尿着一边让腰部一跃而起——刚擦干净的地板又开始被尿弄脏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後一邊尿著一邊讓腰部一躍而起——剛擦乾淨的地板又開始被尿弄髒。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00557",
		linknext = "0055_00559",
		line = 6931,
	},
	["0055_00559"] = {
		{"text"},
		text = {
