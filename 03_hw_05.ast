	["0055_00451"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0219", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No seas tan ingenua como para pensar que solo es un juego. Estar obligada a reírte agotará tu resistencia e incluso podría provocarte disnea. Hinami, puedes irte ahora si no quieres hacerlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不要当成游戏小看。如果持续被强制发笑，体力会被消耗，甚至还可能陷入呼吸困难……雏见，要放弃的话只能趁现在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不要當成遊戲小看。如果持續被強制發笑，體力會被消耗，甚至還可能陷入呼吸困難……雛見，要放棄的話只能趁現在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00450",
		linknext = "0055_00452",
		line = 5606,
	},
