		},
		linkback = "0055_00447",
		linknext = "0055_00449",
		line = 5571,
	},
	["0055_00449"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0218", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There is no place in the SS for quibbling over the smallest things. So we are going to test your tolerance towards tickling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……如果因为一点小事就说出丧气话是做不了FS的。因此，现在开始进行挠痒痒的忍耐考试。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……如果因為一點小事就說出喪氣話是做不了FS的。因此，現在開始進行撓癢癢的忍耐考試。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00448",
		linknext = "0055_00450",
		line = 5583,
	},
	["0055_00450"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tickling...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“挠痒痒……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「撓癢癢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00449",
		linknext = "0055_00451",
		line = 5594,
	},
	["0055_00451"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0219", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don't be so naive to think it's just a game. Being compelled to laugh will sap your endurance, and could even lead to dyspnea. Hinami, this is your chance to quit while you still can.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不要当成游戏小看。如果持续被强制发笑，体力会被消耗，甚至还可能陷入呼吸困难……雏见，要放弃的话只能趁现在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不要當成遊戲小看。如果持續被強制發笑，體力會被消耗，甚至還可能陷入呼吸困難……雛見，要放棄的話只能趁現在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00450",
		linknext = "0055_00452",
		line = 5606,
	},
	["0055_00452"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0964", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hrmph, I'm not quitting. I've been tickled countless times since I was little. It's nothing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔……我不放弃。挠痒痒之类的从小时候开始就被弄过很多次了，根本没有问题！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔……我不放棄。撓痒癢之類的從小時候開始就被弄過很多次了，根本沒有問題！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00451",
		linknext = "0055_00453",
		line = 5618,
	},
	["0055_00453"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0220", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Very well. As before, you have five minutes. If you are unable to tolerate it and give up, you will be disqualified. Let's begin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……这样啊，我知道了。限制时间同样是5分钟。如果受不了投降的话就是不及格……那么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……這樣啊，我知道了。限制時間同樣是5分鐘。如果受不了投降的話就是不及格……那麼……」",
					{"rt2"},
				},
			},
		},
