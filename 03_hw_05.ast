	["0055_00163"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0574", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Jeje. Por suerte, contamos con muchos afrodisíacos y medicinas vigorizantes... Rei, dale la medicina “B”.”",
					{"rt2"},
				},
			},
			cn = {
