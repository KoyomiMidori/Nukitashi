		line = 7187,
	},
	["0055_00577"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0190", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡No sirve de nada intentarlo si sigues fracasando! ¡Si solo con eso se desmayan, no están preparados para el entrenamiento de la SS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……就算努力了，不行就是不行！光是这样就失去意识，那肯定跟不上FS的训练！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……就算努力了，不行就是不行！光是這樣就失去意識，那肯定跟不上FS的訓練！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00576",
		linknext = "0055_00578",
		line = 7199,
	},
	["0055_00578"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Espera! ¡Estoy seguro de que me desmayé como efecto secundario del afrodisíaco!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请等一下！我倒下肯定是药的副作用！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請等一下！我倒下肯定是藥的副作用！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00577",
		linknext = "0055_00579",
		line = 7211,
	},
	["0055_00579"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Me tomé como tres! ¡Eso provocaría efectos secundarios en cualquiera!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种东西喝了3瓶，任谁都会出问题的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種東西喝了3瓶，任誰都會出問題的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00578",
		linknext = "0055_00580",
		line = 7222,
	},
	["0055_00580"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0191", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Di lo que quieras! ¿Te piensas que vamos a permitir que un hombre impotente se una a nuestras filas? ¿O que te demos tu suministro especial de afrodisíacos para que lo lleves contigo? ¡Esa cosa no es barata!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就算是那样，我也不可能让阳痿的男人进来！还是说你想要求让自己一直带着壮阳药！？那可不便宜哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就算是那樣，我也不可能讓陽痿的男人進來！還是說你想要求讓自己一直帶著壯陽藥！？那可不便宜哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00579",
		linknext = "0055_00581",
		line = 7236,
	},
	["0055_00581"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero aun sin eso, yo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算没有那种东西，我也——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算沒有那種東西，我也——」",
					{"rt2"},
				},
