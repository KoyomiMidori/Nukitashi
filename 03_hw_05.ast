	["0055_00602"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0897", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Rei-chan, Rei-chan, ¿qué hay de mí?! ¡¿También hay una cuota especial para mí?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱礼酱，我呢！？我是不是也能有特别的位置！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬禮醬，我呢！？我是不是也能有保障名額！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00601",
		linknext = "0055_00603",
		line = 7534,
	},
	["0055_00603"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0201", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Para ti, Hinami... ¿Cómo lo digo...? Si te unieras a la SS, algunos turistas podrían confundirse sobre cuál es la edad legal de consentimiento...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见……嗯，怎么说。雏见在FS的话，可能会让游客误解条例的对象年龄……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見……嗯，怎麼說。雛見在FS的話，可能會讓遊客誤解條例的對象年齡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00602",
		linknext = "0055_00604",
		line = 7548,
	},
	["0055_00604"] = {
