	},
	["0055_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Me está diciendo que le muestre la polla?",
					{"rt2"},
				},
			},
			cn = {
				{
					"要我在这样的地方把鸡巴露出来——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"要我在這樣的地方把肉棒露出來——？",
