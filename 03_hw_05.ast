		line = 7727,
	},
	["0055_00615"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00113", file2="hinami_01m_00204", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0902", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡L-Lo siento mucho, Tachibana-kun! ¡Um, bueno! ¡Estaba tratando de ayudarte a que te unieras a la SS para ayudarte y no pude ayudarte para que me ayudaras a unirme!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对、对不起，橘君！那个，呃！虽然我本来也打算加入FS的，但变成结果一个人就只有你了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對、對不起，橘君！那個，呃！雖然我本來也打算加入FS的，但變成結果一個人就只有你了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00614",
		linknext = "0055_00616",
		line = 7742,
	},
	["0055_00616"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
