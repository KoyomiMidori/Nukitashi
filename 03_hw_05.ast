			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡No! ¡Yo también quiero unirme! ¡Quiero unirme a la SS y darles una paliza a todos esos tips malos! Así, ¡hyah!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不是，我也希望入队哦。我要加入FS，惩罚那些坏人！哼、哼！”",
