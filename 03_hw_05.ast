			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh no, I wouldn't ever do that. They're our guests right now. Can you tell me about their inquiry?”",
					{"rt2"},
				},
