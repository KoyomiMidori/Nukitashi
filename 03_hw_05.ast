	["0055_00619"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", file2="hinami_01m_00204", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0904", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
