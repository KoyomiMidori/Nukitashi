	["0055_00456"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0221", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana, acompáñalas en las cosquillas. En la SS habrá ocasiones en las que tendrás que ayudar con otros castigos además de la guillotina.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘，你也去挠痒。除了断头台，FS也会根据需要帮忙执行挠痒痒等惩罚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘，你也去撓癢。除了斷頭臺，FS也會根據需要幫忙執行撓癢癢等懲罰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00455",
		linknext = "0055_00457",
		line = 5672,
	},
	["0055_00457"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0222", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No puedes ser indulgente con la tortura, aunque el sujeto sea uno de tus amigos o familiares. ¡Si veo que la tratas con indulgencia, no dudaré en descalificarlos a los dos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“即使对方是自己的同伴，拷问时也必须要保持冷峻的态度……如果，等等你要是稍微手下留情了，两方都不会被录取的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「即使對方是自己的同伴，拷問時也必須要保持冷峻的態度……如果，等等你要是稍微手下留情了，兩方都不會被錄取的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00456",
		linknext = "0055_00458",
		line = 5684,
	},
