		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0189", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Por favor... ¿en serio se desmayaron los dos? ¡No puedo creerlo! ¡Ninguno de ustedes es apto para entrar a la SS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真是的……没想到你们俩都昏过去了。真是不像话！不能让你们加入FS！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真是的……沒想到你們倆都昏過去了。真是不像話！不能讓你們加入FS！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00574",
		linknext = "0055_00576",
		line = 7171,
	},
	["0055_00576"] = {
		{"fgact", ch="桐香", id=8, act="移動", x=200, y=0, time=700},
		{"fgact", ch="礼", id=9, act="移動", x=-200, y=0, time=700},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=0, y=-100, time=700},
		{"text"},
		text = {
