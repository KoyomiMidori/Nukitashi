				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Intenté entrar en la oficina del comité de moral pública de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然在风纪委员室里时，因为拼命想要加入FS，所以不是时候——",
