				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Le están haciendo cosquillas sin parar en todas partes... La parte interna de los muslos, el torso, la parte posterior de las piernas... y parece que se está poniendo más sensible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大腿内侧、腹部、脚底等被一直挠痒痒，似乎连皮肤都变得越来越敏感。",
					{"rt2"},
				},
			},
			tw = {
