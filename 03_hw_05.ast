		linkback = "0055_00136",
		linknext = "0055_00138",
		line = 1743,
	},
	["0055_00138"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0569", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It is our duty as SS to train them, is it not? Were you a perfect soldier the moment you enlisted?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“锻炼他们也是我们FS的工作，不是吗？你一开始也并不是完美的士兵呀？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「鍛煉他們也是我們FS的工作，不是嗎？你一開始也並不是完美的士兵呀？」",
					{"rt2"},
				},
			},
		},
