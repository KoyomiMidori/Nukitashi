		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did I stutter? I'll have you know, I'm dead serious. Think about it for a sec.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然是认真的，你想想看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然是認真的，你想想看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00052",
		linknext = "0055_00054",
		line = 685,
	},
	["0055_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We formed the NLNS a while ago, but we still haven't turned up anything on Fumino save for her name and age.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然NLNS已经成立很久了——但现在只知道文乃的名字和年龄。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然NLNS已經成立很久了——但現在只知道文乃的名字和年齡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00053",
		linknext = "0055_00055",
		line = 696,
	},
	["0055_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And if the SS is going to increase their recruitment numbers... we're not gonna be able to hide our identities for much longer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，FS却越来越多……我不认为能永远隐瞒我们的身份。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，FS卻越來越多……我不認為能永遠隱瞞我們的身份。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00054",
		linknext = "0055_00056",
		line = 707,
	},
	["0055_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The longer we can't find Fumino, the greater our risk of being swept up in disaster is. This isn't a sustainable situation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要找不到文乃，情况就会越来越糟，我们不能再这样下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要找不到文乃，情況就會越來越糟，我們不能再這樣下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00055",
		linknext = "0055_00057",
		line = 718,
	},
	["0055_00057"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's why I want to enter the SS as a spy. That way we can look into the public order problem and keep tabs on their movements.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，作为间谍潜入FS内部。这样就能得到治安问题情报，也能了解到他们的动向。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，作為間諜潛入FS內部。這樣就能得到治安問題情報，也能了解到他們的動向。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00056",
		linknext = "0055_00058",
		line = 730,
	},
	["0055_00058"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0876", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Wow, you'll be a real spy! That's so cool!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇……那是真正的间谍啊，太帅了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇……那是真正的間諜啊，太帥了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00057",
		linknext = "0055_00059",
		line = 744,
	},
	["0055_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not only will we be able to learn more about what's going on, but maybe we'll even be able to learn more about Fumino. It'll be two birds with one stone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。而且，FS应该还有其他不能外流的情报——或许可以找到有关文乃的线索。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。而且，FS應該還有其他不能外流的情報——或許可以找到有關文乃的線索。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00058",
		linknext = "0055_00060",
		line = 756,
	},
	["0055_00060"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00122", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1051", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I understand your reasoning and all, Bro... but that's kinda mental.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我明白哥哥说的……但是，太危险了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我明白哥哥說的……但是，太危險了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00059",
		linknext = "0055_00061",
		line = 769,
	},
	["0055_00061"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If we want to bring down this damn perverted sex law, then we're not gonna get anywhere until we stop being afraid to take initiative.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们的目的是摧毁变态条例……如果害怕冒险的话，能做到的事情就都会办不到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們的目的是摧毀變態條例……如果害怕冒險的話，能做到的事情就都會辦不到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00060",
		linknext = "0055_00062",
		line = 781,
	},
	["0055_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Besides, if I can do this, then it'll make it safer for you guys, since we'll always be able to keep track of the SS's movements.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且——如果我潜入成功的话，麻沙酱们反而会更安全。因为可以得到FS的动向。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且——如果我潛入成功的話，麻沙醬們反而會更安全。因為可以得到FS的動向。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00061",
		linknext = "0055_00063",
		line = 793,
	},
	["0055_00063"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00122", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1052", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I guess, but, like... it doesn't feel right for you to do this alone. Could you maybe not? Pretty please?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“话是这样说……可是一个人做那样的事情不好吧……还是不要吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「話是這樣說……可是一個人做那樣的事情不好吧……還是不要吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00062",
		linknext = "0055_00064",
		line = 806,
	},
	["0055_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa's really distressed about this, and it's not like I don't understand why.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然麻沙酱比以往任何时候都要不安，但是她的心情我非常理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然麻沙醬比以往任何時候都要不安，但是她的心情我非常理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00063",
		linknext = "0055_00065",
		line = 816,
	},
	["0055_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter how much we argue, we're still the only family we have left.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平时不管吵得多兇，我们都是对方唯一的家人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平時不管吵得多兇，我們都是對方唯一的家人。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00064",
		linknext = "0055_00066",
		line = 826,
	},
	["0055_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That is exactly why I have to do this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——也因此我必须这么做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——也因此我必須這麼做。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00065",
		linknext = "0055_00067",
		line = 836,
	},
	["0055_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As long as that perverted sex law stands, my sister and friends will keep being in danger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要变态条例还在，妹妹，这些朋友们……所有人都会一直处在危险之中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要變態條例還在，妹妹，這些朋友們……所有人都會一直處在危險之中。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00066",
		linknext = "0055_00068",
		line = 846,
	},
	["0055_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please, Asa. I'm doing this for your sake.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱请你理解我，这也是为了你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬請你理解我，這也是為了你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00067",
		linknext = "0055_00069",
		line = 858,
	},
	["0055_00069"] = {
