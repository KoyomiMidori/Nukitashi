		linkback = "0055_00104",
		linknext = "0055_00106",
		line = 1357,
	},
	["0055_00106"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0165", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Me parece bien que te emocione, pero ya estás en tercer año, ¿recuerdas? Aunque puedas entrar a la SS, no podrás hacer mucho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然你的心意很好……可是雏见已经是3年级生了。现在进也太迟了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然你的心意很好……可是雛見已經是3年級生了。現在進也太遲了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00105",
		linknext = "0055_00107",
		line = 1369,
	},
	["0055_00107"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0885", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Eso no es cierto! ¡Nunca es demasiado tarde para seguir tu pasión!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没那回事。没有什么事情是迟的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒那回事。沒有什麼事情是遲的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00106",
		linknext = "0055_00108",
		line = 1381,
	},
	["0055_00108"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0166", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Debes saber que los miembros de la SS tienen que someterse a un régimen de entrenamiento increíblemente intenso. Deberías disfrutar mejor tu último año.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……不过，FS的训练很辛苦哦？这已经是你学校生活的最后一年了不是吗？应该抓紧时间创造些更快乐的回忆啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……不過，FS的訓練很辛苦哦？這已經是你學校生活的最後一年了不是嗎？應該抓緊時間創造些更快樂的回憶啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00107",
		linknext = "0055_00109",
		line = 1393,
	},
	["0055_00109"] = {
