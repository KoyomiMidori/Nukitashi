		linkback = "0055_00006",
		linknext = "0055_00008",
		line = 104,
	},
	["0055_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que me acuerdo, Hotori también terminó en nuestro grupo después de que la salvara de ser abusada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想起来，畔会在这里也是因为她被袭击的时候救了她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想起來，畔會在這裡也是因為她被襲擊的時候救了她。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00007",
		linknext = "0055_00009",
		line = 114,
	},
	["0055_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No sé muy bien por qué... pero tal vez el orden de la isla se esté desmoronando. Y no solo para los niños.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道原因是什么——不只是小孩子，岛上的治安可能在很多方面都恶化了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道原因是什麼——不只是小孩子，島上的治安可能在很多方面都惡化了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00008",
		linknext = "0055_00010",
		line = 124,
	},
	["0055_00010"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Será que esto estará relacionado con que no hayamos podido encontrar nada sobre Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说不定——完全得不到文乃的情报一事，会不会也和这个有关呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說不定——完全得不到文乃的情報一事，會不會也和這個有關呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00009",
		linknext = "0055_00011",
		line = 136,
	},
	["0055_00011"] = {
