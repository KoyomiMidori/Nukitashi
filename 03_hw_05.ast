					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Puedo adaptarme a cualquier situación!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我可以随机应变地行动！”",
