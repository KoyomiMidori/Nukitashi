				{
					name = {"礼", "禮"},
					"「就算是那樣，我也不可能讓陽痿的男人進來！還是說你想要求讓自己一直帶著壯陽藥！？那可不便宜哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00579",
		linknext = "0055_00581",
		line = 7236,
	},
	["0055_00581"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But even without that, I...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算没有那种东西，我也——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算沒有那種東西，我也——」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00580",
		linknext = "0055_00582",
		line = 7247,
	},
	["0055_00582"] = {
		{"bgm", stop=1},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0192", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Enough! You took the trials, and you failed! Face up or shut up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“闭嘴！你们参加了考试后，结果是不及格！你们要接受现实。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「閉嘴！你們參加了考試後，結果是不及格！你們要接受現實。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00581",
		linknext = "0055_00583",
		line = 7261,
	},
	["0055_00583"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't find an argument to refute that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被这么一说，就什么都没法反驳了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被這麼一說，就什麼都沒法反駁了。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00582",
		linknext = "0055_00584",
		line = 7273,
	},
	["0055_00584"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"bgm", file="bgm04.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0580", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, Rei. Based on this outcome, I wager we consider it a success.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，礼，这样的结果，算他们合格也可以吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，禮，這樣的結果，算他們合格也可以吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00583",
		linknext = "0055_00585",
		line = 7288,
	},
	["0055_00585"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0193", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Huh? Miss Touka, what do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么……？桐香大人，你刚刚说了什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼……？桐香大人，你剛剛說了什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00584",
		linknext = "0055_00586",
		line = 7304,
	},
	["0055_00586"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0581", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“His results on the erect broad jump are unmatched. Should the final result not be determined but the sum of each test? In that case, Tachibana would have just reached a passing grade.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“勃起跳远的纪录远远超出了合格的标准值。本考试是依照各个项目的合计进行判断的，前辈应该刚好过了合格线吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「勃起跳遠的紀錄遠遠超出了合格的標準值。本考試是依照各個項目的合計進行判斷的，前輩應該剛好過了合格線吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00585",
		linknext = "0055_00587",
		line = 7316,
	},
	["0055_00587"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00124", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0194", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Maybe so, but this man is impotent, and don't get me started on his sexual potential. If someone can't get an erection without assistance, what place do they have in the SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“确实是这样……但这个男人是阳痿，性能力本身就有问题。要让无法靠自己勃起的阳痿进入FS实在是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「確實是這樣……但這個男人是陽痿，性能力本身就有問題。要讓無法靠自己勃起的陽痿進入FS實在是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00586",
		linknext = "0055_00588",
		line = 7330,
	},
	["0055_00588"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00104", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0582", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei, that attitude of yours needs some adjustment. Surely you are aware of the anti-impotent discrimination issue?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“礼，请更正你的发言。性功能障碍者的歧视问题你也是知道的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「禮，請更正你的發言。性功能障礙者的歧視問題你也是知道的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00587",
		linknext = "0055_00589",
		line = 7344,
	},
	["0055_00589"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0195", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Please forgive my impudence...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……！真是失礼了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……！真是失禮了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00588",
		linknext = "0055_00590",
		line = 7358,
	},
	["0055_00590"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0896", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Anti-impotent dis-what now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“性功能障碍遮……七视……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「性功能障礙遮……七視……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00589",
		linknext = "0055_00591",
		line = 7372,
	},
	["0055_00591"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0196", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Anti-impotent discrimination. It's a hot-button issue these days. There are those who treat individuals like Tachibana here as lesser citizens, simply because they cannot have sex due to one reason or another.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“性功能障碍者……以像橘一样的阳痿为首，由于种种理由而不能做爱的人——对他们的歧视，最近成为了问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「性功能障礙者……以像橘一樣的陽痿為首，由於種種理由而不能做愛的人——對他們的歧視，最近成為了問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00590",
		linknext = "0055_00592",
		line = 7386,
	},
	["0055_00592"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On an island where sex is everything, I suppose it makes sense that some people would look down on those who can't have sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这里是做爱至上主义的青蓝岛——岛上的人瞧不起无法做爱的人是很正常的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這裡是做愛至上主義的青藍島——島上的人瞧不起無法做愛的人是很正常的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00591",
		linknext = "0055_00593",
		line = 7396,
	},
	["0055_00593"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0197", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Now that you mention it, I do remember the OSS sending out an edict. It said to be cautious to avoid inciting impotent people, so they don't stage any large-scale protests.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样说来，SHO也有传令……说要注意不要让性障碍者团体进行大规模抗议……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣說來，SHO也有傳令……說要注意不要讓性障礙者團體進行大規模抗議……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00592",
		linknext = "0055_00594",
		line = 7410,
	},
	["0055_00594"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0583", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And bearing that in mind, refusing this man's entry will do nothing but throw more fuel on the fire.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“在这种情况下，如果因为性障碍就拒绝前辈入队的话……会是火上加油吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「在這種情況下，如果因為性障礙就拒絕前輩入隊的話……會是火上加油吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00593",
		linknext = "0055_00595",
		line = 7424,
	},
	["0055_00595"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=-600, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0198", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yes, you make a strong point. Nevertheless, I still have my concerns... If we allow a man who cannot have sex into our ranks, would that not incite animosity in itself?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是，你说得对……但是，让这个男人加入的话……无法做爱的FS，这不会招来反感吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是，你說得對……但是，讓這個男人加入的話……無法做愛的FS，這不會招來反感嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00594",
		linknext = "0055_00596",
		line = 7439,
	},
	["0055_00596"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0584", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“How about this... I suggest we establish a quota for such people within the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“既然如此……就在FS中设置专门聘用这些人的‘位置’吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「既然如此……就在FS中設置專門聘用這些人的『保障名額』吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00595",
		linknext = "0055_00597",
		line = 7453,
	},
	["0055_00597"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00112", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0199", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Are you referring to what they call... affirmative action? You wish to set a quota for impotents in the SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那也就是说……制定平权法案吗？在FS里加入阳痿的位置……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
