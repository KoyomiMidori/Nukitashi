		linkback = "0055_00172",
		linknext = "0055_00174",
		line = 2188,
	},
	["0055_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿En presencia de las presidentas del comité de moral pública, el consejo estudiantil y Wata-chan?",
					{"rt2"},
				},
			},
			cn = {
				{
					"房间里不仅有风纪委员长和学生会长，还有渡酱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"房間裡不僅有風紀委員長和學生會長，還有渡醬。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00173",
		linknext = "0055_00175",
		line = 2198,
	},
	["0055_00175"] = {
		{"text"},
		text = {
