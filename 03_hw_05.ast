			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“It'll be fiiiiiine! I'm your senior, not to mention I'm friends with Rei. I also can't let anyone else go through what I did!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没关系的！我是前辈，和礼酱关系也很好……而且，我也绝对不希望再发生像之前那样的事情！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒關係的！我是前輩，和禮醬關係也很好……而且，我也絕對不希望再發生像之前那樣的事情！」",
					{"rt2"},
				},
			},
		},
