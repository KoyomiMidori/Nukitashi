		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0939", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, Tachibana-kun... Mira mis tetas. Es vergonzoso, y no tengo mucha confianza en mi cuerpo... Pero si te excita, me sentiré feliz.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……橘君……盯着胸在看……虽然没自信的我有点害羞……不过，如果能让你兴奋……我就开心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……橘君……盯著胸在看……雖然沒自信的我有點害羞……不過，如果能讓你興奮……我就開心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00368",
