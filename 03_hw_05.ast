		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="hcg01_00003", x=0, y=0, path=":cg/hcg01/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0913", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje, qué obediente. Sí, sí.. buen chico, buen chico.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵……终于老老实实地蹲下来了。好乖好乖……了不起了不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呵呵……終於老老實實地蹲下來了。好乖好乖……了不起了不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00644",
		linknext = "0055_00646",
		line = 8166,
	},
	["0055_00646"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me abraza con sus brazos delgados y me acaricia la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我被纤细的手臂抱住，还被抚摸着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我被纖細的手臂抱住，還被撫摸著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00645",
		linknext = "0055_00647",
		line = 8177,
	},
	["0055_00647"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Wata-chan...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……渡酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……渡醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00646",
		linknext = "0055_00648",
		line = 8188,
	},
	["0055_00648"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="hcg01_00001", x=0, y=0, path=":cg/hcg01/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0914", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sé que mañana será un día difícil para ti. Gracias por esforzarte tanto por nosotras.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君，明天开始一定会很辛苦吧……谢谢你，为了大家这么努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君，明天開始一定會很辛苦吧……謝謝你，為了大家這麼努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00647",
		linknext = "0055_00649",
		line = 8203,
	},
	["0055_00649"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su tono es relajante, casi maternal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那声音比平时更加温柔，更加包容一切。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那聲音比平時更加溫柔，更加包容一切。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00648",
		linknext = "0055_00650",
		line = 8213,
	},
	["0055_00650"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero aún no he hecho nada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么……我还没努力呢，现在才要开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼……我還沒努力呢，現在才要開始。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00649",
		linknext = "0055_00651",
		line = 8224,
	},
	["0055_00651"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0915", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, te estás esforzando mucho. Eres nuestro líder en la escuela y un hermano mayor responsable en casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，你努力了。在学校是大家的队长，在家里是可靠的哥哥呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，你努力了。在學校是大家的隊長，在家裡是可靠的哥哥呀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00650",
		linknext = "0055_00652",
		line = 8236,
	},
	["0055_00652"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="hcg01_00003", x=0, y=0, path=":cg/hcg01/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0916", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Solo recuerda que soy tu senpai y que puedes contar conmigo cuando lo necesites. Ven, ven... Eres muy responsable... Todo va a salir bien...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这种时候可以跟前辈撒娇哦……来，好乖好乖……橘君真是个努力的人啊……好乖好乖……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這種時候可以跟前輩撒嬌哦……來，好乖好乖……橘君真是個努力的人啊……好乖好乖……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00651",
		linknext = "0055_00653",
		line = 8251,
	},
	["0055_00653"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan tiene un olor extrañamente nostálgico.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱身上散发着令人怀念的味道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬身上散發著令人懷念的味道。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00652",
		linknext = "0055_00654",
		line = 8261,
	},
	["0055_00654"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es un aroma maravilloso—suave pero vibrante, como los pétalos de las flores de verano humedecidos por el rocío de la mañana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像早晨被水濡湿的夏之花所散发出的清新柔软且不可思议的香气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像早晨被水濡濕的夏之花所散發出的清新柔軟且不可思議的香氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00653",
		linknext = "0055_00655",
		line = 8271,
	},
	["0055_00655"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es como un olor que recuerdo de mi infancia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小时候我经常闻到这种味道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小時候我經常聞到這種味道。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00654",
		linknext = "0055_00656",
		line = 8281,
	},
	["0055_00656"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que siempre me burlo de ella por ser una loli plana, pero me siento extrañamente nostálgico mientras dejo que me acaricie la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明平时都戏弄她是萝莉、是飞机场——但现在心情却奇妙地充满了乡愁，被随心所欲地抚摸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明平時都戲弄她是蘿莉、是飛機場——但現在心情卻奇妙地充滿了鄉愁，被隨心所欲地撫摸。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00655",
		linknext = "0055_00657",
		line = 8291,
	},
	["0055_00657"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="hcg01_00001", x=0, y=0, path=":cg/hcg01/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0917", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sé que el entrenamiento de la SS será duro, pero no dudes en acudir a mí cuando sientas que te vas a romper. Siempre estaré ahí para darte cariño cuando lo necesites.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“FS的训练，想必会有很多辛苦……如果痛苦的话随时告诉我。我是橘君的同伴，随时都可以这样给你摸摸头哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「FS的訓練，想必會有很多辛苦……如果痛苦的話隨時告訴我。我是橘君的同伴，隨時都可以這樣給你摸摸頭哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00656",
		linknext = "0055_00658",
		line = 8306,
	},
	["0055_00658"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jaja... me siento tranquilo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈……真让人放心啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈……真讓人放心啊。」",
					{"rt2"},
				},
			},
