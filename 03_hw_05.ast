			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hrmph, no voy a rendirme. Me han hecho cosquillas muchas veces desde que era niña. ¡No es para tanto!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔……我不放弃。挠痒痒之类的从小时候开始就被弄过很多次了，根本没有问题！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔……我不放棄。撓痒癢之類的從小時候開始就被弄過很多次了，根本沒有問題！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00451",
		linknext = "0055_00453",
		line = 5618,
	},
	["0055_00453"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0220", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Muy bien. Como antes, tienes cinco minutos. Si no puedes soportarlo y te rindes, quedarás descalificada. Comencemos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……这样啊，我知道了。限制时间同样是5分钟。如果受不了投降的话就是不及格……那么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……這樣啊，我知道了。限制時間同樣是5分鐘。如果受不了投降的話就是不及格……那麼……」",
					{"rt2"},
				},
			},
		},
