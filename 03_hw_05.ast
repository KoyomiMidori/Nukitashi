		linkback = "0055_00123",
		linknext = "0055_00125",
		line = 1590,
	},
	["0055_00125"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Alguien interrumpe nuestra conversación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"瞬间——我有种风纪委员室的空气被奇妙地曲折了的错觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"瞬間——我有種風紀委員室的空氣被奇妙地曲折了的錯覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00124",
		linknext = "0055_00126",
		line = 1602,
	},
	["0055_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Reizeiin Touka, la presidenta del comité de moral pública, entra en la escena.",
					{"rt2"},
				},
			},
			cn = {
				{
					"进来的是——学生会长，冷泉院桐香。",
					{"rt2"},
				},
			},
			tw = {
				{
					"進來的是——學生會長，冷泉院桐香。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00125",
		linknext = "0055_00127",
		line = 1612,
	},
	["0055_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta es la mujer que ascendió rápidamente en las filas de la SS, convirtiéndose en su líder en menos de un año.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是1年级，却站在FS顶端的女人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是1年級，卻站在FS頂端的女人。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00126",
		linknext = "0055_00128",
		line = 1622,
	},
	["0055_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca la había visto de cerca. Su energía es abrumadora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是第一次这么近距离看她——她身上有着令人不由自主地屏住呼吸的不可思议气场。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是第一次這麼近距離看她——她身上有著令人不由自主地屏住呼吸的不可思議氣場。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00127",
		linknext = "0055_00129",
		line = 1632,
	},
	["0055_00129"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0566", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Perdóname, no sabía que tenías visitas. ¡Pero qué sorpresa! Jeje.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“真是失礼了，没想到有客人。呵呵，还真是稀奇呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「真是失禮了，沒想到有客人。呵呵，還真是稀奇呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00128",
		linknext = "0055_00130",
		line = 1646,
	},
	["0055_00130"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0171", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Touka-sama... No se preocupe. Pase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“桐香大人……不，不用在意他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
