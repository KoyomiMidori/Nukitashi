	},
	["0055_00017"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1851", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It, uhh... It's like when you see two things happen and you feel like there's gotta be some connection, even if there's nothing there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“后此谬误……就是马上把连续发生的两件事，作为原因和结果联系起来……大概是这种感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「後此謬誤……就是馬上把連續發生的兩件事，作為原因和結果聯繫起來……大概是這種感覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00016",
		linknext = "0055_00018",
		line = 230,
	},
	["0055_00018"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0870", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So like, if it turned out that a bunch of people with big boobs suddenly died of a cold, then everyone'd think it's the boobs' fault? They'd be all, 'Down with big badonkers! Exterminate the dobonhonkeros!' You think we could make that happen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃，如果有人看到巨乳后突然感冒死掉的话，感冒的原因就是巨乳！巨乳不好！铲除巨乳！是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃，如果有人看到巨乳後突然感冒死掉的話，感冒的原因就是巨乳！巨乳不好！剷除巨乳！是這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00017",
		linknext = "0055_00019",
		line = 244,
	},
	["0055_00019"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00105", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1049", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pretty wild imagination you've got there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“渡酱好像说出了不得了的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「渡醬好像說出了不得了的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00018",
		linknext = "0055_00020",
		line = 257,
	},
	["0055_00020"] = {
		{"fg", file="hinami_01m_00001", file3="hinami_01m_00302", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0871", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That means... I can make everyone finally realize that those honkers are nothing more than fleshy sacs of pure evil that must be purged! It's time for a cleansing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我想到一件很厉害的事情哦！只要用这招，大家就会发现巨乳不好，就能打败巨乳了！打败巨乳吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我想到一件很厲害的事情哦！只要用這招，大家就會發現巨乳不好，就能打敗巨乳了！打敗巨乳吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00019",
		linknext = "0055_00021",
		line = 271,
	},
	["0055_00021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't think there'd be anyone left on the island, then...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果在这个岛上做了那种事，活下来的大概就只剩渡酱吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果在這個島上做了那種事，活下來的大概就只剩渡醬吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00020",
		linknext = "0055_00022",
		line = 283,
	},
	["0055_00022"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"ex", time=700, func="wait"},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1852", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The media's always pulling this kinda shit, making up a public stance so they can sway people to their side. You gotta be able to pick up on it or you'll always be falling for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是，实际上经常会有不好的媒体为了捏造对自己有利的情报而使用这个谬误……如果作为着眼点来看，在某种意义上是没有错的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是，實際上經常會有不好的媒體為了捏造對自己有利的情報而使用這個謬誤……如果作為著眼點來看，在某種意義上是沒有錯的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00021",
		linknext = "0055_00023",
		line = 301,
	},
	["0055_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“True. Wata, you gotta be wary of believing everything the media tells you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……渡酱，请小心不要被媒体的信息战欺骗了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……渡醬，請小心不要被媒體的資訊戰欺騙了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00022",
		linknext = "0055_00024",
		line = 313,
	},
	["0055_00024"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0872", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahaha, don't you worry. I'm the elder here, remember? I'm not gonna get tricked so easily!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈，不用担心。我比大家都年长哦？没那么容易被骗的啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈，不用擔心。我比大家都年長哦？沒那麼容易被騙的啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00023",
		linknext = "0055_00025",
		line = 327,
	},
	["0055_00025"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1050", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“For me, I started getting bigger in the chest when I started pwning a bunch of foreign noobs in my FPS games.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我的胸是从在FPS游戏中不停地怼不会玩游戏的外国人才开始变大的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我的胸是從在FPS遊戲中不停地懟不會玩遊戲的外國人才開始變大的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00024",
		linknext = "0055_00026",
		line = 340,
	},
	["0055_00026"] = {
		{"fg", file="hinami_02m_00001", file3="hinami_02m_00302", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0873", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well, I'm gonna get on those eff-pee-ess games and start pawning those damn foreign newbs too!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“今后我要每天在FPS游戏里怼不会玩游戏的外国人！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「今後我要每天在FPS遊戲裡懟不會玩遊戲的外國人！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00025",
		linknext = "0055_00027",
		line = 354,
	},
	["0055_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So much for 'I'm not gonna get tricked so easily,' huh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不能滥用刚学会的知识去玩弄渡酱哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不能濫用剛學會的知識去玩弄渡醬哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00026",
		linknext = "0055_00028",
		line = 366,
	},
	["0055_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, what were we talking about again?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……刚才说到哪里了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……剛才說到哪裡了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00027",
		linknext = "0055_00029",
		line = 378,
	},
	["0055_00029"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1853", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Easily distracted much... We're supposed to be talking about how the issues with public order and our failure to find this Fumino girl are related or not.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“总是马上就聊歪掉……说到治安的恶化和‘文乃’的问题要联系起来可能有点勉强。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「總是馬上就聊歪掉……說到治安的惡化和『文乃』的問題要聯繫起來可能有點勉強。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00028",
		linknext = "0055_00030",
		line = 392,
	},
	["0055_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，说得对……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，說得對……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00029",
		linknext = "0055_00031",
		line = 404,
	},
	["0055_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase might have a point.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，也许正如奈奈濑所说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，也許正如奈奈瀨所說。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00030",
		linknext = "0055_00032",
		line = 414,
	},
	["0055_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I might just be trying to draw lines between two points where no real connection exists.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的道理，只是把知道的东西硬联系在一起而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的道理，只是把知道的東西硬聯繫在一起而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00031",
		linknext = "0055_00033",
		line = 424,
	},
	["0055_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And assuming we'll get a lead on Fumino's location by shifting our attention to the public order problem is... a spotty idea at best.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把目光转向治安问题，想藉此得到文乃的线索——老实说确实很不合理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把目光轉向治安問題，想藉此得到文乃的線索——老實說確實很不合理。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00032",
		linknext = "0055_00034",
		line = 434,
	},
	["0055_00034"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still... I can't let this slide.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，我……即使这样，我也无法忽视现在的状况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，我……即使這樣，我也無法忽視現在的狀況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00033",
		linknext = "0055_00035",
		line = 446,
	},
	["0055_00035"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the sex seekers of age in this island do whatever they want.",
					{"rt2"},
				},
			},
			cn = {
				{
					"成为性人的岛民们都在各自热闹着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"成為性人的島民們都在各自熱鬧著。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00034",
		linknext = "0055_00036",
		line = 462,
	},
	["0055_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It is the very thing I'm fighting against, and I still wish to change it. Still, as imperfect as it is, I agree that the law has its reasons.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这当然也是需要被矫正的状况，但最起码他们都有取得彼此的同意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這當然也是需要被矯正的狀況，但最起碼他們都有取得彼此的同意。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00035",
		linknext = "0055_00037",
		line = 472,
	},
	["0055_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But it's a whole different thing if children become endangered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但对象如果是小孩子，那就另当别论了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但對象如果是小孩子，那就另當別論了。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00036",
		linknext = "0055_00038",
		line = 482,
	},
	["0055_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Forcing sex onto someone without their consent... last I checked, that's called rape, and it's just another form of violent assault.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有取得共识的性爱——就和暴力一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有取得共識的性愛——就和暴力一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00037",
		linknext = "0055_00039",
		line = 493,
	},
	["0055_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can't sit on my ass and do nothing about this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我无法在知道发生了这种事后，还置之不理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我無法在知道發生了這種事後，還置之不理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00038",
		linknext = "0055_00040",
		line = 504,
	},
	["0055_00040"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1854", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I was expecting you to say something like that. To be honest, I don't think it's good to pretend nothing's happening when something's bad... Even though it's kind of breaking the rules.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……嗯，你就是这种人吧。老实说，我也不愿意对坏事视而不见……虽然我自己也违反条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……嗯，你就是這種人吧。老實說，我也不願意對壞事視而不見……雖然我自己也違反條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00039",
		linknext = "0055_00041",
		line = 518,
	},
	["0055_00041"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0385", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Isn't that the SS and OSS's job?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是但是……那些事情不是FS和SHO的工作吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是但是……那些事情不是FS和SHO的工作嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00040",
		linknext = "0055_00042",
		line = 532,
	},
	["0055_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It should be, but it looks like they can't handle it themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“本来应该是如此，但事实上他们无法做到完全管控。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「本來應該是如此，但事實上他們無法做到完全管控。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00041",
		linknext = "0055_00043",
		line = 543,
	},
	["0055_00043"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0874", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“A few days ago, Rei actually mentioned that the SS is understaffed. Apparently they're going to do a big recruiting push.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那个……礼酱说他们人手不足。所以，听说要增加FS的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那個……禮醬說他們人手不足。所以，聽說要增加FS的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00042",
		linknext = "0055_00044",
		line = 557,
	},
	["0055_00044"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that so? That's trouble for us too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……真麻烦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……真麻煩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00043",
		linknext = "0055_00045",
		line = 569,
	},
	["0055_00045"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like we wouldn't have already had our hands full with looking for Fumino and dealing with this public order issue, but we're gonna have more enemies to watch out for, too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“寻找‘文乃’，还要对治安问题进行调查，在这种时候敌人还增员……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「尋找『文乃』，還要對治安問題進行調查，在這種時候敵人還增員……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00044",
		linknext = "0055_00046",
		line = 582,
	},
	["0055_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I thought about that, though, a realization struck me that almost left me speechless.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这时——我脑中浮现出了我自己也会惊讶的点子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這時——我腦中浮現出了我自己也會驚訝的點子。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00045",
		linknext = "0055_00047",
		line = 592,
	},
	["0055_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The SS is a branch of the OSS, so their work is keeping public order, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS是SHO的底层组织……当然，维持治安也是他们的工作……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS是SHO的底層組織……當然，維持治安也是他們的工作……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00046",
		linknext = "0055_00048",
		line = 604,
	},
	["0055_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So the SS probably has more info on what's happening here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，FS内部有关于治安问题的资料——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，FS內部有關於治安問題的資料——」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00047",
