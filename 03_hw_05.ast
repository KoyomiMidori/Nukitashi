			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, ¿s-solo quedan 30 segundos?! Tachibana-kun, ¿qué hacemos? ¿Podrás hacerlo a tiempo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哇哇，30秒！怎、怎么办？橘君，怎么样？射射能赶上吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哇哇，30秒！怎、怎麼辦？橘君，怎麼樣？射射能趕上嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00413",
		linknext = "0055_00415",
		line = 5082,
	},
	["0055_00415"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, ugh... L-Lo intentaré.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊、唔……我、我会加油的……”",
					{"rt2"},
				},
			},
			tw = {
