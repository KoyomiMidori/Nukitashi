			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, fue mi decisión. Yo debería pedirte perdón... No pude ayudarte... Soy una senpai inútil.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，这是我想做的。但是……结果没能帮上忙，对不起……我真是没用，没资格当前辈啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，這是我想做的。但是……結果沒能幫上忙，對不起……我真是沒用，沒資格當前輩啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00622",
		linknext = "0055_00624",
		line = 7854,
	},
	["0055_00624"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Inútil... Eso no es verdad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“才没有那种事呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「才沒有那種事呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00623",
		linknext = "0055_00625",
		line = 7866,
	},
	["0055_00625"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se lo digo, pero no puedo decirle mucho más.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算我试着这样说，渡酱还是十分沮丧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算我試著這樣說，渡醬還是十分沮喪。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00624",
		linknext = "0055_00626",
		line = 7876,
	},
	["0055_00626"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La verdad, creo que es mejor que no haya podido unirse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对我来说，不如说渡酱没有加入真是太好了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"對我來說，不如說渡醬沒有加入真是太好了——",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00625",
		linknext = "0055_00627",
		line = 7886,
	},
	["0055_00627"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Siendo así, ¿podrías cuidar a Asa-chan de ahora en adelante?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……既然这样。渡酱前辈，可以从明天开始替我照顾好麻沙酱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……既然這樣。渡醬前輩，可以從明天開始替我照顧好麻沙醬嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00626",
		linknext = "0055_00628",
		line = 7898,
	},
	["0055_00628"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0906", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? ¿A Asane-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……麻沙音酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……麻沙音醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00627",
		linknext = "0055_00629",
		line = 7912,
	},
	["0055_00629"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Como aprendiz de la SS, habrá ocasiones en las que no pueda cuidar de ella. ¿Te gustaría cuidarla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。既然我成为了FS的训练生，就可能有照顾不到她的部分出现……可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。既然我成為了FS的訓練生，就可能有照顧不到她的部分出現……可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00628",
		linknext = "0055_00630",
		line = 7923,
	},
	["0055_00630"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[500] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0907", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Sip, tu senpai se hará cargo! Jeje... qué hermano tan cariñoso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……嗯，交给前辈吧！呵呵……橘君真的是非常温柔的哥哥呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……嗯，交給前輩吧！呵呵……橘君真的是非常溫柔的哥哥呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00629",
		linknext = "0055_00631",
		line = 7938,
	},
	["0055_00631"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, tú eres la lo— la hermana mayor cariñosa al hacer esto por mí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不不，能答应我这样的请求，渡酱才是个温柔的萝……姐姐呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不不，能答應我這樣的請求，渡醬才是個溫柔的蘿……姐姐呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00630",
		linknext = "0055_00632",
		line = 7950,
	},
	["0055_00632"] = {
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00124", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0908", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje, si tú lo dices... ¿Mmm? ¿Por qué ibas a decir algo que empezaba con 'lo'?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿，是吗……嗯？刚才你说‘萝’了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿，是嗎……嗯？剛才你說『蘿』了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00631",
		linknext = "0055_00633",
		line = 7964,
	},
	["0055_00633"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Te lo habrás imaginado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你想太多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你想太多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00632",
		linknext = "0055_00634",
		line = 7976,
	},
	["0055_00634"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0909", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Me lo imaginé? Si tú lo dices...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是心理作用吗……是吗……可能是吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是心理作用嗎……是嗎……可能是吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00633",
		linknext = "0055_00635",
		line = 7990,
	},
	["0055_00635"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin, a partir de mañana me infiltraré en la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管怎样——从明天开始，FS潜入作战就要开始了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管怎樣——從明天開始，FS潛入作戰就要開始了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00634",
		linknext = "0055_00636",
		line = 8002,
	},
	["0055_00636"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si todo sale según lo previsto, puedo investigar ese problema de orden público.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“潜入内部后，首先要调查一下岛上的治安问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「潛入內部後，首先要調查一下島上的治安問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00635",
		linknext = "0055_00637",
		line = 8013,
	},
	["0055_00637"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0910", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí... No podemos quedarnos de brazos cruzados cuando chicas como Yuki-chan pueden estar en peligro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是啊……如果有希这样的孩子遇到危险，实在是让人放不下心啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是啊……如果有希這樣的孩子遇到危險，實在是讓人放不下心啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00636",
		linknext = "0055_00638",
		line = 8027,
	},
	["0055_00638"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así es, y si logro conseguir información sobre Fumino, mataré dos pájaros de un tiro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对。然后只要顺势得到有关‘文乃’的情报，我们的目的也就能达成了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對。然後只要順勢得到有關『文乃』的情報，我們的目的也就能達成了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00637",
		linknext = "0055_00639",
		line = 8038,
	},
	["0055_00639"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tengo que darlo todo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“终于要努力了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「終於要努力了呢。」",
