		line = 1381,
	},
	["0055_00108"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0166", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You should know that SS members have to undergo an incredibly intense training regimen. You should have more fun with your last year here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……不过，FS的训练很辛苦哦？这已经是你学校生活的最后一年了不是吗？应该抓紧时间创造些更快乐的回忆啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……不過，FS的訓練很辛苦哦？這已經是你學校生活的最後一年了不是嗎？應該抓緊時間創造些更快樂的回憶啊。」",
					{"rt2"},
				},
			},
		},
