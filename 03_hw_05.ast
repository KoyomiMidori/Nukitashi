					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I have to object, they look really feeble. They're far from adequate to become SS members!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是桐香大人，他们看上去就很弱……我不觉得是适合FS的人才……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是桐香大人，他們看上去就很弱……我不覺得是適合FS的人才……！」",
					{"rt2"},
