					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Sí, señora!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是的！”",
