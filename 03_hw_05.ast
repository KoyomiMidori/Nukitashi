			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Agh... Las cosas se han puesto feas por aquí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊呜呜……总觉得最近哪里都很可怕啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊嗚嗚……總覺得最近哪裡都很可怕啊……」",
