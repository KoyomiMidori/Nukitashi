	["0055_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Reizeiin Touka, the president of the disciplinary committee, enters the room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"进来的是——学生会长，冷泉院桐香。",
