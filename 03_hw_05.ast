		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So yeah. It looks like there's been an outbreak of sex crimes against minors going on lately.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——所以说，最近好像有诱拐小孩的事件。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——所以說，最近好像有誘拐小孩的事件。」",
					{"rt2"},
				},
			},
		},
		linknext = "0055_00002",
		line = 23,
	},
	["0055_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The next week, we had a meeting at lunch to tell them about what had happened.",
					{"rt2"},
				},
			},
			cn = {
				{
					"周一的午休，跟聚集在一起的成员说了前几天发生的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"週一的午休，跟聚集在一起的成員說了前幾天發生的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00001",
		linknext = "0055_00003",
		line = 33,
	},
	["0055_00003"] = {
