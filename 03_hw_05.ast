		linkback = "0055_00606",
		linknext = "0055_00608",
		line = 7633,
	},
	["0055_00608"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso, está haciendo que las cosas sean increíblemente incómodas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"气氛尴尬的要死。",
					{"rt2"},
				},
			},
			tw = {
				{
					"氣氛尷尬的要死。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00607",
		linknext = "0055_00609",
		line = 7643,
	},
	["0055_00609"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De alguna manera, solo ahora lo pienso y me doy cuenta de la locura que hice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事到如今——真的是事到如今，但冷静下来想想，我真的做了很不得了的事情啊……",
					{"rt2"},
				},
			},
			tw = {
				{
					"事到如今——真的是事到如今，但冷靜下來想想，我真的做了很不得了的事情啊……",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00608",
		linknext = "0055_00610",
		line = 7653,
	},
	["0055_00610"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00111", file2="hinami_02m_00204", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0899", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“T-Tachibana-kun... ¿Podrías... no contarle a nadie lo que pasó hoy...? Lo de la... orina, y todo lo que hicimos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘、橘君……如果可以的话，希望能对大家保密……那个……我尿出来的、事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘、橘君……如果可以的話，希望能對大家保密……那個……我尿出來的、事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00609",
		linknext = "0055_00611",
		line = 7667,
	},
	["0055_00611"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“J-Jamás hablaré de eso. No digamos nada sobre el examen de ingreso... sí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不会说的……入队考试的事情全都保密吧……我们彼此。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不會說的……入隊考試的事情全都保密吧……我們彼此。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00610",
		linknext = "0055_00612",
		line = 7679,
	},
	["0055_00612"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00204", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6300] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00119", file2="hinami_02m_00204", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=6300, time=300, mode=3, x=0, y=0},
			},
			[8500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00204", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0900", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿S-Sí? Sí, tienes razón... ¡Olvidemos por completo el día de hoy! Olvídalo... olvídalo... ¡vale, ya lo olvidé!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这、这样啊……嗯，说得也是……这样的话，今天的事就忘掉吧！忘掉——忘掉——好，忘掉了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這、這樣啊……嗯，說得也是……這樣的話，今天的事就忘掉吧！忘掉——忘掉——好，忘掉了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00611",
		linknext = "0055_00613",
		line = 7697,
	},
	["0055_00613"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", file2="hinami_02m_00204", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0211", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Mujer A"},
					"“¡No, no lo hagas, noooo! Si sigues estimulando mi clítoris así, ¡voy a orinarmeeee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "A女"},
					"“讨厌，不行、不行啦……！一直被那样玩弄阴蒂的话……要尿出来了～～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "A女"},
					"「討厭，不行、不行啦……！一直被那樣玩弄陰蒂的話……要尿出來了～～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00612",
		linknext = "0055_00614",
		line = 7712,
	},
	["0055_00614"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", file2="hinami_01m_00204", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=100, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
