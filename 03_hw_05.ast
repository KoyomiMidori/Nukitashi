	["0055_00105"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00124", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=-400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cada puño hace que Rei se sienta más y más angustiada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长终于开始一脸困扰地盯着猫拳头。",
