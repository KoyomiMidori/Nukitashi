		line = 7004,
	},
	["0055_00563"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se queda inmóvil y ya no responde cuando le hago cosquillas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱瘫倒在那里——即使轻轻搔痒，也没有反应。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬癱倒在那裡——即使輕輕搔癢，也沒有反應。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00562",
