				{"vo", file="hinami0869", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Fumino? Why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦……文乃酱？为什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦……文乃醬？為什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00010",
		linknext = "0055_00012",
		line = 150,
	},
	["0055_00012"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If the island's descending into this kind of situation, then maybe she would have gotten into a similar situation herself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“假如岛的治安状况真的恶化了，‘文乃’也可能会是其中一个受害者，被囚禁在某个地方——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「假如島的治安狀況真的惡化了，『文乃』也可能會是其中一個受害者，被囚禁在某個地方——」",
					{"rt2"},
