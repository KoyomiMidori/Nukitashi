		{"fg", file="asane_02m_00007", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1217", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Huuh!? Y-You unplugged the ethernet cable! What if they shadowban my account for DC'ing!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊！？干、干什么啊都断线了啊要是被封号了怎么办……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊！？幹、幹什麼啊都斷線了啊要是被封號了怎麼辦……！！」",
					{"rt2"},
				},
			},
		},
