	["0077_00463"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it's just... you're up awfully early, aren't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，因为……最近这段时间你不是都在睡觉吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，因為……最近這段時間你不是都在睡覺嗎……？」",
