					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Trust me, this is for your own good.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原谅我吧……这也是为了拯救麻沙酱的生命啊……！”",
