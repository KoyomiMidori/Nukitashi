					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔……那就用這個……啊，你這個……等等，你等一下……拋投也太狡猾了！抓住也太狡猾！」",
					{"rt2"},
				},
			},
