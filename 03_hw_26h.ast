			},
			cn = {
				{
					name = {"礼"},
					"“这、这次真的是……只有这一次哦！！你的恋人可是雏见！如果和我外遇我可不会原谅你的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這、這次真的是……只有這一次哦！！你的戀人可是雛見！如果和我外遇我可不會原諒你的！！」",
