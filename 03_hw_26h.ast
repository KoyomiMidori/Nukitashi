	["0077_00461"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00103", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1212", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Excuuuse me? Is that any way to greet cute little sister? You got a problem with me being here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊？怎么对着可爱的妹妹做出那种反应……我在家里不好吗……？”",
