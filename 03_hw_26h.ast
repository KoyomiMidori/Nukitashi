			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Typical lolicon bullshit. I swear to God, I'm gonna have you switch over to Nanase-san one of these days.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“说些莫名其妙的话……切，所以我才说萝莉控……我现在马上就让奈奈濑同学转行来代替她……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「說些莫名其妙的話……嘖，所以我才說蘿莉控……我現在馬上就讓奈奈瀨同學轉行來代替她……！」",
