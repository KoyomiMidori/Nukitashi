				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't see how anyone would see that as pleasurable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但做那种事是不可能让她打从心底觉得舒服的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但做那種事是不可能讓她打從心底覺得舒服的。",
