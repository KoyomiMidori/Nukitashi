		line = 672,
	},
	["0077_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The NLNS founding principle was that sex was only for those who are in love. We rejected this kind of immoral sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们一直在主张性爱是与心爱的人进行的行为，否定无秩序的性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們一直在主張性愛是與心愛的人進行的行為，否定無秩序的性。",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00052",
		linknext = "0077_00054",
		line = 682,
	},
	["0077_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was how we were able to get the perverted sex law abolished, after struggling for so long.",
					{"rt2"},
				},
			},
			cn = {
				{
					"并且在奋斗后，成功破坏了变态条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"並且在奮鬥後，成功破壞了變態條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00053",
		linknext = "0077_00055",
		line = 692,
	},
	["0077_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wouldn't it go against those core values to have sex with a woman who isn't my girlfriend?",
					{"rt2"},
				},
			},
			cn = {
				{
					"干了这些事的我，还和不是女朋友的人做爱——这不是很奇怪吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"幹了這些事的我，還和不是女朋友的人做愛——這不是很奇怪嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00054",
		linknext = "0077_00056",
		line = 702,
	},
