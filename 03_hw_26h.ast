		line = 436,
	},
	["0077_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's always had to sell her body to survive and protect her family.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈一直都是为了生存——为了家人而献身。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩一直都是為了生存——為了家人而獻身。",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00032",
		linknext = "0077_00034",
		line = 446,
	},
	["0077_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's had to do it over and over again, no matter how much she hated it or how much it hurt.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算经历过无数次的委屈，最终还是未能习惯，她也因此感到苦恼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算經歷過無數次的委屈，最終還是未能習慣，她也因此感到苦惱。",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00033",
		linknext = "0077_00035",
		line = 456,
	},
	["0077_00035"] = {
		{"text"},
		text = {
