				},
			},
			cn = {
				{
					"今天好像是礼前辈久违的休息日，所以她和雏见一起来我家玩对战游戏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天好像是禮前輩久違的休息日，所以她和雛見一起來我家玩對戰遊戲。",
