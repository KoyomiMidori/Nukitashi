		linkback = "0077_00462",
		linknext = "0077_00464",
		line = 5931,
	},
	["0077_00464"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00106", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1213", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Normally, yeah. But I had the craziest dream. There was this wild three-way... you were there... I was just about to join, but then I woke up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是啊……不过我做了个超级色情的3P梦……虽然我不记得了，但好像哥哥也在那里……我也想加入的时候，就醒了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是啊……不過我做了個超級色情的3P夢……雖然我不記得了，但好像哥哥也在那裡……我也想加入的時候，就醒了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00463",
		linknext = "0077_00465",
		line = 5945,
	},
	["0077_00465"] = {
