				{
					name = {"ヒナミ", "Hinami"},
					"“So I want Jun-kun to show her what it means for sex to feel good.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“所以，我希望淳君能让她舒服。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「所以，我希望淳君能讓她舒服。」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00036",
		linknext = "0077_00038",
		line = 490,
	},
	["0077_00038"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How did you come to that conclusion?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么你会得出这个结论……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼你會得出這個結論……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00037",
		linknext = "0077_00039",
		line = 502,
	},
	["0077_00039"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Listen, Hinami. I'm sure you already know this, but I'll only do that with someone I love. That was the entire founding principle of the NLNS, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“听好了，雏见……你知道的吧？我只跟喜欢的人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「聽好了，雛見……你知道的吧？我只跟喜歡的人——」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00038",
		linknext = "0077_00040",
		line = 514,
	},
	["0077_00040"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1880", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jun-kun, do you hate Rei-chan...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“淳君……讨厌礼酱吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「淳君……討厭禮醬嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00039",
		linknext = "0077_00041",
		line = 528,
	},
	["0077_00041"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00040",
		linknext = "0077_00042",
		line = 540,
	},
	["0077_00042"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now, hold up. That's not really the same thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——等一下……这个和那个是不一样的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——等一下……這個和那個是不一樣的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00041",
		linknext = "0077_00043",
		line = 552,
	},
	["0077_00043"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1881", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You know Rei-chan loves you, Jun-kun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是礼酱……喜欢淳君哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是禮醬……喜歡淳君哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00042",
		linknext = "0077_00044",
		line = 566,
	},
	["0077_00044"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, she told me. But wouldn't you hate it? I'd be doing it with another woman.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这……好像没错……不过……雏见也不愿意吧？不愿意我和其他女人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這……好像沒錯……不過……雛見也不願意吧？不願意我和其他女人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00043",
		linknext = "0077_00045",
		line = 578,
	},
	["0077_00045"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1882", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“If it were just any other woman, then yeah, I'd hate it. But if it's Rei-chan... I don't think I'd mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“要是是其他人的话我不愿意……但是，礼酱的话没关系……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「要是是其他人的話我不願意……但是，禮醬的話沒關係……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00044",
		linknext = "0077_00046",
		line = 590,
	},
	["0077_00046"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1883", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“All this time, Rei-chan's been striving so hard all be herself, sacrificing herself for the sake of others. Not only that, but she always protected me, all so I could have the wonderful romance that she never could.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱一直以来都是一个人在努力，为了某人而牺牲自己……一直在守护我，希望我能谈一场美好的恋爱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬一直以來都是一個人在努力，為了某人而犧牲自己……一直在守護我，希望我能談一場美好的戀愛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00045",
		linknext = "0077_00047",
		line = 602,
	},
	["0077_00047"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00108", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1884", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“And yet, after all that... for Rei-chan, sex just brings up unpleasant memories. That's terrible...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是……礼酱自己的做爱回忆却都是痛苦的……这样不行……太不公平了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是……禮醬自己的做愛回憶卻都是痛苦的……這樣不行……太不公平了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00046",
		linknext = "0077_00048",
		line = 616,
	},
	["0077_00048"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hinami...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“雏见……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雛見……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00047",
		linknext = "0077_00049",
		line = 628,
	},
	["0077_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I understand what she's saying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明白她的意思。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明白她的意思。",
