		linkback = "0077_00048",
		linknext = "0077_00050",
		line = 638,
	},
	["0077_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's the type who wants to help when she sees someone suffering. She can't just sit idly by.",
					{"rt2"},
				},
			},
			cn = {
				{
					"重要的人如果感到痛苦，就要伸出援手。会忍不住想去帮忙——雏见就是这样的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"重要的人如果感到痛苦，就要伸出援手。會忍不住想去幫忙——雛見就是這樣的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00049",
		linknext = "0077_00051",
		line = 648,
	},
	["0077_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's got a bigger heart than anyone else. Hell, that's why I fell for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她比谁都温柔——所以我才喜欢上了她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她比誰都溫柔——所以我才喜歡上了她。",
					{"rt2"},
				},
			},
