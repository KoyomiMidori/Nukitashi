		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But... still!",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是……可是。",
