		{"bg", id=1, file="bg11_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, mode=3, x=0, y=0},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_009_00000"},
		{"fgact", ch="手嶋", id=9, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0268", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ya used ta live 'ere when you was just a sprout, right? Somethin' happen to ya then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“听说你小时候有住过这个岛啊？那个时候发生了什么是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「聽說你小時候有住過這個島啊？那個時候發生了什麼是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00317",
		linknext = "0109_00319",
		line = 4383,
	},
	["0109_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I speak, he'll be leading me on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一说话，就会被这个男人牵着鼻子走。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一說話，就會被這個男人牽著鼻子走。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00318",
		linknext = "0109_00320",
		line = 4393,
	},
	["0109_00320"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What I need right now is to buy time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在的我需要做的，是争取时间——",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在的我需要做的，是爭取時間——",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00319",
		linknext = "0109_00321",
		line = 4403,
	},
	["0109_00321"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0269", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Silent treatment, eh? I'll answer for ya, then. Tachibana, wasn't there some broad you knew who snuffed it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你不打算回答吗？那我来替你回答……橘，听说你认识的一个女人死了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你不打算回答嗎？那我來替你回答……橘，聽說你認識的一個女人死了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00320",
		linknext = "0109_00322",
		line = 4415,
	},
	["0109_00322"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a105"},
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
