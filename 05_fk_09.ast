	["0109_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I decided to pop into the base for the first time in a while, but as I enter, I hear some sort of noise going off, like I walked through a metal detector with loose change on me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很久没回去的旧巢，一回来马上就响起了拒绝迎接的效果音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"很久沒回去的舊巢，一回來馬上就響起了拒絕迎接的效果音。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00081",
		linknext = "0109_00083",
		line = 1077,
	},
	["0109_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a sensor positioned immediately outside the elevator in the base.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个基地，在穿过电梯的地方设置了传感器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個基地，在穿過電梯的地方設置了傳感器。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00082",
		linknext = "0109_00084",
		line = 1087,
	},
	["0109_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If any unusual radio waves are being transmitted by the individual, it will set off an alarm.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当身上有发出可疑电波的东西时，就会发出警示音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當身上有發出可疑電波的東西時，就會發出警示音。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00083",
		linknext = "0109_00085",
		line = 1097,
	},
	["0109_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yo, Asa? The sensor on the elevator's bugging out, and I don't know why. Is it a malfunction with my tablet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂麻沙酱，不知道为什么感应器有反应了，是平板引起的故障吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂麻沙醬，不知道為什麼感應器有反應了，是平板引起的故障嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00084",
		linknext = "0109_00086",
		line = 1109,
	},
	["0109_00086"] = {
