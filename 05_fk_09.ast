		},
		linkback = "0109_00110",
		linknext = "0109_00112",
		line = 1448,
	},
	["0109_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. The SS... no, the OSS, know about her and are searching for her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错。SS——不，SHO掌握了‘文乃’的信息，正在搜索。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯。SS——不，SHO掌握了『文乃』的資訊，正在搜索。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00111",
		linknext = "0109_00113",
		line = 1460,
	},
	["0109_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They also claim that her existence is somehow connected with the illegal sex industry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且，她的存在也和地下风俗有关。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且，她的存在也和地下風俗有關。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00112",
		linknext = "0109_00114",
		line = 1471,
	},
	["0109_00114"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
