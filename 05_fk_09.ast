	["0109_00350"] = {
		{"bgm", file="bgm21", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0280", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“C'mon, it's real simple, Tachibana. Come over to the dark side.”",
					{"rt2"},
