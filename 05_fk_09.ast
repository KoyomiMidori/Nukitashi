	["0109_00399"] = {
		{"bg", id=1, file="bg11_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00109", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="手嶋", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"fgact", ch="手嶋", id=9, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0296", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“The fuck!? Special combat force!? I thought I brainwashed you assholes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“这些家伙是——特种战斗部的特攻部队！？我应该全都洗脑了啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「這些傢伙是——特種戰鬥部的特攻部隊！？我應該全都洗腦了啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00398",
		linknext = "0109_00400",
		line = 5491,
	},
	["0109_00400"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=11, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="仁浦", id=11, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0168", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I had it undone. It took a great deal of money, though. All your men upstairs are restrained as well. Give it up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我已经解除了。虽然花了很多钱——上面那些人也都被压制住了，你可以放弃了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我已經解除了。雖然花了很多錢——上面那些人也都被壓制住了，你可以放棄了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00399",
		linknext = "0109_00401",
		line = 5505,
	},
	["0109_00401"] = {
		{"fgact", id=9, ch="手嶋", act="stopact"},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00119", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="手嶋", id=9, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0297", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Don't you fuckin' get it!? If this shit goes public, yer gonna suffer the most! People're forever gonna think this island's a bastion of crime!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你懂自己在干嘛吗！？这事要是暴露了，最受伤的可是你啊！因为是你让这个岛成为犯罪的温床！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你懂自己在幹嘛嗎！？這事要是暴露了，最受傷的可是你啊！因為是你讓這個島成為犯罪的溫床！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00400",
		linknext = "0109_00402",
		line = 5520,
	},
	["0109_00402"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0298", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“An' when they learn just how deep things've spread, it's gonna be yer bonce in the pillory! You fine with that, you fuck!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你一直以来累积起来的东西会受到很大的打击哦！？这样也没关系吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你一直以來累積起來的東西會受到很大的打擊哦！？這樣也沒關係嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00401",
		linknext = "0109_00403",
		line = 5532,
	},
	["0109_00403"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=11, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
