			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You sure about this, though? About the whole entrusting me with trying to get Fukiko to join our little go-home club thing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是我做得到吗？是要说服叫吹子的孩子加入我们回家社对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是我做得到嗎？是要說服叫吹子的孩子加入我們回家社對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00149",
		linknext = "0109_00151",
		line = 1964,
	},
	["0109_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Can you not call it a go-home club, please? It's not wrong, but it's too on-point.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请不要说是回家社……因为太合适了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請不要說是回家社……因為太合適了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00150",
		linknext = "0109_00152",
		line = 1976,
	},
	["0109_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And if anything, I can't leave this in anyone else's hands but your own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“倒不如说，只能拜托渡酱前辈了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「倒不如說，只能拜託渡醬前輩了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00151",
		linknext = "0109_00153",
		line = 1988,
	},
	["0109_00153"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2124", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well, I've never really done this before... If she's two years your junior, she'd be three years mine. Can I get through to her? I'm a little worried.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“虽然这种事我没什么经验……不过和橘君差两岁的话，和我就是差三岁咯？好担心啊，能不能谈开呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「雖然這種事我沒什麼經驗……不過和橘君差兩歲的話，和我就是差三歲咯？好擔心啊，能不能談開呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00152",
		linknext = "0109_00154",
		line = 2003,
	},
	["0109_00154"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think it's ideal myself. You'll seem that much more her elder that way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没问题的，对方看起来反而更年长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒問題的，對方看起來反而更年長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00153",
		linknext = "0109_00155",
		line = 2015,
	},
	["0109_00155"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2200] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00120", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=2200, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami2125", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Fair enough...? Yeah, you really get it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“原来如此……？嗯，橘君真懂呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「原來如此……？嗯，橘君真懂呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00154",
		linknext = "0109_00156",
		line = 2032,
	},
	["0109_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I do my best to flatter her, and she still doesn't really get it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱前辈虽然一脸不太明白的样子，但还是附和了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬前輩雖然一臉不太明白的樣子，但還是附和了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00155",
		linknext = "0109_00157",
		line = 2042,
	},
	["0109_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I figured Fukiko would find being introduced suddenly to a large crowd intimidating, so I brought the teammate I believed to be the least intimidating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然一大堆人去的话吹子也会怕，所以我带来了最容易亲近的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然一大堆人去的話吹子也會怕，所以我帶來了最容易親近的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00156",
		linknext = "0109_00158",
		line = 2052,
	},
	["0109_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all, Wata's the friendly type, and even if they don't get along, the whole loli thing should make for a cheap laugh or two.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱很友好，即使话聊不开，也能用萝莉梗来逗笑对方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬很友好，即使話聊不開，也能用蘿莉梗來逗笑對方。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00157",
		linknext = "0109_00159",
		line = 2062,
	},
	["0109_00159"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2126", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Just thinking about the island I grew up on having an illegal sex industry... It makes me sick. And I think leaving her on her own is gonna be, like, harmful and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……我也觉得绝对不能原谅自己成长的岛上有这种地下风俗。但是一直一个人的话……我觉得影响会更不好呢，就跟毒药一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……我也覺得絕對不能原諒自己成長的島上有這種地下風俗。但是一直一個人的話……我覺得影響會更不好呢，就跟毒藥一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00158",
		linknext = "0109_00160",
		line = 2077,
	},
	["0109_00160"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2127", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So I think the best thing would be for us to become her friends.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“所以如果我们能成为她的朋友，那就最好不过了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「所以如果我們能成為她的朋友，那就最好不過了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00159",
		linknext = "0109_00161",
		line = 2092,
	},
	["0109_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. My thoughts exactly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……嗯，的确如此，渡酱前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……嗯，的確如此，渡醬前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00160",
		linknext = "0109_00162",
		line = 2104,
	},
	["0109_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gets right to the core of the issue in her usual ditzy manner.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱虽然看起来呆呆的，但说出的话却一真见血。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬雖然看起來呆呆的，但說出的話卻一真見血。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00161",
		linknext = "0109_00163",
		line = 2114,
	},
	["0109_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She needs companions — or to put it another way — friends.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的，她需要同伴——换句话说，就是需要朋友。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的，她需要同伴——換句話說，就是需要朋友。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00162",
		linknext = "0109_00164",
		line = 2124,
	},
	["0109_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Loneliness is poison.",
					{"rt2"},
				},
			},
			cn = {
				{
					"孤独，就是毒药。",
					{"rt2"},
				},
			},
			tw = {
				{
					"孤獨，就是毒藥。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00163",
		linknext = "0109_00165",
		line = 2134,
	},
	["0109_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It will eat away at your soul, and one day it will break your heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是会慢慢侵蚀心灵，并在某天轻易使人内心崩溃的剧毒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是會慢慢侵蝕心靈，並在某天輕易使人內心崩潰的劇毒。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00164",
		linknext = "0109_00166",
		line = 2144,
	},
	["0109_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Both me, and this quote-unquote 'loli' who's felt isolated despite living on this island all her life, know that all too well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是我——还有一直在这个岛上忍受着名为“萝莉”的孤独的渡酱也知道的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是我——還有一直在這個島上忍受著名為「蘿莉」的孤獨的渡醬也知道的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00165",
		linknext = "0109_00167",
		line = 2154,
	},
	["0109_00167"] = {
