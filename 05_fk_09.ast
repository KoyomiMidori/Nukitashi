			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huh, I wonder why? She doesn't have much in the way of redeeming qualities outside of her face, but she's not bad in a fight... Uh, Darling?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哎，怎么了吗？光姬酱虽然是除了长得好看之外没啥用的孩子，但战斗力还蛮强的哦……亲爱的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哎，怎麼了嗎？光姬醬雖然是除了長得好看之外沒啥用的孩子，但戰鬥力還蠻強的哦……親愛的？」",
					{"rt2"},
				},
			},
		},
