			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Let me see... Oh, looks like you're right. It seems to be transmitting GPS data outside of the Cumblr app... Did you do something with your tablet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“借我看看……哎呀，好像是呢，除了‘淫sta’外，还有什么在发出位置信息……平板怎么了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「借我看看……哎呀，好像是呢，除了『淫sta』外，還有什麼在發出位置資訊……平板怎麼了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00085",
		linknext = "0109_00087",
		line = 1127,
	},
	["0109_00087"] = {
