	},
	["0109_00270"] = {
		{"fg", mode=-1, id=8, ch="手嶋", lv=5, time=500},
		{"se", id=0, loop=0, file="se_a235"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He handcuffs me to a pole.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我背上贴着柱子，双手被手铐给绑在了后面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我背上貼著柱子，雙手被手銬給綁在了後面。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00269",
		linknext = "0109_00271",
		line = 3768,
	},
	["0109_00271"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00102", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0252", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Now you and I can finally 'ave ourselves a quiet little chat... eh, Junnosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“这样终于可以慢慢聊了呢……淳之介君？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「這樣終於可以慢慢聊了呢……淳之介君？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00270",
		linknext = "0109_00272",
		line = 3783,
	},
	["0109_00272"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He says that with a sickening grin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那家伙脸上浮现出令人恶心的好人笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那傢伙臉上浮現出令人噁心的好人笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00271",
		linknext = "0109_00273",
		line = 3793,
	},
	["0109_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everything becomes crystal clear.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于是，一切都明朗了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"於是，一切都明朗了。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00272",
		linknext = "0109_00274",
		line = 3803,
	},
	["0109_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This man is my real enemy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙——是我的敌人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙——是我的敵人。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00273",
		linknext = "0109_00275",
		line = 3813,
	},
	["0109_00275"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that really was you yesterday...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——手嶋先生，没想到昨天那个人真的是你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——手嶋先生，沒想到昨天那個人真的是你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00274",
		linknext = "0109_00276",
		line = 3825,
	},
	["0109_00276"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0253", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“What, ya thought it was a reach fer such a borin' fuck of a nine-to-fiver uncomfortable wit' sex ta do somethin' like that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你觉得不可能吗？觉得一个不擅长色情、头脑不好的老好人上班族，怎么可能做那种事是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你覺得不可能嗎？覺得一個不擅長色情、頭腦不好的老好人上班族，怎麼可能做那種事是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00275",
		linknext = "0109_00277",
		line = 3839,
	},
	["0109_00277"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I couldn't prove it... I figured I wouldn't tell the SS until I did more investigation, had more concrete evidence on my side...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我没有确切的证据。所以打算在进一步调查搜证前先别向FS报告——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我沒有確切的證據。所以打算在進一步調查搜證前先別向FS報告——」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00276",
		linknext = "0109_00278",
		line = 3851,
	},
	["0109_00278"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0254", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hahaha! Fuckin' mong! Why d'ya think I lured ya here today? I know what kinda bloke you fuckin' are, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈哈哈！笨蛋，所以我今天把你引到这里来了。我早就知道你的个性了，橘……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈哈哈！笨蛋，所以我今天把你引到這裡來了。我早就知道你的個性了，橘……」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00277",
		linknext = "0109_00279",
		line = 3865,
	},
	["0109_00279"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Teshima cackles away, quite amused.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋愉快地笑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋愉快地笑了。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00278",
		linknext = "0109_00280",
		line = 3875,
	},
	["0109_00280"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0255", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Lemme tell ya, I know a thing or two 'bout psychology. Enough ta get a masters in it. No matter who I talk to, I can get a complete profile of their personality jes' like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我学过一点心理学……硕士也是那方面的科系。所以说不管是什么人，只要稍微说几句话，就能简单地进行心理分类。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我學過一點心理學……碩士也是那方面的科系。所以說不管是什麼人，只要稍微說幾句話，就能簡單地進行心理分類。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00279",
		linknext = "0109_00281",
		line = 3889,
	},
	["0109_00281"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's impressive. And yet you're in the yakuza? Surely you would've had better job prospects than this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那还真是相当便利的能力啊。结果你成了黑社会？没有更好的工作了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那還真是相當便利的能力啊。結果你成了黑社會？沒有更好的工作了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00280",
		linknext = "0109_00282",
		line = 3901,
	},
	["0109_00282"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00102", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"se", id=1, loop=0, file="se_a021"},
		{"text"},
		delay = {
			[8000] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=8000},
				{"se", id=0, loop=0, file="se_a201", delay2=8000},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0256", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ya think I'm lyin'? Then why d'ya think those OSS twats sold out their organization? How about it, Miss Vice President of the Special Combat Unit?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你觉得我是骗人的吗？那么……你觉得SHO的人为什么会突然背叛组织呢？你说是吧，特殊战斗部的副委员长小姐？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你覺得我是騙人的嗎？那麼……你覺得SHO的人為什麼會突然背叛組織呢？你說是吧，特殊戰鬥部的副委員長小姐？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00281",
		linknext = "0109_00283",
		line = 3920,
	},
	["0109_00283"] = {
		{"se", id=1, stop=1, time=1000},
		{"bg", id=1, file="bg11_1_00000", x=0, y=0, path=":bg/", sync=0, time=600, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=0, y=0},
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00117", path=":fg/kouki_01m/", id=8, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=700, mode=3, x=600, y=0},
		{"fgact", ch="光姫", id=8, act="移動", x=-200, y=0, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Miss Senba...!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——仙波、小姐……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——仙波、小姐……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00282",
		linknext = "0109_00284",
		line = 3937,
	},
	["0109_00284"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0159", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Everything is for Lord Teshima... You are my purpose in life, My Lord...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“……所有的一切，都是为了手嶋大人……这就是我的生存意义，主人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「……所有的一切，都是為了手嶋大人……這就是我的生存意義，主人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00283",
		linknext = "0109_00285",
		line = 3949,
	},
	["0109_00285"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=9, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0257", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“There ya have it, Tachibana. It's a real snap to have dominion over someone's mind if ya can get deep into it. Threats, shock treatment, an' smooth talk— that's how I get more pawns on me side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“就是这么回事，橘……只要能读懂对方的心思，心理控制就很容易了。威胁、电击、甜言蜜语，我就是这样增加自己的棋子的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「就是這麼回事，橘……只要能讀懂對方的心思，心理控制就很容易了。威脅、電擊、甜言蜜語，我就是這樣增加自己的棋子的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00284",
		linknext = "0109_00286",
		line = 3964,
	},
	["0109_00286"] = {
		{"fg", mode=-1, id=8, ch="光姫", lv=5, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is that why the numbers of SS and OSS have been diminishing?",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS和SHO越来越少，就是这样——",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS和SHO越來越少，就是這樣——",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00285",
		linknext = "0109_00287",
		line = 3976,
