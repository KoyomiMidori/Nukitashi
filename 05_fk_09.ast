			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You motherfuckers aren't good for anything but collecting corrupt money anyway!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这家伙能做到的，顶多也只是赚些见不得光的钱而已——！”",
