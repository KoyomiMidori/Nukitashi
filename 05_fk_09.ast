		text = {
			vo = {
				{"vo", file="teshima0263", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“It's psychological trauma. That's why ya keep it hidden away. How's that? Bullseye, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“心理创伤，即Psychological trauma。因为这个原因，你才会隐藏起来。怎么样，说中了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「心理創傷，即Psychological trauma。因為這個原因，你才會隱藏起來。怎麼樣，說中了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00307",
		linknext = "0109_00309",
		line = 4238,
	},
	["0109_00309"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look away and he smiles, amused.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把视线移开后，手嶋愉快地笑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我把視線移開後，手嶋愉快地笑了。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00308",
		linknext = "0109_00310",
		line = 4248,
	},
	["0109_00310"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0264", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I've already done my homework on ya. Ya think that time you and I met was just coincidence?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“很久以前我就在调查你的事情了哦？难道你以为那个时候是偶然碰面的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「很久以前我就在調查你的事情了哦？難道你以為那個時候是偶然碰面的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00309",
		linknext = "0109_00311",
		line = 4262,
	},
	["0109_00311"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did you say!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什么——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說什麼——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00310",
		linknext = "0109_00312",
		line = 4274,
	},
	["0109_00312"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0265", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I'd heard there was some little shit tryin'a fuck with our business. Findin' ya was easier than piss. But yer comrades proved a right pain in me ass.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我听说有小鬼在妨碍我们的副业……你的话很快就发现了。虽然另一个人花了很长时间……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我聽說有小鬼在妨礙我們的副業……你的話很快就發現了。雖然另一個人花了很長時間……」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00311",
		linknext = "0109_00313",
		line = 4288,
	},
	["0109_00313"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
