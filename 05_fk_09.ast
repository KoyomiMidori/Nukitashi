		{"bg", id=18, file="pm3_00001", x=0, y=0, path=":cg/pm3/", ev=1, time=300, lv=5, ax=1250, ay=455, bx=-450, by=-5},
		{"fg", file="touka_01l_00001", file1="touka_01l_00115", path=":fg/touka_01l/", id=9, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, style="blur", blurx=11, blury=11, time=300, mode=3, x=-50, y=-300},
