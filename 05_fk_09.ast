		linkback = "0109_00321",
		linknext = "0109_00323",
		line = 4429,
	},
	["0109_00323"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How the fuck does he—",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙，为什么会知道——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙，為什麼會知道——",
					{"rt2"},
				},
