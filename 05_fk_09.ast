				{"vo", file="hitoura0169", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Of course. If it means I can shut you down, that will be no skin off my nose.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯——如果能把你们摧毁的话，那种程度的事情根本不疼不痒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯——如果能把你們摧毀的話，那種程度的事情根本不痛不癢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00402",
		linknext = "0109_00404",
		line = 5546,
	},
	["0109_00404"] = {
