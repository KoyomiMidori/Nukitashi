		linkback = "0109_00106",
		linknext = "0109_00108",
		line = 1397,
	},
	["0109_00108"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir, we are doing everything we possibly can. From going undercover in the SS, to infiltrating the OSS HQ, to combing through all the video footage we have available to us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老爷爷，我们已经尽了最大的努力了。潜入FS，潜入SHO总部，还搜索了大量的影像。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「老爺爺，我們已經盡了最大的努力了。潛入FS，潛入SHO總部，還搜索了大量的影像。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00107",
		linknext = "0109_00109",
		line = 1411,
	},
	["0109_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But we have not found anyone who matches Fumino's description. Plus, she cannot be found in any birth registry, so we barely have anything to go on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是没能发现被认为是‘文乃’少女的身姿，户籍信息不存在，连个影子都没能抓住。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是沒能發現被認為是『文乃』少女的身姿，戶籍資訊不存在，連個影子都沒能抓住。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00108",
		linknext = "0109_00110",
		line = 1423,
	},
	["0109_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The one major issue holding us back is that we are working with a severe lack of suitable information about her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这完全是因为我们缺乏情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這完全是因為我們缺乏情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00109",
		linknext = "0109_00111",
		line = 1435,
	},
	["0109_00111"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0113", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Suitable information...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“你说情报——？”",
