			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“The fuck!? Don't ya know what position yer in right now!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你知道自己的立场吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你知道自己的立場吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00374",
		linknext = "0109_00376",
		line = 5092,
	},
	["0109_00376"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You mad, Teshima!? Huh!? Maybe if you used that psychology of yours to profile yourself, you'd have figured it out sooner!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“生气了吗手嶋！？用擅长的心理学对自己进行心理分析应该就会明白了吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「生氣了嗎手嶋！？用擅長的心理學對自己進行心理分析應該就會明白了吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00375",
		linknext = "0109_00377",
		line = 5104,
	},
	["0109_00377"] = {
