				{"vo", file="teshima0266", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Good thing ya make sure ta put yer goggles on whenever yer goin' into a fight, Junnosuke!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“行动的时候要好好戴着护目镜才可以哦？淳之介君？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「行動的時候要好好戴著護目鏡才可以哦？淳之介君？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00312",
		linknext = "0109_00314",
		line = 4302,
	},
	["0109_00314"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=4, size=7.5, time=50, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
