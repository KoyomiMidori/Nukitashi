					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ever heard of the Kazan Shingan style? Well, me organization does somethin' like that, with a bit o' karate shit thrown in. Pretty practical, ain't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你知道华山心眼流吗？就跟我们组织学的空手道一样……很有实践性吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你知道華山心眼流嗎？就跟我們組織學的空手道一樣……很有實踐性吧？」",
					{"rt2"},
				},
