	["0109_00447"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="rei_01f_00001", file1="rei_01f_00101", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1118", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Miss Touka. As requested by Senator Hitoura, I met with that mainland official in lieu of yourself. The meeting concluded uneventfully.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……桐香大人。仁浦先生委托的和本岛官员的会面，桐香大人代理顺利完成工作了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……桐香大人。仁浦先生委託的和本島官員的會面，桐香大人代理順利完成工作了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00446",
		linknext = "0109_00448",
		line = 6205,
	},
	["0109_00448"] = {
		{"fg", mode=-1, id=9, ch="桐香", lv=5, time=100},
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=600, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=9, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0730", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I see. Good work, Rei. Give my regards to Ikuko as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，是吗……辛苦了，礼。也帮我向郁子问声好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，是嗎……辛苦了，禮。也幫我向郁子問聲好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00447",
		linknext = "0109_00449",
		line = 6222,
	},
	["0109_00449"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1119", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yes, I've done so. With that said, why were you absent from the island on the day of the meeting? Did you have another engagement?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“好的，那就……不过桐香大人，为什么当天你会没办法离开岛呢？有什么要紧事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好的，那就……不過桐香大人，為什麼當天你會沒辦法離開島呢？有什麼要緊事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00448",
		linknext = "0109_00450",
		line = 6234,
	},
	["0109_00450"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=9, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0731", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes... Let us simply say it was something which seemed interesting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，因为……好像会发生一些很有趣的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，因為……好像會發生一些很有趣的事情。」",
