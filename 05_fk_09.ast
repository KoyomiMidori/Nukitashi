	["0109_00369"] = {
		{"bgm", stop=1},
		{"se", id=1, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What if I do, then? What would that do to your coffers?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——如果你这样做，那你们的收入来源怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——如果你這樣做，那你們的收入來源怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00368",
		linknext = "0109_00370",
		line = 5013,
	},
	["0109_00370"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00121", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0287", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Huh? Like, if we destroy this island, the illegal shit on the mainland's gonna recover. Don't be such a smarta—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啥……？那种东西，只要毁掉这个岛，本岛的风俗业就会复活。这样——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啥……？那種東西，只要毀掉這個島，本島的風俗業就會復活。這樣——」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00369",
		linknext = "0109_00371",
		line = 5027,
	},
	["0109_00371"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It won't. You can't just revive something that's already dead. You'd need to find another income stream. And how d'you think that'd work out?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不对。曾经衰退的东西是不会轻易恢复的。也就是说会需要其他的收入来源。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不對。曾經衰退的東西是不會輕易恢復的。也就是說會需要其他的收入來源。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00370",
		linknext = "0109_00372",
		line = 5040,
	},
	["0109_00372"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don't want to destroy this island. You want to control it. Either way, you still want it to be a haven for your sex industry shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然如此，你们一定不会毁掉这个岛，而是会直接占领，甚至将这里改造成风俗岛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然如此，你們一定不會毀掉這個島，而是會直接佔領，甚至將這裡改造成風俗島。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00371",
		linknext = "0109_00373",
		line = 5052,
	},
	["0109_00373"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00120", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0288", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Motherfucker... You figured that out?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你他妈……居然想到了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你他媽……居然想到了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00372",
		linknext = "0109_00374",
		line = 5066,
	},
	["0109_00374"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did I get ya? I don't need a fuckin' masters to figure that out! Especially not when you're just some close-minded yakuza dipshit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“吓了一跳吗？但是这种程度的事情即使不学心理学也能知道，这就是你们这些狡猾的黑社会的想法！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嚇了一跳嗎？但是這種程度的事情即使不學心理學也能知道，這就是你們這些狡猾的黑社會的想法！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00373",
		linknext = "0109_00375",
		line = 5078,
	},
	["0109_00375"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00114", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
