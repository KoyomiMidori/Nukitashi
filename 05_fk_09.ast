		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I messaged Nanase earlier to tell her we need to discuss the OSS written report.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我觉得有必要讨论一下有关之前联系奈奈濑说过的SHO的报告书的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我覺得有必要討論一下有關之前聯繫奈奈瀨說過的SHO的報告書的事情。」",
					{"rt2"},
				},
			},
