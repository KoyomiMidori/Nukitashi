			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Is that true, Tachibana!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……真的吗？橘同学……！？”",
