		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0275", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“What did ya fuckin' expect? That bitch got completely oppressed by the residents! Stoned 'er like Jesus fuckin' Christ!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“那也是没办法的事！那样的女人就算被居民迫害也没办法！我想就连耶稣都会向她扔石头哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「那也是沒辦法的事！那樣的女人就算被居民迫害也沒辦法！我想就連耶穌都會向她扔石頭哦！？」",
					{"rt2"},
				},
			},
		},
