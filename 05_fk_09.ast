		{"cgact", file="cgact", id=18, act="アルファフェード点滅", loop=1, alpha="0,256", time=150, alphadel=1, lv=5, x=-5, y=-5},
		{"ex", time=320, func="wait"},
		{"se", id=1, loop=1, file="se_a107"},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0274", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Well, ya know, it was a big fuckin' deal back then! An illegal sex industry threatenin' the law? No shit people woulda been up in arms about that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“毕竟那时候好像做得很大嘛！威胁到条例的地下风俗，对岛上的人来说一定是个很大的麻烦吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「畢竟那時候好像做得很大嘛！威脅到條例的地下風俗，對島上的人來說一定是個很大的麻煩吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00333",
		linknext = "0109_00335",
		line = 4575,
	},
	["0109_00335"] = {
