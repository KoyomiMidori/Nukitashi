		linkback = "0109_00313",
		linknext = "0109_00315",
		line = 4316,
	},
	["0109_00315"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00120", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=9, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0267", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Watch yer attitude, you little shit. Use that damp rag in yer fuckin' skull and remember I got a hostage.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“喂注意你的态度哦？好好想想这里可是有人质的哦？”",
					{"rt2"},
				},
