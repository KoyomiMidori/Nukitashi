		linkback = "0109_00115",
		linknext = "0109_00117",
		line = 1512,
	},
	["0109_00117"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If even they are on the prowl for her, what is that supposed to mean? Just who is this Fumino girl, anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就连组织都前去搜索的‘文乃’究竟是什么身份？她到底是什么人物？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就連組織都前去搜索的『文乃』究竟是什麼身份？她到底是什麼人物？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00116",
		linknext = "0109_00118",
		line = 1528,
	},
	["0109_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He doesn't respond.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人没有回答我的问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人沒有回答我的問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00117",
		linknext = "0109_00119",
		line = 1538,
	},
	["0109_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Instead...",
					{"rt2"},
				},
			},
			cn = {
				{
					"取而代之的是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"取而代之的是。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00118",
		linknext = "0109_00120",
		line = 1548,
	},
	["0109_00120"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0115", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“I only gave you one condition: to secure Fumino. If I planned on answering your inquiry, I would have told you from the start.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“……对你们下达的命令只有救出‘文乃’。我应该一开始就告诉过你们要满足这个要求了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「……對你們下達的命令只有救出『文乃』。我應該一開始就告訴過你們要滿足這個要求了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00119",
		linknext = "0109_00121",
		line = 1561,
	},
	["0109_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know that. However...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我知道，可是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我知道，可是——」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00120",
		linknext = "0109_00122",
		line = 1573,
	},
	["0109_00122"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0116", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“If you are unable to do that much, boy, know that your funding will be cut off. That will be all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“如果做不到，就没有更多援助了，知道了吗年轻人？……就这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「如果做不到，就沒有更多援助了，知道了嗎年輕人？……就這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00121",
		linknext = "0109_00123",
		line = 1586,
	},
	["0109_00123"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He cuts off the transmission.",
