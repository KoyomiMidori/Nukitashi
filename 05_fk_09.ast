	["0109_00093"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Could you please stop throwing that word around? This isn't a fake outrage gaming blog.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别理所当然地那样称呼我，这可不是培育型棒球游戏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
