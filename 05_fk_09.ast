astver = 2.0
ast = {
	["0109_00001"] = {
		{"savetitle", text="弔鐘一音", ja="弔鐘一音", en="The Sound of a Funeral Bell", cn="一声丧钟", tw="一聲喪鐘"},
		{"eval", exp="g.05_fk_09=1"},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg23_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0726", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As I'm sure you are all aware, Governor Hitoura was kidnapped last night by an unknown entity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……我想大家应该都知道了，昨天晚上仁浦县知事被人绑架了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……我想大家應該都知道了，昨天晚上仁浦縣知事被人綁架了。」",
					{"rt2"},
				},
			},
		},
		linknext = "0109_00002",
		line = 22,
	},
	["0109_00002"] = {
		{"bgm", file="bgm30", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The next day, at lunch.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第二天中午。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第二天中午。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00001",
		linknext = "0109_00003",
		line = 33,
	},
	["0109_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS have gathered in the disciplinary committee office for an emergency assembly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们FS因为紧急召集在风纪委员室集合了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們FS因為緊急召集在風紀委員室集合了。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00002",
		linknext = "0109_00004",
		line = 43,
	},
	["0109_00004"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0727", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The identity of the kidnappers is yet unknown, but the SS have taken appropriate precautions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然还不能确定是由哪个逆贼一手策划的，但是事件已经防患于未然了。是由我们FS阻止的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然還不能確定是由哪個逆賊一手策劃的，但是事件已經防患於未然了。是由我們FS阻止的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00003",
		linknext = "0109_00005",
		line = 55,
	},
	["0109_00005"] = {
		{"bg", id=1, file="bg23_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0728", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And so, Governor Hitoura has come here to our academy at short notice, in order to thank us directly. Come in, sir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“关于这件事，仁浦县知事想直接表示感谢，所以今天急忙来到了学校，请进。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「關於這件事，仁浦縣知事想直接表示感謝，所以今天急忙來到了學校，請進。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00004",
		linknext = "0109_00006",
		line = 70,
	},
	["0109_00006"] = {
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a stir in the crowd.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家惊呼了一声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家驚呼了一聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00005",
		linknext = "0109_00007",
		line = 82,
	},
	["0109_00007"] = {
		{"se", id=0, loop=0, file="se_a079"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The office door opens, and a man walks in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员室的门开了，一个男人走了进来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員室的門開了，一個男人走了進來。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00006",
		linknext = "0109_00008",
		line = 93,
	},
	["0109_00008"] = {
		{"se", id=0, loop=0, file="se_d006"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are loud cheers as he walks in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与此同时，欢呼声响起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與此同時，歡呼聲響起。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00007",
		linknext = "0109_00009",
		line = 104,
	},
	["0109_00009"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00111", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="仁浦", id=10, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The man — Governor Hitoura — raises one hand to acknowledge the cheers somewhat bashfully.",
					{"rt2"},
				},
			},
			cn = {
				{
					"男人——仁浦县知事好像很不习惯地用一只手回应着他们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"男人——仁浦縣知事好像很不習慣地用一隻手回應著他們。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00008",
		linknext = "0109_00010",
		line = 116,
	},
	["0109_00010"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0150", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I merely intended to say a brief thanks, without intending to make a spectacle of things... But your student council president was quite insistent on more.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我应该说了不用太大费周章，这种打招呼太小题大做了……看来你们的学生会长好像有点坏心眼呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我應該說了不用太大費周章，這種打招呼太小題大做了……看來你們的學生會長好像有點壞心眼呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00009",
		linknext = "0109_00011",
		line = 129,
	},
	["0109_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He smiles bashfully and the crowd breaks into laughter.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他害羞的笑容，引起大家一阵骚动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他害羞的笑容，引起大家一陣騷動。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00010",
		linknext = "0109_00012",
		line = 139,
	},
	["0109_00012"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0151", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Anyway, I want to thank everyone for their handling of the incident last night. As a result of your hard work, I am unharmed. Thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“总之，关于昨天晚上的事，我想向大家表示感谢。因为你们的努力，我平安归来了。谢谢你们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「總之，關於昨天晚上的事，我想向大家表示感謝。因為你們的努力，我平安歸來了。謝謝你們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00011",
		linknext = "0109_00013",
		line = 153,
	},
	["0109_00013"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0152", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“To express my gratitude, I have arranged for a rather humble sort of luncheon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“为了表示感谢，今天我简单地准备了午餐。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「為了表示感謝，今天我簡單地準備了午餐。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00012",
		linknext = "0109_00014",
		line = 165,
	},
	["0109_00014"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0153", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I'm unable to create something on a grand scale, given it's for the duration of a lunch break, but I hope you enjoy it, given the allotted time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为只是午休时间，所以不能做得太张扬，但如果你们能在有限的时间里开心地度过就好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為只是午休時間，所以不能做得太張揚，但如果你們能在有限的時間裡開心地度過就好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00013",
		linknext = "0109_00015",
		line = 179,
	},
	["0109_00015"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The cloth covering the table is pulled away, and I see a spread of food that could not be remotely described as humble.",
					{"rt2"},
				},
			},
			cn = {
				{
					"盖在桌上的罩子被拿掉了，桌布上摆放着很多不能说是简便的料理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"蓋在桌上的罩子被拿掉了，桌布上擺放著很多不能說是簡便的料理。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00014",
		linknext = "0109_00016",
		line = 192,
	},
	["0109_00016"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0154", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Sadly, there's no alcohol involved here, but we'll save that for another time. Cheers!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“很遗憾没有酒精，这部份就等下次的机会吧。那么，干杯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「很遺憾沒有酒精，這部份就等下次的機會吧。那麼，乾杯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00015",
		linknext = "0109_00017",
		line = 205,
	},
	["0109_00017"] = {
		{"se", id=0, loop=0, file="se_a202"},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He raises his glass, and everyone else follows suit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他举起杯子，所有人都像在追随他一样举起杯子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他舉起杯子，所有人都像在追隨他一樣舉起杯子。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00016",
		linknext = "0109_00018",
		line = 218,
	},
	["0109_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then the stand-up party begins with quite heated enthusiasm.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在异样的热气中，无座式宴会开始了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在異樣的熱氣中，無座式宴會開始了。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00017",
		linknext = "0109_00019",
		line = 228,
	},
	["0109_00019"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00111", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0155", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You'd be pleased to get an autograph from this old man? I'm used to handshakes, but this is a first for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……收到这种大叔的签名会开心吗？虽然我习惯握手，但签名还是第一次呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……收到這種大叔的簽名會開心嗎？雖然我習慣握手，但簽名還是第一次呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00018",
		linknext = "0109_00020",
		line = 242,
	},
	["0109_00020"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0303", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "FS女学生A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female SS Student A"},
					"“Yes, I really like older men... ah, no, I just want to show you my support!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "FS女学生A"},
					"“是的，我……喜欢比我年长的人……啊，不对，我会支持你的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "FS女學生A"},
					"「是的，我……喜歡比我年長的人……啊，不對，我會支持你的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00019",
		linknext = "0109_00021",
		line = 254,
	},
	["0109_00021"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[500] = {
				{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, delay2=500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0156", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Really? Sure, I don't mind if you vote for me in the next election. Nah, just kidding. Where should I sign?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是吗。那只要下次选举时你把票投给我……不，我开玩笑，我要签哪里比较好？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是嗎。那只要下次選舉時你把票投給我……不，我開玩笑，我要簽哪裡比較好？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00020",
		linknext = "0109_00022",
		line = 270,
	},
	["0109_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's instantly surrounded by SS, who harass him for signatures and hound him with questions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生瞬间被FS包围住，受到了签名和提问的攻势。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生瞬間被FS包圍住，受到了簽名和提問的攻勢。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00021",
		linknext = "0109_00023",
		line = 280,
	},
	["0109_00023"] = {
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“He's really popular.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真是有人气啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真是有人氣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00022",
		linknext = "0109_00024",
		line = 294,
	},
	["0109_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's like a complete turnaround, the way he responds to everyone with that nihilistic smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我瞥了一眼表情和刚才完全不同，用虚无的笑容对应大家的仁浦先生，并自言自语道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我瞥了一眼表情和剛才完全不同，用虛無的笑容對應大家的仁浦先生，並自言自語道。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00023",
		linknext = "0109_00025",
		line = 304,
	},
	["0109_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He is kind of like an idol among the islanders; among young and old, men and women alike.",
					{"rt2"},
				},
			},
			cn = {
				{
					"话说回来，仁浦先生在岛上似乎无论男女老少都很支持他。",
					{"rt2"},
				},
			},
			tw = {
				{
					"話說回來，仁浦先生在島上似乎無論男女老少都很支持他。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00024",
		linknext = "0109_00026",
		line = 314,
	},
	["0109_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And he doesn't look so bad, either. I doubt the citizens would have gone along with his policy if that weren't the case.",
					{"rt2"},
				},
			},
			cn = {
				{
					"长相也不坏，不然民众应该不会接受这种莫名其妙的政策吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"長相也不壞，不然民眾應該不會接受這種莫名其妙的政策吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00025",
		linknext = "0109_00027",
		line = 324,
	},
	["0109_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe that's the real side of him?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——这就是仁浦先生原本的样貌吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"——這就是仁浦先生原本的樣貌嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00026",
		linknext = "0109_00028",
		line = 334,
	},
	["0109_00028"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0616", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Gosh, Hitoura's as popular as ever. All this food, and yet everyone focuses on him. Kinda weird, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“仁浦大叔今天也非常受欢迎呢〜大家都不想吃饭了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「仁浦大叔今天也非常受歡迎呢〜大家都不想吃飯了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00027",
		linknext = "0109_00029",
		line = 348,
	},
	["0109_00029"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Commander Onabuta... aren't you going to talk to him too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“女部田……中队长不要紧吗？不跟大家一样去跟仁浦县知事说话吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「女部田……中隊長不要緊嗎？不跟大家一樣去跟仁浦縣知事說話嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00028",
		linknext = "0109_00030",
		line = 360,
	},
	["0109_00030"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00121", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0617", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Those of us in the upper ranks of the SS get to see him often at meetings and so on. Right, Rei?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我们这些FS上层在会议中经常会碰到他，所以不要紧。你说是吧，礼酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我們這些FS上層在會議中經常會碰到他，所以不要緊。你說是吧，禮醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00029",
		linknext = "0109_00031",
		line = 374,
	},
	["0109_00031"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00113", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="郁子", id=10, act="移動", x=-400, y=0, time=700},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1112", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hm? Yeah, more or less... Good grief, here it's time to eat, and yet they choose to sit around chattering. Such an undisciplined lot. Nom, nom...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯？啊，是啊……嚼嚼嚼……真是的，能吃的时候不吃，闲聊什么的，真是教育不足……嚼嚼嚼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯？啊，是啊……嚼嚼嚼……真是的，能吃的時候不吃，閒聊什麼的，真是教育不足……嚼嚼嚼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00030",
		linknext = "0109_00032",
		line = 392,
	},
	["0109_00032"] = {
		{"fgact", ch="礼", id=9, act="振動下", loop=3, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's heaped her plate with enough food for multiple people, and is scarfing it down without hesitation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长把不知道是几人分的量盛到盘子里，以一定的速度一直吃着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員長把不知道是幾人分的量盛到盤子裡，以一定的速度一直吃著。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00031",
		linknext = "0109_00033",
		line = 403,
	},
	["0109_00033"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00111", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0618", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“By the way, what happened to Kokie? Didn't she flake out on the beach?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“话说回来礼酱，光姬酱怎么样了？她不是倒在沙滩上吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「話說回來禮醬，光姬醬怎麼樣了？她不是倒在沙灘上嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00032",
		linknext = "0109_00034",
		line = 417,
	},
	["0109_00034"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00113", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=3, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1113", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Right, she was rushed to hospital, but she doesn't seem to have fully regained consciousness. She keeps mumbling incomprehensible things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嚼嚼……嗯，那之后，她马上被送往医院了……意识好像很混乱，在说些莫名其妙的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嚼嚼……嗯，那之後，她馬上被送往醫院了……意識好像很混亂，在說些莫名其妙的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00033",
		linknext = "0109_00035",
		line = 432,
	},
	["0109_00035"] = {
		{"text"},
