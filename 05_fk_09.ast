	["0109_00352"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0281", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ya hate the people who killed that woman, right? Ya hate non-virgins, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你恨那些杀了那个女人的人对吧？你恨非处女对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你恨那些殺了那個女人的人對吧？你恨非處女對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00351",
		linknext = "0109_00353",
		line = 4821,
	},
	["0109_00353"] = {
		{"text"},
		text = {
