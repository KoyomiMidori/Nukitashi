		linkback = "0109_00056",
		linknext = "0109_00058",
		line = 725,
	},
	["0109_00058"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Th-That wasn't my intention. I just felt that the OSS were useless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我、我并没有想过要挑战他们，只是觉得SHO太没用了而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我、我並沒有想過要挑戰他們，只是覺得SHO太沒用了而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00057",
		linknext = "0109_00059",
		line = 737,
	},
	["0109_00059"] = {
		{"se", id=0, loop=0, file="se_a031"},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=30, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="移動", x=-400, y=0, time=800},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="礼", id=9, act="移動", x=-200, y=0, time=700},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=400, y=0},
				{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1115", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“T-Tachibana! How dare you say that to him! I am terribly sorry, he only transferred to this school a short while ago!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂，橘！你竟然跟仁浦大人说这种话……！对不起，因为他才刚转校过来没多久……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂，橘！你竟然跟仁浦大人說這種話……！對不起，因為他才剛轉校過來沒多久……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00058",
		linknext = "0109_00060",
		line = 758,
	},
	["0109_00060"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0160", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hahaha! No, he's probably right. We were definitely ineffectual. We just needed someone to say so outright.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哈哈哈！不，你说得对，实际上我们确实很没用。我们只是需要一个能说清楚的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哈哈哈！不，你說得對，實際上我們確實很沒用。我們只是需要一個能說清楚的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00059",
		linknext = "0109_00061",
		line = 772,
	},
	["0109_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He looks amused with my sarcasm.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对我的讽刺，仁浦先生露出了愉快的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對我的諷刺，仁浦先生露出了愉快的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00060",
		linknext = "0109_00062",
		line = 782,
	},
	["0109_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's either broad-minded, or very tolerant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与其说豁达，不如说是——器量很大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與其說豁達，不如說是——器量很大。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00061",
		linknext = "0109_00063",
		line = 792,
	},
	["0109_00063"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0161", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But next time, I would rather you contacted me, and not the SS, young man. Let me see your tablet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不过下次不用跟FS，直接跟我抱怨就行了。少年，把平板拿出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不過下次不用跟FS，直接跟我抱怨就行了。少年，把平板拿出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00062",
		linknext = "0109_00064",
		line = 806,
	},
	["0109_00064"] = {
