			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Then come to my side. I'll find a good use for yer giant dong. Namely, controllin' people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“既然如此——你就成为我的同伴吧。那个巨根能在我想干的事情上派上用场，能用来操纵他人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「既然如此——你就成為我的同伴吧。那個巨根能在我想幹的事情上派上用場，能用來操縱他人……」",
					{"rt2"},
				},
			},
