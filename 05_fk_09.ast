		linkback = "0109_00113",
		linknext = "0109_00115",
		line = 1485,
	},
	["0109_00115"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As part of my undercover work in the SS, I saw the OSS report with my own eyes. There's no mistaking it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我在FS读了SHO的报告书。不会错的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我在FS讀了SHO的報告書。不會錯的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00114",
		linknext = "0109_00116",
		line = 1499,
	},
	["0109_00116"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
