					{"rt2"},
				},
			},
			en = {
				{
					"So that's how she ended up?",
					{"rt2"},
				},
			},
			cn = {
				{
					"变成那样了吗……",
					{"rt2"},
				},
			},
			tw = {
				{
					"變成那樣了嗎……",
					{"rt2"},
				},
