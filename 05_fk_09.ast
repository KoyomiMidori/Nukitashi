	["0109_00317"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00101", file2="fumino_01m_00202", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=1000, mode=3, x=100, y=-200},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=3000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why is he the hostage?",
					{"rt2"},
