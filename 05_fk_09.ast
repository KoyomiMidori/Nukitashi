					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“How 'bout it, Tachibana? Ya want revenge on all those loathsome non-virgins, don't ya?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“怎么样，橘——你不想向非处女、向你憎恨的所有人复仇吗？”",
					{"rt2"},
				},
			},
