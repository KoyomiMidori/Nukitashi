		{"bg", id=1, file="bg11_1l_00000", x=-300, y=0, path=":bg/", sync=0, ev=1, style="blur", blurx=11, blury=11, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=1, act="移動", x=595, y=-5, time=6000},
		{"text"},
		text = {
