			cn = {
				{
					name = {"手嶋"},
					"“我希望你说我是为了胜利而努力诶。你才是锻炼不足吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我希望你說我是為了勝利而努力欸。你才是鍛煉不足吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00268",
