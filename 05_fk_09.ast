		},
		linkback = "0109_00322",
		linknext = "0109_00324",
		line = 4439,
	},
	["0109_00324"] = {
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="手嶋", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0270", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“How do I know? No fuckin' shit I'd fuckin' know! I'm the king of the illegal sex grift! I look shit up and I find it out!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你说我为什么会知道？那还用说啊！？我可是地下风俗的老板哦！？一查马上就知道了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你說我為什麼會知道？那還用說啊！？我可是地下風俗的老闆哦！？一查馬上就知道了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00323",
		linknext = "0109_00325",
		line = 4454,
	},
	["0109_00325"] = {
		{"bg", id=1, file="bg11_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=9, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0271", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ya moved not long after that. Like you was fixin' ta run away. That woulda been awful traumatic fer ya.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“那之后你马上就搬家了，就像逃走了一样。这好像又对你造成了很大的心理创伤呢。”",
