				{"vo", file="misaki2112", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sh-She can't even stand up... Hurry and lay her down, gently!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，腰腿……完全……请小心躺下——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，腰腿……完全……請小心躺下——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00100",
		linknext = "0125_00102",
		line = 1201,
	},
	["0125_00102"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She can barely even keep her eyes open. She seems to have been deprived of food and drink.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的脸已经明显衰弱，别说吃饭了，大概连水都没有喝足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的臉已經明顯衰弱，別說吃飯了，大概連水都沒有喝足。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00101",
		linknext = "0125_00103",
		line = 1212,
	},
	["0125_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Half her face is smeared with blood from her nose, and her stare projects a thousand miles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的半张脸都是鼻血，两眼空洞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的半張臉都是鼻血，兩眼空洞。",
