	["0125_00177"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00107", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1098", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Please forgive... me... I do not know... the current state... of affairs in the world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我……非常抱歉……没有机会……了解社会的情况……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我……非常抱歉……沒有機會……了解社會的情況……」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00176",
		linknext = "0125_00178",
		line = 2363,
	},
	["0125_00178"] = {
