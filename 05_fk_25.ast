		linkback = "0125_00044",
		linknext = "0125_00046",
		line = 514,
	},
	["0125_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was because of me that she ended up this way.",
					{"rt2"},
				},
