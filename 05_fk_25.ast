				},
			},
		},
		linkback = "0125_00102",
		linknext = "0125_00104",
		line = 1222,
	},
	["0125_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no semblance of her usual composed appearance.",
