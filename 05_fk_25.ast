	},
	["0125_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't you ever! EVER! Try to sacrifice yourself... just to make someone else happy... ever again...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从今以后……！从今以后……不要再为了别人的幸福……牺牲自己了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從今以後……！從今以後……不要再為了別人的幸福……犧牲自己了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00198",
