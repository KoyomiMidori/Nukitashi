	},
	["0125_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This little girl did that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么小的女孩子。",
					{"rt2"},
