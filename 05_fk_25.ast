		line = 524,
	},
	["0125_00047"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0024", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“Haha, you're crying... I've never seen you cry before...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“哈哈……第一次看到……文乃哭了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「哈哈……第一次看到……文乃哭了呢……」",
					{"rt2"},
				},
