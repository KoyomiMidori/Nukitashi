	["0125_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To think she'd abandon all hope for herself to fulfill my wish.",
					{"rt2"},
				},
			},
			cn = {
				{
					"抛弃自己的一切，来实现我的愿望什么的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"拋棄自己的一切，來實現我的願望什麼的。",
