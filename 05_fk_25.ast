		linkback = "0125_00043",
		linknext = "0125_00045",
		line = 504,
	},
	["0125_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All in the name of protecting me.",
					{"rt2"},
