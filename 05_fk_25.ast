		{"bg", id=2, file="bg11_1l_00000", x=-300, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=10000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A voice rings out from somewhere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知从哪里传来了声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知從哪裡傳來了聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00106",
		linknext = "0125_00108",
		line = 1289,
	},
	["0125_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There must be speakers planted throughout this mansion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"整间房子好像都成了扩音器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"整間房子好像都成了擴音器。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00107",
		linknext = "0125_00109",
		line = 1299,
	},
	["0125_00109"] = {
		{"se", id=0, stop=1, time=1000},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bgm", file="bgm22.5", vol=100},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0175", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“So you really did come here. If only greater men had your persistence, boy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“真的来到这里了是吗。真是令人生气的行动力啊，小鬼——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「真的來到這裡了是嗎。真是令人生氣的行動力啊，小鬼——」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00108",
		linknext = "0125_00110",
		line = 1316,
	},
	["0125_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sakimori...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“防人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「防人——」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00109",
		linknext = "0125_00111",
		line = 1328,
	},
	["0125_00111"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why did you do this to her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你为什么要对这孩子这样做？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你為什麼要對這孩子這樣做？」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00110",
		linknext = "0125_00112",
		line = 1340,
	},
	["0125_00112"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0176", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“It was always my intent to. Though had she listened to me, I may have been more lenient. If only she had truly been my subservient little puppet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“我本来就打算这样做了。不过，这个姑娘还不肯当我的傀儡——如果听了我的话，对她的待遇应该会再好一点吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「我本來就打算這樣做了。不過，這個姑娘還不肯當我的傀儡——如果聽了我的話，對她的待遇應該會再好一點吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00111",
		linknext = "0125_00113",
		line = 1352,
	},
	["0125_00113"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0177", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“A young girl's story is bound to resonate with the public nowadays. Especially if spoken from her own lips. But that little bitch refused to open her mouth for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“女孩子说的话特别能在社会上引起反响，如果是自然的嗓音就更有效果了。但是，这家伙一点都不想说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「女孩子說的話特別能在社會上引起反響，如果是自然的嗓音就更有效果了。但是，這傢伙一點都不想說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00112",
		linknext = "0125_00114",
		line = 1364,
	},
	["0125_00114"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you did this? Locked her up underground to teach her a lesson? Tried to make her know her place?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你就把她关在地下，想藉由调教让她顺从吗——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你就把她關在地下，想藉由調教讓她順從嗎——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00113",
		linknext = "0125_00115",
		line = 1376,
	},
	["0125_00115"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0178", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“That did not work either. Bloody hell, she would have been the final push I needed to completely destroy Seiran Island...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“但没有效果。真是的，明明还差一步就能完全击垮青蓝岛了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「但沒有效果。真是的，明明還差一步就能完全擊垮青藍島了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00114",
		linknext = "0125_00116",
		line = 1388,
	},
	["0125_00116"] = {
		{"se", id=0, loop=0, file="se_a098"},
