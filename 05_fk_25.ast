		linkback = "0125_00164",
		linknext = "0125_00166",
		line = 2222,
	},
	["0125_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, here's some water. Drink it. Just take small, easy sips.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃，喝点水，静下心来，慢慢来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃，喝點水，靜下心來，慢慢來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00165",
		linknext = "0125_00167",
		line = 2234,
	},
	["0125_00167"] = {
