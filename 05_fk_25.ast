	},
	["0125_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I didn't just want happiness for myself! I wanted happiness for you too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“希望不仅仅是自己，而是连文乃都要一起幸福……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「希望不僅僅是自己，而是連文乃都要一起幸福……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00192",
		linknext = "0125_00194",
		line = 2550,
	},
	["0125_00194"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just wanted to fulfill that trivial little wish of yours— to give you a normal life and make you happy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你能达成自己小小的愿望——能够过上幸福的‘普通生活’，我就满足了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你能達成自己小小的願望——能夠過上幸福的『普通生活』，我就滿足了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00193",
		linknext = "0125_00195",
		line = 2562,
	},
	["0125_00195"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=4, size=10, time=50, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you risking your life to fulfill my own wish... That won't bring me any happiness!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然而你——不管你怎么献身实现我的愿望，我都不会高兴的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然而你——不管你怎麼獻身實現我的願望，我都不會高興的！！」",
