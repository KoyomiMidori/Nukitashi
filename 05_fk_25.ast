	["0125_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She'd already been frail for a long time, and she'd forced herself too hard now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她总是勉强着本来就很柔弱的身体——",
					{"rt2"},
