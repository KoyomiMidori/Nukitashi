		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0174", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“When a doll serves no further purpose to you, it is perfectly natural to throw it away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“——没用的人偶当然会被丢弃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——沒用的人偶當然會被丟棄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00105",
		linknext = "0125_00107",
		line = 1269,
	},
	["0125_00107"] = {
		{"se", id=0, loop=0, file="se_b032"},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
