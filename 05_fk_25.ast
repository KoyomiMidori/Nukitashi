astver = 2.0
ast = {
	["0125_00001"] = {
		{"fg", mode=-1, id=30},
		{"savetitle", text="献身心中", ja="献身心中", en="Mind, Body, and Soul", cn="身心俱呈", tw="獻身內心"},
		{"eval", exp="g.05_fk_25=1"},
		{"colortone", style="sepia"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg29_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"bgm", file="bgm22", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I always adored the view of the town from the top of the mountain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我很喜欢从山顶俯视城市的景色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我很喜歡從山頂俯視城市的景色。",
					{"rt2"},
				},
			},
		},
		linknext = "0125_00002",
		line = 21,
	},
	["0125_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I was little, I loved being able to see the view of the brilliant blue ocean, the lush verdant greenery, and the bustling activity of the people at a glance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小时候的我热爱广阔的大海、郁郁葱葱的树木，以及可以看到人们活力的风景。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小時候的我熱愛廣闊的大海、鬱鬱蔥蔥的樹木，以及可以看到人們活力的風景。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00001",
		linknext = "0125_00003",
		line = 31,
	},
	["0125_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Getting a bird's eye view of the island before dusk made me feel almost godlike, as though I could almost see everything happening.",
					{"rt2"},
				},
			},
			cn = {
				{
					"黄昏时分，我从这里鸟瞰小岛，仿佛自己成了上帝，可以看透一切。",
					{"rt2"},
				},
			},
			tw = {
				{
					"黃昏時分，我從這裡鳥瞰小島，彷彿自己成了上帝，可以看透一切。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00002",
		linknext = "0125_00004",
		line = 41,
	},
	["0125_00004"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0009", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "宮司"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Shintoist Priest"},
					"“There really is a god who lives here. One I've devoted my whole life to... a rather wistful sort of god.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "宫司"},
					"“这里真的有神灵。一位为了另一位神灵倾注一生的悲伤神灵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "宮司"},
					"「這裡真的有神靈。一位為了另一位神靈傾注一生的悲傷神靈。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00003",
		linknext = "0125_00005",
		line = 53,
	},
	["0125_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I still remember those kind words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那温柔的话语，我现在还记得。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那溫柔的話語，我現在還記得。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00004",
		linknext = "0125_00006",
		line = 63,
	},
	["0125_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I was little, I had nothing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小时候，我什么都没有。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小時候，我什麼都沒有。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00005",
		linknext = "0125_00007",
		line = 73,
	},
	["0125_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I lived with my mother in a little cabin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"天天都和母亲两人住在小屋里生活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"天天都和母親兩人住在小屋裡生活。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00006",
		linknext = "0125_00008",
		line = 83,
	},
	["0125_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wasn't able to play in the park like other children. All I did was spend my days looking down at the town.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也不能像其他孩子一样在公园玩，只能从山上眺望城市。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也不能像其他孩子一樣在公園玩，只能從山上眺望城市。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00007",
		linknext = "0125_00009",
		line = 93,
	},
	["0125_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, thanks to the kind shinto priest and my strong, yet gentle, mother who looked after me, I never once thought of it as unpleasant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，多亏了一直帮助我的亲切宫司先生，还有坚强温柔的母亲，我一次都没有觉得辛苦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，多虧了一直幫助我的親切宮司先生，還有堅強溫柔的母親，我一次都沒有覺得辛苦。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00008",
		linknext = "0125_00010",
		line = 103,
	},
	["0125_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I did not have a father.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父亲不在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父親不在。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00009",
		linknext = "0125_00011",
		line = 113,
	},
	["0125_00011"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“That man is a pitiful sort of person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“他啊，是个非常可怜的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「他啊，是個非常可憐的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00010",
		linknext = "0125_00012",
		line = 125,
	},
	["0125_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's how Mother described him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲是那样说父亲的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親是那樣說父親的。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00011",
		linknext = "0125_00013",
		line = 135,
	},
	["0125_00013"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0017", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“He thinks it's normal to live alone. That's how he sees his life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“他是个认为孤独是理所当然的人，是个认为那就是他自己的人生的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「他是個認為孤獨是理所當然的人，是個認為那就是他自己的人生的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00012",
		linknext = "0125_00014",
		line = 147,
	},
	["0125_00014"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0018", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“So my existence distorted his worldview. I'm certain I would have just been an obstacle to his dreams.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“所以，有我在的话他的心情就会动摇。那一定会妨碍他的梦想吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「所以，有我在的話他的心情就會動搖。那一定會妨礙他的夢想吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00013",
		linknext = "0125_00015",
		line = 159,
	},
	["0125_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Presumably that's why she left him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，母亲才会离开父亲的身边吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，母親才會離開父親的身邊嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00014",
		linknext = "0125_00016",
		line = 169,
	},
	["0125_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I'd forgotten that by now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到现在，我也已经搞不明白了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到現在，我也已經搞不明白了。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00015",
		linknext = "0125_00017",
		line = 179,
	},
	["0125_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mother was very methodical.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲是非常一丝不苟的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親是非常一絲不苟的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00016",
		linknext = "0125_00018",
		line = 189,
	},
	["0125_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was the one who taught me everything— how to conduct myself, how to cook, how to clean.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的一举一动都是她教的。教我做饭、洗衣服的，正是母亲。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的一舉一動都是她教的。教我做飯、洗衣服的，正是母親。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00017",
		linknext = "0125_00019",
		line = 199,
	},
	["0125_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I recall, she was also extremely tender-hearted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，我还记得她是一个非常温柔的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，我還記得她是一個非常溫柔的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00018",
		linknext = "0125_00020",
		line = 209,
	},
	["0125_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was that age where I began to understand that my existence was the cause of her being unable to live a normal life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个时候起——我就已经开始察觉到，是因为我的存在，才让母亲无法过上普通人的生活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個時候起——我就已經開始察覺到，是因為我的存在，才讓母親無法過上普通人的生活。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00019",
		linknext = "0125_00021",
		line = 219,
	},
	["0125_00021"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0019", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“That's not true at all. I'm alive now precisely because I have you. That's enough for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“没那回事。因为有文乃在，妈妈才能活下去。因为文乃一直在我身边——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「沒那回事。因為有文乃在，媽媽才能活下去。因為文乃一直在我身邊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00020",
		linknext = "0125_00022",
		line = 231,
	},
	["0125_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She always smiled. She was always energetic and cheerful. Like she didn't have a care in the world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总是笑着，有精神，开朗——就像世上没有痛苦的事一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總是笑著，有精神，開朗——就像世上沒有痛苦的事一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00021",
		linknext = "0125_00023",
		line = 241,
	},
	["0125_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even when she was going off to 'work' — all for my sake, I might add — she'd have a cheerful lilt in her step.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是为了扶养我，而去",
					{"ruby", text="・・"},
					"工作",
					{"/ruby"},
					"的时候，步伐也像要去散步一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是為了扶養我，而去",
					{"ruby", text="・・"},
					"工作",
					{"/ruby"},
					"的時候，步伐也像要去散步一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00022",
		linknext = "0125_00024",
		line = 251,
	},
	["0125_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even when people hurled horrible abuse at her, she'd just smile at me affectionately, as if she were just hearing a brook's gentle babble.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算被周围的人说了难听的话，也像听到了河流的水声般，脸上挂着充满慈爱的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算被周圍的人說了難聽的話，也像聽到了河流的水聲般，臉上掛著充滿慈愛的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00023",
		linknext = "0125_00025",
		line = 261,
	},
	["0125_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I grew up taking after her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着母亲那样的背影，我长大了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著母親那樣的背影，我長大了。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00024",
		linknext = "0125_00026",
		line = 271,
	},
	["0125_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But even Mother had just one regret.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，这样的母亲，也有一个遗憾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，這樣的母親，也有一個遺憾。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00025",
		linknext = "0125_00027",
		line = 281,
	},
	["0125_00027"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0020", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“Fumino... You know, I actually have the desire to devote myself to someone, just a little bit. It courses through my blood and keeps me going.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“文乃，妈妈的身上，流淌着一半希望为别人奉献的血。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「文乃，媽媽的身上，流淌著一半希望為別人奉獻的血。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00026",
		linknext = "0125_00028",
		line = 293,
	},
	["0125_00028"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0021", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“I did find someone I wanted to devote myself to... but it was not to be for us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“我找到了一位愿意为他尽心尽力的人，但是——却没能和他在一起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「我找到了一位願意為他盡心盡力的人，但是——卻沒能和他在一起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00027",
		linknext = "0125_00029",
		line = 305,
	},
	["0125_00029"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0022", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“And... I feel just a little sad about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“只有这点……让我有点悲伤……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「只有這點……讓我有點悲傷……」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00028",
		linknext = "0125_00030",
		line = 317,
	},
	["0125_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those words resonated strongly, even to my own childish heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"类似独白的话语，强烈地震撼了我幼小的心灵。",
					{"rt2"},
				},
			},
			tw = {
				{
					"類似獨白的話語，強烈地震撼了我幼小的心靈。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00029",
		linknext = "0125_00031",
		line = 327,
	},
	["0125_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Surely she must have been searching for someone all this time. Even in that moment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妈妈一定在找某个人。就连现在也是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"媽媽一定在找某個人。就連現在也是。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00030",
		linknext = "0125_00032",
		line = 337,
	},
	["0125_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So when she went outside and someone would call to her... even if it was just the usual abuse, she still desired someone's contact.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以就算她在外面走着，即使有人叫她，有时候还被说些恶劣的话语，她还是在找着某个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以就算她在外面走著，即使有人叫她，有時候還被說些惡劣的話語，她還是在找著某個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00031",
		linknext = "0125_00033",
		line = 347,
	},
	["0125_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Mother was hardly alone in that regard.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，那不只是母亲。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，那不只是母親。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00032",
		linknext = "0125_00034",
		line = 357,
	},
	["0125_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everyone wants the company of another.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人们都在寻找着某个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人們都在尋找著某個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00033",
		linknext = "0125_00035",
		line = 367,
	},
	["0125_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's human nature to want to search for that which money can't buy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人类总是在寻找着某个不可替代的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人類總是在尋找著某個不可替代的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00034",
		linknext = "0125_00036",
		line = 377,
	},
	["0125_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"One time, the shinto priest said this to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有一天，宫司先生如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有一天，宮司先生如此說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00035",
		linknext = "0125_00037",
		line = 387,
	},
	["0125_00037"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0010", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "宮司"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Shintoist Priest"},
					"“Gods are clairvoyant, so they can always see everything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "宫司"},
					"“——因为神有千里眼，所以一切都看得一清二楚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "宮司"},
					"「——因為神有千里眼，所以一切都看得一清二楚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00036",
		linknext = "0125_00038",
		line = 399,
	},
	["0125_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I wished for the same sort of power.",
					{"rt2"},
				},
