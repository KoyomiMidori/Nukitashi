		line = 2632,
	},
	["0125_00201"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Stop believing that it's okay to throw your own life away...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要再觉得……自己一个人成为牺牲品也没关系了……”",
