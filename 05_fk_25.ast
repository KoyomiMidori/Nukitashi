		},
		linkback = "0125_00046",
		linknext = "0125_00048",
		line = 536,
	},
	["0125_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never been the type to cry. Even as a kid, apparently.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从以前开始，好像就是个几乎不哭的孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從以前開始，好像就是個幾乎不哭的孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00047",
		linknext = "0125_00049",
		line = 546,
	},
	["0125_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I received gifts, got scolded, or got hurt, I did not cry.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使没收到礼物，被骂了，受伤了，都没有哭过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使沒收到禮物，被罵了，受傷了，都沒有哭過。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00048",
		linknext = "0125_00050",
		line = 556,
	},
	["0125_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had never recalled shedding tears of sadness up to that point.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自己是个没有悲伤哭泣的记忆的孩子。",
