	["0125_00172"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1097", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Why... are you... here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“为什、么……您……会在这里……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「為什、麼……您……會在這裡……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00171",
		linknext = "0125_00173",
		line = 2302,
	},
	["0125_00173"] = {
		{"se", id=0, loop=0, file="se_b045"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Because you called for me, Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为你呼唤了我，文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為你呼喚了我，文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00172",
		linknext = "0125_00174",
		line = 2315,
	},
	["0125_00174"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Remember how you told me before that wherever I am, if I call for you, you'll come running?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“之前你不是说过吗，只要我叫你，你就会从任何地方赶过来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「之前你不是說過嗎，只要我叫你，你就會從任何地方趕過來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00173",
		linknext = "0125_00175",
		line = 2327,
	},
	["0125_00175"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I'm just returning the favor. If you call for me, I'll come running to you. That's all there is to it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我也是，只要文乃叫我，我什么地方都会去。仅此而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我也是，只要文乃叫我，我什麼地方都會去。僅此而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00174",
		linknext = "0125_00176",
		line = 2339,
	},
	["0125_00176"] = {
