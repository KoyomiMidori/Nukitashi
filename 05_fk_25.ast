	},
	["0125_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But watching Mother fade away and die before my eyes caused the tears to gush forth profusely enough to smear my vision.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是看到母亲的死，我第一次流下了模糊视线的眼泪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是看到母親的死，我第一次流下了模糊視線的眼淚。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00050",
		linknext = "0125_00052",
		line = 576,
	},
	["0125_00052"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0025", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“I have to leave you now... But I sincerely hope you can meet someone you can trust.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“……希望被留下的文乃……可以遇到……能够打从心底信任的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「……希望被留下的文乃……可以遇到……能夠打從心底信任的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00051",
		linknext = "0125_00053",
		line = 588,
	},
	["0125_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She said to me in a fading voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲用微弱的声音说着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親用微弱的聲音說著。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00052",
		linknext = "0125_00054",
		line = 598,
	},
	["0125_00054"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0026", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "Mother"},
					"“Whomever you find, if you devote yourself to them completely, in heart and soul... They will surely stay with you, and bring you happiness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "母亲"},
					"“只要对自己找到的人尽心尽力……那那个人一定会把你一直留在身边……给你幸福的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "母親"},
					"「只要對自己找到的人盡心盡力……那那個人一定會把你一直留在身邊……給你幸福的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00053",
		linknext = "0125_00055",
		line = 610,
	},
	["0125_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She did not want her daughter to inherit her sadness by being unable to achieve what she herself could not.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像不想自己没完成的事情——自己的不幸，让女儿继承一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像不希望自己沒完成的事情——自己的不幸，讓女兒繼承一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00054",
		linknext = "0125_00056",
		line = 620,
	},
	["0125_00056"] = {
		{"text"},
		text = {
