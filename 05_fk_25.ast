	["0125_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, Fumino just stares vacantly at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是文乃本人却一脸茫然地看着我。",
					{"rt2"},
				},
