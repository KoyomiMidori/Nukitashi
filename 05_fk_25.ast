					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「你在擔心什麼呢。啊，我有好好把處女膜留下來。我想你一定會高興的……唔哈哈哈哈……！」",
					{"rt2"},
