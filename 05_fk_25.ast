					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「來了哥哥——！目視確認，正面兩隊，共計8，裝備實槍，手槍3，衝鋒槍5——接觸！」",
					{"rt2"},
				},
			},
		},
