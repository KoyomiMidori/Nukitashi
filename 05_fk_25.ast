	["0125_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had a hunch she would react this way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃从一开始就知道会变成这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃從一開始就知道會變成這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00182",
		linknext = "0125_00184",
		line = 2433,
	},
	["0125_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's a proud servant that would go to any lengths to fulfill her master's desires.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她是个无论什么愿望，都会为主人实现的全能佣人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她是個無論什麼願望，都會為主人實現的全能傭人。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00183",
		linknext = "0125_00185",
		line = 2443,
	},
	["0125_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She would take any measure, under any circumstance, to achieve her goals. As a 'humble and faithful Sakimori.'",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论是任何难题，“犬马防人”都会用尽任何手段来完成。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論是任何難題，「犬馬防人」都會用盡任何手段來完成。",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00184",
		linknext = "0125_00186",
		line = 2453,
	},
	["0125_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why she did this to fulfill my wish.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以文乃为了实现我的愿望——",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以文乃為了實現我的願望——",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00185",
		linknext = "0125_00187",
		line = 2463,
	},
	["0125_00187"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
