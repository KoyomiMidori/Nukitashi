				{
					name = {"光姫", "Kouki"},
					"“Si puedes eyacular en el sexo sin protección, habrás demostrado tu inocencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“如果可以无套射精，那你这次的清白将被证明。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「如果可以無套射精，那你這次的清白將被證明。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00458",
		linknext = "0015_00460",
		line = 6095,
	},
	["0015_00460"] = {
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00103", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0034", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“¡Pero si eres un no-copulador, te obligaré a confesar tus \ncrímenes mediante una eyaculación pura y brutal!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“如果你是反交尾势力，那你将在这里与射精一同将邪恶的东西吐出来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「如果你是反交尾勢力，那你將在這裡與射精一同將邪惡的東西吐出來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00459",
		linknext = "0015_00461",
		line = 6109,
	},
	["0015_00461"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sea como sea, me van a follar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论哪种方法，我都无法摆脱做爱——",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論哪種方法，我都無法擺脫做愛——",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00460",
		linknext = "0015_00462",
		line = 6119,
	},
	["0015_00462"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No tengo armas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——我没有带什么武器呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——我沒有帶什麼武器呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00461",
		linknext = "0015_00463",
		line = 6131,
	},
	["0015_00463"] = {
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00103", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0035", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“En ese caso, puedes simplemente darme una erección, ¿sí? Si te vas a negar—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“那么，你能勃起吗？如果你拒绝，你就是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「那麼，你能勃起嗎？如果你拒絕，你就是——」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00462",
		linknext = "0015_00464",
		line = 6145,
	},
	["0015_00464"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
