	["0015_00399"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0068", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "女A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Mujer A"},
					"“Ah, Me alegra haberte atrapado... Me excito mucho viendo \ncómo violan a alguien. Mi coño tenía ganitas ",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "A女"},
					"“啊啊，还好抓到的是你……我一看到强奸马上就会湿掉，所以很困扰……小穴一直好疼好疼……",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "A女"},
					"「啊啊，還好抓到的是你……我一看到強姦馬上就會濕掉，所以很困擾……小穴一直好疼好疼……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00398",
		linknext = "0015_00400",
		line = 5334,
	},
