	},
	["0015_00090"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00125", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo estoy pensando en el origen de los gusanos cerebrales.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没事，只是想知道原因——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒事，只是想知道原因——」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00089",
		linknext = "0015_00091",
		line = 1211,
	},
	["0015_00091"] = {
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me mira con confusión y ladea la cabeza, pero no insiste más.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑困惑着歪着脑袋，但没有再说下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨困惑著歪著腦袋，但沒有再說下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00090",
		linknext = "0015_00092",
		line = 1222,
	},
	["0015_00092"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00114", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0481", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Jaa. Hoy he estado huyendo de todas las formas posibles del Lanzaamiento, y luego mi hermano se me adelantó... Hoy es un día en el que se me acumulan las desgracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哈……经历了逃脱‘击坠王’，还看到哥哥踏出新的一步，各种令人震惊的事情都在今天发生……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哈……經歷了逃脫『擊墜王』，還看到哥哥踏出新的一步，各種令人震驚的事情都在今天發生……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00091",
		linknext = "0015_00093",
		line = 1237,
	},
	["0015_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero lo último fue un malentendido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“其中一半是你的误解好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「其中一半是你的誤會好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00092",
		linknext = "0015_00094",
		line = 1248,
	},
	["0015_00094"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0480", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Cómo llegaste aquí? ¿Intentaron hacerte algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“麻沙酱是怎么来到这里的？应该有被其他人约吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「麻沙醬是怎麼來到這裡的？應該有被其他人約吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00093",
		linknext = "0015_00095",
		line = 1262,
	},
	["0015_00095"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0482", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí, pero... Los distraje con acertijos y usé esa oportunidad para huir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我是被约了……但我设置了一个谜语，乘机逃出来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我是被約了……但我設置了一個謎語，乘機逃出來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00094",
		linknext = "0015_00096",
		line = 1276,
	},
	["0015_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿De casualidad llevabas un traje verde con signos de interrogación?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谜语是用来设置的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謎語是用來設置的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00095",
		linknext = "0015_00097",
		line = 1288,
	},
	["0015_00097"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0481", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Eh? ¿Qué clase de acertijos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嘿，你设置的谜语是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嘿，你設置的謎語是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00096",
		linknext = "0015_00098",
		line = 1302,
	},
	["0015_00098"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0483", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Las papas, son un alimento básico. ¿Qué papa debes comer para volverte más lascivo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“土豆中最色情的女王是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「土豆中最色情的女王是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00097",
		linknext = "0015_00099",
		line = 1316,
	},
	["0015_00099"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0482", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mmm, ni idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯——是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯——是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00098",
		linknext = "0015_00100",
		line = 1330,
	},
	["0015_00100"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0484", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Respuesta: Cremas blancas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“答案是生土豆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「答案是生土豆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00099",
		linknext = "0015_00101",
		line = 1344,
	},
	["0015_00101"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y yo que pensaba que mis bromas eran malas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我妹妹真无聊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我妹妹真無聊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00100",
		linknext = "0015_00102",
		line = 1356,
	},
	["0015_00102"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0483", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pero si ignoran los acertijos y siguen insistiendo, ¿qué haces?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是，你如何对付那些无视谜语想要强行发生关系的人呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是，你如何對付那些無視謎語想要強行發生關係的人呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00101",
		linknext = "0015_00103",
		line = 1368,
	},
	["0015_00103"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00113", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0485", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pedir sexo es facilísimo, pero si sigues con esa actitud,\nmorirás.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这就是你求我做爱的态度？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這就是你求我做愛的態度？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00102",
		linknext = "0015_00104",
		line = 1382,
	},
	["0015_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero vaya dedicación, de verdad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“厉害。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「厲害。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00103",
		linknext = "0015_00105",
		line = 1394,
	},
	["0015_00105"] = {
		{"se", id=0, loop=0, file="se_a112"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0484", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No te olvides de la presunción...”",
