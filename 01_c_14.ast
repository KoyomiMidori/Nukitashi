					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Considerando su habitual popularidad, puedo entender por qué estaría agotada desde que comenzó el evento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从她平常受欢迎的程度来看，就可以理解活动开始之后奈奈濑为什么会疲惫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從她平常受歡迎的程度來看，就可以理解活動開始之後奈奈瀨為什麼會疲憊。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00039",
		linknext = "0015_00041",
		line = 512,
	},
	["0015_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mucha gente se le debió acercar y está a punto de poner fin a todo esto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"肯定有数也数不清的人要约她打炮吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"肯定有數也數不清的人要約她打炮吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00040",
		linknext = "0015_00042",
		line = 522,
	},
	["0015_00042"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0465", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡¿Por qué los condones son tan difíciles de estirar?! ¡Hacerlos uno a uno es un fastidio!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话说要把安全套拉长怎么这么难啊……！？每个都好麻烦啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話說要把保險套拉長怎麼這麼難啊……！？每個都好麻煩啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00041",
		linknext = "0015_00043",
		line = 536,
	},
	["0015_00043"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es que no sabes hacerlo bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为你拉长的方法不对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是因為你拉長的方法不對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00042",
		linknext = "0015_00044",
		line = 548,
	},
	["0015_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mira, no debes jalarlo con la mano. Debes colocarlo sobre el glande y deslizarlo hacia abajo con los dedos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不能那样用手拉，要这样把它戴在龟头的顶端，然后用手一转。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不能那樣用手拉，要這樣把它戴在龜頭的頂端，然後用手一轉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00043",
		linknext = "0015_00045",
		line = 559,
	},
	["0015_00045"] = {
