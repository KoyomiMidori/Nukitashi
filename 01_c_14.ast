		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aquí ATM-01. Necesito la base.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这里是",
					{"ruby", text="原子"},
					" AT",
					{"/ruby"},
					"M-01。基地，能听到吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這裡是",
					{"ruby", text="原子"},
					" AT",
					{"/ruby"},
					"M-01。基地，能聽到嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00243",
		linknext = "0015_00245",
		line = 3239,
	},
	["0015_00245"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0493", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aquí Null Base, te recibo fuerte y claro. ¿Cuál es tu situación?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这里是Null基地，感应良好。那边呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這裡是Null基地，感應良好。那邊呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00244",
		linknext = "0015_00246",
		line = 3252,
	},
	["0015_00246"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La voz de Asane se escucha en el pequeño auricular que tengo en la oreja.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱的声音从耳朵里戴着的小型耳机中传出。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬的聲音從耳朵裡戴著的小型耳機中傳出。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00245",
		linknext = "0015_00247",
		line = 3262,
	},
	["0015_00247"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No ha pasado nada. ¿Puedes obtener algún dato posicional de la persona con estado de virginidad desconocida con la que me encontré hace poco?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这边也没有问题。刚才发给你的地区里的处女躯不明器的位置情报数据取得了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這邊也沒有問題。剛才發給你的地區裡的處女軀不明器的位置情報數據取得了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00246",
		linknext = "0015_00248",
		line = 3274,
	},
	["0015_00248"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0494", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Datos adquiridos. Es una persona manejando a 8 km/h en las montañas, hay cuatro personas persiguiéndola. No se han avistado otros enemigos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“已取得。山中有一个以大约8公里/小时的速度行进的物体，后面有4个追逐其的物体。此外没有其他敌人的身影。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「已取得。山中有一個以大約8公里/小時的速度行進的物體，後面有4個追逐其的物體。此外沒有其他敵人的身影。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00247",
		linknext = "0015_00249",
		line = 3286,
	},
	["0015_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Envía esa ubicación a mi HIS, voy a seguirla. ¿Alguna otra información?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“将位置信息发到HIS并继续跟踪。其他信息呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「將位置資訊發到HIS並繼續跟踪。其他資訊呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00248",
		linknext = "0015_00250",
		line = 3297,
	},
	["0015_00250"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0495", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ya la estoy mandando a tu HIS. Debido a la falta de cámaras de seguridad en las montañas, no hay información del IAE.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“将信息传输到HIS。由于山上没有岛上的防犯摄像头，所以IFF没有反应。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「將資訊傳輸到HIS。由於山上沒有島上的防犯攝影機，所以IFF沒有反應。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00249",
		linknext = "0015_00251",
		line = 3310,
	},
	["0015_00251"] = {
		{"se", id=0, loop=0, file="se_a020"},
