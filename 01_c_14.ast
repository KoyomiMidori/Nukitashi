		line = 5997,
	},
	["0015_00451"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si mis sospechas son correctas, esa chica es una no-copuladora como nosotros.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果我的猜测是对的，那个女孩应该跟我们一样是反交尾势力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果我的猜測是對的，那個女孩應該跟我們一樣是反交尾勢力。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00450",
		linknext = "0015_00452",
		line = 6007,
	},
	["0015_00452"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo que significaría que ha estado evitando el sexo todo este tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，她到现在都特意在回避做爱。",
