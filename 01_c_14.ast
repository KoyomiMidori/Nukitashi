					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Geez... You really should take up exercising, get some more stamina into that constitution of— Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是的……你要是不再运动增强体力的话——嗯？”",
