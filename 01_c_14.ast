			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Let's see... it's not waxing just yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊——",
					{"ruby", text="・・・・・・"},
