	["0015_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los anuncios suelen decir, “¡Afrodisíaco altamente eficaz! \n¡También funciona muy bien como rotulador mágico para escribir obscenidades en tu cuerpo o llevar la cuenta!”",
					{"rt2"},
				},
			},
			cn = {
				{
					"写着“催淫效果一级棒！可以用来写淫语的身体用正字马克催淫笔！”的旗帜立在一旁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"寫著「催淫效果一級棒！可以用來寫淫語的身體用正字馬克催淫筆！」的旗幟立在一旁。",
					{"rt2"},
