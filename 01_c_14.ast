					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Están muy grandes... Me están diciendo “queremos corrernos, queremos corrernos”... Tendré que ayudarlas, ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“蛋蛋……都涨起来了呢……它是不是在说‘我想出去〜我想出去〜’呢……？那放它出去好吗？嗯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「蛋蛋……都漲起來了呢……它是不是在說『我想出去〜我想出去〜』呢……？那放它出去好嗎？嗯？」",
					{"rt2"},
				},
			},
		},
