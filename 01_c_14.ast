			cn = {
				{
					name = {"モブ男D", "C男"},
					"“像你这样岛上的淫乱女，只要向我们分开双腿然后啊啊叫就可以了！知道吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "C男"},
					"「像你這樣島上的淫亂女，只要向我們分開雙腿然後啊啊叫就可以了！知道嗎！？」",
					{"rt2"},
