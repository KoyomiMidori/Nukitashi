	},
	["0015_00091"] = {
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gives me a confused look and tilts her head, but doesn't press the issue any further.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑困惑着歪着脑袋，但没有再说下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨困惑著歪著腦袋，但沒有再說下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00090",
		linknext = "0015_00092",
		line = 1222,
	},
	["0015_00092"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00114", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0481", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sigh. Today I've been running every which way from this Shootdown bullshit, and then my bro got ahead of me... today's just one calamity after another.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哈……经历了逃脱‘击坠王’，还看到哥哥踏出新的一步，各种令人震惊的事情都在今天发生……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哈……經歷了逃脫『擊墜王』，還看到哥哥踏出新的一步，各種令人震驚的事情都在今天發生……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00091",
		linknext = "0015_00093",
		line = 1237,
	},
	["0015_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That second one was your misunderstanding, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“其中一半是你的误解好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「其中一半是你的誤會好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00092",
		linknext = "0015_00094",
		line = 1248,
	},
	["0015_00094"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0480", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So how were you able to get here? Anybody try to make a move on you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“麻沙酱是怎么来到这里的？应该有被其他人约吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「麻沙醬是怎麼來到這裡的？應該有被其他人約吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00093",
		linknext = "0015_00095",
		line = 1262,
	},
	["0015_00095"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0482", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, but... I managed to distract them with some riddles and used the opportunity to get away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我是被约了……但我设置了一个谜语，乘机逃出来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我是被約了……但我設置了一個謎語，乘機逃出來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00094",
		linknext = "0015_00096",
		line = 1276,
	},
	["0015_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Were you wearing a green suit with question marks on it, by any chance?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谜语是用来设置的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謎語是用來設置的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00095",
		linknext = "0015_00097",
		line = 1288,
	},
	["0015_00097"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0481", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh? What kind of riddles?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
