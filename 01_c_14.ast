	["0015_00441"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0028", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "???"},
					"“Me llamo Senba Kouki, soy del Grupo de Relaciones Públicas de la OSS, formo parte de la División de Publicidad, así como las Divisiones de Orden Público y Combate Especial.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "？ ？ ？"},
					"“我的名字是仙波光姬。SHO广播委员会宣传实行部门，兼治安管理委员会特殊战斗部的成员。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "？？？"},
					"「我的名字是仙波光姬。SHO推廣委員會宣傳執行部，兼治安管理委員會特殊戰鬥部的成員。」",
					{"rt2"},
				},
			},
		},
