		line = 2505,
	},
	["0015_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase's been in charge of buying our daily necessities for a while now, so shopping for consumables isn't needed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最近奈奈濑买了日用品，所以我没有去买消耗品。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最近奈奈瀨買了日用品，所以我沒有去買消耗品。",
