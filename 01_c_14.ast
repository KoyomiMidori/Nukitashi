		line = 6027,
	},
	["0015_00454"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y podría resultarle más difícil evitar el sexo pervertido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么——以后想要回避做爱的话，会更困难吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼——以後想要迴避做愛的話，會更困難吧。",
					{"rt2"},
				},
			},
