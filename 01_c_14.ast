					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "B男"},
					"「哈哈，但我們說的沒錯吧？這些人都是通過做愛在賺錢，對此我們很羨慕呢〜所以……」",
					{"rt2"},
