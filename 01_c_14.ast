				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? I think my dad used to be like that... What about it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯？我爸爸好像是……为什么问这个？”",
