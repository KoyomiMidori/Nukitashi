		line = 2558,
	},
	["0015_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That way, Nanase wouldn't be able to pull the kind of scheme she's pulling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话，就没有人会像奈奈濑那样作弊了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話，就沒有人會像奈奈瀨那樣作弊了。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00189",
		linknext = "0015_00191",
		line = 2568,
	},
	["0015_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know you're probably wondering, why don't they do that? Well, the thing is, it'd deprive the girls of the thrill of being in charge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是说到为什么不发给男孩，似乎是为了避免失去女孩用嘴帮忙带套的美妙感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是說到為什麼不發給男孩，似乎是為了避免失去女孩用嘴幫忙戴套的美妙感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00190",
		linknext = "0015_00192",
		line = 2578,
	},
	["0015_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Plus, a girl carrying condoms around has something intrinsically seductive to it that a guy couldn't hope to possess.",
					{"rt2"},
				},
			},
			cn = {
				{
					"此外，据说拿着安全套的女孩是一种煽情的存在，所以才没有给男孩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"此外，據說拿著保險套的女孩是一種煽情的存在，所以才沒有給男孩。",
					{"rt2"},
