		},
		linkback = "0015_00096",
		linknext = "0015_00098",
		line = 1302,
	},
	["0015_00098"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0483", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Potatoes, they're truly a staple food. Which type should you eat to become more lewd?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“土豆中最色情的女王是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「土豆中最色情的女王是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00097",
		linknext = "0015_00099",
		line = 1316,
	},
	["0015_00099"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0482", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
