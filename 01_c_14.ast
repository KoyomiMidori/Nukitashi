					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And here I thought my jokes sucked.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我妹妹真无聊……”",
					{"rt2"},
				},
