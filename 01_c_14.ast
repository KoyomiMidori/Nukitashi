	["0015_00134"] = {
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0489", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Eh? ¿Te estás asustando?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哎呀，难道渡酱害怕吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哎呀，難道渡醬害怕嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00133",
		linknext = "0015_00135",
		line = 1806,
	},
	["0015_00135"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0301", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡N-No! ¡Soy la mayor, y si les pasa algo, tendré que cuidarlos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我、我不害怕……！作为长辈，如果有什么事情我必须保护大家……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我、我不害怕……！作為長輩，如果有什麼事情我必須保護大家……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00134",
		linknext = "0015_00136",
		line = 1821,
	},
	["0015_00136"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0489", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Espero que la oscuridad te dé mucho sueño. Si es que eres toda una loli.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“渡酱在昏暗的地方会想睡觉吧，因为是萝莉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「渡醬在昏暗的地方會想睡覺吧，因為是蘿莉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00135",
		linknext = "0015_00137",
		line = 1834,
	},
	["0015_00137"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0302", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡No soy una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00136",
		linknext = "0015_00138",
		line = 1849,
	},
	["0015_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Shh! Silencio, chicas. Estamos en medio de una operación estratégica.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嘘，你们太放松了。不要忘记我们在作战行动当中。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「噓，你們太放鬆了。不要忘記我們在作戰行動當中。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00137",
		linknext = "0015_00139",
		line = 1861,
	},
	["0015_00139"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=100},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Poco después, me detengo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过了一会儿，我停了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過了一會，我停了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00138",
		linknext = "0015_00140",
		line = 1879,
	},
	["0015_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hemos llegado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00139",
		linknext = "0015_00141",
		line = 1890,
	},
	["0015_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Frente a nosotros está la puerta trasera. ¿Ves esos agujeros a la izquierda y a la derecha?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果往前走就是后门……但左右各有一个通往其他地方的洞对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果往前走就是後門……但左右各有一個通往其他地方的洞對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00140",
		linknext = "0015_00142",
		line = 1902,
	},
	["0015_00142"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0303", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ay, tienes razón! No me di cuenta en la oscuridad, pero sí vi unos agujeritos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，真的诶……！因为太暗了，完全没有发现有一个小洞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，真的欸……！因為太暗了，完全沒有發現有一個小洞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00141",
		linknext = "0015_00143",
		line = 1916,
	},
	["0015_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, salen en lugares diferentes. Ese lado va a un acantilado y a un callejón sin salida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这两个洞通向不同的地方。一个是通向悬崖断壁。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這兩個洞通向不同的地方。一個是通向懸崖斷壁。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00142",
		linknext = "0015_00144",
		line = 1928,
	},
	["0015_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En cuanto a lo otro, te llevaré al océano.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“另一个是大海。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「另一個是大海。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00143",
		linknext = "0015_00145",
		line = 1939,
	},
	["0015_00145"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0304", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Océano? ¿Vamos a nadar y salir de aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“大海……？那么，难道要游出去？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「大海……？那麼，難道要遊出去？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00144",
		linknext = "0015_00146",
		line = 1953,
	},
	["0015_00146"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por supuesto que no. Te perderías y te ahogarías con lo oscuro que está. Acompáñame.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么可能。如果在如此黑暗的地方游泳的话，很快就会失去方向感淹死的——这边。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼可能。如果在如此黑暗的地方游泳的話，很快就會失去方向感淹死的——這邊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00145",
		linknext = "0015_00147",
		line = 1965,
	},
	["0015_00147"] = {
		{"se", id=0, loop=0, file="se_a027"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nos movemos lentamente en la ruta del océano.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们沿着大海路线慢慢往前走。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們沿著大海路線慢慢往前走。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00146",
		linknext = "0015_00148",
		line = 1983,
	},
	["0015_00148"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al cabo de un rato llegamos a una amplia extensión.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过了一会儿，到了一个空旷的空间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過了一會，到了一個空曠的空間。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00147",
		linknext = "0015_00149",
		line = 2000,
	},
	["0015_00149"] = {
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0305", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vaya, qué grande. Ah, ahí está el océano... Espera, parece que es más un río, ¿no? ¿Puedo escuchar sus movimientos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇，这边好空旷啊。啊，大海也……比起大海，看起来比较像一条河？只有一些水在流动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇，這邊好空曠啊。啊，大海也……比起大海，看起來比較像一條河？只有一些水在流動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00148",
		linknext = "0015_00150",
		line = 2014,
	},
	["0015_00150"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora mismo estamos cerca de la luna nueva, por lo que hay marea baja.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是因为现在快要新月了，是退潮的时候。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是因為現在快要新月了，是退潮的時候。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00149",
		linknext = "0015_00151",
		line = 2026,
	},
	["0015_00151"] = {
		{"fgact", ch="ヒナミ", id=5, act="移動", x=400, y=0, time=700},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=400, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=600},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0490", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“La marea cambia según las fases de la luna, y este lugar suele estar sumergido bajo el agua. No se puede pasar por aquí en determinados días y horas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“根据月亮的满亏，水位会发生变化，所以这里平常在海里。这是一条不选择时期和时间的情况下无法走的路线。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「根據月亮的滿虧，水位會發生變化，所以這裡平常在海裡。這是一條不選擇時期和時間的情況下無法走的路線。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00150",
		linknext = "0015_00152",
		line = 2041,
	},
	["0015_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque gracias a eso, nadie te verá aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“相对的，也没有人能找到它。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「相對的，也沒有人能找到它。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00151",
		linknext = "0015_00153",
		line = 2053,
	},
	["0015_00153"] = {
		{"se", id=0, loop=0, file="se_a027"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La pared rocosa está ligeramente húmeda y cada uno de nuestros pasos produce un sonido de salpicadura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岩石已经有些湿了，每次走路都发出声响。",
					{"rt2"},
				},
			},
			tw = {
				{
					"岩石已經有些濕了，每次走路都發出聲響。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00152",
		linknext = "0015_00154",
		line = 2064,
	},
	["0015_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Probablemente sea el último día en que podamos tomar esta ruta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这条路线大概会在最后一天完全消失吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這條路線大概會在最後一天完全消失吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00153",
		linknext = "0015_00155",
		line = 2074,
	},
	["0015_00155"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bgm", file="bgm02", vol=100},
		{"se", id=0, loop=0, file="se_a035"},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00114", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0306", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Qué brillante... Fiuu... Por fin salimos de la cueva...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜哦，好耀眼……哈啊，咿……我们终于走出山洞了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚哦，好耀眼……哈啊，咿……我們終於走出山洞了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00154",
		linknext = "0015_00156",
		line = 2102,
	},
	["0015_00156"] = {
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0306b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? Esto es el otro lado de la playa, ¿no? ¿Es la ladera que da al mar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……咦，这里是海滩的反方向，山之手的靠海那一侧对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……咦，這裡是海灘的反方向，山之手的靠海那一側對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00155",
		linknext = "0015_00157",
		line = 2118,
	},
	["0015_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, ¿conoces este lugar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对，你怎么知道？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對，你怎麼知道？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00156",
		linknext = "0015_00158",
		line = 2130,
	},
	["0015_00158"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0307", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí. Mis abuelos viven en la ladera, aunque nunca había llegado aquí. Estamos bastante lejos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，我爷爷和奶奶都是山之手人。不过我没来过这边，因为这里很远。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，我爺爺和奶奶都是山之手人。不過我沒來過這邊，因為這裡很遠。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00157",
		linknext = "0015_00159",
		line = 2144,
	},
	["0015_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta ruta es muy remota en cuanto a su ubicación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的，这条路线会带我们到非常偏僻的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的，這條路線會帶我們到非常偏僻的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00158",
		linknext = "0015_00160",
		line = 2154,
	},
	["0015_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es la región menos desarrollada de la isla, donde el mar se encuentra con las montañas circundantes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上最不发达，且与大海以及周围山脉相连的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上最不發達，且與大海以及周圍山脈相連的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00159",
		linknext = "0015_00161",
		line = 2164,
	},
	["0015_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Además, ninguno de los caminos está pavimentado, por lo que tardarías mucho tiempo en llegar a casa desde aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"此外，这里连道路都没有铺设，所以从这里回家需要一段时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"此外，這裡連道路都沒有鋪設，所以從這裡回家需要一段時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00160",
		linknext = "0015_00162",
		line = 2174,
	},
	["0015_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es una ruta muy práctica para caminar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想要步行的话，这不是条实用的路线。",
