	},
	["0015_00467"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora mismo estoy un poco impotente. No se me para.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那个，我现在有些阳痿。硬不太起来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那個，我現在有些陽痿。硬不太起來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00466",
		linknext = "0015_00468",
		line = 6190,
	},
	["0015_00468"] = {
		{"bgm", file="bgm04", vol=100},
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00109", file2="kouki_01l_00202", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="kouki_01m_00001", file1="kouki_01m_00102", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="kouki0036", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“¿Eh? ¡Aah! ¡Por eso es que no me querías responder! ¡Veo, veo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“诶……啊！这样啊，所以你没法回答……！啊——原来如此原来如此！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「欸……啊！這樣啊，所以你沒法回答……！啊——原來如此原來如此！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00467",
		linknext = "0015_00469",
		line = 6209,
	},
	["0015_00469"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00111", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0037", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Te pido disculpas. A los hombres les preocupa mucho no poder tener una erección... Los chicos deben sentirse igual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“那真是很抱歉。男性会对自己无法勃起一事感到十分在意……男孩子也是一样的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「那真是很抱歉。男性會對自己無法勃起一事感到十分在意……男孩子也是一樣的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00468",
		linknext = "0015_00470",
		line = 6223,
	},
	["0015_00470"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me muestra una expresión tierna y cariñosa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仙波警卫忽然露出温柔和善的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仙波警衛忽然露出溫柔和善的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00469",
		linknext = "0015_00471",
		line = 6233,
	},
	["0015_00471"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estoy intentando mejorarlo levantando pesas... pero no me está ayudando mucho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我有尝试过努力锻炼什么的……但还是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我有嘗試過努力鍛煉什麼的……但還是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00470",
		linknext = "0015_00472",
		line = 6245,
	},
	["0015_00472"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00106", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
