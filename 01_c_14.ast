		{"fgact", ch="ヒナミ", id=5, act="移動", x=-400, y=0, time=700},
		{"fg", file="asane_01m_00001", file1="asane_01m_00114", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0490", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Eep... I gotta walk a fuckin' death march now... This hill's too steep, and I am chafing in my thighs right now... Bro, piggyback...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嘤……从现在开始要走一大段路吗……而且还是非常陡峭的路，这对大腿的负担很大……哥哥，背我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嚶……從現在開始要走一大段路嗎……而且還是非常陡峭的路，這對大腿的負擔很大……哥哥，背我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00163",
		linknext = "0015_00165",
		line = 2211,
	},
	["0015_00165"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You should be ashamed of yourself. You're the big sister here, and this little girl here's walking better than you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么小的小孩子都在好好走路哦？作为姐姐的你不害羞吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼小的小孩子都在好好走路哦？作為姐姐的你不害羞嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00164",
		linknext = "0015_00166",
		line = 2223,
	},
	["0015_00166"] = {
