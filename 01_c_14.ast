			tw = {
				{
					"也就是說，她到現在都特意在迴避做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00451",
		linknext = "0015_00453",
		line = 6017,
	},
	["0015_00453"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si dijera la verdad, sería moralmente repugnante, podría ponerla en peligro.",
