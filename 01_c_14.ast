					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien, ahora estoy bajando la colina... Estoy en un lugar muy abierto.”",
					{"rt2"},
				},
			},
			cn = {
