	["0015_00346"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00112", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0498", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“H-Manito, eso fue muy peligroso... ¡Ni siquiera tienes tu equipo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你、你太乱来了哥哥……明明一个装备都没有带……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你、你太亂來了哥哥……明明一個裝備都沒有帶……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00345",
		linknext = "0015_00347",
		line = 4661,
	},
	["0015_00347"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jaaa, ugh... ¡Mi cuerpo se movió solo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈啊、哈啊……不小心，身体就自己动起来了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈啊、哈啊……不小心，身體就自己動起來了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00346",
		linknext = "0015_00348",
		line = 4673,
	},
	["0015_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
