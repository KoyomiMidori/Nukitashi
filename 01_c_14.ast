	},
	["0015_00354"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right, I'm down the hill now... I'm in this wide-open expanse.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我虽然抵达坡道下方了……但突然到了一片平地。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我雖然抵達坡道下方了……但突然到了一片平地。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00353",
		linknext = "0015_00355",
		line = 4761,
	},
	["0015_00355"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00101", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0500", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Looks like you're on the hiking trail. Enjoy frolicking in nature while frolicking with each other, and all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那里是岛上的散步路线。据说是为了一边享受大自然一边做爱而建的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那裡是島上的散步路線。據說是為了一邊享受大自然一邊做愛而建的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00354",
		linknext = "0015_00356",
		line = 4774,
	},
	["0015_00356"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How do I get out from here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我该怎么从这里逃离？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我該怎麼從這裡逃離？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00355",
		linknext = "0015_00357",
		line = 4786,
	},
	["0015_00357"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00103", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0501", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Since you jumped down from the cliff, this is going to be a bit of a roundabout, but you should be able to get to the base of the mountain near the beach.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为你已经从悬崖上下来了，所以要绕一点路，但应该可以到达海滩附近的山脚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為你已經從懸崖上下來了，所以要繞一點路，但應該可以到達海灘附近的山腳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00356",
		linknext = "0015_00358",
		line = 4799,
	},
	["0015_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm closer to the town than I thought. In which case...",
					{"rt2"},
				},
			},
			cn = {
				{
					"比我想象的要更靠近城镇。这样的话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"比我想像的要更靠近城鎮。這樣的話——",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00357",
		linknext = "0015_00359",
		line = 4809,
	},
	["0015_00359"] = {
		{"bg", id=14, file="system_radar_00001", x=0, y=0, path=":bg/", time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=14, act="アルファフェード点滅", loop=-1, alpha="90,256", time=750, alphadel=0, lv=5, x=0, y=0},
		{"fg", file="asane_01f_00001", file1="asane_01f_00109", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0502", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wait, hold up... Seeing an entity approaching, virginity status unknown. I'm not entirely sure, but I'm seeing a group of two, so probably SHO guards?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“等、等一下……有一个处女躯不明器正在接近，这是——不清楚，有两组，会是SHO的警卫吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「等、等一下……有一個處女軀不明器正在接近，這是——不清楚，有兩組，會是SHO的警衛嗎？」",
					{"rt2"},
				},
			},
		},
