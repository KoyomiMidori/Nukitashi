	["0015_00247"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Situation normal here. Can you get any positional data on the subject of unknown virginity status I encountered previously?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这边也没有问题。刚才发给你的地区里的处女躯不明器的位置情报数据取得了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這邊也沒有問題。剛才發給你的地區裡的處女軀不明器的位置情報數據取得了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00246",
		linknext = "0015_00248",
		line = 3274,
	},
	["0015_00248"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0494", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Data acquired. One person traveling at 8 kph through mountains, with four persons in pursuit. No other enemies spotted.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“已取得。山中有一个以大约8公里/小时的速度行进的物体，后面有4个追逐其的物体。此外没有其他敌人的身影。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「已取得。山中有一個以大約8公里/小時的速度行進的物體，後面有4個追逐其的物體。此外沒有其他敵人的身影。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00247",
		linknext = "0015_00249",
		line = 3286,
	},
	["0015_00249"] = {
