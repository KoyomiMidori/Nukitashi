			},
		},
		linkback = "0015_00479",
		linknext = "0015_00481",
		line = 6387,
	},
	["0015_00481"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi cinturón se desabrocha en un parpadeo.",
