		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=500},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
