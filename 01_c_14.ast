				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“刚刚有人报警，说有一名扰乱性产行为的男子出现了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「剛剛有人報警，說有一名擾亂性產行為的男子出現了。」",
