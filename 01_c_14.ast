					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“De hecho, no...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，实际上……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，實際上……」",
					{"rt2"},
