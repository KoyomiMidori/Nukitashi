		linkback = "0015_00110",
		linknext = "0015_00112",
		line = 1494,
	},
	["0015_00112"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0298", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Mmm? Ay, tranquila, no pasa nada. ¡Soy tu senpai, así que tengo un gran corazón!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯？没事没事，别在意。前辈就是该心胸宽大！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯？沒事沒事，別在意。前輩就是該心胸寬大！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00111",
		linknext = "0015_00113",
		line = 1508,
	},
	["0015_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta situación sería menos incómoda si su corazón no fuera lo\núnico grande de ella...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果其他地方也很大，就不会这样了……",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果其他地方也很大，就不會這樣了……",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00112",
		linknext = "0015_00114",
		line = 1518,
	},
	["0015_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que todos tenemos nuestras circunstancias.",
					{"rt2"},
				},
			},
			cn = {
				{
					"情况因人而异。",
					{"rt2"},
				},
			},
			tw = {
				{
					"情況因人而異。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00113",
		linknext = "0015_00115",
		line = 1528,
	},
	["0015_00115"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero me alegra que hubiéramos llegado a salvo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论如何，值得庆幸的是每个人都安全聚集到了这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論如何，值得慶幸的是每個人都安全聚集到了這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00114",
		linknext = "0015_00116",
		line = 1539,
	},
	["0015_00116"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo, me preocupa un poco cumplir con la petición de nuestro patrocinador. Con este tipo de eventos, tenemos mucho trabajo por delante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但类似这样的活动一直举行的话，我们会很难满足出资者的要求。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但類似這樣的活動一直舉行的話，我們會很難滿足出資者的要求。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00115",
		linknext = "0015_00117",
		line = 1552,
	},
	["0015_00117"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0487", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí. Pero seguramente podríamos cumplir sus “condiciones” si no hiciéramos ningún esfuerzo por retirarnos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是的，为了不被撤退资金，最好早点达成对方的‘条件’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是的，為了不被撤退資金，最好早點達成對方的『條件』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00116",
		linknext = "0015_00118",
		line = 1566,
	},
	["0015_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sea como sea, aunque tomáramos medidas, seguimos cortos de miembros.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即使想积极开展作战行动，但人数依然不足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即使想積極開展作戰行動，但人數依然不足。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00117",
		linknext = "0015_00119",
		line = 1576,
	},
	["0015_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No tengo los números a mi favor para tratar esto como una organización hecha y derecha.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还没有能力说我们可以作为组织行动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還沒有能力說我們可以作為組織行動。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00118",
		linknext = "0015_00120",
		line = 1586,
	},
	["0015_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así que no tengo que darme prisa. Solo tengo que mantener la vista puesta en el objetivo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那就先别担心了——现在最好专注于眼前的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那就先別擔心了——現在最好專注於眼前的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00119",
		linknext = "0015_00121",
		line = 1596,
	},
	["0015_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan, ¿qué está pasando en la escuela?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，学校的状况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，學校的狀況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00120",
		linknext = "0015_00122",
		line = 1608,
	},
	["0015_00122"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0487", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mmm, veamos... No hay cambios. Las estaciones de la SS siguen estando más concurridas de lo habitual, y también hay mucha más gente buscando sexo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯，是的……果然和上次一样，SS的位置比平时更加散开……性触者的数量也比平常要多得多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯，是的……果然和上次一樣，SS的位置比平時更加散開……性觸者的數量也比平常要多得多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00121",
		linknext = "0015_00123",
		line = 1623,
	},
	["0015_00123"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0488", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No es nuestro único problema. Esta mañana pude confirmar que la OSS ha aumentado sus propias filas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“而且我认为问题不只是SS和性触者。今天早上来到学校时，我发现 SHO警卫的数量也增加了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「而且我認為問題不只是SS和性觸者。今天早上來到學校時，我發現 SHO警衛的數量也增加了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00122",
		linknext = "0015_00124",
		line = 1637,
	},
	["0015_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque logremos esquivar a las soldados de la SS, tendremos que enfrentarnos a las guardias de la OSS...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使离开了SS的范围，也必须警惕SHO警卫吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使離開了SS的範圍，也必須警惕SHO警衛嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00123",
		linknext = "0015_00125",
		line = 1649,
	},
	["0015_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Teniendo esto en cuenta, salir de la escuela no nos librará de todo el peligro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，离开学校并不表示就安全了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，離開學校並不表示就安全了。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00124",
		linknext = "0015_00126",
		line = 1659,
	},
	["0015_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esto me dará problemas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有点棘手啊——",
					{"rt2"},
				},
			},
			tw = {
				{
					"有點棘手啊——",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00125",
		linknext = "0015_00127",
		line = 1669,
	},
	["0015_00127"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan, ¿la luna saldrá esta noche?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，月亮出来了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，月亮出來了嗎？」",
					{"rt2"},
				},
