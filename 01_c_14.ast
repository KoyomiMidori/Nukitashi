			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Firstly, I ain't little, and secondly, I'm supposed to be the big sister!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不小！而且我才是姐姐！”",
					{"rt2"},
				},
