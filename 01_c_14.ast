	["0015_00076"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00111", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0477", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Waaaah, you traitor! Betraying your own sister and leaving your cum-filled condoms all over the place like in some NTR plot! Waaah, waaah!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哇啊啊，哥哥背叛了妹妹……！就像背叛NTR剧情的事后一样，射了一大堆精让安全套散落一地——！哇啊啊，唔啊啊啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哇啊啊，哥哥背叛了妹妹……！就像背叛NTR劇情的事後一樣，射了一大堆精讓保險套散落一地——！哇啊啊，唔啊啊啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00075",
		linknext = "0015_00077",
		line = 994,
	},
	["0015_00077"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn it... how could I make my little sister cry like this? I'm a failure of a big brother!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔……把妹妹弄哭成这样，我不配当哥哥——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔……把妹妹弄哭成這樣，我不配當哥哥——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00076",
		linknext = "0015_00078",
		line = 1006,
	},
	["0015_00078"] = {
