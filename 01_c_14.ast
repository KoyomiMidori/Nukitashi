					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me acaricia los testículos con los dedos. La sensación es distinta a cuando me los toco yo mismo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用指尖挑逗着我的蛋。自己触摸和其他人触摸是完全不一样的刺激。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用指尖挑逗著我的蛋。自己觸摸和其他人觸摸是完全不一樣的刺激。",
