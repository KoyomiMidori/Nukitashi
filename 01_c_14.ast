	},
	["0015_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tiene sus limitantes, pero también tiene una gran ventaja, y es que garantiza nuestra seguridad. Vámonos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然有很多限制，但它的强项是绝对安全——走吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然有很多限制，但它的強項是絕對安全——走吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00162",
		linknext = "0015_00164",
		line = 2195,
	},
	["0015_00164"] = {
		{"se", id=0, loop=0, file="se_a018"},
