					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, they both come out in different locations. That side goes to a cliff, and a dead end.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这两个洞通向不同的地方。一个是通向悬崖断壁。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這兩個洞通向不同的地方。一個是通向懸崖斷壁。」",
