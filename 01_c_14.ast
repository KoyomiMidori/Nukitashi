		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0478", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Heh, bawling like that just because you thought your big bro got taken... You really do care about him, don't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵，以为哥哥被抢了所以嚎啕大哭……你真的很喜欢哥哥呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呵呵，以為哥哥被搶了所以嚎啕大哭……你真的很喜歡哥哥呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00086",
		linknext = "0015_00088",
		line = 1173,
	},
	["0015_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Say, Nanase. There any close male relatives in your family who have their eyes obscured by their bangs?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……奈奈濑的亲戚中，有没有双眼被刘海遮住的男人？”",
