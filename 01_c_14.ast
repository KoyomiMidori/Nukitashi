					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wata-chan. Are you okay? It must have been hard getting here today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“渡酱。没事吧？今天来这里很辛苦吧？”",
