			tw = {
				{
					"然後這對於我們而言，也是一樣的。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00454",
		linknext = "0015_00456",
		line = 6047,
	},
	["0015_00456"] = {
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00103", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0032", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“¿Te niegas a responder? En ese caso, bajo la autoridad de la División Especial de Combate, debo pedirte que entregues inmediatamente tus armas y me des una erección.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“回答不出来吗？这样的话，我以特殊战斗部的的权限要求你——立即解除武装并马上勃起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「回答不出來嗎？這樣的話，我以特殊戰鬥部的的權限要求你——立即解除武裝並馬上勃起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00455",
		linknext = "0015_00457",
		line = 6061,
	},
	["0015_00457"] = {
		{"text"},
		text = {
