				{
					name = {"モブ女B", "女A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Mujer A"},
					"“Así que pondré tus brazos ahí y lo cerraré con llave... ¡Qué maravilla! No es lo mismo que las cuerdas, pero me vale.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "A女"},
					"“只要把双臂放进去，然后固定住……嗯，这样就可以进行拘束play了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "A女"},
					"「只要把雙臂放進去，然後固定住……嗯，這樣就可以進行拘束play了。」",
					{"rt2"},
				},
			},
		},
