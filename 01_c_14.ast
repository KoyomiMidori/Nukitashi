	["0015_00480"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me encuentro tumbado en la playa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我意识到时，我以一种非常糟糕的姿势被推倒在海滩上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我意識到時，我以一種非常糟糕的姿勢被推倒在海灘上。",
					{"rt2"},
