			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Hmph! Apuesto a que sabes todo eso solo por tus preciados onaholes, ¿verdad? Al menos eres un hombre con buen gusto en lo que respecta a juguetes sexuales.”",
