	["0015_00128"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0488", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Veamos... Aún no está lista.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊——",
					{"ruby", text="・・・・・・"},
					"还没有满月呢",
					{"/ruby"},
					"。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊——",
					{"ruby", text="・・・・・・"},
					"還沒有滿月呢",
					{"/ruby"},
					"。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00127",
		linknext = "0015_00129",
		line = 1695,
	},
	["0015_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vale, creo que hoy usaremos esa ruta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好吧，那么——今天使用那条路线。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好吧，那麼——今天使用那條路線。」",
					{"rt2"},
				},
