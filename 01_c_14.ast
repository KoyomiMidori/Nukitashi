				{"vo", file="asane0484", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Answer: White creamers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“答案是生土豆。”",
