	},
	["0015_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right ahead of us is the rear gate. Can you see those holes on the left and right sides?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果往前走就是后门……但左右各有一个通往其他地方的洞对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果往前走就是後門……但左右各有一個通往其他地方的洞對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00140",
		linknext = "0015_00142",
		line = 1902,
	},
	["0015_00142"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0303", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Wow, you're right! I didn't really notice in the dark, but yeah, I can see some small holes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，真的诶……！因为太暗了，完全没有发现有一个小洞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，真的欸……！因為太暗了，完全沒有發現有一個小洞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00141",
		linknext = "0015_00143",
		line = 1916,
	},
	["0015_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
