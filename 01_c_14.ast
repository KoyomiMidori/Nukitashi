	["0015_00526"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0057", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Jeje, pero veo que se ha puesto un poquito más grande... Te la voy a poner tan dura y a punto de estallar que te dolerá la próstata... ",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“唔呵呵，但是稍微有些变大了呢……那让我帮你勃起到前列腺开始发痛为止吧〜",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「唔呵呵，但是稍微有些變大了呢……那讓我幫你勃起到前列腺開始發痛為止吧〜",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00525",
		linknext = "0015_00527",
		line = 6922,
	},
	["0015_00527"] = {
		{"text"},
