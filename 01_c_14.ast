			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“¿En serio? ¿Tu polla no quiere ponerse dura...? Qué lástima.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“这样啊……但小鸡鸡就是硬不起来吗……这很辛苦吧，很难受吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「這樣啊……但小雞雞就是硬不起來嗎……這很辛苦吧，很難受吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00471",
		linknext = "0015_00473",
		line = 6259,
	},
	["0015_00473"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
