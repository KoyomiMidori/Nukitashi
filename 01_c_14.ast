					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nop. Esta base tiene una ruta secreta... pero solo disponemos de un breve segundo para utilizarla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
