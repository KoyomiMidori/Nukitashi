					{"rt2"},
				},
			},
			tw = {
				{
					"朝著放在右肩上的手往後看，那裡站著一位臉蛋漂亮的美女。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00441",
		linknext = "0015_00443",
		line = 5905,
	},
	["0015_00443"] = {
		{"bgm", file="bgm12", vol=100},
		{"text"},
		text = {
			vo = {
