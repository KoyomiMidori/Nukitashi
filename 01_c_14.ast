	["0015_00482"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0040", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Jeje... ¿Te asusté? Lo siento, seguro te sorprendió eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“唔呵呵……吓到了吗……？对不起，但你心动了吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「唔呵呵……嚇到了嗎……？對不起，但你心動了吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00481",
		linknext = "0015_00483",
		line = 6409,
	},
	["0015_00483"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voz seductora me susurra al oído.",
					{"rt2"},
				},
			},
			cn = {
				{
					"迷人的声音，在我耳边酥酥麻麻地响起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"迷人的聲音，在我耳邊酥酥麻麻地響起。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00482",
