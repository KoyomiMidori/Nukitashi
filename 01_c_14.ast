	["0015_00085"] = {
		{"bgm", file="bgm02", vol=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0480", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, so it was just a misunderstanding, then? Thank God, so we don't have a traitor in the base after all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“什么嘛，是误解啊……太好了，基地里的哥哥不是背叛者……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「什麼嘛，是誤會啊……太好了，基地裡的哥哥不是背叛者……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00084",
		linknext = "0015_00086",
		line = 1147,
	},
	["0015_00086"] = {
