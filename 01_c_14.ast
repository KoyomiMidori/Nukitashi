					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ehh... Ahora tengo que hacer una maldita marcha de la muerte... Esta colina es demasiado empinada y ahora mismo me están rozando los muslos... Cárgame, manito...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嘤……从现在开始要走一大段路吗……而且还是非常陡峭的路，这对大腿的负担很大……哥哥，背我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嚶……從現在開始要走一大段路嗎……而且還是非常陡峭的路，這對大腿的負擔很大……哥哥，背我……」",
					{"rt2"},
				},
			},
		},
