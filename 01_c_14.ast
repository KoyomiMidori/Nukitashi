		linknext = "0015_00442",
		line = 5892,
	},
	["0015_00442"] = {
		{"se", id=0, loop=0, file="se_a033"},
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00103", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
