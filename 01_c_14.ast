			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aun así, patear a alguien cuando está caído... Eso va a enfadar a sus amigos. Pero bueno, lo que hiciste estuvo bien. Buen trabajo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“即使是那样，鞭尸也太过分了……那种事情最容易惹对方生气了。不过算了，的确要那样做才有效。干得漂亮。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「即使是那樣，鞭屍也太過分了……那種事情最容易惹對方生氣了。不過算了，的確要那樣做才有效。幹得漂亮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00348",
		linknext = "0015_00350",
		line = 4696,
	},
