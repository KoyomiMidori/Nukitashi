		linkback = "0015_00472",
		linknext = "0015_00474",
		line = 6269,
	},
	["0015_00474"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Claramente me tomó en serio.",
