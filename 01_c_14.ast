					name = {"光姫", "光姬"},
					"“好了，小鸡鸡已经完全变大了呢……那么，把它插入姐姐已经湿漉漉的小穴里吧……",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「好了，小雞雞已經完全變大了呢……那麼，把它插入姐姐已經濕漉漉的小穴裡吧……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
