		{"fg", file="kouki_01l_00001", file1="kouki_01l_00104", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
