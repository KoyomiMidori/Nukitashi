			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cómo salgo de aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我该怎么从这里逃离？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我該怎麼從這裡逃離？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00355",
		linknext = "0015_00357",
		line = 4786,
	},
	["0015_00357"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00103", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0501", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Como saltaste desde el acantilado, va a ser un poco complicado, pero deberías llegar a la base de la montaña cerca de la playa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为你已经从悬崖上下来了，所以要绕一点路，但应该可以到达海滩附近的山脚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為你已經從懸崖上下來了，所以要繞一點路，但應該可以到達海灘附近的山腳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00356",
		linknext = "0015_00358",
		line = 4799,
	},
	["0015_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy más cerca de la ciudad de lo que pensaba. Siendo así...",
					{"rt2"},
				},
			},
			cn = {
				{
					"比我想象的要更靠近城镇。这样的话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"比我想像的要更靠近城鎮。這樣的話——",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00357",
		linknext = "0015_00359",
		line = 4809,
	},
	["0015_00359"] = {
		{"bg", id=14, file="system_radar_00001", x=0, y=0, path=":bg/", time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=14, act="アルファフェード点滅", loop=-1, alpha="90,256", time=750, alphadel=0, lv=5, x=0, y=0},
		{"fg", file="asane_01f_00001", file1="asane_01f_00109", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0502", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Espera... Veo una entidad acercándose, estado de virginidad desconocido. No estoy del todo segura, pero veo un grupo de dos, ¿probablemente sean guardias de la OSS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“等、等一下……有一个处女躯不明器正在接近，这是——不清楚，有两组，会是SHO的警卫吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「等、等一下……有一個處女軀不明器正在接近，這是——不清楚，有兩組，會是SHO的警衛嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00358",
		linknext = "0015_00360",
		line = 4824,
	},
	["0015_00360"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Esos imbéciles se hicieron los inocentes y llamaron al servicio de emergencias!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那群人，居然把自己当成受害者紧急呼叫了——！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那群人，居然把自己當成受害者緊急呼叫了——！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00359",
		linknext = "0015_00361",
		line = 4836,
	},
	["0015_00361"] = {
