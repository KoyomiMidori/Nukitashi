			},
			en = {
				{
					name = {"モブ男A", "Hombre A"},
					"“Si me vuelves a hacer eso, te daré una paliza de las antiguas. ¡A la gente también le gusta eso, así que saldré ganando!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男A", "A男"},
					"“对了，如果你还想逃跑的话，我会把你揍得更惨哦。而且这样重口味的也有人喜欢，所以无论哪样都好！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男A", "A男"},
					"「對了，如果你還想逃跑的話，我會把你揍得更慘哦。而且這樣重口味的也有人喜歡，所以無論哪樣都好！」",
					{"rt2"},
				},
			},
		},
