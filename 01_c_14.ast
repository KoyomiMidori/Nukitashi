					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm glad you understand... I'd never want you to think that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太好了……我没有被认为是背叛者……”",
