	["0015_00523"] = {
		{"se", id=1, loop=1, file="se_c020"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0056", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Vaya... Aún no está dura... La mayoría ya la tendría durita...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“咦……还没变硬呢……大多数人这个时候都会硬邦邦的说……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「咦……還沒變硬呢……大多數人這個時候都會硬梆梆的說……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00522",
