	},
	["0015_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seguramente se estarán preguntando: ¿por qué no lo hacen? Verán, eso le quitaría a las chicas la emoción de estar al mando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是说到为什么不发给男孩，似乎是为了避免失去女孩用嘴帮忙带套的美妙感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是說到為什麼不發給男孩，似乎是為了避免失去女孩用嘴幫忙戴套的美妙感覺。",
					{"rt2"},
