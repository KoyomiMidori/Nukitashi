		linkback = "0015_00133",
		linknext = "0015_00135",
		line = 1806,
	},
	["0015_00135"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0301", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“A-Am not! I'm older than you guys, so if something happens, I gotta watch your backs!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我、我不害怕……！作为长辈，如果有什么事情我必须保护大家……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我、我不害怕……！作為長輩，如果有什麼事情我必須保護大家……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00134",
		linknext = "0015_00136",
		line = 1821,
	},
	["0015_00136"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0489", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I'd expect the dark to make you pretty sleepy. What with you being a loli and all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“渡酱在昏暗的地方会想睡觉吧，因为是萝莉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「渡醬在昏暗的地方會想睡覺吧，因為是蘿莉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00135",
		linknext = "0015_00137",
		line = 1834,
