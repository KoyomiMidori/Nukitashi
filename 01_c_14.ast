		linkback = "0015_00144",
		linknext = "0015_00146",
		line = 1953,
	},
	["0015_00146"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course not. You'd just get lost and drown, with how dark it is. Right, come this way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么可能。如果在如此黑暗的地方游泳的话，很快就会失去方向感淹死的——这边。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼可能。如果在如此黑暗的地方游泳的話，很快就會失去方向感淹死的——這邊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00145",
		linknext = "0015_00147",
		line = 1965,
	},
	["0015_00147"] = {
		{"se", id=0, loop=0, file="se_a027"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We slowly move along the ocean route.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们沿着大海路线慢慢往前走。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們沿著大海路線慢慢往前走。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00146",
		linknext = "0015_00148",
		line = 1983,
	},
	["0015_00148"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After a little while we come to a broad expanse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过了一会儿，到了一个空旷的空间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過了一會，到了一個空曠的空間。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00147",
		linknext = "0015_00149",
		line = 2000,
	},
	["0015_00149"] = {
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0305", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Whoa, it's pretty vast out here. Oh, there's the ocean... wait, it sounds more like a river, doesn't it? I can hear it flowing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇，这边好空旷啊。啊，大海也……比起大海，看起来比较像一条河？只有一些水在流动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇，這邊好空曠啊。啊，大海也……比起大海，看起來比較像一條河？只有一些水在流動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00148",
		linknext = "0015_00150",
		line = 2014,
	},
	["0015_00150"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's almost a new moon period right now, so it's low tide.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是因为现在快要新月了，是退潮的时候。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是因為現在快要新月了，是退潮的時候。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00149",
		linknext = "0015_00151",
		line = 2026,
	},
	["0015_00151"] = {
		{"fgact", ch="ヒナミ", id=5, act="移動", x=400, y=0, time=700},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=400, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=600},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0490", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The tide changes according to the phases of the moon, and this place is usually underwater. You can't get through here on certain days and times.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“根据月亮的满亏，水位会发生变化，所以这里平常在海里。这是一条不选择时期和时间的情况下无法走的路线。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「根據月亮的滿虧，水位會發生變化，所以這裡平常在海裡。這是一條不選擇時期和時間的情況下無法走的路線。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00150",
		linknext = "0015_00152",
		line = 2041,
	},
	["0015_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Though in return, nobody'll see you coming through here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“相对的，也没有人能找到它。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「相對的，也沒有人能找到它。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00151",
		linknext = "0015_00153",
		line = 2053,
	},
	["0015_00153"] = {
