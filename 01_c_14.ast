			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Gimme a moment of shame over an eternity of pain any day of the week... Brooooo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对于麻沙酱而言比起痛苦还是暂时在大家面前出丑比较好……哥哥〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對於麻沙醬而言比起痛苦還是暫時在大家面前出醜比較好……哥哥〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00166",
		linknext = "0015_00168",
		line = 2252,
	},
	["0015_00168"] = {
