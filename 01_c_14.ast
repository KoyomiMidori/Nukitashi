				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los condones de la marca OSS que se pueden adquirir en diversos puestos están disponibles en una amplia gama de colores, con envoltorios, sabores y aromas llamativos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在店里卖的SHO制安全套颜色五彩缤纷、包装华丽，有的还有味道或者气味。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在店裡賣的SHO製保險套顏色五彩繽紛、包裝華麗，有的還有味道或者氣味。",
