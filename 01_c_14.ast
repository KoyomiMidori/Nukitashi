		linkback = "0015_00464",
		linknext = "0015_00466",
		line = 6168,
	},
	["0015_00466"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tengo que confesarme.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我别无选择，只能自白。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我別無選擇，只能自白。",
