		linkback = "0015_00100",
		linknext = "0015_00102",
		line = 1356,
	},
	["0015_00102"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0483", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But if they ignore the riddles and keep persisting, what do you do about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是，你如何对付那些无视谜语想要强行发生关系的人呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是，你如何對付那些無視謎語想要強行發生關係的人呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00101",
		linknext = "0015_00103",
		line = 1368,
	},
	["0015_00103"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00113", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0485", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Asking for sex is easy as pie, but keep up that attitude and you'll have to die.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这就是你求我做爱的态度？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這就是你求我做愛的態度？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00102",
		linknext = "0015_00104",
		line = 1382,
	},
	["0015_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
