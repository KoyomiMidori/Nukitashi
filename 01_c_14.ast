		line = 6419,
	},
	["0015_00484"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0041", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“¿Sabes? Las guardias de la OSS han recibido capacitación sobre cómo hacer que los hombres con disfunción eréctil disfruten de los placeres de la isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“SHO警卫为了让患有勃起功能障碍的人也能够在这个岛上享受快乐，受过专门的教育。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「SHO警衛為了讓患有勃起功能障礙的人也能夠在這個島上享受快樂，受過專門的教育。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00483",
		linknext = "0015_00485",
		line = 6431,
	},
	["0015_00485"] = {
		{"text"},
		text = {
