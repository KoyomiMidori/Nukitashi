	["0015_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shh! Stay on your guards, ladies. We're in the middle of a strategic operation here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嘘，你们太放松了。不要忘记我们在作战行动当中。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
