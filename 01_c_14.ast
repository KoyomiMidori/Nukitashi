		linkback = "0015_00154",
		linknext = "0015_00156",
		line = 2102,
	},
	["0015_00156"] = {
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0306b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? This is the other side of the beach, isn't it? Over on the hillside facing the sea?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……咦，这里是海滩的反方向，山之手的靠海那一侧对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……咦，這裡是海灘的反方向，山之手的靠海那一側對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00155",
		linknext = "0015_00157",
		line = 2118,
	},
	["0015_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. You know this place?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对，你怎么知道？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對，你怎麼知道？」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00156",
		linknext = "0015_00158",
		line = 2130,
	},
	["0015_00158"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0307", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah. My grandparents live on the hillside. Though I've never made it this far before. We're pretty far out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，我爷爷和奶奶都是山之手人。不过我没来过这边，因为这里很远。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，我爺爺和奶奶都是山之手人。不過我沒來過這邊，因為這裡很遠。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00157",
		linknext = "0015_00159",
		line = 2144,
	},
	["0015_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This route is certainly nothing if not remote in its location.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的，这条路线会带我们到非常偏僻的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的，這條路線會帶我們到非常偏僻的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00158",
		linknext = "0015_00160",
		line = 2154,
	},
	["0015_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the most undeveloped region on the island, where the sea meets the surrounding mountains.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上最不发达，且与大海以及周围山脉相连的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上最不發達，且與大海以及周圍山脈相連的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00159",
		linknext = "0015_00161",
		line = 2164,
	},
	["0015_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Furthermore, none of the paths here are paved so it would take a long time to get home from here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"此外，这里连道路都没有铺设，所以从这里回家需要一段时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"此外，這裡連道路都沒有鋪設，所以從這裡回家需要一段時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00160",
		linknext = "0015_00162",
		line = 2174,
	},
	["0015_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not a very practical route to take on foot.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想要步行的话，这不是条实用的路线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想要步行的話，這不是條實用的路線。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00161",
		linknext = "0015_00163",
		line = 2184,
	},
	["0015_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It has its limitations, but it has one big strength, and that's ensuring our safety is guaranteed. Come on, let's go.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然有很多限制，但它的强项是绝对安全——走吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然有很多限制，但它的強項是絕對安全——走吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00162",
		linknext = "0015_00164",
		line = 2195,
	},
