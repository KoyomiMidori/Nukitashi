	["0015_00450"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero ¿qué hago con lo demás?",
					{"rt2"},
				},
			},
			cn = {
				{
