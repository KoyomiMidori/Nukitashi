		linknext = "0015_00205",
		line = 2724,
	},
	["0015_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You often see sex toy trash thrown out like this on the road.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的成人用品垃圾经常被丢弃在街上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的成人用品垃圾經常被丟棄在街上。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00204",
		linknext = "0015_00206",
		line = 2734,
	},
	["0015_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are a lot of people who litter around here. What happens in Vegas, and all that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正所谓外地旅游没人认识，很多人都随地扔垃圾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正所謂外地旅遊沒人認識，很多人都隨地扔垃圾。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00205",
		linknext = "0015_00207",
		line = 2744,
	},
	["0015_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But somebody's got to pick all that trash up and have it dealt with in the morning. So it essentially helps create new jobs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，当然也有一大早就开始捡垃圾的工作在，这的确与新的雇用机会联系在一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，當然也有一大早就開始撿垃圾的工作在，這的確與新的僱用機會聯繫在一起。",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00206",
