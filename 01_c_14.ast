					"“¡Oye, piénsalo! ¿Crees que me gustaría tener sexo con una zorra?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你仔细想想，我怎么会和婊子啪啪啪呢？”",
