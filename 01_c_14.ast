	},
	["0015_00346"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00112", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0498", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“B-Bro, that was seriously dangerous... You don't even have any equipment on you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你、你太乱来了哥哥……明明一个装备都没有带……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你、你太亂來了哥哥……明明一個裝備都沒有帶……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00345",
		linknext = "0015_00347",
		line = 4661,
	},
	["0015_00347"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haah, ugh... My body just moved on its own!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈啊、哈啊……不小心，身体就自己动起来了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈啊、哈啊……不小心，身體就自己動起來了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00346",
		linknext = "0015_00348",
		line = 4673,
	},
	["0015_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even I can't quite understand why I went that far.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是我自己，也不知道为什么会做到那地步——",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是我自己，也不知道為什麼會做到那地步——",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00347",
		linknext = "0015_00349",
		line = 4683,
	},
	["0015_00349"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00107", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0499", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Still, kicking a guy when he's down... That's really gonna piss his friends off. Well, it was all the more effective that way. Good job.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“即使是那样，鞭尸也太过分了……那种事情最容易惹对方生气了。不过算了，的确要那样做才有效。干得漂亮。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「即使是那樣，鞭屍也太過分了……那種事情最容易惹對方生氣了。不過算了，的確要那樣做才有效。幹得漂亮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0015_00348",
		linknext = "0015_00350",
		line = 4696,
	},
	["0015_00350"] = {
		{"text"},
		text = {
