	["0099_00048"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00301", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=-400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1903", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wow, you watch that show too? That's prestige stuff, I love it... Where are they at with the reruns?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“麻沙音酱在看色情游妻吗！很棒吧……重播现在播到哪里了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「麻沙音醬在看色情遊妻嗎！很棒吧……重播現在播到哪裡了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00047",
		linknext = "0099_00049",
		line = 666,
	},
	["0099_00049"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1554", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Erothrob just got the prize, and used his old doujin Climax as the basis for a commercial revival. It's a big, emotional turning point, and definitely something you shouldn't miss.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“色情抖君在评选中获得金奖，同人时代创作的高潮君在商业圈复活……这展开真是太感动人心了，所以不能错过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「色情抖君在評選中獲得金獎，同人時代創作的高潮君在商業圈復活……這展開真是太感動人心了，所以不能錯過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00048",
		linknext = "0099_00050",
		line = 680,
	},
	["0099_00050"] = {
