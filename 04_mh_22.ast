		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm29", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“People still don't come here, do they?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这一带……还是一样没有人来啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這一帶……還是一樣沒有人來啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00170",
		linknext = "0099_00172",
		line = 2289,
	},
	["0099_00172"] = {
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1921", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, we're pretty deep in the mountains. I can't expect anyone would think they'd find anything out here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“毕竟是在山里……而且也没什么特别的理由吸引人来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「畢竟是在山裡……而且也沒什麼特別的理由吸引人來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00171",
		linknext = "0099_00173",
		line = 2303,
	},
	["0099_00173"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry for bringing you here on our date.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“抱歉，难得的约会却来这种地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「抱歉，難得的約會卻來這種地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00172",
		linknext = "0099_00174",
		line = 2315,
	},
	["0099_00174"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=5000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1922", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, no. After what you told me, I wanted to come here, too. This is where we first met, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不不不……如果是我被那样说的话，我也会想来的……我们第一次见面也是在这里对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不不不……如果是我被那樣說的話，我也會想來的……我們第一次見面也是在這裡對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00173",
		linknext = "0099_00175",
		line = 2331,
	},
	["0099_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her hair flutters in the gentle breeze and she gives me a tender smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"微风吹拂着头发，美岬静静眯起了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"微風吹拂著頭髮，美岬靜靜瞇起了眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00174",
		linknext = "0099_00176",
		line = 2341,
	},
	["0099_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was so long ago that I came here to save Misaki from being assaulted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像是很久以前的事了，当时就是在这里拯救被袭击的美岬的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像是很久以前的事了，當時就是在這裡拯救被襲擊的美岬的。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00175",
		linknext = "0099_00177",
		line = 2351,
	},
	["0099_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We saw each other after that, but I think that was when we became self-conscious about each other.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然在那之前也见过面——但彼此开始认识对方应该是从那时候才开始的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然在那之前也見過面——但彼此開始認識對方應該是從那時候才開始的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00176",
		linknext = "0099_00178",
		line = 2361,
	},
	["0099_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At the time I thought you were a regular, modest girl, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那时候，我还以为你是个文静低调的女孩子呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那時候，我還以為你是個文靜低調的女孩子呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00177",
		linknext = "0099_00179",
		line = 2372,
	},
	["0099_00179"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00128", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1923", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I'll have you know I'm very modest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……我确实很文静低调哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……我確實很文靜低調哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00178",
		linknext = "0099_00180",
		line = 2386,
	},
	["0099_00180"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are skydiving and driving armored vehicles through walls things that modest girls do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“低调的女孩子会用装甲车撞破大楼的墙壁飞进来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「低調的女孩子會用裝甲車撞破大樓的牆壁飛進來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00179",
		linknext = "0099_00181",
		line = 2398,
	},
	["0099_00181"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=10, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1924", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Of course they do. Modest girls have extreme firepower deep down, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“会的会的。低调的孩子心里都藏着强大的能量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「會的會的。低調的孩子心裡都藏著強大的能量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00180",
		linknext = "0099_00182",
		line = 2413,
	},
	["0099_00182"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“More crazy talk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你还是一样爱说些乱来的话呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你還是一樣愛說些亂來的話呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00181",
		linknext = "0099_00183",
		line = 2425,
	},
	["0099_00183"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1925", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You got a problem with crazy girls?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你不喜欢乱来的女孩子吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你不喜歡亂來的女孩子嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00182",
		linknext = "0099_00184",
		line = 2439,
	},
	["0099_00184"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I love them. I wouldn't have confessed to you here if I didn't.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“超喜欢。所以才在这里告白了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「超喜歡。所以才在這裡告白了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00183",
		linknext = "0099_00185",
		line = 2451,
	},
	["0099_00185"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1926", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ehehe... I love you too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……我也超喜欢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……我也超喜歡你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00184",
		linknext = "0099_00186",
		line = 2465,
	},
	["0099_00186"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a050", vol=50},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We walk through the hills with our fingers entwined.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像是要缠绕住指尖一样，我们牵着手在山里走路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像是要纏繞住指尖一樣，我們牽著手在山裡走路。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00185",
		linknext = "0099_00187",
		line = 2478,
	},
	["0099_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just doing this makes me vividly remember everything we've been through together.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样走着，至今和美岬经历过的往事就会鲜明地复活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣走著，至今和美岬經歷過的往事就會鮮明地複活。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00186",
		linknext = "0099_00188",
		line = 2488,
	},
	["0099_00188"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I reflect on those days, I eventually stop walking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想着那过于充实的日子，我们终于停下了脚步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回想著那過於充實的日子，我們終於停下了腳步。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00187",
		linknext = "0099_00189",
		line = 2499,
	},
	["0099_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the cliff the three of us threw ourselves over that day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"眼前的，就是那天——和文乃3个人一起飞跃而下的悬崖。",
					{"rt2"},
				},
			},
			tw = {
				{
					"眼前的，就是那天——和文乃3個人一起飛躍而下的懸崖。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00188",
		linknext = "0099_00190",
		line = 2509,
	},
	["0099_00190"] = {
		{"bg", id=3, file="bg25_1_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=500, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01f_00002", file1="misaki_01f_00107", file2="misaki_01f_00201", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1927", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I never paid attention to the scenery before, but looking at it now it's really beautiful, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“景色什么的，到现在为止都没怎么在意过……但这样看着真的很美呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「景色什麼的，到現在為止都沒怎麼在意過……但這樣看著真的很美呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00189",
		linknext = "0099_00191",
		line = 2523,
	},
	["0099_00191"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
