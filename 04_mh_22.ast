		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bg", id=2, file="bg19_1l_00000", x=-100, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"text"},
		text = {
