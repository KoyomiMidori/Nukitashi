					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The three of us sit at the dinner table and she removes the cloth wrapper.",
					{"rt2"},
				},
			},
			cn = {
				{
					"美岬打开拿来的方巾，三人围坐餐桌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"美岬打開拿來的方巾，三人圍坐餐桌。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00036",
		linknext = "0099_00038",
		line = 516,
	},
	["0099_00038"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Munch, munch... thanks for bringing food every weekend.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嚼嚼嚼……谢谢你每次休息都带饭来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嚼嚼嚼……謝謝你每次休息都帶飯來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00037",
		linknext = "0099_00039",
		line = 528,
	},
	["0099_00039"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1899", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Nom... no, it's nothing. When I told my mom I got a boyfriend, she was so happy she was moved to tears. I don't even need to ask, she just does it on her own each week.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哈唔……不不。我跟妈妈说了有男朋友之后她高兴地哭了……每周都吵着说要给我做饭。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哈唔……不不。我跟媽媽說了有男朋友之後她高興地哭了……每週都吵著說要給我做飯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00038",
		linknext = "0099_00040",
		line = 541,
	},
	["0099_00040"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1900", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“She's always weeping for joy when she does it, so I always need to try and get through to her before I leave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且每次做饭都喜极而泣，所以周末早上总是听着妈妈的哭声醒来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且每次做飯都喜極而泣，所以周末早上總是聽著媽媽的哭聲醒來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00039",
		linknext = "0099_00041",
		line = 555,
	},
	["0099_00041"] = {
