		line = 2664,
	},
	["0099_00202"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm... I dunno.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯——也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00201",
		linknext = "0099_00203",
		line = 2676,
	},
	["0099_00203"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, she talks a lot of shit, but at the end of the day I think she'd just say it's fine and not make a big deal over it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然她会不停抱怨，但最后还是会认可吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然她會不停抱怨，但最後還是會認可吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00202",
		linknext = "0099_00204",
		line = 2688,
	},
	["0099_00204"] = {
		{"fg", file="misaki_01l_00002", file2="misaki_01l_00201", file3="misaki_01l_00307", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1931", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, yeah, I can see that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……那景象浮现在眼前了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……那景象浮現在眼前了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00203",
		linknext = "0099_00205",
		line = 2702,
	},
	["0099_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Should we have her to the speech at the reception?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反正机会难得，要不要也拜托她在仪式上致辞？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「反正機會難得，要不要也拜託她在儀式上致辭？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00204",
		linknext = "0099_00206",
		line = 2713,
	},
	["0099_00206"] = {
		{"fg", file="misaki_01l_00002", file1="misaki_01l_00118", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1932", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ooh, you want to have her heartlessly jeering at me in front of everyone?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哦哦……我能在会场上听到冷酷的责骂吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哦哦……我能在會場上聽到冷酷的責罵嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00205",
		linknext = "0099_00207",
		line = 2727,
	},
	["0099_00207"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not so sure about that. I think she'd be surprisingly moved. Maybe even to tears.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谁知道呢。说不定她会哭出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「誰知道呢。說不定她會哭出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00206",
		linknext = "0099_00208",
		line = 2739,
	},
	["0099_00208"] = {
		{"fg", file="misaki_01l_00002", file1="misaki_01l_00111", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1933", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Aww, that'd be no good. If she started crying, then I'd need to bawl my eyes out, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……那、那可不行啊……要是麻沙音酱哭了，我一定也会泣不成声的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……那、那可不行啊……要是麻沙音醬哭了，我一定也會泣不成聲的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00207",
		linknext = "0099_00209",
		line = 2753,
	},
	["0099_00209"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If that happened, I'd cry too, just out of sympathy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那样的话……我也会跟着哭出来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那樣的話……我也會跟著哭出來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00208",
		linknext = "0099_00210",
		line = 2765,
	},
	["0099_00210"] = {
		{"fg", file="misaki_01l_00002", file1="misaki_01l_00106", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="misaki_01l_00002", file1="misaki_01l_00111", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1934", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Then my mom would be wailing and sobbing... Wah, that wouldn't be any good! That'd just be like a funeral!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我妈妈应该也会放声大哭吧……哇哇，不行！要变得跟葬礼一样了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我媽媽應該也會放聲大哭吧……哇哇，不行！要變得跟葬禮一樣了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00209",
		linknext = "0099_00211",
		line = 2781,
	},
	["0099_00211"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A funeral-like wedding reception...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“像葬礼的婚礼是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「像葬禮的婚禮是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00210",
		linknext = "0099_00212",
		line = 2793,
	},
	["0099_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I laugh at the absurd concept.",
					{"rt2"},
				},
			},
			cn = {
				{
					"光是想想就觉得很好笑——我笑了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"光是想想就覺得很好笑——我笑了出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00211",
		linknext = "0099_00213",
		line = 2803,
	},
	["0099_00213"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You always know how to cheer me up when I'm depressed, don't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的……和美岬在一起真的太开心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的……和美岬在一起真的太開心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00212",
		linknext = "0099_00214",
		line = 2815,
	},
	["0099_00214"] = {
		{"fg", file="misaki_01l_00002", file2="misaki_01l_00201", file3="misaki_01l_00308", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1935", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's like you read my mind. Every day, every hour, every minute, and every second that I spend with you is so blissful that I don't have time to get tired of you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那是我要说的。只要和淳之介君在一起，每天……每一分每一秒都太幸福了，连疲劳的时间都没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那是我要說的。只要和淳之介君在一起，每天……每一分每一秒都太幸福了，連疲勞的時間都沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00213",
		linknext = "0099_00215",
		line = 2829,
	},
	["0099_00215"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We'll probably get married, have kids, and grow old together, and that won't change.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今后——即使结婚、生了孩子，某天我们都老了……这样的日子也还会持续下去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今後——即使結婚、生了孩子，某天我們都老了……這樣的日子也還會持續下去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00214",
		linknext = "0099_00216",
		line = 2841,
	},
	["0099_00216"] = {
		{"fg", file="misaki_01l_00002", file2="misaki_01l_00201", file3="misaki_01l_00306", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1936", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I'm sure it won't. As long as we're together, I'm sure our lives will be a whirlwind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊……如果和淳之介在一起，我的人生应该会很忙吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊……如果和淳之介在一起，我的人生應該會很忙吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00215",
		linknext = "0099_00217",
		line = 2855,
	},
	["0099_00217"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That a bad thing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你讨厌那样的人生吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你討厭那樣的人生嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00216",
		linknext = "0099_00218",
		line = 2867,
	},
	["0099_00218"] = {
		{"fg", file="misaki_01l_00002", file1="misaki_01l_00107", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1937", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, I'm looking forward to it. Ever since you said you'd protect me for my whole life, that's been pretty much my plan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不会……我就想要那样的人生。从淳之介君说要守护我一辈子的时候开始……我就一直是这么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不會……我就想要那樣的人生。從淳之介君說要守護我一輩子的時候開始……我就一直是這麼想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00217",
		linknext = "0099_00219",
		line = 2881,
	},
	["0099_00219"] = {
		{"fg", file="misaki_01l_00002", file1="misaki_01l_00102", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1938", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I really love you, Junnosuke. Please protect me for my whole life.”",
