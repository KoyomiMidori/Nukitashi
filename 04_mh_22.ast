	},
	["0099_00110"] = {
		{"fgact", ch="美岬", id=6, act="移動", x=400, y=0, time=500},
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00105", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2085", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I swear I hear so many things I shouldn't when I run into you two...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你们在大马路上聊些什么啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你們在大馬路上聊些什麼啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00109",
		linknext = "0099_00111",
		line = 1448,
	},
	["0099_00111"] = {
		{"fg", file="misaki_01l_00002", file1="misaki_01l_00109", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase. Fancy seeing you here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑……真是巧啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨……真是巧啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00110",
		linknext = "0099_00112",
		line = 1462,
	},
	["0099_00112"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1916", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You heard that? Oh... Are you out shopping?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“真是太丢人了……在买东西吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「真是太丟人了……在買東西嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00111",
		linknext = "0099_00113",
		line = 1476,
	},
	["0099_00113"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2086", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No, I'm here to watch the filming. Wata invited me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不，我是来看电影拍摄的，渡酱邀请我来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不，我是來看電影拍攝的，渡醬邀請我來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00112",
		linknext = "0099_00114",
		line = 1490,
	},
	["0099_00114"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bg", id=2, file="bg22_1l_00000", x=0, y=200, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=-200},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2087", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei! You were so cool!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱！太帅了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬！太帥了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00113",
		linknext = "0099_00115",
		line = 1508,
	},
	["0099_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I see Wata standing on her folding chair, waving at the disciplinary committee president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一看，渡酱正站在钢管椅上向风纪委员长挥手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一看，渡醬正站在鋼管椅上向風紀委員長揮手。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00114",
		linknext = "0099_00116",
		line = 1518,
	},
	["0099_00116"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2088", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, Tachibana and Misaki! They just finished filming an awesome action scene with the SS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……啊，橘君，美岬酱！现在正在拍动作戏呢！FS的大家都很厉害喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……啊，橘君，美岬醬！現在正在拍動作戲呢！FS的大家都很厲害喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00115",
		linknext = "0099_00117",
		line = 1536,
	},
	["0099_00117"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1917", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ooh! Even Ikuko is here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶——那郁子酱也来了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸——那郁子醬也來了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00116",
		linknext = "0099_00118",
		line = 1550,
	},
	["0099_00118"] = {
