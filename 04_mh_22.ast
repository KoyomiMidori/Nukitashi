		{"fg", file="asane_01m_00007", file1="asane_01m_00128", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0037", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“This is Pussy Galore, giving the people what they want. Cool Seiran has officially taken its first major step forward, with filming for the movie †SEIRAN† now underway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"“接受你的一切，我是茅津野播音员。作为CoolSeiran项目的第一弹，电影†SEIRAN†的拍摄将从今天开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"「接受你的一切，我是主播茅津野。作為CoolSeiran項目的第一彈，電影†SEIRAN†的拍攝將從今天開始。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00050",
		linknext = "0099_00052",
		line = 708,
	},
	["0099_00052"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1555", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Huh? Oh, right... The SBS isn't airing their original shows anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……咦……？……啊，对了。SHK的节目已经不播了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……咦……？……啊，對了。SHK的節目已經不播了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00051",
		linknext = "0099_00053",
		line = 722,
	},
	["0099_00053"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh yeah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00052",
		linknext = "0099_00054",
		line = 734,
	},
	["0099_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's someone who looks like a movie producer being interviewed on the TV.",
					{"rt2"},
				},
			},
			cn = {
				{
					"电视里，有个像是电影制片人的人正在接受采访。",
					{"rt2"},
				},
			},
			tw = {
				{
					"電視裡，有個像是電影製片人的人正在接受采訪。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00053",
		linknext = "0099_00055",
		line = 744,
	},
	["0099_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The film is being made for release throughout Japan, not just for Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这不是面向“青蓝岛”的电影，而是预定在日本全国上映的电影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這不是面向「青藍島」的電影，而是預定在日本全國上映的電影。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00054",
		linknext = "0099_00056",
		line = 754,
	},
	["0099_00056"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1904", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I guess there'll be a lot more of this from now on, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“今后，这样的会越来越多吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「今後，這樣的會越來越多嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00055",
		linknext = "0099_00057",
		line = 768,
	},
	["0099_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Probably. I guess it depends on public opinion, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大概吧。要看今后的动向了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大概吧。要看今後的動向了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00056",
		linknext = "0099_00058",
		line = 779,
	},
	["0099_00058"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is all because of what happened that day, when we defeated the Yakuza to rescue Asa and Governor Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那天——我们打倒黑社会联合，救出麻沙酱和仁浦先生之后。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那天——我們打倒黑社會聯合，救出麻沙醬和仁浦先生之後。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00057",
		linknext = "0099_00059",
		line = 795,
	},
	["0099_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hitoura announced that he'd be stepping down as prefectural governor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生明确表示将辞去县知事一职。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生明確表示將辭去縣知事一職。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00058",
		linknext = "0099_00060",
		line = 805,
	},
	["0099_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Along with that announcement, he made two promises.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时约定了两件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時約定了兩件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00059",
		linknext = "0099_00061",
		line = 815,
	},
	["0099_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The first was the abolition of the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一个是之前提到的废除变态条例，也就是我们的目的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一個是之前提到的廢除變態條例，也就是我們的目的。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00060",
		linknext = "0099_00062",
		line = 825,
	},
	["0099_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The other was the continuation of the OSS and its suborganization, the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"另一个——则是维持SHO和下层组织FS的存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"另一個——則是維持SHO和下層組織FS的存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00061",
		linknext = "0099_00063",
		line = 835,
	},
	["0099_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the OSS and SS were abolished along with the law, it'd leave Ikuko out in the cold, among lots of others.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果条例被废除，连SHO和FS也会被卷入，郁子等许多人都会流落街头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果條例被廢除，連SHO和FS也會被捲入，郁子等許多人都會流落街頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00062",
		linknext = "0099_00064",
		line = 845,
	},
	["0099_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So he promised that wouldn't happen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，这是为了避免变成那样的约定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，這是為了避免變成那樣的約定。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00063",
		linknext = "0099_00065",
		line = 855,
	},
	["0099_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was his way of thanking them for helping with his rescue and ousting of the Yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是我对帮助我救出麻沙音的他们的一种感谢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是我對幫助我救出麻沙音的他們的一種感謝。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00064",
		linknext = "0099_00066",
		line = 865,
	},
	["0099_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I would've expected that the people would hate him for abolishing the law, but that didn't end up happening.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，作为破坏条例的男人，如果我被岛上的人恨之入骨也不足为奇——但结果并没有变成那样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，作為破壞條例的男人，如果我被島上的人恨之入骨也不足為奇——但結果並沒有變成那樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00065",
		linknext = "0099_00067",
		line = 875,
	},
	["0099_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm guessing it's because most of them knew Teshima was the one who was wreaking havoc on the island, so most of their ire was directed at him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"关于这点，了解情况的人大多都把愤怒的矛头指向了在岛上作乱的手嶋一伙人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"關於這點，了解情況的人大多都把憤怒的矛頭指向了在島上作亂的手嶋一夥人。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00066",
		linknext = "0099_00068",
		line = 885,
	},
	["0099_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Meanwhile, those who didn't had already expressed their lack of faith in the government by signing the petition.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是一无所知的岛民，对知事的不信任感也从之前就开始的签名运动上就表现出来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是一無所知的島民，對知事的不信任感也從之前就開始的簽名運動上就表現出來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00067",
		linknext = "0099_00069",
		line = 895,
	},
	["0099_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thus, Governor Hitoura's departure didn't come as any particular surprise.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此，仁浦知事的辞职平静地令人惊讶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此，仁浦知事的辭職平靜地令人驚訝。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00068",
		linknext = "0099_00070",
		line = 905,
	},
	["0099_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, despite his promise of continued existence for the SS and OSS, that couldn't happen without a cost.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，既然说要让FS和SHO继续存在，那当然会需要成本。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，既然說要讓FS和SHO繼續存在，那當然會需要成本。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00069",
		linknext = "0099_00071",
		line = 915,
	},
	["0099_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The current situation came about from the transitional arrangements he put in place before he resigned.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此——他在下台之前在各处做了疏通，结果似乎就造就了现在的情况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此——他在下臺之前在各處做了疏通，結果似乎就造就了現在的情況。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00070",
		linknext = "0099_00072",
		line = 925,
	},
	["0099_00072"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1556", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“They're trying to present Seiran Island as some kind of holy land like Jerusalem, but do you think it'll be able to stay a tourist destination now? I saw people on the internet calling it the unholy land Erosalem.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然说要把青蓝岛打造成圣地……但这样真的能维持游客量吗……网上都说它是圣蒂耶乳撒冷哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然說要把青藍島打造成聖地……但這樣真的能維持遊客量嗎……網上都說它是聖蒂耶乳撒冷哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00071",
		linknext = "0099_00073",
		line = 938,
	},
	["0099_00073"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who gives a shit what the internet thinks? I guess we'll see what happens once that movie comes out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“网络是网络。不过最终还是要看电影能否成功了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「網路是網路。不過最終還是要看電影能否成功了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00072",
		linknext = "0099_00074",
		line = 950,
	},
	["0099_00074"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn't it also meant to be the setting for some anime too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我记得这里还预定要成为动画片的背景舞台对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我記得這裡還預定要成為動畫片的背景舞臺對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00073",
		linknext = "0099_00075",
		line = 962,
	},
	["0099_00075"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1557", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Probably porn, right? It'd have to be if it was set here. Guess we won't be getting otaku pilgrimages any time soon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“以青蓝岛为舞台的动画片绝对是色情动漫吧……这样就不能圣地化了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「以青藍島為舞臺的動畫片絕對是色情動漫吧……這樣就不能聖地化了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00074",
		linknext = "0099_00076",
		line = 976,
	},
	["0099_00076"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1905", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I think it's a post-apocalyptic story about a man and woman making their way here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我也是听说的，不过好像是人类几乎灭亡后剩下的男女，漂泊到青蓝岛的故事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我也是聽說的，不過好像是人類幾乎滅亡後剩下的男女，漂泊到青藍島的故事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00075",
		linknext = "0099_00077",
		line = 989,
	},
	["0099_00077"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00116", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1906", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“They don't know how to have kids, but they wander around a dilapidated Lewd Land and find some old documents that teach them how to reproduce.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“原本连生孩子的方法都不知道的两人，在陈旧的变态乐园到处走动了解了岛上的历史，才渐渐知道如何繁殖……据说是这样的内容。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「原本連生孩子的方法都不知道的兩人，在陳舊的變態樂園到處走動了解了島上的歷史，才漸漸知道如何繁殖……據說是這樣的內容。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00076",
		linknext = "0099_00078",
		line = 1003,
	},
	["0099_00078"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1558", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Fucking normie-bait bullshit, then. If they made it a story about two girls instead, I'd be all over that shit. Cowards...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好狡猾，听着就觉得很有趣……如果不是男女而是两个女的那就是100亿分了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好狡猾，聽著就覺得很有趣……如果不是男女而是兩個女的那就是100億分了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00077",
		linknext = "0099_00079",
		line = 1017,
	},
	["0099_00079"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1907", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I've heard rumors of foreign studios interested in filming here too, actually. I think they want to do something called Slutnado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“听说海外也有人想用这里当成作品的舞台。好像是想拍一部叫做变态鲨鱼的作品。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「聽說海外也有人想用這裡當成作品的舞臺。好像是想拍一部叫做變態鯊魚的作品。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00078",
		linknext = "0099_00080",
		line = 1031,
	},
	["0099_00080"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1559", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That sounds like some serious dogshit. I'll have to check it out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“100%是烂电影吧……一定要去看……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「100%是爛電影吧……一定要去看……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00079",
		linknext = "0099_00081",
		line = 1045,
	},
	["0099_00081"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At least we know there's some demand for that trash.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是抢手啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是搶手啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00080",
		linknext = "0099_00082",
		line = 1057,
	},
	["0099_00082"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00129", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1560", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“This never seemed like the kind of place where they'd set movies, though. It was never an issue before because of the SBS monopoly, not to mention the perverted sex law and all that shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“毕竟这么适合创作的岛并不多……以往好像是被SHK独占或是因为变态条例而让人却步……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「畢竟這麼適合創作的島並不多……以往好像是被SHK獨占或是因為變態條例而讓人卻步……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00081",
		linknext = "0099_00083",
		line = 1071,
	},
	["0099_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because the law is gone, it can now be used as a setting for such large-scale productions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为变态条例走入了历史，才能好好把这里当成创作的舞台——是这个意思吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為變態條例走入了歷史，才能好好把這裡當成創作的舞臺——是這個意思嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00082",
		linknext = "0099_00084",
		line = 1081,
	},
	["0099_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I heard that the perverted amusement park, the lube fountain, ass wall art, and those kinds of things weren't removed, but left as cultural monuments.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一问我才知道，变态乐园、润滑液喷泉、壁尻体等都没有被拆除，将成为文化遗产。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一問我才知道，變態樂園、潤滑液噴泉、壁尻體等都沒有被拆除，將成為文化遺產。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00083",
		linknext = "0099_00085",
		line = 1091,
	},
	["0099_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The island isn't gonna erase its history. Instead, it'll monetize it to stay a tourist attraction.",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛并没有涂改变态的历史，而是选择将岛本身作为旅游资源的道路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島並沒有塗改變態的歷史，而是選擇將島本身作為旅遊資源的道路。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00084",
		linknext = "0099_00086",
		line = 1101,
	},
	["0099_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess it works for me, as long as the law is gone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种感觉——就好像与青蓝岛和解了的自己一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種感覺——就好像與青藍島和解了的自己一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00085",
		linknext = "0099_00087",
		line = 1111,
	},
	["0099_00087"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
