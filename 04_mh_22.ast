				{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00301", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1898", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“As long as I have Junnosuke, I'm invincible! Anyway, I brought food again, so let's eat together!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为只要和淳之介君在一起，不管到哪都不会有敌人的。今天也带饭来了，一起吃吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為只要和淳之介君在一起，不管到哪都不會有敵人的。今天也帶飯來了，一起吃吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00035",
		linknext = "0099_00037",
		line = 500,
	},
	["0099_00037"] = {
