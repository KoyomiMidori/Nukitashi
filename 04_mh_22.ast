		linknext = "0099_00146",
		line = 1921,
	},
	["0099_00146"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00145",
		linknext = "0099_00147",
		line = 1933,
	},
	["0099_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I call to her, she turns to me with a slightly startled look.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被搭话——她用看似微微惊讶的动作回过头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被搭話——她用看似微微驚訝的動作回過頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00146",
		linknext = "0099_00148",
		line = 1943,
	},
	["0099_00148"] = {
		{"bgm", file="bgm10", vol=100},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0342", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Ah, Tachibana and Hotori. It's been a while. I hope you've been well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“橘大人、畔大人……好久不见，看来您们平安无事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「橘大人、畔大人……好久不見，看來您們平安無事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00147",
		linknext = "0099_00149",
		line = 1957,
	},
	["0099_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the first time I've spoken to her before she's noticed me. That's odd.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前她应该都能在被打招呼之前就发现对方，真稀奇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之前她應該都能在被打招呼之前就發現對方，真稀奇。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00148",
		linknext = "0099_00150",
		line = 1967,
	},
	["0099_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It shouldn't be odd, but it is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，这也不奇怪吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，這也不奇怪吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00149",
		linknext = "0099_00151",
		line = 1977,
	},
	["0099_00151"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Have you been discharged? Are you feeling better?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“出院了吗？身体……已经没事了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「出院了嗎？身體……已經沒事了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00150",
		linknext = "0099_00152",
		line = 1989,
	},
	["0099_00152"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0343", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Today is the first day in a long time that they've given me permission to leave the hospital. I would like to express my thanks to you two once more.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“今天得到了久违的外出许可……我想再次向二位表示感谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「今天得到了久違的外出許可……我想再次向二位表示感謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00151",
		linknext = "0099_00153",
		line = 2003,
	},
	["0099_00153"] = {
		{"fg", file="misaki_01f_00002", file1="misaki_01f_00114", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1918", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Gratitude...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“感谢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「感謝……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00152",
		linknext = "0099_00154",
		line = 2016,
	},
	["0099_00154"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0344", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“The gratitude I feel to you is overwhelming, because you protected both myself and the island, as well as rescuing my father.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“您们保护了这个美丽的岛屿……救了我和父亲的命……我真的非常感谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「您們保護了這個美麗的島嶼……救了我和父親的命……我真的非常感謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00153",
		linknext = "0099_00155",
		line = 2030,
	},
	["0099_00155"] = {
		{"fg", file="misaki_01f_00002", file1="misaki_01f_00106", file2="misaki_01f_00202", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1919", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We're the ones who should be thanking you. If it weren't for you, we wouldn't have gotten anywhere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“感谢什么的……那是我们要说的。如果没有文乃酱，我们会怎么样呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「感謝什麼的……那是我們要說的。如果沒有文乃醬，我們會怎麼樣呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00154",
		linknext = "0099_00156",
		line = 2043,
	},
	["0099_00156"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. If I had my shit together, you wouldn't have lost your eyesight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……如果我再能干一点的话，那只眼睛也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……如果我再能幹一點的話，那隻眼睛也……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00155",
		linknext = "0099_00157",
		line = 2055,
	},
	["0099_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They were unable to save her eye.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃的眼睛无法治愈了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃的眼睛無法治癒了。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00156",
		linknext = "0099_00158",
		line = 2065,
	},
	["0099_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The tissue was destroyed beyond repair. There was nothing they could do.",
					{"rt2"},
				},
			},
			cn = {
				{
					"眼球的组织已经完全被破坏，要让其再生是不可能的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"眼球的組織已經完全被破壞，要讓其再生是不可能的。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00157",
		linknext = "0099_00159",
		line = 2075,
	},
	["0099_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She'll never see out of both eyes ever again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以——她已经无法再用双眼看东西了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以——她已經無法再用雙眼看東西了。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00158",
		linknext = "0099_00160",
		line = 2085,
	},
	["0099_00160"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00115", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0345", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Please don't concern yourself with that. Even if I can't see out of one side, the island's beauty is not diminished.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……请您们不要在意，就算只用一只眼睛看，岛上的美丽也不会因此减半。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……請您們不要在意，就算只用一隻眼睛看，島上的美麗也不會因此減半。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00159",
		linknext = "0099_00161",
		line = 2099,
	},
	["0099_00161"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0346", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I may no longer have my eagle eyes that can see everything, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“确实，我失去了丰玉之瞳……已经不能再纵观所有的事物……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「確實，我失去了豐玉之瞳……已經不能再縱觀所有的事物……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00160",
		linknext = "0099_00162",
		line = 2111,
	},
	["0099_00162"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0347", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“What I can see with one eye now is far more brilliant than all that I could see with both.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是对我来说……大家替我守护了的这个岛……比我之前用两只眼睛见到时，还要更加鲜明许多。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是對我來說……大家替我守護了的這個島……比我之前用兩隻眼睛見到時，還要更加鮮明許多。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00161",
		linknext = "0099_00163",
		line = 2125,
	},
	["0099_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00162",
		linknext = "0099_00164",
		line = 2136,
	},
	["0099_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's got a more relaxed expression than I've ever seen on her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃的表情看起来比以前柔和多了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃的表情看起來比以前柔和多了。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00163",
		linknext = "0099_00165",
		line = 2146,
	},
	["0099_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe this is how she normally is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许这才是她本来的容貌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許這才是她本來的容貌。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00164",
		linknext = "0099_00166",
		line = 2156,
	},
	["0099_00166"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0348", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I will never forget when you reached out to me while I was alone, and when I saw you exchange your vows of love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我还清楚地记得橘大人向一个人战斗的我伸出手时的情景……两位互相说着爱的话语时的情景。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我還清楚地記得橘大人向一個人戰鬥的我伸出手時的情景……兩位互相說著愛的話語時的情景。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00165",
		linknext = "0099_00167",
		line = 2168,
	},
	["0099_00167"] = {
		{"fg", file="misaki_01f_00002", file2="misaki_01f_00204", file3="misaki_01f_00307", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1920", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, aah... that's right, you were there, weren't you? Ahaha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊、啊——这么说来，当时文乃酱也在场啊……啊哈哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊、啊——這麼說來，當時文乃醬也在場啊……啊哈哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00166",
		linknext = "0099_00168",
		line = 2181,
	},
	["0099_00168"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0349", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This may be selfish for me to say, but even back then, I was truly grateful to see you fighting to protect the island. Even when I was a hostage, it was extremely encouraging to see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“虽然是我的一厢情愿……不过，那时我真心觉得有守护这个岛真是太好了……即使在我成为人质的那段时间里，这也一直在鼓励着我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「雖然是我的一廂情願……不過，那時我真心覺得有守護這個島真是太好了……即使在我成為人質的那段時間裡，這也一直在鼓勵著我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00167",
		linknext = "0099_00169",
		line = 2195,
	},
	["0099_00169"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00107", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0350", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Therefore, Tachibana and Hotori... I wish you all the happiness in the world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以……还请橘大人、畔大人……请一定要幸福地生活。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以……還請橘大人、畔大人……請一定要幸福地生活。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00168",
		linknext = "0099_00170",
		line = 2209,
	},
	["0099_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The first true smile I've seen from her feels somehow ephemeral, and it's filled with affection.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第一次见到的文乃的笑容有些虚幻——而且充满了慈爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第一次見到的文乃的笑容有些虛幻——而且充滿了慈愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00169",
		linknext = "0099_00171",
		line = 2219,
	},
	["0099_00171"] = {
