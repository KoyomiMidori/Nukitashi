		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=100},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_043_00000"},
		{"ex", time=1000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg22_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm02", vol=100},
		{"bg", id=1, file="bg22_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After dinner, I walk around the shopping district, hand-in-hand with Misaki.",
					{"rt2"},
				},
			},
			cn = {
				{
					"饭后，我与美岬手牵着手走向繁华街。",
					{"rt2"},
				},
			},
			tw = {
				{
					"飯後，我與美岬手牽著手走向繁華街。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00086",
		linknext = "0099_00088",
		line = 1158,
	},
	["0099_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The blazing sun is brilliantly shining down from the clear blue sky once again today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在晴朗的天空中灿烂耀眼的太阳，今天也毫不留情地照射着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在晴朗的天空中燦爛耀眼的太陽，今天也毫不留情地照射著。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00087",
		linknext = "0099_00089",
		line = 1168,
	},
	["0099_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The hottest time of day has passed, but the hot breeze on this island of everlasting summer stubbornly refuses to cool down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本以为盛夏早已过去，但这常夏的岛屿似乎不知道该如何降温。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本以為盛夏早已過去，但這常夏的島嶼似乎不知道該如何降溫。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00088",
		linknext = "0099_00090",
		line = 1178,
	},
	["0099_00090"] = {
		{"fg", file="misaki_01m_00002", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1908", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ehehe, it sure is hot again today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿，今天也很热呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿，今天也很熱呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00089",
		linknext = "0099_00091",
		line = 1192,
	},
	["0099_00091"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You seem to be happy.”",
					{"rt2"},
				},
			},
