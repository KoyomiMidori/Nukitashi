				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“需要啊……这次制作的是应用了MerqualiaAR，把周围的人都变成女部田前辈而不是畔同学的最强app……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「需要啊……這次製作的是應用了MerqualiaAR，把周圍的人都變成女部田前輩而不是畔同學的最強app……」",
					{"rt2"},
				},
