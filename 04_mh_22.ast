					"“Fuck off, it's your fault. Right, TV time... Cuck Shadows is gonna be on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“吵死了都怪你……啊……电视电视……色情游戏的妻子要播了。”",
					{"rt2"},
				},
			},
			tw = {
				{
