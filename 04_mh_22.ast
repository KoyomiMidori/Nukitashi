		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1914", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I appreciate it, but I've been fat by Seiran Island standards my whole life, and I'm gradually creeping up on mainland 'chubby'. A disaster is coming, I tell you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我也是……可是虽然至今都只是青蓝岛标准的胖子，但现在也逐渐要达到本岛上的胖子等级了……实在还是有点感到危机啊。”",
