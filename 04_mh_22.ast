					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, should I have said it's nowhere near as beautiful as you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……但美岬比景色更美——我该说这样的话吗？”",
