		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once the law was gone, the SS no longer had to enforce sexual activity at school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随着变态条例的消失，在校内鼓励性行为的FS也失去了作用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨著變態條例的消失，在校內鼓勵性行為的FS也失去了作用。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00124",
		linknext = "0099_00126",
		line = 1676,
	},
	["0099_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In its place, I hear they're going to be participating in artistic projects like this from now on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为代替，今后他们将致力于这些艺术类的活动。",
