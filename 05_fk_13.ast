	},
	["0113_00020"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00008", file1="asane_01m_00116", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1633", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Thank Fumino for that. She came to wake me, and I tried to ignore her, but she stood there without moving for ages... I was forced to not ignore her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是文乃叫我起来的……一开始我没理会她，可是她一动不动地一直坐在我旁边……最后我还是输了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是文乃叫我起來的……一開始我沒理會她，可是她一動不動地一直坐在我旁邊……最後我還是輸了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00019",
		linknext = "0113_00021",
		line = 294,
	},
	["0113_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's quite vulnerable to psychological attacks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我家妹妹其实对精神攻击很弱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我家妹妹其實對精神攻擊很弱。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00020",
		linknext = "0113_00022",
		line = 304,
	},
	["0113_00022"] = {
		{"se", id=0, loop=0, file="se_a145"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Furthermore, she doesn't have much willpower, so she cracks easily.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且因为没有毅力，很多时候很快就会屈服。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且因為沒有毅力，很多時候很快就會屈服。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00021",
		linknext = "0113_00023",
		line = 315,
	},
	["0113_00023"] = {
