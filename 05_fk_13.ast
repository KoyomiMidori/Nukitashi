					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I-I see! Then I'll have one more, no, twenty more cups of that, please!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是、是这样啊……！那请再来1杯，不对，20杯！”",
