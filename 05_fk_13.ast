				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=9500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2017", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“There's, like... something captivating about the way she carries herself. She looks like such a delicate little lily... which I guess makes me Quasimodo by comparison.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎么说呢……是会不由自主地看入迷的样子呢……走路的姿势如同百合一样……我则有点驼背……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「怎麼說呢……是會不由自主地看入迷的樣子呢……走路的姿勢如同百合一樣……我則有點駝背……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00139",
		linknext = "0113_00141",
		line = 2076,
	},
	["0113_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
