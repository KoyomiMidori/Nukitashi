		linkback = "0113_00022",
		linknext = "0113_00024",
		line = 328,
	},
	["0113_00024"] = {
		{"se", id=0, loop=0, file="se_a178"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mmm, this is good... Wait, since when did we have tea? And roasted green tea, at that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，好喝……咦，我们家什么时候有茶了？而且还是烘焙茶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，好喝……咦，我們家甚麼時候有茶了？而且還是烘焙茶……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00023",
		linknext = "0113_00025",
		line = 341,
	},
	["0113_00025"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_01m_00007", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0651", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“There were some aged tea leaves on your shelf... so I prepared them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“架子上有过期的茶叶……所以我就把它煎了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「架子上有過期的茶葉……所以我就把它煎了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00024",
		linknext = "0113_00026",
		line = 356,
	},
	["0113_00026"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was just thinking how much I'd love some before a meal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我正想在饭前喝一口茶呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我正想在飯前喝一口茶呢……」",
					{"rt2"},
				},
			},
		},
