					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Like a servant, awaiting their master's next instructions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就好像在问“有什么事吗？”一样。",
					{"rt2"},
