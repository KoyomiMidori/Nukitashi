					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Let's see... probably around 4:30?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯……大概、4点半左右吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗯……大概、4點半左右吧……？」",
					{"rt2"},
				},
			},
