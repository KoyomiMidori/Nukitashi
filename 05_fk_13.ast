					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whatever, just get your mitts off my leftovers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别一边说那种话一边把哥哥剩下的便当吃掉啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別一邊說那種話一邊把哥哥剩下的便當吃掉啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00118",
