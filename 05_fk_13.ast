		linkback = "0113_00313",
		linknext = "0113_00315",
		line = 4495,
	},
	["0113_00315"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00121", path=":fg/fumino_02m/", id=5, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
