		linkback = "0113_00244",
		linknext = "0113_00246",
		line = 3547,
	},
	["0113_00246"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00106", file2="asane_02m_00202", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1650", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I'm out now. I had a nice long soak.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我已经出来了……已经在热水里泡够了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我已經出來了……已經在熱水裡泡夠了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00245",
		linknext = "0113_00247",
		line = 3561,
	},
	["0113_00247"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
