		{"bg", id=1, file="bg12_1l_00000", x=-300, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look, Asa. Even Nanase can be nice to her. Can't you do the same?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你看奈奈濑对她那么温柔，麻沙酱你也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你看奈奈瀨對她那麼溫柔，麻沙醬你也……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00116",
		linknext = "0113_00118",
		line = 1664,
	},
	["0113_00118"] = {
