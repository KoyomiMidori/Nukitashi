		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_045_00000"},
		{"bgm", file="bgm23", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0710", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“So... if... if you happen to be... pleased with my work...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以……如果……如果，您能……高兴的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以……如果……如果，您能……高興的話……」",
					{"rt2"},
				},
			},
		},
