		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I value purity, and despise people who have casual sex. I see copulation as a noble act, and condemn those who engage in indecent copulation.”",
