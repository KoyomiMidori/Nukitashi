					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Isn't she more like a servant?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那种感觉，应该是佣人吧……？”",
