			cn = {
				{
					name = {"淳之介"},
					"“哦，麻沙酱醒了吗……这么早啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦，麻沙醬醒了嗎……這麼早啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00018",
		linknext = "0113_00020",
