			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I only ask... that you give a few words of praise... such as 'well done, Fumino'...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“只要一句……‘干得好，文乃’……能这样对我说的话……”",
