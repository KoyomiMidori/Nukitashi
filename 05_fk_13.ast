					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, her posture is always solid. She definitely does impose on the atmosphere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“与其说姿势很好，不如说一直都很凛然。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「與其說姿勢很好，不如說一直都很凜然。」",
					{"rt2"},
				},
