				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2015", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Y-Yes, please! Them's the breaks, I'm such a tub of lard that even with the A/C going full blast I still find it hot ahahaha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“好、好的……！是的，我是胖子所以就算空调开得很大，也只有我一个人觉得热啊哈哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「好、好的……！是的，我是胖子所以就算空調開得很大，也只有我一個人覺得熱啊哈哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00135",
		linknext = "0113_00137",
		line = 2014,
	},
	["0113_00137"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0670", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Oolong tea contains polymerized polyphenols, which may help with weight loss. Please enjoy it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……乌龙茶中含有聚合多酚等脱脂成分……请品尝吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……烏龍茶中含有聚合多酚等脫脂成分……請品嚐吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00136",
