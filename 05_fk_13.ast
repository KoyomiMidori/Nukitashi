		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you ARE an annoying twat with a fucked-up worldview.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你本来就是一个性格乖僻惹人厌的女人吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你本來就是一個性格乖僻惹人厭的女人吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00101",
		linknext = "0113_00103",
		line = 1443,
	},
	["0113_00103"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1644", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“All right, this IS a pretty damn good bento! Since it's all Japanese stuff it's not greasy at all, but it's all crispy and shit! If only I had some soup to go with it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不过虽然这个便当很好吃啊〜……！只是全是没有脂肪的日本料理，都干巴巴的……！这样的话不端汤给我喝可就有点难评价了呢〜……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不過雖然這個便當很好吃啊〜……！只是全是沒有脂肪的日本料理，都乾巴巴的……！這樣的話不端湯給我喝可就有點難評價了呢〜……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00102",
		linknext = "0113_00104",
		line = 1458,
	},
	["0113_00104"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0663", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Here you are. I made this soup, and put it into an insulated flask while it was warm.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“请喝这个……这是味增汤，我把它装进保温水壶里带来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「請喝這個……這是味噌湯，我把它裝進保溫水壺裡帶來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00103",
		linknext = "0113_00105",
		line = 1474,
	},
	["0113_00105"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
