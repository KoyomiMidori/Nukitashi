			},
		},
		text = {
			vo = {
				{"vo", file="asane1647", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So that bitch really DOES want to usurp me as the real sister! That goddamn little turncoat... I swear, I'll kick her ass out one day... Nom nom nom.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……！那个女人果然是想要夺走妹妹正宫的位置！不可原谅的叛逆行为……总有一天、总有一天会把你赶出去……嚼嚼嚼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……！那個女人果然是想要奪走妹妹正宮的位置！不可原諒的叛逆行為……總有一天、總有一天會把你趕出去……嚼嚼嚼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00117",
		linknext = "0113_00119",
		line = 1684,
	},
	["0113_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
