	["0113_00248"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00124", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1651", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I'm not quite sure what you're up to... but don't screw around with her too much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我不知道你在做什么……不过，玩文乃你也要适可而止啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我不知道你在做什麼……不過，玩文乃你也要適可而止啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00247",
		linknext = "0113_00249",
		line = 3588,
	},
	["0113_00249"] = {
		{"se", id=0, loop=0, file="se_a056"},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=600},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says something ominous, and then returns to her own room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说了些不寻常的话之后，麻沙音立刻回到了房间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說了些不尋常的話之後，麻沙音立刻回到了房間。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00248",
		linknext = "0113_00250",
		line = 3602,
	},
	["0113_00250"] = {
		{"se", id=0, loop=0, file="se_a079"},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=3, time=300, x=0, y=0, alphadel=1, style="reset"},
		{"fg", mode=-1, id=5, ch="文乃", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess this girl really will do whatever I tell her to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……果然不管什么事，她都能立刻帮我做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……果然不管什麼事，她都能立刻幫我做。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00249",
		linknext = "0113_00251",
		line = 3617,
	},
	["0113_00251"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This makes what Hotori and Nanase said at lunch time ring true.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样一来——越来越觉得中午畔和奈奈濑的发言是真的了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣一來——越來越覺得中午畔和奈奈瀨的發言是真的了。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00250",
		linknext = "0113_00252",
		line = 3627,
	},
	["0113_00252"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Right... Guess I'll just go all the way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好……这样的话，就试到底吧。",
