			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Y-Yes. Please do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“好、好的……请一定、一定要帮我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「好、好的……請一定、一定要幫我……」",
