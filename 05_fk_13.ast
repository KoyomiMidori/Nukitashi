	["0113_00067"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because of the illegal sex industry, there's the possibility that the island is a hotbed of crime, so the government needs to investigate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"极有可能成为地下风俗等犯罪温床的青蓝岛，应该进行一次政府视察。",
					{"rt2"},
				},
			},
			tw = {
				{
					"極有可能成為地下風俗等犯罪溫床的青藍島，應該進行一次政府視察。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00066",
		linknext = "0113_00068",
		line = 981,
	},
	["0113_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For people on the side of justice, that's a good enough justification to placate them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这很有道理，确实是个能让正义人士奋起的理由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這很有道理，確實是個能讓正義人士奮起的理由。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00067",
		linknext = "0113_00069",
		line = 991,
	},
	["0113_00069"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2185", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“That said, I don't think Hitoura would try to hire a bunch of 50-yen army types to counteract the criticism. The OSS already has a division like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过仁浦先生在网络这愧不可能没有雇用所谓的‘消防队’。连SHO都有这个部门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過仁浦先生在網路這愧不可能沒有僱用所謂的『消防隊』。連SHO都有這個部門。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00068",
		linknext = "0113_00070",
		line = 1005,
	},
	["0113_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So somebody must've stoked the flames, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，有可能是有人在故意让事件蔓延……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，有可能是有人在故意讓事件蔓延……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00069",
		linknext = "0113_00071",
		line = 1017,
	},
	["0113_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not entirely improbable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不是没有可能。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不是沒有可能。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00070",
		linknext = "0113_00072",
		line = 1027,
	},
	["0113_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Like, take the yakuza. They probably haven't exhausted all their power just yet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"例如黑社会们正用尽最后一丝力量进行反击。",
					{"rt2"},
				},
			},
			tw = {
				{
					"例如黑社會們正用盡最後一絲力量進行反擊。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00071",
		linknext = "0113_00073",
		line = 1037,
	},
	["0113_00073"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Either way, it means the OSS have allocated some of their resources to that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎样，SHO的资源会被分配到那边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎樣，SHO的資源會被分配到那邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00072",
		linknext = "0113_00074",
		line = 1048,
	},
	["0113_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lucky for us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然对我们来说是值得感激的事情——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然對我們來說是值得感激的事情——",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00073",
		linknext = "0113_00075",
		line = 1058,
	},
	["0113_00075"] = {
		{"bgm", file="bgm30", vol=100},
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-400, y=0, time=800},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0657", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Nanase, Junnosuke. Would you like some chilled tea?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……奈奈濑同学，淳之介大人。要喝凉茶吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……奈奈瀨同學，淳之介大人。要喝涼茶嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00074",
		linknext = "0113_00076",
		line = 1077,
	},
	["0113_00076"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, Fumino... Thanks. I was just getting thirsty, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦，文乃……谢谢，我刚来，刚好口渴了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦，文乃……謝謝，我剛來，剛好口渴了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00075",
		linknext = "0113_00077",
		line = 1090,
	},
	["0113_00077"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0658", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Would you like a refill?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“要再来一杯吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「要再來一杯嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00076",
		linknext = "0113_00078",
		line = 1104,
	},
	["0113_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, that's enough. Thanks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，够了，谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，夠了，謝謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00077",
		linknext = "0113_00079",
		line = 1116,
	},
	["0113_00079"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Also, I'm sorry, but I haven't got any lunch. I was planning to get yours and mine at the cafeteria, but yeah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……比起这个，抱歉没有午饭。我本来是打算连你那份也从小卖部买面包回来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……比起這個，抱歉沒有午飯。我本來是打算連你那份也從福利社買麵包回來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00078",
		linknext = "0113_00080",
		line = 1128,
	},
	["0113_00080"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0659", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Sorry for taking it upon myself, but I prepared lunch. Please eat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“恕我擅自准备好了……请用……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「恕我擅自準備好了……請用……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00079",
		linknext = "0113_00081",
		line = 1144,
	},
	["0113_00081"] = {
		{"se", id=0, loop=0, file="se_a216"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She takes out a tiny multi-tiered bento out, and removes the lid.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃把从某处取出来的小尺寸重箱的盖子打开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃把從某處取出來的小尺寸重箱的蓋子打開。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00080",
		linknext = "0113_00082",
		line = 1155,
	},
	["0113_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What I can see inside is quite a luxurious-looking traditional Japanese meal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"里面装着看起来华丽且豪华，像是要去赏花时吃的日式便当。",
					{"rt2"},
				},
			},
			tw = {
				{
					"裡面裝著看起來華麗且豪華，像是要去賞花時吃的日式便當。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00081",
		linknext = "0113_00083",
		line = 1165,
	},
	["0113_00083"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2186", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wooow, amazing... Did you prepare this? You didn't make this yesterday, did you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哇啊啊啊啊啊，好厉害……这个是文乃准备的……？昨天不是没有准备吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哇啊啊啊啊啊，好厲害……這個是文乃準備的……？昨天不是沒有準備嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00082",
		linknext = "0113_00084",
		line = 1180,
	},
	["0113_00084"] = {
		{"fg", file="fumino_02m_00007", file1="fumino_02m_00110", file2="fumino_02m_00202", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0660", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No... I prepared it this morning. I'm terribly sorry for it being so meager.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……是早上开始准备的，所以不是很精致，真是对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……是早上開始準備的，所以不是很精緻，真是對不起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00083",
		linknext = "0113_00085",
		line = 1194,
	},
	["0113_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, if this is meager, then the shit I make may as well be literal garbage.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不不，如果这是粗茶淡饭的话，我做的料理就像厨余一样了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不不，如果這是粗茶淡飯的話，我做的料理就像廚餘一樣了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00084",
		linknext = "0113_00086",
		line = 1206,
	},
	["0113_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase's cooking is relaxing, home-style stuff, like your mom used to make (to coin a phrase).",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说奈奈濑做的料理是充满家庭气息的菜品，",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說奈奈瀨做的料理是充滿家庭氣息的菜品，",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00085",
		linknext = "0113_00087",
		line = 1216,
	},
	["0113_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this is the kind of thing you'd get at a swanky Japanese restaurant. It's a feast for the eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那这些就像某间日本料理店的招牌菜，看上去非常美丽。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那這些就像某間日本料理店的招牌菜，看上去非常美麗。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00086",
		linknext = "0113_00088",
		line = 1226,
	},
	["0113_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This must've taken hours to put together...",
					{"rt2"},
				},
			},
			cn = {
				{
					"做这样的东西，一般要花上几个小时才对——",
