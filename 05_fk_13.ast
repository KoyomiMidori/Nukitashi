			tw = {
				{
					name = {"淳之介"},
					"「我喜歡貞潔，討厭隨意的性行為。把性行為看做高尚的行為，對不雅的性行為定罪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00307",
		linknext = "0113_00309",
		line = 4414,
	},
	["0113_00309"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see the flesh bestowed upon us by God as of the utmost value, and the inner parts — especially the genitals — to be inextricably tied to the soul.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说把神赐予我们的肉体视为最重要的部分，把身体内部，特别是性器官及其附带的精神视为最重要的部分。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說把神賜予我們的肉體視為最重要的部分，把身體內部，特別是性器官及其附帶的精神視為最重要的部分。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00308",
		linknext = "0113_00310",
		line = 4426,
	},
	["0113_00310"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=5, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=5, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0705", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Indubitably.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“原来原来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「原來原來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00309",
		linknext = "0113_00311",
		line = 4441,
	},
	["0113_00311"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So I absolutely refuse to have casual sex! If I ever share a bed with a woman, it'll be someone I pledge to spend my life with!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“正因为如此，我才不会轻易做爱——！和我同床而眠的女人，就是要白头偕老的对象！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「正因為如此，我才不會輕易做愛——！和我同床而眠的女人，就是要白頭偕老的對象！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00310",
		linknext = "0113_00312",
		line = 4453,
	},
	["0113_00312"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=2.5, time=100, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I haven't pledged a vow of marriage to her, she's not getting the D!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果不是发誓要结婚的对象，就绝对不会做爱——！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果不是發誓要結婚的對象，就絕對不會做愛——！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00311",
		linknext = "0113_00313",
		line = 4467,
	},
	["0113_00313"] = {
		{"se", id=0, loop=0, file="se_a208"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00109", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=5, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0706", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Such strength of will, such pride and conviction... I am most impressed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“多么……强烈的自尊、强烈的信念、坚守信念的精神……文乃深受感动……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「多麼……強烈的自尊、強烈的信念、堅守信念的精神……文乃深受感動……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00312",
		linknext = "0113_00314",
		line = 4483,
	},
	["0113_00314"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
