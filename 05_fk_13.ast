		linkback = "0113_00089",
		linknext = "0113_00091",
		line = 1263,
	},
	["0113_00091"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jesus, isn't that way too early!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“会不会太早了……！？”",
