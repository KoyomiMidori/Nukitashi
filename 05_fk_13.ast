	["0113_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Was that... a laugh I heard?",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才她笑了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才她笑了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00240",
		linknext = "0113_00242",
		line = 3502,
	},
	["0113_00242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I mean, confusion is clearly written all over her face, but...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然她一脸“发生什么事了吗？”的表情……",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然她一臉「發生什麼事了嗎？」的表情……",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00241",
		linknext = "0113_00243",
		line = 3512,
	},
	["0113_00243"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However unconventional-sounding it was... that was a laugh, right?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她发出奇怪的声音，笑了吧……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她發出奇怪的聲音，笑了吧……？",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00242",
		linknext = "0113_00244",
		line = 3522,
	},
	["0113_00244"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="asane_02m_00007", file1="asane_02m_00104", file2="asane_02m_00202", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=-800, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
