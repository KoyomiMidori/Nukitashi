			},
		},
		text = {
			vo = {
				{"vo", file="asane1634", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, frig... Guess I'll just have to get some of Nanase's vittles in me to take the edge off... Om nom nom, nom nom... Delish!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——好累……这样的早晨就应该来一发奈奈濑同学的饭……呜呜，嚼嚼嚼！嗯好吃……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊——好累……這樣的早晨就應該來一發奈奈瀨同學的飯……嗚嗚，嚼嚼嚼！嗯好吃……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00026",
		linknext = "0113_00028",
		line = 388,
	},
	["0113_00028"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, I thought Nanase wouldn't make miso soup for us because it spoils too quick in the summer?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……咦，奈奈濑那家伙不是说味增汤容易变味所以夏天就不做了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……咦，奈奈瀨那傢伙不是說味噌湯容易變味所以夏天就不做了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00027",
		linknext = "0113_00029",
		line = 400,
	},
	["0113_00029"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1635", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mm... Upon further tasting, I have discerned this is somewhat lacking in Nanasenium!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……仔细一尝，奈奈濑分子好像有些不够……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……仔細一嚐，奈奈瀨分子好像有些不夠……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00028",
		linknext = "0113_00030",
		line = 415,
	},
	["0113_00030"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0652", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Pardon my insolence... but I prepared breakfast... I'm pleased it is to your liking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“恕我冒昧……早餐是我准备的……要是合您的口味就好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「恕我冒昧……早餐是我準備的……要是合您的口味就好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00029",
		linknext = "0113_00031",
		line = 430,
	},
	["0113_00031"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1636", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“S-Seriously? Compared to Nanase's cooking, this may as well have come from some dingy-ass karaoke bar in the sticks!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这、这种东西，和奈奈濑同学的料理相比就是当地卡拉ok店的料理吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這、這種東西，和奈奈瀨同學的料理相比就是當地卡拉ok店的料理吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00030",
		linknext = "0113_00032",
		line = 445,
	},
	["0113_00032"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You were just banging on about how good it is a second ago. Why do you have to clash with Fumino so much?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚才你不是说很好吃吗？为什么你要对文乃这么坏啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剛才你不是說很好吃嗎？為什麼你要對文乃這麼壞啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00031",
		linknext = "0113_00033",
		line = 457,
	},
	["0113_00033"] = {
		{"fg", ch="文乃", lv=2, id=7, time=0, sync=0, mode=3, path=":fg/fumino_02m/", file="fumino_02m_00001", size="m", file1="fumino_02m_00110", head="fumino_02m", x=-400},
		{"fgact", ch="文乃", id=7, act="移動", x=800, y=0, time=800},
		{"text"},
		delay = {
			[1000] = {
				{"fgact", ch="文乃", id=7, act="振動下", loop=8, size=5, time=250, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1637", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Heh. If I were gonna accept some interloping cousin barging into our house and forcing her way into our and Nanase's little love nest, I wouldn't be playin' with a full deck!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哼，对突然来家里住下来的表姐妹能温柔才奇怪呢居然侵入我的领地这里明明是我和哥哥和奈奈濑同学的爱的小巢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哼，對突然來家裡住下來的表姐妹能溫柔才奇怪呢居然侵入我的領地這裡明明是我和哥哥和奈奈瀨同學的愛的小巢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00032",
		linknext = "0113_00034",
		line = 473,
	},
	["0113_00034"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"fg", file="asane_01m_00007", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fgact", ch="文乃", id=7, act="振動下", loop=4, size=12.5, time=250, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, if you hate it that much, then I'll eat it all myself.”",
					{"rt2"},
				},
			},
			cn = {
