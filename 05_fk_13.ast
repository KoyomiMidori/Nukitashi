				{"vo", file="fumino0707", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“What kind of servant would not understand their master's words? I'm impressed, Junnosuke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果不能理解主人说的话，要怎么能胜任仆从……真不愧是淳之介同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果不能理解主人說的話，要怎麼能勝任僕從……真不愧是淳之介同學……」",
					{"rt2"},
				},
			},
		},
