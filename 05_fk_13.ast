				{"vo", file="asane1645", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Shit, she actually had it on hand...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“居然出现了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「居然出現了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00104",
		linknext = "0113_00106",
		line = 1489,
	},
	["0113_00106"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's like she's prepared for everything we can say...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要说出口就什么都会出现吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要說出口就什麼都會出現嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00105",
		linknext = "0113_00107",
		line = 1501,
	},
	["0113_00107"] = {
		{"se", id=1, loop=0, file="se_a094"},
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00121", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0664", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have prepared some mitsumame as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“甜点我准备了红豆寒天……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「甜點我準備了紅豆寒天……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00106",
		linknext = "0113_00108",
		line = 1517,
	},
	["0113_00108"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She even brought out a chilled and reasonably portioned dessert!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还配了清凉爽口的甜点……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還配了清涼爽口的甜點……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00107",
		linknext = "0113_00109",
		line = 1529,
	},
	["0113_00109"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1646", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I-I only have eyes for Nanase's cooking!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我、我觉得奈奈濑同学的料理才是独一无二的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我、我覺得奈奈瀨同學的料理才是獨一無二的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00108",
		linknext = "0113_00110",
		line = 1544,
	},
	["0113_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, Nanase, your cooking is pretty good too! Gives off that 'like mom used to make' feeling and stuff!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑的菜也很好吃啊，感觉就像妈妈做的菜一样！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨的菜也很好吃啊，感覺就像媽媽做的菜一樣！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00109",
		linknext = "0113_00111",
		line = 1556,
	},
	["0113_00111"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2189", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, yeah, thanks. But I'm the homemade cooking type, so I can't make anything remotely like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好的好的，谢谢。但是我的菜是家常菜，做不了这些。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好的好的，謝謝。但是我的菜是家常菜，做不了這些。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00110",
		linknext = "0113_00112",
		line = 1571,
	},
	["0113_00112"] = {
		{"fg", file="fumino_02m_00007", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[8500] = {
				{"fg", file="fumino_02m_00007", file1="fumino_02m_00110", file2="fumino_02m_00202", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0665", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“That is most unfair. Having had the pleasure of tasting your cooking, it is terribly delicious indeed. Anything save for Japanese-style food I cannot prepare myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“没有那种事……我吃了奈奈濑的料理，非常好吃……我除了日式料理什么都不会做……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「沒有那種事……我吃了奈奈瀨的料理，非常好吃……我除了日式料理什麼都不會做……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00111",
		linknext = "0113_00113",
		line = 1588,
	},
	["0113_00113"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2190", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, really? Well, the next time I make Western or Chinese stuff for Jun, I'll teach you how to do that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊，是吗？那下次我来整理一下淳他们喜欢的西餐和中国菜的菜谱，我来教你吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊，是嗎？那下次我來整理一下淳他們喜歡的西餐和中國菜的菜譜，我來教你吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00112",
		linknext = "0113_00114",
		line = 1604,
	},
	["0113_00114"] = {
