		line = 1236,
	},
	["0113_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, what time did you wake up this morning?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃，你今天几点起床的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃，你今天幾點起床的？」",
					{"rt2"},
				},
