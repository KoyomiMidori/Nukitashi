	["0113_00061"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2182", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Just poring over the latest news articles. Our strategies are influenced by what we know, so I need to go over this stuff to formulate our strategies.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我在检查最近的报道。战略是受信息左右的，要想制定作战方案必须事先学习。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我在檢查最近的報導。戰略是受情報左右的，要想制定作戰方案必須事先學習。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00060",
		linknext = "0113_00062",
		line = 896,
	},
	["0113_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Diligent as ever, huh... So what do you see in the news about the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑真勤奋啊……岛上的报道怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨真勤奮啊……島上的報導怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00061",
		linknext = "0113_00063",
		line = 908,
	},
	["0113_00063"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2183", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, basically the whole internet's on fire with the illegal sex industry stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那个啊……关于地下风俗的事情，好像网络上上了热搜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那個啊……關於地下風俗的事情，好像網路上上了熱搜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00062",
		linknext = "0113_00064",
		line = 922,
	},
	["0113_00064"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2184", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hitoura evidently seems to have bribed the mass media into silence, but there's still a lot of discussion on social media.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“电视媒体好像被仁浦先生的封口费堵上了嘴，但是SNS上的话题还在继续。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「電視媒體好像被仁浦先生的封口費堵上了嘴，但是SNS上的話題還在繼續。」",
					{"rt2"},
				},
			},
