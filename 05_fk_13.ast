	},
	["0113_00092"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00121", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0662", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Since I have not been on night patrol, I have been able to sleep much more regularly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“因为少了巡逻，所以久违地睡得很饱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「因為少了巡邏，所以久違地睡得很飽……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00091",
		linknext = "0113_00093",
		line = 1289,
	},
	["0113_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Considering she went to sleep after I checked the house, that would have been after midnight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"话虽如此，但文乃是在检查过房间后才睡的，所以应该已经12点多了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"話雖如此，但文乃是在檢查過房間後才睡的，所以應該已經12點多了。",
					{"rt2"},
				},
			},
		},
