	["0113_00132"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"text"},
		delay = {
			[6500] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=3, size=12.5, time=150, ease="easeinout_sine", delay2=6500},
			},
			[8000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=0, y=0},
				{"se", id=0, loop=0, file="se_a098", delay2=8000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2013", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Right? I'm so surprised, she's nothing like what I expected her to be. Glug, glug... Aaah, that hit the spot!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是吧？和想象中的不一样，我吓了一跳……咕噜咕噜……噗哈，好喝！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是吧？和想像中的不一樣，我嚇了一跳……咕嚕咕嚕……噗哈，好喝！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00131",
		linknext = "0113_00133",
		line = 1945,
	},
	["0113_00133"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, Hotori... Since when were you a tea drinker?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……畔，你什么时候喝起了茶？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……畔，你什麼時候喝起了茶？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00132",
		linknext = "0113_00134",
		line = 1957,
	},
	["0113_00134"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00125", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="美岬", id=6, act="浮遊横", loop=6, size=5, time=50, ease="easeinout_sine", delay2=1000},
			},
			[4500] = {
				{"se", id=0, loop=0, file="se_a093", delay2=4500},
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00122", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2014", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? WHAAAAAT!? I-It's true! This cup of tea somehow just appeared in my hand! I-Is this my latest gluttony-related delusion!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶？吼啊啊啊啊！真、真的啊！等我发现的时候已经拿起茶了……这是吃货会看到的临终的幻觉吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸？吼啊啊啊啊！真、真的啊！等我發現的時候已經拿起茶了……這是吃貨會看到的臨終的幻覺嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00133",
		linknext = "0113_00135",
		line = 1979,
	},
	["0113_00135"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=-400, y=0, time=500},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=700},
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0669", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Pardon my rudeness, but I noticed you were sweating, so I prepared some chilled oolong tea for you. Would you care for more?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不敢当……您出了这么多汗，所以为您端了一杯冰凉的乌龙茶……再来一杯怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不敢當……您出了這麼多汗，所以為您端了一杯冰涼的烏龍茶……再來一杯怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00134",
		linknext = "0113_00136",
		line = 1997,
	},
	["0113_00136"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
