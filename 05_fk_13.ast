				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you get what I'm saying!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……！你能明白吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……！你能明白嗎……！？」",
					{"rt2"},
				},
