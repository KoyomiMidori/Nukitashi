					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y'know, I think you're still being a little too formal with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那个‘大人’果然有点太敬畏了，不太好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那個『大人』果然有點太敬畏了，不太好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00154",
		linknext = "0113_00156",
		line = 2255,
	},
	["0113_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
