					{"rt2"},
				},
			},
			en = {
				{
					"I'm just surprised she saw through it that quickly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然在这么短的时间内就看穿了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然在這麼短的時間內就看穿了——",
					{"rt2"},
