	},
	["0113_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since she specifically gave you oolong, she evidently knew you were conscious about being pudgy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且知道你在意自己很胖，所以一开始就拿出了乌龙茶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且知道你在意自己很胖，所以一開始就拿出了烏龍茶……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00142",
		linknext = "0113_00144",
		line = 2114,
	},
	["0113_00144"] = {
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00303", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2019", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That almost hurts more than what I get told out loud...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这比被直接说更让我觉得受伤……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這比被直接說更讓我覺得受傷……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00143",
		linknext = "0113_00145",
		line = 2128,
	},
	["0113_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I doubt you'd get that kind of service if you just asked anyone to do it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我觉得那种侍奉的方法，不是随随便便就能做到的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我覺得那種侍奉的方法，不是隨隨便便就能做到的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00144",
		linknext = "0113_00146",
		line = 2140,
	},
	["0113_00146"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps she had some kind of special training.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她接受过什么特殊的训练吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"她接受過什麼特殊的訓練嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00145",
		linknext = "0113_00147",
		line = 2152,
	},
	["0113_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I can't imagine she had such an opportunity, given her situation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是考虑到文乃的生活环境，应该没有那么宽裕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是考慮到文乃的生活環境，應該沒有那麼寬裕。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00146",
		linknext = "0113_00148",
		line = 2162,
	},
	["0113_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Come to think of it, she did mention how she took after the behavior and conduct of her mother...",
					{"rt2"},
				},
			},
			cn = {
				{
					"对了，她说过她的一举一动都是母亲教的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"對了，她說過她的一舉一動都是母親教的——",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00147",
		linknext = "0113_00149",
		line = 2172,
	},
	["0113_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, can you come here for a sec?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃，你能来一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃，你能來一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00148",
		linknext = "0113_00150",
		line = 2184,
	},
	["0113_00150"] = {
		{"se", id=0, loop=0, file="se_a007"},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
