		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lunch time. Having emerged non-victorious from the cafeteria bum rush, I head for the base with a growling stomach, and see Nanase and Asa there.",
					{"rt2"},
				},
			},
			cn = {
