		linknext = "0113_00330",
		line = 4683,
	},
	["0113_00330"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=5, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0709", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It is my honor, as Kotoyose Fumino, to work for your sake.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“为了您工作……这才是我、琴寄文乃的荣耀……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「為了您工作……這才是我、琴寄文乃的榮耀……」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00329",
		linknext = "0113_00331",
		line = 4697,
	},
	["0113_00331"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There doesn't appear to be a shred of deception in her words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那句话没有一丝虚假。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那句話沒有一絲虛假。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00330",
		linknext = "0113_00332",
		line = 4707,
	},
	["0113_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She really does seem to be saying that nothing gives her greater pleasure.",
