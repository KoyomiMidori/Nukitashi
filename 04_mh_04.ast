		line = 3594,
	},
	["0081_00272"] = {
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"bg", id=2, file="bg07_1_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hame_01m_00002", path=":fg/hame_01m/", id=3, lv=5, head="hame_01m", ch="ハメ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, we gotta get outta here, Hotori! There's nothing safe about this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔，我们要逃出这个地方！这里完全不安全。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔，我們要逃出這個地方！這裡完全不安全。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00271",
		linknext = "0081_00273",
		line = 3611,
	},
	["0081_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, even if we do escape, then what?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，出去之后该怎么办——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，出去之後該怎麼辦——",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00272",
		linknext = "0081_00274",
		line = 3621,
	},
	["0081_00274"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I want to get back to school so we can be safer, but won't they be suspicious if we're not on the bus going back?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想避开目光回到学校，但如果不在回程的公交车上，会不会被怀疑啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想避開目光回到學校，但如果不在回程的巴士上，會不會被懷疑啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00273",
		linknext = "0081_00275",
		line = 3633,
	},
	["0081_00275"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00104", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0673", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That shouldn't be a problem. Usually they let anyone who wants to continue doing volunteer work stay here afterwards.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这点应该不用担心。因为有意愿的人可以在放学后继续留在游乐园做志愿者……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這點應該不用擔心。因為有意願的人可以在放學後繼續留在遊樂園做志工……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00274",
		linknext = "0081_00276",
		line = 3646,
	},
	["0081_00276"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So if you can go wherever you like as a volunteer at the park, that means they won't notice if we suddenly disappear!",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么，如果当作我们一直在游乐园的某个地方做志愿者的话……就算不知不觉间消失了也不会被发现——！",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼，如果當作我們一直在遊樂園的某個地方做志工的話……就算不知不覺間消失了也不會被發現——！",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00275",
		linknext = "0081_00277",
		line = 3656,
	},
	["0081_00277"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, new plan. Dump the suit and we'll climb over the fence and escape into the woods. We can't take the regular exit or they'll find us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好——那出了布偶后就越过栅栏从森林里逃出去吧。一般路线会被抓到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好——那出了布偶後就越過柵欄從森林裡逃出去吧。一般路線會被抓到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00276",
		linknext = "0081_00278",
		line = 3668,
	},
	["0081_00278"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Once we reach a road, that's where you come in. Pick up a bike and head to the school. Got it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从那里去到道路上之后——就是畔的擅长领域了。在某处捡台自行车去学校，做得到吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從那裡去到道路上之後——就是畔的擅長領域了。在某處撿臺自行車去學校，做得到嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00277",
		linknext = "0081_00279",
		line = 3680,
	},
	["0081_00279"] = {
		{"fgact", ch="ハメ", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
