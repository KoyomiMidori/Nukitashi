					{"gaiji", text="①"},
					"的心情，然后监视着你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「當然。我想知道你是不是真的是反交尾勢力，所以讓大家變成啊哈～",
					{"gaiji", text="①"},
