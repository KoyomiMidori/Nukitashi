	["0081_00432"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, it's not just any bike. It's a climax bike. Maybe it's just as important to her as my dutch wives are to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——不是普通的自行车，而是高潮自行车，说不定那跟我的充气娃娃是一样的存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——不是普通的自行車，而是高潮自行車，說不定那跟我的充氣娃娃是一樣的存在。",
					{"rt2"},
				},
			},
		},
