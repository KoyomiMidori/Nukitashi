		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00111", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0169", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Sigh, no one here has any stamina, they're never able to get me off. And then I'm stuck there until it goes all the way around! I should know by now not to bother with the phallus wheel...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唉……大家马上就射了，还不够满足啊。到绕完一圈前都不能再去找下一个小鸡鸡……坐上啊啊车是错误的吗〜……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「唉……大家馬上就射了，還不夠滿足啊。到繞完一圈前都不能再去找下一個小雞雞……坐上啊啊車是錯誤的嗎〜……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00280",
		linknext = "0081_00282",
		line = 3753,
	},
	["0081_00282"] = {
		{"bg", id=1, file="bg07_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="jun_01m_00001", file1="jun_01m_00103", file2="jun_01m_00202", file4="jun_01m_00401", path=":fg/jun_01m/", id=2, lv=5, head="jun_01m", ch="淳之介", mw="mw", sync=0, mode=3, x=-400, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, mode=3, x=400, y=0},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_043_00000"},
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00111", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0170", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huh? Ah, I spy some naughty kids trying to play truant from their volunteer work. We can't have that, now, can we ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“咦？啊〜……那些孩子们做志愿者还偷懒，那可不行哦——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「咦？啊〜……那些孩子們做志工還偷懶，那可不行哦——」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00281",
		linknext = "0081_00283",
		line = 3772,
	},
	["0081_00283"] = {
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00105", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0171", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Who would turn down such a great opportunity for sex with so many people by playing hooky?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“难得能和各种各样的人做爱，为什么要偷懒呢……好奇怪啊——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「難得能和各種各樣的人做愛，為什麼要偷懶呢……好奇怪啊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00282",
		linknext = "0081_00284",
		line = 3785,
	},
	["0081_00284"] = {
		{"fg", mode=-1, id=30, ch="郁子", lv=5},
