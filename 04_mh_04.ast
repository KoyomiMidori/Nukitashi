		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just restrain yourself like the rest of us. Is that too much to ask from a native Seiran Islander?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“忍耐一下吧……这对在青蓝岛长大的人来说很残酷吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「忍耐一下吧……這對在青藍島長大的人來說很殘酷嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00108",
		linknext = "0081_00110",
		line = 1413,
	},
	["0081_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At the very least, just do it in privacy. Doing it out in the open puts you at risk of being approached by sex-seekers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最大限度地让步——至少要在别人看不到的地方做吧。不然可能会被性触者攻击不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最大限度地讓步——至少要在別人看不到的地方做吧。不然可能會被性觸者攻擊不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00109",
		linknext = "0081_00111",
		line = 1425,
	},
	["0081_00111"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0639", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ugh... okay. I could turn away when I do it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……我明白了……那你能面向对面吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……我明白了……那你能面向對面嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00110",
		linknext = "0081_00112",
		line = 1439,
	},
	["0081_00112"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00304", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that what I said? Don't do it around us at all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别我一说完你就一副想要自慰的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別我一說完你就一副想要自慰的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00111",
		linknext = "0081_00113",
		line = 1451,
	},
	["0081_00113"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0640", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? I thought you said it was fine as long as they couldn't see me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦……只要不被别人看见就行了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦……只要不被別人看見就行了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00112",
		linknext = "0081_00114",
		line = 1465,
	},
	["0081_00114"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Maybe I didn't put it right. I meant do it so that people won't notice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可能是我说的方式有问题……请尽量别被其他人发现……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可能是我說的方式有問題……請盡量別被其他人發現……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00113",
		linknext = "0081_00115",
		line = 1477,
	},
	["0081_00115"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I mean, I understand it isn't Hotori's fault.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也明白畔并没有错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也明白畔並沒有錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00114",
		linknext = "0081_00116",
		line = 1488,
	},
	["0081_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her values are fucked from being raised on this accursed island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个岛的存在，使得畔的价值观变得如此奇怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個島的存在，使得畔的價值觀變得如此奇怪。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00115",
		linknext = "0081_00117",
		line = 1498,
	},
	["0081_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I won't be able to change an ingrained way of thinking overnight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"多年积淀下来的观念不是轻易就能改变的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"多年積澱下來的觀念不是輕易就能改變的。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00116",
		linknext = "0081_00118",
		line = 1508,
	},
	["0081_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But maybe I can with persistence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——只要坚持下去，总有一天会改变的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——只要堅持下去，總有一天會改變的。",
					{"rt2"},
				},
			},
		},
