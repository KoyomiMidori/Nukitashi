		{"text"},
		text = {
			vo = {
				{"vo", file="asane1256", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Every floor's got at least triple the usual sex-seekers. Every guy's at least at work the shaft status, while the girls are all at drenched and overflowing ",
					{"gaiji", text="①"},
					"...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“每层都比平时多出3倍的性触者……男生最低也都处在‘昂起鸡巴’状态……女生也同样都是‘一塌胡涂要溢出了",
					{"gaiji", text="①"},
					"’状态……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「每樓都比平時多出3倍的性觸者……男生最低也都處在『昂起肉棒』狀態……女生也同樣都是『一塌糊塗要溢出了",
					{"gaiji", text="①"},
					"』狀態……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00323",
		linknext = "0081_00325",
		line = 4364,
	},
	["0081_00325"] = {
