		line = 4068,
	},
	["0081_00301"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? Really? I hope you didn't draw too much attention.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……不要紧吗？你这么露骨地打探的话，肯定会被怀疑的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……不要緊嗎？你這麼露骨地打探的話，肯定會被懷疑的吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00300",
		linknext = "0081_00302",
		line = 4080,
	},
	["0081_00302"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00120", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1947", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's fine. I just put her name on one of my old textbooks, then dropped it off at the staff room saying she'd lost it and I wanted to return it to her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没事的。我只是在以前用过的教科书上写上‘琴寄文乃’的名字，然后去职员办公室问说这是几班的孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒事的。我只是在以前用過的教科書上寫上『琴寄文乃』的名字，然後去職員辦公室問說這是幾班的孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00301",
		linknext = "0081_00303",
		line = 4093,
	},
	["0081_00303"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn, that's not a bad idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你真聪明啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你真聰明啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00302",
		linknext = "0081_00304",
		line = 4105,
	},
	["0081_00304"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00112", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1948", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Heh, why else would I be the head strategist? It didn't work, though. They said that wasn't the name of any student here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵，我这个作战方案负责人可没有白当啊。不过……结果还是不行。他们说没有这样的学生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呵呵，我這個作戰方案負責人可沒有白當啊。不過……結果還是不行。他們說沒有這樣的學生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00303",
		linknext = "0081_00305",
		line = 4118,
	},
	["0081_00305"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So she's not enrolled at this school, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这么说来，‘文乃’连学校都没上——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這麼說來，『文乃』連學校都沒上——」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00304",
		linknext = "0081_00306",
		line = 4130,
	},
	["0081_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Or if she is, she's using an alias.",
					{"rt2"},
				},
			},
			cn = {
				{
					"至少，没有“琴寄文乃”这个名字的学生在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"至少，沒有「琴寄文乃」這個名字的學生在。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00305",
		linknext = "0081_00307",
		line = 4140,
	},
	["0081_00307"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought knowing her age would be a big lead, but looks like it wasn't able to get us anywhere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“本以为只要知道年龄就能找到解决的方法……结果还是没有有用的线索啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「本以為只要知道年齡就能找到解決的方法……結果還是沒有有用的線索啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00306",
		linknext = "0081_00308",
		line = 4152,
	},
	["0081_00308"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00106", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1949", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, we still just don't have enough info. Even if it's not anything about her specifically, even any random info about the other islanders might help us dig up a lead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“情报还是不够……即使不是文乃的事，只要能掌握岛民的情报，就一定会有线索的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「情報還是不夠……即使不是文乃的事，只要能掌握島民的情報，就一定會有線索的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00307",
		linknext = "0081_00309",
		line = 4165,
	},
	["0081_00309"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's right. A comprehensive enough knowledge of the islanders might help us get a lead on searching for Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"的确，如果能广泛收集岛民的信息，就能从中找到“文乃”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"的確，如果能廣泛收集島民的資訊，就能從中找到「文乃」。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00308",
		linknext = "0081_00310",
		line = 4175,
	},
	["0081_00310"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Information on the islanders... that's something the OSS and SS would have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“岛民的情报……这么说来，FS和SHO的话可能会有吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「島民的情報……這麼說來，FS和SHO的話可能會有吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00309",
		linknext = "0081_00311",
		line = 4187,
	},
	["0081_00311"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, you're a super hacka, can you get access to that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，能不能用你拿手的技巧偷过来呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，能不能用你拿手的技巧偷過來呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00310",
		linknext = "0081_00312",
		line = 4199,
	},
	["0081_00312"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00112", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1251", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nope nope nope, impossibly impossible, the most impossibly fucking impossible thing ever conceived.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不行不行办不到办不到那里办不到真的办不到绝对办不到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不行不行辦不到辦不到那裡辦不到真的辦不到絕對辦不到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00311",
		linknext = "0081_00313",
		line = 4212,
	},
	["0081_00313"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That bad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反应好夸张啊你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「反應好誇張啊你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00312",
		linknext = "0081_00314",
		line = 4224,
	},
	["0081_00314"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00122", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1252", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Last time I just stuck my head in to look around a bit, they almost caught me. They've got some real batshit security.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“之前有一次差点被发现了……我明明只是想跟他们打个招呼……那边的安全系统太可怕了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「之前有一次差點被發現了……我明明只是想跟他們打個招呼……那邊的安全系統太可怕了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00313",
		linknext = "0081_00315",
		line = 4237,
	},
	["0081_00315"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm... What if you had direct access to a terminal rather than over the internet? Could you hack in from there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……假设不是在网上而是直接连接终端的话——能不能把里面的数据抽出来呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……假設不是在網上而是直接連接終端的話——能不能把裡面的數據抽出來呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00314",
		linknext = "0081_00316",
		line = 4249,
	},
	["0081_00316"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1253", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It'd be piss-easy, but how the fuck do you plan to make that happen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯，那倒是很简单……但是不用说，直接连接上前的行动绝对一点都不简单……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯，那倒是很簡單……但是不用說，直接連接上前的行動絕對一點都不簡單……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00315",
		linknext = "0081_00317",
		line = 4262,
	},
	["0081_00317"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nothing ventured, nothing gained. We're going to need to make some bold moves if we want to get anywhere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不入虎穴，焉得虎子——我们也差不多该采取大胆的行动了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不入虎穴，焉得虎子——我們也差不多該採取大膽的行動了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00316",
		linknext = "0081_00318",
		line = 4274,
	},
	["0081_00318"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we don't do anything, the risk of being jumped by sex-seekers will never go away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使保持沉默，只要还待在这个岛上，就有被性触者袭击的危险。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使保持沉默，只要還待在這個島上，就有被性觸者襲擊的危險。",
