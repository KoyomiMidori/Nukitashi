	["0081_00445"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if Hotori's kinda strange, having her say that to my face makes me feel a bit excited.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被她当面这样感谢——即使知道畔有些奇怪的地方，但依然还是觉得小鹿乱撞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被她當面這樣感謝——即使知道畔有些奇怪的地方，但依然還是覺得小鹿亂撞。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00444",
		linknext = "0081_00446",
		line = 6099,
	},
	["0081_00446"] = {
		{"se", id=0, loop=0, file="se_a163"},
		{"ex", time=500, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, it's Asa. I'll tell her we're safe...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——啊，是麻沙酱，要告诉她我们平安无事才行……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——啊，是麻沙醬，要告訴她我們平安無事才行……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00445",
		linknext = "0081_00447",
		line = 6113,
	},
	["0081_00447"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0692", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, sorry. You must be worried about Asane. Does your leg still hurt? I'll take you home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……对不起。麻沙音酱明明很担心你……脚还疼吧？我送你回家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……對不起。麻沙音醬明明很擔心你……腳還痛吧？我送你回家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00446",
		linknext = "0081_00448",
		line = 6127,
	},
	["0081_00448"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't worry about it. We're close to your place, aren't we? My leg's okay now. I can walk from here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要在意——畔的家很近吧？脚的话已经没事了，这里是可以一个人回家的距离。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要在意——畔的家很近吧？腳的話已經沒事了，這裡是可以一個人回家的距離。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00447",
		linknext = "0081_00449",
		line = 6139,
	},
