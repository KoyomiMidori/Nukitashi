		line = 4415,
	},
	["0081_00329"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can worry about searching for Fumino later. Right now, let's focus on dealing with this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“搜索文乃的作战计划之后再说吧……首先考虑眼前的情况……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「搜索文乃的作戰計劃之後再說吧……首先考慮眼前的情況……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00328",
		linknext = "0081_00330",
		line = 4427,
	},
	["0081_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asane, can we use the limestone cave route?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙音，钟乳洞路线能用吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙音，鐘乳洞路線能用嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00329",
		linknext = "0081_00331",
		line = 4438,
	},
	["0081_00331"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1258", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It's still covered with seawater, it won't be open for a few more days. Given how things look, it'd probably be best to leave through the back gate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“还要再等几天呢……被海水覆盖了……从目前的状况来看，回去的话最好是走后门……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「還要再等幾天呢……被海水覆蓋了……從目前的狀況來看，回去的話最好是走後門……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00330",
		linknext = "0081_00332",
		line = 4450,
	},
	["0081_00332"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, we can't just bust out of here. Should we just wait here and ride it out?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要突破可不是容易的事……要先在这里等他们冷静下来吗——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要突破可不是容易的事……要先在這裡等他們冷靜下來嗎——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00331",
		linknext = "0081_00333",
		line = 4462,
	},
	["0081_00333"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=6, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1950", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You think they'll stop anytime soon? This is unprecedented, so who knows? The first-floor shutters are still open, so we should be able to escape pretty quick through the front gate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“要是会冷静下来就好了……但这种情况下可说不定呢……现在1楼的铁门也还开着，从正门应该可以比较快就走到学校外面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「要是會冷靜下來就好了……但這種情況下可說不定呢……現在1樓的鐵門也還開著，從正門應該可以比較快就走到學校外面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00332",
		linknext = "0081_00334",
		line = 4476,
	},
	["0081_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When it gets dark the first-floor shutters are closed, making it necessary to climb to the upper levels to get out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一到傍晚1楼的门就会被关上，所以就必须从楼上回去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一到傍晚1樓的門就會被關上，所以就必須從樓上回去。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00333",
		linknext = "0081_00335",
		line = 4486,
	},
	["0081_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they keep this up through the evening, we'll be stuck.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果等到傍晚也是这种状况的话，那才是最糟糕的状况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果等到傍晚也是這種狀況的話，那才是最糟糕的狀況。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00334",
		linknext = "0081_00336",
		line = 4496,
	},
	["0081_00336"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1259", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“If I were a bettin' dame, I'd guess there's some kinda aphrodisiac at play here. If so, they won't be in any shape to pay attention to us. What do you think, Bro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“从现况来看，性触者很有可能受到了催情剂等的效果影响，可以推测他们对周围的注意力不高……哥哥，怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「從現況來看，性觸者很有可能受到了催情劑等的效果影響，可以推測他們對周圍的注意力不高……哥哥，怎麼辦？」",
