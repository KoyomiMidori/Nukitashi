			en = {
				{
					name = {"美岬", "Misaki"},
					"“Did you make him cum?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“让他射了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「讓他射了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00269",
		linknext = "0081_00271",
		line = 3582,
	},
	["0081_00271"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nah... Just knocked him out cold.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——只是晕过去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——只是暈過去了。」",
					{"rt2"},
