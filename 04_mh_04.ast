	["0081_00326"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00114", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1257", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I have no fucking idea, but it looks even worse than during Shootdown King. Hell, even some SS are getting down and dirty outside their usual posts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然不知道原因……不过这可能比击坠王的时候更可怕……一部分FS好像也都离开岗位进行性产行为……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然不知道原因……不過這可能比擊墜王的時候更可怕……一部分FS好像也都離開崗位進行性產行為……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00325",
		linknext = "0081_00327",
		line = 4390,
	},
	["0081_00327"] = {
