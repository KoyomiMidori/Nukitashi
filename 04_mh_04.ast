	["0081_00320"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's say we tried to get the data directly from a terminal. Where do you think would be the easiest place to sneak into and get it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，假设要从某个终端获取数据的话……最容易进去的地方是哪里？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，假設要從某個終端獲取數據的話……最容易進去的地方是哪裡？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00319",
		linknext = "0081_00321",
		line = 4306,
	},
	["0081_00321"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1254", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I'll look into it and get back to you. Most likely it'd be the student council room, but... huh? Whoa, whoa, what the fuck!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那我可能要调查一下。冷静想想应该是学生会室吧……咦？哇，这是怎么回事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那我可能要調查一下。冷靜想想應該是學生會室吧……咦？哇，這是怎麼回事……」",
					{"rt2"},
				},
			},
		},
