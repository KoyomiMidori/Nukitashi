			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sigh... still, you just had to touch my belly again. It felt like you were licking my flab with all ten of your fingers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过……哈啊……又被摸了……这软软的肉块，像被10根手指舔过一样被摸了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過……哈啊……又被摸了……這軟軟的肉塊，像被10根手指舔過一樣被摸了……」",
					{"rt2"},
				},
			},
		},
