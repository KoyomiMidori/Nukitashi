				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Phew... we should be okay here, hardly anyone comes out this far. Thanks, Tanizaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呼……到这里应该就没问题了。这一带年轻人本来就很少……谢谢你，谷崎先生……”",
