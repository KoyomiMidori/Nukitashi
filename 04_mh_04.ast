	["0081_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Soy el único que sabe lo linda que es. Es el clásico estereotipo de heroína aburrida de los juegos y los animes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有我知道她可爱的一面——如果用游戏或动画比喻的话，她一定就是那样的女主角吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有我知道她可愛的一面——如果用遊戲或動畫比喻的話，她一定就是那樣的女主角吧。",
					{"rt2"},
				},
