		line = 6286,
	},
	["0081_00461"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Can a girl just tell a guy that he's cool that easily?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——女生会那么轻易地对异性说出“好帅”之类的话吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"——女生會那麼輕易地對異性說出「好帥」之類的話嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00460",
		linknext = "0081_00462",
		line = 6296,
	},
	["0081_00462"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase and Wata probably could, but Nanase's a slut and Wata is Wata.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑和渡酱的话平时是会说没错——但奈奈濑是婊子，渡酱则是渡酱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨和渡醬的話平時是會說沒錯——但奈奈瀨是婊子，渡醬則是渡醬。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00461",
		linknext = "0081_00463",
		line = 6306,
	},
	["0081_00463"] = {
		{"text"},
		text = {
