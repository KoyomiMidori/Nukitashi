	["0081_00524"] = {
		{"fg", file="ikuko_01m_00001", file2="ikuko_01m_00201", file3="ikuko_01m_00302", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0181", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hehe, people with sprained ankles shouldn't push themselves so hard. Letting yourself get hurt like that to protect a girl... I like you more and more each time I see you ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵……脚都扭伤了，还是不要太勉强比较好哦——？受伤了还要保护女孩子，好帅啊……越来越喜欢你了♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵……腳都扭傷了，還是不要太勉強比較好哦——？受傷了還要保護女孩子，好帥啊……越來越喜歡你了♪」",
					{"rt2"},
				},
			},
		},
