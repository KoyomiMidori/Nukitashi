	["0081_00132"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0135", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Today, you students of Minotsuki Academy will be doing volunteer work at Lewd Land.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“今天，我们将请水乃月学园的各位到变态乐园做志愿者。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「今天，我們將請水乃月學園的各位到變態樂園做志工。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00131",
