			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Empacó algunas sobras de anoche. Si todavía tienes hambre, puedes comer un poco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我把剩下的料理带过来了。如果肚子还饿的话，可以给你吃一点……”",
