	["0081_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This afternoon is a field trip involving multiple year levels. We were able to rush and barely make it on the transfer bus on time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天下午是学年联合的课外教学——多亏我们有抓紧时间，总算坐上了移动用的公交车。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天下午是學年聯合的課外教學——多虧我們有抓緊時間，總算坐上了移動用的巴士。",
					{"rt2"},
				},
