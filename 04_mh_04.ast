	["0081_00087"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00116", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1300] = {
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00126", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=1300, time=300, mode=3, x=0, y=0},
			},
			[2600] = {
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00104", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=2600, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0628", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Glick, glick... paaah. Desafiar tu apetito y hacer dieta es contradecir la naturaleza humana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咕噜咕噜……噗哈啊。我在想，抵抗食欲的减肥，是违反作为人的本能。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咕嚕咕嚕……噗哈啊。我在想，抵抗食慾的減肥，是違反作為人的本能。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00086",
		linknext = "0081_00088",
		line = 1123,
	},
	["0081_00088"] = {
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00304", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3000] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine", delay2=3000},
			},
			[5000] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine", delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0629", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“In fact, I read online once that the stress from that kind of diet will actually make most people fatter. Even for those who lose weight, the majority aren't able to keep up the diet and gain the weight right back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那种减肥，可能反而会因为压力而变胖。而且就算变瘦了，如果无法继续控制食欲的话，也没办法继续保持身材对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那種減肥，可能反而會因為壓力而變胖。而且就算變瘦了，如果無法繼續控制食慾的話，也沒辦法繼續保持身材對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00087",
		linknext = "0081_00089",
		line = 1140,
	},
	["0081_00089"] = {
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3500] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine", delay2=3500},
			},
			[7000] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine", delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0630", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Spending your whole life going against your natural instincts and forcing yourself to diet is a fate worse than death, if you ask me. I'd say the most important element of proper 'dieting' is actually exercise.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是，为了身材而控制食欲生活不就跟死了一样吗？所以我认为减肥的基本不是饮食，而是运动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是，為了身材而控制食慾生活不就跟死了一樣嗎？所以我認為減肥的基本不是飲食，而是運動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00088",
		linknext = "0081_00090",
		line = 1155,
	},
	["0081_00090"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fine, but I'm sure holding off on eating a single bag of chips won't stress you out to the point where you gain weight, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之先别吃薯片了吧？”",
