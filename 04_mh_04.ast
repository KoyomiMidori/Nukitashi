			},
			cn = {
				{
					name = {"美岬"},
					"“哇啊啊有人！？……啊，是橘同学吗？你吓了我一跳啊……请跟我打声招呼吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哇啊啊有人！？……啊，是橘同學嗎？你嚇了我一跳啊……請跟我打聲招呼吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00039",
		linknext = "0081_00041",
		line = 507,
	},
	["0081_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí te hablé. No te diste cuenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我有打招呼，但你没有注意到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我有打招呼，但你沒有注意到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00040",
		linknext = "0081_00042",
		line = 519,
	},
	["0081_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No es como que contradictorio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……怎么觉得立场和平时颠倒了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……怎麼覺得立場和平時顛倒了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00041",
		linknext = "0081_00043",
		line = 531,
	},
	["0081_00043"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0610", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sí, tienes razón. Cuando leo, tiendo a concentrarme tanto que dejo de fijarme en lo que me rodea. Lo siento...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“原来如此……我只要一集中精神读书，就会很容易看不见周围……对不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「原來如此……我只要一集中精神讀書，就會很容易看不見周圍……對不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00042",
		linknext = "0081_00044",
		line = 545,
	},
	["0081_00044"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, no me molesta. ¿Estás leyendo cosas de Natsume Souseki?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，我并没有特别在意——话说你在看夏目漱石的书吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，我並沒有特別在意——話說你在看夏目漱石的書嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00043",
		linknext = "0081_00045",
		line = 557,
	},
	["0081_00045"] = {
		{"bgm", stop=1},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0611", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, estoy leyendo algo de Masturbe Souseki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，是高潮漱石。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，是高潮漱石。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00044",
		linknext = "0081_00046",
		line = 572,
	},
	["0081_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“…………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「…………」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00045",
		linknext = "0081_00047",
		line = 583,
	},
	["0081_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué acabas de decir...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“抱歉，你说什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「抱歉，你說什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00046",
		linknext = "0081_00048",
		line = 595,
	},
	["0081_00048"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0612", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Masturbe Souseki. ¿No lo conoces? Es un autor muy famoso en esta isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“高潮漱石。你不知道吗？他是住在岛内的作家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「高潮漱石。你不知道嗎？他是住在島內的作家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00047",
		linknext = "0081_00049",
		line = 609,
	},
	["0081_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, pero escuchar eso me da migraña...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“糟了，我的头开始痛了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「糟了，我的頭開始痛了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00048",
		linknext = "0081_00050",
		line = 621,
	},
	["0081_00050"] = {
		{"bgm", file="bgm08", vol=100},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0613", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Souseki es genial. Una y otra vez da vida al genio literario de la era Meiji, y sus historias están llenas de una sátira e ironía ingeniosas. ¡Me tiene inmersa en sus mundos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“漱石老师很厉害哦……用连明治时代的文豪也会赞叹的笔调写出那样充满讽刺的风趣故事……很让人上瘾呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「漱石老師很厲害哦……用連明治時代的文豪也會讚歎的筆調寫出那樣充滿諷刺的風趣故事……很讓人上癮呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00049",
		linknext = "0081_00051",
		line = 636,
	},
	["0081_00051"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00126", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0614", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Su mejor obra es 'Soy un Coño'. ¡Sus proyecciones cínicas y divertidas desde el punto de vista de un coño son muy entretenidas de leer!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“特别是这部‘我是攻’的完成度非常惊人！从攻的观点来讽刺社会的有趣之处真是痛快无比！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「特別是這部『我是攻』的完成度非常驚人！從攻的觀點來諷刺社會的有趣之處真是痛快無比！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00050",
		linknext = "0081_00052",
		line = 650,
	},
	["0081_00052"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[700] = {
				{"fg", file="misaki_01m_00001", file3="misaki_01m_00304", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=700, time=300, mode=3, x=0, y=0},
			},
			[4800] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0615", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Esa hermosa línea introductoria, 'Soy un coño. Me llamo Vagina.' sí que te sabe enganchar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“开头写的‘我是攻。宿命是战斗’这句话特别出色，光是这句话，就让人产生一种不得不读下去的心情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「開頭寫的『我是攻。宿命是戰鬥』這句話特別出色，光是這句話，就讓人產生一種不得不讀下去的心情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00051",
		linknext = "0081_00053",
		line = 668,
	},
	["0081_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La lectora que siempre está callada se vuelve locuaz y animada cuando habla de libros. Eso es normal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平时安静的文学少女，说到书的话题突然很多嘴——这是很常有的套路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平時安靜的文學少女，說到書的話題突然很多嘴——這是很常有的套路。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00052",
		linknext = "0081_00054",
		line = 678,
	},
	["0081_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si estuviera hablando de Natsume Souseki, me parecería encantador.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果她说的是夏目漱石，我也会欣然接受吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果她說的是夏目漱石，我也會欣然接受吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00053",
		linknext = "0081_00055",
		line = 688,
	},
	["0081_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lamentablemente, me está hablando de Masturbe Souseki.",
					{"rt2"},
				},
			},
			cn = {
				{
					"遗憾的是，她说的是高潮漱石。",
					{"rt2"},
				},
			},
			tw = {
				{
					"遺憾的是，她說的是高潮漱石。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00054",
		linknext = "0081_00056",
		line = 698,
	},
	["0081_00056"] = {
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00301", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0616", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Es tan interesante que hasta Ninomiya Sontoku dejaría de caminar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“有趣到即使是二宫金次郎也会停下脚步读一读哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「有趣到即使是二宮金次郎也會停下腳步讀一讀哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00055",
		linknext = "0081_00057",
		line = 712,
	},
	["0081_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero la mayoría se sienta a la hora de leer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……他最近好像都坐着读呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……他最近好像都坐著讀呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00056",
		linknext = "0081_00058",
		line = 724,
	},
	["0081_00058"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
