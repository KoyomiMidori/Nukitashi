			},
		},
		text = {
			vo = {
				{"vo", file="nanase0666", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Why's that... Oh, because the SHO's color is blue? How original.”",
					{"rt2"},
				},
			},
