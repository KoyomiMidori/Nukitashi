		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, mode=3, x=0, y=0},
		{"extrans", sync=0, time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0684", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Still, things have gotten quite lively in the NLNS with the number of people increasing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“——不过话说回来，NLNS的人也增加了，变得相当热闹了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「——不過話說回來，NLNS的人也增加了，變得相當熱鬧了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00263",
