	["0026_00099"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We've all come together as a team.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——我们像这样作为团队聚集在了一起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——我們像這樣作為團隊聚集在了一起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00098",
		linknext = "0026_00100",
		line = 1331,
	},
	["0026_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're kindred spirits, companions who have gathered together to evade, escape, and make it home safely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“逃跑，回避，逃跑……为了平安回归而聚集在一起的、志同道合的同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「逃跑，迴避，逃跑……為了平安回歸而聚集在一起的、志同道合的同伴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00099",
		linknext = "0026_00101",
		line = 1342,
	},
	["0026_00101"] = {
