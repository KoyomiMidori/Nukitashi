		linknext = "0026_00118",
		line = 1606,
	},
	["0026_00118"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=500},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0440", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh yeah, Tachibana-kun. Didn't Tachibana-kun say something about unity as a group earlier?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……啊，对了，橘君。刚才你不是说过要作为团队团结起来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……啊，對了，橘君。剛才你不是說過要作為團隊團結起來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00117",
		linknext = "0026_00119",
		line = 1622,
	},
	["0026_00119"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. The last battle we had was a mess. We're too discombobulated. We need a united front.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。上次的战斗队伍散乱了。团结很重要。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。上次的戰鬥隊伍散亂了。團結很重要。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00118",
		linknext = "0026_00120",
		line = 1634,
	},
	["0026_00120"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0441", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I've been thinking the same. So I've been wondering about how our team's supposed to be more on the same page.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我也这么觉得。所以我一直在想有没有什么办法能让大家更加团结一致。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我也這麼覺得。所以我一直在想有沒有什麼辦法能讓大家更加團結一致。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00119",
		linknext = "0026_00121",
		line = 1646,
	},
	["0026_00121"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0442", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Like, maybe we could do something to have some more solidarity as a team?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果说像个团队一样，大家都拿个统一的东西怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果說像個團隊一樣，大家都拿個統一的東西怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00120",
		linknext = "0026_00122",
		line = 1658,
	},
	["0026_00122"] = {
		{"fgact", ch="ヒナミ", id=5, act="移動", x=200, y=0, time=700},
		{"fgact", ch="美岬", id=6, act="移動", x=-200, y=0, time=700},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=700, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0665", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, that would be good. Like how in baseball and soccer, the teams have a uniform which gives them a sense of camaraderie.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，也许不错。棒球或者足球也有为了让球员产生归属感的制服……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，也許不錯。棒球或者足球也有為了讓球員產生歸屬感的制服……」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00121",
		linknext = "0026_00123",
		line = 1674,
	},
	["0026_00123"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0604", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But we'd need something subtle which would express that we're an anti-copulation team...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是太明显的话就好像在宣扬自己是反交尾势力一样，选个比较低调的吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是太明顯的話就好像在宣揚自己是反交尾勢力一樣，選個比較低調的吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00122",
		linknext = "0026_00124",
		line = 1687,
	},
	["0026_00124"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0212", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So... something like having a team color that we all wear...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那样的话……决定个主题颜色，穿那个颜色的东西之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那樣的話……決定個主題顏色，穿那個顏色的東西之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00123",
		linknext = "0026_00125",
		line = 1701,
	},
	["0026_00125"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
