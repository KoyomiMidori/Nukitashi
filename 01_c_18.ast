	["0026_00107"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Being able to form a team with you all... has been my honor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“能和你们组队……我真的很幸运。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「能和你們組隊……我真的很幸運。」",
					{"rt2"},
				},
