			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I'm just glad I don't have to think about the SS for a while now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“想到可以暂时不考虑SS的事，心情真的相当轻松。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「想到可以暫時不考慮SS的事，心情真的相當輕鬆。」",
