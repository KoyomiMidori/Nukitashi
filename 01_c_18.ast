	["0026_00060"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00117", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no way I can breathe a word about this to them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有这件事，就算是队伍的同伴，也绝对说不出口——",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有這件事，就算是隊伍的同伴，也絕對說不出口——",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00059",
		linknext = "0026_00061",
		line = 813,
	},
	["0026_00061"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0655", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, knowing you, you probably just chucked sand in her face or some other underhanded shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……反正不就是狼狈地扔沙子让对方胆怯，然后再用些卑鄙的手段不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……反正不就是狼狽地扔沙子讓對方膽怯，然後再用些卑鄙的手段不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00060",
		linknext = "0026_00062",
		line = 827,
	},
	["0026_00062"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey! I fight with HONOR, dammit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什、我怎么会——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什、我怎麼會——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00061",
		linknext = "0026_00063",
		line = 839,
	},
	["0026_00063"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0656", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, anyway, you're safe, all's well that ends well and stuff. We'd better get to the main event now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“总之你平安无事就好了，那我们开始今天的主题吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「總之你平安無事就好了，那我們開始今天的主題吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00062",
		linknext = "0026_00064",
		line = 854,
	},
	["0026_00064"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Main event...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“主题……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「主題……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00063",
		linknext = "0026_00065",
		line = 866,
	},
	["0026_00065"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1900] = {
				{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=1900, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=1900},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0432", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, right! Heh heh, you see... We all decided we should have a little celebration today!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，对了！呼呼，实际上今天……我们想要来庆祝一下！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，對了！呼呼，實際上今天……我們想要來慶祝一下！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00064",
		linknext = "0026_00066",
		line = 883,
	},
	["0026_00066"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A celebration?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“庆祝？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「慶祝？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00065",
		linknext = "0026_00067",
		line = 895,
	},
	["0026_00067"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0204", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“A celebration that Tachibana-san made it home safely, but more importantly, we'd like to commemorate becoming members of this team, and everything it's done for us and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“庆祝橘同学能平安回来，还有多亏了橘同学，我们成员又能共聚一堂……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「慶祝橘同學能平安回來，還有多虧了橘同學，我們成員又能共聚一堂……」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00066",
		linknext = "0026_00068",
		line = 909,
	},
	["0026_00068"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0657", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah. I figured we could have ourselves a little feast. Think of it as an overdue pep rally, I guess?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对。我想开个小宴会。虽然有点迟，但就像决意集会那样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對。我想開個小宴會。雖然有點遲，但就像決意集會那樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00067",
		linknext = "0026_00069",
		line = 923,
	},
	["0026_00069"] = {
		{"se", id=0, loop=0, file="se_a182"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0433", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“And Nanase-chan said she'd handle the cooking! She's got all the ingredients and everything!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“料理是由奈奈濑酱来做呢！材料也买了很多！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「料理是由奈奈瀨醬來做呢！材料也買了很多！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00068",
		linknext = "0026_00070",
		line = 936,
	},
	["0026_00070"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00109", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0601", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A-A-A-A feast cooked by Nanase-san...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“奈奈奈、奈奈濑同学的宴会料理……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「奈奈奈、奈奈瀨同學的宴會料理……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00069",
		linknext = "0026_00071",
		line = 949,
	},
	["0026_00071"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0205", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wow... I've heard the stories about Nanase-san's cooking, so I can hardly wait! Oh, but I'd better take things in moderation...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哇……奈奈濑同学，听说你很会做菜，我很期待……！啊……不过我要小心不能吃太多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哇……奈奈瀨同學，聽說你很會做菜，我很期待……！啊……不過我要小心不能吃太多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00070",
		linknext = "0026_00072",
		line = 964,
	},
	["0026_00072"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0658", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“All right, I'm gonna need everyone's help. Let's get this done quickly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那大家帮忙一下，赶快做一做吧。”",
					{"rt2"},
				},
			},
			tw = {
