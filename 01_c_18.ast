			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We've cooperated to overcome massive hardships.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们共同克服了巨大的困难。”",
