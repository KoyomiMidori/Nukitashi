	["0026_00042"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0429", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, Tachibana-kun is amazing! Like, that girl's apparently the strongest of the whole SS attack force! I heard that from Rei-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事，不过橘君好厉害啊！因为我有听礼酱说过，那个人是SS攻击部队中最厉害的的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒事，不過橘君好厲害啊！因為我有聽禮醬說過，那個人是SS攻擊部隊中最厲害的的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00041",
		linknext = "0026_00043",
		line = 571,
	},
	["0026_00043"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0201", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, right... The SS's first squad is often just called the 'attack force', and apparently that squad's commander was appointed for being the strongest fighter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这么说来……SS的一队又被称为‘突击部队’，个人战斗力最高的人会被任命为中队长……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這麼說來……SS的一隊又被稱為『突擊部隊』，個人戰鬥力最高的人會被任命為中隊長……」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00042",
		linknext = "0026_00044",
		line = 585,
	},
	["0026_00044"] = {
