		linkback = "0026_00106",
		linknext = "0026_00108",
		line = 1432,
	},
	["0026_00108"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We rest now, solely for the sake of unity as a group. So let's enjoy today to the fullest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是我们为了作为组织团结在一起，而实施的休养，虽然只是一时的——但现在就尽情地享受吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是我們為了作為組織團結在一起，而實施的休養，雖然只是一時的——但現在就盡情地享受吧。」",
					{"rt2"},
				},
			},
		},
