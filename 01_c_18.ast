					{"rt2"},
				},
			},
			en = {
				{
					"I exchange glances with Asa-chan, but she just shakes her head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我向麻沙酱使了个眼色，但被无奈地摇了摇头。",
