	["0026_00116"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0664", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Glad you enjoyed it... I'll clean up, you guys relax.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好好，给大家献丑了……我收拾就好了大家休息吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好好，給大家獻醜了……我收拾就好了大家休息吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00115",
		linknext = "0026_00117",
		line = 1592,
	},
	["0026_00117"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=200, y=0, time=600},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=400},
		{"text"},
		text = {
			ja = {
