	["0094_00378"] = {
		{"se", id=1, loop=1, file="se_d031", vol=40},
		{"cgdel", id=18, lv=5, time=100, alphadel=1},
		{"bg", id=18, file="bg26_2_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0020", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Heh... They got right to the snoggin'. If that ain't true love. Ya seein' this, me love? Ta think the Misaki ya changed the diapers of's grown up this much...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“哦……彼此没有一丝迷惑的吻……这就是爱……看呀，老婆子……你换过尿布的美岬酱，都已经长得这么大了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「哦……彼此沒有一絲迷惑的吻……這就是愛……看呀，老婆子……你換過尿布的美岬醬，都已經長得這麼大了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00377",
		linknext = "0094_00379",
		line = 5185,
	},
	["0094_00379"] = {
