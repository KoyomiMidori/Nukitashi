		},
		linkback = "0094_00314",
		linknext = "0094_00316",
		line = 4392,
	},
	["0094_00316"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00113", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0508", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Darling? What's wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲爱的？怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「親愛的？怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00315",
		linknext = "0094_00317",
		line = 4405,
	},
	["0094_00317"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If we could fix that fighter plane, do you think we could go on the offensive?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果——能修好那架战斗机的话……我们不就可以展开攻势了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果——能修好那架戰鬥機的話……我們不就可以展開攻勢了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00316",
		linknext = "0094_00318",
		line = 4417,
	},
	["0094_00318"] = {
