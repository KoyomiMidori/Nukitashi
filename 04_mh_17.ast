					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hang on a sec.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……等一下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……等一下。」",
					{"rt2"},
				},
