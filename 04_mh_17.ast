	["0094_00380"] = {
		{"bgm", file="bgm31", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0021", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Shaddap! I dun promised dozens'a ladies a future, ya jelly-bellied lass!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“吵死啦！别看我这样，与我一起立下誓言的老婆子可是有好几十个呢！看我摆弄你的肚子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「吵死啦！別看我這樣，與我一起立下誓言的老婆子可是有好幾十個呢！看我擺弄你的肚子！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00379",
		linknext = "0094_00381",
		line = 5216,
	},
	["0094_00381"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="浮遊横", loop=5, size=12.5, time=75, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I listen to the old man rattling on, almost inappropriately for his age, I can't help but smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着内心依然年轻的健藏老人大喊大叫，我不禁露出了苦笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著內心依然年輕的健藏老人大喊大叫，我不禁露出了苦笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00380",
		linknext = "0094_00382",
		line = 5229,
	},
	["0094_00382"] = {
