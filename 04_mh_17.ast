		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg10_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"se", id=1, loop=1, file="se_d031", vol=60},
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0004", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Ain't happenin', lad!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“唉——做不到啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「唉——做不到啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00317",
		linknext = "0094_00319",
		line = 4468,
	},
	["0094_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After taking Asa home, I consulted the old man, but he cheerfully dismissed the idea outright.",
					{"rt2"},
				},
			},
			cn = {
				{
					"先把麻沙酱送回家后，我立刻去和健藏老人商量——结果被他爽快地拒绝了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"先把麻沙醬送回家後，我立刻去和健藏老人商量——結果被他爽快地拒絕了。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00318",
		linknext = "0094_00320",
		line = 4478,
	},
	["0094_00320"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don't even want to know why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……可以告诉我理由吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……可以告訴我理由嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00319",
		linknext = "0094_00321",
		line = 4490,
	},
	["0094_00321"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0005", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Yer talkin' 'bout the Seiran Prototype, yeah? I seen it myself. It's an old wartime model.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“你是指试制晴岚对吧？我也有直接看到过……那是战时的机体，早就已经太旧了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「你是指試製晴嵐對吧？我也有直接看到過……那是戰時的機體，早就已經太舊了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00320",
		linknext = "0094_00322",
		line = 4502,
	},
	["0094_00322"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0006", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“There ain't gonna be parts fer somethin' like that no more, and even if I did fix 'er up, she's a carrier-borne attack aircraft. She won't get nowhere without a catapult, y'see?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“已经找不到当时的零件了，就算再修理一下，也只会变成水上攻击机。如果没有弹射器，就没办法起飞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「已經找不到當時的零件了，就算再修理一下，也只會變成水上攻擊機。如果沒有彈射器，就沒辦法起飛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00321",
		linknext = "0094_00323",
		line = 4514,
	},
	["0094_00323"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, okay... sigh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……唉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊……唉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00322",
		linknext = "0094_00324",
		line = 4526,
	},
	["0094_00324"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought my plan was solid, but I guess not.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本以为是个不错的方案，但是事情没有那么顺利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本以為是個不錯的方案，但是事情沒有那麼順利。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00323",
		linknext = "0094_00325",
		line = 4536,
	},
	["0094_00325"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0007", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“But why d'ya wanna know? Are ya military nuts or somethin'?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“不过你为什么突然说这些？你喜欢那驾飞机吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
