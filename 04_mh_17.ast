		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bg", id=2, file="bg26_2l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-105, y=-5, time=30000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Who'd have thought I'd see this day?",
					{"rt2"},
				},
			},
			cn = {
				{
					"真没想到会有这样的一天。",
					{"rt2"},
