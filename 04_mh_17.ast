			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“嘿嘿嘿！昨天还叫我淳之介爷爷呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
