				{
					name = {"健蔵", "健藏"},
					"“原来如此啊……怪不得最近总觉得奇怪，原来事情发展成这样了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「原來如此啊……怪不得最近總覺得奇怪，原來事情發展成這樣了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00366",
		linknext = "0094_00368",
		line = 5049,
	},
	["0094_00368"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki could be put in harm's way at any time. So I need to beat the yakuza and destroy the new law at any cost.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就连美岬什么时候会面临危险都不知道。所以，我无论如何都想打败黑社会，摧毁条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就連美岬什麼時候會面臨危險都不知道。所以，我無論如何都想打敗黑社會，摧毀條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00367",
		linknext = "0094_00369",
		line = 5061,
	},
	["0094_00369"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0015", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Hm... Well, fighter plane's off th' table, but that Magical Mirror Misaki's bin drivin'... Aikaze, she called it? Hee hee hee, I can work a bit o' me conversion magic on that fer sure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“嗯……虽然战斗机有点难，但美岬酱的魔镜号……叫爱风来着？嘿嘿嘿，那个我倒是能够改造。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「嗯……雖然戰鬥機有點難，但美岬醬的魔鏡號……叫愛風來著？嘿嘿嘿，那個我倒是能夠改造。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00368",
		linknext = "0094_00370",
		line = 5073,
	},
	["0094_00370"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Conversion... You can do that for us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“改造……那种事情做得到吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「改造……那種事情做得到嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00369",
		linknext = "0094_00371",
		line = 5085,
	},
	["0094_00371"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Ya brought up that d10o stuff... If'n I have somma that, I could turn 'er into an armored vehicle. Hee hee, an' I could even deck 'er out wit' some heavy weaponry... Whee hee hee hee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“刚才听到的d10o……只要有那个，就可以让它变成装甲车了吧……嘿嘿，而且还可以装上各种武器……嘿嘿嘿嘿嘿！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「剛才聽到的d10o……只要有那個，就可以讓它變成裝甲車了吧……嘿嘿，而且還可以裝上各種武器……嘿嘿嘿嘿嘿！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00370",
		linknext = "0094_00372",
		line = 5097,
	},
	["0094_00372"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Conversion or no conversion, just one vehicle won't be enough to storm the OSS HQ.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使改造了，光是爱风也无法攻进SHO的总部。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使改造了，光是愛風也無法攻進SHO的總部。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00371",
		linknext = "0094_00373",
		line = 5107,
	},
	["0094_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if we have an armored vehicle on our side, that'll definitely tip the scales in our favor a little for future battles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——如果有了装甲车，肯定会对以后的战斗有所帮助。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——如果有了裝甲車，肯定會對以後的戰鬥有所幫助。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00372",
		linknext = "0094_00374",
		line = 5117,
	},
	["0094_00374"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then please do, Mr. Kenzou! I'll provide all the d10o you need for it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“健藏先生，我会提供d10o的。所以请务必……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「健藏先生，我會提供d10o的。所以請務必……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00373",
		linknext = "0094_00375",
		line = 5129,
	},
	["0094_00375"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0017", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Hold up! Listen, laddie. I know I dun told ya Misaki's like me idol, but really, she's more like a daughter t'me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“嗯，等一下！听好了年轻人，虽然我刚才说美岬酱是偶像……但对我来说，她也像我的女儿一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「嗯，等一下！聽好了年輕人，雖然我剛才說美岬醬是偶像……但對我來說，她也像我的女兒一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00374",
		linknext = "0094_00376",
		line = 5141,
	},
	["0094_00376"] = {
		{"se", id=1, stop=1, time=2000},
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0018", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Are ya really prepared ta keep 'er safe, no matter what? If ya really love this girl, I want ya t'show me just how much ya do, here 'n now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“你……真的有保护她到底的觉悟吗？你到底有多爱美岬酱……现在就在这里让我见识一下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「你……真的有保護她到底的覺悟嗎？你到底有多愛美岬醬……現在就在這裡讓我見識一下。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00375",
		linknext = "0094_00377",
		line = 5155,
	},
	["0094_00377"] = {
