				{
					name = {"淳之介"},
					"“……好像还远远不够呢。虽然一边解除洗脑一边有在稳步增加……但还不够。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……好像還遠遠不夠呢。雖然一邊解除洗腦一邊有在穩步增加……但還不夠。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00288",
		linknext = "0094_00290",
		line = 4074,
	},
	["0094_00290"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we could find something to suddenly draw the public's attention, maybe we could move things forward, but at our current pace we'll never get anywhere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果能在某个地方引起世人的关注，形势就会一下子发生变化——但照这样发展下去，要凑齐规定数量，将需要很长的时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果能在某個地方引起世人的關注，形勢就會一下子發生變化——但照這樣發展下去，要湊齊規定數量，將需要很長的時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00289",
		linknext = "0094_00291",
		line = 4090,
	},
	["0094_00291"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Meanwhile, Teshima's oppression will go on unchallenged.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这期间内，只能一直容许手嶋的蛮行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這期間內，只能一直容許手嶋的蠻行。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00290",
		linknext = "0094_00292",
		line = 4100,
	},
	["0094_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All that's happening is the potential risk to Misaki is increasing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"危险波及美岬的可能性也会提高。",
					{"rt2"},
				},
			},
			tw = {
				{
					"危險波及美岬的可能性也會提高。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00291",
		linknext = "0094_00293",
		line = 4110,
	},
	["0094_00293"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Goddamn it... If only we could just bum-rush the OSS HQ and root those fuckers out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶……干脆直接攻击SHO总部吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡……乾脆直接攻擊SHO總部吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00292",
		linknext = "0094_00294",
		line = 4122,
	},
	["0094_00294"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00114", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0506", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Don't even try it. You'll be in danger even if you're within earshot of the place. They've got guards on watch everywhere, and if you try to go in by boat, they'll use the batteries.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不行不行。那样的地方，现在光是靠近都很危险哦？他们在里面监视着，要是坐船过去的话，可能会被炮台攻击。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不行不行。那樣的地方，現在光是靠近都很危險哦？他們在裡面監視著，要是坐船過去的話，可能會被砲臺攻擊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00293",
		linknext = "0094_00295",
		line = 4135,
	},
	["0094_00295"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Batteries? You mean, those old artillery installments used by the former Imperial Army? I thought those were just for show.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“炮台……是旧日军的文化遗产吗？那只是装饰品吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「砲臺……是舊日軍的文化遺產嗎？那只是裝飾品吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00294",
		linknext = "0094_00296",
		line = 4147,
	},
	["0094_00296"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00113", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0507", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Nope, pretty sure they're live. Kokie may be a dizzy broad, but she's also a real nut for military-related stuff. The way she goes on about them, I'm pretty sure they're still live.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不，我想还能动。光姬酱虽然很笨但是是个军事通，她有热情地跟我解说过。听她的口气……是现在都还在运作的感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不，我想還能動。光姬醬雖然很笨但是是個軍事通，她有熱情地跟我解說過。聽她的口氣……是現在都還在運作的感覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00295",
		linknext = "0094_00297",
		line = 4161,
	},
	["0094_00297"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sigh... Well, that's just fucking great. This island never fails to have bullshit around every corner.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈……像在开玩笑一样呢。这个岛真的是有够乱来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈……像在開玩笑一樣呢。這個島真的是有夠亂來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00296",
		linknext = "0094_00298",
		line = 4173,
	},
	["0094_00298"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yeah, firing cannons at people sounds fucking insane, but so does a law that encourages perverted sex to the point of making abstinence a criminal offense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然觉得如果开炮什么的反而会成为大问题——但在鼓励变态做爱的岛上讲常识才显得荒谬吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然覺得如果開砲什麼的反而會成為大問題——但在鼓勵變態做愛的島上講常識才顯得荒謬吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00297",
		linknext = "0094_00299",
		line = 4183,
	},
	["0094_00299"] = {
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a193"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A silence falls on us, and all we can hear is the turning of the bike chain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我沉默不语，只听见自行车链子转动的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沉默不語，只聽見自行車鍊子轉動的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00298",
		linknext = "0094_00300",
		line = 4196,
	},
	["0094_00300"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, Misaki, is that Tanizaki? Didn't he die a warrior's death?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个……美岬，那辆脚踏车——难道是谷崎吗？它不是死了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個……美岬，那輛腳踏車——難道是谷崎嗎？它不是死了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00299",
		linknext = "0094_00301",
		line = 4208,
	},
	["0094_00301"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1625", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, yeah. Old Man Kenzou resuscitated him. He's really great with machines; he says he was a mechanical engineer when he was younger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，是的。是健藏爷爷帮我复苏的。他以前就很擅长摆弄机器。他说他年轻的时候是一个机械技师。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，是的。是健藏爺爺幫我複甦的。他以前就很擅長擺弄機器。他說他年輕的時候是一個機械技師。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00300",
		linknext = "0094_00302",
		line = 4221,
	},
	["0094_00302"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ooh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00301",
		linknext = "0094_00303",
		line = 4232,
	},
	["0094_00303"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00204", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[9300] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=9300, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1626", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“To be honest, though, he sounds kinda sus. He always tends to blurt out some pretty tall tales, like, 'I'm the one wot made Mechag*dz*ll*' and stuff. Though I did take him pretty seriously as a kid.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“说实话很可疑。因为他老是说些敷衍的话……机械哥◯拉是他做的之类的……不过我小时候也相信过就是了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「說實話很可疑。因為他老是說些敷衍的話……機械哥◯拉是他做的之類的……不過我小時候也相信過就是了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00302",
		linknext = "0094_00304",
		line = 4248,
	},
	["0094_00304"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fucking adorable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好可爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好可愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00303",
		linknext = "0094_00305",
		line = 4258,
	},
	["0094_00305"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1627", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Regardless, he's really good at what he does. I didn't even ask for this, but he gave Tanizaki an autopilot function, based on how it was done in Aikaze.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过他确实是有技术的。明明没有委托他，但他却自己用爱风的零件帮谷崎先生安装了自动驾驶功能……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過他確實是有技術的。明明沒有委託他，但他卻自己用愛風的零件幫谷崎先生安裝了自動駕駛功能……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00304",
		linknext = "0094_00306",
		line = 4272,
	},
	["0094_00306"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn, that's really something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……那还真了不起啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……那還真了不起啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00305",
		linknext = "0094_00307",
		line = 4284,
	},
	["0094_00307"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00301", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1628", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“At my parents' wedding ceremony, he came up with this human cannonball act, firing the bride and groom out of a cannon. It was really exciting, and it was even caught on video!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“在我父母的结婚典礼上，健藏爷爷还用自己做的人类大炮把新郎新娘射飞热闹了一下……还有留着录像呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「在我父母的結婚典禮上，健藏爺爺還用自己做的人類大砲把新郎新娘射飛熱鬧了一下……還有留著影片呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00306",
		linknext = "0094_00308",
		line = 4298,
	},
	["0094_00308"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“He and your parents are all crazy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“健藏先生和畔家都很厉害啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「健藏先生和畔家都很厲害啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00307",
		linknext = "0094_00309",
		line = 4310,
	},
	["0094_00309"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00307", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1629", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“He's just hot-blooded. With the right materials, he'd even build tanks for fighter planes! That's what he says, at least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“健藏爷爷很激进。他到现在还在说‘只要有材料我就可以造出坦克和战斗机！’”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「健藏爺爺很激進。他到現在還在說『只要有材料我就可以造出坦克和戰鬥機！』」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00308",
		linknext = "0094_00310",
		line = 4324,
	},
	["0094_00310"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn, if only he actually could build us a fighter plane...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“希望他是真的能造出战斗机……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「希望他是真的能造出戰鬥機……」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00309",
		linknext = "0094_00311",
		line = 4336,
	},
	["0094_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we had one of those, we could probably breach OSS HQ.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果真有那种东西的话，或许可以攻破SHO总部。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果真有那種東西的話，或許可以攻破SHO總部。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00310",
		linknext = "0094_00312",
		line = 4346,
	},
	["0094_00312"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Gun batteries and fighter planes would make for a pretty insane situation, even for this island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"炮台和战斗机，感觉真的会变成不得了的状况……",
					{"rt2"},
				},
			},
			tw = {
				{
					"砲臺和戰鬥機，感覺真的會變成不得了的狀況……",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00311",
		linknext = "0094_00313",
		line = 4356,
	},
	["0094_00313"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, that reminds me. Wasn't there a story about a fighter plane being found on the island once?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，这个岛……很久以前就听说有发现过战斗机了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，這個島……很久以前就聽說有發現過戰鬥機了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00312",
		linknext = "0094_00314",
		line = 4368,
	},
	["0094_00314"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I casually ask, and stop walking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无意中说着，我突然停下脚步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無意中說著，我突然停下腳步。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00313",
		linknext = "0094_00315",
		line = 4380,
	},
	["0094_00315"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
