	["0094_00329"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At the end of the day, the perverted sex law really helped revitalize Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说来说去，青蓝岛因为条例而变繁荣也是毋庸置疑的事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說來說去，青藍島因為條例而變繁榮也是毋庸置疑的事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00328",
		linknext = "0094_00330",
		line = 4596,
	},
	["0094_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I assumed all the old folks probably revered Hitoura for bringing prosperity to the island when it was losing inhabitants.",
					{"rt2"},
				},
			},
			cn = {
				{
					"给人口逐渐变得稀少的岛上带来繁荣的仁浦先生——我以为岛上的老人都会信奉他。",
					{"rt2"},
				},
			},
			tw = {
				{
					"給人口逐漸變得稀少的島上帶來繁榮的仁浦先生——我以為島上的老人都會信奉他。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00329",
		linknext = "0094_00331",
		line = 4606,
	},
	["0094_00331"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
