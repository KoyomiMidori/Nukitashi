			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Ya know, I owe Hitoura a lot, but... I had a good, hard think 'bout the law, before they put out the new one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“确实真的该感谢仁浦大人……但在这次的新条例公布之前，我就对这个条例有点意见了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「確實真的該感謝仁浦大人……但在這次的新條例公佈之前，我就對這個條例有點意見了。」",
					{"rt2"},
				},
			},
		},
