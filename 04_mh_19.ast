				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if MARQualia makes her look like Misaki—",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算使用Merqualia的功能把她的外表变成美岬——",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算使用Merqualia的功能把她的外表變成美岬——",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00147",
