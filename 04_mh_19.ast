		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1507", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I apologize for my bro... Though, I'm basically enabling him at this point anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我哥真是对不起……虽然我也做了软件……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我哥真是對不起……雖然我也做了軟體……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00046",
		linknext = "0096_00048",
		line = 747,
	},
	["0096_00048"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn straight she is. Asa was the one who helped me perfect the MARQualia Protocol.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……Merqualia协议的完成离不开麻沙酱的协助。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……Merqualia協議的完成離不開麻沙醬的協助。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00047",
		linknext = "0096_00049",
		line = 759,
	},
	["0096_00049"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"MARQualia, or Misaki Augmented Reality Qualia for short.",
					{"rt2"},
				},
			},
			cn = {
				{
					"Merqualia——正式名称为Misaki AR Qualia。",
					{"rt2"},
				},
			},
			tw = {
				{
					"Merqualia——正式名稱為Misaki AR Qualia。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00048",
		linknext = "0096_00050",
		line = 773,
	},
	["0096_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's loaded with high-res pictures of Misaki, and when the goggles recognize a sex-seeker, they superimpose the pictures over them. It's a type of augmented reality system.",
					{"rt2"},
				},
			},
			cn = {
				{
					"内藏庞大的美岬照片库，能让被护目镜识别的性触者身上重叠美岬的照片——是个有点像扩张现实的系统。",
					{"rt2"},
				},
			},
			tw = {
				{
					"內藏龐大的美岬照片庫，能讓被護目鏡識別的性觸者身上重疊美岬的照片——是個有點像擴張現實的系統。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00049",
		linknext = "0096_00051",
		line = 783,
	},
	["0096_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, the pictures aren't all there is to it. Then it wouldn't feel realistic.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，仅仅那样的话看起来就只是照片，美岬感不够也显得不自然。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，僅僅那樣的話看起來就只是照片，美岬感不夠也顯得不自然。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00050",
		linknext = "0096_00052",
		line = 793,
	},
	["0096_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why, whenever I activate, I have to kiss her, so the way she feels is nice and fresh on my mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此，发动时有必要和美岬接吻，让脑子里都染上美岬的颜色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此，發動時有必要和美岬接吻，讓腦子裡都染上美岬的顏色。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00051",
		linknext = "0096_00053",
		line = 803,
	},
	["0096_00053"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That way, the unnatural quality of her picture overlaid on everyone goes away. It just looks like I'm surrounded by Misakis.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样一来，影像的不自然感就会消失——一切都能被完美地改写成美岬。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣一來，影像的不自然感就會消失——一切都能被完美地改寫成美岬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00052",
		linknext = "0096_00054",
		line = 815,
	},
	["0096_00054"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seriously, everyone on the island looks like Misaki to me now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在现在的我看来，岛上的人全是美岬——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在現在的我看來，島上的人全是美岬——」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00053",
		linknext = "0096_00055",
		line = 827,
	},
	["0096_00055"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6500] = {
				{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0521", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“So if you used that, I could look like Misaki to you, too? Aha ♪ We could have sex again just like we used to!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“也就是说，如果用那个的话，我看起来也会像美岬酱是吗？这样的话……啊哈哈♪又能像以前那样做爱了是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「也就是說，如果用那個的話，我看起來也會像美岬醬是嗎？這樣的話……啊哈哈♪又能像以前那樣做愛了是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00054",
		linknext = "0096_00056",
		line = 842,
	},
	["0096_00056"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, but that's a no-go.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是不可能的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是不可能的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00055",
		linknext = "0096_00057",
		line = 854,
	},
	["0096_00057"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00113", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“For a start, there's no reason to do that. But more importantly, this only works on people I have zero interest in—i.e., randos. And you obviously don't fit that definition.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先没有做爱的理由——最重要的是，Merqualia的对象是和我几乎没有关系的家伙——也就是从我的视点出发的路人角。女部田被排除在外。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先沒有做愛的理由——最重要的是，Merqualia的對象是和我幾乎沒有關係的傢伙——也就是從我的視點出發的路人角。女部田被排除在外。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00056",
		linknext = "0096_00058",
		line = 867,
	},
