		linkback = "0096_00149",
		linknext = "0096_00151",
		line = 2276,
	},
	["0096_00151"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0670", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As much as I'd love to experience it for myself... it appears you've reached your limit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然我也很想尝尝……但是看起来已经达到极限了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然我也很想嚐嚐……但是看起來已經達到極限了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00150",
		linknext = "0096_00152",
		line = 2288,
	},
	["0096_00152"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You think I've got a limit? I just can't get hard to you, bitch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么极限。对你我是无法勃起的——仅此而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼極限。對你我是無法勃起的——僅此而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00151",
		linknext = "0096_00153",
		line = 2300,
	},
	["0096_00153"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00106", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0671", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh really? What a terrible shame.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀，是吗……那真是太遗憾了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀，是嗎……那真是太遺憾了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00152",
		linknext = "0096_00154",
		line = 2314,
	},
	["0096_00154"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0672", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Well, that's fine. It would be a disaster for these girls if I were to pass out here with them. If you'll excuse me, I'll be taking my leave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……不过，现在就先这样了。要是连我都倒下，这些孩子就没人照顾了。今天就先让我暂时撤退吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……不過，現在就先這樣了。要是連我都倒下，這些孩子就沒人照顧了。今天就先讓我暫時撤退吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00153",
		linknext = "0096_00155",
		line = 2328,
	},
	["0096_00155"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll have you know that they won't listen to Teshima anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我话说在前头……他们不会再听手嶋的话了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我話說在前頭……他們不會再聽手嶋的話了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00154",
		linknext = "0096_00156",
		line = 2340,
	},
	["0096_00156"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0673", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, I'm aware of what you've been doing. That being said, they'll probably still listen to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，我很清楚。不过……如果是我说的话或许会听吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，我很清楚。不過……如果是我說的話或許會聽吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00155",
		linknext = "0096_00157",
		line = 2354,
	},
	["0096_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's true.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00156",
		linknext = "0096_00158",
		line = 2364,
	},
	["0096_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Most of the SS respect and follow the president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听说FS的人大部分都为学生会长所倾心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽說FS的人大部分都為學生會長所傾心。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00157",
		linknext = "0096_00159",
		line = 2374,
	},
	["0096_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In fact, even though we undid Hanamaru's brainwashing, she hasn't joined our cause.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事实上，花丸委员长也解开了洗脑——但她还是没有站在我们这边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"事實上，花丸委員長也解開了洗腦——但她還是沒有站在我們這邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00158",
		linknext = "0096_00160",
		line = 2384,
	},
	["0096_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's got her own opinion on the new perverted sex law, but she's not the type to act on her own against the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然听说她也对新・变态条例有自己的想法，但只要她的立场还是FS，就不能以个人的名义擅自行动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然聽說她也對新・變態條例有自己的想法，但只要她的立場還是FS，就不能以個人的名義擅自行動。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00159",
		linknext = "0096_00161",
		line = 2394,
	},
	["0096_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if I were to free every member of the SS, as long as the president is still under Teshima's control, they all are.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算能个别解除洗脑——但如果不能解开学生会长的洗脑，FS实际上就不能从手嶋的支配中解放出来吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算能個別解除洗腦——但如果不能解開學生會長的洗腦，FS實際上就不能從手嶋的支配中解放出來吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00160",
		linknext = "0096_00162",
		line = 2404,
	},
	["0096_00162"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0674", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“We've caused you quite the inconvenience. Please try to take good care of Ikuko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那么，打扰你了。郁子的事……就拜托你了哦，前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那麼，打擾你了。郁子的事……就拜託你了哦，前輩？」",
					{"rt2"},
				},
			},
		},
