	["0096_00090"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0665", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I've heard so much about you. You set a trap for a large troupe of the SS, and you even beat our prized special advance guard member Ikuko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我很清楚你的情况。你给FS的大部队设了圈套，还赢了我们引以为豪的特别尖兵——郁子对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我很清楚你的情況。你給FS的大部隊設了圈套，還贏了我們引以為豪的特別尖兵——郁子對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00089",
		linknext = "0096_00091",
		line = 1351,
	},
	["0096_00091"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Prized? Big talk from the woman who took her place in the SS away from her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“引以为豪？你把她从FS赶了出来，竟然还能说出那样的话……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「引以為豪？你把她從FS趕了出來，竟然還能說出那樣的話……！」",
					{"rt2"},
				},
			},
		},
