					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我收到了你是反交尾势力的报告……但一问之下，听说你最近都毫不在意地在做爱呢。我能看看——你的力量吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我收到了你是反交尾勢力的報告……但一問之下，聽說你最近都毫不在意地在做愛呢。我能看看——你的力量嗎？」",
					{"rt2"},
				},
			},
		},
