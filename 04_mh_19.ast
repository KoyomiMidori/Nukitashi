			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It's different when she's speaking to an audience. In person-to-person terms, she's more of a physical communicator.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那种的和闲聊又是不一样的能力了。对桐香酱来说，交流就是用身体来进行的行为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「那種的和閒聊又是不一樣的能力了。對桐香醬來說，交流就是用身體來進行的行為。」",
					{"rt2"},
				},
			},
		},
