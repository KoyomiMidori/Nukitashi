		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg21_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_033_00000"},
		{"bgm", file="bgm04.5", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, where do we hit first?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——首先要从哪里进攻呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——首先要從哪裡進攻呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00069",
		linknext = "0096_00071",
		line = 1116,
	},
	["0096_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We boldly walk through the school building to the exit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我正大光明地走在教学楼里，来到出入口前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我正大光明地走在校舍裡，來到出入口前。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00070",
		linknext = "0096_00072",
		line = 1126,
	},
	["0096_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since I'm still working on undoing brainwashing, I need to spend lots of time in and around crowded areas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然目的是解除洗脑，那就有必要尽量去人多的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然目的是解除洗腦，那就有必要盡量去人多的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00071",
		linknext = "0096_00073",
		line = 1136,
	},
	["0096_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had everyone else go home through the limestone cave, and I'll rendezvous with them later.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于是我让其他成员从钟乳洞路线回家，之后再汇合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"於是我讓其他成員從鐘乳洞路線回家，之後再會合。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00072",
		linknext = "0096_00074",
		line = 1146,
	},
	["0096_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, are there any more brainwashed students present on the campus?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，校园里还有被洗脑的学生吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，校園裡還有被洗腦的學生嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00073",
		linknext = "0096_00075",
		line = 1157,
	},
	["0096_00075"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1510", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Can't say for sure whether they're brainwashed, but I'm picking up some sex seekers. Signals in the school building, and also the courtyard... huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然不能判断洗脑的有无，但性触者到处都是……教学楼里、操场上……咦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然不能判斷洗腦的有無，但性觸者到處都是……校舍裡、操場上……咦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00074",
		linknext = "0096_00076",
		line = 1170,
	},
	["0096_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00075",
		linknext = "0096_00077",
		line = 1182,
	},
	["0096_00077"] = {
		{"bgm", stop=1},
		{"fg", file="asane_01f_00001", file1="asane_01f_00109", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1511", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“SS... We got SS in the courtyard! And their leader is Reizei—I mean, the student council prez! It's their main squad, Bro!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“SS……FS来到了校园里……！率领的是冷泉院——学生会长……！是FS本队啊，哥哥……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「SS……FS來到了校園裡……！率領的是冷泉院——學生會長……！是FS本隊啊，哥哥……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00076",
		linknext = "0096_00078",
		line = 1196,
	},
	["0096_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did you say?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00077",
		linknext = "0096_00079",
		line = 1208,
	},
	["0096_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For a while, most of the SS top brass haven't been showing up at school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最近一段时间，大部分有能力的FS都从学校消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最近一段時間，大部分有能力的FS都從學校消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00078",
		linknext = "0096_00080",
		line = 1218,
	},
	["0096_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There were rumors going around that they'd received orders from above, but I'm guessing it's because of Teshima.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说是收到上级的特殊命令之类的——但一定是手嶋的指使。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說是收到上級的特殊命令之類的——但一定是手嶋的指使。",
					{"rt2"},
				},
