		{"fg", mode=-1, id=7, ch="美岬3", lv=5, time=300},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0669", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I see. Most impressive, Tachibana. Still, this... hehe, this is beyond my expectations.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“原来如此……不愧是前辈。不过，没想到会变成这样……呵呵，超出了我的想象呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「原來如此……不愧是前輩。不過，沒想到會變成這樣……呵呵，超出了我的想像呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00143",
		linknext = "0096_00145",
		line = 2209,
	},
	["0096_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oh, right. Forgot about her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对了——还剩这个女人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對了——還剩這個女人。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00144",
		linknext = "0096_00146",
		line = 2219,
	},
	["0096_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The secret technique MARQualia only works as no-name background characters, as Misaki describes herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"Merqualia是因为自称是路人脸的美岬——对象是对我来说印象很浅的",
					{"ruby", text="・・"},
					"路人",
					{"/ruby"},
					"才有办法使用的奥义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"Merqualia是因為自稱是路人臉的美岬——對象是對我來說印像很淺的",
					{"ruby", text="・・"},
					"路人",
					{"/ruby"},
					"才有辦法使用的奧義。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00145",
		linknext = "0096_00147",
		line = 2229,
	},
	["0096_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The student council president has a powerful, charismatic aura that leaves a lasting impact on everyone she meets, myself included.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长强烈的存在感，清晰地刻画在我心中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長強烈的存在感，清晰地刻畫在我心中。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00146",
		linknext = "0096_00148",
		line = 2239,
	},
	["0096_00148"] = {
