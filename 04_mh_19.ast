			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, nothing for the moment. It's more that I have a personal interest in you... Heh heh, or rather, your little endowment that made Ikuko black out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，现在我不会出手。只是，连郁子都会昏厥的东西……呵呵，我对那个有兴趣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，現在我不會出手。只是，連郁子都會昏厥的東西……呵呵，我對那個有興趣。」",
