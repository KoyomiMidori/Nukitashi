		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00105", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0522", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I see... So Tokie really said that... Maybe she's worried about me after all?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是吗？桐香酱说了那种话……是在担心我吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是嗎？桐香醬說了那種話……是在擔心我嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00164",
		linknext = "0096_00166",
		line = 2509,
	},
	["0096_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's still brainwashed, and isn't she the main reason why you were kicked out? Don't take her too seriously.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她还是洗脑状态，而且也是把女部田从FS赶出来的罪魁祸首吧？还是不要太相信比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她還是洗腦狀態，而且也是把女部田從FS趕出來的罪魁禍首吧？還是不要太相信比較好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00165",
		linknext = "0096_00167",
		line = 2521,
	},
	["0096_00167"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00124", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0523", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, I believe her. If there's one thing I know about Tokie, it's that verbal communication is far from her strong suit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……我会当真的……桐香酱她啊，其实很不擅长说话交流呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……我會當真的……桐香醬她啊，其實很不擅長說話交流呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00166",
		linknext = "0096_00168",
		line = 2535,
	},
	["0096_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I never got that impression. She's a master at whipping up a crowd.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是看起来不像不擅长……她总是在人前发表演说不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是看起來不像不擅長……她總是在人前發表演說不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00167",
