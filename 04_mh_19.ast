	["0096_00062"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00127", file2="misaki_01m_00203", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2062", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun... You've always said that the islanders are all crazy for as long as I can remember. But right now, I don't think there's anyone on the island who's crazier than you are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳……你啊，虽然你一直说这个岛上的人很奇怪……但我觉得你是这个岛上最奇怪的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳……你啊，雖然你一直說這個島上的人很奇怪……但我覺得你是這個島上最奇怪的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00061",
		linknext = "0096_00063",
		line = 977,
	},
	["0096_00063"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why, thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00062",
		linknext = "0096_00064",
		line = 989,
	},
	["0096_00064"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2063", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Somebody remind me what the fuck I'm doing in this organization again...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我为什么会在这个组织里……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我為什麼會在這個組織裡……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00063",
		linknext = "0096_00065",
		line = 1003,
	},
	["0096_00065"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00112", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1508", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“N-Nanase, are you okay? You really gotta stay away from Misakium, I hear it's a neurotoxin or some shit. Just look what it did to Bro...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“奈、奈奈濑同学振作点……注意不要沾到有害物质美岬分子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「奈、奈奈瀨同學振作點……注意不要沾到有害物質美岬分子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00064",
		linknext = "0096_00066",
		line = 1016,
	},
	["0096_00066"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“With this, I'm doing it with hundreds of Misakis each day. The brainwashing ain't got shit on us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在的我，一天可以和好几百个美岬做爱——洗脑什么的，已经不是敌人了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在的我，一天可以和好幾百個美岬做愛——洗腦什麼的，已經不是敵人了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00065",
		linknext = "0096_00067",
		line = 1028,
	},
	["0096_00067"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="hinami_01m_00001", file3="hinami_01m_00303", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2067", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Can you tell who's brainwashed now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是，你能马上判断是否有被洗脑吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是，你能馬上判斷是否有被洗腦嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00066",
		linknext = "0096_00068",
		line = 1043,
	},
	["0096_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My love for Misaki shows me the way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我已经可以判断了，因为我爱美岬。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我已經可以判斷了，因為我愛美岬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00067",
		linknext = "0096_00069",
		line = 1055,
	},
	["0096_00069"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1509", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So we're going all-in now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这样都行……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這樣都行……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00068",
		linknext = "0096_00070",
		line = 1069,
