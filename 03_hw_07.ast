	["0057_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nuestro entrenamiento hasta ahora ha ido mucho más allá de lo que normalmente se consideraría adecuado para los estudiantes, pero esto parece normal en comparación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然平时就是一堆学生不应该有的训练——但这更是令人觉得头脑异常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然平時就是一堆學生不應該有的訓練——但這更是令人覺得頭腦異常。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00137",
