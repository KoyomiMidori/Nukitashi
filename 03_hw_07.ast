	["0057_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras estoy perdido en mis pensamientos, Wata-chan mira fijamente la correa que me dio con una extraña expresión.",
					{"rt2"},
				},
			},
			cn = {
