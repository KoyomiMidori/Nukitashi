	["0057_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was pretty sure we passed them through the right holes, but we must've done something wrong.",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该交叉穿过孔洞了才对，是途中弄错了吗——",
