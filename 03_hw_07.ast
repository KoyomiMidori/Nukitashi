					name = {"淳之介", "Junnosuke"},
					"“Huh? Nothing really hurts...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——咦？比想象中不疼呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——咦？比想像中不痛呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00265",
		linknext = "0057_00267",
		line = 3601,
	},
	["0057_00267"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0328", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Of course. The point of CQC is to subdue belligerents so they can be safely detained. It's not meant to cause lasting injuries.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“当然。SQC的基本目的是镇压暴徒，不是为了伤害暴徒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「當然。SQC的基本目的是鎮壓暴徒，不是為了傷害暴徒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00266",
		linknext = "0057_00268",
		line = 3614,
	},
	["0057_00268"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，是这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，是這樣啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00267",
		linknext = "0057_00269",
		line = 3626,
	},
	["0057_00269"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0329", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If we were using weapons, it would be a different story. Would you have preferred that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果是使用武器的真功夫那就另当别论了……你比较想练那种吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果是使用武器的真功夫那就另當別論了……你比較想練那種嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00268",
		linknext = "0057_00270",
		line = 3638,
	},
	["0057_00270"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
