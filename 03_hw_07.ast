		linkback = "0057_00160",
		linknext = "0057_00162",
		line = 2189,
	},
	["0057_00162"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0295", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If it happens to be loaded, and the safety is turned off, it can go off at any time. Do you need me to explain any further?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“里面装了子弹，如果没有上保险，就处于随时能开枪的状态——还需要说明吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「裡面裝了子彈，如果沒有上保險，就處於隨時能開槍的狀態——還需要說明嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00161",
		linknext = "0057_00163",
		line = 2201,
	},
	["0057_00163"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“N— Sir! No, sir!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——Sir——！No——！Sir——！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——Sir——！No——！Sir——！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00162",
		linknext = "0057_00164",
		line = 2213,
	},
	["0057_00164"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0296", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don't ever point a weapon at a friendly outside of training again. You will be thrown out of the SS with no room for appeal if you do. Do I make myself clear?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“除了训练以外不许再把枪对着队友。下次再这样不用多说直接赶出FS。明白了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「除了訓練以外不許再把槍對著隊友。下次再這樣不用多說直接趕出FS。明白了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00163",
		linknext = "0057_00165",
		line = 2225,
	},
	["0057_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir! Yes, sir!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——！Yes——！Sir——！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——！Yes——！Sir——！！」",
					{"rt2"},
