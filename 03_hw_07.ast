	},
	["0057_00118"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00116", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0290", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Then hurry up and build a rapport with your team! Your shitty leadership is why you couldn't get those tents up. Now drop and give me 200 SS-style burpees, three sets!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那就立刻来提高与队友的同伴意识吧！因为队长的判断失误没能完成任务。全体人员FS式波比跳200次3套！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那就立刻來提高與隊友的同伴意識吧！因為隊長的判斷失誤沒能完成任務。全體人員FS式波比跳200次3套！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00117",
		linknext = "0057_00119",
		line = 1584,
	},
