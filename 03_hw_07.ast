					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Spread the tents out first! After that... get the poles. Stick the poles through them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先……把帐篷打开！然后……是杆子。把杆子穿过去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先……把帳篷打開！然後……是桿子。把桿子穿過去！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00081",
