	["0057_00162"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0295", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Si está cargada y el seguro está desactivado, puede dispararse en cualquier momento. ¿Necesitas que te lo explique mejor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“里面装了子弹，如果没有上保险，就处于随时能开枪的状态——还需要说明吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「裡面裝了子彈，如果沒有上保險，就處於隨時能開槍的狀態——還需要說明嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00161",
