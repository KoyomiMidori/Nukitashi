					"“¡V-Vale!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00208",
