		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=7.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0254", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Disculpa? ¡A mí no me vas a responder con un 'sí'! ¡Quítense la mugre de la oreja y escúchenme, idiotas! ¡A partir de ahora, la primera y última palabra que saldrá de sus asquerosas bocas será 'señor'!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“‘是的’！？你说‘是的’！？把堵在耳朵小穴里的小穴渣渣掏干净好好听着！张开嘴巴小穴吐出精液的前后都要加上‘Sir’！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「『是的』！？你說『是的』！？把堵在耳朵小穴裡的小穴渣渣掏乾淨好好聽著！張開嘴巴小穴吐出精液的前後都要加上『Sir』！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00004",
		linknext = "0057_00006",
		line = 96,
	},
