				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ah, ¿yo...? Como presidenta del comité de moral pública, creo que tener un conejito tan linda en un lugar visible podría dañar mi imagen...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我……？不……我也有作为风纪委员长的立场……把那么可爱的兔子放在能看得见的位置上有些……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我……？不……我也有作為風紀委員長的立場……把那麼可愛的兔子放在能看得見的位置上有些……」",
					{"rt2"},
				},
			},
		},
