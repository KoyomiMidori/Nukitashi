	},
	["0057_00332"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[8500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1050", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, I was just thinking that putting the strap on your tablet is a great idea. I should do that with mine! Rei, why don't you do it, too? Then we can all match!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……橘君，我在想把挂件挂在平板上好像不错……我也试试吧。对了，礼酱也来试试！这样大家就都一样了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……橘君，我在想把挂件掛在平板上好像不錯……我也試試吧。對了，禮醬也來試試！這樣大家就都一樣了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00331",
		linknext = "0057_00333",
		line = 4427,
	},
	["0057_00333"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=-400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0337", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, uh, as disciplinary committee president, I think having a cutesy rabbit in such a visible place might hurt my image...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我……？不……我也有作为风纪委员长的立场……把那么可爱的兔子放在能看得见的位置上有些……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我……？不……我也有作為風紀委員長的立場……把那麼可愛的兔子放在能看得見的位置上有些……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00332",
		linknext = "0057_00334",
		line = 4442,
	},
	["0057_00334"] = {
