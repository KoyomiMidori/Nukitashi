	["0057_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me da vueltas la cabeza y no puedo pensar con claridad...",
					{"rt2"},
				},
			},
			cn = {
				{
					"到底是什么——大脑在摇晃，无法正常运转。",
