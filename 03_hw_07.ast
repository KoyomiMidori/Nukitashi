	["0057_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca fui tan tonto como para pensar que el entrenamiento de selección sería más fácil que el entrenamiento para los miembros oficiales.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是选拔用的训练，应该比正式成员做的训练更轻松——什么的，我从一开始就没这么认为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是選拔用的訓練，應該比正式成員做的訓練更輕鬆——什麼的，我從一開始就沒這麼認為。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00038",
		linknext = "0057_00040",
		line = 595,
	},
	["0057_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jaaa. jaaa... Aun así... ¡No me esperaba esto...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……这是……再怎么说这都……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……這是……再怎麼說這都……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00039",
		linknext = "0057_00041",
		line = 606,
	},
	["0057_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de hacer las infernales flexiones de la SS en la playa como ayer, corrimos hasta el patio y dimos diez vueltas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和昨天一样在海滩做了地狱FS式俯卧撑后跑回操场——然后又跑了10圈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和昨天一樣在海灘做了地獄FS式伏地挺身後跑回操場——然後又跑了10圈。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00040",
		linknext = "0057_00042",
		line = 616,
	},
	["0057_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si solo hubiéramos estado dando vueltas normales, no habría pasado nada, pero había algo más.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且与只在运动场跑是不同的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且與只在運動場跑是不同的。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00041",
		linknext = "0057_00043",
		line = 626,
	},
	["0057_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras hacíamos las infernales flexiones en la playa, nos prepararon una pista de obstáculos, como las que se utilizan en el entrenamiento militar real.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在去海滨的期间，出现了类似军队训练设施的竞技设施。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在去海濱的期間，出現了類似軍隊訓練設施的競技設施。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00042",
