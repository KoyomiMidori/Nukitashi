		{"fg", file="rei_01l_00001", file1="rei_01l_00104", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"se", id=0, loop=0, file="se_a035"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0277", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You're squad leader. You are to convey my instructions to your group exactly. When I say to fuck pussies, you'll ask, 'How many?' If their cum ends up in assholes, it's your ass on the line. Understood?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你是队长。正确地传达我的指示。说要插入小穴就插入小穴。要是精子们跑到菊花就是你的责任。知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你是隊長。正確地傳達我的指示。說要插入小穴就插入小穴。要是精子們跑到菊花就是你的責任。知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00071",
		linknext = "0057_00073",
		line = 1035,
	},
	["0057_00073"] = {
		{"text"},
