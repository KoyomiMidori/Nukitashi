					name = {"礼", "Rei"},
					"“But I knew you'd try that! Listen up! As soon as a superior opponent gets the upper hand, you've already lost!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是，那种进攻已经在我的预料之中了！听好，给我记住了！当你被比自己强的对手制造出不利于自己的状况时，你就已经完了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是，那種進攻已經在我的預料之中了！聽好，給我記住了！當你被比自己強的對手製造出不利於自己的狀況時，你就已經完了！」",
					{"rt2"},
				},
			},
		},
