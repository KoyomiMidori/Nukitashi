				{
					{"exfont", size="f4"},
					name = {"淳之介", "Junnosuke"},
					"“¡¡SEÑOR!! ¡¡NO, SEÑOR!!”",
					{"rt2"},
					{"exfont"},
				},
			},
			cn = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"“Sir——！！No——！！Sir——！！！”",
					{"rt2"},
					{"exfont"},
