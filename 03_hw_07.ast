	["0057_00343"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[5700] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=5700, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1051", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Era Asane-chan? Será mejor que vuelvas rápido a casa. ¡Nos vemos luego, Rei-chan!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是麻沙音酱吧？你得早点回家啊。嗯，这样的话……再见了，礼酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是麻沙音醬吧？你得早點回家啊。嗯，這樣的話……再見了，禮醬！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00342",
		linknext = "0057_00344",
		line = 4556,
	},
	["0057_00344"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0338", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí, nos vemos luego. Ya oscureció, así que ten cuidado al volver a casa. No tomes atajos dudosos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，再见。天已经黑了，你一定要小心。别想着要早点到家就走奇怪的路。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，再見。天已經黑了，你一定要小心。別想著要早點到家就走奇怪的路。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00343",
		linknext = "0057_00345",
		line = 4570,
	},
	["0057_00345"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yo también me voy. Gracias por toda tu ayuda hoy, Tadasugawa-senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么我也……糺川前辈，今天也受你照顾了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼我也……糺川前輩，今天也受你照顧了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00344",
		linknext = "0057_00346",
		line = 4582,
	},
