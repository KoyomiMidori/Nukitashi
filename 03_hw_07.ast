	},
	["0057_00231"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0319", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡¿Alguna vez has oído el dicho 'los ganadores no usan porno'?! ¡Significa que no debes ser tonto y actur por placer en lugar de progresar en la vida! ¡Ahora mismo, eres ese idiota!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“有句话叫包皮系带胜过冠军腰带！是用来嘲笑比起胜利优先选择快乐的笨蛋的话！就是在说你现在的情况，对吧包皮系带！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「有句話叫包皮繫帶勝過冠軍腰帶！是用來嘲笑比起勝利優先選擇快樂的笨蛋的話！就是在說你現在的情況，對吧包皮繫帶！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00230",
		linknext = "0057_00232",
		line = 3134,
	},
