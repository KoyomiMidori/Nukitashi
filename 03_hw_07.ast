			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Ay, pobre gatito! ¡Hasta Susuko-chan, la de primer año, es más rápida que tú! ¡¿Lo único que te hace mover el culo es hacer que se corra tu polla rota?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎么了小猫咪！？输给1年级的丝丝子了哦！不只是精子，连干劲也出不来吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼了小貓咪！？輸給1年級的絲絲子了哦！不只是精子，連幹勁也出不來嗎！？」",
					{"rt2"},
				},
			},
		},
