	},
	["0057_00286"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“辛苦了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「辛苦了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00285",
		linknext = "0057_00287",
		line = 3855,
	},
	["0057_00287"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, that's not what I'm talking about. Why are you still at school?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不对。你为什么还留在这里？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不對。你為什麼還留在這裡？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00286",
		linknext = "0057_00288",
		line = 3867,
	},
	["0057_00288"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1041", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Asane took the day off, so I thought I'd wait for you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为今天麻沙音酱休息，我想等会儿橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為今天麻沙音醬休息，我想等一下橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00287",
		linknext = "0057_00289",
		line = 3881,
	},
	["0057_00289"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh yeah, that's right...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，这么说来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，這麼說來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00288",
		linknext = "0057_00290",
		line = 3893,
	},
	["0057_00290"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She stayed home today, claiming to be suffering from 'post-graduation apathy'.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天麻沙酱用“因为很困”这种应届毕业生会讲的理由休息了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天麻沙醬用「因為很困」這種應屆畢業生會講的理由休息了。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00289",
		linknext = "0057_00291",
		line = 3903,
	},
	["0057_00291"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normally I wouldn't stand for bullshit like that, but since I've been leaving home so early each morning for training, I didn't have the time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平时我都会逼她去上学，但训练生每天早上都很早，所以没有多余的时间照顾她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平時我都會逼她去上學，但訓練生每天早上都很早，所以沒有多餘的時間照顧她。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00290",
		linknext = "0057_00292",
		line = 3913,
	},
	["0057_00292"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1042", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I was watching you train for a bit, and you were really giving it your all! It was amazing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我只看了一点点训练……橘君今天也很努力呢，真了不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我只看了一點點訓練……橘君今天也很努力呢，真了不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00291",
		linknext = "0057_00293",
		line = 3927,
	},
	["0057_00293"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nah, it's only thanks to the lucky charm you made me. It helps keep me going.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，多亏了渡酱的护身符，我一看到它就精神百倍。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，多虧了渡醬的護身符，我一看到它就精神百倍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00292",
		linknext = "0057_00294",
		line = 3939,
	},
	["0057_00294"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[700] = {
