			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Lo que te diga tu instructora es ley! ¡Si lo entiendes, deja de encorvarte como si estuvieras masturbándote y ponte de pie! ¡Desata tu boca para chupar y habla como si tuvieras huevos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在这里长官说的话是绝对的！如果你明白了，就不要一直像手淫完的小鸡鸡那样蹲着，站起来！张开嘴巴小穴回答！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「在這裡長官說的話是絕對的！如果你明白了，就不要一直像手淫完的小雞雞那樣蹲著，站起來！張開嘴巴小穴回答！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00016",
		linknext = "0057_00018",
		line = 254,
	},
	["0057_00018"] = {
