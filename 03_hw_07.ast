	},
	["0057_00101"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0282", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The other team managed just fine, didn't they? Tell me, who was the leader here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“另一队是漂亮的勃起帐篷哦。那边的指挥是谁？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「另一隊是漂亮的勃起帳篷哦。那邊的指揮是誰？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00100",
		linknext = "0057_00102",
		line = 1382,
	},
	["0057_00102"] = {
		{"text"},
		text = {
