					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Take it down! We're doing the poles again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“把帐篷叠起来！重新装好柱子！”",
					{"rt2"},
				},
			},
			tw = {
