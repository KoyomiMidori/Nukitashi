	["0057_00383"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What if we abolish the law? What would she do?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果我们破坏了条例——那糺川前辈会怎么样呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果我們破壞了條例——那糺川前輩會怎麼樣呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00382",
		linknext = "0057_00384",
		line = 5062,
	},
	["0057_00384"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wouldn't she see me as trying to destroy her livelihood?",
