	["0057_00160"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0294", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Te lo explico? Cuando tomaste esa arma, apuntabas con el cañón en mi dirección. Y tenías el dedo en el gatillo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你不知道吗？你接枪的时候枪口朝向我，手指还在扳机上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你不知道嗎？你接槍的時候槍口朝向我，手指還在扳機上。」",
