		linkback = "0057_00107",
		linknext = "0057_00109",
		line = 1466,
	},
	["0057_00109"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0286", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Anyone should be able to pitch a tent in under 10 minutes, and you bitches had 15! What did you think the extra time was for, jacking off!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“本来设置帐篷10分钟就够了！但我给了15分钟。你以为这5分钟是给你自慰用的吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「本來設置帳篷10分鐘就夠了！但我給了15分鐘。你以為這5分鐘是給你自慰用的嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00108",
		linknext = "0057_00110",
		line = 1478,
	},
	["0057_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir! No, sir!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——No——Sir——！”",
					{"rt2"},
