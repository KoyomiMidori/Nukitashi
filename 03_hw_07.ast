		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0271", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Acelera el ritmo! ¡¿Qué eres, el espermatozoide más lento de la corrida?! ¡Si no quieres nadar, vuelve a tu calcetín!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“太慢了太慢了！你们都是蛞蝓精子吗！？如果不想受精就赶快回家射在纸巾上吧！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「太慢了太慢了！你們都是蛞蝓精子嗎！？如果不想受精就趕快回家射在紙巾上吧！！」",
					{"rt2"},
				},
			},
		},
