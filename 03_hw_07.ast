	["0057_00394"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00120", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1059", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“If there's something bothering you, you can discuss it with me! It's a senior's duty to help her underclassmen in any way she can!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“有烦恼的话，可以跟我商量哦！橘君的前辈什么都可以回答你哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「有煩惱的話，可以跟我商量哦！橘君的前輩什麼都可以回答你哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00393",
		linknext = "0057_00395",
		line = 5181,
	},
	["0057_00395"] = {
