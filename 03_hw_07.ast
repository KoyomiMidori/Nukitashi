	["0057_00390"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As long as it exists, Wata, Asa, and all of my companions are at risk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要有这个条例，渡酱和麻沙酱——我的同伴，将受到无秩序性爱的威胁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要有這個條例，渡醬和麻沙醬——我的同伴，將受到無秩序性愛的威脅。",
					{"rt2"},
				},
