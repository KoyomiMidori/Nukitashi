	},
	["0057_00327"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo único que se me ocurre es que ella miraría sus mejillas hinchadas y diría algo como, “¿Tienes muchas pollas en la boca o qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然做的时候是一边看着松鼠鼓起的脸颊，一边说着“这个表情是怎么回事，难道嘴里含着鸡巴吗！”……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然做的時候是一邊看著松鼠鼓起的臉頰，一邊說著「這個表情是怎麼回事，難道嘴裡含著肉棒嗎！」……？",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00326",
		linknext = "0057_00328",
		line = 4365,
	},
	["0057_00328"] = {
