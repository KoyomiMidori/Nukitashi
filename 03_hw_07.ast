					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Bueno, perdimos mucho tiempo. Empecemos con el entrenamiento de tiro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么……稍微花了些时间呢……我们开始射击训练吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
