		linkback = "0057_00103",
		linknext = "0057_00105",
		line = 1418,
	},
	["0057_00105"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0284", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué les parece? Schubert no solo es compositor, ¡sino que también se monta unas carpas increíbles! ¿Lo sabías, Nekobana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“舒伯特训练生不仅会写歌还会搭帐篷呢！你知道这事吗小猫咪？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「舒伯特訓練生不僅會寫歌還會搭帳篷呢！你知道這事嗎小貓咪？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00104",
		linknext = "0057_00106",
		line = 1430,
	},
	["0057_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡No, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——No——Sir——！”",
