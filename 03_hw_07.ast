				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Acepta el dolor! Si aún tienes energía para gritar, ¡úsala para pensar! ¡¿Qué vas a hacer?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“爱上疼痛吧！如果你还有余力尖叫，就把它全部用在思考上吧！回答呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「愛上疼痛吧！如果你還有餘力尖叫，就把它全部用在思考上吧！回答呢！？」",
					{"rt2"},
				},
			},
		},
