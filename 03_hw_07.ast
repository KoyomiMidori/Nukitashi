	["0057_00392"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From the beginning, I've dedicated myself to bringing the law down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把这个岛的存在方式破坏一次之类的，我从一开始就做好了思想准备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把這個島的存在方式破壞一次之類的，我從一開始就做好了思想準備。",
