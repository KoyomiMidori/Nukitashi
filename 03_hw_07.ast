	["0057_00233"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0320", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué, estás gritando por tu mamá? ¡El dolor nublará tu juicio y gritar no te ayudará a encontrar una solución!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喊了妈妈会来救你吗！？疼痛会让判断力变迟钝，惨叫会让思考停止哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喊了媽媽會來救你嗎！？疼痛會讓判斷力變遲鈍，慘叫會讓思考停止哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00232",
		linknext = "0057_00234",
		line = 3160,
	},
	["0057_00234"] = {
		{"se", id=0, loop=0, file="se_b047"},
