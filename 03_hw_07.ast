			},
		},
		linkback = "0057_00109",
		linknext = "0057_00111",
		line = 1489,
	},
	["0057_00111"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00110", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0287", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What you should've done is spend those five extra minutes determining if anyone in your group had experience, but apparently that was too much for you! Any cocksucking bitch could tell what your problem is!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“只要有5分钟应该就能轻松确认有没有经验才对！但你却没有确认！为什么没有，只要看着你的蠢样就连奶油猪都能懂！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「只要有5分鐘應該就能輕鬆確認有沒有經驗才對！但你卻沒有確認！為什麼沒有，只要看著你的蠢樣就連奶油豬都能懂！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00110",
		linknext = "0057_00112",
		line = 1503,
	},
	["0057_00112"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0288", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You don't think your companions can be trusted! There's no place in the SS for assholes who just want to order others around! If you won't be able to trust your team, then fuck off home to momma!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“因为你根本就没有信任同伴的意思！如果只想一个人出风头就赶快滚出去！FS不需要不相信同伴的人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「因為你根本就沒有信任同伴的意思！如果只想一個人出風頭就趕快滾出去！FS不需要不相信同伴的人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00111",
		linknext = "0057_00113",
		line = 1515,
	},
	["0057_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's nothing I can, or could, say to that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一点声音都发不出来。",
					{"rt2"},
