	},
	["0057_00107"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0285", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I seem to recall telling you to be the leader! Can a leader do his job when he doesn't know his companions?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我应该命令你当队长了！连同伴的事情都不知道能当队长吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我應該命令你當隊長了！連同伴的事情都不知道能當隊長嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00106",
		linknext = "0057_00108",
		line = 1455,
	},
	["0057_00108"] = {
