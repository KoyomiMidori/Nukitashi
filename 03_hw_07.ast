		linknext = "0057_00271",
		line = 3650,
	},
	["0057_00271"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0330", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Kidding. You're not ready. You've improved very slightly, but you've still got miles to go. You won't get anywhere without a lot of hard work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……开玩笑的，对你来说还太早了。虽然已经有些长进了……但还差得远呢。今后也要好好努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……開玩笑的，對你來說還太早了。雖然已經有些長進了……但還差得遠呢。今後也要好好努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00270",
		linknext = "0057_00272",
		line = 3664,
	},
	["0057_00272"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。」",
					{"rt2"},
				},
