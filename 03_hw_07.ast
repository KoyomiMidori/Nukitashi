		{"ex", time=1000, func="wait"},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"se", id=1, loop=1, file="se_d031", vol=60},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Una vez que terminaron los infernales ejercicios, solo nos dieron cinco minutos para recuperarnos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"地狱般的波比跳200次3套结束后，终于有了5分钟的休息时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"地獄般的波比跳200次3套結束後，終於有了5分鐘的休息時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00119",
		linknext = "0057_00121",
		line = 1643,
	},
	["0057_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jaa... jaa... Schubert, ¿verdad? Lamento no haberte preguntado antes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈……是叫舒伯特吗？刚才是我不好……都怪我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈……是叫舒伯特嗎？剛才是我不好……都怪我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00120",
		linknext = "0057_00122",
		line = 1655,
	},
	["0057_00122"] = {
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0005", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Ah, no te preocupes por eso. Estoy aquí para unirme a las comunicaciones. Mi resistencia no es gran cosa, pero me considero bastante inteligente. No tengas miedo de preguntarme lo que quieras.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“没事的……我的志愿是通讯部队……虽然对体力没有自信，但对知识有自信。今后可以多依靠我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「沒事的……我的志願是通訊部隊……雖然對體力沒有自信，但對知識有自信。今後可以多依靠我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00121",
		linknext = "0057_00123",
		line = 1668,
	},
	["0057_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vale... está bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……我会的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……我會的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00122",
		linknext = "0057_00124",
		line = 1680,
	},
	["0057_00124"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0006", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Je... Tal y como yo lo veo, tenemos un 85,5 % de posibilidades de superar este entrenamiento de selección. ¿Crees que podremos aprobarlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“呼……根据我的计算，我们通过选拔训练的概率是85.5%……一起加入FS吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「呼……根據我的計算，我們通過選拔訓練的概率是85.5%……一起加入FS吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00123",
		linknext = "0057_00125",
		line = 1692,
	},
	["0057_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Ojalá.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00124",
		linknext = "0057_00126",
		line = 1703,
	},
	["0057_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A pesar de su nombre tan raro, parecía un buen tipo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然名字很奇怪，却很有男子气概。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然名字很奇怪，卻很有男子氣概。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00125",
		linknext = "0057_00127",
		line = 1713,
	},
	["0057_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hacer amistad con los aprendices de la SS es como fraternizar con el enemigo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和志愿FS的人建立起情感，也让我的心情有点复杂——",
					{"rt2"},
				},
			},
			tw = {
				{
					"和志願FS的人建立起情感，也讓我的心情有點複雜——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00126",
		linknext = "0057_00128",
		line = 1723,
	},
	["0057_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun así, tengo que hacer lo posible para ganarme su confianza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但为了得到信任，不应该做令人怀疑的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但為了得到信任，不應該做令人懷疑的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00127",
		linknext = "0057_00129",
		line = 1733,
	},
	["0057_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras esté aquí, tengo que tragarme mi orgullo y ocultar mi verdadera personalidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这里的期间，有必要隐藏原本的信条。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這裡的期間，有必要隱藏原本的信條。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00128",
		linknext = "0057_00130",
		line = 1743,
	},
	["0057_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pase lo que pase, tengo que presentarme como un miembro modelo de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"隐藏信念，扼杀自我，像个FS行动——",
					{"rt2"},
				},
			},
			tw = {
				{
					"隱藏信念，扼殺自我，像個FS行動——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00129",
		linknext = "0057_00131",
		line = 1753,
	},
	["0057_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es mi deber como líder del NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为NLNS的领导者，这些事情都必须完成。",
					{"rt2"},
				},
			},
