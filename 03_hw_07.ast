		{"ex", time=500, func="wait"},
		{"bgm", file="bgm09", vol=100},
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0312", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Fallaste! ¡Mantén la postura, no recuerdo haberte dicho que te pusieras así! ¡Dobla los codos y las rodillas, o el retroceso te hará perder la puntería!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“打歪了！你的姿势又歪了！我有让你以那样的姿势开枪吗！？手肘和膝盖都不要伸直，会因为反动而偏离目标的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「打歪了！你的姿勢又歪了！我有讓你以那樣的姿勢開槍嗎！？手肘和膝蓋都不要伸直，會因為反動而偏離目標的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00207",
		linknext = "0057_00209",
		line = 2778,
	},
	["0057_00209"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
