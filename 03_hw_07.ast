				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero si cerrara los ojos ahora mismo... creería que estoy en el infierno.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——光是闭上眼睛，我就已经看到了地狱。",
