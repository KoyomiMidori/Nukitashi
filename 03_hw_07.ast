	["0057_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En lugar de Tadasugawa-senpai, Hanamaru es nuestra instructora de hoy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸委员长代替糺川前辈担任教官一职。",
