		},
		linkback = "0057_00166",
		linknext = "0057_00168",
		line = 2261,
	},
	["0057_00168"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bgm", file="bgm04.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0297", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Jaa... No tendría que estarte enseñando algo tan básico. Por cierto, ya puedes dejar de decirme 'señor'. Es molesto en una conversación personal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唉……给我成长到不用我告诉你也能做出这种判断的程度。还有，现在不用叫我Sir。一对一很吵很刺耳。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唉……給我成長到不用我告訴你也能做出這種判斷的程度。還有，現在不用叫我Sir。一對一很吵很刺耳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00167",
		linknext = "0057_00169",
		line = 2276,
	},
	["0057_00169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Se— Está bien, lo entiendo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——是的，我明白了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——是的，我明白了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00168",
		linknext = "0057_00170",
		line = 2288,
	},
	["0057_00170"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0298", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ahora pasemos al entrenamiento con armas. ¿Has visto a miembros de la SS o la OSS utilizando armas de fuego?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，接下来要开始射击训练了……有看过FS和SHO用枪吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，接下來要開始射擊訓練了……有看過FS和SHO用槍嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00169",
		linknext = "0057_00171",
		line = 2302,
	},
	["0057_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——有过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——有過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00170",
		linknext = "0057_00172",
		line = 2313,
	},
	["0057_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me pregunta que si las he observado. Pues me han apuntado con esas cosas muchísimas veces.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有过，之前被枪口对准过好几次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有過，之前被槍口對準過好幾次。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00171",
		linknext = "0057_00173",
		line = 2323,
	},
	["0057_00173"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0299", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya veo. Entonces ya sabrás que utilizan munición antidisturbios no letal. La idea es apuntar a las piernas de los manifestantes para incapacitarlos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊……那你知道吧，子弹是防暴弹。打在暴徒的脚上使之无力化是基本用法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣啊……那你知道吧，子彈是防暴彈。打在暴徒的腳上使之無力化是基本用法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00172",
		linknext = "0057_00174",
		line = 2335,
	},
	["0057_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cuántos disparos se necesitan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是——要打几发才能使之无力化？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是——要打幾發才能使之無力化？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00173",
		linknext = "0057_00175",
		line = 2346,
	},
	["0057_00175"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0300", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Solo uno. Después de eso, es casi imposible escapar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“只要一枪，基本上就不可能正常逃走。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「只要一槍，基本上就不可能正常逃走。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00174",
		linknext = "0057_00176",
		line = 2360,
	},
	["0057_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tienen bastante potencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然有如此威力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然有如此威力。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00175",
		linknext = "0057_00177",
		line = 2370,
	},
	["0057_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me han apuntado tantas veces, pero ahora me doy cuenta de la suerte que he tenido al escapar cuando eso sucede.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前中了几枪还能逃到现在——也许只是单纯的幸运。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之前中了幾槍還能逃到現在——也許只是單純的幸運。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00176",
		linknext = "0057_00178",
		line = 2380,
	},
	["0057_00178"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0301", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Esas son solo las pistolas de los nuevos reclutas. A medida que suben de nivel, se les equipa con metralletas, rifles de asalto y rifles de francotirador.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就连新兵使用的手枪都有相当的威力。特别奖学生的话，就连冲锋枪、突击步枪、狙击步枪——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就連新兵使用的手槍都有相當的威力。特別獎學生的話，就連衝鋒槍、突擊步槍、狙擊步槍——」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00177",
		linknext = "0057_00179",
		line = 2392,
	},
	["0057_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me da una explicación detallada de cada arma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"糺川前辈向我解说各种武器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"糺川前輩向我解說各種武器。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00178",
		linknext = "0057_00180",
		line = 2402,
	},
	["0057_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Recibo una clase exhaustiva sobre el armamento del enemigo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，我们的敌人正对我展示着自己在用的武器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，我們的敵人正對我展示著自己在用的武器。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00179",
		linknext = "0057_00181",
		line = 2412,
	},
	["0057_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Enterarme de la potencia de fuego de cada una me horroriza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直接听到其威力有多大——说实话也没让我太恐惧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直接聽到其威力有多大——說實話也沒讓我太恐懼。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00180",
		linknext = "0057_00182",
		line = 2422,
	},
	["0057_00182"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0302", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Un disparo al cráneo con una de estas armas causaría una conmoción cerebral. Los disparos repetidos pueden provocar encefalopatía traumática crónica.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这些武器如果打到头部就会出现脑震荡。如果反复被击中，有可能会导致慢性创伤性脑病变。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這些武器如果打到頭部就會出現腦震盪。如果反覆被擊中，有可能會導致慢性創傷性腦病變。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00181",
		linknext = "0057_00183",
		line = 2434,
	},
	["0057_00183"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Encefa-¿eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“慢性创伤……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「慢性創傷……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00182",
		linknext = "0057_00184",
		line = 2446,
	},
	["0057_00184"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0303", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Supongo que probablemente te suene más la abreviatura ETC. Antes se llamaba síndrome del boxeador.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“简单说来，就是所谓的拳击员痴呆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「簡單說來，就是所謂的拳擊手癡呆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00183",
		linknext = "0057_00185",
		line = 2460,
	},
	["0057_00185"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sí, he oído que eso les pasa mucho a los boxeadores y luchadores.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，拳击手和职业摔跤选手容易得的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，拳擊手和職業摔跤選手容易得的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00184",
		linknext = "0057_00186",
		line = 2472,
	},
	["0057_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al parecer, es común en cualquier deporte en el que puedan producirse golpes en la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不只是这些，听说头部容易受到冲击的体育运动员也很容易得拳击员痴呆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不只是這些，聽說頭部容易受到衝擊的體育運動員也很容易得拳擊手癡呆。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00185",
		linknext = "0057_00187",
		line = 2482,
	},
	["0057_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si no recuerdo mal, los traumatismos craneales repetidos pueden causar daño cerebral, lo que provoca dolores de cabeza y pérdida de memoria.",
					{"rt2"},
				},
			},
			cn = {
				{
					"头反复持续受到强烈冲击的结果，大脑会出现问题，引起头痛、记忆障碍——",
					{"rt2"},
				},
			},
			tw = {
				{
					"頭反覆持續受到強烈衝擊的結果，大腦會出現問題，引起頭痛、記憶障礙——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00186",
		linknext = "0057_00188",
		line = 2492,
	},
	["0057_00188"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0304", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No solo les pasa a los deportistas. Los soldados que sufren traumatismos craneales repetidos también pueden ser propensos a padecerlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不只是体育运动员。反复患上脑震荡的士兵也容易得拳击员痴呆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不只是體育運動員。反覆患上腦震蕩的士兵也容易得拳擊手癡呆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00187",
		linknext = "0057_00189",
		line = 2506,
	},
	["0057_00189"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0305", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Por eso, si algún miembro de la SS recibe una bala antidisturbios en la cabeza, siempre se le concederá un permiso para recuperarse. Es nuestra responsabilidad proteger a nuestros soldados.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以在FS里，无论什么情况，如果被防暴弹击中头部，就会被赋予几天休假。这不是权利而是义务。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以在FS裡，無論什麼情況，如果被防暴彈擊中頭部，就會被賦予幾天休假。這不是權利而是義務。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00188",
		linknext = "0057_00190",
		line = 2518,
	},
	["0057_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Esta arma tiene tanta potencia...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我接下来要用的枪有这么大的威力——是个意思对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我接下來要用的槍有這麼大的威力——是個意思對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00189",
		linknext = "0057_00191",
		line = 2529,
	},
	["0057_00191"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"cgact", file="cgact", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0306", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Así es. Recuérdalo siempre. Como dije, a menos que se te indique lo contrario, siempre debes apuntar a las piernas. Además, nunca debes disparar sin permiso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是的，千万不要忘记这件事……不过，正如最初说的，瞄准的基本是脚。而且，如果没有得到开枪许可，连开枪都不行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是的，千萬不要忘記這件事……不過，正如最初說的，瞄準的基本是腳。而且，如果沒有得到開槍許可，連開槍都不行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00190",
		linknext = "0057_00192",
		line = 2544,
	},
	["0057_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Con qué frecuencia se presentan esas situaciones?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“发出开枪许可的频率大概是多少呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「發出開槍許可的頻率大概是多少呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00191",
		linknext = "0057_00193",
		line = 2555,
	},
	["0057_00193"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0307", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Es imposible saberlo. Hay personas que han estado en la SS desde que estaban en clases de nivel B y nunca han visto un combate real.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不能一概而论。有人从B等部开始做了6年FS，却一次实战经验都没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不能一概而論。有人從B等部開始做了6年FS，卻一次實戰經驗都沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00192",
		linknext = "0057_00194",
		line = 2569,
	},
	["0057_00194"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0308", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sin embargo, dudo que ese sea el caso ahora. En todo el tiempo que llevo en la SS, nunca he visto una situación como la actual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是现在不可能了。我虽然加入FS已经有很长时间了……但是最近的状况明显不正常。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是現在不可能了。我雖然加入FS已經有很長時間了……但是最近的狀況明顯不正常。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00193",
		linknext = "0057_00195",
		line = 2583,
	},
	["0057_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debe estar hablando del problema de seguridad pública que ha estado ocurriendo últimamente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所谓的异常，果然和岛上的治安问题有关吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所謂的異常，果然和島上的治安問題有關吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00194",
		linknext = "0057_00196",
		line = 2593,
	},
	["0057_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que las 'circunstancias' también involucran la aparición de la NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对糺川前辈而言，反交尾势力的存在也属于“异常”之中吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"對糺川前輩而言，反交尾勢力的存在也屬於「異常」之中吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00195",
		linknext = "0057_00197",
		line = 2603,
	},
	["0057_00197"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0309", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Aunque normalmente apuntamos a las piernas, no dudes en apuntar a la cabeza cuando te enfrentes a la escoria del Frente Anticopulación a cualquiera que intente abusar de las lolis.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然说瞄准脚是基本……但如果对方是反交尾势力或对未达性年者下手的萝莉控人渣，就可以毫不犹豫对头开枪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然說瞄準腳是基本……但如果對方是反交尾勢力或對未達性年者下手的蘿莉控人渣，就可以毫不猶豫對頭開槍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00196",
		linknext = "0057_00198",
		line = 2616,
	},
	["0057_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su tono es escalofriante y me hace estremecer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冰冷的声音吓得我背脊发颤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冰冷的聲音嚇得我背脊發顫。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00197",
		linknext = "0057_00199",
		line = 2626,
	},
	["0057_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun después de explicar,e los peligros de apuntar a la cabeza, me dice que no dude en hacerlo con los miembros del NLNS—mis amigas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才还在说明头部受到一击有多么危险，反交尾势力——也就是如果对方是我们的话，就会毫不客气地攻击头部。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才還在說明頭部受到一擊有多麼危險，反交尾勢力——也就是如果對方是我們的話，就會毫不客氣地攻擊頭部。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00198",
		linknext = "0057_00200",
		line = 2636,
	},
	["0057_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No lo entiendo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00199",
		linknext = "0057_00201",
		line = 2646,
	},
	["0057_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Qué tiene de malo creer que no puedes tener sexo sin amor?",
					{"rt2"},
				},
			},
			cn = {
				{
					"提倡爱，拒绝无秩序的性爱难道就那么糟糕吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"提倡愛，拒絕無秩序的性愛難道就那麼糟糕嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00200",
		linknext = "0057_00202",
		line = 2656,
	},
	["0057_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Por qué tiene que ser tan hostil?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么要被如此仇视？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼要被如此仇視？",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00201",
		linknext = "0057_00203",
		line = 2666,
	},
	["0057_00203"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0310", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“El otro caso es el de los traidores. Tachibana, en el caso improbable de que traiciones a la SS, quiero que sepas que no dudaré en apuntarte a la cabeza. ¿Te queda claro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“还有……叛徒也是。橘，万一你做出背叛FS的行为，我一定会毫不犹豫地对你的头开枪，给我记住。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「還有……叛徒也是。橘，萬一你做出背叛FS的行為，我一定會毫不猶豫地對你的頭開槍，給我記住。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00202",
		linknext = "0057_00204",
		line = 2678,
	},
	["0057_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00203",
		linknext = "0057_00205",
		line = 2689,
	},
	["0057_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Empiezo a sudar frío.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冒冷汗了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冒冷汗了。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00204",
		linknext = "0057_00206",
		line = 2699,
	},
	["0057_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se siente como si supiera mis verdaderas intenciones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"简直——就像被看穿了一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"簡直——就像被看穿了一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00205",
		linknext = "0057_00207",
		line = 2709,
	},
	["0057_00207"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
