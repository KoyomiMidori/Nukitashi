				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡¡Sí, señor!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——Yes——Sir——！！”",
					{"rt2"},
