		linkback = "0057_00072",
		linknext = "0057_00074",
		line = 1046,
	},
	["0057_00074"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0278", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You're going to erect two tents. You've got 15 minutes. I don't mean a tent in your pants, but I don't think 15 minutes would be enough for you to do that anyway! Your job will be to divide everyone else into groups!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，在15分钟内搭建两个帐篷。事先说好不是胯下的帐篷！从分班开始全是你负责！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，在15分鐘內搭建兩個帳篷。事先說好不是胯下的帳篷！從分班開始全是你負責！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00073",
		linknext = "0057_00075",
		line = 1058,
	},
	["0057_00075"] = {
