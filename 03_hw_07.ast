		line = 1115,
	},
	["0057_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I split the trainees into two equal groups and we immediately get started on the tents.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我将训练生分成两半，立即开始搭建帐篷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我將訓練生分成兩半，立即開始搭建帳篷。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00078",
		linknext = "0057_00080",
		line = 1125,
	},
	["0057_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since none of us had ever put up a tent before, I had no doubt it was going to be a complete shambles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在没有学过组装方法的情况下就突然要我们搭建帐篷，她还是一样那么乱来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在沒有學過組裝方法的情況下就突然要我們搭建帳篷，她還是一樣那麼亂來。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00079",
		linknext = "0057_00081",
		line = 1135,
	},
	["0057_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still though, since I was given this responsibility, I have no choice but to make this work.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，既然被任命为队长，这点事情还是要做好的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，既然被任命為隊長，這點事情還是要做好的——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00080",
		linknext = "0057_00082",
		line = 1145,
	},
	["0057_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
