		{"text"},
		text = {
			vo = {
				{"vo", file="rei0253", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Como ya saben, soy Tadasugawa Rei, presidenta del comité de moral pública y su instructora. Sus bocas permanecerán cerradas con alambre a menos que se les hable o estén chupando pollas. ¿Entendido?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你们应该知道吧，我就是你们的教官糺川礼风纪委员长！除了被搭话和口交时以外，都把自己的嘴巴小穴缝上！知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你們應該知道吧，我就是你們的教官糺川禮風紀委員長！除了被搭話和口交時以外，都把自己的嘴巴小穴縫上！知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00002",
		linknext = "0057_00004",
		line = 69,
	},
	["0057_00004"] = {
