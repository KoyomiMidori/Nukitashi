	["0057_00332"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[8500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1050", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, es que estaba pensando que ponerle una correa a tu tableta era genial. ¡Debería hacerlo con la mía! Rei-chan, ¿por qué no lo haces tú también? ¡Así llevaremos lo mismo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……橘君，我在想把挂件挂在平板上好像不错……我也试试吧。对了，礼酱也来试试！这样大家就都一样了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……橘君，我在想把挂件掛在平板上好像不錯……我也試試吧。對了，禮醬也來試試！這樣大家就都一樣了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00331",
		linknext = "0057_00333",
		line = 4427,
	},
	["0057_00333"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=-400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
