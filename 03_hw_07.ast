	["0057_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I take my finger away from the trigger and put the gun down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我松开手指，放下枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我鬆開手指，放下槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00212",
		linknext = "0057_00214",
		line = 2883,
	},
	["0057_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After being such a failure at everything else, I wasn't delusional enough to think I'd be any better at firing a gun.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一开始我也是抱着“虽然其他不行，但是只对射击有着非比寻常的才能”这样的期待。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一開始我也是抱著「雖然其他不行，但是只對射擊有著非比尋常的才能」這樣的期待。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00213",
		linknext = "0057_00215",
		line = 2893,
	},
	["0057_00215"] = {
		{"bg", id=1, file="bg17_2_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00113", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0314", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, it's not really worth praising, but at least you did improve as you went.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然一开始就知道了，但还真是连奉承的话都说不出口的结果……不过后半部分有好一些。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然一開始就知道了，但還真是連奉承的話都說不出口的結果……不過後半部分有好一些。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00214",
		linknext = "0057_00216",
		line = 2907,
	},
	["0057_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It shouldn't be a surprise that I'm hopeless at this, too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然还是不行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然還是不行。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00215",
		linknext = "0057_00217",
		line = 2917,
	},
	["0057_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure that if I had my goggles I'd be able to fire much more accurately, but of course using them here isn't an option.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果有护目镜辅助的话，命中精度应该会有飞跃性的提高，但不能在FS使用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果有護目鏡輔助的話，命中精度應該會有飛躍性的提高，但不能在FS使用。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00216",
		linknext = "0057_00218",
		line = 2927,
	},
	["0057_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's amazing I've even made it this far without them, honestly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但没天分到这种地步，反而让人有种神清气爽的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但沒天分到這種地步，反而讓人有種神清氣爽的感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00217",
		linknext = "0057_00219",
		line = 2937,
	},
	["0057_00219"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0315", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Looks like they're still in the middle of their procreation training. All right, that's enough target practice for now. Let's do some special combat training now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么……性产训练还在继续的样子。好……橘，射击就到此为止了。我来特别帮你训练一下格斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼……性產訓練還在繼續的樣子。好……橘，射擊就到此為止了。我來特別幫你訓練一下格鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00218",
		linknext = "0057_00220",
		line = 2951,
	},
	["0057_00220"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0316", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I'm going to teach you Seiran Island Cunt-Quencher Combat, also known as CQC. It's not for the faint of heart. You think you can handle it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“现在要教你的是Seiranto Quench Combat……简称SQC的格斗术。这不是儿戏，你有觉悟吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「現在要教你的是Seiranto Quench Combat……簡稱SQC的格鬥術。這不是兒戲，你有覺悟嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00219",
		linknext = "0057_00221",
		line = 2965,
	},
	["0057_00221"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes! Please!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好的，拜托了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好的，拜託了！」",
					{"rt2"},
				},
