					"“¡Hoy entrenarán en grupos! ¡La mayor parte de las actividades de la SS se realizan en escuadrones! ¡Nekobana, ven aquí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“今天进行集体演习！FS的作战行动基本以分队规模进行！猫橘——过来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「今天進行集體演習！FS的作戰行動基本以分隊規模進行！貓橘——過來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00069",
		linknext = "0057_00071",
		line = 1007,
	},
	["0057_00071"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡Sí, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——Yes——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——Yes——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00070",
		linknext = "0057_00072",
		line = 1019,
	},
	["0057_00072"] = {
		{"bg", id=2, file="bg08_1l_00000", x=0, y=-100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="rei_01l_00001", file1="rei_01l_00104", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"se", id=0, loop=0, file="se_a035"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0277", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Eres el líder del escuadrón. Debes transmitir mis instrucciones a tu grupo con exactitud. Cuando diga que follen coños, preguntarás: ¿A cuántos?.Si su semen acaba en culos, serás tú quien responda. ¿Entendido?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你是队长。正确地传达我的指示。说要插入小穴就插入小穴。要是精子们跑到菊花就是你的责任。知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你是隊長。正確地傳達我的指示。說要插入小穴就插入小穴。要是精子們跑到菊花就是你的責任。知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00071",
		linknext = "0057_00073",
		line = 1035,
	},
	["0057_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡Sí, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——Yes——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——Yes——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00072",
		linknext = "0057_00074",
		line = 1046,
	},
	["0057_00074"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0278", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Vas a montar dos tiendas de campaña. Tienes 15 minutos. No me refiero a una tienda de campaña en tus pantalones, ¡pero no creo que 15 minutos sean suficientes para que hagas eso! ¡Tu trabajo será dividir a los demás en grupos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，在15分钟内搭建两个帐篷。事先说好不是胯下的帐篷！从分班开始全是你负责！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，在15分鐘內搭建兩個帳篷。事先說好不是胯下的帳篷！從分班開始全是你負責！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00073",
		linknext = "0057_00075",
		line = 1058,
	},
	["0057_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡Sí, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——Yes——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——Yes——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00074",
		linknext = "0057_00076",
		line = 1069,
	},
	["0057_00076"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0279", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Muévete! ¡Ran, pon el temporizador a 15 minutos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“马上开始！兰，测15分钟！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「馬上開始！蘭，測15分鐘！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00075",
		linknext = "0057_00077",
		line = 1083,
	},
	["0057_00077"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=0, loop=0, file="se_a020"},
		{"ex", time=700, func="wait"},
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Escuchen! ¡Tenemos 15 minutos para armar dos tiendas de campaña! ¡Divídanse en dos grupos y pónganse a trabajar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“听好了！接下来的15分钟内我要搭建两个帐篷——从中央开始分成左右两组工作！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「聽好了！接下來的15分鐘內我要搭建兩個帳篷——從中央開始分成左右兩組工作！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00076",
		linknext = "0057_00078",
		line = 1103,
	},
	["0057_00078"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0000", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“¡Chi cheñol!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00077",
		linknext = "0057_00079",
		line = 1115,
	},
	["0057_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Divido a los aprendices en dos grupos iguales y nos ponemos manos a la obra con las tiendas de campaña.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我将训练生分成两半，立即开始搭建帐篷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我將訓練生分成兩半，立即開始搭建帳篷。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00078",
		linknext = "0057_00080",
		line = 1125,
	},
	["0057_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como ninguno de nosotros había montado nunca una tienda de campaña, no me cabía duda de que iba a ser un desastre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在没有学过组装方法的情况下就突然要我们搭建帐篷，她还是一样那么乱来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在沒有學過組裝方法的情況下就突然要我們搭建帳篷，她還是一樣那麼亂來。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00079",
		linknext = "0057_00081",
		line = 1135,
	},
	["0057_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, dado que se me ha asignado esta responsabilidad, no tengo más remedio que hacer que esto funcione.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，既然被任命为队长，这点事情还是要做好的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，既然被任命為隊長，這點事情還是要做好的——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00080",
		linknext = "0057_00082",
		line = 1145,
	},
	["0057_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Primero extiendan las tiendas! Después... tomen los palos. ¡Introduzcan los palos por ellas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先……把帐篷打开！然后……是杆子。把杆子穿过去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先……把帳篷打開！然後……是桿子。把桿子穿過去！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00081",
		linknext = "0057_00083",
		line = 1157,
	},
	["0057_00083"] = {
		{"se", id=0, loop=0, file="se_a185"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Espero que estemos haciéndolo bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"组装的流程应该是对的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"組裝的流程應該是對的。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00082",
		linknext = "0057_00084",
		line = 1168,
	},
	["0057_00084"] = {
		{"se", id=0, loop=0, file="se_a146"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como nunca he hecho esto antes, no sé si 15 minutos son suficientes y no sé cómo distribuir el tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"由于没有经验，不知道15分钟是长是短，也不知道各工程的适当时间分配。",
					{"rt2"},
				},
			},
			tw = {
				{
					"由於沒有經驗，不知道15分鐘是長是短，也不知道各工程的適當時間分配。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00083",
		linknext = "0057_00085",
		line = 1179,
	},
	["0057_00085"] = {
		{"se", id=0, loop=0, file="se_a149"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sea como sea, debemos darnos prisa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之要抓紧时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之要抓緊時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00084",
		linknext = "0057_00086",
		line = 1190,
	},
	["0057_00086"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien, levántenlas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，把帐篷立起来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好，把帳篷立起來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00085",
		linknext = "0057_00087",
		line = 1202,
	},
	["0057_00087"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="obekka0003", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"おべっか"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"おべっか", "Lamebotas"},
					"“¡Señor! ¿Eh? Esto no está bien...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"おべっか", "马屁精"},
					"“Sir——！咦？感觉有点奇怪……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"おべっか", "馬屁精"},
					"「Sir——！咦？感覺有點奇怪……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00086",
		linknext = "0057_00088",
		line = 1214,
	},
	["0057_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00087",
		linknext = "0057_00089",
		line = 1226,
	},
	["0057_00089"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=2.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Montaron la tienda tal y como se les indicó, pero definitivamente no parece estar bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"靠气势搭起的帐篷，确实有些奇怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"靠氣勢搭起的帳篷，確實有些奇怪。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00088",
		linknext = "0057_00090",
		line = 1238,
	},
	["0057_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No está recta, los postes se doblan y sobresalen en ángulos extraños.",
					{"rt2"},
				},
			},
			cn = {
				{
					"帐篷没有笔直地立着，柱子向一个奇妙的方向弯曲着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"帳篷沒有筆直地立著，柱子向一個奇妙的方向彎曲著。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00089",
		linknext = "0057_00091",
		line = 1248,
	},
	["0057_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estaba bastante seguro de que los habíamos pasado por los agujeros correctos, pero debimos haber hecho algo mal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该交叉穿过孔洞了才对，是途中弄错了吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"應該交叉穿過孔洞了才對，是途中弄錯了嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00090",
		linknext = "0057_00092",
		line = 1258,
	},
	["0057_00092"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Quítenla! ¡Vamos a volver a hacer los postes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“把帐篷叠起来！重新装好柱子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「把帳篷疊起來！重新裝好柱子！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00091",
		linknext = "0057_00093",
		line = 1270,
	},
	["0057_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mierda, perdimos mucho tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"糟了。这是巨大的时间损失。",
					{"rt2"},
				},
			},
			tw = {
				{
					"糟了。這是巨大的時間損失。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00092",
		linknext = "0057_00094",
		line = 1280,
	},
	["0057_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No podremos terminarlo a tiempo...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话，15分钟是来不及——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話，15分鐘是來不及——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00093",
		linknext = "0057_00095",
		line = 1290,
	},
	["0057_00095"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00104", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
