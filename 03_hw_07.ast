		linkback = "0057_00271",
		linknext = "0057_00273",
		line = 3676,
	},
	["0057_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can tell I've improved throughout this grueling selection training.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我自己也切实感受到，通过这次选拔训练，自己变得比以前更强了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我自己也切實感受到，通過這次選拔訓練，自己變得比以前更強了。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00272",
		linknext = "0057_00274",
		line = 3686,
	},
	["0057_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though the SS is the natural enemy of the NLNS, I should probably be grateful for this opportunity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS对NLNS来说是天敌一样的存在——但在这件事上可以感谢一下。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS對NLNS來說是天敵一樣的存在——但在這件事上可以感謝一下。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00273",
		linknext = "0057_00275",
		line = 3696,
	},
	["0057_00275"] = {
