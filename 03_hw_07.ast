	["0057_00019"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0261", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡No te escucho, mierda! ¡Un viejo inválido corriéndose en las sábanas hace más ruido que tú! ¡¿Se te rompió la boca junto con la polla?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“完全听不见！卧病不起的臭老头的射精声都比你大声！你连上面的嘴巴都是性无能吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「完全聽不見！臥病不起的臭老頭的射精聲都比你大聲！你連上面的嘴巴都是性無能嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00018",
		linknext = "0057_00020",
		line = 284,
	},
	["0057_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
