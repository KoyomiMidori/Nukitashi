	["0057_00389"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa misma ley obliga a las personas a tener relaciones sexuales sin restricciones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷静想想。变态条例，是倡导无秩序性爱的条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷靜想想。變態條例，是倡導無秩序性愛的條例。",
