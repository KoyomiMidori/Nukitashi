	["0057_00342"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bueno... lo compraré.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过……买回去吧。",
