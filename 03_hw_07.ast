		linknext = "0057_00344",
		line = 4556,
	},
	["0057_00344"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0338", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah, see you. It's already dark, so take care on your way home. Don't take any questionable shortcuts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，再见。天已经黑了，你一定要小心。别想着要早点到家就走奇怪的路。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，再見。天已經黑了，你一定要小心。別想著要早點到家就走奇怪的路。」",
