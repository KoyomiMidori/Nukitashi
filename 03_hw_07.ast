			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Habrase visto! ¡Siguen aquí! ¡No sabía que todos ustedes fueran tan masoquistas, cobardes! ¡¿Saben lo que les espera a las perras buenas?! ¡200 sentadillas al estilo de la SS! ¡Muevan el culo!”",
