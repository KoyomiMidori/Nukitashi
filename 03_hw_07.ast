			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No vuelvas a apuntarle a un compañero fuera del entrenamiento. Si lo haces, serás expulsado de la SS sin posibilidad de apelación. ¿Queda claro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“除了训练以外不许再把枪对着队友。下次再这样不用多说直接赶出FS。明白了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「除了訓練以外不許再把槍對著隊友。下次再這樣不用多說直接趕出FS。明白了嗎？」",
					{"rt2"},
				},
			},
