		line = 1723,
	},
	["0057_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, though, I need to do whatever I can to gain their trust.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但为了得到信任，不应该做令人怀疑的事情。",
					{"rt2"},
				},
