		line = 4794,
	},
	["0057_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sea cual sea su posición, sería bueno conocerla mejor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管从哪个立场来说，知道了都没有损失。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管從哪個立場來說，知道了都沒有損失。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00360",
		linknext = "0057_00362",
		line = 4804,
	},
	["0057_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cómo se conocieron?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最初是什么时候认识的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最初是什麼時候認識的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00361",
		linknext = "0057_00363",
		line = 4815,
	},
	["0057_00363"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00119", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[8300] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=3, size=12.5, time=300, ease="easeinout_sine", delay2=8300},
			},
			[10300] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=10300, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1053", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pues bueno... Rei-chan llegó a la isla el año antes de cumplir la mayoría de edad... así que eso fue hace uno, dos, tres... ¿hace seis años?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……礼酱来到岛上是她成为性人的前一年……一、二、三……是六年前吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……禮醬來到島上是她成為性人的前一年……一、二、三……是六年前吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00362",
		linknext = "0057_00364",
		line = 4832,
	},
	["0057_00364"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Espera. Acabas de tirarme una bomba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请稍等一下。刚才你好像随口说了不得了的新信息……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請稍等一下。剛才你好像隨口說了不得了的新資訊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00363",
		linknext = "0057_00365",
		line = 4844,
	},
	["0057_00365"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Solía vivir en el continente?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“糺川前辈是从本岛搬来的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「糺川前輩是從本島搬來的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00364",
		linknext = "0057_00366",
		line = 4856,
	},
	["0057_00366"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1054", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí, así es.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，是啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，是啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00365",
		linknext = "0057_00367",
		line = 4869,
	},
	["0057_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca lo habría pensando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这真是令人震惊的新事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這真是令人震驚的新事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00366",
		linknext = "0057_00368",
		line = 4879,
	},
	["0057_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si solo llegó aquí hace seis años, debería haber madurado lo suficiente como para haber desarrollado sus propios valores y principios morales.",
					{"rt2"},
				},
			},
			cn = {
				{
					"6年前……那是情感和伦理观念早已成型的年龄吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"6年前……那是情感和倫理觀念早已成型的年齡吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00367",
		linknext = "0057_00369",
		line = 4889,
	},
	["0057_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque en ese momento no hubiera alcanzado la madurez sexual, si se crió en el continente, seguramente le habrán parecido extrañas las costumbres de la isla, al menos al principio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使当时搬来这里时还不是性人，但只要是本岛人，就一定会觉得这里很异常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使當時搬來這裡時還不是性人，但只要是本島人，就一定會覺得這裡很異常。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00368",
		linknext = "0057_00370",
		line = 4899,
	},
	["0057_00370"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Cómo es que ahora se siente tan cómoda con ellas?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但现在却熟悉成那样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但現在卻熟悉成那樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00369",
		linknext = "0057_00371",
		line = 4909,
	},
	["0057_00371"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que al principio debía ser bastante abierta, o que cedió fácilmente a la presión de adaptarse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是她原本就抵抗力弱呢，还是只是轻易就被岛上的同调压力吞噬了呢——这一点我不得而知。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是她原本就抵抗力弱呢，還是只是輕易就被島上的同調壓力吞噬了呢——這一點我不得而知。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00370",
		linknext = "0057_00372",
		line = 4919,
	},
	["0057_00372"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero eso es increíble. Nunca habría pensado que una oficial de la SS y presidente del comité de moral pública vivía en el continente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，真是不得了啊……从本岛来的人还当上了FS的风纪委员长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，真是不得了啊……從本島來的人還當上了FS的風紀委員長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00371",
		linknext = "0057_00373",
		line = 4931,
	},
	["0057_00373"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1055", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿No te parece que Rei-chan es genial? Al parecer, se unió a la SS únicamente por su familia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，礼酱真的很厉害，而且还很伟大呢！她加入FS是为了家人哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，禮醬真的很厲害，而且還很偉大呢！她加入FS是為了家人哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00372",
		linknext = "0057_00374",
		line = 4945,
	},
	["0057_00374"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿A qué te refieres?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么说？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼說？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00373",
		linknext = "0057_00375",
		line = 4957,
	},
	["0057_00375"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1056", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pues, um... No conozco bien los detalles, pero me dijo que no tiene papá y que su mamá estaba hospitalizada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，那个……我也不是很清楚，不过……礼酱家爸爸不在，妈妈在住院。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，那個……我也不是很清楚，不過……禮醬家爸爸不在，媽媽在住院。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00374",
		linknext = "0057_00376",
		line = 4971,
	},
	["0057_00376"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00375",
		linknext = "0057_00377",
		line = 4983,
	},
	["0057_00377"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1057", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí. Como tiene hermanos menores a los que cuidar, necesitaba la beca.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……还有，因为有弟弟和妹妹，所以礼酱一直在FS里努力，为了争取奖学金。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……還有，因為有弟弟和妹妹，所以禮醬一直在FS裡努力，為了爭取獎學金。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00376",
		linknext = "0057_00378",
		line = 4997,
	},
	["0057_00378"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00377",
		linknext = "0057_00379",
		line = 5009,
	},
	["0057_00379"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De ser cierto, no me imagino lo difícil que debe haber sido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听了那样的话，反而变得难办了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽了那樣的話，反而變得難辦了。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00378",
		linknext = "0057_00380",
		line = 5019,
	},
	["0057_00380"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora entiendo por qué se comporta así durante el entrenamiento. Probablemente sea su sentido innato de la responsabilidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么她会进行那么彻底的——甚至可以说是过度的指导，或许就是来自这种责任感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼她會進行那麼徹底的——甚至可以說是過度的指導，或許就是來自這種責任感。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00379",
		linknext = "0057_00381",
		line = 5029,
