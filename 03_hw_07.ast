	["0057_00262"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al hacer la reverencia, mi tensión se libera y caigo de espaldas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我低下头一下子没了力气，一屁股坐了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我低下頭一下子沒了力氣，一屁股坐了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00261",
		linknext = "0057_00263",
		line = 3559,
	},
	["0057_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al final, me pasé todo el tiempo recibiendo una paliza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果——到天黑为止一直被打得落花流水。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結果——到天黑為止一直被打得落花流水。",
					{"rt2"},
				},
