	},
	["0057_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not standing up straight, and the poles are bending and sticking out at weird angles.",
