			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I made it in home economics a long time ago and gave it to her as a present.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“在很久以前，家庭课的时候做了送给礼酱的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「在很久以前，家庭課的時候做了送給禮醬的。」",
