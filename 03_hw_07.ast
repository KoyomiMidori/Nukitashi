	["0057_00267"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0328", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Cierto. El objetivo del CC es someter a los agresores para detenerlos de forma segura. No pretende causar lesiones permanentes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“当然。SQC的基本目的是镇压暴徒，不是为了伤害暴徒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「當然。SQC的基本目的是鎮壓暴徒，不是為了傷害暴徒。」",
