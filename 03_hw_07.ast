	["0057_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hah... Hah... Schubert, was it? Sorry I didn't think to ask you beforehand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈……是叫舒伯特吗？刚才是我不好……都怪我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈……是叫舒伯特嗎？剛才是我不好……都怪我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00120",
		linknext = "0057_00122",
		line = 1655,
	},
	["0057_00122"] = {
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0005", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Oh, don't worry about it. I'm here to join comms. My stamina isn't much to speak of, but I consider myself to be pretty smart. Don't be afraid to AMA.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“没事的……我的志愿是通讯部队……虽然对体力没有自信，但对知识有自信。今后可以多依靠我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「沒事的……我的志願是通訊部隊……雖然對體力沒有自信，但對知識有自信。今後可以多依靠我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00121",
		linknext = "0057_00123",
		line = 1668,
	},
	["0057_00123"] = {
