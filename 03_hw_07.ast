		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ejerce presión sobre el brazo que tiene retorcido detrás de mi espalda, provocándome un dolor punzante.",
					{"rt2"},
				},
			},
			cn = {
				{
