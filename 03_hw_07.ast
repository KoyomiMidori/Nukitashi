	["0057_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Being yelled at has nothing on being reprimanded in that perfectly calm voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"比起被骂，以平静的语气被指责更可怕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"比起被罵，以平靜的語氣被指責更可怕。",
