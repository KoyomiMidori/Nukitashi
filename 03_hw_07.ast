	["0057_00028"] = {
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0267", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Y una mierda! ¡Un mierda como tú no puede decidir su nombre! ¡A partir de ahora te llamas Schubert! ¿Te gusta ese nombre, Mozart?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“开什么玩笑！区区精液胆敢报上像人类般的名字！你从今天开始就叫舒伯特！知道了吗，莫扎特！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「開什麼玩笑！區區精液膽敢報上像人類般的名字！你從今天開始就叫舒伯特！知道了嗎，莫扎特！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00027",
		linknext = "0057_00029",
		line = 428,
	},
	["0057_00029"] = {
		{"text"},
		text = {
