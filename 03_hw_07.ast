	["0057_00304"] = {
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I knew they were old friends, but not to that extent.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然听说是旧识，居然还做了那样的事情啊。",
					{"rt2"},
				},
			},
			tw = {
