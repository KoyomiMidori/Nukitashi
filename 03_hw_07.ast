			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Por qué te ríes? ¡Fuiste tú el que preguntó! ¡No es justo! ¡Deja de burlarte de mí!”",
