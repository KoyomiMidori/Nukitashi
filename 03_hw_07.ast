		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me muestra la correa con forma de ardilla que lleva en su bolso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱转了个身，给我看挂在书包上的松鼠挂件。",
