					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, that's right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，是啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，是啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00365",
		linknext = "0057_00367",
		line = 4869,
	},
	["0057_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never would've guessed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这真是令人震惊的新事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這真是令人震驚的新事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00366",
		linknext = "0057_00368",
		line = 4879,
	},
	["0057_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If she only came here six years ago, she should've been emotionally mature enough to have developed her own values and morals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"6年前……那是情感和伦理观念早已成型的年龄吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"6年前……那是情感和倫理觀念早已成型的年齡吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00367",
		linknext = "0057_00369",
		line = 4889,
	},
	["0057_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if she wasn't sexually mature at the time, if she grew up on the mainland, then she must've found the island's customs bizarre, at least at first.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使当时搬来这里时还不是性人，但只要是本岛人，就一定会觉得这里很异常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使當時搬來這裡時還不是性人，但只要是本島人，就一定會覺得這裡很異常。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00368",
		linknext = "0057_00370",
		line = 4899,
	},
	["0057_00370"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How could she be so comfortable with them now?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但现在却熟悉成那样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但現在卻熟悉成那樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00369",
		linknext = "0057_00371",
		line = 4909,
	},
	["0057_00371"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suppose she must have been pretty open to begin with, or she easily gave in to the pressure to conform.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是她原本就抵抗力弱呢，还是只是轻易就被岛上的同调压力吞噬了呢——这一点我不得而知。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是她原本就抵抗力弱呢，還是只是輕易就被島上的同調壓力吞噬了呢——這一點我不得而知。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00370",
		linknext = "0057_00372",
		line = 4919,
	},
	["0057_00372"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But that's pretty shocking. I never would've thought an SS officer and president of the disciplinary committee was originally a mainlander.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，真是不得了啊……从本岛来的人还当上了FS的风纪委员长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，真是不得了啊……從本島來的人還當上了FS的風紀委員長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00371",
		linknext = "0057_00373",
		line = 4931,
	},
	["0057_00373"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1055", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Isn't Rei amazing? Apparently she joined the SS entirely because of her family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，礼酱真的很厉害，而且还很伟大呢！她加入FS是为了家人哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，禮醬真的很厲害，而且還很偉大呢！她加入FS是為了家人哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00372",
		linknext = "0057_00374",
		line = 4945,
	},
	["0057_00374"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么说？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼說？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00373",
		linknext = "0057_00375",
		line = 4957,
	},
	["0057_00375"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1056", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I, so, uhh... I don't know the full details, but she told me that she doesn't have a father, and her mother was hospitalized.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，那个……我也不是很清楚，不过……礼酱家爸爸不在，妈妈在住院。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，那個……我也不是很清楚，不過……禮醬家爸爸不在，媽媽在住院。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00374",
		linknext = "0057_00376",
		line = 4971,
	},
	["0057_00376"] = {
