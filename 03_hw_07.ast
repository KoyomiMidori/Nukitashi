			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡Rei-senpai! ¡Ya pasaron 15 minutos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“礼前辈，15分钟过去了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「禮前輩，15分鐘過去了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00094",
		linknext = "0057_00096",
		line = 1304,
	},
	["0057_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, it's not even almost done.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不行——完全不行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不行——完全不行。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00095",
		linknext = "0057_00097",
		line = 1314,
	},
	["0057_00097"] = {
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=50},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=50},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0280", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Hagan fila!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“全员列队！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「全員列隊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00096",
		linknext = "0057_00098",
		line = 1331,
	},
	["0057_00098"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡Sí, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……Sir——Yes——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……Sir——Yes——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00097",
		linknext = "0057_00099",
		line = 1343,
	},
	["0057_00099"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00118", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0281", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Oh? ¡Nunca había visto una tienda de campaña así? ¡Pero es increíble! ¡Debe ser una tienda de campaña del futuro! ¡¿Se atreven a acampar en ella, idiotas?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哦……这是帐篷吗？太棒了！我第一次见到这种形状，是未来的帐篷吗！你们会在这里野营吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哦……這是帳篷嗎？太棒了！我第一次見到這種形狀，是未來的帳篷嗎！你們會在這裡野營嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00098",
		linknext = "0057_00100",
		line = 1357,
	},
	["0057_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡No, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——No——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——No——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00099",
		linknext = "0057_00101",
		line = 1368,
	},
	["0057_00101"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0282", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“El otro equipo lo hizo muy bien, ¿no? A ver, ¿quién era el líder aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“另一队是漂亮的勃起帐篷哦。那边的指挥是谁？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「另一隊是漂亮的勃起帳篷哦。那邊的指揮是誰？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00100",
		linknext = "0057_00102",
		line = 1382,
	},
	["0057_00102"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0003", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“¡Señor! ¡Era yo, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“Sir——！是我！Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「Sir——！是我！Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00101",
		linknext = "0057_00103",
		line = 1394,
	},
	["0057_00103"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0283", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Has hecho esto antes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你有经验吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你有經驗嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00102",
		linknext = "0057_00104",
		line = 1406,
	},
	["0057_00104"] = {
		{"text"},
		text = {
