	["0057_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Making friends with SS trainees feels a bit like fraternizing with the enemy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和志愿FS的人建立起情感，也让我的心情有点复杂——",
					{"rt2"},
				},
			},
			tw = {
				{
					"和志願FS的人建立起情感，也讓我的心情有點複雜——",
					{"rt2"},
				},
			},
