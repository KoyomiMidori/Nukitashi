	["0057_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My head's spinning, and I can't think straight...",
					{"rt2"},
				},
			},
			cn = {
				{
					"到底是什么——大脑在摇晃，无法正常运转。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到底是什麼——大腦在搖晃，無法正常運轉。",
