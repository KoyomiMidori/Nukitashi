		{"fg", file="ran_01m_00001", file1="ran_01m_00103", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0153", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡Denegado! ¿Crees que eres apta para la SS si te quedas sin energía después de una corridita o dos? Tienes que correrte consecutivamente en todo momento y conservar energía. ¡No lo olvides, soldado!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“不认可！你认为才潮吹一两次就撑不住的人能当上FS吗！？要时刻注意让自己能在保持体力充沛的状态下连续潮吹！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「不認可！你認為才潮吹一兩次就撐不住的人能當上FS嗎！？要時刻注意讓自己能在保持體力充沛的狀態下連續潮吹！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00134",
		linknext = "0057_00136",
		line = 1849,
	},
	["0057_00136"] = {
