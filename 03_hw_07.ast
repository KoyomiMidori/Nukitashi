	["0057_00156"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0293", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No vuelvas a cometer ese maldito error nunca más. ¿Entendido?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你刚刚犯了绝对不应该犯的错误。明白吗？”",
					{"rt2"},
				},
			},
			tw = {
