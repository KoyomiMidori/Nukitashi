		linkback = "0057_00220",
		linknext = "0057_00222",
		line = 2977,
	},
	["0057_00222"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0317", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Good answer. Very well, then. Think of me as an enemy and come at me with everything you've got.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“只有回答能独当一面呢……好吧，训练中不用担心上下关系，尽全力来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「只有回答能獨當一面呢……好吧，訓練中不用擔心上下關係，盡全力來吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00221",
		linknext = "0057_00223",
		line = 2989,
	},
