	["0057_00021"] = {
		{"se", id=0, loop=0, file="se_a021"},
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=2, file="bg17_1l_00000", x=300, y=-250, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-305, y=345, time=13000, lv=5},
		{"fgact", ch="礼", id=9, act="振動下", loop=17, size=7.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0262", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Escúchame bien! ¡Aquí no hay intolerancia! ¡No menosprecio a los que tienen una polla flácida, una polla pequeña, eyaculación precoz o labios vaginales anormalmente gruesos! ¡Aquí todos son iguales, unos contenedores de semen sin valor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“听好了！我不会歧视！无论是性功能障碍短小早泄还是黑木耳大阴唇，我都不会瞧不起！因为你们这群混蛋们全部都是平等的垃圾精子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「聽好了！我不會歧視！無論是性功能障礙短小早洩還是黑木耳大陰唇，我都不會瞧不起！因為你們這群混蛋們全部都是平等的垃圾精子！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00020",
		linknext = "0057_00022",
		line = 315,
	},
	["0057_00022"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=3, file="bg17_1l_00000", x=500, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=3, act="移動", x=-805, y=-5, time=13000, lv=5},
		{"fgact", ch="礼", id=9, act="振動下", loop=16, size=7.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0263", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Hay 300 millones de espermatozoides en cada eyaculación! ¡Solo uno de ellos logra fertilizar un óvulo! ¡Ustedes son los 299,999,999 que no lo logran!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“一次射出的精子有3亿个！能受精的只有1个！但是，你们连剩下的2亿9999万以下省略的精液都比不上！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「一次射出的精子有3億個！能受精的只有1個！但是，你們連剩下的2億9999萬以下省略的精液都比不上！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00021",
		linknext = "0057_00023",
		line = 332,
	},
	["0057_00023"] = {
		{"se", id=0, stop=1, time=2000},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=3, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
