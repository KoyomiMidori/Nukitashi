	["0057_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As part of the NLNS, I can't help but see everyone here as the enemy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来就连一起接受FS选拔训练的人，对于NLNS的我来说也都是敌人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來就連一起接受FS選拔訓練的人，對於NLNS的我來說也都是敵人。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00113",
		linknext = "0057_00115",
		line = 1535,
	},
	["0057_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her assessment that I couldn't trust them was dead on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被点出不打算信任别人一事，准确地戳中了我的要害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被點出不打算信任別人一事，準確地戳中了我的要害。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00114",
		linknext = "0057_00116",
		line = 1545,
	},
	["0057_00116"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00104", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0289", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I don't care if you can't commufornicate! That just means you gotta try even harder! Got it!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不能做爱可无法成为借口！不能做爱的话，就要比别人更注意周围的情况！知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不能做愛可無法成為藉口！不能做愛的話，就要比別人更注意周圍的情況！知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00115",
		linknext = "0057_00117",
		line = 1559,
	},
	["0057_00117"] = {
		{"text"},
		text = {
			ja = {
