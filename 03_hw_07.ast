	["0057_00124"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0006", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Heh... The way I see it, we've got about an 85.5% chance of getting through this selection training. You think we can both pass?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“呼……根据我的计算，我们通过选拔训练的概率是85.5%……一起加入FS吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「呼……根據我的計算，我們通過選拔訓練的概率是85.5%……一起加入FS吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00123",
		linknext = "0057_00125",
		line = 1692,
	},
