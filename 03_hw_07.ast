	["0057_00283"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Wata-chan? ¿Qué haces aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个声音……渡酱？为什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個聲音……渡醬？為什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00282",
		linknext = "0057_00284",
		line = 3815,
	},
	["0057_00284"] = {
		{"se", id=0, loop=0, file="se_a022"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan se acerca corriendo, con su mochila a la espalda y su silla plegable bajo el brazo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"背着书包、抱着钢管椅子的渡酱，小跑步过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"背著書包、抱著鋼管椅的渡醬，小跑步過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00283",
		linknext = "0057_00285",
		line = 3826,
	},
	["0057_00285"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"fgact", ch="礼", id=9, act="移動", x=-400, y=0, time=700},
		{"se", id=0, stop=1, time=1000},
		{"bgm", file="bgm23", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1040", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Terminaste el entrenamiento de hoy, ¿verdad? ¡Buen trabajo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“训练刚刚结束吧？你们两个都辛苦了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「訓練剛剛結束吧？你們兩個都辛苦了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00284",
		linknext = "0057_00286",
		line = 3843,
	},
	["0057_00286"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me esforcé mucho...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“辛苦了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「辛苦了……」",
					{"rt2"},
