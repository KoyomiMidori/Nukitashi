				{"vo", file="rei0284", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, how about that? Schubert isn't just a composer, he pitches a hell of a tent, too! Did you know that, Pussybana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“舒伯特训练生不仅会写歌还会搭帐篷呢！你知道这事吗小猫咪？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「舒伯特訓練生不僅會寫歌還會搭帳篷呢！你知道這事嗎小貓咪？」",
					{"rt2"},
				},
			},
		},
