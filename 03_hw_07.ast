					"或者说——看到一起度过地狱般的日子的实习生们做爱的情景，说实话心情很复杂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者說——看到一起度過地獄般的日子的實習生們做愛的情景，說實話心情很複雜。",
					{"rt2"},
				},
			},
