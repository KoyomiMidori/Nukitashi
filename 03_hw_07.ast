					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I was really tired after training, but you've helped me perk back up again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……因为刚才的训练而感到疲惫的身体充满了力量——”",
