	["0057_00030"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00118", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=-400, y=0},
		{"fgact", ch="礼", id=9, act="移動", x=400, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0268", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tú, la de las coletas... ¡Te he visto antes! ¡Eres esa lameculos que se matriculó antes, pero que se largó al primer día! ¿Has venido aquí para volver a hacer las cosas a medias, gusano?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那边的双马尾……我记得你……你是以前第一天就被淘汰的拍马屁小穴对吧！你又想来被嘲笑吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那邊的雙馬尾……我記得你……你是以前第一天就被淘汰的拍馬屁小穴對吧！你又想來被嘲笑嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00029",
		linknext = "0057_00031",
		line = 455,
	},
	["0057_00031"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="obekka0001", path=":vo/", ch="bmob"},
			},
			ja = {
				{
