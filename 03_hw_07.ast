	["0057_00397"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien... Mi laptop pesa demasiado. Me cuesta mucho llevarla, pero no puedo dejarla atrás. ¿Qué hago?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么……最近电脑系统有点肥大，反应很迟钝，该怎么办才好呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼……最近電腦系統有點肥大，反應很遲鈍，該怎麼辦才好呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00396",
		linknext = "0057_00398",
		line = 5215,
	},
