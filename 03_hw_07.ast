					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Lo hice en la clase de economía doméstica hace mucho tiempo y se lo regalé.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“在很久以前，家庭课的时候做了送给礼酱的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「在很久以前，家庭課的時候做了送給禮醬的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00301",
