	["0057_00170"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0298", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Now, let's get to weapons practice. Have you observed SS or OSS members using firearms before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，接下来要开始射击训练了……有看过FS和SHO用枪吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，接下來要開始射擊訓練了……有看過FS和SHO用槍嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00169",
		linknext = "0057_00171",
		line = 2302,
	},
	["0057_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——有过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——有過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00170",
		linknext = "0057_00172",
		line = 2313,
	},
	["0057_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Observed, she says. Lady, I've had them point the fuckin' things at me more times than I can count.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有过，之前被枪口对准过好几次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有過，之前被槍口對準過好幾次。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00171",
		linknext = "0057_00173",
		line = 2323,
	},
	["0057_00173"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0299", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I see. Then you'd already know that they use non-lethal riot ammunition. The idea is to aim for the rioters' legs in order to incapacitate them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊……那你知道吧，子弹是防暴弹。打在暴徒的脚上使之无力化是基本用法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣啊……那你知道吧，子彈是防暴彈。打在暴徒的腳上使之無力化是基本用法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00172",
		linknext = "0057_00174",
		line = 2335,
	},
	["0057_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How many hits does that usually take?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是——要打几发才能使之无力化？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是——要打幾發才能使之無力化？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00173",
		linknext = "0057_00175",
		line = 2346,
	},
	["0057_00175"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0300", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Just one. It effectively becomes impossible to escape after that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“只要一枪，基本上就不可能正常逃走。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「只要一槍，基本上就不可能正常逃走。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00174",
		linknext = "0057_00176",
		line = 2360,
	},
	["0057_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's a lotta power.",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然有如此威力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然有如此威力。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00175",
		linknext = "0057_00177",
		line = 2370,
	},
	["0057_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They've been pointed at me so many times, but now I realize just how lucky I've been to always escape.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前中了几枪还能逃到现在——也许只是单纯的幸运。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之前中了幾槍還能逃到現在——也許只是單純的幸運。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00176",
		linknext = "0057_00178",
		line = 2380,
	},
	["0057_00178"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0301", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That's just the new recruits' handguns. As they rise through the ranks, they get equipped with SMGs, assault rifles, and sniper rifles.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就连新兵使用的手枪都有相当的威力。特别奖学生的话，就连冲锋枪、突击步枪、狙击步枪——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就連新兵使用的手槍都有相當的威力。特別獎學生的話，就連衝鋒槍、突擊步槍、狙擊步槍——」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00177",
		linknext = "0057_00179",
		line = 2392,
	},
	["0057_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gives me a lengthy explanation of each.",
					{"rt2"},
				},
			},
			cn = {
				{
					"糺川前辈向我解说各种武器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"糺川前輩向我解說各種武器。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00178",
		linknext = "0057_00180",
		line = 2402,
	},
	["0057_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I receive a comprehensive lecture on the enemy's armament.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，我们的敌人正对我展示着自己在用的武器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，我們的敵人正對我展示著自己在用的武器。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00179",
		linknext = "0057_00181",
		line = 2412,
	},
	["0057_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hearing first-hand about the firepower of each one horrifies me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直接听到其威力有多大——说实话也没让我太恐惧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直接聽到其威力有多大——說實話也沒讓我太恐懼。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00180",
		linknext = "0057_00182",
		line = 2422,
	},
	["0057_00182"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0302", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“A shot to the skull from one of these would cause a concussion. Repeated shots risk causing chronic traumatic encephalopathy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这些武器如果打到头部就会出现脑震荡。如果反复被击中，有可能会导致慢性创伤性脑病变。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這些武器如果打到頭部就會出現腦震盪。如果反覆被擊中，有可能會導致慢性創傷性腦病變。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00181",
		linknext = "0057_00183",
		line = 2434,
	},
	["0057_00183"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Encepha-huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“慢性创伤……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「慢性創傷……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00182",
		linknext = "0057_00184",
		line = 2446,
	},
	["0057_00184"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0303", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I suppose you'd probably be more familiar with the abbreviation, CTE. They used to call it punch-drunk syndrome.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“简单说来，就是所谓的拳击员痴呆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「簡單說來，就是所謂的拳擊手癡呆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00183",
		linknext = "0057_00185",
		line = 2460,
	},
	["0057_00185"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, yeah, I've heard that happens to boxers and wrestlers a lot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，拳击手和职业摔跤选手容易得的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，拳擊手和職業摔跤選手容易得的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00184",
		linknext = "0057_00186",
		line = 2472,
	},
	["0057_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently it's common in any sport where impacts to the head can happen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不只是这些，听说头部容易受到冲击的体育运动员也很容易得拳击员痴呆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不只是這些，聽說頭部容易受到衝擊的體育運動員也很容易得拳擊手癡呆。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00185",
		linknext = "0057_00187",
		line = 2482,
	},
	["0057_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I remember correctly, repeated head trauma can cause brain damage, leading to headaches and memory loss.",
					{"rt2"},
				},
			},
			cn = {
				{
					"头反复持续受到强烈冲击的结果，大脑会出现问题，引起头痛、记忆障碍——",
					{"rt2"},
				},
			},
			tw = {
				{
					"頭反覆持續受到強烈衝擊的結果，大腦會出現問題，引起頭痛、記憶障礙——",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00186",
		linknext = "0057_00188",
		line = 2492,
	},
	["0057_00188"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0304", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It doesn't just happen to athletes. Soldiers who suffer repeated head trauma can be prone to it as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不只是体育运动员。反复患上脑震荡的士兵也容易得拳击员痴呆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不只是體育運動員。反覆患上腦震蕩的士兵也容易得拳擊手癡呆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00187",
		linknext = "0057_00189",
		line = 2506,
	},
	["0057_00189"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0305", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That's why, if any SS member under any circumstances takes a riot bullet to the head, they are given time off to recover. It's our responsibility to protect our soldiers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以在FS里，无论什么情况，如果被防暴弹击中头部，就会被赋予几天休假。这不是权利而是义务。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以在FS裡，無論什麼情況，如果被防暴彈擊中頭部，就會被賦予幾天休假。這不是權利而是義務。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00188",
		linknext = "0057_00190",
		line = 2518,
	},
	["0057_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This weapon has that much power...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我接下来要用的枪有这么大的威力——是个意思对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我接下來要用的槍有這麼大的威力——是個意思對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00189",
		linknext = "0057_00191",
		line = 2529,
	},
	["0057_00191"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"cgact", file="cgact", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0306", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That's right. Always remember that. As I said, unless otherwise directed, you are to always aim for the legs. Additionally, you are never to fire without explicit permission.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是的，千万不要忘记这件事……不过，正如最初说的，瞄准的基本是脚。而且，如果没有得到开枪许可，连开枪都不行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是的，千萬不要忘記這件事……不過，正如最初說的，瞄準的基本是腳。而且，如果沒有得到開槍許可，連開槍都不行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00190",
		linknext = "0057_00192",
		line = 2544,
	},
	["0057_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How frequently do those situations come up?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“发出开枪许可的频率大概是多少呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「發出開槍許可的頻率大概是多少呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00191",
		linknext = "0057_00193",
		line = 2555,
	},
	["0057_00193"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0307", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It's impossible to say. There are people who've been in the SS ever since they were in B-level classes and have never seen a proper combat situation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不能一概而论。有人从B等部开始做了6年FS，却一次实战经验都没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不能一概而論。有人從B等部開始做了6年FS，卻一次實戰經驗都沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00192",
		linknext = "0057_00194",
		line = 2569,
	},
	["0057_00194"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0308", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I doubt that's the case anymore, though. In all my time in the SS, I've never seen circumstances like what's going on right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是现在不可能了。我虽然加入FS已经有很长时间了……但是最近的状况明显不正常。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是現在不可能了。我雖然加入FS已經有很長時間了……但是最近的狀況明顯不正常。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00193",
		linknext = "0057_00195",
		line = 2583,
	},
	["0057_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must be talking about the public security problem that's been going on lately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所谓的异常，果然和岛上的治安问题有关吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所謂的異常，果然和島上的治安問題有關吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00194",
		linknext = "0057_00196",
		line = 2593,
	},
	["0057_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suspect the 'circumstances' also include the rise of the NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对糺川前辈而言，反交尾势力的存在也属于“异常”之中吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"對糺川前輩而言，反交尾勢力的存在也屬於「異常」之中吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00195",
		linknext = "0057_00197",
		line = 2603,
	},
	["0057_00197"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0309", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“While we ordinarily aim for the legs, feel free to aim for the head when dealing with the scum of the Anti-Copulation Front or anyone who tries to assault lolis.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然说瞄准脚是基本……但如果对方是反交尾势力或对未达性年者下手的萝莉控人渣，就可以毫不犹豫对头开枪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然說瞄準腳是基本……但如果對方是反交尾勢力或對未達性年者下手的蘿莉控人渣，就可以毫不猶豫對頭開槍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00196",
		linknext = "0057_00198",
		line = 2616,
	},
	["0057_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her tone is chilling, and sends shivers down my spine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冰冷的声音吓得我背脊发颤。",
					{"rt2"},
