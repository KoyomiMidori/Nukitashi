			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿T-Talento oculto?! No lo sé, nunca lo había pensado... pero me gusta cómo suena eso... jejeje...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
