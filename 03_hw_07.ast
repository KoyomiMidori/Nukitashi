	["0057_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't imagine how she would've looked while making it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她做的时候到底是什么表情呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"她做的時候到底是什麼表情呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00325",
		linknext = "0057_00327",
		line = 4355,
	},
	["0057_00327"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All I can imagine is that she would look at its puffed-up cheeks and say something like, “What, you got too many cocks in your mouth?”",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然做的时候是一边看着松鼠鼓起的脸颊，一边说着“这个表情是怎么回事，难道嘴里含着鸡巴吗！”……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然做的時候是一邊看著松鼠鼓起的臉頰，一邊說著「這個表情是怎麼回事，難道嘴裡含著肉棒嗎！」……？",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00326",
		linknext = "0057_00328",
		line = 4365,
	},
	["0057_00328"] = {
		{"text"},
		text = {
