			},
		},
		text = {
			vo = {
				{"vo", file="hinami1043", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Really? Ehehe, I'm happy to hear that. I'm glad it helps!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的吗？嘿嘿，那样说我很高兴啊，还好我做了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的嗎？嘿嘿，那樣說我很高興啊，還好我做了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00293",
		linknext = "0057_00295",
