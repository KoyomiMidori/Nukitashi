					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好！一個人都沒放棄，我很喜歡！開心吧豬頭們！現在起做FS式波比跳200次作為獎賞！開始！」",
					{"rt2"},
				},
			},
		},
