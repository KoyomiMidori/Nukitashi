					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, no...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不、不用了……”",
					{"rt2"},
