	["0057_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su mirada es fría como el hielo mientras me deja sin aliento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我气息奄奄地瞪着她，糺川前辈的表情却是冰冷的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我氣息奄奄地瞪著她，糺川前輩的表情卻是冰冷的。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00229",
