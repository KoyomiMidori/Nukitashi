		linkback = "0057_00158",
		linknext = "0057_00160",
		line = 2165,
	},
	["0057_00160"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0294", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Shall I explain? When you took that weapon, you had the muzzle pointed in my direction. And your finger was on the trigger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你不知道吗？你接枪的时候枪口朝向我，手指还在扳机上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你不知道嗎？你接槍的時候槍口朝向我，手指還在扳機上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00159",
		linknext = "0057_00161",
		line = 2177,
	},
	["0057_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
