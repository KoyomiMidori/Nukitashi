		linkback = "0057_00097",
		linknext = "0057_00099",
		line = 1343,
	},
	["0057_00099"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00118", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0281", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh? Never seen a tent like this before! Out-fucking-standing! It must be a tent from the future! Would you assholes camp in this!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哦……这是帐篷吗？太棒了！我第一次见到这种形状，是未来的帐篷吗！你们会在这里野营吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哦……這是帳篷嗎？太棒了！我第一次見到這種形狀，是未來的帳篷嗎！你們會在這裡野營嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00098",
		linknext = "0057_00100",
		line = 1357,
	},
	["0057_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir! No, sir!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——No——Sir——！”",
