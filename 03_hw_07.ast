	["0057_00156"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0293", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don't you ever make that fucking mistake again. Understood?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你刚刚犯了绝对不应该犯的错误。明白吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你剛剛犯了絕對不應該犯的錯誤。明白嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00155",
		linknext = "0057_00157",
