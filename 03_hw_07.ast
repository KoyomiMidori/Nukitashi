				{"vo", file="hinami1043", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿En serio? Jeje, me alegra saberlo. ¡Me alegra que te sirva de ayuda!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的吗？嘿嘿，那样说我很高兴啊，还好我做了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的嗎？嘿嘿，那樣說我很高興啊，還好我做了……」",
					{"rt2"},
				},
			},
