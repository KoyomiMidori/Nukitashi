		linkback = "0057_00105",
		linknext = "0057_00107",
		line = 1441,
	},
	["0057_00107"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0285", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Creo recordar que te dije que fueras el líder! ¿Puede un líder hacer su trabajo si no conoce a sus compañeros?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我应该命令你当队长了！连同伴的事情都不知道能当队长吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我應該命令你當隊長了！連同伴的事情都不知道能當隊長嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00106",
		linknext = "0057_00108",
		line = 1455,
	},
	["0057_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡No, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——No——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——No——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00107",
		linknext = "0057_00109",
		line = 1466,
	},
	["0057_00109"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0286", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Cualquiera debería armar una tienda de campaña en menos de 10 minutos, y unas perras como ustedes tuvieron 15! ¡¿Para qué creyeron que era el tiempo extra, para masturbarse o qué?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“本来设置帐篷10分钟就够了！但我给了15分钟。你以为这5分钟是给你自慰用的吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「本來設置帳篷10分鐘就夠了！但我給了15分鐘。你以為這5分鐘是給你自慰用的嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00108",
		linknext = "0057_00110",
		line = 1478,
	},
	["0057_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡No, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——No——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——No——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00109",
		linknext = "0057_00111",
		line = 1489,
	},
	["0057_00111"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00110", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0287", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Lo que debieron haber hecho es dedicar esos cinco minutos extra a averiguar si alguien de su grupo tenía experiencia, ¡pero parece que fue mucho pedir! ¡Cualquier perra chupapollas podría decirte cuál es tu problema!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“只要有5分钟应该就能轻松确认有没有经验才对！但你却没有确认！为什么没有，只要看着你的蠢样就连奶油猪都能懂！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「只要有5分鐘應該就能輕鬆確認有沒有經驗才對！但你卻沒有確認！為什麼沒有，只要看著你的蠢樣就連奶油豬都能懂！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00110",
		linknext = "0057_00112",
		line = 1503,
	},
	["0057_00112"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0288", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡No crees que tus compañeros sean confiables! ¡En la SS no hay lugar para idiotas que solo quieren dar órdenes a los demás! ¡Si no puedes confiar en tu equipo, vuelve a casa con mamá!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“因为你根本就没有信任同伴的意思！如果只想一个人出风头就赶快滚出去！FS不需要不相信同伴的人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「因為你根本就沒有信任同伴的意思！如果只想一個人出風頭就趕快滾出去！FS不需要不相信同伴的人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00111",
		linknext = "0057_00113",
		line = 1515,
	},
	["0057_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No hay nada que pueda decir al respecto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一点声音都发不出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一點聲音都發不出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00112",
		linknext = "0057_00114",
		line = 1525,
	},
	["0057_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como parte del NLNS, no dejo de ver a todos los que están aquí como enemigos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来就连一起接受FS选拔训练的人，对于NLNS的我来说也都是敌人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來就連一起接受FS選拔訓練的人，對於NLNS的我來說也都是敵人。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00113",
		linknext = "0057_00115",
		line = 1535,
	},
	["0057_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su conclusión de que no podía confiar en ellos era acertada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被点出不打算信任别人一事，准确地戳中了我的要害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被點出不打算信任別人一事，準確地戳中了我的要害。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00114",
		linknext = "0057_00116",
		line = 1545,
	},
	["0057_00116"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00104", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0289", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡No me importa si no puedes comufornicar! ¡Eso solo significa que tienes que esforzarte aún más! ¡¿Entendido?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不能做爱可无法成为借口！不能做爱的话，就要比别人更注意周围的情况！知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不能做愛可無法成為藉口！不能做愛的話，就要比別人更注意周圍的情況！知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00115",
		linknext = "0057_00117",
		line = 1559,
	},
	["0057_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Señor! ¡Sí, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“Sir——Yes——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「Sir——Yes——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00116",
		linknext = "0057_00118",
		line = 1570,
	},
	["0057_00118"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00116", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0290", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Pues date prisa y crea una buena relación con tu equipo! Tu pésimo liderazgo es la razón por la que no pudiste montar esas tiendas. Al suelo y haz 200 flexiones al estilo de la SS, ¡y que sean tres series!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那就立刻来提高与队友的同伴意识吧！因为队长的判断失误没能完成任务。全体人员FS式波比跳200次3套！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那就立刻來提高與隊友的同伴意識吧！因為隊長的判斷失誤沒能完成任務。全體人員FS式波比跳200次3套！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00117",
		linknext = "0057_00119",
		line = 1584,
	},
	["0057_00119"] = {
		{"text"},
		text = {
