		line = 2790,
	},
	["0057_00210"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0313", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Es como el sexo! ¡Si no tienes una erección, no puedes correrte! ¡Si tu postura es incorrecta, no puedes disparar! ¡Graba eso en tu mente!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就像做爱一样！小鸡鸡不以正确姿势勃起的话，不就不能射精了吗！姿势不正确就打不中！把它记在身体里！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就像做愛一樣！小雞雞不以正確姿勢勃起的話，不就不能射精了嗎！姿勢不正確就打不中！把它記在身體裡！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00209",
		linknext = "0057_00211",
		line = 2802,
	},
	["0057_00211"] = {
