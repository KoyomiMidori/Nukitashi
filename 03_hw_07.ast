	},
	["0057_00380"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can see why she is the way she is during training. It's probably her innate sense of responsibility.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么她会进行那么彻底的——甚至可以说是过度的指导，或许就是来自这种责任感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼她會進行那麼徹底的——甚至可以說是過度的指導，或許就是來自這種責任感。",
					{"rt2"},
				},
			},
		},
