	["0057_00032"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0269", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Este coño ronronea como un gatito cuando habla! ¿Qué te ha inspirado a volver arrastrándote? ¿Tu papá se ha dejado chupar por el coño de tu mamá?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“声音相当可爱的小穴啊！你又干什么来了！爸爸被妈妈的小穴吸进去了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「聲音相當可愛的小穴啊！你又幹什麼來了！爸爸被媽媽的小穴吸進去了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00031",
		linknext = "0057_00033",
		line = 481,
	},
	["0057_00033"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="obekka0002", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"おべっか"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"おべっか", "Lamebotas"},
					"“¡Señor! ¡Vivo en un hogar sin padre, así que quiero facilitarle la vida a mi madre con los fondos de la beca, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"おべっか", "马屁精"},
					"“Sir——！因为是母子单亲家庭，所以想拿特别奖学金让妈妈轻松点！Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"おべっか", "馬屁精"},
					"「Sir——！因為是母子單親家庭，所以想拿特別獎學金讓媽媽輕鬆點！Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00032",
		linknext = "0057_00034",
		line = 493,
	},
	["0057_00034"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0270", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Ah, qué bonito! ¡Hasta mi coño siente ganas de llorar por ti! Voy a darte una paliza en tu coñito adulador en lugar de tu papá, así que espero que estés lista para chorrear jugos vaginales por todos los poros de tu puto cuerpo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“孝顺到我的小穴都快哭了！今后我要代替爸爸操你那个谄媚小穴，所以你最好从全身的毛孔里都流出爱液做好准备！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「孝順到我的小穴都快哭了！今後我要代替爸爸操你那個諂媚小穴，所以你最好從全身的毛孔裡都流出愛液做好準備！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00033",
		linknext = "0057_00035",
		line = 507,
	},
	["0057_00035"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tadasugawa-senpai continúa con su implacable torrente de insultos, pasando revista a los aprendices y poniéndole a cada uno su propio nombre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"糺川前辈之后也目中无人地全力发挥，一个接一个给训练生任意取名字。",
					{"rt2"},
				},
			},
			tw = {
				{
					"糺川前輩之後也目中無人地全力發揮，一個接一個給訓練生任意取名字。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00034",
		linknext = "0057_00036",
		line = 519,
	},
	["0057_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ni siquiera hemos comenzado con el entrenamiento.",
					{"rt2"},
				},
			},
			cn = {
