	["0057_00254"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00116", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0324", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Intentaste cegarme? Nada mal. Has superado el nivel de 'trapo para correrse' y ahora rondas el de 'onahole'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“攻击眼睛吗……不坏的选择。就让你从射在卫生纸上的精子升级成被射在飞机杯里的精子吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「攻擊眼睛嗎……不壞的選擇。就讓你從射在衛生紙上的精子升級成被射在飛機杯裡的精子吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00253",
		linknext = "0057_00255",
		line = 3415,
	},
	["0057_00255"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00104", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0325", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Pero sabía que lo intentarías! ¡Escúchame! ¡Tan pronto como un oponente superior toma ventaja, todo se acabó!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是，那种进攻已经在我的预料之中了！听好，给我记住了！当你被比自己强的对手制造出不利于自己的状况时，你就已经完了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是，那種進攻已經在我的預料之中了！聽好，給我記住了！當你被比自己強的對手製造出不利於自己的狀況時，你就已經完了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00254",
		linknext = "0057_00256",
		line = 3429,
	},
