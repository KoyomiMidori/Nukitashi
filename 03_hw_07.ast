	["0057_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While I'm lost in thought, Wata stares at the strap she gave me with a strange look on her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我正胡思乱想时，渡酱带着烦恼的表情看着我的挂件。",
					{"rt2"},
				},
			},
			tw = {
