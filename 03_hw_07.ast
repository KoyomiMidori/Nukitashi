				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Todo el entrenamiento infernal de los últimos días me ha endurecido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这几天的地狱训练我也不是白挨的。",
					{"rt2"},
