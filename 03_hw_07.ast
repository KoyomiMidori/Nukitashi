		{"fg", file="rei_01ll_00001", file1="rei_01ll_00110", path=":fg/rei_01ll/", id=8, lv=5, head="rei_01ll", ch="礼", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"bg", id=2, file="bg17_1l_00000", x=500, y=0, lv=5, path=":bg/", sync=0, ev=1, style="blur", blurx=11, blury=11, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-805, y=-5, time=11000, lv=5},
		{"fgact", ch="礼", id=8, act="移動", x=-600, y=0, time=11000},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0264", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"非表示", "礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Rei"},
					"“¡No son más que esperma desorganizado y repugnante que no puede competir! ¡Están destinados a ser desechados en un pañuelo de papel, como una cucaracha aplastada y rociada con insecticida!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "礼"},
					"“你们是连竞争都无法参加的垃圾精子！射在卫生纸上和被喷了杀虫剂的蟑螂一起焚化处理就是你们的命运！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "禮"},
					"「你們是連競爭都無法參加的垃圾精子！射在衛生紙上和被噴了殺蟲劑的蟑螂一起焚化處理就是你們的命運！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00022",
		linknext = "0057_00024",
		line = 357,
	},
	["0057_00024"] = {
		{"fg", mode=-1, id=8, ch="礼", lv=5, time=300},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=2, lv=5, time=300, alphadel=1, evmaskoff=1},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0265", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Mis órdenes son convertirse en esperma con el que la propia Virgen María se sentiría orgullosa de ser fecundada, atarse un condón y deshacerse de todos aquellos que no tengan lo necesario para servir en mi querida SS. ¿Lo entienden, gusanos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“把你们培养成即使中出不丢脸的精子，把没用的精子包在安全套里从我心爱的FS里排除就是我的责任！知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「把你們培養成即使中出不丟臉的精子，把沒用的精子包在保險套裡從我心愛的FS裡排除就是我的責任！知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00023",
		linknext = "0057_00025",
		line = 378,
	},
	["0057_00025"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0000", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト", "訓練男子学生A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Estudiante en entrenamiento A"},
					"“¡Señor! ¡Sí, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "男训练生A"},
					"“Sir——Yes——Sir——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "男訓練生A"},
					"「Sir——Yes——Sir——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00024",
		linknext = "0057_00026",
		line = 390,
	},
	["0057_00026"] = {
		{"fgact", ch="礼", id=9, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0266", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Tú, el de ahí! ¡El de los dientes amarillentos, como una eyaculación de hace un día que aún no se ha limpiado del piso! ¿Cómo te llamas, imbécil?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那里的腰带！混蛋，那像安全套一样的腰带到底是怎么回事！报上名来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那裡的腰帶！混蛋，那像保險套一樣的腰帶到底是怎麼回事！報上名來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00025",
		linknext = "0057_00027",
		line = 403,
	},
	["0057_00027"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0001", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト", "訓練男子学生A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Estudiante en entrenamiento A"},
					"“¡Señor! ¡Nakamura Shuu, señor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "男训练生A"},
					"“Sir——！中村秀！Sir——！”",
					{"rt2"},
				},
			},
			tw = {
