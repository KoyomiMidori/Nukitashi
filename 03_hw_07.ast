					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Por qué no me ayudas a ganarme la confianza de Tadasugawa-senpai para que podamos cumplir con lo que queremos hacer?”",
