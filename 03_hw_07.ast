	["0057_00264"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tras sometidos al infierno del orgasmo, los demás aprendices tuvieron que limpiar las instalaciones de entrenamiento, todos estaban al borde de la muerte.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其他训练生似乎也在经历了高潮地狱后，还被强迫收拾训练器材，每个人都半死不活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其他訓練生似乎也在經歷了高潮地獄後，還被強迫收拾訓練器材，每個人都半死不活。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00263",
		linknext = "0057_00265",
		line = 3579,
	},
	["0057_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después del dolor que sufrí durante ese entrenamiento de combate, no creo que pueda llegar a casa, o...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也被FS式的格斗术弄到全身伤，连能不能好好回家都不知道——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也被FS式的格鬥術弄到全身傷，連能不能好好回家都不知道——",
					{"rt2"},
				},
			},
		},
