					name = {"ヒナミ", "Hinami"},
					"“Was that from Asane? You'd better hurry home, then. See you later, Rei!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是麻沙音酱吧？你得早点回家啊。嗯，这样的话……再见了，礼酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是麻沙音醬吧？你得早點回家啊。嗯，這樣的話……再見了，禮醬！」",
					{"rt2"},
				},
