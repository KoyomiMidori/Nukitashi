	["0072_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He really exposed everything. He wasn't just trying to intimidate Teshima, he went all-out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这并不是为了压制手嶋而进行的威胁或吓唬，而是仁浦先生真的向媒体透露了地下风俗的信息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這並不是為了壓制手嶋而進行的威脅或嚇唬，而是仁浦先生真的向媒體透露了地下風俗的資訊。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00007",
		linknext = "0072_00009",
		line = 98,
	},
	["0072_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And so, there's currently a firestorm of comments online debating over the exact level of corruption on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果，即使真伪不明，关于青蓝岛的种种恶评也在网上传播开来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結果，即使真偽不明，關於青藍島的種種惡評也在網上傳播開來。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00008",
		linknext = "0072_00010",
		line = 108,
	},
	["0072_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"“isn't that island like a yakuza paradise? gotta be no shortage of illegal shit happening there”",
