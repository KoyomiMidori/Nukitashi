		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“'Massive Prostitution Ring Uncovered, Puts Eliot Spitzer Scandal To Shame'... 'Dark Side of Seiran Island Brought to Light'... 'Notorious Sex Island Finally Crosses the Line'...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大规模卖淫问题被发现……青蓝岛的黑影……变态岛，终于越过了底线……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大規模賣淫問題被發現……青藍島的黑影……變態島，終於越過了底線……」",
					{"rt2"},
				},
			},
		},
		linknext = "0072_00002",
		line = 20,
	},
	["0072_00002"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
