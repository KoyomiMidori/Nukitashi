			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, it doesn't look like that's the case. The national public broadcaster's not saying a thing about it, it seems.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不，好像不是那样哦……全国区的节目好像没有那么郑重地提起青蓝岛的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不，好像不是那樣哦……全國區的節目好像沒有那麼鄭重地提起青藍島的事情……」",
					{"rt2"},
				},
