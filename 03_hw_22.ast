			cn = {
				{
					"一问，麻沙酱指向了平板的屏幕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一問，麻沙醬指向了平板的螢幕。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00020",
		linknext = "0072_00022",
		line = 247,
	},
	["0072_00022"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“'Arrests Made in Connection with Prostitution Ring'... Wait, the suspects are members of the National Diet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“涉嫌卖淫被捕……嫌疑人是国会议员？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「涉嫌賣淫被捕……嫌疑人是國會議員？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00021",
		linknext = "0072_00023",
		line = 259,
	},
	["0072_00023"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1167", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yep. Looks like this incident really set off a chain of dominoes. All the news shows were banging on about Seiran Island at first, but now we've got a big scandal on our hands.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……这次的事件爆发后，这样的事情被接二连三地爆出来……虽然一开始节目上都在指责青蓝岛，但现在都在报导这些丑闻了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……這次的事件爆發後，這樣的事情被接二連三地爆出來……雖然一開始節目上都在指責青藍島，但現在都在報導這些醜聞了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00022",
		linknext = "0072_00024",
		line = 272,
	},
	["0072_00024"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00023",
		linknext = "0072_00025",
		line = 284,
	},
	["0072_00025"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Reading further, I see that numerous politicians are being suspected of having links to prostitution on Seiran Island. That definitely sounds like scandal material.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我再次查看了一下，确实有复数的政治家在青蓝岛涉嫌卖淫，这造成了巨大的丑闻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我再次查看了一下，確實有復數的政治家在青藍島涉嫌賣淫，這造成了巨大的醜聞。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00024",
		linknext = "0072_00026",
		line = 296,
	},
	["0072_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though it's not like the media's tired of talking about Seiran Island now. It's more that the initial story had its time in the news cycle, and the newest headlines tend to displace older ones in the zeitgeist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然关于青蓝岛的话题不断，但因为人类很单纯，只要有更爆炸性的情报出现，就会像忘记之前的事情一样扑过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然關於青藍島的話題不斷，但因為人類很單純，只要有更爆炸性的情報出現，就會像忘記之前的事情一樣撲過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00025",
		linknext = "0072_00027",
		line = 306,
	},
	["0072_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like that, no one cares about Seiran Island anymore. They're just going on about the illegal sex trade and this massive national scandal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，在青蓝岛的卖淫——指的正是这次的地下风俗事件。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，在青藍島的賣淫——指的正是這次的地下風俗事件。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00026",
		linknext = "0072_00028",
		line = 316,
	},
	["0072_00028"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1746", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see those yakuza are plastered all over the news too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“关于黑社会的事情，也有很多新闻报道……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「關於黑社會的事情，也有很多新聞報導……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00027",
		linknext = "0072_00029",
		line = 330,
	},
	["0072_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the main force of the Yakuza Teshima talked about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是手嶋所说的“母体”黑社会团体。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是手嶋所說的「母體」黑社會團體。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00028",
		linknext = "0072_00030",
		line = 340,
	},
	["0072_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not even about the Seiran prostitution scandal. Apparently they've been connected with some past unresolved incidents.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不仅是青蓝岛的卖淫，与其成员相关的过去未被解决的事件也被提及。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不僅是青藍島的賣淫，與其成員相關的過去未被解決的事件也被提及。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00029",
		linknext = "0072_00031",
		line = 350,
	},
	["0072_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's not even all there is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且——不仅如此。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且——不僅如此。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00030",
		linknext = "0072_00032",
		line = 360,
	},
	["0072_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently they've found some connections between some big-shot politician on his way out of office and crime syndicates, and people are talking a bunch about that, too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就好像同一艘船上的人一样，更加有名的政治家和暴力团的关系也浮出水面，那边也成为了热门话题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就好像同一艘船上的人一樣，更加有名的政治家和暴力團的關係也浮出水面，那邊也成為了熱門話題。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00031",
		linknext = "0072_00033",
		line = 370,
	},
	["0072_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"More and more sensationalist headlines are drawing the general public's attention, making them forget about Seiran Island's involvement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"更加激动人心的事件频频吸引着大众的目光，渐渐远离了对青蓝岛的指责。",
					{"rt2"},
				},
			},
			tw = {
				{
					"更加激動人心的事件頻頻吸引著大眾的目光，漸漸遠離了對青藍島的指責。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00032",
		linknext = "0072_00034",
		line = 380,
	},
	["0072_00034"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Was this his game all along?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他从一开始，就想到了这一步——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他從一開始，就想到了這一步——」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00033",
		linknext = "0072_00035",
		line = 392,
	},
	["0072_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I remember him talking about ensuring the safety of the island before crushing the illegal sex trade.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要在破坏地下风俗前思考一下善后方案——仁浦先生的确是这么说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要在破壞地下風俗前思考一下善後方案——仁浦先生的確是這麼說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00034",
		linknext = "0072_00036",
		line = 402,
	},
	["0072_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't know how he pulled this off, but I'm guessing he knew that this would happen beforehand, laying the groundwork to get the public riled up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道他使用了什么样的手段，但他确实想到了这一步，事先做好了煽动民众的准备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道他使用了什麼樣的手段，但他確實想到了這一步，事先做好了煽動民眾的準備。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00035",
		linknext = "0072_00037",
		line = 412,
	},
	["0072_00037"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1168", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hell, if anything, people like the governor even more than before. That Yakuza arrest was a great PR stunt, not to mention how it exposed a bunch of corrupt politicians.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“县知事的评价……好像反而比以前更好了。因为检举黑社会这事成了契机，让他将腐败政治家的真面目揭发出来什么的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「縣知事的評價……好像反而比以前更好了。因為檢舉黑社會這事成了契機，讓他將腐敗政治家的真面目揭發出來什麼的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00036",
		linknext = "0072_00038",
		line = 424,
	},
	["0072_00038"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Looks like this all played out exactly as he planned.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这一切都在他的计划之内吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這一切都在他的計劃之內吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00037",
		linknext = "0072_00039",
		line = 436,
	},
	["0072_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's like he had us dancing in the palm of his hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像被他操控着一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像被他操控著一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00038",
		linknext = "0072_00040",
		line = 446,
	},
	["0072_00040"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, he did manage to fully eradicate the illegal sex trade. Now there shouldn't be any more victims going forward.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，完全驱逐了地下风俗是事实。现在，已经不会再有人受到伤害了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，完全驅逐了地下風俗是事實。現在，已經不會再有人受到傷害了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00039",
		linknext = "0072_00041",
		line = 458,
	},
	["0072_00041"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1747", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's true. Now all that's left is the law, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，是啊……接下来，就剩条例的事情……了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，是啊……接下來，就剩條例的事情……了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00040",
		linknext = "0072_00042",
		line = 471,
	},
	["0072_00042"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
