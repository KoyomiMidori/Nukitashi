	},
	["0072_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even when she learned I wasn't impotent, she showed me compassion and sympathy. She didn't start questioning why I wasn't having sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"知道我是阳痿的时候，礼前辈也没有强迫我做爱，反而充满了同情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"知道我是陽痿的時候，禮前輩也沒有強迫我做愛，反而充滿了同情。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00066",
		linknext = "0072_00068",
		line = 772,
	},
	["0072_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought she moved here when she was little and got used to it after she became sexually mature, but maybe I was wrong.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我原本感叹她在成为性人之前搬到了这里，居然还习惯了青蓝岛——或许，那也不是事实也说不定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我原本感嘆她在成為性人之前搬到了這裡，居然還習慣了青藍島——或許，那也不是事實也說不定。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00067",
		linknext = "0072_00069",
		line = 782,
	},
	["0072_00069"] = {
		{"text"},
		text = {
