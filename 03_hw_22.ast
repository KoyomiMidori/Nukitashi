			cn = {
				{
					"搞不懂她到底知不知道真相——学生会长扑哧扑哧地笑了笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"搞不懂她到底知不知道真相——學生會長噗哧噗哧地笑了笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00082",
		linknext = "0072_00084",
		line = 1008,
	},
	["0072_00084"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0622", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So, what brings you here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那么，有什么事呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那麼，有什麼事呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00083",
		linknext = "0072_00085",
		line = 1022,
	},
	["0072_00085"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Can you tell us about Rei's past?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……请告诉我有关礼前辈的过去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……請告訴我有關禮前輩的過去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00084",
		linknext = "0072_00086",
		line = 1034,
	},
	["0072_00086"] = {
		{"fgact", ch="桐香", id=8, act="移動", x=-400, y=0, time=700},
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1754", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Please, Touka. We really want to know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“拜托了桐香酱……我们无论如何都想知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「拜託了桐香醬……我們無論如何都想知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00085",
		linknext = "0072_00087",
		line = 1049,
	},
	["0072_00087"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0623", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Really? Sure, I don't mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是吗……嗯，可以哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是嗎……嗯，可以哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00086",
		linknext = "0072_00088",
		line = 1065,
	},
	["0072_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's just telling us, no questions asked.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毫不迟疑，也不问理由——学生会长一脸凉爽的表情回答。",
					{"rt2"},
				},
			},
			tw = {
				{
					"毫不遲疑，也不問理由——學生會長一臉涼爽的表情回答。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00087",
		linknext = "0072_00089",
		line = 1075,
	},
	["0072_00089"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Should you really be telling us this so readily?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……可以吗？这么干脆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……可以嗎？這麼乾脆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00088",
		linknext = "0072_00090",
		line = 1087,
	},
	["0072_00090"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00115", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0624", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“A couple of seniors want to get to know Rei better. Who am I to say no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈是想更深入了解礼的事情吧？那为什么还要隐瞒呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩是想更深入了解禮的事情吧？那為什麼還要隱瞞呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00089",
		linknext = "0072_00091",
		line = 1101,
	},
	["0072_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her expression is a bit unusual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一脸不可思议的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一臉不可思議的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00090",
		linknext = "0072_00092",
		line = 1111,
	},
	["0072_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's like she doesn't even know why we'd ask her that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她是认真的吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"她是認真的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00091",
		linknext = "0072_00093",
		line = 1121,
	},
	["0072_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The obvious thing would be that she's got some kind of ulterior motive, but from my assessment of her, she's not that type.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果她另有打算的话，还比较能让我信服——不过学生会长应该不是我能衡量的人吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果她另有打算的話，還比較能讓我信服——不過學生會長應該不是我能衡量的人吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00092",
		linknext = "0072_00094",
		line = 1131,
	},
	["0072_00094"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0625", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If I'm not mistaken, Watarai has known her longer than I have, so I assume you want to know about the time before they met. Do you mean before she came to Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“渡会同学应该比我和礼相识得更长吧……那么，你们想知道的是更之前的……是到青蓝岛之前的事情对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「渡會同學應該比我和禮相識得更長吧……那麼，你們想知道的是更之前的……是到青藍島之前的事情對嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00093",
		linknext = "0072_00095",
		line = 1145,
	},
	["0072_00095"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1755", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00094",
		linknext = "0072_00096",
		line = 1158,
	},
	["0072_00096"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0626", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Very well. As much as I would love to stay and discuss Rei's past at length, I am very busy, so I will only be able to give you the abridged version.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“原来如此……虽然我想慢慢地跟你们说，但可惜我之后有一些事情……所以我就挑重点说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「原來如此……雖然我想慢慢地跟你們說，但可惜我之後有一些事情……所以我就挑重點說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00095",
		linknext = "0072_00097",
		line = 1172,
	},
	["0072_00097"] = {
		{"bgm", stop=1},
		{"fg", file="touka_01m_00001", file1="touka_01m_00104", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0627", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Quite simply, she was sold off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“简单来说，礼被卖掉了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「簡單來說，禮被賣掉了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00096",
		linknext = "0072_00098",
		line = 1187,
	},
	["0072_00098"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00112", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1756", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sold off...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“被卖掉……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「被賣掉……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00097",
		linknext = "0072_00099",
		line = 1201,
	},
	["0072_00099"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[6300] = {
				{"fg", file="touka_01m_00001", file1="touka_01m_00104", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=6300, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0628", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That's right. Apparently, she was born into a very poor family on the mainland, where she lived much of her life. Unfortunately, they were eventually unable to make ends meet, so she came here to help pay off their debts. That's her story.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。她出生在本岛的贫困家庭，在那里生活了很长时间……但后来生活逐渐困难，她为了偿还债务，才来到了青蓝岛……就是这样的过程。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。她出生在本島的貧困家庭，在那裡生活了很長時間……但後來生活逐漸困難，她為了償還債務，才來到了青藍島……就是這樣的過程。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00098",
		linknext = "0072_00100",
		line = 1218,
	},
	["0072_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hold my breath.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无法呼吸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無法呼吸。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00099",
		linknext = "0072_00101",
		line = 1228,
	},
	["0072_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei came to this island for money.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈，为了钱，来到这个岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩，為了錢，來到這個島。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00100",
		linknext = "0072_00102",
		line = 1238,
	},
	["0072_00102"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0629", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“We know for a fact that many people enlist in the SS for the scholarship money. As a matter of fact, that's the source of the majority of our recruits.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈也知道吧，以奖学金为目的加入FS的人不在少数。倒不如说，大部分都是为了奖学金。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩也知道吧，以獎學金為目的加入FS的人不在少數。倒不如說，大部分都是為了獎學金。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00101",
		linknext = "0072_00103",
		line = 1250,
	},
	["0072_00103"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0630", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Since the primary task of the SS is to have sex, as long as you survive the selection training, most of what you'll be doing is indulging yourself and others. It's not particularly difficult or undesirable work, for most.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“FS的主要工作说到底就是做爱……只要克服选拔训练的话，基本上只要把身体交给快感……就不是件困难的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「FS的主要工作說到底就是做愛……只要克服選拔訓練的話，基本上只要把身體交給快感……就不是件困難的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00102",
		linknext = "0072_00104",
		line = 1264,
	},
	["0072_00104"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00106", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0631", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“However, Rei's situation was unique, and she never really got used to life here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是，礼……因为情况特殊，所以并没能融入这个岛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是，禮……因為情況特殊，所以並沒能融入這個島。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00103",
		linknext = "0072_00105",
		line = 1278,
	},
	["0072_00105"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She didn't?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说没融入是……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說沒融入是……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00104",
		linknext = "0072_00106",
		line = 1290,
	},
	["0072_00106"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00108", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0632", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Perhaps that's putting it too lightly... in reality, she loathes the act of sex entirely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“她在心底，对性行为抱有厌恶感……应该可以这么说吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「她在心底，對性行為抱有厭惡感……應該可以這麼說吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00105",
		linknext = "0072_00107",
		line = 1304,
	},
	["0072_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel like I got whiplash from that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感觉头脑被重击了一般。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感覺頭腦被重擊了一般。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00106",
		linknext = "0072_00108",
		line = 1314,
	},
	["0072_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei, the disciplinary committee president, one of the top members of the SS, loathes sex?",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长——站在FS顶端的礼前辈，厌恶做爱？",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員長——站在FS頂端的禮前輩，厭惡做愛？",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00107",
		linknext = "0072_00109",
		line = 1324,
	},
	["0072_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How can that be true?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果这是真的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果這是真的。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00108",
		linknext = "0072_00110",
		line = 1334,
	},
	["0072_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's been engaging in sexual acts this whole time, even though she deeply despised it?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那她一直到现在，都是压抑着内心的厌恶进行性行为吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那她一直到現在，都是壓抑著內心的厭惡進行性行為嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00109",
		linknext = "0072_00111",
		line = 1344,
	},
	["0072_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Does that mean she's been putting up with it all along just to support her family?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了养活家人，一直一直都这么忍受过来了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了養活家人，一直一直都這麼忍受過來了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00110",
		linknext = "0072_00112",
		line = 1354,
	},
	["0072_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What would that do to a person?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那到底是什么样的感觉——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那到底是什麼樣的感覺——",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00111",
		linknext = "0072_00113",
		line = 1364,
	},
	["0072_00113"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0633", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If anyone here could save her, it would be people who are just like her. For example, yourself and Watarai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果说有人能帮助礼的话……那一定是和礼一样……是前辈和渡会同学这样的人吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「如果說有人能幫助禮的話……那一定是和禮一樣……是前輩和渡會同學這樣的人吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00112",
		linknext = "0072_00114",
		line = 1378,
	},
	["0072_00114"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0634", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Please, could you find some way to help her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以，请你们……一定要帮帮礼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以，請你們……一定要幫幫禮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00113",
		linknext = "0072_00115",
		line = 1392,
	},
	["0072_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So she says, with that same unreadable smile on her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无法读出感情的脸上带着微笑，说着和之前某一天同样的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無法讀出感情的臉上帶著微笑，說著和之前某一天同樣的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00114",
		linknext = "0072_00116",
		line = 1402,
	},
	["0072_00116"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0635", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Ah, but that may be asking a lot. We're enemies, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——算就我这么说，应该也很困难吧。毕竟，我们好像是敌对关系的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——算就我這麼說，應該也很困難吧。畢竟，我們好像是敵對關係的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00115",
		linknext = "0072_00117",
		line = 1416,
	},
	["0072_00117"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's true.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00116",
		linknext = "0072_00118",
		line = 1428,
	},
	["0072_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She definitely knows who we really are.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的真面目，她好像早就知道了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的真面目，她好像早就知道了。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00117",
		linknext = "0072_00119",
		line = 1438,
	},
	["0072_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why is she not apprehending us? Is she just sympathizing with Rei's cause, or is there something else?",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此却没有逮捕我们，是因为在意礼前辈，还是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此卻沒有逮捕我們，是因為在意禮前輩，還是——",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00118",
		linknext = "0072_00120",
		line = 1448,
	},
	["0072_00120"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1757", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jun... We have to save Rei. We need to help her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“淳君……要帮帮礼酱才行呢……去帮助她吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「淳君……要幫幫禮醬才行呢……去幫助她吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00119",
		linknext = "0072_00121",
		line = 1462,
	},
	["0072_00121"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“————嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「————嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00120",
		linknext = "0072_00122",
		line = 1474,
	},
	["0072_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels awfully presumptuous for me to say that, after I used and betrayed her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"背叛，伤害，现在才想着帮助——这实在是非常可笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"背叛，傷害，現在才想著幫助——這實在是非常可笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00121",
		linknext = "0072_00123",
		line = 1484,
	},
	["0072_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know that all too well. It's like running someone over then trying to tell them a wheelchair.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这我当然知道。我知道这就像把轮椅卖给自己开车撞的人一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這我當然知道。我知道這就像把輪椅賣給自己開車撞的人一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00122",
