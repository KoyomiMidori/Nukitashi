			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mr. Hitoura said he'd expose everything he'd found out about the illegal sex trade.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“仁浦先生好像把地下风俗的事情全部暴露出来了呢。”",
