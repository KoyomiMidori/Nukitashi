		line = 148,
	},
	["0072_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Look at all these self-proclaimed experts with keyboards who feel like they have to have an opinion about this. Makes me wanna fuckin' puke.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到处都是自称名侦探的人，光是看着就让人反感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到處都是自稱名偵探的人，光是看著就讓人反感。",
