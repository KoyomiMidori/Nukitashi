	["0072_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We've already decided not to hand Fumino over, and after all this, Senator Hitoura has only become more beloved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"决定了绝对不把文乃交出去后，通过这次事件，仁浦先生的地位也越来越牢固。",
					{"rt2"},
				},
			},
			tw = {
				{
					"決定了絕對不把文乃交出去後，通過這次事件，仁浦先生的地位也越來越牢固。",
					{"rt2"},
