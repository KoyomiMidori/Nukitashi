					"「……哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00001",
		linknext = "0072_00003",
		line = 32,
	},
	["0072_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Flicking through my online news aggregator on my tablet, I let out a fittingly disgusted sigh.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在平板上浏览网页的我，忍不住叹了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在平板上瀏覽網頁的我，忍不住嘆了口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00002",
		linknext = "0072_00004",
		line = 42,
	},
	["0072_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Respectable local and national newspapers, clickbait blogs and social media have all been on fire with Seiran Island-related stories since yesterday.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正直的新闻网站、煽动情绪的博客、社交网络，从昨天开始到处都是关于青蓝岛的话题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正直的新聞網站、煽動情緒的博客、社交網路，從昨天開始到處都是關於青藍島的話題。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00003",
		linknext = "0072_00005",
		line = 52,
	},
	["0072_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even the island's main social media site, Fuckbook, is now choked with posts containing rumors and speculation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛的SNS“Hametter”上也都是这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島的SNS「Hametter」上也都是這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00004",
		linknext = "0072_00006",
		line = 62,
	},
	["0072_00006"] = {
