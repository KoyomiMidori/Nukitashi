					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still... Why would he take the 'sunlight is the best disinfectant' approach?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是……为什么要告发呢？”",
