	["0072_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've been thinking it's odd for a long time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我以前就觉得很奇怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我以前就覺得很奇怪。",
