	},
	["0072_00016"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1745", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Is there something weird about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？这很奇怪吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？這很奇怪嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00015",
		linknext = "0072_00017",
		line = 184,
	},
	["0072_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wouldn't quite say it's strange, but doing that's just going to bring the heat down on Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“并不是说奇怪……但是那样做的话，反而会出现责备青蓝岛的人吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「並不是說奇怪……但是那樣做的話，反而會出現責備青藍島的人吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00016",
		linknext = "0072_00018",
		line = 195,
	},
	["0072_00018"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The mainlanders already view this place as some kind of problem child at best. You give 'em this much red meat on a silver platter, and that's gotta be putting the perception of this place in the negatives.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“青蓝岛本来就很容易在本岛上成为问题。如果给他们这种攻击材料，明明也会对支持率产生影响——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「青藍島本來就很容易在本島上成為問題。如果給他們這種攻擊材料，明明也會對支持率產生影響——」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00017",
		linknext = "0072_00019",
		line = 207,
	},
	["0072_00019"] = {
		{"fgact", ch="ヒナミ", id=5, act="移動", x=400, y=0, time=500},
