			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我想问一些关于料理调味的事情……但你好像在忙，我等等再来吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我想問一些關於料理調味的事情……但你好像在忙，我等等再來吧……」",
					{"rt2"},
