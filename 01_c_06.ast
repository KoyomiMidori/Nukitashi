		linkback = "0007_00326",
		linknext = "0007_00328",
		line = 4272,
	},
	["0007_00328"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0202", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí, así es como la llamas tú. Decidí que yo también...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，淳也这么叫，所以我觉得我也可以……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，淳也這麼叫，所以我覺得我也可以……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00327",
		linknext = "0007_00329",
		line = 4286,
	},
	["0007_00329"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00119", file2="asane_01m_00204", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=4, act="浮遊", loop=3, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0307", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Aaah, aaaaah, Asa-chan!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊啊、啊啊啊啊啊、麻沙酱……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
