				{"vo", file="nanase0137", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Eh? Lo sien— Espera, ¿qué le pasa a tu hermana? ¿Por qué le sangra la nariz?”",
