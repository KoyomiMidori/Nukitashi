		linkback = "0007_00342",
		linknext = "0007_00344",
		line = 4516,
	},
	["0007_00344"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No pienses mal. Como mi hermana tuvo una fiebre muy alta y se desmayó, salí a comprar hielo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别误会了。我只是想给想太多而发烧晕倒的妹妹顺便买个冰淇淋而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別誤會了。我只是想給想太多而發燒暈倒的妹妹順便買個冰淇淋而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00343",
		linknext = "0007_00345",
		line = 4528,
	},
	["0007_00345"] = {
		{"text"},
		text = {
