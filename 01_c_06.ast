					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien, ¿para qué me necesitabas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说片桐找我有什么事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說片桐找我有什麼事？」",
					{"rt2"},
