				{"fg", file="asane_01m_00002", file1="asane_01m_00109", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=4, act="浮遊", loop=3, size=12.5, time=100, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Te voy a dar una pata— Espera, ¿Asa-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什——麻沙酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說什——麻沙醬？」",
