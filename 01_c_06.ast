	["0007_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es un tema sensible, así que no sabe cómo responder.",
					{"rt2"},
