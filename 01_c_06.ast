			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Por qué no le das un sorbo, manita?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“妹妹也可以尝一尝哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「妹妹也可以嚐一嚐哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00243",
		linknext = "0007_00245",
		line = 3169,
	},
	["0007_00245"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, ¿tú también viniste, Asa-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦，麻沙酱也在吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦，麻沙醬也在嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00244",
		linknext = "0007_00246",
		line = 3181,
	},
	["0007_00246"] = {
		{"fgact", ch="奈々瀬", id=8, act="移動", x=-400, y=0, time=800},
		{"fg", file="asane_01m_00002", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0289", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“S-Sí, siempre estuve aquí... ¡Solo estaba... escondida tras los tatamis...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“在……一直都在……我只是躲在榻榻米的房间里……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「在……一直都在……我只是躲在榻榻米的房間裡……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00245",
		linknext = "0007_00247",
		line = 3196,
	},
	["0007_00247"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Por qué te escondes en tu propio hogar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你为什么在自己家里还要躲起来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你為什麼在自己家裡還要躲起來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00246",
		linknext = "0007_00248",
		line = 3208,
	},
	["0007_00248"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Katagiri cae tan perfectamente en sus gustos que se mantiene más alejada de lo necesario. Es bastante cobarde, ¿a que no?",
					{"rt2"},
				},
			},
			cn = {
				{
					"似乎是因为太喜欢片桐了，所以无法靠近她。真是胆小的孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"似乎是因為太喜歡片桐了，所以無法靠近她。真是個膽小的孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00247",
		linknext = "0007_00249",
		line = 3218,
	},
	["0007_00249"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0181", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Y bien? ¿Te gusta? Espero que te quede gustando.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么样？味道好吗？希望你能喜欢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼樣？味道好嗎？希望你能喜歡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00248",
		linknext = "0007_00250",
		line = 3232,
	},
	["0007_00250"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00113", file2="asane_01m_00204", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="浮遊", loop=3, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0290", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“E-E-E-E-Está delicioso de verdad y es tan increíblemente delicioso que hasta me da vergüenza llevármelo a la boca jijiji.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“当当当当然好吃这么好吃的给我吃我都觉得不好意思了诶嘿嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「當當當當然好吃這麼好吃的給我吃我都覺得不好意思了欸嘿嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00249",
		linknext = "0007_00251",
		line = 3247,
	},
	["0007_00251"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Me estás asustando, manita!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我妹妹怎么这么恶心啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我妹妹怎麼這麼噁心啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00250",
		linknext = "0007_00252",
		line = 3259,
	},
	["0007_00252"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00103", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="asane_02m_00002", file1="asane_02m_00110", file2="asane_02m_00204", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=3, size=12.5, time=100, ease="easeinout_sine", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0291", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡C-Cállate, manito! Jeje...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“吵、吵死了哥哥……！诶嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「吵、吵死了哥哥……！欸嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00251",
		linknext = "0007_00253",
		line = 3276,
	},
	["0007_00253"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me lanza una sonrisa que me resulta muy desagradable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妹妹色色地笑着，眼角都垂了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妹妹色瞇瞇地笑著，眼角都垂了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00252",
		linknext = "0007_00254",
		line = 3286,
	},
	["0007_00254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con lo increíblemente tímida que suele ser Asa-chan con los demás, esto es bastante raro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对于总是对外人过度警戒的麻沙酱而言，这很少见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對於總是對外人過度警戒的麻沙醬而言，這很少見。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00253",
		linknext = "0007_00255",
		line = 3296,
	},
	["0007_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que ahora le gusta Katagiri.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她似乎很喜欢和片桐在一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她似乎很親片桐。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00254",
		linknext = "0007_00256",
		line = 3306,
	},
	["0007_00256"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es probable... o más bien, casi seguro, que sea por su apariencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能也不仅仅……只是喜欢她的外表吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能也不僅僅……只是喜歡她的外表吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00255",
		linknext = "0007_00257",
		line = 3316,
	},
	["0007_00257"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=8, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0182", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Ustedes solían vivir aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……你们以前也有住过这里对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……你們以前也有住過這裡對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00256",
		linknext = "0007_00258",
		line = 3330,
	},
	["0007_00258"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Katagiri deja de cocinar por un momento para preguntarme eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"片桐一边做饭一边问道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"片桐一邊做飯一邊問道。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00257",
		linknext = "0007_00259",
		line = 3340,
	},
	["0007_00259"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, aunque fue hace bastante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，那是很久以前的事情了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，那是很久以前的事情了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00258",
		linknext = "0007_00260",
		line = 3352,
	},
	["0007_00260"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00117", path=":fg/nanase_02m/", id=8, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="nanase_02m_00006", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=8, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0183", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿En serio? Mmm... ¿Cómo eran ustedes cuando eran niños?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，呼……你们以前是什么样的孩子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，呼……你們以前是什麼樣的孩子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00259",
		linknext = "0007_00261",
		line = 3369,
	},
	["0007_00261"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No teníamos ni un solo amigo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们都没有朋友。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們都沒有朋友。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00260",
		linknext = "0007_00262",
		line = 3381,
	},
	["0007_00262"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0184", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mmm. Pues a Tachibana-kun sí me lo imagino así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是吗，不过，橘君的话可以理解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是嗎，不過，橘君的話可以理解。」",
					{"rt2"},
