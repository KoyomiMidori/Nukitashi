		linkback = "0007_00271",
		linknext = "0007_00273",
		line = 3523,
	},
	["0007_00273"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00102", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0294", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Y pues, la gente... se enteró de eso. Me acosaban constantemente... Desde entonces, me lo he guardado para mí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以，当这事……暴露之后……我在这里、也被人欺负……从那以后，我就一直保密着……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以，當這事……暴露之後……我在這裡、也被人欺負……從那以後，我就一直保密著……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00272",
		linknext = "0007_00274",
		line = 3537,
	},
	["0007_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es sorprendente que se lo diga a alguien más.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我妹妹把这事告诉其他人真的很少见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我妹妹把這事告訴其他人真的很少見。",
					{"rt2"},
				},
			},
		},
