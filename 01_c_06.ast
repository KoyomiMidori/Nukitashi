	["0007_00106"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=8, act="移動", x=200, y=0, time=500},
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", file2="asane_01m_00204", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=500},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0024", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Oigan! ¿Cómo así que ya se van a casa? ¿Qué pasó con hacerlo de manera pura? ¡A ver, que sí pueden usar la goma, pero más vale que estén follando!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂你们！这个时间马上回家是怎么回事啊！做爱呢！戴着套也可以总之给我做爱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂你們！這個時間馬上回家是怎麼回事啊！做愛呢！戴著套也可以總之給我做愛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00105",
		linknext = "0007_00107",
		line = 1359,
	},
	["0007_00107"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="奈々瀬", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0136", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah, esto... Es que me voy con estos hermanos a tener un trío con la brisa del mar. Ajaja, solo es una pequeña salida para variar, ¿sí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊，不，呃……我等等打算和这对兄妹一起吹着海风来一场野战3P呢。啊哈哈〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊，不，呃……我等等打算和這對兄妹一起吹著海風來一場野戰3P呢。啊哈哈〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00106",
		linknext = "0007_00108",
		line = 1374,
	},
	["0007_00108"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00112", file2="asane_01m_00204", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=4, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
