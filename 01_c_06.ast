		linkback = "0007_00265",
		linknext = "0007_00267",
		line = 3447,
	},
	["0007_00267"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan es tan linda que hasta la diosa de la luna se pondría celosa, entiendo que los niños quieran molestarla...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱非常可爱即使是月亮女神也黯然失色为之嫉妒所以被其他小孩欺负这种事也是可以理解的并不奇怪——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬非常可愛即使是月亮女神也黯然失色為之嫉妒所以被其他小孩欺負這種事也是可以理解的並不奇怪——」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00266",
		linknext = "0007_00268",
		line = 3459,
	},
	["0007_00268"] = {
