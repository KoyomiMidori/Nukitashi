	["0007_00105"] = {
		{"fg", file="nanase_01l_00001", file1="nanase_01l_00119", file2="nanase_01l_00202", path=":fg/nanase_01l/", id=8, lv=5, head="nanase_01l", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=8, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
