		{"fg", file="nanase_01m_00006", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0178", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bien, ya iba a preparar el caldo para los fideos soba. ¿Te gusta al estilo Kanto?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，我打算做可以保存的荞麦面汤，关东风格的调味可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，我打算做可以保存的蕎麥麵湯，關東風格的調味可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00237",
		linknext = "0007_00239",
		line = 3096,
	},
	["0007_00239"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, mis padres vivieron en Kanto por mucho tiempo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，我父母在关东待得时间比较长……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，我父母在關東待得時間比較長……」",
					{"rt2"},
				},
			},
