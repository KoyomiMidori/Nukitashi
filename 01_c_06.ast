	},
	["0007_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estaba usando la puerta para hacer flexiones de pared, y ahora estoy haciendo abdominales.",
