				{"vo", file="nanase0133", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lo siento, manita. Voy a tener a tu hermano ocupado un rato.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对不起啊妹妹，我借用了一下你哥哥。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對不起啊妹妹，我借用了一下你哥哥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00097",
		linknext = "0007_00099",
		line = 1247,
	},
	["0007_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pasaron cositas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这次是有原因的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這次是有原因的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00098",
		linknext = "0007_00100",
		line = 1259,
	},
	["0007_00100"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0282", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Waahhh! ¡¿Cómo cuando y qué c-clase de c-c-c-c-cosas?!\n¡¿Has estado follando a mis espaldas?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯吼！为什么为什么为什么啊？难道是在我不知道的时候打了一炮……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯吼！為什麼為什麼為什麼啊？難道是在我不知道的時候成了無套粉……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00099",
		linknext = "0007_00101",
		line = 1272,
	},
	["0007_00101"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No digas tonterías, te lo explicaré luego.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要用那种莫名其妙的单词，我等等跟你说明。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要用那種莫名其妙的單詞，我等等跟你說明。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00100",
		linknext = "0007_00102",
		line = 1284,
	},
	["0007_00102"] = {
		{"fg", file="nanase_02l_00001", file1="nanase_02l_00110", path=":fg/nanase_02l/", id=8, lv=5, head="nanase_02l", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0134", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Esto puede ser un poco repentino, pero ¿te importa si me voy a casa con ustedes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然是个突然的请求，但今天可以让我一起回家吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然是個突然的請求，但今天可以讓我一起回家嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00101",
		linknext = "0007_00103",
		line = 1298,
	},
	["0007_00103"] = {
		{"fgact", ch="麻沙音", id=3, act="浮遊横", loop=4, size=7.5, time=50, ease="easeinout_sine"},
		{"text"},
