		linkback = "0007_00368",
		linknext = "0007_00370",
		line = 4824,
	},
	["0007_00370"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase guarda silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑这么说道，然后闭上了嘴。",
					{"rt2"},
				},
