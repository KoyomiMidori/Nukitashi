		linknext = "0007_00337",
		line = 4398,
	},
	["0007_00337"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi hermana (virgen) está tan feliz y nerviosa que no puede dejar de mirar a todos lados.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知是不是因为太高兴，妹妹（处女）睁大眼睛十分动摇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道是不是因為太高興，妹妹（零經驗）睜大眼睛十分動搖。",
					{"rt2"},
