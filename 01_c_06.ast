		{"fg", file="asane_02l_00001", file1="asane_02l_00113", file2="asane_02l_00204", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=200, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0285", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"非表示", "麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Asane"},
					"“¡¡Si de veras tendremos un trío yo elegiré quién me lo va a hacer primero pero ojo que sí me encantaría darle mi virginidad a Nanase-san porque es mi perra ideal pero no puedo descuidar a mi querido hermanito!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "麻沙音"},
					"“3P的重要性在于决定和哪一个先开始做我是很想把处女献给憧憬的辣妹婊奈奈濑同学但也很难割舍我最喜欢的哥哥！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "麻沙音"},
					"「3P的重要性在於決定和哪一個先開始做我是很想把處女獻給憧憬的辣妹婊奈奈瀨同學但也很難割捨我最喜歡的哥哥！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00112",
		linknext = "0007_00114",
		line = 1471,
	},
	["0007_00114"] = {
