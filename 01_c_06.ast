		linknext = "0007_00173",
		line = 2254,
	},
	["0007_00173"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
