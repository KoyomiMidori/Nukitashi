		linkback = "0007_00364",
		linknext = "0007_00366",
		line = 4773,
	},
	["0007_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así que preferiría no hablar de eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我不想说。”",
					{"rt2"},
				},
			},
			tw = {
				{
