	},
	["0007_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pone su mano sobre la mía y niega con la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱把她的手放在我的手上，摇了摇头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬把她的手放在我的手上，搖了搖頭。",
