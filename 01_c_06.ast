		line = 1311,
	},
	["0007_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Maldita sea, no le subas las esperanzas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂，别让这家伙兴奋啦！”",
					{"rt2"},
				},
			},
			tw = {
