		{"fgact", ch="麻沙音", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0296", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡¿Ngh, Na-Nanase?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“唔咕、奈、奈奈濑……同学……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「唔咕、奈、奈奈瀨……同學……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00281",
		linknext = "0007_00283",
		line = 3650,
	},
	["0007_00283"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00116", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0188", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No, yo lo siento... No sabía que era un tema que te incomodaba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对不起，让你说出这么难说出口的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對不起，讓你說出這麼難說出口的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00282",
		linknext = "0007_00284",
		line = 3664,
	},
	["0007_00284"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0297", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Qué es este aroma maravilloso que llena todo mi ser? Siento como si estuviera en una especie de santuario.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这个充满幸福味道的空间难道就是传说中的圣域吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這個充滿幸福味道的空間難道就是傳說中的聖域嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00283",
		linknext = "0007_00285",
		line = 3676,
	},
	["0007_00285"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00106", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0189", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Eres muy valiente... Me halaga que me cuentes algo tan delicado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那么重要的事情……谢谢你告诉我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那麼重要的事情……謝謝你告訴我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00284",
		linknext = "0007_00286",
		line = 3690,
	},
	["0007_00286"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="asane_01m_00002", file1="asane_01m_00119", file2="asane_01m_00204", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=300, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0298", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Qué demonios, ¿esto es una recompensa de mi diosa? Estoy tan feliz ahora mismo que no me importaría morir asfixiada entre sus pechos. No me arrepiento de nada, incluso me alegro de que me acosaran si fue para llegar a esto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“天啊这就是上帝的奖励吗就这样被欧派憋死了我也不会后悔反而还很庆幸以前被人欺负了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「天啊這就是上帝的獎勵嗎就這樣被乳房悶死了我也不會後悔反而還很慶幸以前被人欺負了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00285",
		linknext = "0007_00287",
		line = 3705,
	},
	["0007_00287"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um, ¿hola...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00286",
		linknext = "0007_00288",
		line = 3717,
	},
	["0007_00288"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0190", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Desde ahora puedes considerarme como tu hermana mayor, \nasí que...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“从今天开始，你也可以当我是亲生姐姐……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「從今天開始，你也可以當我是親生姐姐……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00287",
		linknext = "0007_00289",
		line = 3729,
	},
	["0007_00289"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00112", file2="asane_01m_00204", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=300, y=0},
		{"fgact", ch="麻沙音", id=4, act="浮遊横", loop=3, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
		delay = {
			[6500] = {
				{"fgact", ch="麻沙音", id=4, act="移動", x=0, y=100, time=700, delay2=6500},
				{"fgact", ch="麻沙音", id=4, act="浮遊横", loop=3, size=5, time=125, ease="easeinout_sine", delay2=6500},
				{"fg", mode=-1, id=4, ch="麻沙音", lv=5, time=600, delay2=6500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0299", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡¿Ehhh?! No, ya no puedo más, esto no tiene sentido, estas tetas que tengo delante están llenando al máximo mi medidor de felicidad, ay no que me voy a morir pero yaaaaaaa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊……！？不行这已经超出了大脑理解的能力我眼前的两团丰满让幸福指标已经冲破最大值了麻沙酱已经不行了啊啊啊啊啊啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊……！？不行這已經超出了大腦理解的能力我眼前的兩團豐滿讓幸福指標已經衝破最大值了麻沙醬已經不行了啊啊啊啊啊啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00288",
		linknext = "0007_00290",
		line = 3748,
	},
	["0007_00290"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Um, Asane?! ¡Despierta! ¡No te nos vayas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂麻沙音！？喂！振作点！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂麻沙音！？喂！振作點！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00289",
		linknext = "0007_00291",
		line = 3760,
	},
	["0007_00291"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0191", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mm... ¡¿Manita?! ¡¿Por qué te sangra la nariz?! ¡¿Te abrazé muy fuerte?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶……等等，妹妹！？你为什么流鼻血了？是我抱得太紧吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸……等等，妹妹！？你為什麼流鼻血了？是我抱得太緊嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00290",
		linknext = "0007_00292",
		line = 3776,
	},
	["0007_00292"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Fue eso o que le gustó muchísimo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该说是因为抱太紧而让她太享受吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該說是因為抱太緊而讓她太享受吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00291",
		linknext = "0007_00293",
		line = 3788,
	},
	["0007_00293"] = {
		{"fg", file="asane_02f_00002", file1="asane_02f_00122", file2="asane_02f_00204", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0300", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Qué buenas tetas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“胸部幻影阵……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「胸部幻影陣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00292",
		linknext = "0007_00294",
		line = 3801,
	},
	["0007_00294"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Solo hay dos tetas, Asane! ¡ASANEEEEEE!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“胸部没有变多啊！一直都是两个哦！麻沙音！麻沙音——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「胸部沒有變多啊！一直都是兩個哦！麻沙音！麻沙音——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00293",
		linknext = "0007_00295",
		line = 3813,
	},
	["0007_00295"] = {
