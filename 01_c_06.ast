			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ya, manito, ¿está bien que usemos los nombres?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没事啦哥哥也叫人家名字啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒關係啦哥哥也叫人家名字啦……」",
					{"rt2"},
				},
