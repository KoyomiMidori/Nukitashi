		linkback = "0007_00367",
		linknext = "0007_00369",
		line = 4810,
	},
	["0007_00369"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0215", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya no volveré a hablar del pasado... Lo siento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我不会再谈论过去了……所以，很抱歉。”",
