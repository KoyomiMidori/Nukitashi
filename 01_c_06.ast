					"Evidentemente, Asa-chan se enfermó de la emoción.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是因为发生了太多事情，麻沙酱有些发烧了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是因為發生了太多事情，麻沙醬有些發燒了。",
