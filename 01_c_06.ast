		linkback = "0007_00362",
		linknext = "0007_00364",
		line = 4747,
	},
	["0007_00364"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00115", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0213", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Dijiste que no tenías amigos cuando vivías aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“过去曾经住在这里时……你说过，你没有朋友……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「過去曾經住在這裡時……你說過，你沒有朋友……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00363",
		linknext = "0007_00365",
		line = 4761,
	},
	["0007_00365"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No tengo recuerdos agradables de esa época.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那段时间不是个很好的回忆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那段時間不是個很好的回憶。」",
					{"rt2"},
				},
