			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“E-Esto... E-Es que a mí... me gustan las chicas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呃、呃……我……我喜欢女孩子……”",
					{"rt2"},
				},
			},
			tw = {
