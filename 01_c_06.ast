	},
	["0007_00210"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A ver, esta no es la primera vez que tocas el cuerpo de un hombre. ¿Qué tiene de raro el mío?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这又不是你第一次碰到男人的身体。有什么好稀奇的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這又不是你第一次碰到男人的身體。有什麼好稀奇的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00209",
