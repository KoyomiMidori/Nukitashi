				{"vo", file="nanase0200", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mm. Bueno, está bien así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……呃，不是很好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……呃，不是很好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00321",
		linknext = "0007_00323",
		line = 4205,
	},
	["0007_00323"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Q-Qué, ¿no es agradable?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什、什么嘛，你有哪里不喜欢吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「幹、幹嘛，你有哪裡不滿意嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00322",
		linknext = "0007_00324",
		line = 4217,
	},
	["0007_00324"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00110", path=":fg/asane_02m/", id=4, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0306", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Uwah, manito... ¡Qué sonrojo tan virginal te echaste!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哇哥哥才是在害羞什么啊小处男〜！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哇哥哥才是在害羞什麼啊小處男〜！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00323",
		linknext = "0007_00325",
		line = 4231,
	},
	["0007_00325"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No le hables así a tu hermano...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对哥哥说什么呢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對哥哥說什麼呢你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00324",
		linknext = "0007_00326",
		line = 4243,
	},
	["0007_00326"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0201", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Así es. Aunque sea verdad, hay cosas que no se pueden decir, Asa-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是啊，就算是真的，也有可以说跟不可以说的事情哦，麻沙酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是啊，就算是真的，也有可以說跟不可以說的事情哦，麻沙醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00325",
		linknext = "0007_00327",
		line = 4257,
	},
	["0007_00327"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
