		linkback = "0007_00270",
		linknext = "0007_00272",
		line = 3508,
	},
	["0007_00272"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=8, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0186", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“咦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「咦……？」",
					{"rt2"},
				},
