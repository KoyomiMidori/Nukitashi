					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero... Un hombre y una mujer que no están saliendo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但又不是交往中的男女……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但又不是交往中的男女……」",
