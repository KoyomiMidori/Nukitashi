				{"vo", file="rei0025", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“U-Un trío en la playa... No esperaba menos de Katagiri, nuestra puta más ejemplar. Adelante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在、在沙滩上3P？不愧是我们的模范婊子片桐。请继续保持下去。”",
