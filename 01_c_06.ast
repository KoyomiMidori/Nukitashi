		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0210", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lamento lo de antes, cuando les hice preguntas imprudentes. Espero que no te haya resultado doloroso recordar tantas cosas desagradables.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……刚刚真抱歉，问了很多不合适的问题……希望你们不要因为回想起那些事而难受……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……剛剛真抱歉，問了很多不合適的問題……希望你們不要因為回想起那些事而難受……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00349",
		linknext = "0007_00351",
		line = 4602,
	},
	["0007_00351"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, no, no hiciste nada malo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——不是那样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——不是那樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00350",
		linknext = "0007_00352",
		line = 4614,
	},
	["0007_00352"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Creo que Asa-chan sí quería contarlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是麻沙音自己想说的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是麻沙音自己想說的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00351",
		linknext = "0007_00353",
		line = 4624,
	},
	["0007_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase parece ser el tipo de persona que saca eso a relucir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是因为奈奈濑有着让人想说出来的人格特质吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是因為奈奈瀨有著讓人想說出來的人格特質吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00352",
		linknext = "0007_00354",
		line = 4634,
	},
	["0007_00354"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque sea una gyaru y una puta, trata a una chica menor que ella como si fuera su familia...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是个辣妹婊，但她很有顾家的感觉，对小女孩也温柔……一定是因为这些部分吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是個辣妹婊，但她很有顧家的感覺，對小女孩也溫柔……一定是因為這些部分吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00353",
		linknext = "0007_00355",
		line = 4644,
	},
	["0007_00355"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Debería agradecerte por no sentirte incómoda.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以……谢谢你没有心生厌恶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以……謝謝你沒有心生厭惡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00354",
		linknext = "0007_00356",
		line = 4656,
	},
	["0007_00356"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Significa mucho para mí que no te molestes por cómo es Asane... De verdad, muchísimas gracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有对麻沙音感到厌恶……真的很感谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有對麻沙音感到厭惡……真的很感謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00355",
		linknext = "0007_00357",
		line = 4667,
	},
	["0007_00357"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hago una reverencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我对她深深地低下头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我對她深深地低下頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00356",
		linknext = "0007_00358",
		line = 4677,
	},
	["0007_00358"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0211", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun... Quieres mucho a Asa-chan, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳……你真的很爱惜麻沙酱呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳……你真的很愛惜麻沙醬呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00357",
		linknext = "0007_00359",
		line = 4691,
	},
	["0007_00359"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase se encoge de hombros y sonríe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑耸了耸肩后慢慢笑了笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨聳了聳肩後慢慢笑了笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00358",
		linknext = "0007_00360",
		line = 4701,
	},
	["0007_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por supuesto que la quiero. Es mi única hermanita.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是当然的，她可是我唯一的妹妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是當然的，她可是我唯一的妹妹。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00359",
		linknext = "0007_00361",
		line = 4711,
	},
	["0007_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y la persona más importante para mí en este momento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱现在也是我心里最重要的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬現在也是我心裡最重要的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00360",
		linknext = "0007_00362",
		line = 4721,
	},
	["0007_00362"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0212", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya me hablaste de tu hermana, pero... ¿qué hay de ti?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“麻沙酱的事情我是听说了……那你呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「麻沙醬的事情我是聽說了……那你呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00361",
		linknext = "0007_00363",
		line = 4735,
	},
	["0007_00363"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
