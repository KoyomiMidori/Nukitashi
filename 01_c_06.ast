		},
		linkback = "0007_00329",
		linknext = "0007_00331",
		line = 4315,
	},
	["0007_00331"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00113", path=":fg/asane_02m/", id=4, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0308", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Vamos, eso es absurdo, es solo que usar ese tipo de apodo se consideraría cariñoso según la lógica de una persona normal, y pensar que tú me llamarías así... Ay es que soy tan... jejejejeje...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么可能会不好不非常好只不过能用爱称这种通常用于亲密关系之间的称呼来叫在下真的是唔呼呼呼呼呼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼可能會不好不非常好只不過能用愛稱這種通常用於親密關係之間的稱呼來叫在下真的是唔呼呼呼呼呼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00330",
		linknext = "0007_00332",
		line = 4329,
	},
	["0007_00332"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
