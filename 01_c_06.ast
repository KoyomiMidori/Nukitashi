		linknext = "0007_00264",
		line = 3407,
	},
	["0007_00264"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0185", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pero ¿por qué tu hermana? Es muy linda y tiene bastante carisma.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“妹妹是为什么呢？明明这么可爱、这么讨喜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「妹妹是為什麼呢？明明這麼可愛、這麼討喜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00263",
		linknext = "0007_00265",
		line = 3421,
	},
	["0007_00265"] = {
		{"bgm", stop=1},
