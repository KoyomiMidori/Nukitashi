					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ya basta, manito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……哥哥，可以了。”",
					{"rt2"},
				},
			},
			tw = {
