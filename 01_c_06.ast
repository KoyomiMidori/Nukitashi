		linkback = "0007_00227",
		linknext = "0007_00229",
		line = 2937,
	},
	["0007_00229"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=8, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0176", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah, sí. Quería saber qué opinas de la comida de hoy. Tu manita me dijo que te lo preguntara, así que aquí estoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊啊，对了……我有关于料理调味的问题。妹妹跟我说‘问我哥哥’，所以我就来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊啊，對了……我有關於料理調味的問題。妹妹跟我說『問我哥哥』，所以我就來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00228",
		linknext = "0007_00230",
		line = 2951,
	},
	["0007_00230"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está bien, ya voy a la cocina.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦，那我很快就会去厨房。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦，那我很快就會去廚房。」",
					{"rt2"},
				},
			},
		},
