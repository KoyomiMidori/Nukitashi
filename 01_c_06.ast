	},
	["0007_00371"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Que no intente averiguarlo de manera insensible es sorprendentemente maduro para alguien como ella, y más teniendo en cuenta su aspecto provocativo.",
					{"rt2"},
				},
			},
