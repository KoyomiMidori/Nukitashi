		{"bgm", file="bgm03", vol=100},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="奈々瀬", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
