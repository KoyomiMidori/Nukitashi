			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“咳咳……但是你训练得比我想象的要认真呢。说实话有点意外。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「咳咳……但是你訓練得比我想像的還要認真呢。說實話有點意外。」",
