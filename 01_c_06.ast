					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A mí me parece que la virgen es otra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你更像个处男好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你更像個處男好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00331",
		linknext = "0007_00333",
		line = 4341,
	},
	["0007_00333"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0204", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Q-Qué pasa? No te gustó, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎、怎么了……？果然不喜欢吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎、怎麼了……？果然不喜歡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00332",
		linknext = "0007_00334",
		line = 4355,
	},
	["0007_00334"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00112", file2="asane_01m_00204", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0309", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nooo, no es eso. De hecho... me hiciste sentir m-muy feliz...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不，不会不喜欢，而是……太开心了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不，不會不喜歡，而是……太開心了……」",
					{"rt2"},
				},
