	["0007_00367"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aparto la mirada y Nanase se pone nerviosa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我别过视线这么说时，奈奈濑慌张地眨了眨眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我別過視線這麼說時，奈奈瀨慌張地眨了眨眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00366",
		linknext = "0007_00368",
		line = 4796,
	},
	["0007_00368"] = {
		{"text"},
		delay = {
