				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Katagiri sigue tocando mi cuerpo y asiento con algo de pena.",
					{"rt2"},
				},
			},
			cn = {
				{
					"片桐摸着我的身体，同时似乎有些羞涩地点着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"片桐摸著我的身體，同時似乎有些羞澀地點著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00207",
		linknext = "0007_00209",
		line = 2706,
	},
	["0007_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es una respuesta bastante inocente.",
					{"rt2"},
