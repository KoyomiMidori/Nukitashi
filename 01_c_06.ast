		{"fg", file="nanase_01m_00006", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_01m_00002", file1="asane_01m_00102", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ex0001", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"奈々瀬＆麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬＆麻沙音", "Nanase y Asane"},
					"“¡Buen provecho!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬＆麻沙音", "奈奈濑＆麻沙音"},
					"“开动了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬＆麻沙音", "奈奈瀨＆麻沙音"},
					"「開動了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00295",
		linknext = "0007_00297",
		line = 3874,
	},
	["0007_00297"] = {
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por fin podemos cenar, a mi hermana ya no le gotea la nariz como un grifo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妹妹的鼻血也停了，所以我们开始吃晚饭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妹妹的鼻血也停了，所以我們開始吃晚飯。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00296",
		linknext = "0007_00298",
		line = 3885,
	},
	["0007_00298"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como Katagiri no tiene comida en casa, cenará con nosotros esta noche. Asa-chan está más que encantada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天自己家里没东西吃的片桐也一起跟我们吃饭，麻沙酱很开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天自己家裡沒東西吃的片桐也一起跟我們吃飯，麻沙醬很開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00297",
		linknext = "0007_00299",
		line = 3895,
	},
	["0007_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿A qué te refieres con que no tienes comida en casa? ¿Tus padres no te preparan nada?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不过你说家里没东西吃……你父母没煮吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不過你說家裡沒東西吃……你父母沒煮嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00298",
		linknext = "0007_00300",
		line = 3906,
	},
	["0007_00300"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0193", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No. Ambos trabajan y están tan ocupados que apenas pasan tiempo en casa. Eso significa que cocinar es mi responsabilidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是啊。我父母都忙着工作，所以总是不在家。因此家务都是我在做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是啊。我父母都忙著工作，所以總是不在家。因此家事都是我在做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00299",
		linknext = "0007_00301",
		line = 3920,
	},
	["0007_00301"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya veo. Con razón aprendiste a cocinar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，所以才学会了烹饪……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，所以才學會了烹飪……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00300",
		linknext = "0007_00302",
		line = 3932,
	},
	["0007_00302"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa parecía ser la razón por la que se le daba tan bien cocinar, aun cuando es una gyaru.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是辣妹却会做饭的理由，原来是这样啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是辣妹卻會做飯的理由，原來是這樣啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00301",
		linknext = "0007_00303",
		line = 3942,
	},
	["0007_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como era de esperarse, la comida es deliciosa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"味道还是一样美味。",
					{"rt2"},
				},
			},
			tw = {
				{
					"味道還是一樣美味。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00302",
		linknext = "0007_00304",
		line = 3952,
	},
	["0007_00304"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0194", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oye... ¿Tachibana-kun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呐……橘君？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我說……橘君？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00303",
		linknext = "0007_00305",
		line = 3966,
	},
	["0007_00305"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", path=":fg/asane_01m/", id=4, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0303", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"淳之介＆麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介＆麻沙音", "Junnosuke y Asane"},
					"“¿Sí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介＆麻沙音"},
					"“嗯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介＆麻沙音"},
					"「嗯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00304",
		linknext = "0007_00306",
		line = 3980,
	},
	["0007_00306"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00109", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0195", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah, cierto... Los dos son Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊，对了……你们俩都叫橘呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊，對了……你們倆都叫橘呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00305",
		linknext = "0007_00307",
		line = 3995,
	},
	["0007_00307"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Supongo que será más confuso así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在家里可能有点难区分吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在家裡可能有點難區分吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00306",
		linknext = "0007_00308",
		line = 4007,
	},
	["0007_00308"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="nanase_02m_00006", file1="nanase_02m_00120", file2="nanase_02m_00204", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0196", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Cierto. Um, esto... ¿Qué tal si de ahora en adelante usamos nuestros nombres?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是啊。呃，那么……从现在开始，我叫你们的名字吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是啊。呃，那麼……從現在開始，我叫你們的名字吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00307",
		linknext = "0007_00309",
		line = 4023,
	},
	["0007_00309"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说的也是。也行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說的也是。也行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00308",
		linknext = "0007_00310",
		line = 4035,
	},
	["0007_00310"] = {
		{"fg", file="nanase_01m_00006", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="nanase_01m_00006", file1="nanase_01m_00122", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0197", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Eh? Sí, está bien... Umm... ¿Jun...nosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶？嗯，那……淳、之介？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸？嗯，那……淳、之介？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00309",
		linknext = "0007_00311",
		line = 4052,
	},
	["0007_00311"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Por qué te da pena?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在害羞什么啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你在害羞什麼啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00310",
		linknext = "0007_00312",
		line = 4064,
	},
	["0007_00312"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00121", file2="nanase_02m_00204", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0198", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“A-Ah, por favor... Junnosuke suena un poco complicado, ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“吵、吵死了……比较绕口啦，淳之介这个名字。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「吵、吵死了……比較繞口啦，淳之介這個名字。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00311",
		linknext = "0007_00313",
		line = 4078,
	},
	["0007_00313"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No sé, para mí es muy fácil decirlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“淳之介这名字非常好唸好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「淳之介這名字非常好唸好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00312",
		linknext = "0007_00314",
		line = 4090,
	},
	["0007_00314"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00120", file2="nanase_02m_00204", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0199", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pues para ti sí. Te diré Jun. Tú también puedes llamarme Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那我叫你淳好了。还有以后你也要叫我奈奈濑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那我叫你淳好了。還有以後你也要叫我奈奈瀨。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00313",
		linknext = "0007_00315",
		line = 4104,
	},
	["0007_00315"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file2="jun_01f_00204", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? Pero está bien... Solo hay una Katagiri aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃，应该不需要吧……这里叫片桐的也只有一个人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃，應該不需要吧……這裡叫片桐的也只有一個人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00314",
		linknext = "0007_00316",
		line = 4116,
	},
	["0007_00316"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00110", path=":fg/asane_02m/", id=4, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
