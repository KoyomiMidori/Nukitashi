	["0007_00174"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00114", file2="nanase_02m_00204", path=":fg/nanase_02m/", id=8, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
