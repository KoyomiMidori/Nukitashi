		linkback = "0108_00316",
		linknext = "0108_00318",
		line = 4056,
	},
	["0108_00318"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00115", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's bowing her head yet again for some reason.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知为什么，吹子再次低下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知為什麼，吹子再次低下了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00317",
		linknext = "0108_00319",
		line = 4069,
	},
	["0108_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I swear, I've been getting apologized to for no reason today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我今天总是因为自己不明白的事情而被道歉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我今天總是因為自己不明白的事情而被道歉。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00318",
		linknext = "0108_00320",
		line = 4079,
	},
	["0108_00320"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Does she think of me as a dangerous entity or something?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……难道她认为我们是危险的存在吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……難道她認為我們是危險的存在嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00319",
		linknext = "0108_00321",
		line = 4089,
	},
	["0108_00321"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure the islanders probably think of a group trying to destroy the law as a complete bunch of psychos...",
					{"rt2"},
				},
			},
			cn = {
				{
					"在岛上的人看来，说要破坏变态条例完全是“反社会人格”吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"在島上的人看來，說要破壞變態條例完全是「反社會人格」吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00320",
		linknext = "0108_00322",
		line = 4099,
	},
	["0108_00322"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know we're kind of a dangerous organization, but we're a surprisingly cheerful lot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……虽然是很危险的组织，但很不可思议地玩得很开心呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……雖然是很危險的組織，但很不可思議地玩得很開心呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00321",
		linknext = "0108_00323",
		line = 4111,
	},
	["0108_00323"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Our members are all nice people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可能是因为成员都是心地善良的人吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可能是因為成員都是心地善良的人吧。」",
					{"rt2"},
				},
			},
