	},
	["0108_00137"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1103", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I can tell from watching you these last few days that you've been striving beyond the SS training. Surely you must have an objective in mind?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“只要看着你几天，就能知道你除了FS的训练之外也在努力锻炼。那也是……为了达成目的对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「只要看著你幾天，就能知道你除了FS的訓練之外也在努力鍛煉。那也是……為了達成目的對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00136",
		linknext = "0108_00138",
		line = 1782,
	},
	["0108_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00137",
		linknext = "0108_00139",
		line = 1794,
	},
	["0108_00139"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1104", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I despise foolish weaklings, but I do not intend to give up on weaklings who strive to push themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我……虽然讨厌软弱愚蠢的人，但我并不想抛弃在软弱中挣扎的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我……雖然討厭軟弱愚蠢的人，但我並不想拋棄在軟弱中掙扎的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00138",
		linknext = "0108_00140",
		line = 1808,
	},
	["0108_00140"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1105", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You... have certainly been working hard. Push yourself a little more, and you'll be a good soldier. Here... take this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你……嗯，你很努力。只要再努力一点，就能成为一个好士兵。所以……这个给你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你……嗯，你很努力。只要再努力一點，就能成為一個好士兵。所以……這個給你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00139",
		linknext = "0108_00141",
		line = 1823,
	},
	["0108_00141"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She pulls out something from her waist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长从腰间取出了什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員長從腰間取出了什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00140",
		linknext = "0108_00142",
		line = 1834,
	},
	["0108_00142"] = {
		{"se", id=1, loop=0, file="se_b056"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“An SS handgun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是……FS的手枪吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是……FS的手槍嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00141",
		linknext = "0108_00143",
		line = 1847,
	},
	["0108_00143"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1106", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“By all rights, you shouldn't be allowed to handle one of these below the level of OSS guard, but unfortunately, this is the only spare I have to give you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“本来这种型号是SHO警卫以上的水平才能被允许持有的，但不巧现在剩余的只有我的这把旧枪而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「本來這種型號是SHO警衛以上的水平才能被允許持有的，但不巧現在剩餘的只有我的這把舊槍而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00142",
		linknext = "0108_00144",
		line = 1861,
	},
	["0108_00144"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you sure it's okay for me to have it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要给我……真的可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要給我……真的可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00143",
		linknext = "0108_00145",
		line = 1873,
	},
	["0108_00145"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1107", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The only ones allowed to fire them outside of emergency situations are myself, Ikuko, and Miss Touka. You must not use it at any time besides when I order you to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“紧急时刻以外可以开枪的只有我和郁子，还有桐香大人。没有我的命令你绝对不能使用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「緊急時刻以外可以開槍的只有我和郁子，還有桐香大人。沒有我的命令你絕對不能使用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00144",
		linknext = "0108_00146",
		line = 1887,
	},
	["0108_00146"] = {
		{"se", id=1, loop=0, file="se_b056", vol=40},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I grasp it tightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我紧紧握住枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我緊緊握住槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00145",
		linknext = "0108_00147",
		line = 1898,
	},
	["0108_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a little big, but because I've been practicing with one for a while, I know how to hold it perfectly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然尺寸有点大，但不知是不是因为用惯了，我拿得很顺手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然尺寸有點大，但不知是不是因為用慣了，我拿得很順手。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00146",
		linknext = "0108_00148",
		line = 1908,
	},
	["0108_00148"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00119", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1108", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You can have it, if you don't mind it being the one I shot you with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果你不在意这是之前射你的枪的话，就收下吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果你不在意這是之前射你的槍的話，就收下吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00147",
		linknext = "0108_00149",
		line = 1923,
	},
	["0108_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, thank you... Disciplinary Committee President.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好的，谢谢你……风纪委员长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好的，謝謝你……風紀委員長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00148",
		linknext = "0108_00150",
		line = 1935,
	},
	["0108_00150"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1109", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Just use my name. I'm your commanding officer. Calling me by my title during battle will be unwieldy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……叫名字也没关系。我是你的直属长官。在战斗中叫职称也很累吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……叫名字也沒關係。我是你的直屬長官。在戰鬥中叫職稱也很累吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00149",
		linknext = "0108_00151",
		line = 1950,
	},
	["0108_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Understood.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好的，我知道了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好的，我知道了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00150",
		linknext = "0108_00152",
		line = 1962,
	},
	["0108_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My very own gun...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是我的手枪……",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是我的手槍……",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00151",
		linknext = "0108_00153",
		line = 1972,
	},
	["0108_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Given to me as an SS trainee...",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为FS的，我的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為FS的，我的——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00152",
		linknext = "0108_00154",
		line = 1982,
	},
	["0108_00154"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0615", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Rei here doesn't usually give anyone her own gun. At least, I've never seen her do it. She must really like you ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“礼酱她啊，很少把自己的枪给别人哦〜我从来没见过……所以，她应该特别喜欢亲爱的呢♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「禮醬她啊，很少把自己的槍給別人哦〜我從來沒見過……所以，她應該特別喜歡親愛的呢♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00153",
		linknext = "0108_00155",
		line = 1997,
	},
	["0108_00155"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1110", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“D-Don't tell him that, Ikuko! More importantly, we have a demonstration on the mainland to attend after this! Hurry up and get ready!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别、别说些多余的事情郁子！话说你等一下还要和我去本岛进行演习不是吗！快去准备！”",
