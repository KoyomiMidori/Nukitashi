	["0108_00423"] = {
		{"se", id=2, loop=0, file="se_a033", vol=30},
		{"fg", file="asane_02f_00003", file1="asane_02f_00109", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
