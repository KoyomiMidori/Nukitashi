				{
					name = {"麻沙音", "Asane"},
					"“Yeah, they don't know the culprits! But it seems like they knocked him out cold and took him away... All the OSS and SS are being mobilized!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯，不清楚对方是谁……！但是似乎是在没有意识的状态下被带走的……SHO和FS好像要总动员了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯，不清楚對方是誰……！但是似乎是在沒有意識的狀態下被帶走的……SHO和FS好像要總動員了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00363",
		linknext = "0108_00365",
		line = 4622,
	},
	["0108_00365"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I didn't hear a word about that from them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我这边……没有收到联络是吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"我這邊……沒有收到聯絡是嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00364",
		linknext = "0108_00366",
		line = 4634,
	},
	["0108_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Guess they figured it was too big a mission for a rookie.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是他们判断对新手来说负担过重了吧，没办法——",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是他們判斷對新手來說負擔過重了吧，沒辦法——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00365",
		linknext = "0108_00367",
		line = 4644,
	},
	["0108_00367"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if the OSS and SS on patrol rush off now, they should be able to resolve it... No, wait.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过听起来只要让巡逻中的SHO和FS赶过去应该就能立即解决吧——不对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過聽起來只要讓巡邏中的SHO和FS趕過去應該就能立即解決吧——不對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00366",
		linknext = "0108_00368",
		line = 4656,
	},
	["0108_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think back to the end of my training a little while ago.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来，刚才训练的时候……",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，剛才訓練的時候……",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00367",
		linknext = "0108_00369",
		line = 4666,
	},
	["0108_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There was mention of a demonstration on the mainland, which the top brass would have to leave the island for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我好像有听到因为有演习，所以最有实力的那群人都要离开岛上——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我好像有聽到因為有演習，所以最有實力的那群人都要離開島上——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00368",
		linknext = "0108_00370",
		line = 4676,
	},
	["0108_00370"] = {
		{"fg", file="asane_01f_00003", file1="asane_01f_00122", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1592", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It's strange, though. The OSS and SS's movements are blunted, and they're barely making headway. HQ's chain of command seems to be in disarray, and their subordinates don't seem to be following...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是很奇怪……现场的SHO和FS的动作很迟钝，完全没有动作……总部的命令系统混乱，末端机能也没有在运行……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是很奇怪……現場的SHO和FS的動作很遲鈍，完全沒有動作……總部的命令系統混亂，末端機能也沒有在運行……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00369",
		linknext = "0108_00371",
		line = 4689,
	},
	["0108_00371"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel a strange unease from what she says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙音说的话让我很在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙音說的話讓我很在意。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00370",
		linknext = "0108_00372",
		line = 4699,
	},
	["0108_00372"] = {
		{"fg", file="asane_02f_00003", file1="asane_02f_00122", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1593", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I know he's the enemy's big cheese, but what should we do, Bro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对象是敌人的老大，该怎么办哥哥……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對象是敵人的老大，該怎麼辦哥哥……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00371",
		linknext = "0108_00373",
		line = 4712,
	},
	["0108_00373"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Something's going on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有事情发生了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有事情發生了。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00372",
		linknext = "0108_00374",
		line = 4724,
	},
	["0108_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the enemy's commander has gone missing, it's likely that some other kind of disturbance is going on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是否该认为敌人的大将消失了，还是要考虑发生更严重的混乱的可能性——",
					{"rt2"},
				},
			},
			tw = {
				{
					"是否該認為敵人的大將消失了，還是要考慮發生更嚴重的混亂的可能性——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00373",
		linknext = "0108_00375",
		line = 4734,
	},
	["0108_00375"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right, it's settled. We'll rescue him. His life is clearly in danger. Enemy or not, we have to retrieve him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不，要去救他。绑架是人命关天的大事，这事不分敌我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不，要去救他。綁架是人命關天的大事，這事不分敵我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00374",
		linknext = "0108_00376",
		line = 4746,
	},
	["0108_00376"] = {
		{"fg", file="asane_01f_00003", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1594", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“R-Roger that! We'll be waiting for your orders, so we'll stand by until you're ready!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“了、了解……！那我来引导，等我准备好……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「了、了解……！那我來引導，等我準備好……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00375",
		linknext = "0108_00377",
		line = 4759,
	},
	["0108_00377"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a163"},
		{"fg", mode=-1, id=30, ch="麻沙音", lv=5},
		{"ex", time=1000, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, Fukiko. I don't think I can make night patrol today. Did you hear any of that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“吹子，不好意思，今天恐怕不能巡逻了……你听到了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「吹子，不好意思，今天恐怕不能巡邏了……你聽到了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00376",
		linknext = "0108_00378",
		line = 4775,
	},
	["0108_00378"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She turns to face me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回过神时，吹子已经回过头来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回過神時，吹子已經回過頭來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00377",
		linknext = "0108_00379",
		line = 4786,
	},
	["0108_00379"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks tense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她神色紧张。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她神色緊張。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00378",
		linknext = "0108_00380",
		line = 4796,
	},
	["0108_00380"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm not sure what made her so anxious, but she looks pale.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道是什么给她造成了这么大的压力……她脸色铁青地盯着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道是什麼給她造成了這麼大的壓力……她臉色鐵青地盯著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00379",
		linknext = "0108_00381",
		line = 4806,
	},
	["0108_00381"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm going to go rescue Senator Hitoura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我现在要去救仁浦先生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我現在要去救仁浦先生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00380",
		linknext = "0108_00382",
		line = 4818,
	},
	["0108_00382"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't mean to impose on you, but—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我并没有想要强迫你的意思，但——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我並沒有想要強迫你的意思，但——」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00381",
		linknext = "0108_00383",
		line = 4830,
	},
	["0108_00383"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0544", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I will join you. I will aid you with what little ability I have...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“我陪您去……我也会尽微力相助……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「我陪您去……我也會盡微力相助……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00382",
		linknext = "0108_00384",
		line = 4845,
	},
	["0108_00384"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unusually, she responds immediately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她罕见地马上回答。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她罕見地馬上回答。",
