			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Trying to get the attention of prickly ol' Darling!? Gosh, Rei, you're such a sneaky little thing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“想要用傲娇吸引亲爱的是吗——！？礼酱真狡猾，耍小聪明——”",
