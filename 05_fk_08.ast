	["0108_00125"] = {
		{"cgact", file="cgact", id=1, act="stopact"},
		{"bg", id=1, file="bg17_2_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00113", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1098", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Good grief. Your saucy mouth hasn't changed a bit since you joined. Though at least everything else has improved...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真是的，你从刚入队起嘴巴就一直学不乖……其他部份明明都变好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真是的，你從剛入隊起嘴巴就一直學不乖……其他部份明明都變好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00124",
		linknext = "0108_00126",
		line = 1608,
	},
	["0108_00126"] = {
