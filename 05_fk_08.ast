		{"bg", id=18, file="ncg06_l_00001", x=0, y=0, path=":cg/ncg06_l/", ev=1, time=300, lv=5, ax=1290, ay=730, bx=-490, by=-280},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0709", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, Tachibana. What brings you here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“啊，前辈……怎么会来这里？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「啊，前輩……怎麼會來這裡？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00008",
		linknext = "0108_00010",
		line = 144,
	},
	["0108_00010"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My written report. The disciplinary committee president ordered me to submit one for the weekend.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是报告书。因为风纪委员长命令我把休息日的事情写进去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是報告書。因為風紀委員長命令我把休息日的事情寫進去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00009",
		linknext = "0108_00011",
		line = 156,
	},
	["0108_00011"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0710", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, I see. So you didn't come to see me. What a shame.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哦，原来如此……你不是来见我的啊，有点寂寞呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哦，原來如此……你不是來見我的啊，有點寂寞呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00010",
		linknext = "0108_00012",
		line = 168,
	},
	["0108_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have no idea how serious she is, and try to not show any expression as I hand it over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道她的真心话到底是什么，但我还是尽量面不改色地把东西交了上去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道她的真心話到底是什麼，但我還是盡量面不改色地把東西交了上去。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00011",
		linknext = "0108_00013",
		line = 178,
	},
	["0108_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She remains an enemy, irrespective of what position I may end up holding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……不管站在什么样的立场上，她都是敌人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……不管站在什麼樣的立場上，她都是敵人。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00012",
		linknext = "0108_00014",
		line = 188,
	},
	["0108_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to be conscious to not allow myself to be flustered by her again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要有坚定的意识，不能像以前那样胆怯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要有堅定的意識，不能像以前那樣膽怯。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00013",
		linknext = "0108_00015",
		line = 198,
	},
	["0108_00015"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She scans it for a few seconds before giving it a stamp of approval and putting it in the 'Checked ",
					{"gaiji", text="①"},
					"' outbox.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随后她看了几秒报告，就印上‘检查完毕",
					{"gaiji", text="①"},
					"’的印章装进箱子里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨後她看了幾秒報告，就印上『檢查完畢",
					{"gaiji", text="①"},
					"』的印章裝進箱子裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00014",
		linknext = "0108_00016",
		line = 209,
	},
	["0108_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At least read the damn thing properly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……好好读一下啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……好好讀一下啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00015",
		linknext = "0108_00017",
		line = 219,
	},
	["0108_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was practically in tears when the disciplinary committee president was telling me, “This isn't a light novel to be written in first person! You can't write for peanuts, but your ability to write trash fiction is unparalleled!”",
					{"rt2"},
				},
			},
			cn = {
				{
					"到底把被风纪委员长骂说“这是以第一人称视角写成的哎呀哎呀类轻小说吗！明明不会写文章却蛮会自慰的嘛！？”结果真的哭出来的我的辛苦当成什么了呢……",
					{"rt2"},
				},
			},
			tw = {
				{
					"到底把被風紀委員長罵說「這是以第一人稱視角寫成的哎呀哎呀類輕小說嗎！明明不會寫文章卻蠻會自慰的嘛！？」結果真的哭出來的我的辛苦當成什麼了呢……",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00016",
		linknext = "0108_00018",
		line = 229,
	},
	["0108_00018"] = {
		{"se", id=0, loop=0, file="se_a147"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0711", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm impressed you could help tourists the first time you've been stationed out there. I have no problem about your approach, either. That's very good.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“第一次出动就去帮助游客，真厉害呢。而且这个方法也没有问题。很好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「第一次出動就去幫助遊客，真厲害呢。而且這個方法也沒有問題。很好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00017",
		linknext = "0108_00019",
		line = 242,
	},
	["0108_00019"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
