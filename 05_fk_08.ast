					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I have first aid equipment, so I can help. The NLNS is prepared for shit like this. So hurry it up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“放心吧，我身上有治疗工具。NLNS什么道具都有。快点。”",
