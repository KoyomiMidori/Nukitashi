		{"bg", id=1, file="bg05_3l_00000", x=0, y=-250, path=":bg/", sync=0, time=300, lv=5, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=12.5, time=100, ease="easeinout_sine", lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
