	["0108_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It says that the motive behind this racket is the decline in sex trade on the mainland, due to the existence of Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"报告中写道他们之所以犯下这样的罪行，是因为青蓝岛导致了本岛风俗行业的衰退。",
					{"rt2"},
				},
			},
			tw = {
				{
					"報告中寫道他們之所以犯下這樣的罪行，是因為青藍島導致了本島風俗行業的衰退。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00068",
		linknext = "0108_00070",
		line = 846,
	},
	["0108_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It makes sense that there'd be a fall in the sex trade with an island that has free-for-all sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，因为这个无拘无束的做爱海岛，日本的风俗业有缩小的倾向。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，因為這個無拘無束的做愛海島，日本的風俗業有縮小的傾向。",
					{"rt2"},
				},
			},
		},
