		linkback = "0108_00322",
		linknext = "0108_00324",
		line = 4123,
	},
	["0108_00324"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0538", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Is that... so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“是……是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「是……是嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00323",
		linknext = "0108_00325",
		line = 4137,
	},
	["0108_00325"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We've got Nanase, who just looks like a slut, our senior Wata, who just looks like a loli, and Hotori, who can just disappear from your mind's eye when you least expect it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有怎么看都是婊子的奈奈濑，怎么看都是萝莉的渡酱前辈，还有不知道在哪里的畔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有怎麼看都是婊子的奈奈瀨，怎麼看都是蘿莉的渡醬前輩，還有不知道在哪裡的畔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00324",
		linknext = "0108_00326",
		line = 4149,
	},
	["0108_00326"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then there's my sister Asane. She's got a foul mouth and an especially rotten mind, and I love her to bits. She's my pride and joy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“此外还有一个嘴巴很坏但脑袋却更坏的亲爱妹妹麻沙音，最后是不屈不挠的高傲的我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「此外還有一個嘴巴很壞但腦袋卻更壞的親愛妹妹麻沙音，最後是不屈不撓的高傲的我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00325",
		linknext = "0108_00327",
		line = 4161,
	},
	["0108_00327"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And all of us congregate in our secret base every day and spend our time yakking about who knows what.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这些奇怪的人聚在一起，在秘密基地里谈天说地过着每一天。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這些奇怪的人聚在一起，在秘密基地裡談天說地過著每一天。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00326",
		linknext = "0108_00328",
		line = 4173,
	},
	["0108_00328"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0539", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“That sounds... like a lot of fun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“那……看起来、很有趣、的样子呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「那……看起來、很有趣、的樣子呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00327",
		linknext = "0108_00329",
		line = 4188,
	},
	["0108_00329"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... I dare say, it's not so bad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……实际上也很不错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……實際上也很不錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00328",
		linknext = "0108_00330",
		line = 4200,
	},
	["0108_00330"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was just the two of us siblings running around before, but now we have actual friends. It's nice to think about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……对于一直以来都是兄妹二人一起逃跑的我来说，有同伴确实不错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……對於一直以來都是兄妹二人一起逃跑的我來說，有同伴確實不錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00329",
		linknext = "0108_00331",
		line = 4212,
	},
	["0108_00331"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0540", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I'm sure it is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“……嗯，一定……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……嗯，一定……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00330",
		linknext = "0108_00332",
		line = 4227,
	},
	["0108_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her voice fades off into nothingness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“是那样的吧”这句话，她没有完整说出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「是那樣的吧」這句話，她沒有完整說出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00331",
		linknext = "0108_00333",
		line = 4237,
	},
	["0108_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I turn around and see she's smiling slightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回头一看，吹子微微眯起了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回頭一看，吹子微微瞇起了眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00332",
		linknext = "0108_00334",
		line = 4247,
	},
	["0108_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's thinking of elsewhere and staring off into nothingness with that smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像在凝视远方的某个、不存在于这里的东西一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像在凝視遠方的某個、不存在於這裡的東西一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00333",
		linknext = "0108_00335",
		line = 4257,
	},
	["0108_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I see... She's all alone too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对了——她平常也都是一个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對了——她平常也都是一個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00334",
		linknext = "0108_00336",
		line = 4267,
	},
	["0108_00336"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If she has no living relatives and no servants where she lives, then that's easy to assume.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无依无靠，如果说家里没有佣人的话，吹子应该总是独自一人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無依無靠，如果說家裡沒有傭人的話，吹子應該總是獨自一人。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00335",
		linknext = "0108_00337",
		line = 4277,
	},
	["0108_00337"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if she has friends, she probably can't tell anyone that she's doing this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算有朋友，也没办法对他人说自己在做这种事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算有朋友，也沒辦法對他人說自己在做這種事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00336",
		linknext = "0108_00338",
		line = 4287,
	},
	["0108_00338"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's out here, all on her own.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那她果然是孤独的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那她果然是孤獨的。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00337",
		linknext = "0108_00339",
		line = 4297,
	},
	["0108_00339"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Would you like to join the NLNS too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……如果可以的话，吹子也加入NLNS吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……如果可以的話，吹子也加入NLNS吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00338",
		linknext = "0108_00340",
		line = 4309,
	},
	["0108_00340"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00109", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0541", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“诶……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「欸……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00339",
		linknext = "0108_00341",
		line = 4324,
	},
	["0108_00341"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's an organization founded on the principle of using advanced techniques to escape from sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们也是一个基于逃避性爱的高尚理念所创立的健全组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們也是一個基於逃避性愛的高尚理念所創立的健全組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00340",
		linknext = "0108_00342",
		line = 4336,
	},
	["0108_00342"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We have a secret base under the school, and we relax there during recess and eat treats.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在学校的地底下有一个专用的秘密基地，休息时间可以吃点心也可以放放松。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在學校的地底下有一個專用的秘密基地，休息時間可以吃點心也可以放放鬆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00341",
		linknext = "0108_00343",
		line = 4348,
	},
	["0108_00343"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're an eccentric bunch, but we have our fun. And I think Wata in particular would get on well with you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“人嘛，虽然都是些奇怪的家伙，但也很有趣。渡酱的话和吹子一定很快就会成为好朋友。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「人嘛，雖然都是些奇怪的傢伙，但也很有趣。渡醬的話和吹子一定很快就會成為好朋友。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00342",
		linknext = "0108_00344",
		line = 4360,
	},
	["0108_00344"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How about it? Don't you think it sounds fun?”",
