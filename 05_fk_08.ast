					"這裡大概已經被遺忘了，應該會就這樣腐朽下去吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00561",
		linknext = "0108_00563",
		line = 7417,
	},
	["0108_00563"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You seem to know a lot, Fukiko. Do you come here often?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“吹子，你知道得真多啊……你经常来这里吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「吹子，你知道得真多啊……你經常來這裡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00562",
		linknext = "0108_00564",
		line = 7429,
	},
	["0108_00564"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0550", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Yes... My home is nearby, so... I've been chased here often...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“是的……离家也近……被追的时候，经常……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「是的……離家也近……被追的時候，經常……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00563",
		linknext = "0108_00565",
		line = 7444,
	},
	["0108_00565"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She walks in front of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边回答，一边从我眼前走过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊回答，一邊從我眼前走過。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00564",
		linknext = "0108_00566",
		line = 7454,
	},
	["0108_00566"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I see blood on her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的血也在这时滴了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的血也在這時滴了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00565",
		linknext = "0108_00567",
		line = 7464,
	},
	["0108_00567"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, did you get hurt? You're bleeding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂……你伤到哪儿了？在出血哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂……你傷到哪了？在出血哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00566",
		linknext = "0108_00568",
		line = 7476,
	},
	["0108_00568"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		delay = {
			[500] = {
				{"se", id=0, loop=0, file="se_a094", delay2=500},
				{"fg", ch="文乃", id=7, mode=2, path=":fg/fumino_02m/", file="fumino_02m_00001", size="m", file1="fumino_02m_00113", head="fumino_02m", lv=5},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0551", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Huh? So it seems... One of the bullets from the machine gun...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“咦……？好像是呢……刚才那支轻机关枪的子弹，大概有一颗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「咦……？好像是呢……剛才那支輕機關槍的子彈，大概有一顆……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00567",
		linknext = "0108_00569",
		line = 7492,
	},
	["0108_00569"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then I have to stop the bleeding! Where's the wound? I'll tend to it, so show me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那要赶快止血才行吧……！在哪里？给我看看，我帮你治疗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那要趕快止血才行吧……！在哪裡？給我看看，我幫你治療。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00568",
		linknext = "0108_00570",
		line = 7504,
	},
	["0108_00570"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00111", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=2, x=0, y=0},
		{"text"},
		text = {
