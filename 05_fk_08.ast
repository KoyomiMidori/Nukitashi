		{"fg", file="jun_01f_00000", file1="jun_01f_00101", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's unusual for a B-level student to still be around this late. Did you have club activities that ran overtime?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个时间还有B等部的孩子在真是稀奇啊。是社团活动进行到很晚吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個時間還有B等部的孩子在真是稀奇啊。是社團活動進行到很晚嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00197",
