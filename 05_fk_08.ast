		{"fg", file="rei_01m_00001", file1="rei_01m_00103", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1101", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I'm telling you, no! I am simply demonstrating respect for how he trains beyond what is mandated of him here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我就说不是！我只是想说这家伙除了训练之外还会自主训练，所以稍微称赞他一下也行……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我就說不是！我只是想說這傢伙除了訓練之外還會自主訓練，所以稍微稱讚他一下也行……！」",
					{"rt2"},
				},
			},
		},
