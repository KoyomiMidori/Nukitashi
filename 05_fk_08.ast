	["0108_00130"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
