			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah, well... it won't show up in your muscles straight away, but training will show in your improved movements comparatively quickly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
