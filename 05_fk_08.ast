	},
	["0108_00385"] = {
		{"se", id=0, loop=0, file="se_b045"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I put on my combat goggles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我点了点头，戴上了战斗用的护目镜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我點了點頭，戴上了戰鬥用的護目鏡。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00384",
		linknext = "0108_00386",
		line = 4866,
	},
