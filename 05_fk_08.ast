	["0108_00396"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fgact", id=7, ch="文乃", act="stopact"},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=100},
		{"cgact", file="cgact", id=1, act="stopact", lv=5},
		{"bg", id=1, file="bg05_3_00000", x=0, y=0, path=":bg/", sync=0, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=12, file="system_base0000", x=-5, y=-5, path=":cg/system_base/", lv=5, bx=800, by=450},
		{"bg", id=13, file="system_sonar_00000", x=-660, y=38, lv=5, path=":bg/", sync=0, clip="5,91,290,814", ax=145, ay=493, bx=655, by=-43},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"cgact", file="cgact", id=13, act="汎用アクション", rotate=360, time=3000, loop=-1, ease="none", lv=5},
		{"se", id=3, loop=1, file="se_d018", vol=30},
		{"se", id=0, loop=0, file="se_a012"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's not a soul on the beach at this time of night.",
					{"rt2"},
				},
			},
			cn = {
				{
					"夜晚的海滩上一个人都没有。",
					{"rt2"},
				},
			},
			tw = {
				{
					"夜晚的海灘上一個人都沒有。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00395",
		linknext = "0108_00397",
		line = 5051,
	},
	["0108_00397"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's uncharacteristically quiet for Seiran Island, which is nothing like this during the day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"寂静得与不夜岛——青蓝岛不相称。",
					{"rt2"},
				},
			},
			tw = {
				{
					"寂靜得與不夜島——青藍島不相稱。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00396",
		linknext = "0108_00398",
		line = 5061,
	},
	["0108_00398"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Something's not right. Asane, what's the sitrep on Hitoura?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——很奇怪。麻沙音，仁浦先生那边怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——很奇怪。麻沙音，仁浦先生那邊怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00397",
		linknext = "0108_00399",
		line = 5073,
	},
	["0108_00399"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00104", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1597", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“They're coming down the hill. Distance from beach, approximately 1.7 km. Engagement in approximately 4 minutes, 20 seconds.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“正从山岳往下前进。离海滩距离1.7公里。约4分20秒后接触。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「正從山岳往下前進。離海灘距離1.7公里。約4分20秒後接觸。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00398",
		linknext = "0108_00400",
		line = 5086,
	},
	["0108_00400"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They'll be here soon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"马上就要来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"馬上就要來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00399",
		linknext = "0108_00401",
		line = 5096,
	},
	["0108_00401"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm just glad nobody's around. Wouldn't want to stir up a big fight with tourists everywhere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为想避开游客战斗，所以这里没人正合我意，但是……",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為想避開遊客戰鬥，所以這裡沒人正合我意，但是……",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00400",
		linknext = "0108_00402",
		line = 5106,
	},
	["0108_00402"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
