			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe, you get the knack for doing this clerical work when you've been doing it for a while. Speed reading is a part of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，这个工作只要做久了，就能掌握熟练完成事务工作的诀窍。速读也是其中一环。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，這個工作只要做久了，就能掌握熟練完成事務工作的訣竅。速讀也是其中一環。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00020",
		linknext = "0108_00022",
		line = 277,
	},
	["0108_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She read my mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她说得好像读懂了我的心一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她說得好像讀懂了我的心一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00021",
		linknext = "0108_00023",
		line = 287,
	},
	["0108_00023"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0713", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Apparently the ability to speed read is intrinsic to humans. I've heard that you lose it by being trained to read each word one by one in class.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“而且速读本来就是人类拥有的能力哦？我听说过会失去这个能力是因为上课时被训练要仔细阅读每一行文字造成的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「而且速讀本來就是人類擁有的能力哦？我聽說過會失去這個能力是因為上課時被訓練要仔細閱讀每一行文字造成的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00022",
		linknext = "0108_00024",
		line = 299,
	},
	["0108_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see. But you haven't lost it. That's impressive.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……但是学生会长没有失去是吗？真是优秀呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……但是學生會長沒有失去是嗎？真是優秀呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00023",
		linknext = "0108_00025",
		line = 311,
	},
	["0108_00025"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0714", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That's because I hardly went to school when I was little. I didn't receive such training.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“应该说我小时候几乎不上学，所以才没有机会接受训练吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「應該說我小時候幾乎不上學，所以才沒有機會接受訓練吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00024",
		linknext = "0108_00026",
		line = 323,
	},
	["0108_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00025",
		linknext = "0108_00027",
		line = 335,
	},
	["0108_00027"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0715", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It's not really that interesting. Well, let's see... how about some tea?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然是个无聊的话题……对了，要喝红茶吗？毕竟机会难得。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然是個無聊的話題……對了，要喝紅茶嗎？畢竟機會難得。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00026",
		linknext = "0108_00028",
		line = 347,
	},
	["0108_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What about your work? You seem really busy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“工作没关系吗？明明看起来很忙……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「工作沒關係嗎？明明看起來很忙……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00027",
		linknext = "0108_00029",
		line = 358,
	},
	["0108_00029"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0716", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I was just thinking of taking a break. Please, sit over there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我正想休息呢，请坐那边。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我正想休息呢，請坐那邊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00028",
		linknext = "0108_00030",
		line = 370,
	},
	["0108_00030"] = {
		{"se", id=0, loop=0, file="se_a146"},
		{"se", id=1, loop=0, file="se_a003"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She rubs her shoulders and stands up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她拍拍自己的肩膀表现出累了的感觉，然后站了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她拍拍自己的肩膀表現出累了的感覺，然後站了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00029",
		linknext = "0108_00031",
		line = 389,
	},
	["0108_00031"] = {
		{"se", id=0, loop=0, file="se_a147"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Meanwhile, I sit down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而我则坐了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而我則坐了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00030",
		linknext = "0108_00032",
		line = 401,
	},
	["0108_00032"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've eked out a little bit of her past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长的过去——确实有些在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長的過去——確實有些在意。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00031",
		linknext = "0108_00033",
		line = 412,
	},
	["0108_00033"] = {
		{"se", id=1, stop=1, time=1000},
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's delicious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真好喝啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真好喝啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00032",
		linknext = "0108_00034",
		line = 426,
	},
	["0108_00034"] = {
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0717", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Thank you. Milk suits that tea. Help yourself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“谢谢。和牛奶也很合呢，可以的话请用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「謝謝。和牛奶也很合呢，可以的話請用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00033",
		linknext = "0108_00035",
		line = 440,
	},
	["0108_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, what did you mean when you said you didn't go to school?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么……没有去学校是怎么回事呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼……沒有去學校是怎麼回事呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00034",
		linknext = "0108_00036",
		line = 452,
	},
	["0108_00036"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0718", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It's more accurate to say that I didn't have the opportunity to go to school. Our family was in a lot of debt.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“准确地说，是没时间去学校。因为我家有庞大的债务。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「準確地說，是沒時間去學校。因為我家有龐大的債務。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00035",
		linknext = "0108_00037",
		line = 466,
	},
	["0108_00037"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Debt?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……债务？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……債務？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00036",
		linknext = "0108_00038",
		line = 478,
	},
	["0108_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could have sworn someone like her would have had a high-class upbringing...",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷泉院这看似浮夸的名字，让我以为她是哪里的千金大小姐——",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷泉院這看似浮誇的名字，讓我以為她是哪裡的千金大小姐——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00037",
		linknext = "0108_00039",
		line = 488,
	},
	["0108_00039"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0719", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In the past ours was a renowned and respected family, but the enterprises failed with the bursting of the economic bubble, and its worth declined. Eventually, by my parents' generation, they even lost their home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“听说以前好像小有名气，但上一代因为泡沫经济破裂而事业失败，从那时开始就一直没落。最后在我父母这辈终于连家都没了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「聽說以前好像小有名氣，但上一代因為泡沫經濟破裂而事業失敗，從那時開始就一直沒落。最後在我父母這輩終於連家都沒了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00038",
		linknext = "0108_00040",
		line = 502,
	},
	["0108_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She anticipates my thoughts and continues explaining.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像读懂了我的想法似的，她又抢先说了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像讀懂了我的想法似的，她又搶先說了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00039",
		linknext = "0108_00041",
		line = 512,
	},
	["0108_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her story is so unbecoming of the student council president that it even lessens her creepiness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她的故事跟学生会长给我的感觉非常不相称，甚至让我忘了这份被看透内心的厌恶感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她的故事跟學生會長給我的感覺非常不相稱，甚至讓我忘了這份被看透內心的厭惡感。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00040",
		linknext = "0108_00042",
		line = 522,
	},
	["0108_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you were still obliged to take compulsory education, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即便如此，也有义务教育不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即便如此，也有義務教育不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00041",
		linknext = "0108_00043",
		line = 534,
	},
	["0108_00043"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0720", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Unfortunately not. Our family's debt was so great that we couldn't even make ends meet for daily necessities. So us sisters were all forced into service.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“很遗憾，我家的债务金额很大，没办法过上普通的生活。所以我们姐妹一起被送去奉公（帮佣）了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「很遺憾，我家的債務金額很大，沒辦法過上普通的生活。所以我們姐妹一起被送去奉公（幫傭）了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00042",
		linknext = "0108_00044",
		line = 548,
	},
	["0108_00044"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0721", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Did you know there's a famous service industry family in Kyushu that trains servants? Its name is Sakimori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你知道吗？在九州有个培训奉公的著名奉公一族，名叫‘防人’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你知道嗎？在九州有個培訓奉公的著名奉公一族，名叫『防人』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00043",
		linknext = "0108_00045",
		line = 562,
	},
	["0108_00045"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nope, I've never heard of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……我没听过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……我沒聽過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00044",
		linknext = "0108_00046",
		line = 574,
	},
	["0108_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She puts on her usual subtle smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的脸上浮现出与平时相同的浅笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的臉上浮現出與平時相同的淺笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00045",
		linknext = "0108_00047",
		line = 584,
	},
	["0108_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't sense any lying from her expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那个表情，我看不出说谎的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從那個表情，我看不出說謊的感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00046",
		linknext = "0108_00048",
		line = 594,
	},
	["0108_00048"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0722", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Alas, I was a failure as a servant. A complete failure at both cooking and cleaning. Just as I was about to pushed into prostitution, I was saved by this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“可是，作为奉公人的我也是个吊车尾。做饭也好打扫也好，都干得很糟糕。就在我即将沦落为妓女的时候——这个岛拯救了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「可是，作為奉公人的我也是個吊車尾。做飯也好打掃也好，都幹得很糟糕。就在我即將淪落為妓女的時候——這個島拯救了我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00047",
		linknext = "0108_00049",
		line = 608,
	},
	["0108_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's telling the truth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——她说的是真的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——她說的是真的。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00048",
		linknext = "0108_00050",
		line = 618,
	},
	["0108_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But why?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么，为什么……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼，為什麼……？",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00049",
		linknext = "0108_00051",
		line = 628,
	},
	["0108_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why is she telling me this?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么要对我说这些话——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼要對我說這些話——？",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00050",
		linknext = "0108_00052",
		line = 638,
	},
	["0108_00052"] = {
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0723", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe... that's obvious, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，那种事……不是理所当然的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，那種事……不是理所當然的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00051",
		linknext = "0108_00053",
		line = 654,
	},
	["0108_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She sips her tea gracefully and beams a beautiful smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用优雅的动作喝着红茶，太过美丽的脸露出喜色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用優雅的動作喝著紅茶，太過美麗的臉露出喜色。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00052",
		linknext = "0108_00054",
		line = 664,
	},
	["0108_00054"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0724", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm interested in you... Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我对你很有兴趣哦……前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我對你很有興趣哦……前輩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00053",
		linknext = "0108_00055",
		line = 678,
	},
	["0108_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her puppet-like smile is inhuman.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像是没有血肉的玩偶般的笑容——",
					{"rt2"},
				},
			},
			tw = {
				{
					"像是沒有血肉的玩偶般的笑容——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00054",
		linknext = "0108_00056",
		line = 688,
	},
	["0108_00056"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0725", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now, take this. You've completed your first duty, so you are now officially a member of the SS. Which grants you the right to read this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“来，前辈，请看这个……成功完成第一次任务之后，你也是正式的FS成员了，所以你有权阅读。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「來，前輩，請看這個……成功完成第一次任務之後，你也是正式的FS成員了，所以你有權閱讀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00055",
		linknext = "0108_00057",
		line = 704,
	},
	["0108_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's this...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00056",
		linknext = "0108_00058",
		line = 716,
	},
	["0108_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hands me a stack of documents.",
					{"rt2"},
				},
			},
			cn = {
				{
					"纸张资料被递了过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"紙張資料被遞了過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00057",
		linknext = "0108_00059",
		line = 726,
	},
	["0108_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Written on it is the title: “Seiran Island Illegal Sex Industry: Results of Investigation, Appendix III (CONFIDENTIAL)”.",
					{"rt2"},
				},
			},
			cn = {
				{
					"封面上写着《关于地下风俗的青蓝岛调查资料Ⅲ（秘）》。",
					{"rt2"},
				},
			},
			tw = {
				{
					"封面上寫著《關於地下風俗的青藍島調查資料Ⅲ（秘）》。",
					{"rt2"},
