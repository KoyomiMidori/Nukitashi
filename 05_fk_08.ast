	["0108_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS is my enemy. They're incompatible with me on a grand scale.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……FS是敌人。这些人的核心部份和我互不相容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……FS是敵人。這些人的核心部份和我互不相容。",
