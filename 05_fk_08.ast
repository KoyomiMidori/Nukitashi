	},
	["0108_00241"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00101", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2128", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hmm, I see. The OSS investigation made it seem that way too, but I didn't know any details.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，这样啊……既然是SHO的调查，应该就是这样吧……你没有得到更详细的情报对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，這樣啊……既然是SHO的調查，應該就是這樣吧……你沒有得到更詳細的情報對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00240",
		linknext = "0108_00242",
		line = 3153,
	},
	["0108_00242"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, and on another note, I've finally been equipped with a handgun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，不过虽然没有得到详细情报——但我总算得到了手枪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，不過雖然沒有得到詳細情報——但我總算得到了手槍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00241",
		linknext = "0108_00243",
		line = 3165,
	},
	["0108_00243"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00109", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2129", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Handgun? You mean the sort the SS carry around?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“手枪……是FS随身携带的那个？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「手槍……是FS隨身攜帶的那個？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00242",
		linknext = "0108_00244",
		line = 3178,
	},
	["0108_00244"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've finally been more or less officially recognized as part of the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看来我也多少算是被认可为FS的一员了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看來我也多少算是被認可為FS的一員了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00243",
		linknext = "0108_00245",
		line = 3190,
	},
	["0108_00245"] = {
		{"fg", file="nanase_02f_00001", file1="nanase_02f_00110", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2130", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I see. And I bet you're grinning from ear to ear about that now, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样啊……所以你才会高兴到笑呵呵的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣啊……所以你才會高興到笑呵呵的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00244",
		linknext = "0108_00246",
		line = 3203,
	},
	["0108_00246"] = {
		{"se", id=1, loop=0, file="se_b056", vol=50},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm carrying it right now! Shit, I feel like such a badass... Now this is what I call a weapon!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在我也拿着哦！好帅啊，武器果然就该是这种的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在我也拿著哦！好帥啊，武器果然就該是這種的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00245",
		linknext = "0108_00247",
		line = 3216,
	},
	["0108_00247"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00110", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2131", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hmm... Well, as long as you're happy, I'm not gonna complain. Even if you end up being a real SS member.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……你高兴的话我也没意见。……就那样成为FS成员也行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……你高興的話我也沒意見。……就那樣成為FS成員也行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00246",
		linknext = "0108_00248",
		line = 3229,
	},
	["0108_00248"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Perish the thought. This is just me being undercover.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么可能。这只是我暂时的身份。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼可能。這只是我暫時的身份。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00247",
		linknext = "0108_00249",
		line = 3241,
	},
	["0108_00249"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My allegiance is to the NLNS. I'm going to protect you all and help crush the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的本分是NLNS。我要保护你们，并且一起毁掉变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的本分是NLNS。我要保護你們，並且一起毀掉變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00248",
		linknext = "0108_00250",
		line = 3253,
	},
	["0108_00250"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00101", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2132", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, you are the leader, I suppose. The decision's all in your hands. Laters.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……嗯，反正我们的队长是你，所以可以自由决定。那先这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……嗯，反正我們的隊長是你，所以可以自由決定。那先這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00249",
		linknext = "0108_00251",
		line = 3266,
	},
	["0108_00251"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a163"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seemingly implying something with that comment, she ends the transmission.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑意味深长地说完后，切断了通讯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨意味深長地說完後，切斷了通訊。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00250",
		linknext = "0108_00252",
		line = 3278,
	},
	["0108_00252"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She doesn't seriously think I'm gonna sell out the NLNS, does she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……难道是认为我会背叛NLNS吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……難道是認為我會背叛NLNS嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00251",
		linknext = "0108_00253",
		line = 3290,
	},
	["0108_00253"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, we've known each other for quite a while. She knows I'd never do that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，我和奈奈濑已经在一起很长时间了，她肯定懂我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，我和奈奈瀨已經在一起很長時間了，她肯定懂我。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00252",
		linknext = "0108_00254",
		line = 3300,
	},
	["0108_00254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's probably lumped everything together when she says I can do whatever, if I think it's okay.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的意思应该是只要是我经过思考后做出的决定，就没有问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的意思應該是只要是我經過思考後做出的決定，就沒有問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00253",
		linknext = "0108_00255",
		line = 3310,
	},
	["0108_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As my long-time comrade, that is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们已经合作很久了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們已經合作很久了。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00254",
		linknext = "0108_00256",
		line = 3320,
	},
	["0108_00256"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do I really want to do...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想做的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想做的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00255",
		linknext = "0108_00257",
		line = 3332,
	},
	["0108_00257"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Right now, crushing the perverted sex law is what I want most of all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然不会是摧毁变态条例以外的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然不會是摧毀變態條例以外的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00256",
		linknext = "0108_00258",
		line = 3342,
	},
	["0108_00258"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I desire nothing more than to see its utter destruction.",
					{"rt2"},
				},
			},
			cn = {
				{
					"除了摧毁条例之外，我不存在其他的夙愿——",
					{"rt2"},
				},
			},
			tw = {
				{
					"除了摧毀條例之外，我不存在其他的夙願——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00257",
		linknext = "0108_00259",
		line = 3352,
	},
	["0108_00259"] = {
		{"se", id=0, loop=0, file="se_a018"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mhm. Hey, Fukiko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——嗯，哟，吹子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——嗯，喲，吹子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00258",
		linknext = "0108_00260",
		line = 3365,
	},
	["0108_00260"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My thought process is interrupted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我停止思考。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我停止思考。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00259",
		linknext = "0108_00261",
		line = 3375,
	},
	["0108_00261"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I cheerfully raise my right hand to acknowledge the person I'm waiting for.",
					{"rt2"},
				},
			},
