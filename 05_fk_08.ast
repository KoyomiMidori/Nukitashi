	["0108_00061"] = {
		{"bgm", file="bgm14", vol=100},
		{"se", id=0, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My curiosity getting the better of me, I flick through the stack of documents.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我忍不住掀开了资料。",
					{"rt2"},
