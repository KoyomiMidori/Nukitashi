		{"bg", id=1, file="bg05_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Excuse me! I'm Tachibana Junnosuke from the SS, Minotsuki Academy! I've been sent here on emergency deployment!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不好意思！我是水乃月学园的FS橘淳之介！因为收到紧急出动通知而前来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不好意思！我是水乃月學園的FS橘淳之介！因為收到緊急出動通知而前來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00410",
		linknext = "0108_00412",
		line = 5231,
	},
	["0108_00412"] = {
