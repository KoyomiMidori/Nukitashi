		{"bg", id=1, file="bg15_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"se", id=1, loop=0, file="se_a004"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I leave the student council room and quickly head out into the corridor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"告别学生会室后，我快步走在走廊上。",
