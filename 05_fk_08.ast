	},
	["0108_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I grit my teeth and refuse to scream.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但为了不发出惨叫，我咬紧牙关。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但為了不發出慘叫，我咬緊牙關。",
