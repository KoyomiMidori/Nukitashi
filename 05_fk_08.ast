					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've heard the governor's been kidnapped! There's a chance they intend to take him off the island via the beach!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好像是县知事被绑架了，而且可能从这片沙滩上被小船带走……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好像是縣知事被綁架了，而且可能從這片沙灘上被小船帶走……！」",
					{"rt2"},
				},
			},
		},
