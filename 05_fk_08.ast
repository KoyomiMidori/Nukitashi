ast = {
	["0108_00001"] = {
		{"fg", mode=-1, id=30},
		{"savetitle", text="鎧袖一触", ja="鎧袖一触", en="Child's Play", cn="吹灰之力", tw="吹灰之力"},
		{"eval", exp="g.05_fk_08=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg15_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"bgm", file="bgm02", vol=100},
		{"se", id=0, loop=0, file="se_a003"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The next Monday, I went to the student council room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"星期一。放学后我去了学生会室。",
					{"rt2"},
				},
			},
			tw = {
				{
					"星期一。放學後我去了學生會室。",
					{"rt2"},
				},
			},
		},
		linknext = "0108_00002",
		line = 20,
	},
	["0108_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently, I won't get paid for working on the weekend unless I apply for overtime.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使在休息日出勤，除非申请补休，否则就不能休假的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使在休息日出勤，除非申請補休，否則就不能休假的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00001",
		linknext = "0108_00003",
		line = 30,
	},
	["0108_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For a new recruit like me who's only doing training, they won't be giving me time off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"特别是在新兵的时期只有满满的特训，根本没有休息的时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"特別是在新兵的時期只有滿滿的特訓，根本沒有休息的時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00002",
		linknext = "0108_00004",
		line = 40,
	},
	["0108_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On the other hand, once you become part of the SS proper, you get full social services.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但相对的如果成为真正的FS，福利待遇会很完备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但相對的如果成為真正的FS，福利待遇會很完備。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00003",
		linknext = "0108_00005",
		line = 50,
	},
	["0108_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I digress. At any rate, I have training again today, but before that, I have to submit a written report for Sunday, as ordered by the disciplinary committee president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回归正题。总之今天也要训练，但在那之前风纪委员长要我交出星期天的报告书。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回歸正題。總之今天也要訓練，但在那之前風紀委員長要我交出星期天的報告書。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00004",
		linknext = "0108_00006",
		line = 60,
	},
	["0108_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hadn't even written a single word, so I received quite a scolding from her. She was practically shouting at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"报告书什么的一个字也没写过的我，被风纪委员长一边教导（虽然有一半时间在破口大骂）一边写了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"報告書什麼的一個字也沒寫過的我，被風紀委員長一邊教導（雖然有一半時間在破口大罵）一邊寫了出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00005",
		linknext = "0108_00007",
		line = 70,
	},
	["0108_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I somehow managed to end up writing 1200 words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最后总算完成了一份1200字的报告。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最後總算完成了一份1200字的報告。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00006",
		linknext = "0108_00008",
		line = 80,
	},
	["0108_00008"] = {
