					name = {"非表示", "吹子"},
					"“……也是呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……也是呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00282",
