		line = 766,
	},
	["0108_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't speed read the way the president can, but I scour over it as fast as I can.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不能像学生会长那样速读，但还是尽量快速阅读。",
					{"rt2"},
				},
			},
			tw = {
