		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg09_3_00000", x=0, y=0, path=":bg/", sync=0, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=12, file="system_base0000", x=-5, y=-5, path=":cg/system_base/", lv=5, bx=800, by=450},
		{"bg", id=13, file="system_sonar_00000", x=0, y=0, lv=5, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
