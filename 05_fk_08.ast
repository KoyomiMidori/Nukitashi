		{"cgact", file="cgact", id=1, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=5},
		{"fg", file="asane_01f_00003", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"bg", id=13, file="system_sonar_00000", x=-660, y=38, lv=5, path=":bg/", sync=0, clip="5,91,290,814", ax=145, ay=493, bx=655, by=-43},
		{"cgact", file="cgact", id=13, act="汎用アクション", rotate=360, time=3000, loop=-1, ease="none", lv=5},
		{"bgm", file="bgm12", vol=100},
		{"se", id=0, loop=0, file="se_a023"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1595", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Senator Hitoura, our target, has been abducted by a group of individuals, and is presumed unconscious. Currently tracking the vehicle he's being transported in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“据我推测，仁浦先生是被数名犯人捆绑后昏迷过去的。我正在追踪载着仁浦先生的车辆。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「據我推測，仁浦先生是被數名犯人捆綁後昏迷過去的。我正在追踪載著仁浦先生的車輛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00385",
		linknext = "0108_00387",
		line = 4921,
	},
	["0108_00387"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Any predictions on how they plan to make it off the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“打算就那样带走吗……能预测离岛的手段吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「打算就那樣帶走嗎……能預測離島的手段嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00386",
		linknext = "0108_00388",
		line = 4933,
	},
	["0108_00388"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1596", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“They're heading for the beach, not the main port. Most likely they intend to leave via a smaller boat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“要去的地方不是港口，而是海滩……说不定是打算开小型船只逃出去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「要去的地方不是港口，而是海灘……說不定是打算開小型船隻逃出去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00387",
		linknext = "0108_00389",
		line = 4945,
	},
	["0108_00389"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quick getaway, huh. Makes sense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"打算乘坐速度快的小型船逃出去吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"打算乘坐速度快的小型船逃出去嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00388",
		linknext = "0108_00390",
		line = 4955,
	},
	["0108_00390"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, they'll probably get held up at the sea gate, since the OSS has to monitor everyone who enters and leaves the island, so there shouldn't be a problem there. But...",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，那应该会被卡在SHO的入岛审查所的海门，所以应该没问题——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，那應該會被卡在SHO的入島審查所的海門，所以應該沒問題——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00389",
		linknext = "0108_00391",
		line = 4965,
	},
	["0108_00391"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If these fuckers think they can get away with this shit in my own backyard, they've got another thing coming!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不管怎么样，居然在我的地盘里为所欲为。我要教训你们……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不管怎麼樣，居然在我的地盤裡為所欲為。我要教訓你們……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00390",
		linknext = "0108_00392",
		line = 4977,
	},
	["0108_00392"] = {
		{"se", id=0, loop=0, file="se_a023"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", mwframe="mwframe", sync=0, time=400, mode=3, x=-200, y=0},
