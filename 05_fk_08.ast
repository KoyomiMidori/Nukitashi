				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well... you've finally reached a point where you'd be useful in combat. I thought it was worth expressing that judgment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……你终于也达到可以在战斗中派上用场的水平了。这种程度的评价还是能给你的……”",
					{"rt2"},
				},
