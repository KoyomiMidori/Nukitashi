	},
	["0108_00284"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She agreed with me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"得到认同了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"得到認同了。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00283",
		linknext = "0108_00285",
		line = 3655,
	},
	["0108_00285"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shouldn't she have been like, 'Is that so', or something more along the lines of a question...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"平常不都是说“是吗”吗……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"平常不都是說「是嗎」嗎……？",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00284",
		linknext = "0108_00286",
		line = 3665,
	},
	["0108_00286"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's wrong? Did something happen? Tell me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……怎么了吗？有什么事就告诉我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……怎麼了嗎？有什麼事就告訴我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00285",
		linknext = "0108_00287",
		line = 3677,
	},
	["0108_00287"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can actually help if something's troubling you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我还算蛮有行动能力的，有困难我会帮助你的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我還算蠻有行動能力的，有困難我會幫助你的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00286",
		linknext = "0108_00288",
		line = 3689,
	},
	["0108_00288"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", file2="fumino_01m_00204", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0531", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I'm terribly sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“……对不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……對不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00287",
		linknext = "0108_00289",
		line = 3703,
	},
	["0108_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She mutters an apology.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被小小声道歉了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被小小聲道歉了。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00288",
		linknext = "0108_00290",
		line = 3713,
	},
	["0108_00290"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess she doesn't think me to be reliable enough for that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……原来我不可靠到不值得求助吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……原來我不可靠到不值得求助嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00289",
		linknext = "0108_00291",
		line = 3723,
	},
	["0108_00291"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And here I thought we'd made progress...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还以为自己渐渐跟她好起来了呢……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還以為自己漸漸跟她好起來了呢……",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00290",
		linknext = "0108_00292",
		line = 3733,
	},
	["0108_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But dealing with people will never be so straightforward.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，看来没这么顺利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，看來沒這麼順利。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00291",
		linknext = "0108_00293",
		line = 3743,
	},
	["0108_00293"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure I'll be able to understand her if we spend more time together.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果多花点时间，一定能了解她的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果多花點時間，一定能了解她的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00292",
		linknext = "0108_00294",
		line = 3753,
	},
	["0108_00294"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just don't push it. Don't force it. Let it happen naturally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要有耐心，淳之介。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要有耐心，淳之介。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00293",
		linknext = "0108_00295",
		line = 3763,
	},
	["0108_00295"] = {
		{"se", id=0, loop=0, file="se_a018"},
		{"se", id=1, loop=0, file="se_a205"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, I've been overly engrossed in the SS training of late, and I feel like I'm losing sight of my original objective. It's food for thought.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过……我最近太热衷于FS的训练，有时会忘记初心，这需要反省。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過……我最近太熱衷於FS的訓練，有時會忘記初心，這需要反省。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00294",
		linknext = "0108_00296",
		line = 3777,
	},
	["0108_00296"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I even had my team members worried on the phone earlier.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚才我还在电话里被队员担心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剛才我還在電話裡被隊員擔心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00295",
		linknext = "0108_00297",
		line = 3789,
	},
	["0108_00297"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0532", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“…………？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「…………？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00296",
		linknext = "0108_00298",
		line = 3804,
	},
	["0108_00298"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, right. I guess I haven't told you about my team, the NLNS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……啊。这么说来还没详细说起NLNS的事情啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……啊。這麼說來還沒詳細說起NLNS的事情啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00297",
		linknext = "0108_00299",
		line = 3816,
	},
	["0108_00299"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Basically, it's the organization I helped create.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我组织了名为NLNS的队伍。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我組織了名為NLNS的隊伍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00298",
		linknext = "0108_00300",
		line = 3828,
	},
	["0108_00300"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The OSS refer to us as the 'anti-copulation front.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是SHO所说的反交尾势力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是SHO所說的反交尾勢力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00299",
		linknext = "0108_00301",
		line = 3840,
	},
	["0108_00301"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0533", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Anti-copulation front... so you are opposed to the law, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“反交尾势力……是反抗那个条例的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「反交尾勢力……是反抗那個條例的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00300",
		linknext = "0108_00302",
		line = 3855,
	},
	["0108_00302"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yep. We're rebels with a cause. Like, being a rebel without a cause is one thing, but better that you have something to believe in, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，也就是叛国贼……不对，叛岛贼？但这样听起来好像有其他含义……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，也就是叛國賊……不對，叛島賊？但這樣聽起來好像有其他含義……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00301",
		linknext = "0108_00303",
		line = 3867,
	},
	["0108_00303"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, our organization is made up of five people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之，是包括我在内5人组成的组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之，是包括我在內5人組成的組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00302",
		linknext = "0108_00304",
		line = 3879,
	},
	["0108_00304"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0534", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“So... during that battle involving the SS... was that your group?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“难道……是以前、在教学楼和FS交战的、各位……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「難道……是以前、在校舍和FS交戰的、各位……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00303",
		linknext = "0108_00305",
		line = 3893,
	},
	["0108_00305"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that was us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，就是他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，就是他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00304",
		linknext = "0108_00306",
		line = 3905,
	},
	["0108_00306"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Our main objectives are to avoid copulation at all costs, and get home safely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们最大的目的是回避变态交配，平安回到家里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們最大的目的是迴避變態交配，平安回到家裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00305",
		linknext = "0108_00307",
		line = 3917,
	},
	["0108_00307"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As for why... We all loathe procreational actions and despise the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为——我讨厌性产行为，憎恨变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為——我討厭性產行為，憎恨變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00306",
		linknext = "0108_00308",
		line = 3929,
	},
	["0108_00308"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0535", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“……………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00307",
		linknext = "0108_00309",
		line = 3943,
	},
	["0108_00309"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can't accept a law that pressures people to conform and partake in sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不能原谅使用同调压力来扭曲内心，强迫进行性行为的条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不能原諒使用同調壓力來扭曲內心，強迫進行性行為的條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00308",
		linknext = "0108_00310",
		line = 3955,
	},
	["0108_00310"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So one day, we're going to crush that law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，我一定要把那个变态条例破坏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，我一定要把那個變態條例破壞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00309",
		linknext = "0108_00311",
		line = 3967,
	},
	["0108_00311"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes light up slightly and she stares at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到这句话，吹子微微瞪大了眼睛，凝视着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到這句話，吹子微微瞪大了眼睛，凝視著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00310",
		linknext = "0108_00312",
		line = 3980,
	},
	["0108_00312"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But that's for the future. Right now, our main concern is escaping from school and getting home safely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过那是将来的事……现在还是一个以安全逃跑为主的逃亡集团……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過那是將來的事……現在還是一個以安全逃跑為主的逃亡集團……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00311",
		linknext = "0108_00313",
		line = 3992,
	},
	["0108_00313"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right now, though, we gotta kick the asses of those yakuza fuckers!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但目前最重要的是把黑社会打倒——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但目前最重要的是把黑社會打倒——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00312",
		linknext = "0108_00314",
		line = 4004,
	},
	["0108_00314"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0536", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“I'm terribly sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“……对不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「……對不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00313",
		linknext = "0108_00315",
		line = 4018,
	},
	["0108_00315"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? You don't have anything to apologize for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶？不，吹子你不需要道歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？不，吹子你不需要道歉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00314",
		linknext = "0108_00316",
		line = 4030,
	},
	["0108_00316"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00115", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0537", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“No... I'm sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“不……对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「不……對不起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00315",
		linknext = "0108_00317",
		line = 4044,
	},
	["0108_00317"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I forgive you, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那我就原谅你吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那我就原諒你吧……？」",
					{"rt2"},
				},
			},
