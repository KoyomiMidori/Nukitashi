			},
		},
		linkback = "0108_00423",
		linknext = "0108_00425",
		line = 5423,
	},
	["0108_00425"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[1000] = {
				{"se", id=0, loop=0, file="se_b047", delay2=1000},
				{"cgact", file="cgact", id=1, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine", delay2=1000, lv=5},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the fuck are you up to? Your own head honcho's been kidnapp— GAAAAAAH!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在想什么！？我就说组织的老大被绑架了——呜呜呜！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你在想什麼！？我就說組織的老大被綁架了——嗚嗚嗚！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00424",
		linknext = "0108_00426",
		line = 5437,
	},
	["0108_00426"] = {
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00104", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0153", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“And what about it? Any obstacles in the way of our objective must be dealt with. Is that not the way of things?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“那又怎样？为了达到目的而除掉妨碍者，这不是理所当然的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「那又怎樣？為了達到目的而除掉妨礙者，這不是理所當然的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00425",
		linknext = "0108_00427",
		line = 5451,
	},
	["0108_00427"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The two people towering over me from the sides restrain my arms.",
					{"rt2"},
				},
			},
			cn = {
				{
					"两臂被从左右压上来的两人紧紧固定住。",
					{"rt2"},
				},
			},
			tw = {
				{
					"兩臂被從左右壓上來的兩人緊緊固定住。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00426",
		linknext = "0108_00428",
		line = 5461,
	},
	["0108_00428"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're supposed to be the OSS's publicity girl! How can you do this!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你……你不是SHO的宣传负责人吗……！？怎么会做这样的事情——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你……你不是SHO的宣傳負責人嗎……！？怎麼會做這樣的事情——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00427",
		linknext = "0108_00429",
		line = 5473,
	},
	["0108_00429"] = {
		{"cgact", file="cgact", id=1, act="stopact", lv=5},
		{"bg", id=1, file="bg05_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00110", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0154", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“That has nothing to do with this. This is my own will. If it aids in that man furthering his own military rule, I do not mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“那种事怎样都好，这是我的意志。帮助那位大人物走向霸道才是我的喜悦——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「那種事怎樣都好，這是我的意志。幫助那位大人物走向霸道才是我的喜悅——」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00428",
		linknext = "0108_00430",
		line = 5490,
	},
	["0108_00430"] = {
