	["0108_00578"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0554", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“It grazed my inner thigh. I narrowly escaped by chance when I was changing targets.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“因为擦伤了大腿内侧……那时因为想在开枪后改变狙击地点，所以逃过了一劫……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「因為擦傷了大腿內側……那時因為想在開槍後改變狙擊地點，所以逃過了一劫……」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00577",
		linknext = "0108_00579",
		line = 7620,
	},
	["0108_00579"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says that as though it was no big deal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她若无其事地说着。",
