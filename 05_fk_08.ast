					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Emergency deployment?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“紧急、出动……为了什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「緊急、出動……為了什麼……？」",
