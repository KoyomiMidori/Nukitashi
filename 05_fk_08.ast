		{"fgact", ch="文乃", id=7, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fukiko looks uncharacteristically pale.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吹子一副铁青的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吹子一副鐵青的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00391",
		linknext = "0108_00393",
		line = 4991,
	},
	["0108_00393"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The same girl who seemed unfazed even when facing down yakuza...",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使被那么多黑社会包围，也面不改色的吹子——",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使被那麼多黑社會包圍，也面不改色的吹子——",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00392",
		linknext = "0108_00394",
		line = 5001,
	},
	["0108_00394"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come on, Fukiko! Follow my lead!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我会走在前面，你就跟着我吧——出发了，吹子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我會走在前面，你就跟著我吧——出發了，吹子！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00393",
		linknext = "0108_00395",
		line = 5013,
	},
	["0108_00395"] = {
		{"fgact", id=7, ch="文乃", act="stopact"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
