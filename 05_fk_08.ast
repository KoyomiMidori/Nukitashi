	["0108_00127"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00103", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0613", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huuuh, did Rei just praise Darling!? No way!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶诶诶诶，礼酱表扬了亲爱的！？骗人的吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸欸欸欸，禮醬表揚了親愛的！？騙人的吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00126",
		linknext = "0108_00128",
		line = 1642,
	},
	["0108_00128"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1099", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I am capable of praise! If anything, I prefer being able to praise a subordinate... That's not the point!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我也是会表扬的好吗！应该说我本来就是会夸奖部下让他们成长的类型……不，这些暂且不谈！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我也是會表揚的好嗎！應該說我本來就是會誇獎部下讓他們成長的類型……不，這些暫且不談！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00127",
		linknext = "0108_00129",
		line = 1657,
	},
	["0108_00129"] = {
