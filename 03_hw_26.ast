				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, it is, isn't it? Damn, I forgot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，这么说来……我忘了。”",
