				{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine", delay2=300},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0468", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, that's her! The disciplinary committee president!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，对对！风纪委员长同学！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，對對！風紀委員長同學！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00143",
		linknext = "0076_00145",
		line = 1768,
	},
	["0076_00145"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's not very nice to call her anal-retentive.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“再怎么样也不能说人家的菊花看起来很弱吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「再怎麼樣也不能說人家的菊花看起來很弱吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00144",
		linknext = "0076_00146",
		line = 1780,
	},
	["0076_00146"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00118", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0469", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Isn't she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你不觉得看起来很弱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你不覺得看起來很弱嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00145",
		linknext = "0076_00147",
		line = 1794,
	},
	["0076_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Probably, but still.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看起来是蛮弱的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看起來是蠻弱的。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00146",
		linknext = "0076_00148",
		line = 1804,
	},
	["0076_00148"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00118", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0470", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hehe... yes, come to the Misaki side. Tachibana-san, give in to your loneliness, feel it flow through you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嘿嘿……不过这样看来……橘同学终于也被孤立来到美岬这边了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嘿嘿……不過這樣看來……橘同學終於也被孤立來到美岬這邊了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00147",
		linknext = "0076_00149",
		line = 1818,
	},
	["0076_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pass...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“并没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「並沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00148",
		linknext = "0076_00150",
		line = 1829,
	},
	["0076_00150"] = {
		{"fg", file="misaki_02m_00002", file1="misaki_02m_00102", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0471", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, I've perfected a new impression! Want to hear it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“话说我最近学会了新的模仿哦！机会难得我就展示一下吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「話說我最近學會了新的模仿哦！機會難得我就展示一下吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00149",
		linknext = "0076_00151",
		line = 1843,
	},
	["0076_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I say no, will you not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还真是为所欲为啊你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還真是為所欲為啊你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00150",
		linknext = "0076_00152",
		line = 1854,
	},
	["0076_00152"] = {
