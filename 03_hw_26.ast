			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ayo Jun, I'm such a slut, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“喂淳，我可是婊子哦！”",
