	},
	["0076_00369"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Argh, dammit! Why don't we just get serious and have a baby!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哎可恶！干脆就真的跟你做孩子吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哎可惡！乾脆就真的跟你做孩子吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00368",
		linknext = "0076_00370",
		line = 4812,
	},
	["0076_00370"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg05011412", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
