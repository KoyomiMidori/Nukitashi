					"I open my mouth, close it for a moment, and then open it again to speak.",
					{"rt2"},
				},
			},
			cn = {
				{
					"开口，犹豫不决——然后，再一次开口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"開口，猶豫不決——然後，再一次開口。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00104",
		linknext = "0076_00106",
		line = 1260,
	},
	["0076_00106"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Will your eye get better?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那只眼睛，能治好吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那隻眼睛，能治好嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00105",
		linknext = "0076_00107",
		line = 1272,
	},
	["0076_00107"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00115", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0281", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00106",
		linknext = "0076_00108",
		line = 1286,
	},
	["0076_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She probably can't bring herself to lie, and instead just hangs her head apologetically.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一定不会说谎的吧——文乃只是一副很抱歉的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一定不會說謊的吧——文乃只是一副很抱歉的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00107",
		linknext = "0076_00109",
		line = 1296,
	},
	["0076_00109"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00108", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……对不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……對不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00108",
		linknext = "0076_00110",
		line = 1308,
	},
	["0076_00110"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0282", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“There's no need for that look.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……请不要露出那种表情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……請不要露出那種表情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00109",
		linknext = "0076_00111",
		line = 1322,
	},
	["0076_00111"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0283", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“The number of people deeply wounded by the law was by no means small... However, you were able to fulfill your vows.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“因为条例而受到重伤的人绝对不少……不过，您们最后终于如愿以偿了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「因為條例而受到重傷的人絕對不少……不過，您們最後終於如願以償了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00110",
		linknext = "0076_00112",
		line = 1336,
	},
	["0076_00112"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00107", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0284", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I feel proud to have been able to play what small part I could in protecting this beautiful island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“虽然只有微薄之力，但我很自豪自己能为保护这座美丽的岛屿尽一份力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「雖然只有微薄之力，但我很自豪自己能為保護這座美麗的島嶼盡一份力……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00111",
		linknext = "0076_00113",
		line = 1350,
	},
	["0076_00113"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00112",
		linknext = "0076_00114",
		line = 1362,
	},
	["0076_00114"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0285", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Even if I am only looking at it through one eye, it does not halve the beauty of this island...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“就算只用一只眼睛看，岛上的美丽也不会因此减半……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「就算只用一隻眼睛看，島上的美麗也不會因此減半……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00113",
		linknext = "0076_00115",
		line = 1374,
	},
	["0076_00115"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0286", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This island you all saved is far more brilliant than when I could see it with both eyes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“对我来说……大家替我守护了的这个岛……比我之前用两只眼睛见到时，还要更加鲜明许多。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「對我來說……大家替我守護了的這個島……比我之前用兩隻眼睛見到時，還要更加鮮明許多。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00114",
		linknext = "0076_00116",
		line = 1386,
	},
	["0076_00116"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file4="fumino_01m_00402", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0287", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“So please do not concern yourself... as I will be fine. I'm a strong woman.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以，请不要担心……没关系的，文乃是个坚强的女人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以，請不要擔心……沒關係的，文乃是個堅強的女人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00115",
		linknext = "0076_00117",
		line = 1400,
	},
	["0076_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gives me a stout smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃坚决地笑了笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃堅決地笑了笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00116",
		linknext = "0076_00118",
		line = 1410,
	},
	["0076_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I return her brave, undaunted smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了回应那份伟大的情操——我也浮现了笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了回應那份偉大的情操——我也浮現了笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00117",
		linknext = "0076_00119",
		line = 1420,
	},
	["0076_00119"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=100},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=800, rule="eff_012_00000"},
		{"ex", time=1000, func="wait"},
		{"bg", id=1, file="bg22_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=800, rule="eff_012_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I bid her farewell and wander aimlessly along the main street.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和文乃告别后，我在主大道上漫无目的地走着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和文乃告別後，我在主大道上漫無目的地走著。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00118",
		linknext = "0076_00120",
		line = 1463,
	},
	["0076_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are still numerous vestiges from the perverted sex law visible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"变态条例给我们留下的伤痕并不浅。",
					{"rt2"},
				},
			},
			tw = {
				{
					"變態條例給我們留下的傷痕並不淺。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00119",
		linknext = "0076_00121",
		line = 1473,
	},
	["0076_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if the law is abolished, and all traces of it are removed from the island, there are some things that can't be taken away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使条例被完全废除，性的痕迹从岛上消失了——也有无法抹去的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使條例被完全廢除，性的痕跡從島上消失了——也有無法抹去的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00120",
		linknext = "0076_00122",
		line = 1483,
	},
	["0076_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even once everything is over, I'll be reminded of it many times in the future.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算一切都结束了，今后还是会反复回想起好几次吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算一切都結束了，今後還是會反覆回想起好幾次吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00121",
		linknext = "0076_00123",
		line = 1493,
	},
	["0076_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's fine, however.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，这样就可以了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，這樣就可以了。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00122",
		linknext = "0076_00124",
		line = 1503,
	},
	["0076_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They'll serve as reminders to me to make sure no one ever suffers because of something like that again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了不再重蹈覆彻，为了不再让任何人痛苦——这是不能忘记的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了不再重蹈覆徹，為了不再讓任何人痛苦——這是不能忘記的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00123",
		linknext = "0076_00125",
		line = 1513,
	},
	["0076_00125"] = {
		{"bgm", file="bgm02", vol=100},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0462", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Mubebe! It's Misa, Tachibana-san!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“原来来！是橘同学呢美！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「原來來！是橘同學呢美！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00124",
		linknext = "0076_00126",
		line = 1528,
	},
	["0076_00126"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh... who are you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……谁？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……誰？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00125",
		linknext = "0076_00127",
		line = 1540,
	},
	["0076_00127"] = {
		{"bg", id=1, file="bg22_1_00000", x=0, y=0, path=":bg/", sync=0, time=1, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00125", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0463", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So cruel! You really don't remember me at all!? Am I too bland a character to be worth the effort!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“太过分了！还没办法记住我吗！？我有那么没特色吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「太過分了！還沒辦法記住我嗎！？我有那麼沒特色嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00126",
		linknext = "0076_00128",
		line = 1556,
	},
	["0076_00128"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm kidding. You've proven too important for me to forget by now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“开玩笑的。你在我脑中已经是完全忘不掉的程度了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「開玩笑的。你在我腦中已經是完全忘不掉的程度了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00127",
		linknext = "0076_00129",
		line = 1568,
	},
	["0076_00129"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
