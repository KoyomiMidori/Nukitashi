	["0076_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A certain someone's been affecting my sleep schedule, too. I've started naturally getting up early, and now I don't know what people like this do all morning.",
