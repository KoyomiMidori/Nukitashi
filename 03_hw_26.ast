		line = 202,
	},
	["0076_00016"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00123", file4="asane_02l_00402", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1205", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No! If I wanted to live that life, I would've done that all along! I can't let that loli impose her positive lifestyle and self-discipline on me and ruin the image I've spent my whole life cultivating!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不行啊……麻沙酱决定过要过堕落的人生啊……不能败给那种萝莉妹子的管教变成正常人的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不行啊……麻沙醬決定過要過墮落的人生啊……不能敗給那種蘿莉妹子的管教變成正常人的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00015",
		linknext = "0076_00017",
		line = 216,
	},
	["0076_00017"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00103", file4="asane_02l_00402", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1206", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So I'm going back to bed to get my super-unhealthy life back... Don't wake me up while the sun is still in the sky.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以说我现在要睡个回笼觉昼夜颠倒恢复超不健康的生活……晚上之前绝对不要叫醒我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以說我現在要睡個回籠覺晝夜顛倒恢復超不健康的生活……晚上之前絕對不要叫醒我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00016",
		linknext = "0076_00018",
		line = 230,
	},
