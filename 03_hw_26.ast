		linkback = "0076_00010",
		linknext = "0076_00012",
		line = 148,
	},
	["0076_00012"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00112", file2="asane_02l_00202", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1203", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“And yet I still find myself out of bed at this ungodly hour. At this rate, I'll become a respectable citizen with a healthy outlook on life and a good complexion before I know it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是……我居然这么早就起来了……完全就是个正常人啊……太健全了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是……我居然這麼早就起來了……完全就是個正常人啊……太健全了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00011",
		linknext = "0076_00013",
		line = 162,
	},
	["0076_00013"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
