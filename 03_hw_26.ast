			},
		},
		text = {
			vo = {
				{"vo", file="misaki0467", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It's the thought that counts, right? Oh, I also ran into Wata-chan as I was leaving the bakery! She was with that, umm... anal-retentive friend of hers!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“心意很重要的。话说回来，我从蛋糕店出来时见到渡酱了。她和那个，呃……菊花看起来很弱的人在一起！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「心意很重要的。話說回來，我從蛋糕店出來時見到渡醬了。她和那個，呃……菊花看起來很弱的人在一起！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00139",
		linknext = "0076_00141",
		line = 1719,
	},
	["0076_00141"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
