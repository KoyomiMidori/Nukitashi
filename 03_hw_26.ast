	},
	["0076_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We don't need to hide in the shadows anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"已经——不用像以前那样潜伏在阴影中生活了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"已經——不用像以前那樣潛伏在陰影中生活了。",
