					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that's right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得也是。」",
