	["0076_00203"] = {
		{"fg", file="jun_01m_00002", file1="jun_01m_00119", file2="jun_01m_00202", file4="jun_01m_00401", path=":fg/jun_01m/", id=2, lv=5, head="jun_01m", ch="淳之介", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
