				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00350",
		linknext = "0076_00352",
		line = 4549,
	},
	["0076_00352"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00303", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hinami and my baby!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我和雏见的……宝宝……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我和雛見的……寶寶……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00351",
		linknext = "0076_00353",
		line = 4561,
	},
	["0076_00353"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg05013512", set="hcg050135", path=":ev/hcg050135/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg05013512", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0851", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“D-Don't be stupid! Don't let her lure you in with this sweet talk! Listen, Hinami, you're still much too young for that! Save that for after you graduate, and once you're married!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“傻、傻瓜！别被这种花言巧语给骗了！听好了雏见，现在还太早了！那种事……要等毕业、结婚之后才可以……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「傻、傻瓜！別被這種花言巧語給騙了！聽好了雛見，現在還太早了！那種事……要等畢業、結婚之後才可以……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00352",
		linknext = "0076_00354",
		line = 4579,
	},
	["0076_00354"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg05012512", set="hcg050125", path=":ev/hcg050125/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg05012512", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1869", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Married! Ah, that sounds nice... oh, I know! Rei-chan, do you want to give the speech at our wedding!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“结婚……！结婚吗……好棒哦，真是令人憧憬啊……对了！婚礼的致辞可以拜托礼酱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「結婚……！結婚嗎……好棒哦，真是令人憧憬啊……對了！婚禮的致辭可以拜託禮醬嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00353",
		linknext = "0076_00355",
		line = 4597,
	},
	["0076_00355"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg05012412", set="hcg050124", path=":ev/hcg050124/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg05012412", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0852", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Huh? S-Speech? Me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“诶……我、我来致辞吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「欸……我、我來致辭嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00354",
		linknext = "0076_00356",
		line = 4615,
	},
	["0076_00356"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg05011412", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1870", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah! We both really love you Rei-chan, right, Jun-kun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！因为我和淳君都很喜欢礼酱呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！因為我和淳君都很喜歡禮醬呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00355",
		linknext = "0076_00357",
		line = 4630,
	},
	["0076_00357"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg05011512", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0853", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I-I appreciate the gesture, but... T-Tachibana, what do I do!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就、就算你这么说……怎、怎么办橘……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就、就算你這麼說……怎、怎麼辦橘……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00356",
		linknext = "0076_00358",
		line = 4645,
	},
	["0076_00358"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just calm down! Weren't you the one saying not to let her sweet talk lure you in!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请冷静！如果连礼前辈都惊慌失措的话，事情就麻烦了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請冷靜！如果連禮前輩都驚慌失措的話，事情就麻煩了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00357",
		linknext = "0076_00359",
		line = 4657,
	},
	["0076_00359"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg050165-12", set="hcg050165", path=":ev/hcg050165/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050165-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1871", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei-chan... I don't want anyone but Rei-chan. If you won't do it, then I can't have Jun-kun's baby.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不是礼酱不行啊……如果礼酱不致辞的话，我就没法和淳君生孩子了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不是禮醬不行啊……如果禮醬不致辭的話，我就沒法和淳君生孩子了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00358",
		linknext = "0076_00360",
		line = 4675,
	},
	["0076_00360"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, no more babies! I have to draw a line in the sand!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“生、生孩子什么的……果然不行！就连我都没被雏见生过了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「生、生孩子什麼的……果然不行！就連我都沒被雛見生過了！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00359",
		linknext = "0076_00361",
		line = 4687,
	},
	["0076_00361"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0854", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Now you're the one getting carried away!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你也给我差不多一点哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你也給我差不多一點哦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00360",
		linknext = "0076_00362",
		line = 4699,
	},
	["0076_00362"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"fg", file="asane_02f_00007", file1="asane_02f_00121", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1207", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ahh, it's so loud I can't sleep... can't you keep it down!? Bro, what did I tell you about waking me up before sundown!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊真是吵到睡不着了……我不是说过到晚上前别叫醒我吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊真是吵到睡不著了……我不是說過到晚上前別叫醒我嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00361",
		linknext = "0076_00363",
		line = 4713,
	},
	["0076_00363"] = {
