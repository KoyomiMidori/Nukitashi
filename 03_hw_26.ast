	["0076_00014"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00103", file4="asane_02l_00402", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a100"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1204", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, that's not good! People can't survive without toxicity. If I keep this 'healthy lifestyle' bullshit up any longer, all my trademark toxicity will leave me and I'll become a saint!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哪里好……人类为了生存是需要毒素这个东西的啊……如果继续过上这样的健康生活毒素全排出去了会变成圣人君子吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哪裡好……人類為了生存是需要毒素這個東西的啊……如果繼續過上這樣的健康生活毒素全排出去了會變成聖人君子吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00013",
		linknext = "0076_00015",
		line = 190,
	},
	["0076_00015"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
