		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I got no bars...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，没信号……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，沒信號……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00181",
		linknext = "0076_00183",
		line = 2274,
	},
	["0076_00183"] = {
		{"fg", file="rei_01m_00007", file1="rei_01m_00119", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0809", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Again? Isn't it about time you got that thing repaired?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“又是那样吗……差不多该拿去修理了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「又是那樣嗎……差不多該拿去修理了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00182",
		linknext = "0076_00184",
		line = 2288,
	},
	["0076_00184"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Repaired? Yeah, I guess it's been broken ever since I used it as a weapon against the governor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“拿它揍了县知事之后状况就一直不太好呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「拿它揍了縣知事之後狀況就一直不太好呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00183",
		linknext = "0076_00185",
		line = 2300,
	},
	["0076_00185"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="hinami_02m_00002", file1="hinami_02m_00114", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1832", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I-Is it possessed by Hitoura-san? That's scary, you've gotta exorcise it... Evil spirit begone, evil spirit begone!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是、是仁浦先生的怨念吗？好可怕，必须除灵……恶灵退散恶灵退散！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是、是仁浦先生的怨念嗎？好可怕，必須除靈……惡靈退散惡靈退散！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00184",
		linknext = "0076_00186",
		line = 2316,
	},
	["0076_00186"] = {
		{"fg", file="rei_01m_00007", file1="rei_01m_00124", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0810", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“He's still alive... sigh... Yeah, if you hit him that hard with it, then it's probably broken.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“他还活着好吗……唉……做了那种事肯定会坏掉的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「他還活著好嗎……唉……做了那種事肯定會壞掉的吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00185",
		linknext = "0076_00187",
		line = 2330,
	},
	["0076_00187"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was the only melee weapon I had on hand at the time...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那时候实在是忍不住……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那時候實在是忍不住……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00186",
		linknext = "0076_00188",
		line = 2342,
	},
	["0076_00188"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll do that later. What was the message about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唉，先不说这个了……是什么联络？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唉，先不說這個了……是什麼聯絡？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00187",
		linknext = "0076_00189",
		line = 2354,
	},
	["0076_00189"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1833", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, we were just asking if we could go over to Jun-kun's place! Can we?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“就是啊，现在可以去淳君家吗！可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「就是啊，現在可以去淳君家嗎！可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00188",
		linknext = "0076_00190",
		line = 2368,
	},
	["0076_00190"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, of course.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，当然可以。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，當然可以。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00189",
		linknext = "0076_00191",
		line = 2380,
	},
	["0076_00191"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1834", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Really? Ehehe, yay! Let's eat this together, Jun-kun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的吗？诶嘿嘿，太好了！这个，淳君也一起吃吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的嗎？欸嘿嘿，太好了！這個，淳君也一起吃吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00190",
		linknext = "0076_00192",
		line = 2394,
	},
	["0076_00192"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She holds out her tiny hand and shows me a bag with cake in it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见伸出小手，把装着蛋糕的袋子举起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見伸出小手，把裝著蛋糕的袋子舉起來。",
