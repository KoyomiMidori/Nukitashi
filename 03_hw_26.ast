		{"fgact", ch="美岬", id=6, act="移動", x=400, y=0, time=500},
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1917", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Who's that meant to be?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那是在模仿谁啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那是在模仿誰啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00152",
		linknext = "0076_00154",
		line = 1884,
	},
	["0076_00154"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00125", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0473", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Eeek!? Th-The real thing!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哇———！？真、真人！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哇———！？真、真人！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00153",
		linknext = "0076_00155",
		line = 1899,
	},
	["0076_00155"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1918", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“What the hell are you talking about...? Sigh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“什么真人不真人……唉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「什麼真人不真人……唉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00154",
		linknext = "0076_00156",
		line = 1913,
	},
	["0076_00156"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What a coincidence. Did you all have the same idea, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是巧啊……这么说来，大家都往这边来了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是巧啊……這麼說來，大家都往這邊來了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00155",
		linknext = "0076_00157",
		line = 1927,
	},
	["0076_00157"] = {
		{"bgm", file="bgm06", vol=100},
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1919", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's not like there's a ton of options, is there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，休息日会去的地方也只有这附近了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，休息日會去的地方也只有這附近了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00156",
		linknext = "0076_00158",
		line = 1942,
	},
	["0076_00158"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess. I don't think we've ever met in town before, though, have we?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也是……不过至今为止还真的几乎没有在街上碰到过呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也是……不過至今為止還真的幾乎沒有在街上碰到過呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00157",
		linknext = "0076_00159",
		line = 1954,
	},
	["0076_00159"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1920", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I think we were both too busy hiding at home. We don't need to do that anymore, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“因为我们都在避人耳目吧？不过现在……已经没有必要再那样做了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為我們都在避人耳目吧？不過現在……已經沒有必要再那樣做了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00158",
		linknext = "0076_00160",
		line = 1970,
	},
	["0076_00160"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
