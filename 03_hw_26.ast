		{"bg", id=18, file="hcg050125-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0835", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“N-Not all of them, for your information! Really, it was just math! The others were... acceptable!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我、我话说在前面，不是全部！只有数学，其他的……还行！”",
