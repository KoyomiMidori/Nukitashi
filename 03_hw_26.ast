		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050155-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1872", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Fine, then! If Rei-chan won't do it, then screw the wedding! I'll just have Jun-kun's baby and we'll be unmarried parents!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那算了！既然礼酱不帮我致辞，我就直接和淳君一起做宝宝吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那算了！既然禮醬不幫我致辭，我就直接和淳君一起做寶寶吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00362",
		linknext = "0076_00364",
		line = 4731,
	},
	["0076_00364"] = {
