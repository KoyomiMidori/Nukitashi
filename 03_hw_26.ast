	["0076_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As per his promise, Senator Hitoura retracted his proposal to expand the perverted sex law nationwide, and instead declared its abolishment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生按照约定，取消了日本全土变态化计划，并宣布废除变态条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生按照約定，取消了日本全土變態化計劃，並宣布廢除變態條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00058",
