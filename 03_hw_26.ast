					"明明前些日子什么地下风俗还日本全土变态化计划还那么热门，现在却像假的一样沉静。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明前些日子什麼地下風俗還日本全土變態化計劃還那麼熱門，現在卻像假的一樣沉靜。",
					{"rt2"},
				},
