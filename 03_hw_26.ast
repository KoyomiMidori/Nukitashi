					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I don't want to be a third wheel...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我是……不太想做些妨碍你们的事……”",
