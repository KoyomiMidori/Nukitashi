		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050113-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1854", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ehehe... Lucky for both of you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……太好了，你们两个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……太好了，你們兩個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00307",
		linknext = "0076_00309",
		line = 3931,
	},
	["0076_00309"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00308",
		linknext = "0076_00310",
		line = 3943,
	},
	["0076_00310"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is as happy of an ending as I could've hoped for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一定就是所谓的幸福结局吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一定就是所謂的幸福結局吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00309",
		linknext = "0076_00311",
		line = 3953,
	},
	["0076_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not exactly clean, and there's still doubts and misgivings to be had.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不是所有的问题都彻底解决了，也不是所有的疑问都被解答了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不是所有的問題都徹底解決了，也不是所有的疑問都被解答了。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00310",
		linknext = "0076_00312",
		line = 3963,
	},
	["0076_00312"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not perfect.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许并不完全。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許並不完全。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00311",
		linknext = "0076_00313",
		line = 3973,
	},
	["0076_00313"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, I'm truly happy now, and that's all I could've asked for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，现在能像这样相处，对我来说是无比幸福的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，現在能像這樣相處，對我來說是無比幸福的。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00312",
		linknext = "0076_00314",
		line = 3983,
	},
	["0076_00314"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050112-1-1", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0840", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Still, even though the SS will continue to exist however it can, it won't be anywhere near smooth sailing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过……以最好的情况来说，即使SS能继续存在，也还是无法一帆风顺呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不過……以最好的情況來說，即使SS能繼續存在，也還是無法一帆風順呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00313",
		linknext = "0076_00315",
		line = 3998,
	},
	["0076_00315"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If anyone can make it happen, it's you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一定可以的，如果是礼前辈的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一定可以的，如果是禮前輩的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00314",
		linknext = "0076_00316",
		line = 4010,
	},
	["0076_00316"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg050116-12", set="hcg050116", path=":ev/hcg050116/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050116-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0841", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sigh... Look at you, the one responsible for bringing down the law, leaving others to clean up his mess.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唉……毁了条例的罪魁祸首，却把残局扔给别人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唉……毀了條例的罪魁禍首，卻把殘局扔給別人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00315",
		linknext = "0076_00317",
		line = 4028,
	},
	["0076_00317"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1855", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You'll be fine! Believe in me, Rei-chan! If you ever need help, just give me a call!”",
					{"rt2"},
				},
			},
			cn = {
