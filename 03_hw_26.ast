		linknext = "0076_00204",
		line = 2555,
	},
	["0076_00204"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=9, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1839", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I love Jun-kun, and I love Rei-chan! You're both precious to me, so we're all very close!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我超喜欢淳君，也超喜欢礼酱！两个人都很重要！大家都很要好——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我超喜歡淳君，也超喜歡禮醬！兩個人都很重要！大家都很要好——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00203",
		linknext = "0076_00205",
		line = 2569,
	},
	["0076_00205"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=9, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
