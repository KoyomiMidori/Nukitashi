		linknext = "0076_00295",
		line = 3760,
	},
	["0076_00295"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050125-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0837", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Urgh... wh-what did you expect!? I never had any time to study! Really, it's all your fault!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔……我、我也没办法啊！这次根本没有时间学习啊！而且……也不是我的错……是你……是橘的错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔……我、我也沒辦法啊！這次根本沒有時間學習啊！而且……也不是我的錯……是你……是橘的錯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00294",
		linknext = "0076_00296",
		line = 3775,
	},
	["0076_00296"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How's that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么会变成我的错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼會變成我的錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00295",
		linknext = "0076_00297",
		line = 3787,
	},
	["0076_00297"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg050123-12", set="hcg050123", path=":ev/hcg050123/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050123-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0838", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“How!? I could never concentrate, even in class, and nothing really stuck... ever since you betrayed me that day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“还问为什么……上课也不能集中精神，连作业都不能专心做……自从那天，被橘背叛之后……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「還問為什麼……上課也不能集中精神，連作業都不能專心做……自從那天，被橘背叛之後……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00296",
		linknext = "0076_00298",
		line = 3805,
	},
	["0076_00298"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah... I-I'm sorry...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊——对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊——對不起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00297",
		linknext = "0076_00299",
		line = 3817,
	},
	["0076_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I poured salt on an open wound, didn't I?",
					{"rt2"},
				},
			},
			cn = {
				{
					"一提到这件事，我的立场就太薄弱了。这让我无法反驳。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一提到這件事，我的立場就太薄弱了。這讓我無法反駁。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00298",
		linknext = "0076_00300",
		line = 3827,
	},
	["0076_00300"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Umm... I know a lot has happened... But now that everythings settled, you can forgive me, right...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个……虽然发生了很多事……但总算平安落幕了，能请你原谅我吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個……雖然發生了很多事……但總算平安落幕了，能請你原諒我嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00299",
		linknext = "0076_00301",
		line = 3839,
	},
	["0076_00301"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0839", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hmph... I don't think so... I'm gonna keep complaining... Maybe you can weep into your pillow night after night and see how it feels.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哼……才不要……我要一直碎碎念下去……就让你也每天晚上都哭哭啼啼的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哼……才不要……我要一直碎碎念下去……就讓你也每天晚上都哭哭啼啼的吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00300",
		linknext = "0076_00302",
		line = 3851,
	},
	["0076_00302"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please, forgive me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请你见谅……饶了我吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請你見諒……饒了我吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00301",
		linknext = "0076_00303",
		line = 3863,
	},
	["0076_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I grovel on the ground before her, she just pouts and looks away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我低下了头，但礼前辈鼓起脸颊把头转开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我低下了頭，但禮前輩鼓起臉頰把頭轉開。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00302",
		linknext = "0076_00304",
		line = 3873,
	},
	["0076_00304"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even now, thinking back to that day hurts. I don't know if I'll ever recover.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一回想起那天的事情，我的内心就会充满后悔与抱歉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一回想起那天的事情，我的內心就會充滿後悔與抱歉。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00303",
		linknext = "0076_00305",
		line = 3883,
	},
	["0076_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm still glad though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但尽管如此——我还是觉得太好了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但儘管如此——我還是覺得太好了。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00304",
		linknext = "0076_00306",
		line = 3893,
	},
	["0076_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just being able to half-joke about it, even though we parted on such hostile terms...",
					{"rt2"},
				},
			},
			cn = {
				{
					"与SS决裂时留下的深刻伤痕，现在已经可以拿来互相调侃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與SS決裂時留下的深刻傷痕，現在已經可以拿來互相調侃了。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00305",
		linknext = "0076_00307",
		line = 3903,
	},
	["0076_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's more than I could've ever asked for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样就足够了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣就足夠了。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00306",
		linknext = "0076_00308",
		line = 3913,
	},
	["0076_00308"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
