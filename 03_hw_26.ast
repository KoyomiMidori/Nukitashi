	["0076_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unlike Hinami who no one would approach, and Hotori who no one would notice, Nanase drew everyone's attention wherever she went.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与不被人理睬的雏见和不被人发觉的畔不同——奈奈濑比任何人都受到关注。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與不被人理睬的雛見和不被人發覺的畔不同——奈奈瀨比任何人都受到關注。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00164",
		linknext = "0076_00166",
		line = 2037,
	},
	["0076_00166"] = {
		{"text"},
		text = {
