	["0076_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The discussion has been hopelessly derailed. There's no hope of getting it back under control.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事情闹大了——好像已经无法收拾了。",
					{"rt2"},
