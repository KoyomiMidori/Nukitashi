	},
	["0076_00293"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yeah, I know what 'supplementary exam' means.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然参加了补考，那就只意味着一件事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然參加了補考，那就只意味著一件事情。",
