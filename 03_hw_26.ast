			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ohoh, really? Ehehe, what an honor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哦，到那种程度吗！诶嘿嘿，那还真是光荣啊——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哦，到那種程度嗎！欸嘿嘿，那還真是光榮啊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00128",
		linknext = "0076_00130",
		line = 1585,
	},
	["0076_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori is carrying a bag from a bakery.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔一只手拎着蛋糕店的袋子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔一隻手拎著蛋糕店的袋子。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00129",
		linknext = "0076_00131",
		line = 1595,
	},
	["0076_00131"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did something good happen to you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有什么好事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有什麼好事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00130",
		linknext = "0076_00132",
		line = 1607,
	},
	["0076_00132"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0465", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, no. I was just thinking I'd pay Fumino-chan a visit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，没有……我想去探望文乃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，沒有……我想去探望文乃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00131",
		linknext = "0076_00133",
		line = 1621,
	},
	["0076_00133"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, okay.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，原来如此。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，原來如此。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00132",
		linknext = "0076_00134",
		line = 1633,
	},
	["0076_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those two are awfully close, aren't they?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来，畔和文乃的关系很好——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，畔和文乃的關係很好——",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00133",
		linknext = "0076_00135",
		line = 1643,
	},
	["0076_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, maybe that's not the right word. Hotori seems to be quite fond of Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——其实我也不太清楚，只是感觉看上去是畔单方面在缠着文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——其實我也不太清楚，只是感覺看上去是畔單方面在纏著文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00134",
		linknext = "0076_00136",
		line = 1653,
	},
	["0076_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, I'm sure Fumino would be happy to hear Hotori talking about visiting her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过让畔这种疯狂的人去探望的话，文乃的心情也许也会比较开朗一点吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過讓畔這種瘋狂的人去探望的話，文乃的心情也許也會比較開朗一點吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00135",
		linknext = "0076_00137",
		line = 1663,
	},
	["0076_00137"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
