			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Thank you very much for... my father, and the law. I'm terribly sorry for the delay in expressing my gratitude.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“父亲的事，条例的事……非常感谢……感谢晚了，非常抱歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「父親的事，條例的事……非常感謝……感謝晚了，非常抱歉……」",
