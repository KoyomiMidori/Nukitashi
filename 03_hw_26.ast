		{"bg", id=18, file="hcg050154-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0855", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“W-Wait! Okay, Hinami! Don't be hasty! I'll do it! I'll do it for you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“等、等一下！我知道了雏见！别做傻事！我做！我会做的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「等、等一下！我知道了雛見！別做傻事！我做！我會做的！」",
