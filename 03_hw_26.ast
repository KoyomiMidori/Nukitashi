	["0076_00371"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg05011512", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0856", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Wait, what!? No, you can't!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我、我可不会承认哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我、我可不會承認哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00370",
		linknext = "0076_00372",
		line = 4842,
	},
	["0076_00372"] = {
		{"fg", file="asane_02f_00007", file1="asane_02f_00121", file2="asane_02f_00205", file4="asane_02f_00401", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1210", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You're gonna throw in the baby and make it a five-way!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“包含婴儿的实质5P！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「包含嬰兒的實質5P！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00371",
		linknext = "0076_00373",
		line = 4855,
	},
	["0076_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't think any of us know what we're saying anymore. All meaning and reason have been lost.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论是谁，都陷入了连自己在说什么都不知道的混沌旋涡之中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論是誰，都陷入了連自己在說什麼都不知道的混沌旋渦之中。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00372",
		linknext = "0076_00374",
		line = 4865,
	},
	["0076_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our shouted comments become more and more incoherent, and the discussion descends further into absurdity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渐渐地，大家嘴里喊出的话语也变得支离破碎，这样一来，已经没人能让这个情况平静下来了————",
					{"rt2"},
				},
			},
			tw = {
				{
					"漸漸地，大家嘴裡喊出的話語也變得支離破碎，這樣一來，已經沒人能讓這個情況平靜下來了————",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00373",
		linknext = "0076_00375",
		line = 4875,
	},
	["0076_00375"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, even though the exchange is ridiculous, it's still a ton of fun.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，这种傻里傻气的应答，也真的非常开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，這種傻裡傻氣的應答，也真的非常開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00374",
