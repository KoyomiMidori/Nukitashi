	["0076_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It wasn't that long ago that you couldn't get anywhere near social media or news sites without being bombarded with talk of the illegal sex trade or what they called the nationwide 'perversion conversion', but now no one really talks about them anymore.",
					{"rt2"},
				},
			},
			cn = {
