					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, were you worried that after the SS was restructured, you'd be sent home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，是因为SS今后的事情，所以可能过不了暑假是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，是因為SS今後的事情，所以可能過不了暑假是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00283",
		linknext = "0076_00285",
		line = 3622,
	},
	["0076_00285"] = {
