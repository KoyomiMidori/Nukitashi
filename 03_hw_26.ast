	["0076_00153"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00105", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
