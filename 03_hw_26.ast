	["0076_00291"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg050126-1-1", set="hcg050126", path=":ev/hcg050126/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050126-1-1", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0836", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The actual exam, or the supplementary one?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……你是问正式考试还是补考？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……你是問正式考試還是補考？」",
					{"rt2"},
				},
