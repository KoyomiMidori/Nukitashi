		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050123-1-1", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1852", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh! Speaking of that, I'm glad Rei-chan was able to join us for our summer vacation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“说到太好了，礼酱也平安地迎来了暑假，真是太好了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「說到太好了，禮醬也平安地迎來了暑假，真是太好了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00280",
		linknext = "0076_00282",
		line = 3580,
	},
	["0076_00282"] = {
		{"evset", file="hcg05", set="hcg05", path=":ev/hcg05/"},
		{"evset", file="hcg050124-12", set="hcg050124", path=":ev/hcg050124/"},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg050124-12", x=-5, y=-5, path=":cg/hcg05/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0832", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“H-Hinami!? You weren't meant to bring that up...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔！？雏、雏见，那件事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔！？雛、雛見，那件事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00281",
		linknext = "0076_00283",
		line = 3598,
	},
	["0076_00283"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
