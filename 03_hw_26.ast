			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei-chan did so bad on her finals that she was worried she might need to spend the whole vacation studying!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱她啊，期末考试成绩非常差，所以暑假里可能要一直补习。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬她啊，期末考試成績非常差，所以暑假裡可能要一直補習。」",
					{"rt2"},
				},
			},
		},
