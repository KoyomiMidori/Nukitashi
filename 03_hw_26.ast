			tw = {
				{
					"恐怕，那也是仁浦先生事先計劃好的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00061",
		linknext = "0076_00063",
		line = 751,
	},
	["0076_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The uproar from the islanders was nothing when faced with the international criticism the cemented the removal of the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"居民的反对什么的，在世人谴责的巨大压力下根本不起作用，条例的废除用不了多久就定了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"居民的反對什麼的，在世人譴責的巨大壓力下根本不起作用，條例的廢除用不了多久就定了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00062",
		linknext = "0076_00064",
		line = 761,
	},
	["0076_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The irony of the so-called 'majority' that we were fighting all along being shut down by an even larger, more powerful majority is not lost on me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一直以来都在对抗多数派的我们，最后利用了更大的力量拉下了帷幕——真的非常讽刺。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一直以來都在對抗多數派的我們，最後利用了更大的力量拉下了帷幕——真的非常諷刺。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00063",
		linknext = "0076_00065",
		line = 771,
	},
	["0076_00065"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0019", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Even if we have one place where it's permissible, what's gonna happen when the law's abolished? Life without sex isn't a possibility I ever had in my data.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“但是，幸好现在还有部分地区被允许，如果真的被废除的话，到底会变得怎么样呢……不做爱的生活，我的数据里没有哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「但是，幸好現在還有部分地區被允許，如果真的被廢除的話，到底會變得怎麼樣呢……不做愛的生活，我的數據裡沒有哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00064",
		linknext = "0076_00066",
		line = 783,
	},
	["0076_00066"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“You never seemed to have data on, like, anything at all to start with, Bertie.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“伯特同学手上本来就没有任何数据吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「伯特同學手上本來就沒有任何數據吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00065",
		linknext = "0076_00067",
		line = 795,
	},
	["0076_00067"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I think it'll probably be fine in the end.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过我觉得也没那么不好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過我覺得也沒那麼不好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00066",
		linknext = "0076_00068",
		line = 807,
	},
	["0076_00068"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="obekka0011", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"おべっか"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"おべっか", "Bootlicker"},
					"“Oh, right! You're impotent, aren't you, Pussybana? Yeah, I guess it's probably fine for you, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"おべっか", "马屁精"},
					"“是吗，毕竟猫橘君是阳痿嘛……没那么不好……是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"おべっか", "馬屁精"},
					"「是嗎，畢竟貓橘君是陽痿嘛……沒那麼不好……是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00067",
		linknext = "0076_00069",
		line = 819,
	},
	["0076_00069"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00103", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="ran_01m_00001", file1="ran_01m_00106", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ran0194", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Well, I think it's terrible! I don't want it to be repealed! ...I would say that, but Rei-senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“当然不好啊！我坚决反对废除！……虽然想这么说……但礼前辈她……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「當然不好啊！我堅決反對廢除！……雖然想這麼說……但禮前輩她……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00068",
		linknext = "0076_00070",
		line = 834,
	},
	["0076_00070"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Today again?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……礼前辈今天也是那样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……禮前輩今天也是那樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00069",
		linknext = "0076_00071",
		line = 846,
	},
	["0076_00071"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00105", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0195", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“No, I think she's actually taking her first day off in a while... sigh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“不，她今天本来应该是久违的休假……唉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「不，她今天本來應該是久違的休假……唉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00070",
		linknext = "0076_00072",
		line = 860,
	},
	["0076_00072"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00106", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0196", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“She's been making arrangements for what'll happen to us going forward. Given how hard she's been working, I can't really be opposed, can I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“礼前辈针对我们在废除条例后的待遇问题四处奔波走访……这样我们根本没办法反对啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「禮前輩針對我們在廢除條例後的待遇問題四處奔波走訪……這樣我們根本沒辦法反對啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00071",
		linknext = "0076_00073",
		line = 874,
	},
	["0076_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her shoulders slump.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她无力地垂下肩膀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她無力地垂下肩膀。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00072",
		linknext = "0076_00074",
		line = 884,
	},
	["0076_00074"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0060", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I wish Sis and that empty-headded Senba-senpai would stop grumbling and just get back to work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“姐姐和三傻前辈不要再继续说个没完了，请好好工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「姐姐和三傻前輩不要再繼續說個沒完了，請好好工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00073",
		linknext = "0076_00075",
		line = 896,
	},
	["0076_00075"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0061", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“The organization will be restructured after the law is abolished. Apply yourself diligently here and secure your next posting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“废除条例后还会有组织改编。我要在这里努力工作，来争取下一个要职。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「廢除條例後還會有組織改編。我要在這裡努力工作，來爭取下一個要職。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00074",
		linknext = "0076_00076",
		line = 908,
	},
	["0076_00076"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0197", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Does anything faze you...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“凛真是不会动摇呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「凜真是不會動搖呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00075",
		linknext = "0076_00077",
		line = 920,
	},
	["0076_00077"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="obekka0012", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"おべっか"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"おべっか", "Bootlicker"},
					"“Now, now, Hanamaru, there's no need to get so down! Cheer up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"おべっか", "马屁精"},
					"“好了好了花丸酱，消沉也解决不了事情，振作起来吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"おべっか", "馬屁精"},
					"「好了好了花丸醬，消沉也解決不了事情，振作起來吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00076",
		linknext = "0076_00078",
		line = 932,
	},
	["0076_00078"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0020", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“She's right! According to my data, everything should be fine!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“说得没错。只要有我的数据，一定没问题的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「說得沒錯。只要有我的數據，一定沒問題的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00077",
		linknext = "0076_00079",
		line = 944,
	},
	["0076_00079"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0017", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Like, what data?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“虽然根本没有数据。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「雖然根本沒有數據。」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00078",
		linknext = "0076_00080",
		line = 956,
	},
	["0076_00080"] = {
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"According to my condition, the SS will continue to exist after the abolishment of the law. Discussions of their role going forward are apparently still ongoing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"按照与我的约定，即使条例被废除，SS也会继续存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"按照與我的約定，即使條例被廢除，SS也會繼續存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00079",
		linknext = "0076_00081",
		line = 968,
	},
	["0076_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't know what they'll be doing from here on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然还不知道会以什么样的形式实现——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然還不知道會以什麼樣的形式實現——",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00080",
		linknext = "0076_00082",
		line = 978,
	},
	["0076_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But even without the law, it seems to me like things will work out okay for them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但即使没有那样的条例，我觉得他们今后也能很好地相处下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但即使沒有那樣的條例，我覺得他們今後也能很好地相處下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00081",
		linknext = "0076_00083",
		line = 988,
	},
	["0076_00083"] = {
