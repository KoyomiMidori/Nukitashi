	["0076_00196"] = {
		{"fg", file="rei_01m_00007", file1="rei_01m_00119", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
