		linkback = "0076_00191",
		linknext = "0076_00193",
		line = 2405,
	},
	["0076_00193"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You plan to have a party?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要开派对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要開派對嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00192",
		linknext = "0076_00194",
		line = 2417,
	},
	["0076_00194"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1835", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah! Rei-chan's been busy every day since then. We still had the promise that we'd all eat yummy food together!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！礼酱从那之后一直很忙……所以大家一起吃好吃的东西的承诺还没实现！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！禮醬從那之後一直很忙……所以大家一起吃好吃的東西的承諾還沒實現！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00193",
		linknext = "0076_00195",
		line = 2430,
	},
	["0076_00195"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
