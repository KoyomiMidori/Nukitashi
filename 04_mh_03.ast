			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí, vi que cambiaron de lugar... Ya lo revisé con el modo de búsqueda avanzada. Siguen ahí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……话说回来，今天的配置很奇怪呢……嗯……即使用超级搜索查看，也明显有种前所未有的感觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……話說回來，今天的配置很奇怪呢……嗯……即使用超級搜索查看，也明顯有種前所未有的感覺……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00145",
		linknext = "0080_00147",
		line = 1912,
	},
	["0080_00147"] = {
