		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00118", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mierda... ¿Cómo pude hacerle eso a Yuiko? Y a Kireiko, y a Chiemi, y a Maruko... Me siento tan destrozado por haberlas insultado así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶……为什么我要做那样的事……对不起唯子……美子、智惠美、真由子——我没脸站在大家面前。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡……為什麼我要做那樣的事……對不起唯子……美子、智惠美、真由子——我沒臉站在大家面前。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00124",
		linknext = "0080_00126",
		line = 1640,
	},
	["0080_00126"] = {
