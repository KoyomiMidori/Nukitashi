	["0080_00128"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00105", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1241", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Manito, ya se me hacía, pero esta chica está mal de la cabeza. ¿Por qué no te pasas a mi lado y aprecias a las zorritas gyarus?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……哥哥，我之前就稍微察觉到了，这个女人很有问题。不如找个辣妹婊把她替换掉吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……哥哥，我之前就稍微察覺到了，這個女人很有問題。不如找個辣妹婊把她替換掉吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00127",
		linknext = "0080_00129",
		line = 1680,
	},
	["0080_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
