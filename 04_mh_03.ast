		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡En fin! Yuiko me salvó, ya, eso es todo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……总之！多亏了唯子，我得救了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……總之！多虧了唯子，我得救了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00130",
		linknext = "0080_00132",
		line = 1715,
	},
	["0080_00132"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La traje para que sirviera como una HEA, pero nunca pensé que me ayudaría así. Gracias, Yuiko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“本来是用来当诱饵的T-A-E，不过却以意外的形式发挥了作用——谢谢你，唯子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「本來是用來當誘餌的T-A-E，不過卻以意外的形式發揮了作用——謝謝你，唯子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00131",
		linknext = "0080_00133",
		line = 1727,
	},
	["0080_00133"] = {
		{"bgm", file="bgm11", vol=100},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"se", id=2, loop=0, file="se_b048"},
		{"fg", file="dw_00001", path=":fg/dw/", id=3, lv=5, head="dw", ch="dw", mw="mw", sync=0, time=450, mode=3, x=0, y=500},
		{"fgact", ch="dw", id=3, act="移動", x=0, y=-200, time=700},
		{"fgact", ch="dw", id=3, act="浮遊横", loop=6, size=5, time=50, ease="easeinout_sine"},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1956", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Wah! ¡Apareció una mujer salvaje! ¡Ah, ya me acuerdo! Es la persona inflable que usaste aquella vez, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇！？出现了一个女人！？啊，就是这个啊！是以前用过的像气球一样的人对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇！？出現了一個女人！？啊，就是這個啊！是以前用過的像氣球一樣的人對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00132",
		linknext = "0080_00134",
		line = 1751,
	},
	["0080_00134"] = {
		{"se", id=2, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así es, está llena de aire.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错，里面充了空气。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯，裡面充了空氣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00133",
		linknext = "0080_00135",
		line = 1764,
	},
	["0080_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No se inflan tan rápido, pero le puse un dispositivo especial de inflado instantáneo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一般情况下不会在一瞬间膨胀，是我自己安装了燃气产生器才让它可以瞬间膨胀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一般情況下不會在一瞬間膨脹，是我自己安裝了燃氣產生器才讓它可以瞬間膨脹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00134",
		linknext = "0080_00136",
		line = 1776,
	},
	["0080_00136"] = {
		{"fg", file="hinami_02m_00001", file3="hinami_02m_00303", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Son como los que se incluyen en los chalecos salvavidas de los aviones.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应用了类似飞机救生衣的结构。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應用了類似飛機救生衣的結構。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00135",
		linknext = "0080_00137",
		line = 1790,
	},
	["0080_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"También se puede activar de manera remota.",
					{"rt2"},
				},
			},
			cn = {
				{
					"顺便一提，它是可以进行远程操作的优秀产品。",
					{"rt2"},
				},
			},
			tw = {
				{
					"順便一提，它是可以進行遠程操作的優秀產品。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00136",
		linknext = "0080_00138",
		line = 1800,
	},
	["0080_00138"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1939", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Es más complicado de lo que parece. Me llevó mucho tiempo y muchos intentos dar con la cantidad perfecta de aire para inflarla correctamente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然看上去很简单，但要调整好空气量应该很辛苦吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然看上去很簡單，但要調整好空氣量應該很辛苦吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00137",
		linknext = "0080_00139",
		line = 1814,
	},
	["0080_00139"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00120", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1242", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, qué recuerdos. Cuando empezaste a experimentar con esto, se reventaban.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好怀念啊……刚开始还不知道该充多少气，空气老婆瞬间就炸开了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好懷念啊……剛開始還不知道該充多少氣，空氣老婆瞬間就炸開了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00138",
		linknext = "0080_00140",
		line = 1827,
	},
	["0080_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Atsuko, Yoshie, Chika...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“贵子、吉江、千鹤…………！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「貴子、吉江、千鶴…………！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00139",
		linknext = "0080_00141",
		line = 1839,
	},
	["0080_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¡Sus sacrificios no fueron en vano!",
					{"rt2"},
				},
			},
			cn = {
				{
					"你们的牺牲绝对不会白费——！",
					{"rt2"},
				},
			},
			tw = {
				{
					"你們的犧牲絕對不會白費——！",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00140",
		linknext = "0080_00142",
		line = 1849,
	},
	["0080_00142"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1940", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, no cambiemos de tema. En teoría, si pudieras pasar el análisis llamándolas bolsas de basura, nosotras también podríamos hacerlo, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊——好了好了，该把话题转回来了……如果说是垃圾袋就能过检查的话，那谁带充气娃娃都没问题吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊——好了好了，該把話題轉回來了……如果說是垃圾袋就能過檢查的話，那誰帶充氣娃娃都沒問題吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00141",
		linknext = "0080_00143",
		line = 1865,
	},
	["0080_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Me está pidiendo que me separe de mis novias?",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说——要让她们离开我……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說——要讓她們離開我……？",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00142",
		linknext = "0080_00144",
		line = 1875,
	},
	["0080_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que es quisquilloso. No puedo dejarme llevar por mis sentimientos personales cuando la castidad de mis compañeras está en juego.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——我知道的，现在不是该让私人感情介入的时候。这关系着同伴的贞操。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——我知道的，現在不是該讓私人感情介入的時候。這關係著同伴的貞操。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00143",
		linknext = "0080_00145",
		line = 1885,
	},
	["0080_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hoy andaba rara la SS. Puede que las necesitemos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS的动向也有点奇怪……今后确实需要更多的数量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS的動向也有點奇怪……今後確實需要更多的數量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00144",
		linknext = "0080_00146",
		line = 1897,
	},
	["0080_00146"] = {
		{"se", id=0, loop=0, file="se_a118"},
		{"fg", file="asane_01f_00001", file1="asane_01f_00104", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[4300] = {
