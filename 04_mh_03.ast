	["0080_00209"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
			[5600] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=5600, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0587", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, por dentro también. No puedo dejar de gemir, y mamá siempre se enoja conmigo porque no puede oír la tele. Pero mi ano...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“尤其是里面特别弱，每次都会叫出声来，所以妈妈经常骂我说‘听不到电视的声音啦！’，可是肛门的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「尤其是裡面特別弱，每次都會叫出聲來，所以媽媽經常罵我說『聽不到電視的聲音啦！』，可是肛門的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00208",
		linknext = "0080_00210",
		line = 2755,
	},
	["0080_00210"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, ya entendimos. Bájale un poquito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……知道了知道了……你能稍微安静点吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……知道了知道了……你能稍微安靜點嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00209",
		linknext = "0080_00211",
		line = 2767,
	},
	["0080_00211"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[800] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0588", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Eh? ¡Ah, v-vale! ¡Lo siento, me puse a balbucear, ¿verdad?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶？啊、好、好的！对对对对不起，我突然就开始说起自己的事情……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸？啊、好、好的！對對對對不起，我突然就開始說起自己的事情……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00210",
		linknext = "0080_00212",
		line = 2784,
	},
	["0080_00212"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, pero ese no es el problema...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……说自己的事情倒是没什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……說自己的事情倒是沒什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00211",
		linknext = "0080_00213",
		line = 2796,
	},
	["0080_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su comentario nos deja sin palabras, incluso Asa-chan prefiere guardar silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这唐突的发言让大家不禁语塞，甚至连麻沙酱都说不出话来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這唐突的發言讓大家不禁語塞，甚至連麻沙醬都說不出話來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00212",
		linknext = "0080_00214",
		line = 2806,
	},
	["0080_00214"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00107", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1942", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno... Dejando de lado lo de tu ano...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃……肛门的事情先放一边……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃……肛門的事情先放一邊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00213",
		linknext = "0080_00215",
		line = 2821,
	},
	["0080_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las tres muñecas inflables fueron descartadas. ¿Qué pasará con la imagen moderna y tecnológica de nuestra base si también dejamos de lado su ano?",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在就有3个充气娃娃了，如果再加上肛门的话，我们的基地会变成什么样呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在就有3個充氣娃娃了，如果再加上肛門的話，我們的基地會變成什麼樣呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00214",
		linknext = "0080_00216",
		line = 2831,
	},
	["0080_00216"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, tengo que olvidarlo. Tenemos que decidir qué vamos a hacer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，不要想肛门了——必须考虑今后的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，不要想肛門了——必須考慮今後的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00215",
		linknext = "0080_00217",
		line = 2842,
	},
	["0080_00217"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bgm", file="bgm11", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora que sabemos la edad de Fumino, deberíamos utilizar esa información para orientar nuestra búsqueda de más datos, pero me preocupa lo que vaya a hacer la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然知道了文乃的年龄，那就把这件事当作寻找情报的主轴吧——但FS的动向果然还是令人在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然知道了文乃的年齡，那就把這件事當作尋找情報的主軸吧——但FS的動向果然還是令人在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00216",
		linknext = "0080_00218",
		line = 2859,
	},
	["0080_00218"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Al ver lo que pasó hoy, deberíamos tener mucho cuidado y no llamar la atención.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天也发生了那样的事情，也许还是不要做出太显眼的事情比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天也發生了那樣的事情，也許還是不要做出太顯眼的事情比較好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00217",
		linknext = "0080_00219",
		line = 2871,
	},
	["0080_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que a partir de ahora tendremos que andar con muchísimo más cuidado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样一来，FS的监视就成为了问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣一來，FS的監視就成為了問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00218",
		linknext = "0080_00220",
		line = 2881,
	},
	["0080_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hasta ahora, hemos logrado pasar desapercibidos ante la SS gracias a nuestras ideas, pero hay límites evidentes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然到目前为止采取了很多对策，但如果想边防止被FS怀疑边调查的话，就会很绑手绑脚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然到目前為止採取了很多對策，但如果想邊防止被FS懷疑邊調查的話，就會很綁手綁腳。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00219",
		linknext = "0080_00221",
		line = 2891,
	},
	["0080_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun así, no podemos dejar que eso nos detenga. ¿Solo podemos seguir haciendo lo que hemos estado haciendo hasta ahora?",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是也不能因此乱来——眼下还是只能继续以前的做法吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是也不能因此亂來——眼下還是只能繼續以前的做法嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00220",
		linknext = "0080_00222",
		line = 2901,
	},
	["0080_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Limita nuestra capacidad para recabar información, pero realmente no tenemos más opciones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这样要收集情报实在有些困难，但如果没有其他方法，也只好这么做了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這樣要收集情報實在有些困難，但如果沒有其他方法，也只好這麼做了。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00221",
		linknext = "0080_00223",
		line = 2911,
	},
	["0080_00223"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por ahora, daremos por terminado el día y lo retomaremos mañana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天先暂时解散，明天再想想寻找文乃的方法吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天先暫時解散，明天再想想尋找文乃的方法吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00222",
		linknext = "0080_00224",
		line = 2921,
	},
	["0080_00224"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0589", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, um... esto, se me ocurre algo, pero no estoy segura...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那、那个——呃，我不知道该不该说意见……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那、那個——呃，我不知道該不該說意見……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00223",
		linknext = "0080_00225",
		line = 2934,
	},
	["0080_00225"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Hotori? ¿Se te ocurrió algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔……难道你有什么好想法吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔……難道你有什麼好想法嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00224",
		linknext = "0080_00226",
		line = 2946,
	},
	["0080_00226"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0590", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Ah, no, no es para tanto! A ver, es una posibilidad, pero sinceramente, no sé qué tan bien funcionará...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，不是！只是说说看而已……老实说，我也不知道能不能顺利进行……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，不是！只是說說看而已……老實說，我也不知道能不能順利進行……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00225",
		linknext = "0080_00227",
		line = 2963,
	},
	["0080_00227"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora mismo estamos buscando soluciones desesperadas. Además, ayer fuiste la única que nos dijo algo relevante de Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——现在不管再小的希望都要试试。而且，昨天给出搜索文乃的提示的人也是你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——現在不管再小的希望都要試試。而且，昨天給出搜索文乃的提示的人也是你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00226",
		linknext = "0080_00228",
		line = 2975,
	},
	["0080_00228"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tranquila, solo dilo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以不用担心，说说吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以不用擔心，說說吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00227",
		linknext = "0080_00229",
		line = 2987,
	},
	["0080_00229"] = {
		{"text"},
		text = {
