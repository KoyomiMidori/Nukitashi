					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What are those hip motions!? Don't let your sex get complacent! You think you can just rub your crotches together and suddenly you're fucking!? I've seen more action from goddamn bumper cars!!”",
