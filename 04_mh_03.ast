		linkback = "0080_00215",
		linknext = "0080_00217",
		line = 2842,
	},
	["0080_00217"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bgm", file="bgm11", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now that we know Fumino's age, we should use that to direct our searches for more information, but I'm worried about the SS's movements.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然知道了文乃的年龄，那就把这件事当作寻找情报的主轴吧——但FS的动向果然还是令人在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然知道了文乃的年齡，那就把這件事當作尋找情報的主軸吧——但FS的動向果然還是令人在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00216",
		linknext = "0080_00218",
		line = 2859,
	},
	["0080_00218"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Considering what happened today, we should probably take extra care to avoid drawing attention.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天也发生了那样的事情，也许还是不要做出太显眼的事情比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天也發生了那樣的事情，也許還是不要做出太顯眼的事情比較好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00217",
		linknext = "0080_00219",
		line = 2871,
	},
	["0080_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Looks like we'll need to operate under more and more surveillance from now on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样一来，FS的监视就成为了问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣一來，FS的監視就成為了問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00218",
		linknext = "0080_00220",
		line = 2881,
	},
	["0080_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thus far, we've been able to barely fly under the SS' radar with our countermeasures, but there are limits to our capabilities.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然到目前为止采取了很多对策，但如果想边防止被FS怀疑边调查的话，就会很绑手绑脚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然到目前為止採取了很多對策，但如果想邊防止被FS懷疑邊調查的話，就會很綁手綁腳。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00219",
		linknext = "0080_00221",
		line = 2891,
	},
	["0080_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, we can't let that stop us. Is it all we can do to just continue as we have been?",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是也不能因此乱来——眼下还是只能继续以前的做法吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是也不能因此亂來——眼下還是只能繼續以前的做法嗎？",
					{"rt2"},
				},
			},
		},
