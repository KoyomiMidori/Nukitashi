					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Ah, r-right! S-S-S-Sorry, I just started rambling, didn't I!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶？啊、好、好的！对对对对不起，我突然就开始说起自己的事情……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸？啊、好、好的！對對對對不起，我突然就開始說起自己的事情……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00210",
