			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Je. Bueno, vamos a tener otro quinteto así que ya tenemos que irnos. Que tengas un buen día, presidenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呵呵……那么，还有第二轮的5P在等着我们，先告辞了。也祝风纪委员长——有个变态的一天。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呵呵……那麼，還有第二輪的5P在等著我們，先告辭了。也祝風紀委員長——有個變態的一天。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00306",
		linknext = "0080_00308",
		line = 4072,
	},
