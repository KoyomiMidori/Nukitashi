			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They found her deflated during the bag check and asked me what she was.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有次检查的时候，没有空气的唯子被发现了……他们问我这是什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
