			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, I noticed that they changed their postings today... Yeah, just checked with super search mode. They're still there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……话说回来，今天的配置很奇怪呢……嗯……即使用超级搜索查看，也明显有种前所未有的感觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……話說回來，今天的配置很奇怪呢……嗯……即使用超級搜索查看，也明顯有種前所未有的感覺……」",
					{"rt2"},
				},
