					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y cuando más la necesitaba, ¿el torrente de emociones que sentía hizo que desarrollara un alma? Increíble.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了回应我的感情，唯子在这个紧要关头获得了灵魂——这种可能性并不低吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了回應我的感情，唯子在這個緊要關頭獲得了靈魂——這種可能性並不低吧。",
					{"rt2"},
				},
			},
