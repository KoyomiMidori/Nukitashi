	["0080_00142"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1940", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“All right, all right, back on track. Theoretically, if you could get them past the bag check by calling them garbage bags, any of us could do it, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊——好了好了，该把话题转回来了……如果说是垃圾袋就能过检查的话，那谁带充气娃娃都没问题吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊——好了好了，該把話題轉回來了……如果說是垃圾袋就能過檢查的話，那誰帶充氣娃娃都沒問題吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00141",
		linknext = "0080_00143",
		line = 1865,
	},
	["0080_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is she asking me to part with my girlfriends?",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说——要让她们离开我……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說——要讓她們離開我……？",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00142",
		linknext = "0080_00144",
		line = 1875,
	},
	["0080_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know, I'm just being petty. There's no time to get wrapped up in my personal feelings with my companions' chastity is on the line.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——我知道的，现在不是该让私人感情介入的时候。这关系着同伴的贞操。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——我知道的，現在不是該讓私人感情介入的時候。這關係著同伴的貞操。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00143",
		linknext = "0080_00145",
		line = 1885,
	},
	["0080_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
