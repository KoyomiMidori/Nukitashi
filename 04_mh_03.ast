				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There was something up with the SS today. We might need them going forward.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS的动向也有点奇怪……今后确实需要更多的数量。”",
