		linkback = "0080_00119",
		linknext = "0080_00121",
		line = 1572,
	},
	["0080_00121"] = {
		{"fg", file="hinami_01m_00001", file3="hinami_01m_00303", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me mira desconcertadas, no entienden mi respuesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家好像不能理解我的回答，都歪着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家好像不能理解我的回答，都歪著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00120",
		linknext = "0080_00122",
		line = 1586,
	},
	["0080_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La encontraron desinflada durante el análisis y me preguntaron qué era.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有次检查的时候，没有空气的唯子被发现了……他们问我这是什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有次檢查的時候，沒有空氣的唯子被發現了……他們問我這是什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00121",
		linknext = "0080_00123",
		line = 1598,
	},
	["0080_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Los habitantes de la Isla Seiran no saben nada de muñecas, así que les dije que solo era una bolsa de basura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那些青蓝岛的家伙，根本不知道什么是充气娃娃……我立刻就说这是垃圾袋糊弄他们……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那些青藍島的傢伙，根本不知道什麼是充氣娃娃……我立刻就說這是垃圾袋糊弄他們……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00122",
		linknext = "0080_00124",
		line = 1609,
	},
	["0080_00124"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
