					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y pues dijeron que no había problema...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后他们就接受了……”",
					{"rt2"},
