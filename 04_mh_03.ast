		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero esta historia sexual que cuenta Hotori es bastante extravagante. Incluso la presidenta quedó pálida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，畔的口中不断涌出了不得了的性交谭——听到那些话，就连风纪委员长都无法应对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，畔的口中不斷湧出了不得了的性交譚——聽到那些話，就連風紀委員長都無法應對。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00305",
		linknext = "0080_00307",
		line = 4058,
	},
	["0080_00307"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00121", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
