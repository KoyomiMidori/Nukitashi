	["0080_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yuiko fue la primera muñeca inflable con la que lo hice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"唯子是我生平第一次得到的充气娃娃。",
					{"rt2"},
				},
