	["0080_00132"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I brought her to serve as a decoy TAE, but I never thought she's help me like this. Thank you, Yuiko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“本来是用来当诱饵的T-A-E，不过却以意外的形式发挥了作用——谢谢你，唯子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「本來是用來當誘餌的T-A-E，不過卻以意外的形式發揮了作用——謝謝你，唯子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00131",
		linknext = "0080_00133",
		line = 1727,
	},
	["0080_00133"] = {
