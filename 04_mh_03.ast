			en = {
				{
					"Debería agradecerle a los dioses por dejarme vivir esta experiencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这应该是一生只能见到一次的珍贵光景吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這應該是一生只能見到一次的珍貴光景吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00164",
		linknext = "0080_00166",
		line = 2172,
	},
	["0080_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun en vida, siento que estoy en el paraíso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但如果可以选择的话，我宁愿选没有看过这种景象的人生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但如果可以選擇的話，我寧願選沒有看過這種景象的人生。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00165",
		linknext = "0080_00167",
		line = 2182,
	},
	["0080_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin. ¿Qué deberíamos hacer a continuación?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好了，那关于今后要怎么办——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好了，那關於今後要怎麼辦——」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00166",
		linknext = "0080_00168",
		line = 2194,
	},
	["0080_00168"] = {
		{"bgm", stop=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=4, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=5, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=6, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=0, loop=0, file="se_a190"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nuestra conversación es interrumpida por un sonido que no habíamos escuchado en mucho tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这时——我听到了很久没听到的那个声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這時——我聽到了很久沒聽到的那個聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00167",
		linknext = "0080_00169",
		line = 2214,
	},
	["0080_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De pronto, me enderezo y miro el monitor central.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我反射性地挺直脊椎，视线无意识地望向中央显示器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我反射性地挺直脊椎，視線無意識地望向中央顯示器。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00168",
		linknext = "0080_00170",
		line = 2224,
	},
	["0080_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tras momento de estática, el rostro del viejo apareció en el monitor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随后——显示器上出现了杂讯，然后浮现出了老人的身影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨後——顯示器上出現了雜訊，然後浮現出了老人的身影。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00169",
		linknext = "0080_00171",
		line = 2234,
	},
	["0080_00171"] = {
		{"bgm", file="bgm04.5", vol=100},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0080", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“¿Cuánto han avanzado?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00170",
		linknext = "0080_00172",
		line = 2248,
	},
	["0080_00172"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hemos superado con éxito el evento del Rey del Tiroteo. Tal y como se nos pidió, ahora estamos buscando a Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘击坠王’全员平安渡过。现在遵从主要指命，对‘文乃’进行搜索。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『擊墜王』全員平安渡過。現在遵從主要指命，對『文乃』進行搜索。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00171",
		linknext = "0080_00173",
		line = 2260,
	},
	["0080_00173"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0081", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“¿Han avanzado de manera favorable?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“进展如何？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「進展如何？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00172",
		linknext = "0080_00174",
		line = 2273,
	},
	["0080_00174"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hemos hecho todo lo posible por recabar información, pero no hemos conseguido nada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然全体人员都在收集情报——但坦白说，情况并没有进展。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然全體人員都在收集情報——但坦白說，情況並沒有進展。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00173",
		linknext = "0080_00175",
		line = 2285,
	},
	["0080_00175"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0082", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Ya veo. Deben encontrarla cuanto antes. Dicho eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“是吗，我明白了。快点把她找出来。那么——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「是嗎，我明白了。快點把她找出來。那麼——」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00174",
		linknext = "0080_00176",
		line = 2298,
	},
	["0080_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mierda, aún no se puede ir...",
					{"rt2"},
				},
			},
			cn = {
				{
					"糟糕，要被挂断了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"糟糕，要被掛斷了——",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00175",
		linknext = "0080_00177",
		line = 2308,
	},
	["0080_00177"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Podría esperar un momento, por favor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——能稍等一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——能稍等一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00176",
		linknext = "0080_00178",
		line = 2320,
	},
	["0080_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No necesito mucho, pero es que sí necesitamos información sobre ella. Hasta el más mínimo detalle podría ser valioso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"哪怕是一点点也好。任何小事都没关系，我们需要文乃的情报。",
					{"rt2"},
				},
			},
			tw = {
				{
					"哪怕是一點點也好。任何小事都沒關係，我們需要文乃的情報。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00177",
		linknext = "0080_00179",
		line = 2330,
	},
	["0080_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si no le saco información, no lograremos nada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果现在不问点什么出来，情况只会越来越糟。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果現在不問點什麼出來，情況只會越來越糟。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00178",
		linknext = "0080_00180",
		line = 2340,
	},
	["0080_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora mismo, la SS y la OSS se encuentran en máxima alerta. Nuestra capacidad para buscar y recopilar información se ve mermada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们目前的现状——FS和SHO的警戒态势加强了，搜查也受到了很大的行动限制。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們目前的現狀——FS和SHO的警戒態勢加強了，搜查也受到了很大的行動限制。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00179",
		linknext = "0080_00181",
		line = 2351,
	},
	["0080_00181"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nos preocupa mucho que buscar sin pistas los termine atrayendo hacia nosotros.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果毫无线索地盲目寻找——我很担心会不会就此被他们抓到我们的空隙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果毫無線索地盲目尋找——我很擔心會不會就此被他們抓到我們的空隙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00180",
		linknext = "0080_00182",
		line = 2363,
	},
	["0080_00182"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0083", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“¿Necesitan información sobre Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——你是要我告诉你文乃的情报吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——你是要我告訴你文乃的情報嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00181",
		linknext = "0080_00183",
		line = 2376,
	},
	["0080_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se dio cuenta, siento cómo el sudor me baja por la sien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被说中了，我冷汗直冒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被說中了，我冷汗直冒。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00182",
		linknext = "0080_00184",
		line = 2386,
	},
	["0080_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su intensidad me deja sin aliento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"快要输给他的气魄了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"快要輸給他的氣魄了。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00183",
		linknext = "0080_00185",
		line = 2396,
	},
	["0080_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero si retrocedo, todo habrá sido en vano.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但要是在这里退缩的话，这份执着就会失去意义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但要是在這裡退縮的話，這份執著就會失去意義。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00184",
		linknext = "0080_00186",
		line = 2406,
	},
	["0080_00186"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si nos proporciona información sobre Fumino... la habremos encontrado cuando se vuelva a comunicar con nosotros.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——如果能得到关于文乃的情报……在下次联络之前，我一定会找到她的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——如果能得到關於文乃的情報……在下次聯絡之前，我一定會找到她的。」",
					{"rt2"},
				},
			},
		},
