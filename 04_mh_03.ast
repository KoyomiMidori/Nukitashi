	},
	["0080_00207"] = {
		{"bgm", stop=1},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0586", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Mi ano está indefenso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我想是肛门吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我想是肛門吧。」",
