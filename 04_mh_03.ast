					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, una chica que llevara uno de estos levantaría muchas sospechas, ¿no? Así que pensé en llevarlo yo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让女生拿女人型的充气娃娃不太自然，所以我才临时让自己拿的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「讓女生拿女人型的充氣娃娃不太自然，所以我才臨時讓自己拿的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00113",
		linknext = "0080_00115",
		line = 1495,
	},
	["0080_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además... ¿Yuiko? Es mi waifu. No dejaría que nadie más que yo le pusiera un dedo encima.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最重要的是——我的妻子唯子不能寄放在别人那里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最重要的是——我的妻子唯子不能寄放在別人那裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00114",
		linknext = "0080_00116",
		line = 1507,
	},
	["0080_00116"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0580", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Pero no revisan las bolsas? ¿No es por eso que le pediste a Nanase que se quedara con los EAT?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦……但你是怎么通过随身物品检查的呢？我记得是这个原因才让奈奈濑同学拿着E-A-T的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦……但你是怎麼通過隨身物品檢查的呢？我記得是這個原因才讓奈奈瀨同學拿著E-A-T的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00115",
		linknext = "0080_00117",
		line = 1521,
	},
	["0080_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Son HEAs... ¿Te dio hambre o qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是T-A-E……你肚子饿了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是T-A-E……你肚子餓了嗎？」",
