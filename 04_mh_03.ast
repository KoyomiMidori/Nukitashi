			},
			en = {
				{
					name = {"防人老人", "???"},
					"“... Ah, ¿sí? Muy bien, te haré caso. Escucha con atención, no lo voy a repetir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——哦，有趣，那我就信一次你的虚张声势吧。我只说一次。好好听着——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——哦，有趣，那我就信一次你的虛張聲勢吧。我只說一次。好好聽著——」",
					{"rt2"},
