				{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1956", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Whoa!? A wild woman appeared! Oh, I remember this! It's the inflatable person you used that one time, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇！？出现了一个女人！？啊，就是这个啊！是以前用过的像气球一样的人对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇！？出現了一個女人！？啊，就是這個啊！是以前用過的像氣球一樣的人對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00132",
		linknext = "0080_00134",
		line = 1751,
	},
	["0080_00134"] = {
		{"se", id=2, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's right. She's full of air.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错，里面充了空气。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯，裡面充了空氣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00133",
		linknext = "0080_00135",
		line = 1764,
	},
	["0080_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They don't normally inflate this quickly, but I fitted her with a special instant inflation device.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一般情况下不会在一瞬间膨胀，是我自己安装了燃气产生器才让它可以瞬间膨胀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一般情況下不會在一瞬間膨脹，是我自己安裝了燃氣產生器才讓它可以瞬間膨脹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00134",
		linknext = "0080_00136",
		line = 1776,
	},
	["0080_00136"] = {
		{"fg", file="hinami_02m_00001", file3="hinami_02m_00303", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's like the ones that are put into airplane life-jackets.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应用了类似飞机救生衣的结构。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應用了類似飛機救生衣的結構。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00135",
		linknext = "0080_00137",
		line = 1790,
	},
	["0080_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's also remote-activated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"顺便一提，它是可以进行远程操作的优秀产品。",
					{"rt2"},
				},
			},
			tw = {
				{
					"順便一提，它是可以進行遠程操作的優秀產品。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00136",
		linknext = "0080_00138",
		line = 1800,
	},
	["0080_00138"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1939", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's more complicated than it looks. It took a lot of trial and error to get the perfect amount of air to inflate them properly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然看上去很简单，但要调整好空气量应该很辛苦吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然看上去很簡單，但要調整好空氣量應該很辛苦吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00137",
		linknext = "0080_00139",
		line = 1814,
	},
	["0080_00139"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00120", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1242", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, that brings back memories. When you first started experimenting with this, they'd just pop immediately.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好怀念啊……刚开始还不知道该充多少气，空气老婆瞬间就炸开了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好懷念啊……剛開始還不知道該充多少氣，空氣老婆瞬間就炸開了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00138",
		linknext = "0080_00140",
		line = 1827,
	},
	["0080_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
