				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Si no escuché mal, dijiste que la energía fluía desde tus manos y pies... hasta tu polla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是，你刚才确实这么说了……从手脚的尾端涌来了大量的能量……小鸡鸡也被勒住……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是，你剛才確實這麼說了……從手腳的尾端湧來了大量的能量……小雞雞也被勒住……」",
					{"rt2"},
				},
			},
		},
