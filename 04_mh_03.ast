		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0593", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“El quinteto fue fantástico. Probablemente fue el mejor quitento de la historia. ¡Sé que a la presidenta le habría encantado verlo...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是非常激烈的5P哦……这世上没有比那更惊人的5P了……真想让风纪委员长也看一看——！”",
