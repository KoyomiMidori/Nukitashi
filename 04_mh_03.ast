	["0080_00249"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00118", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0593", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The fivesome was really fantastic. Probably the best fivesome that's ever been had. I'm sure that even the disciplinary committee president would've loved to watch!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是非常激烈的5P哦……这世上没有比那更惊人的5P了……真想让风纪委员长也看一看——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是非常激烈的5P哦……這世上沒有比那更驚人的5P了……真想讓風紀委員長也看一看——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00248",
		linknext = "0080_00250",
		line = 3325,
	},
	["0080_00250"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I internally fist-pump, seeing her response to our prattling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看到一下子被说了一大堆话的风纪委员长的反应，我在内心握紧了拳头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看到一下子被說了一大堆話的風紀委員長的反應，我在內心握緊了拳頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00249",
		linknext = "0080_00251",
		line = 3337,
	},
	["0080_00251"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were successful at making her believe we had a fivesome. That's the first step achieved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"成功让他相信我们做了5P了。这样第一阶段就突破了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"成功讓他相信我們做了5P了。這樣第一階段就突破了。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00250",
