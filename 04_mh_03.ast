			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, deep inside me, too. I can't stop moaning, and then Mom always gets angry at me because she can't hear the TV. But my butthole...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“尤其是里面特别弱，每次都会叫出声来，所以妈妈经常骂我说‘听不到电视的声音啦！’，可是肛门的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「尤其是裡面特別弱，每次都會叫出聲來，所以媽媽經常罵我說『聽不到電視的聲音啦！』，可是肛門的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00208",
		linknext = "0080_00210",
		line = 2755,
	},
	["0080_00210"] = {
