				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es lo más cercano que he tenido a una novia. La conozco más que las otras chicas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以和它的相处时间也最长，因此我非常爱它。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以和它的相處時間也最長，因此我非常愛它。",
					{"rt2"},
				},
