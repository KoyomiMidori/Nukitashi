		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bg", id=1, file="bg17_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"bgm", file="bgm09.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0986", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué son esos movimientos de cadera? ¡No dejes que tu sexo se vuelva complaciente! ¡¿Crees que basta con frotar sus entrepiernas y que con eso ya follan?! ¡He visto más acción en los cochecitos que se estrellan!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“腰摆的还不够！你的做爱太自以为是了！别以为光是磨蹭下半身就是做爱！只需要前前后后的话，微型汽车都能做到！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「腰擺的還不夠！你的做愛太自以為是了！別以為光是磨蹭下半身就是做愛！只需要前前後後的話，微型汽車都能做到！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00233",
		linknext = "0080_00235",
		line = 3093,
	},
	["0080_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como siempre, la presidenta del comité de moral pública está dando lecciones sexuales agresivas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长像往常一样进行着做爱的指导。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員長像往常一樣進行著做愛的指導。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00234",
		linknext = "0080_00236",
		line = 3103,
	},
	["0080_00236"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=100, mode=3, x=-400, y=0},
		{"fgact", ch="礼", id=9, act="移動", x=400, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0987", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Y tú! ¡¿No te frustra tener un compañero tan insulso y sin valor?! ¡¿Cómo puedes sentirte tan bien cuando este tipo tiene la potencia de una cortadora de césped?! ¡¿Eres un cobertizo de jardín?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你也是，跟这样的男人做爱不会不甘心吗！被这种微型汽车男干了就一脸舒服……你是车库吗！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你也是，跟這樣的男人做愛不會不甘心嗎！被這種微型汽車男操了就一臉舒服……你是車庫嗎！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00235",
		linknext = "0080_00237",
		line = 3118,
	},
	["0080_00237"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0253", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“¡Ah, nngh! Sí, sí, soy un cobertizo de jardín sucio... ¡Aah! ¡Me vengo, me vengo, me vengo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“啊，呜呜！是的，我就是丑陋的车库啊……啊……！我、我要高潮啦————！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「啊，嗚嗚！是的，我就是醜陋的車庫啊……啊……！我、我要高潮啦————！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00236",
		linknext = "0080_00238",
		line = 3130,
