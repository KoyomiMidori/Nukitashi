	},
	["0080_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The three blow-up dolls have already been put aside. What will happen to our base's cool, high-tech image if we put her anus aside, too?",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在就有3个充气娃娃了，如果再加上肛门的话，我们的基地会变成什么样呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在就有3個充氣娃娃了，如果再加上肛門的話，我們的基地會變成什麼樣呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00214",
		linknext = "0080_00216",
		line = 2831,
	},
	["0080_00216"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, I need to forget it. We need to figure out a course of action.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，不要想肛门了——必须考虑今后的事情。",
