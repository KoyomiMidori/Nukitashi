		{"extrans", sync=0, time=600, rule="eff_012_00000"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sigh... I felt like I was going to have a heart attack.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈啊……我还以为心脏要停了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈啊……我還以為心臟要停了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00187",
		linknext = "0080_00189",
		line = 2478,
	},
	["0080_00189"] = {
		{"se", id=0, loop=0, file="se_a135"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once the screen turns off, the tension leaves me all at once and I sit down on the floor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通讯结束，我虚脱地坐在地上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通訊結束，我虛脫地坐在地上。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00188",
		linknext = "0080_00190",
		line = 2489,
	},
	["0080_00190"] = {
		{"bgm", file="bgm01", vol=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1959", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“My heart was pounding like when I watch dramas. You were amazing, Tachibana!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“像在看电视剧一样心跳加速啊……好厉害啊，橘君！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「像在看電視劇一樣心跳加速啊……好厲害啊，橘君！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00189",
		linknext = "0080_00191",
		line = 2504,
	},
	["0080_00191"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haha... thanks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈……谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈……謝謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00190",
		linknext = "0080_00192",
		line = 2516,
	},
	["0080_00192"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00122", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1247", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Gotta admire his restraint to not point out the four blow-up dolls chilling in his fancy, expansive base.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“看到自己准备的基地里有4个充气娃娃也不吐槽的那个人也相当厉害啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「看到自己準備的基地裡有4個充氣娃娃也不吐槽的那個人也相當厲害啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00191",
		linknext = "0080_00193",
		line = 2529,
	},
	["0080_00193"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00119", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"fgact", ch="美岬", id=6, act="移動", x=0, y=-100, time=700},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=500},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0585", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Asane, were you counting me as one of those dolls?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“麻沙音酱是不是把我也当成充气娃娃算进去了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「麻沙音醬是不是把我也當成充氣娃娃算進去了……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00192",
		linknext = "0080_00194",
		line = 2545,
	},
	["0080_00194"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00110", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, it was worth it. We now have some kind of lead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，辛苦是有价值的……多亏了这样我才获得了新情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，辛苦是有價值的……多虧了這樣我才獲得了新情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00193",
		linknext = "0080_00195",
		line = 2559,
	},
	["0080_00195"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We now know she's two years younger than me, which I assume puts her in B-level third year. That's big.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃的年龄比我小两岁——所以应该是B等部的3年级——光知道这点就已经很有收获了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃的年齡比我小兩歲——所以應該是B等部的3年級——光知道這點就已經很有收穫了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00194",
		linknext = "0080_00196",
		line = 2571,
	},
	["0080_00196"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Where do you think we go now, Nanase? The B-level classes are in this school. You think we should investigate tomorrow?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么……奈奈濑，今后要怎么行动？B等部也在同一个学校里——明天开始去那边搜索吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼……奈奈瀨，今後要怎麼行動？B等部也在同一個學校裡——明天開始去那邊搜索嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00195",
		linknext = "0080_00197",
		line = 2585,
	},
	["0080_00197"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1941", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hmm... not sure that'd be a good idea. You think we'd be able to find her just like that after having no info for so long? Hell, just entering the B-level building would draw SS attention.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……情况会如何呢？能这么容易就找到情报如此匮乏的文乃吗……而且如果我们到B等部，应该会引起FS的猜疑吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……情況會如何呢？能這麼容易就找到情報如此匱乏的文乃嗎……而且如果我們到B等部，應該會引起FS的猜疑吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00196",
		linknext = "0080_00198",
		line = 2597,
	},
	["0080_00198"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“True. If the SS are being more on guard, then we can't afford to take careless risks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“的确……如果FS确实在警戒着这件事，那随便行动也很危险……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「的確……如果FS確實在警戒著這件事，那隨便行動也很危險……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00197",
		linknext = "0080_00199",
		line = 2609,
	},
	["0080_00199"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1960", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“If only the SS had a weakness, like being vulnerable to fire, or something!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果FS的人也有弱点就好了……怕火之类的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果FS的人也有弱點就好了……怕火之類的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00198",
		linknext = "0080_00200",
		line = 2623,
	},
	["0080_00200"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn't that most people?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那大概是全人类的弱点吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那大概是全人類的弱點吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00199",
		linknext = "0080_00201",
		line = 2635,
	},
	["0080_00201"] = {
		{"fg", mode=-1, id=3, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But a weakness? That'd be nice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，弱点吗？如果真有那样的东西就好了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，弱點嗎？如果真有那樣的東西就好了。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00200",
		linknext = "0080_00202",
		line = 2651,
	},
	["0080_00202"] = {
		{"fg", file="hinami_01m_00001", file3="hinami_01m_00303", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From our members, Wata's weakness is reaching high places.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是我们队的成员，渡酱的弱点是够不着高处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是我們隊的成員，渡醬的弱點是搆不著高處。",
					{"rt2"},
