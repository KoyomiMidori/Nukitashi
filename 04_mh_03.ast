	["0080_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Es una represalia contra el Frente Anticopulación?",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许，他们是为了对抗反交尾势力而改变了位置。",
