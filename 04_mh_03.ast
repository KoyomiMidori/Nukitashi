					name = {"淳之介"},
					"“可恶……为什么我要做那样的事……对不起唯子……美子、智惠美、真由子——我没脸站在大家面前。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡……為什麼我要做那樣的事……對不起唯子……美子、智惠美、真由子——我沒臉站在大家面前。」",
					{"rt2"},
