					name = {"淳之介", "Junnosuke"},
					"“Yeah, but the rambling itself wasn't really the problem...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……说自己的事情倒是没什么……”",
