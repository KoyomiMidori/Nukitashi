		linkback = "0080_00206",
		linknext = "0080_00208",
		line = 2726,
	},
	["0080_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Solo hay un silencio ensordecedor.",
					{"rt2"},
