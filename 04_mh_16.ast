			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“That'd really tip the scales. But how exactly do you plan to do that? You can't really use those special blow-up dolls everywhere, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“战况将会有很大的变化……但是，你打算怎么解除洗脑呢？那可不是你自夸的空气老婆能解决的问题哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「戰況將會有很大的變化……但是，你打算怎麼解除洗腦呢？那可不是你自誇的空氣老婆能解決的問題哦？」",
					{"rt2"},
				},
			},
		},
