				{"vo", file="teshima0122", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Why am I here? Wait a tick. Did this little shit just ask me why I'm here? Heh... BWAHAHAHAHAHA!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“为什么会在这里……？等一下，你刚才说我为什么会在这里？呵……哈哈哈哈哈哈哈！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「為什麼會在這裡……？等一下，你剛才說我為什麼會在這裡？呵……哈哈哈哈哈哈哈！！」",
