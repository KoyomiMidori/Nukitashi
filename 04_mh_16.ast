	["0093_00282"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like Onabuta said... I just gotta do the same thing I did to Misaki.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像女部田说的那样——像和美岬那样去做就行了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像女部田說的那樣——像和美岬那樣去做就行了。",
