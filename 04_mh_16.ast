	["0093_00071"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1545", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“What do you take me for? I'm your girlfriend. I know you well enough to know you're telling us how you honestly feel.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“请不要瞧不起我。我是淳之介君的女朋友。你说的是真心话……这我一看就知道了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「請不要瞧不起我。我是淳之介君的女朋友。你說的是真心話……這我一看就知道了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00070",
		linknext = "0093_00072",
		line = 870,
	},
	["0093_00072"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00107", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
