			},
		},
		text = {
			vo = {
				{"vo", file="ran0300", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Ooh, a new business venture under the new law? How admirable! Still, I'm here to punish the scoundrels who'd oppose it, so I don't have the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“哦，想要适应新条例……那真是优秀呢！但是现在我有惩罚抵抗新条例之人的使命……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「哦，想要適應新條例……那真是優秀呢！但是現在我有懲罰抵抗新條例之人的使命……」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00285",
		linknext = "0093_00287",
		line = 3714,
	},
	["0093_00287"] = {
		{"text"},
		text = {
