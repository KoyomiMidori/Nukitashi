		},
		linkback = "0093_00415",
		linknext = "0093_00417",
		line = 5563,
	},
	["0093_00417"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That thing wouldn't just give me a scratch if he pulled the trigger. I'd suffer quite a horrific wound from it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果被击中就不是轻伤那么简单。根据情况不同也可能会是最坏的事态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果被擊中就不是輕傷那麼簡單。根據情況不同也可能會是最壞的事態。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00416",
		linknext = "0093_00418",
		line = 5573,
	},
	["0093_00418"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I cannot, and will not, turn a blind eye to this fucking fiend.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——不能眼睁睁地看着这个恶魔逃走。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——不能眼睜睜地看著這個惡魔逃走。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00417",
		linknext = "0093_00419",
		line = 5583,
	},
	["0093_00419"] = {
		{"cgdel", id=10, lv=5, time=300, alphadel=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=11, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You really think holding on to your hostage to prop up your little kleptocracy's gonna keep making you bank forever?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“利用人质控制傀儡政权来赚钱，你真的认为能长久吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「利用人質控制傀儡政權來賺錢，你真的認為能長久嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00418",
		linknext = "0093_00420",
		line = 5601,
	},
	["0093_00420"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0131", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“No shit I do! Don't ya get it? This island's never given up on that fucked up law. Just figured I'd swoop in and bleed the motherfucker dry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“当然！你知道的吧？这可是以往与疯狂的条例勾搭在一起的岛屿啊？当然要让我尽情地榨一把！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「當然！你知道的吧？這可是以往與瘋狂的條例勾搭在一起的島嶼啊？當然要讓我盡情地榨一把！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00419",
		linknext = "0093_00421",
		line = 5613,
	},
	["0093_00421"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00124", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0132", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Still... when yer just fleecin' people into sex fer money, you get bored o' marks like that real quick. Maybe I'll start rankin' the islanders and charge fer their 'services' accordingly... Oh, right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“但是……只是从游客那里收钱做爱多没意思啊。把居民分成各个等级，等级越高费用也就越高怎么样……啊，对了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「但是……只是從遊客那裡收錢做愛多沒意思啊。把居民分成各個等級，等級越高費用也就越高怎麼樣……啊，對了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00420",
		linknext = "0093_00422",
		line = 5627,
	},
	["0093_00422"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0133", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I've heard that there's organizations usin' video games to make their bank nowadays... 'Loot boxes', I think they're called? Seems there's real scratch to be made in that shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“其他黑社会的副业好像是做游戏啊……好像说是‘转蛋’？那好像很赚钱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「其他黑社會的副業好像是做遊戲啊……好像說是『轉蛋』？那好像很賺錢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00421",
		linknext = "0093_00423",
		line = 5639,
	},
	["0093_00423"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00118", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0134", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Maybe I should apply that mindset to the islanders! Make it so fuckin' the highest-ranked drops costs a whole assload o' cash! Haha, that's gonna fuckin' slap!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“让岛上的人也这样怎么样？为了和等级高的人做爱，必须要氪金几百万才可以……哈哈！真有趣啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「讓島上的人也這樣怎麼樣？為了和等級高的人做愛，必須要氪金幾百萬才可以……哈哈！真有趣啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00422",
		linknext = "0093_00424",
		line = 5653,
	},
	["0093_00424"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This motherfucker...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙……",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙……",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00423",
		linknext = "0093_00425",
		line = 5663,
	},
	["0093_00425"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00124", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0135", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Still, we only got so many people around fer that... Maybe I should just throw in some added incentives fer an additional fee. Sex toys, freaky cosplays, all kindsa wicked shit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“但是人的数量也有限啊……如果要认真做的话，在转蛋里面加上一些成人用品和cosplay也不错呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「但是人的數量也有限啊……如果要認真做的話，在轉蛋裡面加上一些成人用品和cosplay也不錯呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00424",
		linknext = "0093_00426",
		line = 5677,
	},
	["0093_00426"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00117", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0136", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Oh, and guess what!? That beloved girlfriend o' yers might even be a ☆ Normal/Rare at BEST!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不过话说回来！你最喜欢的女朋友估计也才值☆1的白卡吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「不過話說回來！你最喜歡的女朋友估計也才值☆1的白卡吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00425",
		linknext = "0093_00427",
		line = 5691,
	},
	["0093_00427"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He only sees the island and its inhabitants as little worms he can exploit for his bottom line.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙是真的，把青蓝岛，把居住在这里的人们——只当成能够赚钱的玩具。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙是真的，把青藍島，把居住在這裡的人們——只當成能夠賺錢的玩具。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00426",
		linknext = "0093_00428",
		line = 5701,
	},
	["0093_00428"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00114", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0137", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Why the defiant look, Tachibana? Pretty sure ya said ya hate non-virgins.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真是叛逆的眼神啊橘……你明明也说过自己讨厌非处女吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真是叛逆的眼神啊橘……你明明也說過自己討厭非處女吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00427",
		linknext = "0093_00429",
		line = 5715,
	},
	["0093_00429"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if I did say that... they're still a thousand times better than a slimy motherfucker like you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可能说过吧……但是，他们比你好几千倍。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可能說過吧……但是，他們比你好幾千倍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00428",
		linknext = "0093_00430",
		line = 5727,
	},
	["0093_00430"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've made companions on this island... and we're gonna destroy not just the perverted sex law, but your scummy little hopes and dreams, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你恶心的野心和变态条例，我一定要全部摧毁——和这个岛上的同伴们一起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你噁心的野心和變態條例，我一定要全部摧毀——和這個島上的同伴們一起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00429",
		linknext = "0093_00431",
		line = 5739,
	},
	["0093_00431"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0138", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ain't that sweet... So ya trust these companions o' yers, do ya?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真美妙啊……你是说你很相信同伴是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真美妙啊……你是說你很相信同伴是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00430",
		linknext = "0093_00432",
		line = 5753,
	},
	["0093_00432"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're goddamn right I do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——说的没错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯——說的沒錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00431",
		linknext = "0093_00433",
		line = 5765,
	},
	["0093_00433"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00118", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fgact", ch="手嶋", id=8, act="振動下", loop=8, size=7.5, time=75, ease="easeinout_sine", delay2=2500},
			},
			[4000] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0139", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh... pft, heh... HAHAHAHAHA!! Ain't you a big fuckin' comedian, virginfag! Don't you remember what happened when you tried to trust the bloke right in front of ya!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“呼……呵、呵呵……哈哈哈哈哈哈！!真是有趣的玩笑啊，我说处女厨！你已经忘了自己曾经信任在你眼前的人后得到了什么后果了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「呼……呵、呵呵……哈哈哈哈哈哈！!真是有趣的玩笑啊，我說處女廚！你已經忘了自己曾經信任在你眼前的人後得到了什麼後果了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00432",
		linknext = "0093_00434",
		line = 5782,
	},
	["0093_00434"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Blow me. My companions are nothing like you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“住口……我的同伴和你不一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「住口……我的同伴和你不一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00433",
		linknext = "0093_00435",
		line = 5794,
	},
	["0093_00435"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0140", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Bullshit! They're the same! Only thing trustin' people's gonna do is make ya look like a fuckin' chump!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不对！！！是一样的！信任他人什么的只会倒霉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「不對！！！是一樣的！信任他人甚麼的只會倒霉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00434",
		linknext = "0093_00436",
		line = 5808,
	},
	["0093_00436"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that's why you'd rather brainwash people, bring them under your control? You hate the idea of being betrayed that much?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以……你才依靠洗脑来支配吗？因为害怕被背叛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以……你才依靠洗腦來支配嗎？因為害怕被背叛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00435",
		linknext = "0093_00437",
		line = 5820,
	},
	["0093_00437"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00124", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0141", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Yeah. What's wrong with that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“是啊。有什么奇怪的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「是啊。有什麼奇怪的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00436",
		linknext = "0093_00438",
		line = 5834,
	},
	["0093_00438"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The way he goes from shouting to suddenly talking quietly when challenged is unsettling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才明明还一直大声喧哗，但一被挑衅马上救恢复了冷静。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才明明還一直大聲喧嘩，但一被挑釁馬上救恢復了冷靜。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00437",
		linknext = "0093_00439",
		line = 5844,
	},
	["0093_00439"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A more obstinate motherfucker I never did see.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他很难对付。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他很難對付。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00438",
		linknext = "0093_00440",
		line = 5854,
	},
	["0093_00440"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0142", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Well, I've already brought the SS and OSS under my control, an' even made them senile old fucks bend the knee. I was just thinkin' 'bout how it'd be no fun if things was jes' gonna be smooth sailin' from now on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嘛……FS和SHO都已经支配了，那些烦死人的老头子也降服了。我正好觉得事情就这样顺利进展下去很无聊呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嘛……FS和SHO都已經支配了，那些煩死人的老頭子也降服了。我正好覺得事情就這樣順利進展下去很無聊呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00439",
		linknext = "0093_00441",
		line = 5866,
	},
	["0093_00441"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0143", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“So I'm gonna let ya off the hook fer today, since you was such a good customer to my little establishment. It'll be more fun t'watch ya go down strugglin' anyhow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我会让你活下去的，作为来我们店的回礼。你就好好挣扎取悦我吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我會讓你活下去的，作為來我們店的回禮。你就好好掙扎取悅我吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00440",
		linknext = "0093_00442",
		line = 5880,
	},
	["0093_00442"] = {
		{"fgact", ch="手嶋", id=8, act="移動", x=-200, y=0, time=600},
		{"fg", mode=-1, id=8, ch="手嶋", lv=5, time=400},
		{"se", id=0, loop=0, file="se_a069"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He holsters his gun and starts to walk away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放下枪，手嶋离去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放下槍，手嶋離去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00441",
		linknext = "0093_00443",
		line = 5894,
	},
	["0093_00443"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I'm not so naive that I'm just gonna stand here and be glad he's sparing me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"得救了——才不会有这么天真的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"得救了——才不會有這麼天真的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00442",
		linknext = "0093_00444",
		line = 5904,
	},
	["0093_00444"] = {
		{"bgm", file="bgm13", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I cannot let this man go. I mustn't let him brainwash even one more victim.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不能让他走。不能再增加更多被洗脑的受害者了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不能讓他走。不能再增加更多被洗腦的受害者了。",
					{"rt2"},
				},
			},
		},
