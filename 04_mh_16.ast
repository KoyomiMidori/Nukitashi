	["0093_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suffered deep wounds from the verbal abuse I received as a kid about this junk of mine. I'm still scarred by it now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为这个鸡巴，年幼的我被各种辱骂，让我受了很深的伤——那个心理创伤持续到了现在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為這個肉棒，年幼的我被各種辱罵，讓我受了很深的傷——那個心理創傷持續到了現在。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00020",
		linknext = "0093_00022",
		line = 270,
	},
