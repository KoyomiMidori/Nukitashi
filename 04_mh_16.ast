		{"bg", id=11, file="ttci_m010302", x=-5, y=-5, path=":cg/ttci_m/", lv=5, ev=1, time=300, bx=800, by=450},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00120", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
