		linkback = "0093_00059",
		linknext = "0093_00061",
		line = 742,
	},
	["0093_00061"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whether it be the old perverted sex law, the new one, or anything else, I'll never allow any law that allows anyone other than me to have sex with Misaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管是变态条例，还是新・变态条例——这些容许美岬和我以外的男人做爱的条例，我都绝对不能接受!”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管是變態條例，還是新・變態條例——這些容許美岬和我以外的男人做愛的條例，我都絕對不能接受!」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00060",
		linknext = "0093_00062",
		line = 754,
	},
	["0093_00062"] = {
