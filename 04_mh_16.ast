	["0093_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“After spending all of yesterday mulling it over, I realized something. My motivation here has changed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后，昨天我一直想——最后终于发现了。我的动机、我的行动理由改变了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後，昨天我一直想——最後終於發現了。我的動機、我的行動理由改變了。」",
					{"rt2"},
				},
			},
		},
