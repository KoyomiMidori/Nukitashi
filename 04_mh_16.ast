	},
	["0093_00116"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn, no sex-seekers at all. We couldn't have asked for better circumstances.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过没有性触者，对我们来说是最好的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過沒有性觸者，對我們來說是最好的……」",
