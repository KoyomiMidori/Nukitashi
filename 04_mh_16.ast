	["0093_00063"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Honestly, I'd rather be dead than do it with anyone else, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和美岬以外的人做爱什么的——我也厌恶的要死。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和美岬以外的人做愛什麼的——我也厭惡的要死。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00062",
		linknext = "0093_00064",
		line = 780,
	},
	["0093_00064"] = {
