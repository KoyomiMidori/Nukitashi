	["0093_00411"] = {
		{"se", id=1, loop=1, file="se_d031", vol=30},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I reach for my waist, but a gun is already pointed at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在我把手伸向腰部的瞬间，枪口转向了这边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在我把手伸向腰部的瞬間，槍口轉向了這邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00410",
		linknext = "0093_00412",
		line = 5499,
	},
	["0093_00412"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0128", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示", "手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Teshima"},
					"“I took on the SS, and won. What d'you think you can hope to achieve against me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "手嶋"},
					"“只是偶然战胜了FS……就以为能把我怎么样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "手嶋"},
					"「只是偶然戰勝了FS……就以為能把我怎麼樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00411",
		linknext = "0093_00413",
		line = 5511,
	},
	["0093_00413"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0129", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示", "手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Teshima"},
					"“I can read ya like a fuckin' book. You was plannin' on usin' a flashbang to stun me, then use the chance to hit me where it'd count. How's that? Did I win the $64 question?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "手嶋"},
					"“你的想法我了如指掌。用闪光弹夺走视力的瞬间攻击要害——怎么样，猜对了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "手嶋"},
					"「你的想法我瞭如指掌。用閃光彈奪走視力的瞬間攻擊要害——怎麼樣，猜對了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00412",
		linknext = "0093_00414",
		line = 5523,
	},
	["0093_00414"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
