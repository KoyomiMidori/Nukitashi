		},
		linkback = "0093_00040",
		linknext = "0093_00042",
		line = 532,
	},
	["0093_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All this time, I've been eagerly pursuing the downfall of the perverted sex law. I've been telling myself it was for my own ideals, or that it was for Asa's sake, but deep down I think I just wanted revenge on the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到目前为止，我一边说着为了自己的自尊，为了麻沙酱——内心的某处有着想报复这个岛的念头……因此，才不遗余力地想要摧毁条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到目前為止，我一邊說著為了自己的自尊，為了麻沙醬——內心的某處有著想報復這個島的念頭……因此，才不遺餘力地想要摧毀條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00041",
		linknext = "0093_00043",
		line = 544,
	},
	["0093_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Revenge for being bullied when I was young.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——因为过去被欺负了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——因為過去被欺負了。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00042",
		linknext = "0093_00044",
		line = 554,
	},
	["0093_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For how my savior was hurt by non-virgins and sluts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——因为非处女和天天做爱的男人伤害了我的恩人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——因為非處女和天天做愛的男人傷害了我的恩人。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00043",
		linknext = "0093_00045",
		line = 564,
	},
	["0093_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now, the Yakuza control the island. Public order is in shambles. In a way, I think I've had my revenge.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在，岛实际上是被黑社会支配——青蓝岛的秩序开始混乱了。从某个意义上来说，也许可以说是实现了复仇。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在，島實際上是被黑社會支配——青藍島的秩序開始混亂了。從某個意義上來說，也許可以說是實現了復仇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00044",
		linknext = "0093_00046",
		line = 575,
	},
	["0093_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not satisfied, though. Not in the least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，我的心并没有因此而放晴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，我的心並沒有因此而放晴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00045",
		linknext = "0093_00047",
		line = 587,
	},
	["0093_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought it was because I wasn't the one who made it happen, or because it was done by people who were already outlaws.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为不是自己亲手实现的……因为是不法者做的……我思考了很多。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為不是自己親手實現的……因為是不法者做的……我思考了很多。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00046",
		linknext = "0093_00048",
		line = 598,
	},
