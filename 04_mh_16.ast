	["0093_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wearing our uniforms while we collect signatures might draw SS attention, so we're wearing our regular clothes just to be safe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果穿着制服收集签名可能会被FS发现，所以为了谨慎起见，所有人都穿着便服。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果穿著制服收集簽名可能會被FS發現，所以為了謹慎起見，所有人都穿著便服。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00098",
		linknext = "0093_00100",
		line = 1271,
	},
	["0093_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Either that or it's just more comfortable this way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，这也不过是一种心里安慰而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，這也不過是一種心理安慰而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00099",
		linknext = "0093_00101",
		line = 1281,
