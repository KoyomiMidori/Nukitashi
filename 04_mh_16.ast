		{"se", id=0, loop=0, file="se_a030"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0299", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I heard there were a bunch of dissidents opposing the new perverted sex law around here, so I came to punish them. Tachibana, was it you!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“我听说有人对新・变态条例不满所以准备来制裁他……橘君，是你吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「我聽說有人對新・變態條例不滿所以準備來制裁他……橘君，是你嗎！？」",
					{"rt2"},
				},
			},
		},
