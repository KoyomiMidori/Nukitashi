					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oh, nothing... I just wanna say that I'm sorry. For always being so selfish and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不，没什么……一直以来真对不起哦，你总是被我的任性耍得团团转。”",
