	["0093_00117"] = {
		{"fg", file="misaki_01f_00002", file1="misaki_01f_00114", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1556", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Junnosuke, is it time for us to head out, too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“淳之介君，我们也差不多要出发了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「淳之介君，我們也差不多要出發了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00116",
		linknext = "0093_00118",
		line = 1473,
	},
	["0093_00118"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not yet. Can you hold on a bit?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……能再等一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……能再等一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00117",
		linknext = "0093_00119",
		line = 1485,
	},
	["0093_00119"] = {
		{"fg", file="misaki_01f_00002", file1="misaki_01f_00101", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1557", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, yeah. I'll just be reading, so let me know when you're ready.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，好的。我正在看书，准备好了请告诉我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，好的。我正在看書，準備好了請告訴我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00118",
		linknext = "0093_00120",
		line = 1498,
	},
	["0093_00120"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00119",
		linknext = "0093_00121",
		line = 1510,
	},
	["0093_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Misaki returned to her driver's seat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我自信地回应在驾驶席的美岬——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我自信地回應在駕駛席的美岬——",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00120",
		linknext = "0093_00122",
		line = 1520,
	},
	["0093_00122"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=1, file="bg25_1l_00000", x=0, y=200, path=":bg/", sync=0, time=1, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Phew...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呼……」",
					{"rt2"},
