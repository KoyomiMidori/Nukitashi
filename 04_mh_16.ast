				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You really are an all-day sucker, Tachibana. Don't tell me ya still seriously trusted me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真是天真啊橘……难道你还相信着我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真是天真啊橘……難道你還相信著我嗎？」",
