			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Besides, you've done so much for my sake up to this point already, haven't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且，至今为止……淳之介君会使用它……不都是一直是为了我们吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且，至今為止……淳之介君會使用它……不都是一直是為了我們嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00071",
