				},
			},
		},
		linkback = "0093_00002",
		linknext = "0093_00004",
		line = 44,
	},
	["0093_00004"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You bet. I've got the perfect plan to counteract the biggest problem we're facing right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错。我们目前面临的最大问题——我想到了与之对抗的对策。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯。我們目前面臨的最大問題——我想到了與之對抗的對策。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00003",
		linknext = "0093_00005",
		line = 56,
	},
	["0093_00005"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00109", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0477", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Biggest problem, eh. I'm guessing that means the brainwashing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“最大的问题……果然还是那个洗脑吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「最大的問題……果然還是那個洗腦嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00004",
		linknext = "0093_00006",
		line = 69,
	},
	["0093_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Thanks to that, it's not just the yakuza, but even the SS and OSS who are playing into Teshima's hands. Given those conditions, we have no way of beating him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。因为那个洗脑，不仅仅是黑社会，连FS和SHO都对他们言听计从，变成了‘傀儡’。在这种情况下，我们没有胜算。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。因為那個洗腦，不僅僅是黑社會，連FS和SHO都對他們言聽計從，變成了『傀儡』。在這種情況下，我們沒有勝算。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00005",
		linknext = "0093_00007",
		line = 81,
	},
	["0093_00007"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But hear me out—what if we were able to undo the brainwashing, and get everyone on our side instead?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是——如果我能解开洗脑，把他们拉入我的阵营呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是——如果我能解開洗腦，把他們拉入我的陣營呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00006",
		linknext = "0093_00008",
		line = 93,
	},
	["0093_00008"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
