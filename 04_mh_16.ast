					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As long as the law exists, you're potential prey for sex-seekers. I want to keep you safe from them.”",
					{"rt2"},
				},
			},
			cn = {
				{
