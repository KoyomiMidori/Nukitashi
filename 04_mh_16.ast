	["0093_00041"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00104", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1400] = {
