		{"bgm", file="bgm14", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Riding in Aikaze, we make our way toward the island's main street.",
					{"rt2"},
				},
			},
			cn = {
