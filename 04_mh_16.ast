		linknext = "0093_00415",
		line = 5535,
	},
	["0093_00415"] = {
		{"evset", file="ttci_m", set="ttci_m", path=":ev/ttci_m/"},
		{"evset", file="ttci_m010102", set="ttci_m010", path=":ev/ttci_m010/"},
		{"cgdel", id=11, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=11, file="ttci_m010102", x=-5, y=-5, path=":cg/ttci_m/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0130", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示", "手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Teshima"},
					"“Ha! Well, I can end it all right here anyway. Just gotta pull the trigger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "手嶋"},
					"“哈。那种事……只要我在这里开一枪，一切就都结束了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "手嶋"},
					"「哈。那種事……只要我在這裡開一槍，一切就都結束了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00414",
		linknext = "0093_00416",
		line = 5553,
	},
	["0093_00416"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's wielding a real gun.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋的枪是真品。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋的槍是真品。",
					{"rt2"},
				},
