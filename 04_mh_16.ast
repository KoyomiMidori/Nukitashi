					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Yah, hah... I-In that case... If my lymphatic drainage down here is not so admirable... could you take care of it for me?”",
					{"rt2"},
				},
			},
