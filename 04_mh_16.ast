		linkback = "0093_00121",
		linknext = "0093_00123",
		line = 1536,
	},
	["0093_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sitting in Aikaze's rear cabin, I sigh.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在爱风的个室里，我叹了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在愛風的個室裡，我嘆了口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00122",
		linknext = "0093_00124",
		line = 1546,
	},
	["0093_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having left the signature collecting to the others, we're here to work on undoing Teshima's brainwashing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"签名交给了奈奈濑他们——而我们则负责解除被手嶋操纵的“傀儡”的洗脑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"簽名交給了奈奈瀨他們——而我們則負責解除被手嶋操縱的「傀儡」的洗腦。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00123",
		linknext = "0093_00125",
		line = 1556,
	},
	["0093_00125"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00113", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0479", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Junnosuke? What's wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“淳之介君？怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「淳之介君？怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00124",
		linknext = "0093_00126",
		line = 1569,
	},
	["0093_00126"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm a little nervous. I've never approached anyone for sex myself before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有点紧张。我从来没有主动积极做爱过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有點緊張。我從來沒有主動積極做愛過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00125",
		linknext = "0093_00127",
		line = 1581,
	},
	["0093_00127"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0480", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I see. Would you like to practice with me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是这样啊。那么……要把郁当成练习对象吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是這樣啊。那麼……要把郁當成練習對象嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00126",
		linknext = "0093_00128",
		line = 1595,
	},
	["0093_00128"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hell no. I'm not gonna have sex without love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“拒绝。我不会做没有爱的性爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「拒絕。我不會做沒有愛的性愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00127",
		linknext = "0093_00129",
		line = 1607,
	},
	["0093_00129"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0481", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huh? Isn't that exactly your plan, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶——？接下来你不是打算跟各种女孩子做爱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸——？接下來你不是打算跟各種女孩子做愛嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00128",
		linknext = "0093_00130",
		line = 1621,
	},
	["0093_00130"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's all for Misaki's sake. That's how much I love her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这一切都是为了保护美岬而做的，因为有对美岬的爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這一切都是為了保護美岬而做的，因為有對美岬的愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00129",
		linknext = "0093_00131",
		line = 1633,
	},
	["0093_00131"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00111", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0482", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hmm... love is complicated, isn't it? I guess I really will have to give up on that. That's a shame.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哼……爱真是复杂呢。那我只能放弃了……真可惜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哼……愛真是複雜呢。那我只能放棄了……真可惜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00130",
		linknext = "0093_00132",
		line = 1647,
	},
	["0093_00132"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0483", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But I've got a lot of experience with Magical Mirrors, so I can give you some pointers, if you'd like.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过，如果是魔镜号的话，我也经常使用，所以可以给你一些建议哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過，如果是魔鏡號的話，我也經常使用，所以可以給你一些建議哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00131",
		linknext = "0093_00133",
		line = 1661,
	},
	["0093_00133"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? Let's hear it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的吗？告诉我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的嗎？告訴我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00132",
		linknext = "0093_00134",
		line = 1673,
	},
	["0093_00134"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00102", file2="ikuko_01m_00201", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0484", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Sure. Hehe, I always loved our fights, but it's nice to have you relying on me now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯。呵呵……虽然之前战斗的时候也很开心，不过被亲爱的依赖也很开心呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯。呵呵……雖然之前戰鬥的時候也很開心，不過被親愛的依賴也很開心呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00133",
		linknext = "0093_00135",
		line = 1688,
	},
	["0093_00135"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00104", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0485", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Even beginners can easily enjoy sex here in a Magical Mirror. First of all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“魔镜号上有个就算是不习惯的初学者也能简单引导做爱的方法。首先呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
