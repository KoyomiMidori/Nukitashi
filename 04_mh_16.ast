				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you say. But your lymphatic drainage here doesn't look very good.”",
					{"rt2"},
				},
			},
			cn = {
