				{"vo", file="teshima0125", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“But if ya know that, you musta figured it out, right? Why exactly this is my island, and what the fuck I'm doin' here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不过……那你应该明白吧？明白为什么这里是我的岛——为什么我在这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「不過……那你應該明白吧？明白為什麼這裡是我的島——為什麼我在這裡。」",
					{"rt2"},
				},
