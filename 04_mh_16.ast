				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But Misaki, my one greatest love... She has come to admire it. And that's good enough for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然而，我最喜欢的人——美岬，说我的鸡巴很可爱。我……觉得那样就够了。”",
