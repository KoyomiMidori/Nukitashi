		linkback = "0093_00398",
		linknext = "0093_00400",
		line = 5339,
	},
	["0093_00400"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0123", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“No such thing as stupid questions, my ass! This is my fuckin' island. No shit I'd be here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真是愚蠢的问题啊橘……这里是我的岛。我当然在这里啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真是愚蠢的問題啊橘……這裡是我的島。我當然在這裡啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00399",
		linknext = "0093_00401",
		line = 5353,
	},
	["0093_00401"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Your island? The hell you on about? Has all that sex eaten holes in your fucking brain?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说这里是你的岛……？你在说什么……你是不是因为做太多爱而发疯了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說這裡是你的島……？你在說什麼……你是不是因為做太多愛而發瘋了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00400",
		linknext = "0093_00402",
		line = 5364,
	},
	["0093_00402"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00122", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0124", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Well, how 'bout that... Not like I care how ya found out, but I guess that means ya know 'bout me brainwashing method. Tsk, whatta drag...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“怎么……虽然不知道你是从谁那儿听来的，你知道洗脑的方法了是吗？切，真没意思……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「怎麼……雖然不知道你是從誰那聽來的，你知道洗腦的方法了是嗎？呿，真沒意思……」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00401",
		linknext = "0093_00403",
		line = 5378,
	},
	["0093_00403"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00124", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
