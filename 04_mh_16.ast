	["0093_00106"] = {
		{"bg", id=2, file="bg22_1l_00000", x=100, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-105, y=-5, time=50000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We check outside from within Aikaze.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在爱风内部眺望着外面的样子嘟嚷着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在愛風內部眺望著外面的樣子嘟嚷著。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00105",
		linknext = "0093_00107",
		line = 1358,
	},
	["0093_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since the announcement of the new perverted sex law, there's been a dramatic and very visible drop in the number of sex-seekers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"新・变态条例发布后，性触者的数量明显减少了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"新・變態條例發布後，性觸者的數量明顯減少了。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00106",
		linknext = "0093_00108",
		line = 1368,
	},
	["0093_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a vague unease about the new fee, as well as general suspicion about the new law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对新条例的不信任，和对收费制的不安。理由应该有很多吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"對新條例的不信任，和對收費制的不安。理由應該有很多吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00107",
		linknext = "0093_00109",
		line = 1378,
	},
	["0093_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, the main reason for the stillness is the unusual lack of OSS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最大的改变果然还是SHO的数量异常地少。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最大的改變果然還是SHO的數量異常地少。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00108",
		linknext = "0093_00110",
		line = 1388,
	},
	["0093_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Teshima keeps most of the OSS at the headquarters, likely to shore up his defenses.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋将SHO几乎都留在了海上的SHO总部。恐怕是为了巩固守护吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋將SHO幾乎都留在了海上的SHO總部。恐怕是為了鞏固守護吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00109",
		linknext = "0093_00111",
		line = 1398,
	},
	["0093_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since they aren't out and about to get tourists and islanders into sex, the streets seem deserted and quiet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"缺乏呼吁居民和游客进行性产行为的SHO——便是其中一项造成这个现象的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"缺乏呼籲居民和遊客進行性產行為的SHO——便是其中一項造成這個現象的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00110",
		linknext = "0093_00112",
		line = 1408,
	},
	["0093_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The other big reason is because the Yakuza presence on the island has already become common knowledge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"另外——黑社会在青蓝岛的事已经成了传言。",
					{"rt2"},
				},
			},
			tw = {
				{
					"另外——黑社會在青藍島的事已經成了傳言。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00111",
		linknext = "0093_00113",
		line = 1418,
	},
	["0093_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Their kidnapping of Fumino was a huge disturbance, and it involved both the SS and the OSS. Covering it up would've been impossible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"寻找文乃那时，引发了连SHO和FS都被卷进来的骚动，不暴露才奇怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"尋找文乃那時，引發了連SHO和FS都被捲進來的騷動，不暴露才奇怪。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00112",
		linknext = "0093_00114",
		line = 1428,
	},
	["0093_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not only that, but the lack of OSS around to keep up the appearance of public order has the islanders terrified of the outlaws.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在，岛上几乎没有维持治安的SHO，这使得居民变得更加害怕不法分子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在，島上幾乎沒有維持治安的SHO，這使得居民變得更加害怕不法分子。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00113",
		linknext = "0093_00115",
		line = 1438,
	},
	["0093_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The effect is most noticeable in the shopping center, the island's main hub.",
					{"rt2"},
				},
			},
			cn = {
				{
					"特别是作为岛的中心地的繁华街，其倾向尤为明显。",
					{"rt2"},
				},
			},
			tw = {
				{
					"特別是作為島的中心地的繁華街，其傾向尤為明顯。",
					{"rt2"},
				},
			},
