		linknext = "0093_00398",
		line = 5310,
	},
	["0093_00398"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Teshima! Who'd ever trust a snake like you... More importantly, why are you here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“手嶋——谁会相信你……你为什么会在这里。”",
