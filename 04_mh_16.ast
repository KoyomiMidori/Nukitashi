	["0093_00284"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Glad you showed. As it turns out, I've been considering offering massages once the new law goes into effect.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“花丸委员长——其实，我想在新条例实施后，用按摩来赚大钱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「花丸委員長——其實，我想在新條例實施後，用按摩來賺大錢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00283",
		linknext = "0093_00285",
		line = 3685,
	},
	["0093_00285"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And so, Rub-n-Tug Handmaster Junnosuke would like to offer you a massage for the low, low price of absolutely free. Would you be interested?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“按摩师橘淳之介的按摩服务……要体验一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「按摩師橘淳之介的按摩服務……要體驗一下嗎？」",
