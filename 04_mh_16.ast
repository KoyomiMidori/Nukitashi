	["0093_00391"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There was a suspicious-looking basement, but it was totally empty. I didn't find anything that could remotely count as an ace in the hole.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然有间可疑的地下室，但已经完全空了，没有任何的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然有間可疑的地下室，但已經完全空了，沒有任何的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00390",
