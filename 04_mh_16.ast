		linkback = "0093_00101",
		linknext = "0093_00103",
		line = 1307,
	},
	["0093_00103"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2061", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“All right, let's work hard and collect tons of signatures! Let's make this election happen, guys!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好——要努力收集签名咯～！大家——请将神圣的一票投给我们！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好——要努力收集簽名咯～！大家——請將神聖的一票投給我們！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00102",
		linknext = "0093_00104",
		line = 1320,
	},
	["0093_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It doesn't quite feel right to just leave something like that to them, but they've got Nanase, so I'm sure they'll be fine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱好像误会了什么——算了，反正奈奈濑在，应该没问题吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬好像誤會了什麼——算了，反正奈奈瀨在，應該沒問題吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00103",
		linknext = "0093_00105",
		line = 1330,
	},
	["0093_00105"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
