			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ooh, look at that swagger... You've had a flash of inspiration, haven't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哦，这种感觉……有什么灵感吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哦，這種感覺……有什麼靈感嗎？」",
