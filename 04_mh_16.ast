		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[6000] = {
				{"fg", file="misaki_01l_00001", file2="misaki_01l_00201", file3="misaki_01l_00308", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, delay2=6000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1547", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, it's nothing... Well, no, it's not nothing, but if you say that's what you want to do, then I'll support you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的。如果说我什么都没有想……那是骗人的……但淳之介君说要做的话，我想支持你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的。如果說我什麼都沒有想……那是騙人的……但淳之介君說要做的話，我想支持你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00073",
		linknext = "0093_00075",
		line = 913,
	},
	["0093_00075"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00107", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1548", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Still, I know how hard this must be hard for you, so can I give you a little charm to help make you feel a little more comfortable?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是，我也知道这对淳之介君来说是一件很痛苦的事情……所以，为了让你心情平静，我可以给你施个魔法吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是，我也知道這對淳之介君來說是一件很痛苦的事情……所以，為了讓你心情平靜，我可以給你施個魔法嗎？」",
					{"rt2"},
				},
			},
		},
