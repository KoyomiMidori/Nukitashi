					{"rt2"},
				},
			},
			en = {
				{
					"The locations are hard to pin down. I suppose an evil organization would do that in order to hide their tracks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们故意要让地点难以被锁定，确实符合恶人组织会采取的行动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們故意要讓地點難以被鎖定，確實符合惡人組織會採取的行動。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00086",
		linknext = "0103_00088",
		line = 1203,
	},
	["0103_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Our Ariadne Protocol isn't useful for those without GPS, or in the forest with no cameras...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们的‘Ariadne协议’对没有GPS的家伙或没有摄像头的森林里没用啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們的『Ariadne協議』對沒有GPS的傢伙或沒有攝影機的森林裡沒用啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00087",
		linknext = "0103_00089",
		line = 1215,
	},
	["0103_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just wanna hurry and kick those fuckers' asses... I'm getting pretty impatient.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好想快点揍扁他们……真让人着急。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好想快點揍扁他們……真讓人著急。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00088",
		linknext = "0103_00090",
		line = 1225,
	},
	["0103_00090"] = {
