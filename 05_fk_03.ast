		},
		linkback = "0103_00157",
		linknext = "0103_00159",
		line = 2053,
	},
	["0103_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's something exotic about her; something high-class.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个少女，到底该说是神秘呢，还是该说是格调高雅呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個少女，到底該說是神秘呢，還是該說是格調高雅呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00158",
		linknext = "0103_00160",
		line = 2063,
	},
	["0103_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I saw her on the street, I'd probably presume her to have had the kind of upbringing where she was never wanting for anything. That's the vibe I get from her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是在街上相遇，她身上的气场肯定会让人认为她是某个深闺大小姐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是在街上相遇，她身上的氣場肯定會讓人認為她是某個深閨大小姐。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00159",
		linknext = "0103_00161",
		line = 2073,
	},
	["0103_00161"] = {
