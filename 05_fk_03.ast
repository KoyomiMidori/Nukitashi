					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But man, I can't wait to track those assholes down so I can tear 'em a new one!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过只要努力寻找的话，暴打他们的时候反而会更开心呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過只要努力尋找的話，暴打他們的時候反而會更開心呢！」",
					{"rt2"},
				},
