	["0103_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once more, she stands there silently with her beautifully serene expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的脸上又浮现出凛冽而美丽的表情，并且沉默不语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的臉上又浮現出凜冽而美麗的表情，並且沉默不語。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00156",
		linknext = "0103_00158",
		line = 2043,
	},
	["0103_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm entranced by the profile of her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吹子那美丽的侧脸让人不由得看得入了神。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吹子那美麗的側臉讓人不由得看得入了神。",
