					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm... not doing this for the sake of the islanders.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我……并不是为了岛上的人而行动的。”",
