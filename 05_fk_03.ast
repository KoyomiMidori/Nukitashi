		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whenever I'm in town, I can tell an enemy's location precisely with these googles. Pretty cool, eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……如果是市区的话，这个护目镜就几乎能完全锁定敌人的位置。很方便吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……如果是市區的話，這個護目鏡就幾乎能完全鎖定敵人的位置。很方便吧？」",
					{"rt2"},
				},
			},
		},
