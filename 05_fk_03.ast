	["0103_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But at this point in time, that doesn't bother me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是我认为这次的事情，只要这样就可以了。",
