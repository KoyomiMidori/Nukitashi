	["0103_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That weight from my past— how I was thrown into the pit of despair not once, but twice...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这不是该对素不相识，而且比自己还小的女孩子说的内容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這不是該對素不相識，而且比自己還小的女孩子說的內容。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00153",
		linknext = "0103_00155",
		line = 2005,
	},
	["0103_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not exactly something I want to talk about with a girl younger than me whom I barely even know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是令我陷入第二次绝望的阴暗过去。",
