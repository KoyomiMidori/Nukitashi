	["0103_00140"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00101", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0408", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Tachibana... why do you want... to defeat that illegal sex business... so badly?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“——橘、大人……为什么、想要那么……摧毁地下风俗、呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「——橘、大人……為什麼、想要那麼……摧毀地下風俗、呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00139",
		linknext = "0103_00141",
		line = 1850,
	},
	["0103_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
