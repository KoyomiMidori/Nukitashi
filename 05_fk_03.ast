		{"fg", file="fumino_01l_00001", file1="fumino_01l_00110", path=":fg/fumino_01l/", id=5, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=-500},
		{"cgact", file="cgact", id=3, act="移動", x=-5, y=395, time=10000, lv=5},
		{"fgact", ch="文乃", id=5, act="移動", x=0, y=300, time=10000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Physically, she looks quite a lot younger than me, but her face is uncharacteristically mature. Her complexion is pale white, almost like porcelain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从身躯来看应该比我小很多的，但脸孔却端正到显得不太相称。皮肤像瓷器一样白皙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從身軀來看應該比我小很多的，但臉孔卻端正到顯得不太相稱。皮膚像瓷器一樣白皙。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00130",
		linknext = "0103_00132",
		line = 1743,
	},
	["0103_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her posture and stance is always impeccable, and she emanates immense inner strength.",
					{"rt2"},
