	},
	["0103_00106"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Oh right I haven't told you my name it's Tachibana Junnosuke and my online handle's @jun_fappist but I don't really get hung up on how people address me so call me whatever you like!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶？啊，忘了报上名字了我叫橘淳之介网名主要是@junonanist但是并没有固定的名字所以请随便叫吧！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？啊，忘了報上名字了我叫橘淳之介網名主要是@junonanist但是並沒有固定的名字所以請隨便叫吧！！」",
					{"rt2"},
				},
			},
		},
