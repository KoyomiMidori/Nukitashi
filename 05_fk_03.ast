	["0103_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look away, to escape the glare of her red eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像要躲避那双红色瞳孔般，我移开了视线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像要躲避那雙紅色瞳孔般，我移開了視線。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00151",
