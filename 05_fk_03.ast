		{"fg", file="fumino_01ll_00001", file1="fumino_01ll_00101", path=":fg/fumino_01ll/", id=4, lv=5, head="fumino_01ll", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=50, y=0},
