				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At the very least, I know she isn't anyone we can be wary of. Well, my intuition tells me so, at least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——至少我知道她不是坏人，直觉是这样告诉我的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——至少我知道她不是壞人，直覺是這樣告訴我的。」",
