	["0103_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I completely lose the sense of emotional distance between myself and a younger girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对比自己年少的少女，我完全失去了心灵上的距离感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對比自己年少的少女，我完全失去了心靈上的距離感。",
					{"rt2"},
				},
			},
