		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her reddish-brown eyes seem to glitter in the darkness, and are bewitching in a way that sucks you in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她那赤褐色的双瞳，即使在黑暗中也有着淡淡的光辉，有着令人陶醉的魅力。",
