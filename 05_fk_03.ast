					"Her outward appearance leaves quite an impression, right down to the clothes she's clad in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且她——除了身上的和服——还有着令人印象深刻的外表。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且她——除了身上的和服——還有著令人印象深刻的外表。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00128",
