	["0103_00053"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0391", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“It's basically a night watch. There are locations they regularly show up, and I patrol those areas once per night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“他们基本上会在夜里巡视……出没的位置是固定的……所以要在一夜之间把那些地点都巡过一遍……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「他們基本上會在夜裡巡視……出沒的位置是固定的……所以要在一夜之間把那些地點都巡過一遍……」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00052",
		linknext = "0103_00054",
		line = 775,
	},
	["0103_00054"] = {
