	["0103_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She called the kimono she wears her combat uniform, but it definitely doesn't look like a cheap hand-me-down she found in a pawn shop.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被她称为战斗服的和服，看起来也不像便宜货。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被她稱為戰鬥服的和服，看起來也不像便宜貨。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00161",
		linknext = "0103_00163",
		line = 2095,
	},
	["0103_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if she's living on her own, it wouldn't cost pocket change to keep that outfit looking pristine after all that walking in the forest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是一个人生活，如果经济上不宽裕，是无法做出让美丽的织物在森林里弄脏的行为的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是一個人生活，如果經濟上不寬裕，是無法做出讓美麗的織物在森林裡弄髒的行為的。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00162",
		linknext = "0103_00164",
		line = 2105,
	},
	["0103_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
