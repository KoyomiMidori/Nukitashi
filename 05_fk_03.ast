	["0103_00014"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2094", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But how do we do that in practical terms? If we try to get more involved in that, our sponsor's resources will end up getting divvied up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是实际上你打算怎么办？如果你要那样做，资源就无法用来满足出资者的要求了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是實際上你打算怎麼辦？如果你要那樣做，資源就無法用來滿足出資者的要求了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00013",
		linknext = "0103_00015",
		line = 221,
	},
	["0103_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we did that, there's also a possibility we'd lose our sponsorship.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那样的话，我们的赞助就有可能被中断。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那樣的話，我們的讚助就有可能被中斷。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00014",
		linknext = "0103_00016",
		line = 231,
	},
	["0103_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That would put us even further away from my objective.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那离我的夙愿就越来越远了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那離我的夙願就越來越遠了。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00015",
		linknext = "0103_00017",
		line = 241,
	},
	["0103_00017"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00109", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh... There's only one thing to do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼……真是愚蠢的问题啊，你们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼……真是愚蠢的問題啊，你們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00016",
		linknext = "0103_00018",
		line = 254,
	},
	["0103_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We are the extremely strong and handsome anti-copulation front, are we not? We face down the SS and the OSS regularly, do we not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们可是对抗FS和SHO的最大的反交尾势力哦？那种事情——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們可是對抗FS和SHO的最大的反交尾勢力哦？那種事情——」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00017",
		linknext = "0103_00019",
		line = 265,
	},
	["0103_00019"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So we're obviously gonna fuckin' do BOTH!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——两边都干不就好了吗！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——兩邊都幹不就好了嗎！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00018",
		linknext = "0103_00020",
		line = 278,
	},
	["0103_00020"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They're all stunned yet again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所有人再次目瞪口呆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所有人再次目瞪口呆。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00019",
		linknext = "0103_00021",
		line = 294,
	},
	["0103_00021"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00105", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00114", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00105", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This time they all sigh in unison.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，一起叹了一口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，一起嘆了一口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00020",
		linknext = "0103_00022",
		line = 313,
	},
	["0103_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, come on! Where's your enthusiasm, people?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你们干嘛——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你們幹嘛——」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00021",
		linknext = "0103_00023",
		line = 325,
	},
	["0103_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase, you don't mind, do you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……奈奈濑，没问题吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……奈奈瀨，沒問題吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00022",
		linknext = "0103_00024",
		line = 337,
	},
	["0103_00024"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2095", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sigh... Not really. I mean, we gotta do what the leader tells us, right? And it'd haunt my conscience for life to leave pure evil to do its dirty and stuff, so I'm not gonna complain, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“唉……嘛，应该吧？既然队长决定了，不就只能遵守嘛？反正如果放着恶人不管，我晚上也会睡不好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「唉……嘛，應該吧？既然隊長決定了，不就只能遵守嘛？反正如果放著惡人不管，我晚上也會睡不好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00023",
		linknext = "0103_00025",
		line = 351,
	},
	["0103_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry for making extreme demands.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，说了些强人所难的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，說了些強人所難的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00024",
		linknext = "0103_00026",
		line = 363,
	},
	["0103_00026"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2096", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's fine. So, what should we do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没事。那我们要做什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒事。那我們要做什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00025",
		linknext = "0103_00027",
		line = 378,
	},
	["0103_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“First, split up into two groups.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“先把队伍分成两组。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「先把隊伍分成兩組。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00026",
		linknext = "0103_00028",
		line = 390,
	},
	["0103_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll be leader for team A, which will be responsible for illegal sex industry annihilation, and you'll be leader for team B, which is responsible for searching for Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我是消灭地下风俗的A组，而奈奈濑则是搜索文乃的B组队长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我是消滅地下風俗的A組，而奈奈瀨則是搜索文乃的B組隊長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00027",
		linknext = "0103_00029",
		line = 402,
	},
	["0103_00029"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2097", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“How do we split them up? We can't do it evenly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那队伍的分配怎么办？总不能一组一半吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那隊伍的分配怎麼辦？總不能一組一半吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00028",
		linknext = "0103_00030",
		line = 416,
	},
	["0103_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I guess... I'll basically be A team by myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，说得也是……基本上A队我一个人就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，說得也是……基本上A隊我一個人就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00029",
		linknext = "0103_00031",
		line = 428,
	},
	["0103_00031"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whenever there's some kind of big operation, I'll call on the help of members of team B. When I need extra members, I'll consult with you on who to take.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只有有什么大作战时，我才会从B组借人。每次要借谁都会和奈奈濑讨论。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只有有什麼大作戰時，我才會從B組借人。每次要借誰都會和奈奈瀨討論。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00030",
		linknext = "0103_00032",
		line = 440,
	},
	["0103_00032"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2098", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“In other words, you're going to be helping that white-haired girl — Fukiko — you mentioned earlier.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“也就是说淳会和刚才说的那个淡色头发的少女——吹子一起行动是吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「也就是說淳會和剛才說的那個淡色頭髮的少女——吹子一起行動是吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00031",
		linknext = "0103_00033",
		line = 455,
	},
	["0103_00033"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00116", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1944", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Umm... it's not like I'm suspicious of her or anything, but... who on earth is she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃……我也不是在怀疑……但那个孩子到底是什么人……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃……我也不是在懷疑……但那個孩子到底是什麼人……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00032",
		linknext = "0103_00034",
		line = 469,
	},
	["0103_00034"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not really clear on that myself yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这个我也还不确定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這個我也還不確定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00033",
		linknext = "0103_00035",
		line = 481,
	},
	["0103_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All I really know for now is, well... she's got this certain upper-class, or no, maybe royalty-type aura or something about her...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“像是某处的……大小姐吧，像公主般的女孩子……我只知道这些。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「像是某處的……大小姐吧，像公主般的女孩子……我只知道這些。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00034",
		linknext = "0103_00036",
		line = 493,
	},
	["0103_00036"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"cgact", file="cgact", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So if I was probed more deeply about why I'd want to help such a girl, I couldn't really answer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，如果要深问我为什么要和这样的少女合作，我也无法回答。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，如果要深問我為什麼要和這樣的少女合作，我也無法回答。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00035",
		linknext = "0103_00037",
		line = 509,
	},
	["0103_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Am I attracted to the fine livery that makes her look like she had a good upbringing, or am I attracted to her princess-like appearance?",
					{"rt2"},
				},
			},
			cn = {
				{
					"该说是被她那让人联想到深闺大小姐的外表所吸引吗？还是被她那如公主般的外表吸引了呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"該說是被她那讓人聯想到深閨大小姐的外表所吸引嗎？還是被她那如公主般的外表吸引了呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00036",
		linknext = "0103_00038",
		line = 519,
	},
	["0103_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't really verbalize it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使想要语言化，也说不出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使想要語言化，也說不出來。",
					{"rt2"},
				},
			},
