		line = 1460,
	},
	["0103_00109"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0403", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"非表示", "吹子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Fukiko"},
					"“Okay... Tachibana... do you have any family?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "吹子"},
					"“那么……橘、大人……您的家人……不在吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "吹子"},
					"「那麼……橘、大人……您的家人……不在嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00108",
		linknext = "0103_00110",
		line = 1474,
	},
	["0103_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Umm... I mentioned earlier I have a little sister that's a handful.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……刚才我也说了，我有一个很令人费神的妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……剛才我也說了，我有一個很令人費神的妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00109",
		linknext = "0103_00111",
		line = 1486,
	},
	["0103_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's the only one that worries about me, and she's the biggest pain in the universe but really sweet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她是唯一关心我的，宇宙中最麻烦也最可爱的家伙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她是唯一關心我的，宇宙中最麻煩也最可愛的傢伙。」",
					{"rt2"},
				},
