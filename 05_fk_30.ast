					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I have not forgiven the people of Seiran Island to this day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“直到现在——都无法原谅那些青蓝岛的人。”",
