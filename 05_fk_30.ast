	["0130_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are no longer empty bottles of alcohol on the ground.",
					{"rt2"},
				},
			},
			cn = {
				{
					"空酒瓶已经消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"空酒瓶已經消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00056",
		linknext = "0130_00058",
		line = 712,
	},
	["0130_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The whole place is completely tidied up. Books are neatly lined up on the shelf, too. 'Battle Strategy Instructions,' 'How To Control Minds,' and so on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"地上干净了许多，而且整齐地陈列着《战术指南》、《掌握人心》等类型的书籍。",
					{"rt2"},
				},
			},
			tw = {
				{
					"地上乾淨了許多，而且整齊地陳列著《戰術指南》、《掌握人心》等類型的書籍。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00057",
		linknext = "0130_00059",
		line = 722,
	},
	["0130_00059"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0378", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ya've done well gettin' this far. Shouldn't have no more problems usin' yer new power. So I got nothin' left to teach ya's.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真亏你能支撑到现在……这样的话，要使用新的力量应该也没有问题了。我已经没有什么能教你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真虧你能支撐到現在……這樣的話，要使用新的力量應該也沒有問題了。我已經沒有什麼能教你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00058",
		linknext = "0130_00060",
		line = 736,
	},
	["0130_00060"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00116", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then... hah... does that mean I'm fully proficient, Master?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那……哈……已经教完了吗，师傅？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那……哈……已經教完了嗎，師傅？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00059",
		linknext = "0130_00061",
		line = 748,
	},
	["0130_00061"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00122", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0379", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ha! The fuck you are. I'm sayin' there ain't no more point in goin' further, so I'm callin' 'er quits here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“切，不是那个意思……我是说再练也没有意义，所以结束了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「呿，不是那個意思……我是說再練也沒有意義，所以結束了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00060",
		linknext = "0130_00062",
		line = 762,
	},
	["0130_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's got his usual brusque manner.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋先生像往常一样粗鲁地说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋先生像往常一樣粗魯地說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00061",
		linknext = "0130_00063",
		line = 772,
	},
	["0130_00063"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm deeply indebted to you for this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这段时间受你照顾了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這段時間受你照顧了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00062",
		linknext = "0130_00064",
		line = 784,
	},
	["0130_00064"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now I'm more or less ready to walk straight into the jaws of death.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样——我就可以前去赴死了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣——我就可以前去赴死了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00063",
		linknext = "0130_00065",
		line = 796,
	},
	["0130_00065"] = {
		{"bgm", stop=1},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0380", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00064",
		linknext = "0130_00066",
		line = 811,
	},
	["0130_00066"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He puts his hands in his pockets again, looking disgusted with the world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋先生像对世界厌倦了一样，把手伸到口袋里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋先生像對世界厭倦了一樣，把手伸到口袋裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00065",
		linknext = "0130_00067",
		line = 823,
	},
	["0130_00067"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00125", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then he shuts his eyes, folds his arms, and then opens just one eye to look at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后闭上眼睛，抱起胳膊，一只眼睛看着这边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後又閉上眼睛，雙手抱胸，用一隻眼睛看著這邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00066",
		linknext = "0130_00068",
		line = 835,
	},
	["0130_00068"] = {
		{"bgm", file="bgm21", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0381", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Have ya figured out just how yer gonna use that power o' yers?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……你想怎样使用这种力量，得出结论了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「……你想怎樣使用這種力量，得出結論了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00067",
		linknext = "0130_00069",
		line = 848,
	},
	["0130_00069"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——————」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00068",
		linknext = "0130_00070",
		line = 860,
	},
	["0130_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't respond immediately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我没有立刻发出声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沒有立刻發出聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00069",
		linknext = "0130_00071",
		line = 870,
	},
	["0130_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Right now, I can't quite put what I'm feeling into words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在，心中的这个想法，还不能说出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在，心中的這個想法，還不能說出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00070",
		linknext = "0130_00072",
		line = 880,
	},
	["0130_00072"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00105", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0382", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Aw, what the hell. Don't matter no more anyhow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……啊～啊，随便你吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「……啊～啊，隨便你吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00071",
		linknext = "0130_00073",
		line = 894,
	},
	["0130_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then, as if coming to a conclusion of sorts, he drops the question entirely.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手岛似乎察觉到了什么，便不再追问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手島似乎察覺到了什麼，便不再追問。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00072",
		linknext = "0130_00074",
		line = 904,
	},
	["0130_00074"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0383", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I'm done babysittin' yer punk ass now, so it's high time I said goodbye, farewell, an' amen to this island. Tear them fuckers two new assholes fer me, y'hear?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“小孩子的管教结束了，能干的我都干了。也该和这个岛告别了。你就好好替我报仇吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「小孩子的管教結束了，能幹的我都幹了。也該和這個島告別了。你就好好替我報仇吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00073",
		linknext = "0130_00075",
		line = 916,
	},
	["0130_00075"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you leaving the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你要离开这个岛吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你要離開這個島嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00074",
		linknext = "0130_00076",
		line = 928,
	},
	["0130_00076"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0384", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Yeah. Long as fuckin' Sakimori's still stickin' his nose into shit, I'm persona non grata on the mainland... Figure I'll find me some flophouse near Manila t' lay low fer a while.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“是啊。虽然防人那个混蛋还在的时候我不能回到本岛……不过在物价便宜的马尼拉附近躲着也不错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「是啊。雖然防人那個混蛋還在的時候我不能回到本島……不過在物價便宜的馬尼拉附近躲著也不錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00075",
		linknext = "0130_00077",
		line = 944,
	},
	["0130_00077"] = {
		{"fg", mode=-1, id=8, ch="手嶋", lv=5, time=400},
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He clasps his carpetbag shut, throws it over his shoulder, and turns to leave.",
					{"rt2"},
				},
			},
			cn = {
				{
					"将整理好的小行李搭在肩上后，手嶋先生离开了房间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"將整理好的小行李搭在肩上後，手嶋先生離開了房間。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00076",
		linknext = "0130_00078",
		line = 957,
	},
	["0130_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I doubt I'll ever see him again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样，就不会再和手嶋先生见面了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣，就不會再和手嶋先生見面了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00077",
		linknext = "0130_00079",
		line = 967,
	},
	["0130_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This will be our final farewell.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一辈子的离别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一輩子的離別。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00078",
		linknext = "0130_00080",
		line = 977,
	},
	["0130_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've been through a hell of a lot of things with this man.",
					{"rt2"},
				},
			},
			cn = {
				{
					"至今为止，真的和这个人发生了好多事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"至今為止，真的和這個人發生了好多事。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00079",
		linknext = "0130_00081",
		line = 987,
	},
	["0130_00081"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a036"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
