	["0130_00138"] = {
		{"se", id=3, loop=1, file="se_d031", vol=30},
		{"se", id=0, loop=0, file="se_a163"},
		{"ex", time=1000, func="wait"},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0215", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Oh? Still confident enough to take my calls, I see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“——哦，没想到你还有接我电话的力气呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——哦，沒想到你還有接我電話的力氣呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00137",
		linknext = "0130_00139",
		line = 1748,
	},
	["0130_00139"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you want?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……有什么事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……有什麼事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00138",
		linknext = "0130_00140",
		line = 1760,
	},
	["0130_00140"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0216", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“To give you my final warning. After all, you seem to be creeping around and planning something out of my sight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“最后通牒。因为你好像还在偷偷摸摸地四处走动——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「最後通牒。因為你好像還在偷偷摸摸地四處走動——」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00139",
		linknext = "0130_00141",
		line = 1773,
	},
	["0130_00141"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0217", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Give me Fumino, and I will allow your companions to live. There is no further point in you holding on to a girl who is no longer of use anymore, is there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“把文乃交给我。这样的话，我就能让你的朋友们活下去……没有必要把已经没用的姑娘留在身边吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「把文乃交給我。這樣的話，我就能讓你的朋友們活下去……沒有必要把已經沒用的姑娘留在身邊吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00140",
		linknext = "0130_00142",
		line = 1785,
	},
	["0130_00142"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fuck you. Fumino is mine now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我拒绝。文乃是我家的女儿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我拒絕。文乃是我家的女兒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00141",
		linknext = "0130_00143",
		line = 1797,
	},
	["0130_00143"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0218", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Goddamned fool. I have no choice but to take you on with everything I have, then. If you value your lives, you'll come quietly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“愚蠢的男人……那么这次就让我拼尽全力去战斗吧。如果舍不得小命就老老实实待着吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「愚蠢的男人……那麼這次就讓我拼盡全力去戰鬥吧。如果捨不得小命就老老實實待著吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00142",
		linknext = "0130_00144",
		line = 1810,
	},
	["0130_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He has hundreds of times more combat capability.",
					{"rt2"},
				},
			},
			cn = {
				{
					"战斗力相差数百倍。",
					{"rt2"},
				},
			},
			tw = {
				{
					"戰鬥力相差數百倍。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00143",
		linknext = "0130_00145",
		line = 1820,
	},
	["0130_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't have anything resembling a fighting force.",
					{"rt2"},
				},
			},
			cn = {
				{
					"战斗人员不齐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"戰鬥人員不齊。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00144",
		linknext = "0130_00146",
		line = 1830,
	},
	["0130_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I haven't even formulated anything that could be called a strategy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就连所谓的作战计划也无法成立。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就連所謂的作戰計劃也無法成立。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00145",
		linknext = "0130_00147",
		line = 1840,
	},
	["0130_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's virtually zero chance of us succeeding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们几乎没有胜机。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們幾乎沒有勝機。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00146",
		linknext = "0130_00148",
		line = 1850,
	},
	["0130_00148"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0219", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I am sure you despised the perverted sex law as much as I did.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“你应该也和我一样，对‘变态条例’怀恨在心吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「你應該也和我一樣，對『變態條例』懷恨在心吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00147",
		linknext = "0130_00149",
		line = 1862,
	},
	["0130_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He knows that already, but continues.",
					{"rt2"},
				},
			},
			cn = {
				{
					"得知这一点，防人老人继续说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"得知這一點，防人老人繼續說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00148",
		linknext = "0130_00150",
		line = 1872,
	},
	["0130_00150"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0220", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I appointed you because of your deep-seated hatred for the people of the island, as someone with a common goal in mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“正因为我打从心底憎恨岛上的人，所以才会重用你。作为怀有同样目的的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「正因為我打從心底憎恨島上的人，所以才會重用你。作為懷有同樣目的的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00149",
		linknext = "0130_00151",
		line = 1884,
	},
	["0130_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"嗯，说的不错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"嗯，說的不錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00150",
		linknext = "0130_00152",
		line = 1894,
	},
	["0130_00152"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0221", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Does that not make the current state of affairs most ideal to you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“那么，现状才是最好的情况不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「那麼，現狀才是最好的情況不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00151",
		linknext = "0130_00153",
		line = 1906,
	},
	["0130_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's exactly as he says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正如这位老人所说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正如這位老人所說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00152",
		linknext = "0130_00154",
		line = 1916,
	},
	["0130_00154"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0222", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“If anything, should you not be on my side?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“你不是应该站在我这边吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「你不是應該站在我這邊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00153",
		linknext = "0130_00155",
		line = 1928,
	},
	["0130_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"By all rights, I should be allied with this man.",
					{"rt2"},
				},
			},
			cn = {
				{
					"照理来说，我是应该服从于这个男人的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"照理來說，我是應該服從於這個男人的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00154",
		linknext = "0130_00156",
		line = 1938,
	},
	["0130_00156"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0223", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“If you still intend to continue in spite of all that, then show me what you've got. I'll be watching you from the best seat in the house.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“如果这样你还打算继续挣扎，那就让我看看吧——我会在特等席观赏的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「如果這樣你還打算繼續掙扎，那就讓我看看吧——我會在特等席觀賞的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00155",
		linknext = "0130_00157",
		line = 1950,
	},
	["0130_00157"] = {
		{"se", id=0, loop=0, file="se_a255"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He cuts off the call.",
					{"rt2"},
				},
			},
			cn = {
				{
					"电话被挂断了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"電話被掛斷了。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00156",
		linknext = "0130_00158",
		line = 1961,
	},
	["0130_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The electronic sound fades off, being drowned out by the evening cicada calls.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷冰冰的电子音，融入寒蝉的叫声中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷冰冰的電子音，融入寒蟬的叫聲中。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00157",
		linknext = "0130_00159",
		line = 1971,
	},
	["0130_00159"] = {
		{"se", id=0, loop=0, file="se_a053"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A number of shadows appear behind me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后我的背后，出现了复数的身影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後我的背後，出現了複數的身影。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00158",
		linknext = "0130_00160",
		line = 1982,
	},
	["0130_00160"] = {
		{"se", id=3, stop=1, time=6000},
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0089", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“I wouldn't blame ya's if ya wanted t' jes' cut 'n run.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“——就算逃跑也没关系啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「——就算逃跑也沒關係啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00159",
		linknext = "0130_00161",
		line = 1996,
	},
	["0130_00161"] = {
		{"bgm", file="bgm22", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Kenzou speaks, as if speaking for all the other old folks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"代表着岛上的老人们，健藏老人说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"代表著島上的老人們，健藏老人說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00160",
		linknext = "0130_00162",
		line = 2007,
	},
	["0130_00162"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0090", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“That li'l slip, Fumino... She's borne the burden of our selfish wish fer this island t' prosper, and now she's ended up in this state.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“那个孩子——文乃酱受到了我们这些岛民们‘想要繁荣’的虚荣心波及，才变成了那样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「那個孩子——文乃醬受到了我們這些島民們『想要繁榮』的虛榮心波及，才變成了那樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00161",
		linknext = "0130_00163",
		line = 2019,
	},
	["0130_00163"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0091", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“And laddie... we ain't got no bigger regret right now 'n that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“这事——我们老人也带着强烈的罪恶感。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「這事——我們老人也帶著強烈的罪惡感。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00162",
		linknext = "0130_00164",
		line = 2031,
	},
	["0130_00164"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00163",
		linknext = "0130_00165",
		line = 2043,
	},
	["0130_00165"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0092", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“If'n I can fix the you-know-what, ya should be able t'get off the island without havin' to go through the sea gate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“只要修好",
					{"ruby", text="・・"},
					"那个",
					{"/ruby"},
					"，应该不经过海门也能逃出去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「只要修好",
					{"ruby", text="・・"},
					"那個",
					{"/ruby"},
					"，應該不經過海門也能逃出去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00164",
		linknext = "0130_00166",
		line = 2055,
	},
	["0130_00166"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0093", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“An' if ya's both wanna leave, we'll support ya's however we can. We'll do whatever our sorry arses can ta clean up the mess here afterwards.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“如果你们两个人一起逃走的话，我们也会尽全力帮忙的。之后的事情，也会尽我所能打理的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「如果你們兩個人一起逃走的話，我們也會盡全力幫忙的。之後的事情，也會盡我所能打理的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00165",
		linknext = "0130_00167",
		line = 2067,
	},
	["0130_00167"] = {
