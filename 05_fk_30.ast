	["0130_00338"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The woman who saved me from the desperate solitude I was in.",
					{"rt2"},
				},
