	["0130_00247"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I made you a special chair. It's made of the same carbon fiber as the Penile Investigator. It shouldn't break, even if hit by a real bullet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我要给雏见特别制造的椅子。材料用了与‘珍神’相同的强化碳纤维。就算吃了实弹也不会坏掉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我要給雛見特別製造的椅子。材料用了與『珍神』相同的強化碳纖維。就算吃了實彈也不會壞掉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00246",
		linknext = "0130_00248",
		line = 3083,
	},
	["0130_00248"] = {
