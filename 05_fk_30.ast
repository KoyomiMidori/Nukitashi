		},
		text = {
			vo = {
				{"vo", file="nanase2343", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, so that's why you wanted me to submit a battle report. Thanks a ton, I'll put 'em to good use. How about I give you a little kiss in return?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“原来如此，让我再交战斗报告是这么回事啊……谢了，我收下了。作为回礼，要亲你一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「原來如此，讓我再交戰鬥報告是這麼回事啊……謝了，我收下了。作為回禮，要親你一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00234",
		linknext = "0130_00236",
		line = 2923,
	},
	["0130_00236"] = {
