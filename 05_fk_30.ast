		},
		linkback = "0130_00366",
		linknext = "0130_00368",
		line = 4559,
	},
	["0130_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And why I'm fighting now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是我现在，还在战斗的理由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是我現在，還在戰鬥的理由。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00367",
		linknext = "0130_00369",
		line = 4569,
	},
	["0130_00369"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if I'm to fulfill your wish, I'll need to be heard by the entire nation. There are things which must be conveyed to them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是为了实现文乃的愿望，需要有人出来向全国呼吁。有必须传达出来的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是為了實現文乃的願望，需要有人出來向全國呼籲。有必須傳達出來的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00368",
		linknext = "0130_00370",
		line = 4581,
	},
	["0130_00370"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So while we're fighting out there... I need you to stay here, so you can fight your own fight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，我们在那里战斗的时候——我希望文乃能在这里战斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，我們在那裡戰鬥的時候——我希望文乃能在這裡戰鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00369",
		linknext = "0130_00371",
		line = 4593,
	},
	["0130_00371"] = {
