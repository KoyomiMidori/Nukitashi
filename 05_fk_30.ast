					{"rt2"},
				},
			},
			cn = {
				{
					"想要变态做爱的人，和不想要变态做爱的人共存。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想要變態做愛的人，和不想要變態做愛的人共存。",
					{"rt2"},
				},
