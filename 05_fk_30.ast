	["0130_00347"] = {
		{"fg", file="fumino_02l_00001", file1="fumino_02l_00109", path=":fg/fumino_02l/", id=7, lv=5, head="fumino_02l", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She said she could forgive them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃说了要原谅。",
					{"rt2"},
				},
			},
