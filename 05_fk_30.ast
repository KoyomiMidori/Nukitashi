		linkback = "0130_00178",
		linknext = "0130_00180",
		line = 2207,
	},
	["0130_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I still insist on continuing to help them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还要继续帮助吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"還要繼續幫助嗎？",
					{"rt2"},
