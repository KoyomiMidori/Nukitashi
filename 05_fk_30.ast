		linkback = "0130_00346",
		linknext = "0130_00348",
		line = 4340,
	},
	["0130_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That she'd like to forgive all those endlessly fortunate people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她想要原谅所有幸福的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她想要原諒所有幸福的人。",
					{"rt2"},
				},
