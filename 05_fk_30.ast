	},
	["0130_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's all I answer with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的回答只有这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的回答只有這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00167",
		linknext = "0130_00169",
		line = 2089,
	},
	["0130_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we had the you-know-what on our side, we could escape, and just let the OSS building be destroyed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"实际上，只要有",
					{"ruby", text="・・"},
					"那个",
					{"/ruby"},
					"，就能直接无视SHO总部大楼逃出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"實際上，只要有",
					{"ruby", text="・・"},
					"那個",
					{"/ruby"},
					"，就能直接無視SHO總部大樓逃出去。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00168",
		linknext = "0130_00170",
		line = 2099,
	},
	["0130_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've known this for a long time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这件事，我早就理解了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這件事，我早就理解了。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00169",
		linknext = "0130_00171",
		line = 2109,
	},
	["0130_00171"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0094", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Well, if ya know all that, why in the bleedin' 'ell ain't ya gonna do it!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“那到底为什么……既然你都明白了，为什么不那么做呢……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「那到底為什麼……既然你都明白了，為什麼不那麼做呢……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00170",
		linknext = "0130_00172",
		line = 2121,
	},
	["0130_00172"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0095", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Ya despise all the people on the island, don't ya!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“你不是对岛上的所有人怀恨在心吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「你不是對島上的所有人懷恨在心嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00171",
		linknext = "0130_00173",
		line = 2133,
	},
	["0130_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The old folks must have read me completely by now. He raises his voice and continues.",
					{"rt2"},
				},
			},
			cn = {
				{
					"几乎知道了所有事情的老人高声问道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"幾乎知道了所有事情的老人高聲問道。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00172",
		linknext = "0130_00174",
		line = 2143,
	},
	["0130_00174"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0096", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Now, all of us ain't been affected equally... but ya oughta be givin' us the cold shoulder anyways!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“虽然这里的大家并没有直接参与……但也跟见死不救没两样啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「雖然這裡的大家並沒有直接參與……但也跟見死不救沒兩樣啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00173",
		linknext = "0130_00175",
		line = 2155,
	},
	["0130_00175"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0097", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“There ain't a damn reason in the world why ya oughta be helpin' us!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“所以那样的你，没有任何理由救我们——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「所以那樣的你，沒有任何理由救我們——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00174",
		linknext = "0130_00176",
		line = 2167,
	},
	["0130_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I began fighting out of anger. Hatred. Spite.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我会开始战斗，全是因为愤怒和憎恨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我會開始戰鬥，全是因為憤怒和憎恨。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00175",
		linknext = "0130_00177",
		line = 2177,
	},
	["0130_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The old folks are telling me that they fully acknowledge my right to cut and run.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但老人们还是包容了我自说自话的主张，接受了一切。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但老人們還是包容了我自說自話的主張，接受了一切。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00176",
		linknext = "0130_00178",
		line = 2187,
	},
	["0130_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet...",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00177",
		linknext = "0130_00179",
		line = 2197,
	},
	["0130_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I still insist on going on fighting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还要继续战斗吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"還要繼續戰鬥嗎？",
					{"rt2"},
				},
			},
