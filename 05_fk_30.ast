				{"vo", file="misaki2147", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But for a long-shunned plain Jane like myself, this is the chance of a lifetime to make a big impression! I can do it, I'm sure of it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……这是我作为一个平凡而阴阳怪气的人所迎来的一生中最精彩的舞台！我一定会成功的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……這是我作為一個平凡而陰陽怪氣的人所迎來的一生中最精彩的舞臺！我一定會成功的！」",
					{"rt2"},
				},
			},
		},
