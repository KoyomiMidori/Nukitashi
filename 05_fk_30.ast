	["0130_00318"] = {
		{"fg", file="fumino_02l_00001", file1="fumino_02l_00103", path=":fg/fumino_02l/", id=7, lv=5, head="fumino_02l", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
