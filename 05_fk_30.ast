	["0130_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mr. Teshima's voice echoes in the dimly lit basement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"昏暗的地下室，手嶋先生的声音回响着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"昏暗的地下室，手嶋先生的聲音迴響著。",
