astver = 2.0
ast = {
	["0130_00001"] = {
		{"fg", mode=-1, id=30},
		{"savetitle", text="我が誉れ", ja="我が誉れ", en="Honor", cn="芳名留世", tw="自身榮譽"},
		{"eval", exp="g.05_fk_30=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg10_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After that we stayed in various houses in the settlement moving from one to another.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那以后，我们在村子里的家辗转。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從那以後，我們在村子裡的家輾轉。",
					{"rt2"},
				},
			},
		},
		linknext = "0130_00002",
		line = 18,
	},
	["0130_00002"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0149", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "警備兵A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Guard A"},
					"“We have heard rumors of pro-copulation individuals being sheltered here! Do you know anything of that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "警备兵A"},
					"“……我听说这里潜伏着‘交尾势力’的人！你知道吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "警備兵A"},
					"「……我聽說這裡潛伏著『交尾勢力』的人！你知道嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00001",
		linknext = "0130_00003",
		line = 31,
	},
	["0130_00003"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0077", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Whatzat? Yer lookin' fer low vegetation? This ain't a desert island or nothin'!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“啥……？昨天的晚饭是味噌青花鱼啊……和这个不一样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「啥……？昨天的晚飯是味噌青花魚啊……和這個不一樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00002",
		linknext = "0130_00004",
		line = 43,
	},
	["0130_00004"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0150", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "警備兵A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Guard A"},
					"“Tch, goddamn senile old fart... I'll look somewhere else!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "警备兵A"},
					"“切，痴呆老人……找其他的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "警備兵A"},
					"「呿，癡呆老人……找其他的！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00003",
		linknext = "0130_00005",
		line = 55,
	},
	["0130_00005"] = {
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg24_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bg", id=1, file="bg24_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bgm", file="bgm07", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0078", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“They're gone now. Y'can come out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“……他们已经走了，没事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「……他們已經走了，沒事了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00004",
		linknext = "0130_00006",
		line = 74,
	},
	["0130_00006"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seriously, thanks. We owe you one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思，谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思，謝謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00005",
		linknext = "0130_00007",
		line = 86,
	},
	["0130_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the old folks in the settlement are sheltering us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这样，老人们把我们藏在了村里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就這樣，老人們把我們藏在了村裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00006",
		linknext = "0130_00008",
		line = 96,
	},
	["0130_00008"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0079", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“T'warn't nothin', lad. At any rate, some o' me fellow geezers went 'n did some recon for ya.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“没事，没什么好在意的……对了，我们这的老头子们还去侦查了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「沒事，沒什麼好在意的……對了，我們這的老頭子們還去偵查了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00007",
		linknext = "0130_00009",
		line = 108,
	},
	["0130_00009"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0080", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“There's all sorts of machinery and whatsits bein' transported to OSS HQ. Stuff like cranes. Stuff ya'd use fer demolition.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“SHO总部大楼里好像聚集了很多器材。吊车之类的解体车开来了很多。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「SHO總部大樓裡好像聚集了很多器材。吊車之類的解體車開來了很多。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00008",
		linknext = "0130_00010",
		line = 120,
	},
	["0130_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So that's the last holdout, then?",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然，最后是那里吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然，最後是那裡嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00009",
		linknext = "0130_00011",
		line = 130,
	},
	["0130_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I recall what Mr. Sakimori said.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想起了防人老人的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想起了防人老人的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00010",
		linknext = "0130_00012",
		line = 140,
	},
	["0130_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having greatly reduced our ability to act on the island, the progress of the demolition of island facilities has accelerated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自从我们的行动开始不方便之后，岛内设施的拆除就急速进行着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自從我們的行動開始不方便之後，島內設施的拆除就急速進行著。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00011",
		linknext = "0130_00013",
		line = 150,
	},
	["0130_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The OSS HQ building is the only thing left.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在只剩下SHO总部大楼了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在只剩下SHO總部大樓了。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00012",
		linknext = "0130_00014",
		line = 160,
	},
	["0130_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the heart of the island, and the facility where all functionality is managed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是岛的心脏，掌管所有功能的设施。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是島的心臟，掌管所有功能的設施。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00013",
		linknext = "0130_00015",
		line = 170,
	},
	["0130_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Searching for non-conformers, operation of the sea gate, health checks, information control, etc. Everything was managed in that one place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"检查不适合者，海门的开闭，健康管理，信息统筹等。SHO的一切都在那里面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"檢查不適合者，海門的開閉，健康管理，資訊統籌等。SHO的一切都在那裡面。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00014",
		linknext = "0130_00016",
		line = 180,
	},
	["0130_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Without that operating, the island will come to a complete standstill.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果失去了那里，青蓝岛的机能就完全停摆了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果失去了那裡，青藍島的機能就完全停擺了。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00015",
		linknext = "0130_00017",
		line = 190,
	},
	["0130_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All that would be left behind for the island's residents would be more and more despair...",
					{"rt2"},
				},
			},
			cn = {
				{
					"故意把它留到最后，将为居民带来更加强烈的绝望——",
					{"rt2"},
				},
			},
			tw = {
				{
					"故意把它留到最後，將為居民帶來更加強烈的絕望——",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00016",
		linknext = "0130_00018",
		line = 200,
	},
	["0130_00018"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0081", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Me boys tell me the demolition's on fer tonight. Probably at the time when everybody's most likely to hear it. Buncha fuckin' shitheads... tryin'a be all ostentatious about 'er.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“根据老头子掌握的信息，拆除将在今晚进行……大概是打算在声音回响最厉害的时候进行，真是混蛋……那还真是盛大……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「根據老頭子掌握的資訊，拆除將在今晚進行……大概是打算在聲音迴響最厲害的時候進行，真是混蛋……那還真是盛大……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00017",
		linknext = "0130_00019",
		line = 212,
	},
	["0130_00019"] = {
		{"bg", id=1, file="bg24_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2337", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“He mentioned something about having a front row seat for it, too... What a fucking ghoul.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“他还说要坐在特等席上看着……真是够恶心人的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「他還說要坐在特等席上看著……真是夠噁心人的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00018",
		linknext = "0130_00020",
		line = 227,
	},
	["0130_00020"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2265", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Wait, wouldn't that mean Sakimori's gonna be coming to the island himself, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？不过这也就是说，防人爷爷要来这个岛了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？不過這也就是說，防人爺爺要來這個島了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00019",
		linknext = "0130_00021",
		line = 241,
	},
	["0130_00021"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00104", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1823", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That'd make sense... For all we know, he might already be on the island by now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是啊……或许防人老人现在已经来到这个岛上了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是啊……或許防人老人現在已經來到這個島上了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00020",
		linknext = "0130_00022",
		line = 255,
	},
	["0130_00022"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=3, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="美岬", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2140", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But where will he be, exactly? Wouldn't the OSS building be the safest place on the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“可是他在哪里呢？按照常理来想，这个岛上最安全的地方应该是SHO总部大楼吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「可是他在哪裡呢？按照常理來想，這個島上最安全的地方應該是SHO總部大樓吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00021",
		linknext = "0130_00023",
		line = 269,
	},
	["0130_00023"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not if he's going to demolish it. If he truly wants to see everyone despairing about it... it'd have to be the place with the best view of the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，如果说要破坏SHO总部大楼，然后看着对此露出的绝望表情的话……应该会在可以把这个岛尽收眼底的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，如果說要破壞SHO總部大樓，然後看著對此露出的絕望表情的話……應該會在可以把這個島盡收眼底的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00022",
		linknext = "0130_00024",
		line = 281,
	},
	["0130_00024"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2338", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun, those old Japanese army bases were reconstructed, so that means Sakimori has detailed knowledge of the facilities.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……淳，既然他改造了那个旧日本军的基地，说明防人老人很精通那种设施吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……淳，既然他改造了那個舊日本軍的基地，說明防人老人很精通那種設施吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00023",
		linknext = "0130_00025",
		line = 295,
	},
	["0130_00025"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh right, the old battleground site!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——原来如此，那个战场遗址！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——原來如此，那個戰場遺址！」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00024",
		linknext = "0130_00026",
		line = 307,
	},
	["0130_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You can see the whole island from up there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那里可以看到整个岛屿。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡可以看到整個島嶼。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00025",
		linknext = "0130_00027",
		line = 317,
	},
	["0130_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That former battleground site was established on the summit of the mountain to be able to observe and protect the whole island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"战场遗址本来就是为了进行绝对防卫战而被设计在山顶上的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"戰場遺址本來就是為了進行絕對防衛戰而被設計在山頂上的。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00026",
		linknext = "0130_00028",
		line = 327,
	},
	["0130_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a genuine military base which you can position soldiers in various places, with watchtowers, and ground and aircraft cannons.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不仅可以在各处配置士兵，还有瞭望塔，是个包办对地炮和对空炮的真正军事设施。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不僅可以在各處配置士兵，還有瞭望塔，是個包辦對地炮和對空砲的真正軍事設施。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00027",
		linknext = "0130_00029",
		line = 337,
	},
	["0130_00029"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, what's their total military strength in numbers?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……麻沙酱，敌人的综合战斗力大概是多少？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……麻沙醬，敵人的綜合戰鬥力大概是多少？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00028",
		linknext = "0130_00030",
		line = 349,
	},
	["0130_00030"] = {
		{"se", id=0, loop=0, file="se_b031"},
		{"fg", file="asane_01m_00002", file1="asane_01m_00104", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1824", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Adding up the total from all our battles so far, I'm getting an aggregate of 173 soldiers. Factoring in their skill, the best possible odds of us getting through this are roughly... 647 to 5.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“从迄今的战斗统计来看……战斗兵约173人。实力差距，包括期望性观测是……647:5。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「從迄今的戰鬥統計來看……戰鬥兵約173人。實力差距，包括期望性觀測是……647:5。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00029",
		linknext = "0130_00031",
		line = 364,
	},
	["0130_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The enemy vastly outnumbers us, with 5 against 173.",
					{"rt2"},
				},
			},
			cn = {
				{
					"敌人士兵有173人，而我们只有5人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"敵人士兵有173人，而我們只有5人。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00030",
		linknext = "0130_00032",
		line = 374,
	},
	["0130_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not to mention, they're better trained and better equipped than us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对面的战斗装备也更加有利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對面的戰鬥裝備也更加有利。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00031",
		linknext = "0130_00033",
		line = 384,
	},
	["0130_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yeah... Those aren't good odds.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实……是令人绝望的战斗力差距。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實……是令人絕望的戰鬥力差距。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00032",
		linknext = "0130_00034",
		line = 394,
	},
	["0130_00034"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0082", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“I'unno if them former army facilities're still active, but it's gonna be a roight pain t'break through regardless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“不知道旧军队的设备还有没有活着，但不管怎么样都很难突破吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「不知道舊軍隊的設備還有沒有活著，但不管怎麼樣都很難突破吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00033",
		linknext = "0130_00035",
		line = 406,
	},
	["0130_00035"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0083", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“An' if they use them artillery batteries, yer numbers ain't gonna matter if'n they kin jes' blow 'em away wit' one shot. Ya got no hopes o' winnin', t'be honest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“再加上如果炮台还能用的话，再多人都是一炮解决。你们没有胜算……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「再加上如果砲臺還能用的話，再多人都是一炮解決。你們沒有勝算……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00034",
		linknext = "0130_00036",
		line = 418,
	},
	["0130_00036"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00120", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2339", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I doubt it'd be easy to send a scout in to infiltrate that summit beforehand. Especially right before the demolition goes ahead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“因为是可以一览全岛的山顶，要先潜入侦察也不容易……想事先破坏也很困难呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為是可以一覽全島的山頂，要先潛入偵察也不容易……想事先破壞也很困難呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00035",
		linknext = "0130_00037",
		line = 432,
	},
	["0130_00037"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Say, Mr. Kenzou. You got any update on the progress for... you know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“健藏先生——",
					{"ruby", text="・・"},
					"那个",
					{"/ruby"},
					"怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「健藏先生——",
					{"ruby", text="・・"},
					"那個",
					{"/ruby"},
					"怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00036",
		linknext = "0130_00038",
		line = 444,
	},
	["0130_00038"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0084", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“You know...? Oh, THAT 'you know'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“那个啊……难道是",
					{"ruby", text="・・"},
					"那个",
					{"/ruby"},
					"吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「那個啊……難道是",
					{"ruby", text="・・"},
					"那個",
					{"/ruby"},
					"嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00037",
		linknext = "0130_00039",
		line = 456,
	},
	["0130_00039"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0085", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“If I can git 'er workin' again, it could do a right number on their land & air artillery. But we ain't got the parts for 'er.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“如果成功的话，那个的确可以一发打爆炮台和对空炮……但是没有零件哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「如果成功的話，那個的確可以一發打爆砲臺和對空砲……但是沒有零件哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00038",
		linknext = "0130_00040",
		line = 468,
	},
	["0130_00040"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So if you had the parts, you'd be able to get it done, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要有零件就行了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要有零件就行了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00039",
		linknext = "0130_00041",
		line = 480,
	},
	["0130_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wouldn't have been able to previously, but I've recently gotten some experience and making various things.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然对以前的我来说是不可能的事情，但是现在的我有制造过各种各样东西的经验。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然對以前的我來說是不可能的事情，但是現在的我有製造過各種各樣東西的經驗。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00040",
		linknext = "0130_00042",
		line = 490,
	},
	["0130_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We have limited time, but there should be enough time to make it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然时间有限，但要在时间之内制作应该是可能的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然時間有限，但要在時間之內製作應該是可能的。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00041",
		linknext = "0130_00043",
		line = 500,
	},
	["0130_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He scratches his head and nods.",
					{"rt2"},
				},
			},
			cn = {
				{
					"健藏抓抓脑袋，点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"健藏抓抓腦袋，點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00042",
		linknext = "0130_00044",
		line = 510,
	},
	["0130_00044"] = {
		{"se", id=0, loop=0, file="se_b067"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0086", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Roight! I'm still a man! I didn't log all that time as an engineer in th'army fer nothin'! I'll get that bugger workin', or so help me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“……好，我也是男人！赌上原整备兵的名号，我一定会让它动起来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「……好，我也是男人！賭上原整備兵的名號，我一定會讓它動起來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00043",
		linknext = "0130_00045",
		line = 523,
	},
	["0130_00045"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thank you... Really.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你……健藏先生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你……健藏先生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00044",
		linknext = "0130_00046",
		line = 535,
	},
	["0130_00046"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0087", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“But even so... I'm sure ya's understand as much's I do, but it don't matter how gung-ho y'all are, yer still jes' five in number. Ya cain't pull off a battle like that with them numbers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“可是——你们也知道，无论多么精锐，也没办法5个人攻入那里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「可是——你們也知道，無論多麼精銳，也沒辦法5個人攻入那裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00045",
		linknext = "0130_00047",
		line = 548,
	},
	["0130_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Destroying the batteries isn't enough for just five people to infiltrate a former military base.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算摧毁了炮台之类的，还是不可能只靠5个人突破前日军的设施。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算摧毀了砲臺之類的，還是不可能只靠5個人突破前日軍的設施。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00046",
		linknext = "0130_00048",
		line = 558,
	},
	["0130_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unfeasible is hardly the adequate word for it. Suicidal seems more apt.",
					{"rt2"},
				},
			},
			cn = {
				{
					"太不现实了，几乎是自杀行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"太不現實了，幾乎是自殺行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00047",
		linknext = "0130_00049",
		line = 568,
	},
	["0130_00049"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0088", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“But maybe if ya had one more wit' ya's... T'wouldn't be impossible if we're talkin' about a team o' six.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“最低至少还需要1个人——没有6个人，是绝对不可能突破。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「最低至少還需要1個人——沒有6個人，是絕對不可能突破。」",
					{"rt2"},
				},
			},
