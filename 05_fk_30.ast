	["0130_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And...",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后——",
					{"rt2"},
