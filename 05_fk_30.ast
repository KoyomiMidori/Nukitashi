		line = 3933,
	},
	["0130_00313"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is most unusual for her, given that she always listens to what her master says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这对把主人说的事情当成绝对的少女来说，非常罕见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這對把主人說的事情當成絕對的少女來說，非常罕見。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00312",
		linknext = "0130_00314",
		line = 3943,
	},
	["0130_00314"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00103", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1370", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I shall protect everyone's backs. I will take on hundreds of enemies if need be for you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“各位的后背，我一定会守住……就算是上百个敌人，我也会全部打倒……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「各位的後背，我一定會守住……就算是上百個敵人，我也會全部打倒……」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00313",
		linknext = "0130_00315",
		line = 3957,
	},
	["0130_00315"] = {
		{"text"},
		text = {
