	["0130_00240"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm giving you this tablet case. It's much tougher than an ordinary one. If something happens, hit an enemy as hard as you can with it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“给你这个平板。这比一般的平板强度还要高。如果有什么事，就用它来打败敌人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「給你這個平板。這比一般的平板強度還要高。如果有什麼事，就用它來打敗敵人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00239",
		linknext = "0130_00241",
		line = 2990,
	},
	["0130_00241"] = {
