	["0130_00312"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1369", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I can be of use to you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文乃……能帮助您……”",
					{"rt2"},
