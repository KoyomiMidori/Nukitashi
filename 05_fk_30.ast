	["0130_00362"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1379", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You would do all that... for me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“全部……都是为了……我……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「全部……都是為了……我……？」",
