		linkback = "0130_00361",
		linknext = "0130_00363",
		line = 4503,
	},
	["0130_00363"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You've given up everything for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃，你为了我，奉献了一切。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃，你為了我，奉獻了一切。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00362",
		linknext = "0130_00364",
		line = 4515,
	},
	["0130_00364"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So I want to gamble on everything I have for you. Go big or go home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，为了你，我要赌上一切战斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，為了你，我要賭上一切戰鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00363",
		linknext = "0130_00365",
		line = 4527,
	},
	["0130_00365"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I made up my mind about that long ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“很久以前，我就已经下定决心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「很久以前，我就已經下定決心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00364",
		linknext = "0130_00366",
		line = 4539,
	},
	["0130_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's the real reason I'm staying here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是我继续留在这里的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是我繼續留在這裡的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00365",
		linknext = "0130_00367",
		line = 4549,
	},
	["0130_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why I won't run away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是我不想逃避的理由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是我不想逃避的理由。",
					{"rt2"},
				},
