		linkback = "0130_00347",
		linknext = "0130_00349",
		line = 4350,
	},
	["0130_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That she'd like to forgive them the way her mother did.",
