		linkback = "0130_00180",
		linknext = "0130_00182",
		line = 2227,
	},
	["0130_00182"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0098", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Can ya... forgive us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“……你能够原谅我们吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「……你能夠原諒我們嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00181",
		linknext = "0130_00183",
		line = 2239,
	},
	["0130_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I'm going to go on fighting in the name of people whom I've despised for so long...",
					{"rt2"},
				},
			},
			cn = {
				{
					"他这么问道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他這麼問道。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00182",
		linknext = "0130_00184",
		line = 2249,
	},
	["0130_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Does that mean I've forgiven them all?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为一直憎恨的人们战斗，就等于是宽恕了一切。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為一直憎恨的人們戰鬥，就等於是寬恕了一切。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00183",
		linknext = "0130_00185",
		line = 2259,
	},
	["0130_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's plain to see that's what he's really asking me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"你要这么做吗——他如此问道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"你要這麼做嗎——他如此問道。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00184",
		linknext = "0130_00186",
		line = 2269,
	},
	["0130_00186"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0099", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Ya still got time before they make their move. Thanks to all them parts ya made fer me, the repairs are goin' smoothly. I reckon she'll be ready fer prime time by nightfall.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“……在作战行动之前还有时间。多亏你制造的零件，整备很顺利。应该晚上就能动了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「……在作戰行動之前還有時間。多虧你製造的零件，整備很順利。應該晚上就能動了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00185",
		linknext = "0130_00187",
		line = 2281,
	},
	["0130_00187"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0100", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“If you make use of 'er now... ya kin jes' vanish into th' night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“只要用那个——现在的话，可以让你们不被发现。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「只要用那個——現在的話，可以讓你們不被發現。」",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00186",
		linknext = "0130_00188",
		line = 2293,
	},
	["0130_00188"] = {
		{"text"},
		text = {
