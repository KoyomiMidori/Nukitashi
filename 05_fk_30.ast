	["0130_00342"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't bring myself to save the people responsible for the death of my savior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不想帮助把恩人逼上死路的岛上的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不想幫助把恩人逼上死路的島上的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0130_00341",
		linknext = "0130_00343",
		line = 4281,
	},
	["0130_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'd prefer to avenge her death, if I could.",
					{"rt2"},
