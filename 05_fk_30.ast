			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“My own personal weapon! Thanks! I won't lose to anyone when I've got my chair! You can be comfortable in relying on your big sister, Jun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是我专用的武器呢……！谢谢！我有椅子的时候不会输给任何人！放心地依靠姐姐吧，淳君！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是我專用的武器呢……！謝謝！我有椅子的時候不會輸給任何人！放心地依靠姐姐吧，淳君！」",
					{"rt2"},
				},
			},
		},
