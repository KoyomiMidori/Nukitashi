	["0130_00104"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The first time I was in a tight spot was when I was about to be caught by the SS at school, and you saved me by sniping from the mountains.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最初的危机……是在学校中差点被FS抓到的时候，你从山那边狙击帮助了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最初的危機……是在學校中差點被FS抓到的時候，你從山那邊狙擊幫助了我。」",
					{"rt2"},
				},
			},
		},
