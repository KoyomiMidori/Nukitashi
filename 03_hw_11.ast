					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No... Solo tengo que volverme más fuerte.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……因为我必须变得更强。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……因為我必須變得更強。」",
					{"rt2"},
				},
