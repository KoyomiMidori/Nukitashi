		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"se", id=1, loop=1, file="se_a222", vol=80},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei-senpai utilizó su autoridad como presidenta del comité de moral pública para conseguir una pequeña embarcación y partir hacia la sede de la OSS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们利用风纪委员长的权限搭乘小型船前往了SHO的总部。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們利用風紀委員長的權限搭乘小型船前往了SHO的總部。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00447",
		linknext = "0061_00449",
		line = 5824,
	},
	["0061_00449"] = {
		{"bg", id=1, file="bg25_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Para entrar o salir legítimamente de la isla por mar, tanto los ciudadanos como los forasteros deben someterse a una inspección.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管是岛民还是外地人，要想离开这个岛就必须经过SHO进行入岛审查的海门。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管是島民還是外地人，要想離開這個島就必須經過SHO進行入島審查的海門。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00448",
		linknext = "0061_00450",
		line = 5838,
	},
	["0061_00450"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso incluye, obviamente, a cualquier forajido que secuestrara al gobernador.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，就算是绑架县知事的犯罪者也是一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，就算是綁架縣知事的犯罪者也是一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00449",
		linknext = "0061_00451",
		line = 5848,
	},
	["0061_00451"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Para eludir la inspección y entrar por la fuerza, tendrían que tomar la torre de control de la OSS y forzar la apertura de la puerta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果想无视海门强行突破，就有必要控制SHO管制塔并强制开门。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果想無視海門強行突破，就有必要控制SHO管制塔並強制開門。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00450",
		linknext = "0061_00452",
		line = 5858,
	},
	["0061_00452"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo mejor que podemos hacer ahora es intentar defender la torre de control, así que nos dirigimos al cuartel general de la OSS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，我们应该最先进行的是控制塔的防卫——为此我们要前往SHO的总部。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，我們應該最先進行的是控制塔的防衛——為此我們要前往SHO的總部。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00451",
		linknext = "0061_00453",
		line = 5868,
	},
	["0061_00453"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero ¿por qué lo secuestrarían?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……为什么仁浦先生会被盯上呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……為什麼仁浦先生會被盯上呢？」",
