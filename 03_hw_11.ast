	["0061_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta empresa de renombre opera en todo el país, pero permitió que sus productos dispensaran afrodisíacos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们本身是在全国开拓市场的认真厂牌——但现在却掺入了媚药。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們本身是在全國開拓市場的認真廠牌——但現在卻摻入了媚藥。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00156",
		linknext = "0061_00158",
		line = 2058,
	},
	["0061_00158"] = {
		{"text"},
		text = {
