					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero fue gracias a ti que nos atraparon! ¿No te parece increíble? Agáchate y déjame acariciarte la... cabeza... uhh...”",
