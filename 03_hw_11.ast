	},
	["0061_00626"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que por eso me desmayé.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是吗？我因此失去了意识吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是嗎？我因此失去了意識嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00625",
		linknext = "0061_00627",
		line = 8415,
	},
	["0061_00627"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo siento... Aun cuando me diste esa oportunidad, fallé en mi primer intento...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思……你明明帮我做出了空隙，我却没能一枪击中……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思……你明明幫我做出了空隙，我卻沒能一槍擊中……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00626",
		linknext = "0061_00628",
		line = 8426,
	},
	["0061_00628"] = {
		{"fg", file="rei_01l_00006", file1="rei_01l_00107", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0592", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No seas tonto. Te enfrentaste a una guardia de la OSS como aprendiz de la SS y ganaste. Deberías estar orgulloso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“笨蛋。FS的训练生把SHO警卫打倒了。这是一件值得骄傲的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「笨蛋。FS的訓練生把SHO警衛打倒了。這是一件值得驕傲的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00627",
		linknext = "0061_00629",
		line = 8440,
	},
	["0061_00629"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00628",
		linknext = "0061_00630",
		line = 8451,
	},
	["0061_00630"] = {
		{"fg", file="rei_01l_00006", file1="rei_01l_00124", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4700] = {
				{"fg", file="rei_01l_00006", file1="rei_01l_00107", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, delay2=4700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0593", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Por supuesto. Mi petición era algo descabellado, pero fuiste capaz de cumplirla. Gracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊。我才不好意思，让你这么胡来……你做得很好，我很感谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊。我才不好意思，讓你這麼胡來……你做得很好，我很感謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00629",
		linknext = "0061_00631",
		line = 8467,
	},
	["0061_00631"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me alegra escuchar a alguien decirme eso con tanta sinceridad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到她这么说，我真的很高兴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到她這麼說，我真的很高興。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00630",
		linknext = "0061_00632",
		line = 8477,
	},
	["0061_00632"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0594", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Te dieron un tiro en la cabeza. Tardarás un poco en recuperar todas tus fuerzas. Por ahora, descansa; la SS te llevará a casa.”",
					{"rt2"},
				},
			},
