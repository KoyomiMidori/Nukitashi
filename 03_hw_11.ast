		linkback = "0061_00617",
		linknext = "0061_00619",
		line = 8320,
	},
	["0061_00619"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus ojos hermosos me miran, teniendo como telón de fondo el cielo nocturno.",
					{"rt2"},
				},
			},
			cn = {
				{
					"背对着夜空，漂亮的眼睛俯视着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"背對著夜空，漂亮的眼睛俯視著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00618",
		linknext = "0061_00620",
		line = 8330,
	},
	["0061_00620"] = {
		{"text"},
		text = {
