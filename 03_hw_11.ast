		line = 1761,
	},
	["0061_00132"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0084", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "男子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Estudiante A"},
					"“¿¡Así que una polla no te basta!? ¡Pues te daré dos! ¡Aaargh! Joder, voy a correrme en este coño... ¡EMBARÁZATEEE!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "男学生A"},
					"“怎么你一根鸡巴不够吗！？那我将成为你的第二根……啊啊啊啊！哈……小穴、小穴好厉害……怀孕吧喂！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "男學生A"},
					"「怎麼你一根肉棒不夠嗎！？那我將成為你的第二根……啊啊啊啊！哈……小穴、小穴好厲害……懷孕吧喂！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00131",
		linknext = "0061_00133",
		line = 1773,
	},
	["0061_00133"] = {
		{"text"},
		text = {
