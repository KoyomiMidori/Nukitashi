				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana, ¿puedes usar ambas manos? No te seré de mucha ayuda con esta pierna. Te daré la señal desde atrás para que rescates al senador Hitoura. ¿Puedes hacerlo?”",
					{"rt2"},
				},
			},
