		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1189", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tiene razón! ¡Eres un héroe! La SS pensaba que iba a atraparnos con eso, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“奈奈濑酱说的没错！我觉得这是件很了不起的事！这是FS的人为了找到我们而做的事情对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「奈奈瀨醬說的沒錯！我覺得這是件很了不起的事！這是FS的人為了找到我們而做的事情對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00399",
		linknext = "0061_00401",
		line = 5138,
	},
	["0061_00401"] = {
