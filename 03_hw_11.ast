				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Un afrodisíaco tan potente que ni siquiera Rei-senpai puede resistirse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，还是连礼前辈都无法忍受的强力媚药。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，還是連禮前輩都無法忍受的強力媚藥。",
					{"rt2"},
				},
			},
		},
