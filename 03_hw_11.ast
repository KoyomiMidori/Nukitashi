		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apresuro el escaneo mientras Wata-chan me gana tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"趁着渡酱帮我争取时间，我赶快扫描资料。",
					{"rt2"},
				},
			},
			tw = {
				{
					"趁著渡醬幫我爭取時間，我趕快掃描資料。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00038",
		linknext = "0061_00040",
		line = 494,
	},
	["0061_00040"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00101", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0530", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Hinami...? Es raro que estés aquí tan temprano. ¿Pasa algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见……？真少见啊，在这么早的时间……发生什么事了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見……？真少見啊，在這麼早的時間……發生什麼事了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00039",
		linknext = "0061_00041",
		line = 507,
	},
	["0061_00041"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00102", file2="hinami_01f_00202", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1165", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Eh?! N-N-N-Nada... um... No pasa nada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶！？什、什、什么也没有啊……真是的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸！？什、什、什麼也沒有啊……真是的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00040",
		linknext = "0061_00042",
		line = 520,
	},
	["0061_00042"] = {
