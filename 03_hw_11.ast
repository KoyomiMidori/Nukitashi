	["0061_00500"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00111", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0574", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“... Tachibana. Eres la persona más débil aquí, y eso incluye a todos los guardias inconscientes de la OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……橘，你是这里面最弱的。包括倒下的SHO警卫在内，在这里的人当中你是最弱的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……橘，你是這裡面最弱的。包括倒下的SHO警衛在內，在這裡的人當中你是最弱的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00499",
