	["0061_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Necesito tener una asistencia perfecta a los entrenamientos extraescolares de la SS, así que hago lo que puedo como líder del NLNS cuando estoy disponible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后一定要参加FS的训练，所以作为NLNS的队长，这种时候必须尽可能地露面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後一定要參加FS的訓練，所以作為NLNS的隊長，這種時候必須盡可能地露面。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00124",
		linknext = "0061_00126",
		line = 1693,
	},
	["0061_00126"] = {
		{"bgm", file="bgm08", vol=100},
		{"bg", id=2, file="bg15_1_1l_00000", x=300, y=-200, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-455, y=-5, time=20000, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0230", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "意識が高い女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante autoconsciente"},
					"“¡Hyaaah, tu polla es tan innovadora! ¡No tenía inversión previa, y aun así tomaste la iniciativa, perturbando mi coño sin más! ¡M-Me voy a correr en el futuro que siempre he soñado, ahhh!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "自以为是的女学生"},
					"“呀啊啊啊多么激昂的鸡巴啊！没有预约就夺走主导权对小穴放肆调节！要、要、要创新了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "自以為是的女學生"},
					"「呀啊啊啊多麼激昂的肉棒啊！沒有預約就奪走主導權對小穴放肆調節！要、要、要創新了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00125",
		linknext = "0061_00127",
		line = 1708,
	},
	["0061_00127"] = {
		{"se", id=0, loop=1, file="se_d012"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vaya, veo que hoy están trabajando mucho en la autoconciencia. Eso es admirable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。今天也在努力做着自我感觉良好的变态做爱……真令人佩服。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。今天也在努力做著自我感覺良好的變態做愛……真令人佩服。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00126",
		linknext = "0061_00128",
		line = 1721,
	},
	["0061_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Solo soy un cadete, pero sigo siendo miembro de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是训练生，但我还是FS的一员。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是訓練生，但我還是FS的一員。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00127",
		linknext = "0061_00129",
		line = 1731,
	},
	["0061_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tengo que aparentar, al menos en la escuela.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在学校里，必要表现得像个FS。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在學校裡，必要表現得像個FS。",
