	["0061_00415"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00112", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0547", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Eh? Hoy estás muy animado, ¿no? ¿Pasó algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哦？今天比平时更来劲呢……发生什么事了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哦？今天比平時更來勁呢……發生什麼事了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00414",
		linknext = "0061_00416",
		line = 5362,
	},
	["0061_00416"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
