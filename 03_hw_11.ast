		line = 1741,
	},
	["0061_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La ventaja de que todos sepan que soy la cuota de la impotencia es que ya nadie se me acerca para tener sexo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"训练生中有个阳痿的消息似乎已经传开了——最近都没人来邀请我做爱了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"訓練生中有個陽痿的消息似乎已經傳開了——最近都沒人來邀請我做愛了。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00129",
		linknext = "0061_00131",
		line = 1751,
	},
	["0061_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me miran raro, pero al menos ya no tengo que huir constantemente de los buscadores de sexo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然也有被人用怪异的眼神看待过，但不用害怕性触者这点对我非常有利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然也有被人用怪異的眼神看待過，但不用害怕性觸者這點對我非常有利。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00130",
