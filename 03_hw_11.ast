			},
			en = {
				{
					"Tras haberse corrido, Senba-san cae al suelo y se pone a temblar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直到刚才都还在高潮的仙波小姐，现在躺在那里微微颤抖着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直到剛才都還在高潮的仙波小姐，現在躺在那裡微微顫抖著。",
					{"rt2"},
				},
			},
		},
