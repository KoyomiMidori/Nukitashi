			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿De qué hablas, idiota? Hotori no toma eso si puede evitarlo, pero las demás no bebieron esa agua porque les avisaste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨——蛋。你在说什么啊。如果没有你的情报，除了美岬以外全员都会喝到哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨——蛋。你在說什麼啊。如果沒有你的情報，除了美岬以外全員都會喝到哦？」",
