	},
	["0061_00577"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Usé 'eso' para que se desmayara y tomé su cuchillo para cortar las ataduras que nos colocó.",
					{"rt2"},
