		linkback = "0061_00577",
		linknext = "0061_00579",
		line = 7703,
	},
	["0061_00579"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuando pasó eso, Rei-senpai no pudo mirar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"前辈在性行为途中一直背对着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"前輩在性行為途中一直背對著我。",
