					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aquí ATM-01. Me he infiltrado en la oficina del comité de moral pública. ¿Hay rastros del enemigo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这里是ATM-01，成功潜入风纪委员室。敌人呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這裡是ATM-01，成功潛入風紀委員室。敵人呢？」",
					{"rt2"},
				},
			},
		},
		linknext = "0061_00002",
		line = 19,
