		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me encantaría saber cómo es una conversación informal típica entre ellas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那两个人平时都在讲些什么啊？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那兩個人平時都在講些什麼啊？",
