	["0061_00587"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00121", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
