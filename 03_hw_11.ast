			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? Ah... p-pues... um... un poco... ¿no? Aja... ¡ajajajaja...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……啊……嘛……那个……大概……还记得吧？啊哈哈、啊哈哈……！”",
