		{"bgm", file="bgm07", vol=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1173", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ya volvimos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“前辈回来啰——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「前輩回來囉——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00073",
		linknext = "0061_00075",
		line = 1032,
	},
	["0061_00075"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1869", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Lo hicieron muy bien. Aun así, fue un poco arriesgado, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，两人都辛苦了……不过，应该挺危险的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，兩人都辛苦了……不過，應該挺危險的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00074",
		linknext = "0061_00076",
		line = 1045,
	},
	["0061_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya estoy acostumbrado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种程度我已经习惯了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種程度我已經習慣了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00075",
		linknext = "0061_00077",
		line = 1057,
	},
	["0061_00077"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo, tengo que felicitar a Wata por mantener ocupada a Rei-senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，还是多亏渡酱拖住了她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，還是多虧渡醬拖住了她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00076",
		linknext = "0061_00078",
		line = 1069,
	},
	["0061_00078"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1174", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Jeje, por supuesto! ¡Solo cumplo con mi deber como tu senpai!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哼哼，没事没事！我只是作为前辈帮了理所当然的忙而已！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哼哼，沒事沒事！我只是作為前輩幫了理所當然的忙而已！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00077",
		linknext = "0061_00079",
		line = 1083,
	},
	["0061_00079"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1095", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Por cierto... ¿de verdad te salió una cigarra del pecho la semana pasada?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“蝉在胸前羽化是真的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「蟬在胸前羽化是真的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00078",
		linknext = "0061_00080",
		line = 1096,
	},
	["0061_00080"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[11500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00116", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=11500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1175", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? Ah... eso fue medio inventado. En realidad, simplemente aterrizó allí... y empezó a piar... uugh... ¡Casi lloro!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……啊……那个一半是假的……其实是蝉停在我胸前开始叫……呜呜……我都想哭了啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……啊……那個一半是假的……其實是蟬停在我胸前開始叫……嗚嗚……我都想哭了啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00079",
		linknext = "0061_00081",
		line = 1112,
	},
	["0061_00081"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=1, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan baja la cabeza con desánimo y Nanase le da unas palmaditas en la cabeza para animarla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑抚摸着渡酱悲伤地低着的脑袋。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨撫摸著渡醬悲傷地低著的腦袋。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00080",
		linknext = "0061_00082",
		line = 1125,
	},
	["0061_00082"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1870", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Ese es el documento que estábamos buscando? Los revisé, pero no tuve tiempo para leerlos bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那……准备好了吗？扫描到的资料，我只是简单地看了一下重点……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那……準備好了嗎？掃描到的資料，我只是簡單地看了一下重點……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00081",
		linknext = "0061_00083",
		line = 1139,
	},
	["0061_00083"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1871", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hablaba de personas en la Isla Seiran que están involucradas con la yakuza del continente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“青蓝岛内……本岛的风俗行业人士——也就是黑社会的人。那些人好像混进来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「青藍島內……本島的風俗行業人士——也就是黑社會的人。那些人好像混進來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00082",
		linknext = "0061_00084",
		line = 1151,
	},
	["0061_00084"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿La yakuza?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说是黑社会——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說是黑社會——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00083",
		linknext = "0061_00085",
		line = 1165,
	},
	["0061_00085"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=1, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1872", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Parece que se han dedicado al tráfico sexual y otros comercios sexuales ilegales en la isla, creando así una especie de mercado negro. Eso ha influido en el tipo de turistas que visitan la isla, lo que está relacionado con el problema de orden público.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……他们在青蓝岛发展地下风俗，干一些不三不四的事情……结果对游客也带来了影响，导致了治安问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……他們在青藍島發展地下風俗，幹一些不三不四的事情……結果對遊客也帶來了影響，導致了治安問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00084",
		linknext = "0061_00086",
		line = 1180,
	},
	["0061_00086"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya me imaginaba que estaba relacionado con el crimen organizado, pero no me esperaba esto para nada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然我本来就想说和某些组织有关……但没想到是那些人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然我本來就想說和某些組織有關……但沒想到是那些人——」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00085",
		linknext = "0061_00087",
		line = 1192,
	},
	["0061_00087"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=50},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0391", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Esto... El mercado negro que mencionaste... ¿Eso sería aprovechar la ley súperpervertida para obtener dinero?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……所谓的风俗……就是本岛上适用‘变态条例’的场所……这样的认知对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……所謂的風俗……就是本島上適用『變態條例』的場所……這樣的認知對嗎？」",
					{"rt2"},
				},
			},
