	["0061_00457"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como Hitoura creó la ley súperpervertida, tiene sentido que se convirtiera en un objetivo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"变态条例的奠基人县知事——反对条例的人会针对他，并不是什么不自然的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"變態條例的奠基人縣知事——反對條例的人會針對他，並不是什麼不自然的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00456",
		linknext = "0061_00458",
		line = 5929,
	},
	["0061_00458"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Probablemente crean que tenerlo como rehén les daría influencia para cambiar la ley.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实如果是他的话，说不定有改变这个条例的力量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實如果是他的話，說不定有改變這個條例的力量。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00457",
		linknext = "0061_00459",
		line = 5939,
	},
	["0061_00459"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
