				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Parece que sí. Aunque es raro... ¿Por qué no puedo contactar a la OSS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“至少他们是这么想的。不过情况很奇怪……为什么会联系不上SHO？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「至少他們是這麼想的。不過情況很奇怪……為什麼會聯繫不上SHO？」",
					{"rt2"},
				},
			},
