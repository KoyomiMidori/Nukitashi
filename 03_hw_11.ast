		{"se", id=0, loop=0, file="se_b060"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
					{"exfont"},
				},
			},
			en = {
				{
					{"exfont", size="f4"},
					name = {"淳之介", "Junnosuke"},
					"“¡¡Rei-senpai!!”",
					{"rt2"},
					{"exfont"},
				},
			},
			cn = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"“礼前辈！！”",
					{"rt2"},
					{"exfont"},
				},
			},
			tw = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"「禮前輩！！」",
					{"rt2"},
					{"exfont"},
				},
			},
		},
		linkback = "0061_00540",
		linknext = "0061_00542",
		line = 7220,
	},
	["0061_00542"] = {
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"bg", id=2, file="bg01_3l_00000", x=350, y=-250, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La última en quedar en pie le dispara en la pierna. Rei-senpai se derrumba.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她被最后剩下的一个人射中了脚，倒在了地上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她被最後剩下的一個人射中了腳，倒在了地上。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00541",
		linknext = "0061_00543",
		line = 7233,
	},
	["0061_00543"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00109", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="kouki_01m_00001", file1="kouki_01m_00117", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="kouki0121", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Jaa... jaa... ¿De verdad le di? Je, jeje... La pequeña reina pensó que podía desobedecer a la OSS. ¡Qué adorable!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“哈啊哈啊……打、打中了……？呵呵……山大王想忤逆SHO，真是可笑啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「哈啊哈啊……打、打中了……？呵呵……山大王想忤逆SHO，真是可笑啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00542",
		linknext = "0061_00544",
		line = 7250,
	},
	["0061_00544"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es ni más ni menos que Senba Kouki, la portavoz de la OSS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是仙波光姬——SHO的宣传人员。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是仙波光姬——SHO的宣傳人員。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00543",
		linknext = "0061_00545",
		line = 7260,
	},
	["0061_00545"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Incluso ella los traicionó...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"连那个人也倒向敌人那边去了吗……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"連那個人也倒向敵人那邊去了嗎……？",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00544",
		linknext = "0061_00546",
		line = 7270,
	},
	["0061_00546"] = {
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_b047"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Intenta calmar su respiración mientras nos ata las manos y los pies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边调整着杂乱的呼吸，一边把我们的手脚捆绑起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊調整著雜亂的呼吸，一邊把我們的手腳捆綁起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00545",
		linknext = "0061_00547",
		line = 7282,
	},
	["0061_00547"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00121", file2="rei_01f_00202", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0583", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Senba-san... urgh... ¡¿Qué significa esto?! ¡¿Tiene algo en contra del senador Hitoura?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“仙波、小姐……唔……你们打算干什么！？居然与仁浦大人作对……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「仙波、小姐……唔……你們打算幹什麼！？居然與仁浦大人作對……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00546",
		linknext = "0061_00548",
		line = 7295,
	},
	["0061_00548"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0122", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“¿El senador Hitoura? Jeje... ¡qué graciosa! ¿Crees que me importa él?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“仁浦大人？呵呵……真有趣。那样的男人，已经怎样都无所谓了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「仁浦大人？呵呵……真有趣。那樣的男人，已經怎樣都無所謂了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00547",
		linknext = "0061_00549",
		line = 7307,
	},
	["0061_00549"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00548",
		linknext = "0061_00550",
		line = 7319,
	},
	["0061_00550"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuesta pensar que haya gente en la isla que no lo adore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上的人几乎无一不崇拜仁浦县知事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上的人幾乎無一不崇拜仁浦縣知事。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00549",
		linknext = "0061_00551",
		line = 7329,
	},
	["0061_00551"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hubiera pensado que los miembros de la SS y la OSS serían bastante devotos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS和SHO的话更是忠诚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS和SHO的話更是忠誠。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00550",
		linknext = "0061_00552",
		line = 7339,
	},
	["0061_00552"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No parece que lo estén haciendo para rebelarse contra la ley, pero ¿qué están haciendo?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她的言行——看起来不像内心隐藏着对条例的反抗心，那到底为什么……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她的言行——看起來不像內心隱藏著對條例的反抗心，那到底為什麼……？",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00551",
		linknext = "0061_00553",
		line = 7349,
	},
	["0061_00553"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0123", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Sé que retener a Tadasugawa-san atraerá al resto de l SS, pero ¿qué hago con el chico?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“也许等等还会有FS来，糺川同学看起来还有利用价值……但这边的孩子该怎么处置呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「也許等等還會有FS來，糺川同學看起來還有利用價值……但這邊的孩子該怎麼處置呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00552",
		linknext = "0061_00554",
		line = 7361,
	},
	["0061_00554"] = {
		{"fg", file="kouki_01l_00002", file1="kouki_01l_00107", file2="kouki_01l_00201", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0124", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Ooh... ¿Qué te parece? Mirarte me pone tan cachonda que mi coño se moja mucho... Hice algo muy valiente... Creo que me he ganado una pequeña recompensa, ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“嗯哼……不知道为什么，一看到你，我的小穴就湿得一塌糊涂……既然我立了大功……那就把你的鸡巴当成奖励吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「嗯哼……不知道為什麼，一看到你，我的小穴就濕得一塌糊塗……既然我立了大功……那就把你的肉棒當成獎勵吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00553",
		linknext = "0061_00555",
		line = 7375,
	},
	["0061_00555"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Ah!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“—————！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「—————！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00554",
		linknext = "0061_00556",
		line = 7387,
	},
	["0061_00556"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00103", file2="rei_01f_00202", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0584", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Espera! Es impote...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂等等！他是阳痿——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂等等！他是陽痿——」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00555",
		linknext = "0061_00557",
		line = 7400,
	},
	["0061_00557"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0125", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Vaya, ¿qué te tiene tan nerviosa? ¿Tu coño también lo quiere? Lo siento mucho, pero la vencedora se lo lleva.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“哎呀哎呀，怎么突然那么慌张……糺川同学的小穴是不是也想做了？不行哦，我的小穴已经先被爱液弄湿了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
