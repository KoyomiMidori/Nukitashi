		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esquiva fácilmente el disparo, acorta la distancia entre ellas y le da un rodillazo en el abdomen. Con combate cuerpo a cuerpo, somete a la guardia en un abrir y cerrar de ojos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈轻松躲过，然后狠狠地对准她的腹部一个回旋踢——用SQC瞬间制服了警卫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩輕鬆躲過，然後狠狠地對準她的腹部一個迴旋踢——用SQC瞬間制服了警衛。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00478",
