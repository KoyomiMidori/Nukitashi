		{"fg", file="rei_01l_00006", file1="rei_01l_00101", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4200] = {
				{"fg", file="rei_01l_00006", file1="rei_01l_00120", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, delay2=4200, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0589", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí, dejaré la investigación de esta rebelión en tus manos... ¿Mmm? Ah, ¿por fin despiertas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，有关造反的调查就拜托你们了……嗯——？怎么，醒了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，有關造反的調查就拜託你們了……嗯——？怎麼，醒了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00616",
		linknext = "0061_00618",
		line = 8308,
	},
	["0061_00618"] = {
