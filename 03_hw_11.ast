	["0061_00002"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00115", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1092", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Cuatro en la habitación de enfrente. No hay cámaras ahí, así que no puedo darte más información. Dicho esto, es la sala de juegos de la SS, así que deben estar en un cuarteto. Fuaah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“隔壁房间有4个反应……因为没有摄像头所以具体情况不明……不过，因为是FS的做爱房间……应该可以确定是在4P吧……呼啊啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「隔壁房間有4個反應……因為沒有攝影機所以具體情況不明……不過，因為是FS的做愛房間……應該可以確定是在4P吧……呼啊啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00001",
		linknext = "0061_00003",
		line = 32,
	},
