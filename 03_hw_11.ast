	["0061_00146"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Vas a sacarlos? ¿Cómo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……逼出来？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……逼出來？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00145",
		linknext = "0061_00147",
		line = 1934,
	},
	["0061_00147"] = {
		{"bgm", file="bgm09", vol=100},
		{"text"},
		delay = {
			[5200] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=5200, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0542", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pues... Ah, claro, no se le ha informado a los cadetes. Hemos desactivado el aire acondicionado de la escuela y hemos introducido afrodisíacos en las fuentes de agua.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎么了……啊，这么说来还没跟训练生联系过——我们上午让学校里的空调系统全都停止运转，然后往给水器里掺了媚药。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼了……啊，這麼說來還沒跟訓練生聯繫過——我們上午讓學校裡的空調系統全都停止運轉，然後往給水器裡摻了媚藥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00146",
		linknext = "0061_00148",
		line = 1949,
	},
	["0061_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啥——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啥——」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00147",
		linknext = "0061_00149",
		line = 1961,
	},
	["0061_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Afrodisiacos... en las fuentes de agua?",
					{"rt2"},
				},
			},
			cn = {
				{
					"给水器里掺了媚药？",
					{"rt2"},
				},
			},
			tw = {
				{
					"給水器裡摻了媚藥？",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00148",
		linknext = "0061_00150",
		line = 1971,
	},
	["0061_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio? Pensé que esa idea fue descartada. ¿No te preocupaban los problemas legales?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请等一下，那个话题不是没有下文了吗……要是和制造商发生摩擦的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請等一下，那個話題不是沒有下文了嗎……要是和製造商發生摩擦的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00149",
		linknext = "0061_00151",
		line = 1982,
	},
	["0061_00151"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0543", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya lo solucionamos. Invitamos a algunos representantes del fabricante y obtuvimos el permiso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以跟他们谈了。今天早上，我们把那边的大人物请到这里得到了许可。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以跟他們談了。今天早上，我們把那邊的大人物請到這裡得到了許可。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00150",
		linknext = "0061_00152",
		line = 1994,
	},
	["0061_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso me recuerda a esta mañana, y a las voces acaloradas que venían de la habitación al lado de la oficina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天早上——这么说来，风纪委员室旁边传来了激烈的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天早上——這麼說來，風紀委員室旁邊傳來了激烈的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00151",
		linknext = "0061_00153",
		line = 2004,
	},
	["0061_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que así es como persuadieron a los representantes del fabricante para que les dejaran llevar a cabo su plan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"难道是为了实施作战才叫来了制造商的人，用身体笼络了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"難道是為了實施作戰才叫來了製造商的人，用身體籠絡了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00152",
		linknext = "0061_00154",
		line = 2014,
	},
	["0061_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así es esta isla, pero eso es lo que menos me preocupa ahora mismo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真是太符合青蓝岛的手段了——现在这些都无所谓了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真是太符合青藍島的手段了——現在這些都無所謂了。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00153",
		linknext = "0061_00155",
		line = 2024,
	},
