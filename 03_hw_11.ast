			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Bien. ¿Ves esos vehículos de ahí? Corre tan rápido como puedas. Solo te tomará unos segundos, tienes que ser lo suficientemente rápido como para que no te atrapen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“很好。那里有一排车对吧。往那里全力奔跑。只要几秒——你的短跑速度应该不会被抓到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「很好。那裡有一排車對吧。往那裡全力奔跑。只要幾秒——你的短跑速度應該不會被抓到。」",
					{"rt2"},
				},
			},
