	["0061_00530"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=1, loop=0, file="se_b021"},
		{"se", id=0, loop=0, file="se_b054"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=1, size=5, time=75, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0237", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマンD"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS D"},
					"“¡A ver, ya es suficiente! ¡Señorita comandante de batallón, suelte el arma y salga, o su amiguito recibirá una bala en la cara!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫D"},
					"“喂喂喂！藏在那里的大队长！如果不把武器扔掉出来的话，下次我就瞄准那孩子的脸了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛D"},
					"「喂喂喂！藏在那裡的大隊長！如果不把武器扔掉出來的話，下次我就瞄準那孩子的臉了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00529",
		linknext = "0061_00531",
		line = 7018,
	},
	["0061_00531"] = {
		{"se", id=1, loop=0, file="se_b021"},
		{"se", id=0, loop=0, file="se_b054"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=1, size=5, time=75, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡No lo hagas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不行，礼前辈——”",
