	},
	["0061_00419"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0549", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya te lo dije, pero a la hora del almuerzo echamos afrodisíacos en las fuentes de agua para atrapar al Frente Anticopulación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……今天白天，我们为了逼出反交尾势力在给水器里下了媚药对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……今天白天，我們為了逼出反交尾勢力在給水器裡下了媚藥對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00418",
		linknext = "0061_00420",
		line = 5416,
	},
	["0061_00420"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
