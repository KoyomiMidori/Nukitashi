	["0061_00388"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00204", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1185", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Tachibana-kun...? ¿Eh? ¿Esta es la base? Eh, uh... ¿qué pasó?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君……？咦？这里是，基地……？我……我怎么了吗……”",
