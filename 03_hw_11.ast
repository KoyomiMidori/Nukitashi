	["0061_00412"] = {
		{"bgm", file="bgm23", vol=100},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"cgact", file="cgact", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0545", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Mmm. Al principio parecías un caso perdido, pero últimamente te has convertido en algo refinado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……一开始我还觉得你一点用都没有，不过最近确实进步了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……一開始我還覺得你一點用都沒有，不過最近確實進步了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00411",
		linknext = "0061_00413",
		line = 5320,
	},
	["0061_00413"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0546", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Los otros cadetes están en Tierra Lasciva para el Desfile del Lubricante Anal. Como tu entrenamiento ha sido un poco diferente al de ellos, estás muy por delante en cuanto a habilidades de combate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“其他的训练生现在都在变态乐园参加色情润滑阅兵吗……虽然训练时间不同，但战斗能力方面橘比同期要出类拔萃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「其他的訓練生現在都在變態樂園參加色情潤滑閱兵嗎……雖然訓練時間不同，但戰鬥能力方面橘比同期要出類拔萃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00412",
		linknext = "0061_00414",
		line = 5336,
	},
	["0061_00414"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
