	["0061_00532"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0238", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマンD"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la OSS D"},
					"“¡Habrase visto, un martir! ¿Qué tipo de oficial superior manda a sus subordinados al peligro mientras se queda a salvo en su refugio? ¡Salga, o realmente le dispararé!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫D"},
					"“唉……真有精神啊！不过，让下属痛苦，自己则躲在安全区里，还真是个过分的上司呢！你看，真的会打中他哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛D"},
					"「唉……真有精神啊！不過，讓下屬痛苦，自己則躲在安全區裡，還真是個過分的上司呢！你看，真的會打中他哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00531",
		linknext = "0061_00533",
		line = 7045,
	},
	["0061_00533"] = {
