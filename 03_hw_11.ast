	["0061_00492"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=9, time=300, x=0, y=0, alphadel=1, style="reset"},
		{"se", id=0, loop=0, file="se_b022"},
		{"cgact", file="cgact", id=3, act="浮遊横", loop=6, size=10, time=50, ease="easeinout_sine", lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Innumerables balas antidisturbios rebotan en el contenedor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无数的防暴弹打在集装箱上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無數的防暴彈打在集裝箱上。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00491",
		linknext = "0061_00493",
		line = 6448,
	},
	["0061_00493"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como no es munición real, no tenemos que preocuparnos de que el contenedor se rompa, pero esta situación ya es peor de lo que pensábamos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不是实弹就不会击穿集装箱，但情况非常险峻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不是實彈就不會擊穿集裝箱，但情況非常險峻。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00492",
		linknext = "0061_00494",
		line = 6458,
	},
	["0061_00494"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No sé por qué, pero deberíamos considerar a la OSS como nuestros enemigos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算不知道理由，也能认为SHO的人已经成了敌人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算不知道理由，也能認為SHO的人已經成了敵人。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00493",
		linknext = "0061_00495",
		line = 6468,
	},
	["0061_00495"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si no nos movemos, nos rodearán y no podremos escapar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果在这种胶着状态下被包围，就无法打破僵局。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果在這種膠著狀態下被包圍，就無法打破僵局。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00494",
		linknext = "0061_00496",
		line = 6478,
	},
	["0061_00496"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00111", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0572", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Acabo de ver al senador Hitoura. Dos guardias lo tenían atado y se dirigían hacia un barco. Debemos suponer que ya han tomado el canal de salida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“刚才我看到仁浦大人了。他被两名警卫拘束着，正往乘船处走去。应该假定海门已经打开了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「剛才我看到仁浦大人了。他被兩名警衛拘束著，正往乘船處走去。應該假定海門已經打開了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00495",
		linknext = "0061_00497",
		line = 6491,
	},
	["0061_00497"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Se lo van a llevar a la isla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……也就是说——他们要把仁浦先生带出青蓝岛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……也就是說——他們要把仁浦先生帶出青藍島？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00496",
		linknext = "0061_00498",
		line = 6502,
	},
	["0061_00498"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00111", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0573", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí. Tenemos que contenerlos antes de que eso ocurra, pero primero tenemos que salir de aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊……在这之前阻止事态发生，就是我们的任务。为此，我们必须尽快摆脱这种胶着状态。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊……在這之前阻止事態發生，就是我們的任務。為此，我們必須盡快擺脫這種膠著狀態。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00497",
		linknext = "0061_00499",
		line = 6515,
	},
	["0061_00499"] = {
