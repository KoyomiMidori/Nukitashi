					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡¿Qué fue eso?! ¡Si me apuntas con un arma, no tendré piedad contigo! ¡Tachibana, ponte a cubierto y vigila los alrededores!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你这家伙，想干什么！？如果你把枪对准我，即使是SHO我也绝不会饶过你！橘，躲到集装箱的阴影里！监视周围的人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你這傢伙，想幹什麼！？如果你把槍對准我，即使是SHO我也絕不會饒過你！橘，躲到集裝箱的陰影裡！監視周圍的人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00479",
		linknext = "0061_00481",
		line = 6279,
	},
