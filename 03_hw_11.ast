			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Están inconscientes, pero sus heridas no son graves. Probablemente fueron atacados con balas antidisturbios.”",
