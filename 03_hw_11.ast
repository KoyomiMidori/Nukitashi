	["0061_00378"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pude infiltrarme en la SS y acceder a información crucial, pero siguen pasándole cosas malas a ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"都已经潜入FS了，却还让渡酱遭遇了这样的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"都已經潛入FS了，卻還讓渡醬遭遇了這樣的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00377",
		linknext = "0061_00379",
		line = 4819,
	},
	["0061_00379"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Cómo puedo cambiar la ley y el orden público si ni siquiera puedo proteger a una compañera cercana?",
					{"rt2"},
				},
			},
			cn = {
				{
					"连身边的人都保护不了，还谈什么条例和治安问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連身邊的人都保護不了，還談什麼條例和治安問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00378",
		linknext = "0061_00380",
		line = 4829,
	},
	["0061_00380"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00126", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1875", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, ya está vestida... ¿Qué fue lo que pasó?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“总之把衣服穿上了……发生什么了事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「總之把衣服穿上了……發生什麼了事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00379",
		linknext = "0061_00381",
		line = 4842,
	},
	["0061_00381"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Al parecer, la SS discutió su plan de contaminar las fuentes de agua con el fabricante y obtuvieron su permiso. También fueron ellos quienes apagaron el aire acondicionado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……FS跟制造商谈了一下，好像是往给水器里掺了媚药。空调停止也在作战计划的一环。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……FS跟製造商談了一下，好像是往給水器裡摻了媚藥。空調停止也在作戰計劃的一環。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00380",
		linknext = "0061_00382",
		line = 4854,
	},
	["0061_00382"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1876", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ah... Lo sabía. Me parecía un poco raro. ¿Entonces Wata-chan bebió eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“果然是这样啊……我就觉得情况有点不对劲。渡酱喝了那些水对吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「果然是這樣啊……我就覺得情況有點不對勁。渡醬喝了那些水對吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00381",
		linknext = "0061_00383",
		line = 4868,
	},
	["0061_00383"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00104", path=":fg/asane_02m/", id=4, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Les pregunté cómo estaban. Al parecer Asa-chan, que se tomó muy en serio mi consejo, estaba tan paranoica como un drogadicto en una comisaría, y no tocaba las fuentes de agua ni con un palo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"询问之后，原来麻沙酱是听了我的报告后出于野兽本能，一直警戒着给水器所以没喝水。",
					{"rt2"},
				},
			},
			tw = {
				{
					"詢問之後，原來麻沙醬是聽了我的報告後出於野獸本能，一直警戒著給水器所以沒喝水。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00382",
		linknext = "0061_00384",
		line = 4880,
	},
	["0061_00384"] = {
		{"fg", mode=-1, id=4, ch="麻沙音", lv=5, time=100},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase, tan organizada como una dama con su propia serie, solo bebía el té que se traía de casa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑原本就是个像老奶奶一样的女人，加上听了我的话之后，就只喝自己带来的水壶里的茶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨原本就是個像老奶奶一樣的女人，加上聽了我的話之後，就只喝自己帶來的水壺裡的茶。",
					{"rt2"},
				},
