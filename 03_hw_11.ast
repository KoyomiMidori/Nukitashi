	["0061_00464"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por lo que sé sobre el problema de orden público, es posible que los secuestradores estén relacionados con el comercio sexual ilegal—y puede que sean parte de la yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"治安问题也一起考虑进去的话，诱拐犯也可能与地下风俗的关系者——黑社会有关联。",
