		line = 7745,
	},
	["0061_00583"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si tengo que sufrir algo así para enmendar mi error, no me molesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果只是让我承担一些不好的回忆，就能让事态好转的话——这根本算不上什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果只是讓我承擔一些不好的回憶，就能讓事態好轉的話——這根本算不上什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00582",
		linknext = "0061_00584",
		line = 7755,
	},
	["0061_00584"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
