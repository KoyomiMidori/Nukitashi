					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没问题！刚刚那个人已经无力化了——可是，情况不妙啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒問題！剛剛那個人已經無力化了——可是，情況不妙啊……」",
					{"rt2"},
