	["0061_00055"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00115", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0535", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Uh... ¡ejem! ¡Alto ahí! Yyyy... siete minutos y 21 segundos. ¡Ese es el tiempo que tardaron todos en empezar a tener sexo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊——咳咳！好，停止……诶……大家到开始做爱为止，花了7分21秒的时间！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊——咳咳！好，停止……欸……大家到開始做愛為止，花了7分21秒的時間！」",
					{"rt2"},
				},
			},
		},
