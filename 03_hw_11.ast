			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Es cierto. Aunque con esa gran orgía, podemos suponer que también participaron.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊……不过，那样的乱交骚动，也可以认为他们也吃了媚药进行了性行为吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊……不過，那樣的亂交騷動，也可以認為他們也吃了媚藥進行了性行為吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00420",
		linknext = "0061_00422",
		line = 5442,
	},
	["0061_00422"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0551", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Es imposible confirmarlo, pero hay muchas posibilidades de que el Frente Anticopulación haya podido probar el sexo, lo que sería suficiente para hacerles cambiar de opinión. El simple hecho de crear un ambiente así fue suficiente para lograr nuestro objetivo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然实际上我们无从确认……但反交尾势力也在做爱的过程中，体会到了这种快感。这样一来，非性产者就消失了——只要有这样的剧本就足够了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然實際上我們無從確認……但反交尾勢力也在做愛的過程中，體會到了這種快感。這樣一來，非性產者就消失了——只要有這樣的劇本就足夠了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00421",
		linknext = "0061_00423",
		line = 5456,
	},
	["0061_00423"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿A qué te refieres?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思……请问是什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思……請問是什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00422",
		linknext = "0061_00424",
		line = 5468,
	},
	["0061_00424"] = {
		{"bgm", stop=1},
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0552", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sé que tú también lo sabes. Hemos tenido constancia de una organización externa que amenaza el orden público y la seguridad en la Isla Seiran.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……你应该也察觉到了吧——这个岛上存在着威胁治安的外部组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……你應該也察覺到了吧——這個島上存在著威脅治安的外部組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00423",
		linknext = "0061_00425",
		line = 5483,
	},
	["0061_00425"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Trago saliva.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我咽了一口唾沫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我咽了一口唾沫。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00424",
		linknext = "0061_00426",
		line = 5493,
	},
	["0061_00426"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0553", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya te lo dije antes, pero tiene a la OSS muy ocupada, y la SS también ha tomado algunas medidas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就像之前说的那样，SHO已经在应对了——但我们FS也在拟定对策。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就像之前說的那樣，SHO已經在應對了——但我們FS也在擬定對策。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00425",
		linknext = "0061_00427",
		line = 5506,
	},
	["0061_00427"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0554", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hasta ahora, nuestra prioridad principal ha sido someter al Frente Anticopulación. Sin embargo, si podemos dar por disuelto este grupo, es probable que nuestros recursos se redirijan también hacia el problema del orden público.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然到目前为止都一直以镇压反交尾势力为优先……但如果能报告说他们被打败了，我们也能在治安问题上投入比现在更多的资源。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然到目前為止都一直以鎮壓反交尾勢力為優先……但如果能報告說他們被打敗了，我們也能在治安問題上投入比現在更多的資源。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00426",
		linknext = "0061_00428",
		line = 5518,
	},
	["0061_00428"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi corazón late con fuerza mientras asimilo esa información en mi cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个唐突的话题让我心跳加速，我在脑海里咀嚼着那些内容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個唐突的話題讓我心跳加速，我在腦海裡咀嚼著那些內容。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00427",
		linknext = "0061_00429",
		line = 5528,
	},
	["0061_00429"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Entonces... ¿el incidente fue una artimaña para que los altos mandos permitieran a la SS hacerse cargo del problema del orden público?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说——白天发生的事，也是为了能让FS着手治安问题的准备？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說——白天發生的事，也是為了能讓FS著手治安問題的準備？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00428",
		linknext = "0061_00430",
		line = 5540,
	},
	["0061_00430"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0555", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí. Si hubiéramos logrado expulsar a los no-copuladores, habría sido estupendo, pero esa no era la prioridad principal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“当然，我是真心想逼出他们的……但确实是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「當然，我是真心想逼出他們的……但確實是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00429",
		linknext = "0061_00431",
		line = 5554,
	},
	["0061_00431"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Realmente puedes contarme esto...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这件事……是可以对我说的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這件事……是可以對我說的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00430",
		linknext = "0061_00432",
		line = 5566,
	},
	["0061_00432"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0556", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No, pero... Parecías estar bastante alterado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不行。但是……我觉得你好像特别在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不行。但是……我覺得你好像特別在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00431",
		linknext = "0061_00433",
		line = 5578,
	},
	["0061_00433"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gracias... Rei-senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝前輩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00432",
		linknext = "0061_00434",
		line = 5590,
	},
	["0061_00434"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00124", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0557", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No lo hago por amabilidad. No quiero que te vayas corriendo a intentar hacer algo por tu cuenta, ya que sería mi responsabilidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你可别把我想得太好心……如果不先跟你说，我担心总有一天你会一个人往前冲。到时要负责任的可是我哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你可別把我想得太好心……如果不先跟你說，我擔心總有一天你會一個人往前衝。到時要負責任的可是我哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00433",
		linknext = "0061_00435",
		line = 5604,
	},
	["0061_00435"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, lo tendré en cuenta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的——我会铭记在心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的——我會銘記在心的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00434",
		linknext = "0061_00436",
		line = 5616,
	},
	["0061_00436"] = {
		{"bgm", stop=1},
		{"fg", file="rei_01m_00001", file1="rei_01m_00116", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0558", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Me alegra saberlo. Bueno, ya se está haciendo tarde. Tu hermana debe estar esperándote. Vete a casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那就好。好了……今天也晚了，你妹妹还在等你吧？快点回去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那就好。好了……今天也晚了，你妹妹還在等你吧？快點回去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00435",
		linknext = "0061_00437",
		line = 5633,
	},
	["0061_00437"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, muchas gracias por todo lo que hiciste hoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，今天也谢谢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，今天也謝謝了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00436",
		linknext = "0061_00438",
		line = 5645,
	},
	["0061_00438"] = {
		{"se", id=0, loop=0, file="se_a021"},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hago una reverencia y me doy la vuelta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我低下头，转过身去——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我低下頭，轉過身去——",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00437",
		linknext = "0061_00439",
		line = 5658,
	},
	["0061_00439"] = {
