		line = 7713,
	},
	["0061_00580"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Creo que fue una muestra de respeto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一定是她对我的顾虑吧。",
					{"rt2"},
				},
