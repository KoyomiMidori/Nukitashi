				{"vo", file="misaki0397", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡¿P-Por qué te ríes?! ¡¿Es... otro efecto secundario del afrodisíaco?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“为、为什么在笑？啊！难道这是药的副作用！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「為、為什麼在笑？啊！難道這是藥的副作用！？」",
					{"rt2"},
				},
			},
