	["0061_00059"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00115", file2="rei_01f_00204", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0536", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Uhh... Me alegra saberlo. Ahora sí tengo que irme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呜……你能满足就好了……那我真的要走了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗚……你能滿足就好了……那我真的要走了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00058",
		linknext = "0061_00060",
		line = 737,
	},
	["0061_00060"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00118", file2="hinami_01f_00202", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1170", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, n-no! ¡Espera!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊、不、不行！还不行！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊、不、不行！還不行！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00059",
		linknext = "0061_00061",
		line = 750,
	},
	["0061_00061"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00112", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0537", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Eh? ¿Necesitas algo más?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……还不行？有什么事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……還不行？有什麼事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00060",
		linknext = "0061_00062",
		line = 763,
	},
	["0061_00062"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00102", file2="hinami_01f_00202", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1171", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí, eh... ¡l-la semana pasada me pasó algo increíble! ¡Una cigarra salió de mi pecho! ¡Supongo que soy tan delgada que me confundieron con un árbol!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……对了，这么说来，上周有蝉在我胸前羽化了！是因为太平了所以被认为是木头吗——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……對了，這麼說來，上周有蟬在我胸前羽化了！是因為太平了所以被認為是木頭嗎——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00061",
		linknext = "0061_00063",
		line = 776,
	},
	["0061_00063"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00124", file2="rei_01f_00202", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0538", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Hinami? ¿Pasa algo? Suenas... desesperada. ¿Te pasó algo? ¿Quieres hablar con alguien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎、怎么了雏见，突然变得这么自暴自弃……是不是遇到了什么讨厌的事情……？要跟我说说吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎、怎麼了雛見，突然變得這麼自暴自棄……是不是遇到了什麼討厭的事情……？要跟我說說嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00062",
		linknext = "0061_00064",
		line = 789,
	},
