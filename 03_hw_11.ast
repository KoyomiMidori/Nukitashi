			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Lo siento, Tachibana... Volví a... hacer eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对不起，橘……又……让你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對不起，橘……又……讓你……」",
