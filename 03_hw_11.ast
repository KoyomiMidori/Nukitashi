			},
		},
		text = {
			vo = {
				{"vo", file="rei0561", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Estaba de regreso a la isla cuando lo detuvieron. ¡Maldita sea, ¿qué está haciendo la OSS?! ¡La SS están ocupadas en Tierra Lasciva! Aunque sea solo yo, tengo que ir...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊，好像归岛之后马上被袭击了。该死，SHO在干什么……FS全部都在变态乐园啊……！总之，就算只有我一个人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊，好像歸島之後馬上被襲擊了。該死，SHO在幹什麼……FS全部都在變態樂園啊……！總之，就算只有我一個人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00443",
		linknext = "0061_00445",
		line = 5740,
	},
	["0061_00445"] = {
