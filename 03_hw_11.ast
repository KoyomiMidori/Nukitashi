		linknext = "0061_00373",
		line = 4746,
	},
	["0061_00373"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00113", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1874", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡¿Jun?! Por qué Wata-chan— ¡¿Qué demonios pasó?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“等、淳！？你这、渡酱……发生什么事……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「等、淳！？你這、渡醬……發生什麼事……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00372",
		linknext = "0061_00374",
		line = 4759,
	},
	["0061_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cálmense. Estaba en peligro, pero logré salvarla. Ahora, ¿podrían darse prisa y volver a vestirla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不用担心—虽然非常危险，不过我把她救下来了……比起这个，你还是先帮她穿衣服吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不用擔心—雖然非常危險，不過我把她救下來了……比起這個，你還是先幫她穿衣服吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00373",
		linknext = "0061_00375",
		line = 4770,
	},
	["0061_00375"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Antes de darme la vuelta, le entrego la ropa de Wata-chan, completamente desnuda, a Nanase.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把裸体的渡酱和带来的衣服交给奈奈濑她们，然后转过身去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我把裸體的渡醬和帶來的衣服交給奈奈瀨她們，然後轉過身去。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00374",
		linknext = "0061_00376",
		line = 4787,
	},
	["0061_00376"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Mierda!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
