		linkback = "0061_00392",
		linknext = "0061_00394",
		line = 5025,
	},
	["0061_00394"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", file2="hinami_01m_00204", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1188", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡N-No, no, claro que no! Es que, uhh... Estaba tan feliz de que me hubiera salvado... que me dio risa... aja, ajaja...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不、不是那样的啊！呃……我、我只是觉得能得救真是太好了，就忍不住笑了……啊哈、啊哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不、不是那樣的啊！呃……我、我只是覺得能得救真是太好了，就忍不住笑了……啊哈、啊哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00393",
		linknext = "0061_00395",
		line = 5039,
	},
	["0061_00395"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pues se nota que sí se acuerda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从她的样子来看，她好像还清楚记得和我做了什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從她的樣子來看，她好像還清楚記得和我做了什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00394",
		linknext = "0061_00396",
		line = 5049,
	},
	["0061_00396"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo siento... Debí haberte dicho que tuviéramos más cuidado cuando se nos ocurrió esa idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起……如果我再注意点的话，就不会让你喝到那种东西了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起……如果我再注意點的話，就不會讓你喝到那種東西了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00395",
		linknext = "0061_00397",
		line = 5061,
	},
	["0061_00397"] = {
		{"text"},
		text = {
