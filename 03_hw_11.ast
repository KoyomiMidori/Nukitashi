	},
	["0061_00622"] = {
		{"bgm", file="bgm23", vol=100},
		{"fg", file="rei_01l_00006", file1="rei_01l_00102", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0590", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No te preocupes, estamos en un bote de la SS. Estamos a salvo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没事，我们在FS的船上，你什么都不用担心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒事，我們在FS的船上，你什麼都不用擔心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00621",
		linknext = "0061_00623",
		line = 8365,
	},
	["0061_00623"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué... pasó...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃……我……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃……我……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00622",
		linknext = "0061_00624",
		line = 8377,
	},
	["0061_00624"] = {
		{"fg", file="rei_01l_00006", file1="rei_01l_00107", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="rei_01l_00006", file1="rei_01l_00124", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0591", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Derrotaste a la guardia de la OSS y el senador Hitoura está a salvo. Pero parece que tú y la guardia se dieron disparos simultáneos en la cabeza con balas antidisturbios.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你打倒了SHO的警卫，救了仁浦大人。不过是同归于尽——你们互相被对方的防暴弹打中了头。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你打倒了SHO的警衛，救了仁浦大人。不過是同歸於盡——你們互相被對方的防暴彈打中了頭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00623",
		linknext = "0061_00625",
		line = 8393,
	},
	["0061_00625"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nos disparamos al mismo tiempo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“同归于尽……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「同歸於盡……」",
					{"rt2"},
				},
			},
