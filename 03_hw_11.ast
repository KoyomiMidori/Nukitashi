			},
		},
		linkback = "0061_00452",
		linknext = "0061_00454",
		line = 5880,
	},
	["0061_00454"] = {
		{"bg", id=1, file="bg25_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0563", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“El Frente Anticopulación no es el único que se opone a la ley súperpervertida. Esa mujer a la que ayudaste a capturar es un ejemplo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就像反交尾势力一样，有很多家伙都不太喜欢变态条例。你以前抓的女人也是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就像反交尾勢力一樣，有很多傢伙都不太喜歡變態條例。你以前抓的女人也是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00453",
		linknext = "0061_00455",
		line = 5894,
	},
	["0061_00455"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Creen que secuestrar al senador Hitoura es la mejor manera de acabar con la ley?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，如果抓到了仁浦先生，就可以操弄条例……？这可能吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，如果抓到了仁浦先生，就可以操弄條例……？這可能嗎？」",
					{"rt2"},
				},
