					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Soy Tadasugawa Rei, comandante de batallón del escuadrón al mando de la SS. Recibí la noticia de que el senador Hitoura había sido secuestrado y vine para colaborar en su rescate.”",
					{"rt2"},
