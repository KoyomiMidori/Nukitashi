	["0061_00417"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0548", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Ah, sí? Bueno, da igual. ¿Tiene algo que ver con el problema del orden público y la seguridad de los niños en la isla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是吗……不回答也没关系……但那和岛上的治安问题——孩子被盯上的一连串事件有关吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是嗎……不回答也沒關係……但那和島上的治安問題——孩子被盯上的一連串事件有關嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00416",
		linknext = "0061_00418",
		line = 5390,
	},
	["0061_00418"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
