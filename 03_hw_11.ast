				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, esta experiencia terrible fue consecuencia de mi sugerencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但说到底——是我给FS提出了“让他们喝媚药”的方案。",
