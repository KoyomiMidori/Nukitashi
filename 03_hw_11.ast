		linkback = "0061_00066",
		linknext = "0061_00068",
		line = 906,
	},
	["0061_00068"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00112", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0539", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ah, Tachibana... Qué gusto verte por aquí, aunque... ¿a qué te refieres con estar 'bien'?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘……怎么，你和她在一起啊？没问题——是指什么事情？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘……怎麼，你和她在一起啊？沒問題——是指什麼事情？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00067",
		linknext = "0061_00069",
		line = 920,
	},
	["0061_00069"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Dejé mi cuaderno en la oficina por error. Estaba buscándolo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我把笔记本忘在风纪委员室了……我来取的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我把筆記本忘在風紀委員室了……我來取的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00068",
		linknext = "0061_00070",
		line = 932,
	},
	["0061_00070"] = {
