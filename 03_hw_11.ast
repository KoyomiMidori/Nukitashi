					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這……」",
