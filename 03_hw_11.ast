	["0061_00406"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo bueno de todo esto es que pude proteger a Wata-chan de los buscadores de sexo que merodeaban por la escuela.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但能从性触者的魔爪中保护渡酱是不幸中的万幸——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但能從性觸者的魔爪中保護渡醬是不幸中的萬幸——",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00405",
