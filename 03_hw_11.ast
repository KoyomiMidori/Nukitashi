		line = 532,
	},
	["0061_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La última vez que vi a alguien con tan poca habilidad para engañar a la gente fue hace poco.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第一次看到这么不会搪塞的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第一次看到這麼不會搪塞的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00042",
		linknext = "0061_00044",
		line = 542,
	},
	["0061_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y yo que pensaba que sería ideal para distraer a Rei-senpai... Tendré que estar listo para escapar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本以为对付礼前辈的话渡酱最好，但现在应该做好早点撤退的准备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本以為對付禮前輩的話渡醬最好，但現在應該做好早點撤退的準備。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00043",
		linknext = "0061_00045",
		line = 552,
	},
	["0061_00045"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Acelero el proceso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我提高翻书的手速。",
					{"rt2"},
