	["0061_00048"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00112", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0532", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué pasa? ¿Necesitas algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎么了？有什么事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼了？有什麼事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00047",
		linknext = "0061_00049",
		line = 601,
	},
	["0061_00049"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00102", file2="hinami_01f_00202", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1167", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí, umm... ¡Ah! ¡Tengo muchas ganas de volver a ver tu imitación del director de la escuela!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，呃……啊——啊！好久没看到礼酱模仿校长了，想看！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，呃……啊——啊！好久沒看到禮醬模仿校長了，想看！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00048",
		linknext = "0061_00050",
		line = 614,
	},
	["0061_00050"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00119", file2="rei_01f_00202", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0533", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué? No... No creo que eso sea... algo que deba hacer en la escuela con la posición que tengo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什、什么……？不，但是在学校中做那种事……而且还是风纪委员长做那样的模仿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什、什麼……？不，但是在學校中做那種事……而且還是風紀委員長做那樣的模仿……」",
					{"rt2"},
				},
			},
		},
