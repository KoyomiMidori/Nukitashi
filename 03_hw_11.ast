					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Más o menos, pero no tanto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大致是对的，但并不正确。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大致是對的，但並不正確。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00087",
		linknext = "0061_00089",
		line = 1219,
	},
	["0061_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En pocas palabras, es una especie de mercado clandestino para el sexo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“简单来说——就是将性行为当成商品的店。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「簡單來說——就是將性行為當成商品的店。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00088",
		linknext = "0061_00090",
		line = 1231,
	},
	["0061_00090"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=6000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1176", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ooh, he oído que eso pasa en el continente! ¡Si no puedes tener sexo normalmente, puedes pagar para que lo haga contigo! Pero... ¿por qué se molestarían con algo así aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我曾经听说过在本岛上如果正常生活的话就不能做爱，所以有个可以买到做爱的地方！但是……那在青蓝岛上做有意义吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我曾經聽說過在本島上如果正常生活的話就不能做愛，所以有個可以買到做愛的地方！但是……那在青藍島上做有意義嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00089",
		linknext = "0061_00091",
		line = 1247,
	},
	["0061_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora ya no se nota, pero antes había algo así aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有——或者说有过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有——或者說有過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00090",
		linknext = "0061_00092",
		line = 1258,
	},
	["0061_00092"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En el pasado, incluso cuando yo vivía aquí, existía un comercio sexual ilegal que prosperaba bastante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“以前……我还在青蓝岛的时候，的确也有过所谓的地下风俗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「以前……我還在青藍島的時候，的確也有過所謂的地下風俗。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00091",
		linknext = "0061_00093",
		line = 1270,
	},
	["0061_00093"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tan solo mencionar el pasado amenaza con traer de vuelta recuerdos dolorosos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一瞬间，我差点想起以前的事——",
					{"rt2"},
				},
			},
			tw = {
				{
					"一瞬間，我差點想起以前的事——",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00092",
		linknext = "0061_00094",
		line = 1282,
	},
	["0061_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sacudo la cabeza para despejarme y sigo hablando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"摇摇头挥去了邪念。",
					{"rt2"},
				},
			},
			tw = {
				{
					"搖搖頭揮去了邪念。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00093",
		linknext = "0061_00095",
		line = 1292,
	},
	["0061_00095"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ha estado activo bajo las narices de la SS y la OSS, hay límites en lo que la ley súperpervertida permite.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——虽然通过参加FS有了切身的体会，但其实根据变态条例，能做的事情还是有所限制。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——雖然通過參加FS有了切身的體會，但其實根據變態條例，能做的事情還是有所限制。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00094",
		linknext = "0061_00096",
		line = 1304,
	},
	["0061_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por ejemplo, tomarían medidas drásticas contra la violencia sin consentimiento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“例如，如果没有取得双方同意就行暴力等级的性行为，FS和SHO将介入指导。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「例如，如果沒有取得雙方同意就行暴力等級的性行為，FS和SHO將介入指導。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00095",
		linknext = "0061_00097",
		line = 1315,
	},
	["0061_00097"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo, los límites aquí son mucho más flexibles que en cualquier otro lugar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是——青蓝岛是如此对性开放的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是——青藍島是如此對性開放的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00096",
		linknext = "0061_00098",
		line = 1327,
	},
	["0061_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si alguien se entrega a sus deseos sexuales día y noche, sus gustos se intensificarán con el tiempo y se volverán más extremos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果日夜沉迷于性行为，人的欲望就会越来越强烈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果日夜沉迷於性行為，人的慾望就會越來越強烈。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00097",
		linknext = "0061_00099",
		line = 1338,
	},
	["0061_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El comercio sexual ilegal atiende a esas personas. Si podían pagar el precio, podían satisfacer cualquier gusto, incluso fuera de los límites de la ley súperpervertida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“能给这些人排解欲望的地方，就是地下风俗——只要付钱，似乎就能做出任何他们想做的恶劣行为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「能給這些人排解慾望的地方，就是地下風俗——只要付錢，似乎就能做出任何他們想做的惡劣行為。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00098",
		linknext = "0061_00100",
		line = 1349,
	},
	["0061_00100"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1096", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Debería haberse eliminado hace mucho tiempo, pero tal y como está esta isla, es como jugar a pegarle al topo. Lo eliminas y vuelve a aparecer en otro lugar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但那应该在很久以前就被抓出来然后摧毁了……不过毕竟是这样的岛，就算又从其他地方来了，也不奇怪……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但那應該在很久以前就被抓出來然後摧毀了……不過畢竟是這樣的島，就算又從其他地方來了，也不奇怪……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00099",
		linknext = "0061_00101",
		line = 1362,
	},
	["0061_00101"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1177", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Esto... la razón por la que la gente está acosando a los niños es por... ¿el comercio sexual ilegal?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃……既然这样，现在会有孩子们受害……也是那个地下风俗的错吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃……既然這樣，現在會有孩子們受害……也是那個地下風俗的錯嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00100",
		linknext = "0061_00102",
		line = 1374,
	},
	["0061_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí... probablemente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……大概是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……大概是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00101",
		linknext = "0061_00103",
		line = 1386,
	},
	["0061_00103"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No quiero pensar en esto, pero es posible que el mercado negro sexual esté usando a niños y niñas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不想去想象——但从现在的情况来看，可能有少男少女被贩卖到了地下风俗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不想去想像——但從現在的情況來看，可能有少男少女被販賣到了地下風俗。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00102",
		linknext = "0061_00104",
		line = 1402,
	},
	["0061_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El hecho de que haya tardado tanto tiempo en salir a la luz significa que la yakuza estaba haciendo hasta lo imposible para mantenerlo en secreto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但如果是这样，问题应该会变得更大才对——为了不变成那样，黑社会也有所对策是吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但如果是這樣，問題應該會變得更大才對——為了不變成那樣，黑社會也有所對策是嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00103",
		linknext = "0061_00105",
		line = 1412,
	},
	["0061_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"O tal vez la OSS y sus subordinados lo mantenían en secreto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或者，SHO那边也进行了报道管制也说不定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者，SHO那邊也進行了報導管制也說不定。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00104",
		linknext = "0061_00106",
		line = 1422,
	},
	["0061_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Puedo imaginarlo, pero probablemente estoy sesgado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像我自己这样，觉得青蓝岛不好的人也不在少数。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像我自己這樣，覺得青藍島不好的人也不在少數。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00105",
		linknext = "0061_00107",
		line = 1432,
	},
	["0061_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es posible que la OSS sepa que, de hacerse pública la información, sería objeto de duras críticas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果岛上的问题浮出水面，就会给这些人很多的批评材料。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果島上的問題浮出水面，就會給這些人很多的批評材料。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00106",
		linknext = "0061_00108",
		line = 1442,
	},
	["0061_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así que lo han mantenido en secreto desde el principio y no lo han abordado abiertamente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此，他们才没有公开岛的问题，而是想像从一开始就没有发生过任何问题一样秘密地处理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此，他們才沒有公開島的問題，而是想像從一開始就沒有發生過任何問題一樣秘密地處理。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00107",
		linknext = "0061_00109",
		line = 1452,
	},
	["0061_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque sacarlo a la luz evitaría víctimas, dañaría la imagen de la isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果不隐瞒，把信息公开的话就能减少受害者，但为了维护岛的形象而不这么做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果不隱瞞，把資訊公開的話就能減少受害者，但為了維護島的形象而不這麼做。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00108",
		linknext = "0061_00110",
		line = 1462,
	},
	["0061_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde su punto de vista, hacerlo de esta manera ayuda a más personas. Las necesidades de la mayoría prevalecen sobre las necesidades de unos pocos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"杀小虫，养大虫——这个岛从以前就是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"殺小蟲，養大蟲——這個島從以前就是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00109",
		linknext = "0061_00111",
		line = 1472,
	},
	["0061_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es como una especie de control de daños.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总是毫不犹豫地放弃那些少数的牺牲者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總是毫不猶豫地放棄那些少數的犧牲者。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00110",
		linknext = "0061_00112",
		line = 1482,
	},
	["0061_00112"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1873", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Por cierto, recuerdo que mencionaste que iban a hacer algo con las fuentes de agua. ¿Al final sí hicieron algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话说回来，给水器的事情怎么样了？那之后还有没有说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話說回來，給水器的事情怎麼樣了？那之後還有沒有說什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00111",
		linknext = "0061_00113",
		line = 1495,
	},
	["0061_00113"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Dijeron que no lo harían, así que no debería haber ningún problema.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，没有特别说什么。那件事没有问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，沒有特別說什麼。那件事沒有問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00112",
		linknext = "0061_00114",
		line = 1507,
	},
	["0061_00114"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0392", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Fuentes de agua? ¿Cómo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“给水器……？是什么事情？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「給水器……？是什麼事情？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00113",
		linknext = "0061_00115",
		line = 1520,
	},
	["0061_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, es que no estuviste ahí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，昨天畔不在吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，昨天畔不在嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00114",
		linknext = "0061_00116",
		line = 1532,
	},
	["0061_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La SS estaba discutiendo la posibilidad de echar afrodisíacos en las fuentes de agua. La discusión no llegó a ninguna parte, así que no va a suceder.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS说过要往给水器里装媚药。但后来这个话题就消失了，所以没什么问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS說過要往給水器裡裝媚藥。但後來這個話題就消失了，所以沒什麼問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00115",
		linknext = "0061_00117",
		line = 1544,
	},
	["0061_00117"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[4700] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4700, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0393", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Eh? Espera, ¿sabían esto? ¿Por qué soy la única que no lo sabía?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"咦……请稍等一下。大家都知道了吗？为什么只有我不知道？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"咦……請稍等一下。大家都知道了嗎？為什麼只有我不知道？」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00116",
		linknext = "0061_00118",
		line = 1561,
	},
	["0061_00118"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No lo hicimos a propósito. Wata-chan y Nanase estaban en mi casa en ese momento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“并没有排挤你。只是奈奈濑和渡酱碰巧来我家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「並沒有排擠你。只是奈奈瀨和渡醬碰巧來我家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00117",
		linknext = "0061_00119",
		line = 1573,
	},
	["0061_00119"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00120", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1097", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Je. Te mantuviste alejada de toda la diversión, ¿verdad? Es es el distanciamiento social...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嘿……有句话说名字就是自身的代名词，伴没岬果然适合孤单吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嘿……有句話說名字就是自身的代名詞，伴沒岬果然適合孤單吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00118",
		linknext = "0061_00120",
		line = 1586,
	},
	["0061_00120"] = {
