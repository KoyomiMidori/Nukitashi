		},
		text = {
			vo = {
				{"vo", file="misaki0395", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Ay, qué alivio! ¡Por fin llegaste, TachibanaaaAAAAAUGH?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，太好了！橘同学也来了啊啊啊啊啊啊啊啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，太好了！橘同學也來了啊啊啊啊啊啊啊啊！？」",
