	["0061_00585"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me siento agotado, tanto por el cansancio posterior a la eyaculación como por el entrenamiento que estábamos haciendo antes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"射精后的倦怠感和训练的疲劳让我全身无力……",
