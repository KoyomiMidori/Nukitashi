	["0061_00525"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Recibo un balazo en el brazo que me derriba. Mis lentes se deslizan por el asfalto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"左臂被击中而跌倒——眼镜飞到柏油路上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"左臂被擊中而跌倒——眼鏡飛到柏油路上。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00524",
		linknext = "0061_00526",
		line = 6950,
	},
	["0061_00526"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=3, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"bg", id=2, file="bg01_3l_00000", x=200, y=-200, lv=5, path=":bg/", sync=0, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=95, y=-5, time=10000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Haciendo muecas de dolor, apenas puedo divisar a Rei-senpai vengándose despiadadamente de los guardias que la rodean.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我痛苦地歪着脸看了看，只见礼前辈若无其事地击退了所有接近他的警卫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我痛苦地歪著臉看了看，只見禮前輩若無其事地擊退了所有接近他的警衛。",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00525",
		linknext = "0061_00527",
		line = 6966,
	},
	["0061_00527"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me ordenó que no me diera la vuelta, pero terminé haciendo eso. Le fallé.",
					{"rt2"},
				},
			},
			cn = {
				{
					"失败了——她都叫我不要回头了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"失敗了——她都叫我不要回頭了。",
					{"rt2"},
				},
