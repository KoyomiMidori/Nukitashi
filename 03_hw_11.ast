		linkback = "0061_00044",
		linknext = "0061_00046",
		line = 563,
	},
	["0061_00046"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0531", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya veo... Qué bien que te levantaste temprano. Solo intenta no cansarte tanto como para necesitar una siesta por la tarde. Cuídate mucho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊……不过，早起是好事情。但是，要小心不要上课睡午觉。那么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣啊……不過，早起是好事情。但是，要小心不要上課睡午覺。那麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00045",
		linknext = "0061_00047",
		line = 575,
	},
	["0061_00047"] = {
