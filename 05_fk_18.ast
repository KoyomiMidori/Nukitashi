	["0118_00095"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's not non-virgins, but the islanders that I hate?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是非处女，而是讨厌岛上的人吗——”",
