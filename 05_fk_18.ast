	["0118_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm glad that I finally understand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"能理解这些——现在的我觉得太好了。",
					{"rt2"},
				},
