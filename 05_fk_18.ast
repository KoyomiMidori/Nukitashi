	["0118_00250"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="asane_01m_00003", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1717", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wha... Huh? The hell's Fumino doing in here? This is your room... Apart from being where I get to laze around, this is supposed to be a sacred area no one else is permitted to infiltrate...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶……哈啊？为什么文乃在这里？这里是我哥哥的房间……换句话说这里是麻沙酱的地盘是任何人都难以侵犯的神圣领域……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸……哈啊？為什麼文乃在這裡？這裡是我哥哥的房間……換句話說這裡是麻沙醬的地盤是任何人都難以侵犯的神聖領域……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00249",
		linknext = "0118_00251",
		line = 3235,
	},
	["0118_00251"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's a half-truth right there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“神圣也好但这不是你的地盘。”",
