			},
		},
		linkback = "0118_00217",
		linknext = "0118_00219",
		line = 2823,
	},
	["0118_00219"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sorry. I got carried away and touched you inappropriately, especially considering you're a girl and all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……对不起。我太得寸进尺了，居然这样摸女孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……對不起。我太得寸進尺了，居然這樣摸女孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00218",
		linknext = "0118_00220",
		line = 2835,
	},
	["0118_00220"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1010", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Not at all... Please feel free to touch me wherever you wish.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不……只要是您想摸的地方，都可以尽情抚摸……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不……只要是您想摸的地方，都可以盡情撫摸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00219",
		linknext = "0118_00221",
		line = 2850,
	},
	["0118_00221"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——诶？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——欸？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00220",
		linknext = "0118_00222",
		line = 2863,
	},
	["0118_00222"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00110", file2="fumino_01m_00201", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1011", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“What you said earlier... about the possibility of having the power to subjugate people with your phallus...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“刚才你说过的……通过阳具，让人民服从……那种力量的可能性……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「剛才你說過的……通過陽具，讓人民服從……那種力量的可能性……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00221",
		linknext = "0118_00223",
		line = 2877,
	},
	["0118_00223"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00121", file2="fumino_02m_00201", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1012", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If you felt so inclined... please feel free to try it on me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果、在意的话……请拿文乃来试试……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果、在意的話……請拿文乃來試試……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00222",
		linknext = "0118_00224",
		line = 2891,
	},
	["0118_00224"] = {
		{"bgm", file="bgm18", vol=100},
		{"se", id=1, loop=1, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After a short silence, I'm so touched that my chest hurts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"稍微的沉默之后，我的心振动到疼痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"稍微的沉默之後，我的心振動到疼痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00223",
		linknext = "0118_00225",
		line = 2903,
	},
	["0118_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'd be lying if I said I wasn't interested.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说不在意，那是骗人的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說不在意，那是騙人的。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00224",
		linknext = "0118_00226",
		line = 2913,
	},
	["0118_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I am curious to see whether that ability she talked about was just a fabrication or not.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的确有点想搞清楚自己有没有这样的力量，和那个学生会长所说的是不是谎言。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的確有點想搞清楚自己有沒有這樣的力量，和那個學生會長所說的是不是謊言。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00225",
		linknext = "0118_00227",
		line = 2923,
	},
	["0118_00227"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00204", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No... I'm aware of how devoted you are... but I don't think you need to go that far.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——虽然我知道你很有献身精神……不过你不用做到那个地步也可以吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——雖然我知道你很有獻身精神……不過你不用做到那個地步也可以吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00226",
		linknext = "0118_00228",
		line = 2935,
	},
	["0118_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I barely understand how I can say that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"连自己在说什么都有一半不能理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連自己在說什麼都有一半不能理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00227",
		linknext = "0118_00229",
		line = 2945,
	},
	["0118_00229"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00204", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So I think... you shouldn't say stuff like that to a member of the opposite sex... I mean, I have my own thoughts about it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，那个——那种话不能在异性面前说哦～……我是这么认为的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，那個——那種話不能在異性面前說哦～……我是這麼認為的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00228",
		linknext = "0118_00230",
		line = 2957,
	},
	["0118_00230"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00113", file2="fumino_02m_00201", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1013", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I-I am... interested as much as any normal person... Plus...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我、我也……果然……还是感兴趣的……所以……而且……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我、我也……果然……還是感興趣的……所以……而且……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00229",
		linknext = "0118_00231",
		line = 2972,
	},
	["0118_00231"] = {
		{"se", id=1, loop=1, file="se_a107"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My heart is beating so loudly in my ears that I almost can't hear her speaking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心脏的声音，让我听不清楚文乃的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心臟的聲音，讓我聽不清楚文乃的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00230",
		linknext = "0118_00232",
		line = 2983,
	},
	["0118_00232"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00112", file2="fumino_02m_00201", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1014", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have a desire... to be united with the person I've determined will be my master... if possible...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果能与自己认定的主人、结合的话……也是……我的愿望……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果能與自己認定的主人、結合的話……也是……我的願望……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00231",
		linknext = "0118_00233",
		line = 2998,
	},
	["0118_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have no idea why that took the form of a question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我完全不明白为什么会变成疑问句。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我完全不明白為什麼會變成疑問句。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00232",
		linknext = "0118_00234",
		line = 3008,
	},
	["0118_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，这也就是说——",
					{"rt2"},
				},
			},
			tw = {
