	},
	["0118_00169"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“One was a kind girl who was my classmate. The other...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一个是同学，温柔的少女。而另外一个——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一個是同學，溫柔的少女。而另外一個——」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00168",
		linknext = "0118_00170",
		line = 2273,
	},
	["0118_00170"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I never learned her name, but she was from this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——连名字都不知道，是这个岛上的女人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——連名字都不知道，是這個島上的女人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00169",
		linknext = "0118_00171",
		line = 2285,
	},
	["0118_00171"] = {
		{"fg", file="fumino_02m_00003", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1006", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00170",
		linknext = "0118_00172",
		line = 2300,
	},
	["0118_00172"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I brought her up earlier. She just happened to talk to me when I was all alone once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“之前好像也稍微说过这件事……当时，那个人跟孤单的我说话了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「之前好像也稍微說過這件事……當時，那個人跟孤單的我說話了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00171",
		linknext = "0118_00173",
		line = 2312,
	},
	["0118_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She acted like my mother, who was always busy with something and never at home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个女性对我来说，是代替一直很忙不在家的母亲一样的人物。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個女性對我來說，是代替一直很忙不在家的母親一樣的人物。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00172",
		linknext = "0118_00174",
		line = 2322,
	},
	["0118_00174"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She learned about my huge phallus, and accepted me. She said it was just a physical trait.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“知道我的巨根后，那个人肯定了我，说那是我的个性……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「知道我的巨根後，那個人肯定了我，說那是我的個性……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00173",
		linknext = "0118_00175",
		line = 2334,
	},
	["0118_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like that kind young girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"用和那个温柔的少女说过的同样的话，肯定了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"用和那個溫柔的少女說過的同樣的話，肯定了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00174",
		linknext = "0118_00176",
		line = 2344,
	},
	["0118_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If it were not for her, I would surely have hated myself even more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果没有那个人的话，我一定会更加讨厌自己吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果沒有那個人的話，我一定會更加討厭自己吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00175",
		linknext = "0118_00177",
		line = 2354,
	},
	["0118_00177"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But the islanders did nothing but shun her. And eventually, that killed her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，那个人……在岛民强烈的谴责下，死了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，那個人……在島民強烈的譴責下，死了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00176",
		linknext = "0118_00178",
		line = 2366,
	},
	["0118_00178"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She was destitute, and couldn't find a job for some reason or another.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她很穷，不知为什么也没有工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她很窮，不知為什麼也沒有工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00177",
		linknext = "0118_00179",
		line = 2378,
	},
	["0118_00179"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Her only recourse was to work in the illegal sex industry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以……她不得不去地下风俗工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以……她不得不去地下風俗工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00178",
		linknext = "0118_00180",
		line = 2390,
	},
	["0118_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was why she only talked to me somewhere nobody would come to— our secret little hideout.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，她和我只在没有任何人——只在曾经是我和那个孩子的秘密基地——的地方交流。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，她和我只在沒有任何人——只在曾經是我和那個孩子的秘密基地——的地方交流。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00179",
		linknext = "0118_00181",
		line = 2400,
	},
	["0118_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When we met in town, she pretended to not know me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果在街上碰到，她就假装不知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果在街上碰到，她就假裝不知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00180",
		linknext = "0118_00182",
		line = 2410,
	},
	["0118_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I did the same.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也是。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00181",
		linknext = "0118_00183",
		line = 2420,
	},
	["0118_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn't want to face the same judgment as her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为她不想让我也挨骂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為她不想讓我也挨罵。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00182",
		linknext = "0118_00184",
		line = 2430,
	},
	["0118_00184"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't really know why she couldn't get any work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也不知道她为什么没有工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也不知道她為什麼沒有工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00183",
		linknext = "0118_00185",
		line = 2442,
	},
	["0118_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Back then, the economy was booming. There should have been plenty of work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从当时开始青蓝岛就充满了活力，工作明明多得很。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從當時開始青藍島就充滿了活力，工作明明多得很。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00184",
		linknext = "0118_00186",
		line = 2453,
	},
	["0118_00186"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I only asked her about it once... and she just smiled at me sadly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我曾经问过一次——那时她只是悲伤地笑着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我曾經問過一次——那時她只是悲傷地笑著。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00185",
		linknext = "0118_00187",
		line = 2465,
	},
	["0118_00187"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No matter how much people around her ignored her, hated her, or disparaged her, she would say nothing... She was a strong woman.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使被周围无视，被讨厌，被不断谩骂，也什么都不说……是个坚强的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使被周圍無視，被討厭，被不斷謾罵，也什麼都不說……是個堅強的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00186",
		linknext = "0118_00188",
		line = 2477,
	},
	["0118_00188"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But those who abused her were merciless. She ended up having nowhere to live, just because she was making money from sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，那样的她也被周围的人痛骂，用无聊的论调说‘怎么可以用性来赚钱’，从而失去了立足之地……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，那樣的她也被周圍的人痛罵，用無聊的論調說『怎麼可以用性來賺錢』，從而失去了立足之地……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00187",
		linknext = "0118_00189",
		line = 2489,
	},
	["0118_00189"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In the end, she took ill and died.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……最后因病去世了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……最後因病去世了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00188",
		linknext = "0118_00190",
		line = 2501,
	},
	["0118_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The people who abused her were the island's so-called nouveau riche.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……骂她的那些人，就是所谓的“青蓝暴发户”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……罵她的那些人，就是所謂的「青藍暴發戶」。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00189",
		linknext = "0118_00191",
		line = 2511,
	},
	["0118_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The ones who lined their pockets by abusing their privilege.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为青蓝岛的特权而中饱私囊的人们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為青藍島的特權而中飽私囊的人們。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00190",
		linknext = "0118_00192",
		line = 2521,
	},
	["0118_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"According to them, working for the illegal sex industry threatened the island itself, and thus was worthy of their ire.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，在他们看来，光是有在做对岛本身有威胁性的地下风俗的",
					{"ruby", text="・・"},
					"嫌疑",
					{"/ruby"},
					"，就是要被挞伐的对象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，在他們看來，光是有在做對島本身有威脅性的地下風俗的",
					{"ruby", text="・・"},
					"嫌疑",
					{"/ruby"},
					"，就是要被撻伐的對象。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00191",
		linknext = "0118_00193",
		line = 2531,
	},
	["0118_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Clearly her existence would not be allowed legally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"法律上，她的存在的确是不被允许的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"法律上，她的存在的確是不被允許的。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00192",
		linknext = "0118_00194",
		line = 2541,
	},
	["0118_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While the masses of people who felt that way weren't violent, their influence was intense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然得到认可的群众的力量算不上暴力，但也非常猛烈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然得到認可的群眾的力量算不上暴力，但也非常猛烈。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00193",
		linknext = "0118_00195",
		line = 2551,
	},
	["0118_00195"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then I heard it for myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那时候，我确确实实地听到了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那時候，我確確實實地聽到了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00194",
		linknext = "0118_00196",
		line = 2563,
	},
	["0118_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I heard it from the people who continually tormented her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那些经常责备她的人们口中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從那些經常責備她的人們口中。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00195",
		linknext = "0118_00197",
		line = 2573,
	},
	["0118_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How they were legitimately glad she had finally died.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——听到了“总算死了，这下清净了”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——聽到了「總算死了，這下清淨了」。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00196",
		linknext = "0118_00198",
		line = 2583,
	},
	["0118_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And when I heard that, I felt like a precious part of me had been smashed into pieces.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个时候，我感觉自己的某种很重要的东西坏掉了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個時候，我感覺自己的某種很重要的東西壞掉了。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00197",
		linknext = "0118_00199",
		line = 2593,
	},
	["0118_00199"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
