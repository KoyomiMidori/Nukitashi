ast = {
	["0118_00001"] = {
		{"fg", mode=-1, id=30},
		{"savetitle", text="冷泉問答-5-", ja="冷泉問答-5-", en="The Reizei Dialogue -5-", cn="冷泉问答 -5-", tw="冷泉問答 -5-"},
		{"eval", exp="g.05_fk_18=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"se", id=0, loop=0, file="se_a079"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At lunch the next day, I head straight for the student council room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第二天中午，我立刻赶往学生会室。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第二天中午，我立刻趕往學生會室。",
					{"rt2"},
				},
			},
		},
		linknext = "0118_00002",
		line = 19,
	},
	["0118_00002"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"se", id=0, loop=0, file="se_a145"},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=-12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0807", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh? Welcome, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀——欢迎光临，前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀——歡迎光臨，前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00001",
		linknext = "0118_00003",
		line = 35,
	},
	["0118_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The student council president puts on a subtle smile the moment I enter, as though she was anticipating my entry that instant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一开门，学生会长就像早就知道我会在这个时候到来一样，脸上露出了浅浅的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一開門，學生會長就像早就知道我會在這個時候到來一樣，臉上露出了淺淺的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00002",
		linknext = "0118_00004",
		line = 45,
	},
	["0118_00004"] = {
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=-2.5, time=300, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a144"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks for yesterday. Did it live up to your expectations?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“昨天真是谢谢你了。满足你的期待了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「昨天真是謝謝你了。滿足你的期待了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00003",
		linknext = "0118_00005",
		line = 59,
	},
	["0118_00005"] = {
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0808", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, it was a brilliant victory. So great, it makes me want you to myself all the more.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。真是一场漂亮的胜利。我更想把你变成自己的东西了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。真是一場漂亮的勝利。我更想把你變成自己的東西了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00004",
		linknext = "0118_00006",
		line = 75,
	},
	["0118_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I admit I had fun myself. Dashing your expectations by winning a clean sweep and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的心情也很好。因为这是彻底摧毁你们意图的胜利。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的心情也很好。因為這是徹底摧毀你們意圖的勝利。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00005",
		linknext = "0118_00007",
		line = 87,
	},
	["0118_00007"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0809", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And it gave you a memory for the ages, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“而且也有舒服的回忆，对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「而且也有舒服的回憶，對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00006",
		linknext = "0118_00008",
		line = 101,
	},
	["0118_00008"] = {
		{"se", id=1, loop=0, file="se_a145"},
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=7, size=2.5, time=50, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was a bad line to take a sip of tea at.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我差点不小心喷出红茶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我差點不小心噴出紅茶。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00007",
		linknext = "0118_00009",
		line = 114,
	},
	["0118_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As usual, this broad's impossible to read.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……还是一样，是个看不见底的女人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……還是一樣，是個看不見底的女人。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00008",
		linknext = "0118_00010",
		line = 124,
	},
	["0118_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I clear my throat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我清了清嗓子，重整态势。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我清了清嗓子，重整態勢。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00009",
		linknext = "0118_00011",
		line = 134,
	},
	["0118_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, I'm here to ensure you make good on your promise.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之，实现你的承诺吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之，實現你的承諾吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00010",
		linknext = "0118_00012",
		line = 146,
	},
	["0118_00012"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0810", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, of course. What would you like to ask me? If it's about my measurements, the ones published on the official OSS website are still accurate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，当然。你想问什么？顺便说一下，如果是三围的话，SHO的官方网站上写的是正确的哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，當然。你想問什麼？順便說一下，如果是三圍的話，SHO的官方網站上寫的是正確的哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00011",
		linknext = "0118_00013",
		line = 160,
	},
	["0118_00013"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'd like you to tell me about the Sakimori family you were training to serve for in the past.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请告诉我你过去曾接受过奉公修行的‘防人家’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請告訴我你過去曾接受過奉公修行的『防人家』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00012",
		linknext = "0118_00014",
		line = 172,
	},
	["0118_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I knew I'd heard the Sakimori family name before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有关名为防人的家族——没错，我曾听说过一次这个名字。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有關名為防人的家族——沒錯，我曾聽說過一次這個名字。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00013",
		linknext = "0118_00015",
		line = 182,
	},
	["0118_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From her own lips, that is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且是从她的嘴里说出来的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且是從她的嘴裡說出來的。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00014",
		linknext = "0118_00016",
		line = 192,
	},
	["0118_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She let it slip while reminiscing about her youth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为她儿时回忆的一部分，这个情报被她讲了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為她兒時回憶的一部分，這個情報被她講了出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00015",
		linknext = "0118_00017",
		line = 202,
	},
	["0118_00017"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00109", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks caught completely off guard, just for an instant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一瞬间，她的脸上似乎浮现出了被刺中弱点的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一瞬間，她的臉上似乎浮現出了被刺中弱點的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00016",
		linknext = "0118_00018",
		line = 215,
	},
	["0118_00018"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then she contemplates the question for a bit, and nods.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她思考了片刻，然后点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她思考了片刻，然後點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00017",
		linknext = "0118_00019",
		line = 227,
	},
	["0118_00019"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0811", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“How much do you know about the Sakimori family?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈对防人家有多少了解呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩對防人家有多少了解呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00018",
		linknext = "0118_00020",
		line = 241,
	},
	["0118_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just what you mentioned before. It being a prestigious family with a long tradition of raising women as servants.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只有之前和学生会长闲聊过的程度。听说是个善于培养佣人的名门望族，而且还有在培养女佣——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只有之前和學生會長閒聊過的程度。聽說是個善於培養傭人的名門望族，而且還有在培養女傭——」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00019",
		linknext = "0118_00021",
		line = 253,
	},
	["0118_00021"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0812", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The Sakimoris are quite a well-known family with roots in Kyushu. Mostly well-known in the world of finance, and by the upper class, that is. 'Humble and faithful Sakimori', they call it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“防人家是九州某个地区赫赫有名的一族。主要在企业界和",
					{"ruby", text="・・・・・・"},
					"身份高贵之人",
					{"/ruby"},
					"之间，作为‘犬马防人’有名。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「防人家是九州某個地區赫赫有名的一族。主要在企業界和",
					{"ruby", text="・・・・・・"},
					"身份高貴之人",
					{"/ruby"},
					"之間，作為『犬馬防人』有名。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00020",
		linknext = "0118_00022",
		line = 265,
	},
	["0118_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Humble and faithful?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“犬马？是指‘犬马之心’吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「犬馬？是指『犬馬之心』嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00021",
		linknext = "0118_00023",
		line = 277,
	},
	["0118_00023"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0813", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. Honorable to a fault, and proud to serve without ever forsaking their masters. They value having people like that far beyond having abundant wealth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的。把为主君尽忠视为光荣，任何时候都不会抛弃。比起拥有无限的财产，拥有一个他们更有价值……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的。把為主君盡忠視為光榮，任何時候都不會拋棄。比起擁有無限的財產，擁有一個他們更有價值……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00022",
		linknext = "0118_00024",
		line = 291,
	},
	["0118_00024"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0814", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“A will of steel, compelling them to do whatever their employer wishes of them...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“只要是主人所希望的，无论什么事都能实现的钢铁之心——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「只要是主人所希望的，無論什麼事都能實現的鋼鐵之心——」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00023",
		linknext = "0118_00025",
		line = 303,
	},
	["0118_00025"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0815", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Even before my grandparents were born, the Sakimoris were famed for that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“在我们的祖父母出生还要之前的遥远过去，防人一族就被如此讴歌。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「在我們的祖父母出生還要之前的遙遠過去，防人一族就被如此謳歌。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00024",
		linknext = "0118_00026",
		line = 315,
	},
	["0118_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So, it's a powerful family of servants renowned for being incredibly capable and loyal?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……也就是说，是非常有能力且忠诚心很强的佣人一族吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……也就是說，是非常有能力且忠誠心很強的佣人一族嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00025",
		linknext = "0118_00027",
		line = 325,
	},
	["0118_00027"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0816", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But the family itself has very few members. Demand for their services far outstrips supply, which makes them all the more sought-after. Hence why they need to raise others.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是防人家的人数也有限。相比需求的增加，供应跟不上，所以价值才会暴涨，所以，才有必要培养。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是防人家的人數也有限。相比需求的增加，供應跟不上，所以價值才會暴漲，所以，才有必要培養。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00026",
		linknext = "0118_00028",
		line = 337,
	},
	["0118_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Such as yourself, and your elder sister.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是你，还有你姐姐。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是你，還有你姐姐。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00027",
		linknext = "0118_00029",
		line = 349,
	},
	["0118_00029"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0817", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. Servants trained under the Sakimori name are very highly valued. My sister was considered to excel even amongst them, so a caretaker for her appeared very quickly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的。在防人家接受教育的佣人，会得到较高的评价。其中能力优秀的姐姐，很快就出现了买主。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的。在防人家接受教育的佣人，會得到較高的評價。其中能力優秀的姐姐，很快就出現了買主。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00028",
		linknext = "0118_00030",
		line = 364,
	},
	["0118_00030"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0818", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“They were most likely in the yakuza, or a one-percenter who placed high value on appearances. Though I have only her rumors, so I cannot say for certain.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“大概是在某处的黑道一族，或者是异常在意虚荣的土豪——我只听说过传闻，所以不知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「大概是在某處的黑道一族，或者是異常在意虛榮的土豪——我只聽說過傳聞，所以不知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00029",
		linknext = "0118_00031",
		line = 376,
	},
	["0118_00031"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're that deep in the dark about your own sister?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只知道这种程度的情报吗，明明是亲生妹妹……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只知道這種程度的情報嗎，明明是親生妹妹……」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00030",
		linknext = "0118_00032",
		line = 388,
	},
	["0118_00032"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0819", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm afraid so. The Sakimoris always drum into their servants that no one is more important than their master, whom they should value above all others.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是就算是亲生妹妹。防人家教导我们自己的主人永远是最重要的，比任何人都重要。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是就算是親生妹妹。防人家教導我們自己的主人永遠是最重要的，比任何人都重要。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00031",
		linknext = "0118_00033",
		line = 400,
	},
	["0118_00033"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0820", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“They are taught to cut off whomever they must to make their master happy. Even their own family members.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“为了自己主人的幸福，任何人都能抛弃。即使是真正的家人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「為了自己主人的幸福，任何人都能拋棄。即使是真正的家人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00032",
		linknext = "0118_00034",
		line = 412,
	},
	["0118_00034"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0821", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Which is why we have barely ever spoken to each other, despite being sisters.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因此，我们姐妹也几乎没有说过话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因此，我們姐妹也幾乎沒有說過話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00033",
		linknext = "0118_00035",
		line = 424,
	},
	["0118_00035"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0822", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In addition, they also teach forbearance. Experiencing misery, and worse, as much as possible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“其次被彻底教育的是学会忍受。雪上加霜又何妨。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「其次被徹底教育的是學會忍受。雪上加霜又何妨。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00034",
		linknext = "0118_00036",
		line = 439,
	},
	["0118_00036"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0823", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“They're taught to experience repeated hardships, overcome numerous difficulties, and finally attain the fulfillment of your goals through your trials and tribulations.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“‘尝过多重辛酸，克服无数苦难，在辛苦艰难的尽头，成就圆满夙愿。’就像这样——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「『嚐過多重辛酸，克服無數苦難，在辛苦艱難的盡頭，成就圓滿夙願。』就像這樣——」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00035",
		linknext = "0118_00037",
		line = 451,
	},
	["0118_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What the hell do I even say to this?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——我该说什么好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——我該說什麼好。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00036",
		linknext = "0118_00038",
		line = 461,
	},
	["0118_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Putting myself in their place, and thinking about what Asa and I have been through, makes me feel like my chest is going to burst.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果换成自己……换成我和麻沙酱，光想想，胸口就快裂开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果換成自己……換成我和麻沙醬，光想想，胸口就快裂開。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00037",
		linknext = "0118_00039",
		line = 471,
	},
	["0118_00039"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0824", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Heh heh... You're terribly kind, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……呵呵，你真温柔啊，前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……呵呵，你真溫柔啊，前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00038",
		linknext = "0118_00040",
		line = 486,
	},
	["0118_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00039",
		linknext = "0118_00041",
		line = 498,
	},
	["0118_00041"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0825", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You harbor sympathy for your enemy, even while you believe me to be of no use. That is the mark of kindness. Almost too kind, even.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“同情作为敌人的我——就算那是不必要的事情——但也太善良了。可以说是善良过度。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「同情作為敵人的我——就算那是不必要的事情——但也太善良了。可以說是善良過度。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00040",
		linknext = "0118_00042",
		line = 513,
	},
	["0118_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'd call it pity myself. You are nothing if not pitiable to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么……只是觉得可怜，所以同情了你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼……只是覺得可憐，所以同情了你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00041",
		linknext = "0118_00043",
		line = 525,
	},
	["0118_00043"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0826", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You show too much compassion. And that is, well... while an admirable trait, not exactly a praiseworthy one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你对很多东西都太慈悲了。这……是啊……一定是很美好的事情，但不是件好事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你對很多東西都太慈悲了。這……是啊……一定是很美好的事情，但不是件好事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00042",
		linknext = "0118_00044",
		line = 539,
	},
	["0118_00044"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not following what you're saying here. I'm a man who only acts to preserve his own dignity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不知道你在说什么。我是个只靠自己的矜持行动的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不知道你在說什麼。我是個只靠自己的矜持行動的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00043",
		linknext = "0118_00045",
		line = 551,
	},
	["0118_00045"] = {
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
				{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine", delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0827", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And I am simply observing where that dignity comes from. Heh, if not for that, I would never have taken such an interest in you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我说的是那份矜持出现的原因。呵呵，不过要是你不是那样的话，我就不会对你感兴趣了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我說的是那份矜持出現的原因。呵呵，不過要是你不是那樣的話，我就不會對你感興趣了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00044",
		linknext = "0118_00046",
		line = 566,
	},
	["0118_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't give a shit about that. I just wanted to know about the Sakimori family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这跟我无关。我想知道的，只有关于防人家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這跟我無關。我想知道的，只有關於防人家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00045",
		linknext = "0118_00047",
		line = 578,
	},
	["0118_00047"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0828", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So I see. Incidentally, there is a rumor I heard near the conclusion of my own training as a servant.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“好的……话说，在奉公人修行的时候，我听说过这样的传闻。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「好的……話說，在奉公人修行的時候，我聽說過這樣的傳聞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00046",
		linknext = "0118_00048",
		line = 593,
	},
	["0118_00048"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0829", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Long ago, the eldest son of the head of the Sakimori family and the eldest daughter of a rich and powerful land owner from western Japan eloped.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“以前，宗家防人的长子，在西日本和拥有强大力量的大地主的长女，私奔了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「以前，宗家防人的長子，在西日本和擁有強大力量的大地主的長女，私奔了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00047",
		linknext = "0118_00049",
		line = 607,
	},
	["0118_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The son of the family infamous for never betraying their master?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……以不会背叛主人而闻名的家族的长子吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……以不會背叛主人而聞名的家族的長子嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00048",
		linknext = "0118_00050",
		line = 619,
	},
	["0118_00050"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0830", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. That's why it's a famous story. They say that couple eventually had a daughter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。正因为如此才很有名。之后不久，他们俩之间生出了女儿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。正因為如此才很有名。之後不久，他們倆之間生出了女兒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00049",
		linknext = "0118_00051",
		line = 634,
	},
	["0118_00051"] = {
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=500},
		{"se", id=1, loop=1, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A daughter...",
					{"rt2"},
				},
			},
			cn = {
				{
					"女儿——",
					{"rt2"},
				},
			},
			tw = {
				{
					"女兒——",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00050",
		linknext = "0118_00052",
		line = 647,
	},
	["0118_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I have to surmise based on what I know, if anybody from that humble and faithful Sakimori family would have the resolve to elope...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果，我现在的推测是对的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果，我現在的推測是對的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00051",
		linknext = "0118_00053",
		line = 657,
	},
	["0118_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It would have to be the Sakimori we know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"私奔的“犬马防人”，就是那个防人老人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"私奔的「犬馬防人」，就是那個防人老人。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00052",
		linknext = "0118_00054",
		line = 667,
	},
	["0118_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The eldest daughter of a wealthy household would have been his wife.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大地主的女儿，是作为其妻子的女性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大地主的女兒，是作為其妻子的女性。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00053",
		linknext = "0118_00055",
		line = 677,
	},
	["0118_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So their daughter and Senator Hitoura would have given birth to—",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们之间生出的少女和……那个仁浦先生之间生出的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們之間生出的少女和……那個仁浦先生之間生出的——",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00054",
		linknext = "0118_00056",
		line = 687,
	},
	["0118_00056"] = {
		{"bgm", stop=1},
		{"se", id=1, stop=1, time=1000},
		{"fg", file="touka_01m_00001", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0831", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Would that not be Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——就是‘文乃’对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——就是『文乃』對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00055",
		linknext = "0118_00057",
		line = 703,
	},
	["0118_00057"] = {
		{"se", id=0, loop=1, file="se_a107"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
