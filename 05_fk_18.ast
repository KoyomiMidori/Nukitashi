	["0118_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm going to take her back to the man related to her by blood.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我已经决定将她平安送到血亲那里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我已經決定將她平安送到血親那裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00213",
		linknext = "0118_00215",
		line = 2776,
	},
	["0118_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And to do that, I'll smash any obstacle in my way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此无论什么障碍，我都会摧毁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此無論什麼障礙，我都會摧毀。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00214",
		linknext = "0118_00216",
		line = 2786,
	},
	["0118_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm not going to rest until my objective of bringing happiness to her has been achieved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想要让这个孩子幸福的心情，在到达目的前绝不动摇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想要讓這個孩子幸福的心情，在到達目的前絕不動搖。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00215",
		linknext = "0118_00217",
		line = 2796,
	},
	["0118_00217"] = {
