				{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine", delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1132", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Wha— N-Not at all...! Listen, Tachibana, non-SS have no business being in the student council room! Miss Touka is a very busy woman. Go on, get out of here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什！我才没有……！喂橘，这次就算了，但非FS的人别靠近学生会室！桐香大人也很忙喔。好了，快回去快回去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什！我才沒有……！喂橘，這次就算了，但非FS的人別靠近學生會室！桐香大人也很忙喔。好了，快回去快回去！」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00075",
		linknext = "0118_00077",
		line = 978,
	},
	["0118_00077"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=1},
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=10, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", file2="rei_01m_00204", path=":fg/rei_01m/", id=8, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=1, mode=3, x=-400, y=0},
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=10, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="touka_01l_00001", file1="touka_01l_00110", path=":fg/touka_01l/", id=10, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="桐香", id=10, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine", delay2=1500},
				{"se", id=0, loop=0, file="se_a093", delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0838", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“My, how intimidating. I suppose I had better show you the door before she gets truly irate. This way, please.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“唉好可怕啊。那么，前辈，在礼生气之前……回去的路在这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「唉好可怕啊。那麼，前輩，在禮生氣之前……回去的路在這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00076",
		linknext = "0118_00078",
		line = 1001,
	},
	["0118_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She shows me to the door in a friendly tone of voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长就像在推我的背一样，用极其友好的语气把我送到了门口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長就像在推我的背一樣，用極其友好的語氣把我送到了門口。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00077",
		linknext = "0118_00079",
		line = 1011,
	},
	["0118_00079"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=8, ch="礼", lv=5, time=100},
		{"fg", file="touka_01l_00001", file1="touka_01l_00102", path=":fg/touka_01l/", id=10, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0839", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You know... I finally get it now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——啊啊，我……终于明白了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——啊啊，我……終於明白了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00078",
		linknext = "0118_00080",
		line = 1028,
	},
	["0118_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She nonchalantly whispers that into my ear.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，她以若无其事的表情对我耳语道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，她以若無其事的表情對我耳語道。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00079",
		linknext = "0118_00081",
		line = 1038,
	},
	["0118_00081"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0840", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I believe for certain that I want to help you. You are misunderstood by others, and you stifle your own capabilities. The islanders have made you suffer for very long indeed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我一定要成为你的力量。被周围的人误会的你，扼杀自己才能的你，还有长年被岛上的人折磨的你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我一定要成為你的力量。被周圍的人誤會的你，扼殺自己才能的你，還有長年被島上的人折磨的你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00080",
		linknext = "0118_00082",
		line = 1050,
	},
	["0118_00082"] = {
		{"fg", file="touka_01l_00001", file1="touka_01l_00113", path=":fg/touka_01l/", id=10, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0841", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It is not non-virgins as a whole you hate, but the non-virgins who hurt someone precious to you. Ergo, it is the islanders you hate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你不是讨厌非处女，而是对伤害了你重要的人的非处女——也就是说，你恨岛上的人们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你不是討厭非處女，而是對傷害了你重要的人的非處女——也就是說，你恨島上的人們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00081",
		linknext = "0118_00083",
		line = 1064,
	},
	["0118_00083"] = {
		{"se", id=1, loop=1, file="se_a105"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——————」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00082",
		linknext = "0118_00084",
		line = 1077,
	},
	["0118_00084"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=8, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=500, mode=3, x=300, y=0},
		{"fgact", ch="礼", id=8, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1133", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana, what are you just standing around for? Stomachache, perhaps? If you're going to hang around here, you may as well help us with this paperwork.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎么了橘，为什么停在了那里？肚子疼吗？比起一直站着，倒不如来帮我们处理文件。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼了橘，為什麼停在了那裡？肚子痛嗎？比起一直站著，倒不如來幫我們處理文件。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00083",
		linknext = "0118_00085",
		line = 1091,
	},
	["0118_00085"] = {
		{"se", id=1, loop=1, file="se_a107"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0842", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But you have your junk on your side, and the right to use it. So you ought to be able to conquer all those who hurt you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“可是你有那个鸡巴。同时，也有那个权利。正因为如此，你才可以对所有伤害你的人进行报仇。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「可是你有那個肉棒。同時，也有那個權利。正因為如此，你才可以對所有傷害你的人進行報仇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00084",
		linknext = "0118_00086",
		line = 1104,
	},
	["0118_00086"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0843", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Using your enormous phallus will have every woman on the island kowtowing to you. They will heed your every word. You would have control over half this island's inhabitants.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果你使用巨根，岛上的女人一定会服从于你，无论发生什么事都顺从你。这不就等于掌握了岛上的一半吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「如果你使用巨根，島上的女人一定會服從於你，無論發生什麼事都順從你。這不就等於掌握了島上的一半嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00085",
		linknext = "0118_00087",
		line = 1116,
	},
	["0118_00087"] = {
		{"fg", file="touka_01l_00001", file1="touka_01l_00113", path=":fg/touka_01l/", id=10, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=10, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0844", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I can help you. Why not take revenge? On those who made your loved one suffer, who just idly looked on and wallowed in their habitual state.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我可以帮你。嗯，进行报复吧？对着那些使自己重要的人痛苦不堪的人，只是袖手旁观的人，以及所有享受惰性的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我可以幫你。嗯，進行報復吧？對著那些使自己重要的人痛苦不堪的人，只是袖手旁觀的人，以及所有享受惰性的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00086",
		linknext = "0118_00088",
		line = 1131,
	},
	["0118_00088"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0845", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“With your massive equipment and my help, we can demonstrate to the islanders the true extent of your abilities.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“用巨大的男根，让岛上的人看见你拥有的所有才能吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「用巨大的男根，讓島上的人看見你擁有的所有才能吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00087",
		linknext = "0118_00089",
		line = 1143,
	},
	["0118_00089"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=8, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=500, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00120", file2="rei_01m_00202", path=":fg/rei_01m/", id=8, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=500, y=0},
				{"fgact", ch="礼", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1134", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“How long do you plan on standing there, Tachibana? Tachibana...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你打算站到什么时候橘！……橘？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你打算站到什麼時候橘！……橘？」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00088",
		linknext = "0118_00090",
		line = 1160,
	},
	["0118_00090"] = {
		{"se", id=1, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="touka_01ll_00001", file1="touka_01ll_00113", path=":fg/touka_01ll/", id=10, lv=5, head="touka_01ll", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=10, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0846", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But in return... I want you to make me your number one.”",
					{"rt2"},
				},
			},
			cn = {
