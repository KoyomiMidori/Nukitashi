		linkback = "0118_00207",
		linknext = "0118_00209",
		line = 2712,
	},
	["0118_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having come to this realization, I now know that being unable to accept it would have let the student council president wrap me around her little finger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果我不能自己领悟，消化的话，恐怕又要被学生会长单方面进攻了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果我不能自己領悟，消化的話，恐怕又要被學生會長單方面進攻了。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00208",
		linknext = "0118_00210",
		line = 2722,
	},
	["0118_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I'm not gonna let her get the best of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是之前的情况，绝对无法战胜那个家伙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是之前的情況，絕對無法戰勝那個傢伙。",
					{"rt2"},
				},
			},
		},
