		{"fg", file="asane_02m_00003", file1="asane_02m_00108", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"fg", file="fumino_01l_00003", file1="fumino_01l_00109", file2="fumino_01l_00201", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1715", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"非表示", "麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Asane"},
					"“BROOOO! I had a nightmare! I kicked this giant isopod, and then it stood up, opened its mouth and swallowed me up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "麻沙音"},
					"“哥哥～……！我做了个可怕的梦～……！是个我把一只大王具足虫踢着玩，结果牠突然站起来张大嘴把我吞下去的梦～……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "麻沙音"},
					"「哥哥～……！我做了個可怕的夢～……！是個我把一隻大王具足蟲踢著玩，結果牠突然站起來張大嘴把我吞下去的夢～……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00245",
		linknext = "0118_00247",
		line = 3170,
	},
	["0118_00247"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00111", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1716", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I was so scared! Please make it all better! Read me a picture book until I flake out again and bring me some water whenever I get thirsty please and thank!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好可怕啊～……！快摸摸我……！就那样一直讲童话故事直到我入睡为止还要在我口渴的时候轻轻地把水放进我嘴里～……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好可怕啊～……！快摸摸我……！就那樣一直講童話故事直到我入睡為止還要在我口渴的時候輕輕地把水放進我嘴裡～……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00246",
		linknext = "0118_00248",
		line = 3185,
	},
	["0118_00248"] = {
