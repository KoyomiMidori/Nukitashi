	["0118_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if my initial actions were borne out of a desire to take out revenge on the islanders, that no longer matters.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……假设我的初期冲动，是来自对岛民们的报复心的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……假設我的初期衝動，是來自對島民們的報復心的話。",
					{"rt2"},
				},
			},
		},
