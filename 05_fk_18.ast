		linknext = "0118_00200",
		line = 2605,
	},
	["0118_00200"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why didn't I associate that with me being a virgin addict?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……为什么，我没有把这个跟我的处女厨联系在一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……為什麼，我沒有把這個跟我的處女廚聯繫在一起。",
					{"rt2"},
				},
			},
		},
		linkback = "0118_00199",
		linknext = "0118_00201",
		line = 2616,
	},
	["0118_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I probably wanted to forget that past.",
					{"rt2"},
				},
			},
