			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0443", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yay! ♪ So yeah, we're both gonna be downtown for a while. Heh heh... You two have fun, now! Mwah~”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“太好了～♪就是这样，那我们要绕道而行了……呵呵……你们慢慢来～嗯啾。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「太好了～♪就是這樣，那我們要繞道而行了……呵呵……你們慢慢來～嗯啾。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00293",
		linknext = "0092_00295",
		line = 3936,
	},
	["0092_00295"] = {
