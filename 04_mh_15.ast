				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I find myself moved almost to tears by Misaki's kindness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我被美岬的温柔打动，差点哭了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我被美岬的溫柔打動，差點哭了出來。",
					{"rt2"},
				},
			},
