	["0092_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that's Wata for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱就跟平常一样呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬就跟平常一樣呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00150",
		linknext = "0092_00152",
		line = 2014,
	},
	["0092_00152"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", file="asane_02m_00001", file1="asane_02m_00113", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="浮遊横", loop=15, size=5, time=75, ease="easeinout_sine"},
		{"text"},
		delay = {
			[7000] = {
				{"fgact", ch="麻沙音", id=3, act="浮遊横", loop=17, size=7.5, time=75, ease="easeinout_sine", delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1478", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, f-fuck, Bro... With both Nanabuta and Onase here I'm gonna get so turned on that my brain's gonna overheat and my panties are gonna fucking overflow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊，哥、哥哥……奈奈部田前辈和女濑同学都在这样下去脚踏两条船的我的脚就会湿润润地幸福指数天元突破要升天啦……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊，哥、哥哥……奈奈部田前輩和女瀨同學都在這樣下去腳踏兩條船的我的腳就會濕潤潤地幸福指數天元突破要升天啦……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00151",
		linknext = "0092_00153",
		line = 2031,
	},
	["0092_00153"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think the brainworms are getting to your Broca's area, little missy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“情感会不会超前语言能力太多了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「情感會不會超前語言能力太多了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00152",
		linknext = "0092_00154",
		line = 2043,
	},
	["0092_00154"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki, don't you have something to say?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……美岬什么都不说吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……美岬什麼都不說嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00153",
		linknext = "0092_00155",
		line = 2055,
	},
	["0092_00155"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1445", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I sort of had a hunch this would happen. I know how kind you are, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我隐约有会变成这样的感觉了……因为淳之介君很温柔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我隱約有會變成這樣的感覺了……因為淳之介君很溫柔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00154",
		linknext = "0092_00156",
		line = 2070,
	},
	["0092_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00155",
		linknext = "0092_00157",
		line = 2082,
	},
	["0092_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I only spoke to her briefly yesterday, but she's seen through everything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明昨天只是说了几句，美岬却什么都看透了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明昨天只是說了幾句，美岬卻什麼都看透了。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00156",
		linknext = "0092_00158",
		line = 2092,
	},
	["0092_00158"] = {
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While I'm deeply moved, I have to keep my composure. I clear my throat and turn to face everyone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边感慨万千，一边清了清嗓子，面向所有人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊感慨萬千，一邊清了清嗓子，面向所有人。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00157",
		linknext = "0092_00159",
		line = 2108,
	},
	["0092_00159"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now, Onabuta was formerly a member of the SS, and we have faced her down as our enemy. I'm sure you all have your own feelings about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——女部田是一直以来与我们敌对的FS的一员。我想大家都有各自的想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——女部田是一直以來與我們敵對的FS的一員。我想大家都有各自的想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00158",
		linknext = "0092_00160",
		line = 2120,
	},
	["0092_00160"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But she's worthy of our trust. You have my word on that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是——可以信任她。我能保证。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是——可以信任她。我能保證。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00159",
		linknext = "0092_00161",
		line = 2132,
	},
	["0092_00161"] = {
		{"fg", file="ikuko_01l_00002", file1="ikuko_01l_00121", file2="ikuko_01l_00201", path=":fg/ikuko_01l/", id=10, lv=5, head="ikuko_01l", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0418", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Darling...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲爱的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「親愛的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00160",
		linknext = "0092_00162",
		line = 2145,
	},
	["0092_00162"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She was the SS's strongest asset, and their first squad commander. I don't think anything is more reassuring than having her on our side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“女部田是FS中最强的一队队长。如果能站在我们这边，没有比这更让人安心的了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「女部田是FS中最強的一隊隊長。如果能站在我們這邊，沒有比這更讓人安心的了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00161",
		linknext = "0092_00163",
		line = 2157,
	},
	["0092_00163"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0419", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Darling...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲爱的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「親愛的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00162",
		linknext = "0092_00164",
		line = 2169,
	},
	["0092_00164"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Forgetfulness is magic bestowed on us by God, but forgiveness is magic people find for themselves. To coin a phrase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你知道这句格言吗？忘却是神赋予的魔法，但宽恕却是人所拥有的魔法——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你知道這句格言嗎？忘卻是神賦予的魔法，但寬恕卻是人所擁有的魔法——」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00163",
		linknext = "0092_00165",
		line = 2181,
	},
	["0092_00165"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0420", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Darjeeling...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“大吉岭……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「大吉嶺……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00164",
		linknext = "0092_00166",
		line = 2193,
	},
	["0092_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Onabuta used to represent everything we've been fighting against. But personally... I'm willing to forgive her. How about you guys?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“女部田的过往行为和我们的意志是相反的。但是——我想宽恕那样的她……可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「女部田的過往行為和我們的意志是相反的。但是——我想寬恕那樣的她……可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00165",
		linknext = "0092_00167",
		line = 2205,
	},
	["0092_00167"] = {
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2055", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Me too! Senior's gotta treat her cute little juniors with respect and all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“当然啦，作为前辈要对后辈温柔才行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「當然啦，作為前輩要對後輩溫柔才行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00166",
		linknext = "0092_00168",
		line = 2222,
	},
	["0092_00168"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2047", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hey, if you're cool with that, I'm cool with it too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“如果你觉得可以的话，我也不反对咯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
