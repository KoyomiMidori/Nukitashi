					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hmmm... I see how it is. I think I can put two and two together here ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯……原来如此。郁好像明白了啊♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯……原來如此。郁好像明白了啊♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00290",
		linknext = "0092_00292",
