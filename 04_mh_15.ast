					"“I hate to drag everyone back into the real world when you're having so much fun, but... what do we do going forward?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……虽然不太想在气氛高涨的时候提起现实……但接下来该怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……雖然不太想在氣氛高漲的時候提起現實……但接下來該怎麼辦？」",
					{"rt2"},
				},
