		linkback = "0092_00241",
		linknext = "0092_00243",
		line = 3246,
	},
	["0092_00243"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1458", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You did it because you didn't have a choice, right? Like to help us escape, or to rescue us. If anything, I should be thanking you for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那也是没办法的事不是吗？你是为了让我们逃掉，为了帮助我们才做的……我反而非常感谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那也是沒辦法的事不是嗎？你是為了讓我們逃掉，為了幫助我們才做的……我反而非常感謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00242",
		linknext = "0092_00244",
		line = 3260,
	},
	["0092_00244"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
