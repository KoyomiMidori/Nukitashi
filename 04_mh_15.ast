					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look... You do know who I am, right? I'm an anti-copulator. I'm the head honcho of an organization standing up against wanton fucking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我说啊……你不是知道吗？我可是反交尾势力，是反对无秩序性爱的组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我說啊……你不是知道嗎？我可是反交尾勢力，是反對無秩序性愛的組織。」",
					{"rt2"},
				},
			},
