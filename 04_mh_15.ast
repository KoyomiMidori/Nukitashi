	["0092_00088"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0400", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I just wanted to thank you, since you were so kind to me yesterday. It made me really happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我想报答你……昨天你对我那么温柔……我真的很高兴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我想報答你……昨天你對我那麼溫柔……我真的很高興……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00087",
		linknext = "0092_00089",
