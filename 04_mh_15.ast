	["0092_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She flashes a beautiful, innocent smile. The kind she never showed when fighting me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是和她敌对时从未见过的——天真无邪的少女的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是和她敵對時從未見過的——天真無邪的少女的笑容。",
					{"rt2"},
				},
			},
