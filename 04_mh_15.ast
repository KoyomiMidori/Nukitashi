		},
		linkback = "0092_00196",
		linknext = "0092_00198",
		line = 2642,
	},
	["0092_00198"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1452", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Co...!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“小鸡……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「小雞……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00197",
		linknext = "0092_00199",
		line = 2657,
	},
	["0092_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just leave it, Misaki. It brings up some unpleasant memories for her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别这样美岬，大概是因为光是回想就很痛苦吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別這樣美岬，大概是因為光是回想就很痛苦吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00198",
		linknext = "0092_00200",
		line = 2669,
	},
	["0092_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Spouting swear words can be a coping mechanism when dealing with trauma. She's not the only one who does it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“每当想起讨厌的回忆时，就会不由自主地说粗话来掩饰——这谁都会吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「每當想起討厭的回憶時，就會不由自主地說粗話來掩飾——這誰都會吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00199",
		linknext = "0092_00201",
		line = 2680,
	},
	["0092_00201"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even Misaki's done it before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"美岬好像也有这样过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"美岬好像也有這樣過。",
					{"rt2"},
