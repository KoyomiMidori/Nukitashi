	["0092_00292"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00107", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0442", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Say, li'l sis. You wanna come hang out with me in town? I still need to thank you properly too and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呐妹妹，现在和我一起上街好吗？我也想答谢妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「吶妹妹，現在和我一起上街好嗎？我也想答謝妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00291",
		linknext = "0092_00293",
		line = 3906,
	},
	["0092_00293"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00112", file2="asane_01m_00204", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1490", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Th-Thank me!? Y-You mean you wanna, like, THANK me thank me!? Y-Y-Yes please, please please please please...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“答……答谢！？那、那果然是答谢（另有含义）吗……一、一定要……一定要一定要一定要……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「答……答謝！？那、那果然是答謝（另有含義）嗎……一、一定要……一定要一定要一定要……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00292",
		linknext = "0092_00294",
		line = 3920,
	},
	["0092_00294"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
