		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, good question... Just getting a new member doesn't mean we're any closer to resolving the issue at hand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……也是。就算多了一个成员，情况也没有进展……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……也是。就算多了一個成員，情況也沒有進展……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00183",
		linknext = "0092_00185",
		line = 2470,
	},
	["0092_00185"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since we know we can't trust the SS, we'll have to break into OSS HQ... No, scratch that. Too risky.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然知道FS也靠不住，那就只能想办法由我们潜入SHO总部——不，这太难了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然知道FS也靠不住，那就只能想辦法由我們潛入SHO總部——不，這太難了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00184",
		linknext = "0092_00186",
		line = 2482,
	},
	["0092_00186"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2049", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I had an idea myself. Why don't we demand a recall?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我有一个想法……要不要罢免？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我有一個想法……要不要罷免？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00185",
		linknext = "0092_00187",
		line = 2496,
	},
	["0092_00187"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2057", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Recall?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“爸免？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「爸免？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00186",
		linknext = "0092_00188",
		line = 2509,
	},
	["0092_00188"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2050", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Make the voters reconsider. If we can get at least a third of the voters' signatures, it's possible to request a dismissal ballot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“就是要求卸任。如果得到1/3以上的选民的签名，就可以要求进行罢免投票。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「就是要求卸任。如果得到1/3以上的選民的簽名，就可以要求進行罷免投票。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00187",
		linknext = "0092_00189",
		line = 2523,
	},
	["0092_00189"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2051", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The new perverted sex law has people at large losing faith in Governor Hitoura. We might be able to lead public opinion and make it happen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“目前因为新・变态条例，对仁浦先生的不信任感越来越高，如果能好好引导舆论，我觉得有实现的可能……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「目前因為新・變態條例，對仁浦先生的不信任感越來越高，如果能好好引導輿論，我覺得有實現的可能……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00188",
		linknext = "0092_00190",
		line = 2537,
	},
	["0092_00190"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“True... His approval rating was higher than a Hollywood producer on Little Saint James not that long ago, but now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“确实……以前因为支持率太高我从来没想过，但如果是现在的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「確實……以前因為支持率太高我從來沒想過，但如果是現在的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00189",
		linknext = "0092_00191",
		line = 2549,
	},
	["0092_00191"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00109", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0423", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Still... If you try to appeal for signatures, you'll get the SS and OSS riding your butts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过……如果想收集签名的话，FS和SHO的人应该会马上过来吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過……如果想收集簽名的話，FS和SHO的人應該會馬上過來吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00190",
		linknext = "0092_00192",
		line = 2562,
	},
	["0092_00192"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right... They've all been brainwashed by Teshima, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也是……毕竟他们被手嶋洗脑了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也是……畢竟他們被手嶋洗腦了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00191",
		linknext = "0092_00193",
		line = 2574,
	},
	["0092_00193"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1450", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Brainwashed!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“洗脑……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「洗腦……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00192",
		linknext = "0092_00194",
		line = 2589,
	},
	["0092_00194"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, right... I haven't told you guys yet. So, basically...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，话说我还没跟你们说过。其实——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，話說我還沒跟你們說過。其實——」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00193",
		linknext = "0092_00195",
		line = 2601,
	},
	["0092_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I explain what Onabuta told me to the others.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把从女部田那里听到的向美岬们说明。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我把從女部田那裡聽到的向美岬們說明。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00194",
		linknext = "0092_00196",
		line = 2611,
	},
	["0092_00196"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1451", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yikes, so he can basically control people's minds? Spooky. How did he do it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦咦……那不就是心灵控制吗？真是可怕啊……但是，到底是怎么洗脑的呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦咦……那不就是心靈控制嗎？真是可怕啊……但是，到底是怎麼洗腦的呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00195",
		linknext = "0092_00197",
		line = 2627,
	},
	["0092_00197"] = {
		{"bgm", stop=1},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0424", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Cock...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“小鸡鸡……”",
					{"rt2"},
