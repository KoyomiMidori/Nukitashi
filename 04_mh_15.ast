		{"bgm", stop=1},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="misaki_02m_00001", file2="misaki_02m_00201", file3="misaki_02m_00307", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1457", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You've broken my heart... Not! Don't worry, I don't blame you for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“真的很失望——什么的……只是玩笑罢了。我不会责怪淳之介君的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「真的很失望——什麼的……只是玩笑罷了。我不會責怪淳之介君的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00240",
		linknext = "0092_00242",
		line = 3234,
	},
	["0092_00242"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
