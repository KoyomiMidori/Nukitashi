	["0092_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a different kind of light in her soft eyes from usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那抬头仰望的瞳孔中含有透明的水分，散发出和平时不同的光芒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那抬頭仰望的瞳孔中含有透明的水分，散發出和平時不同的光芒。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00134",
		linknext = "0092_00136",
		line = 1771,
	},
	["0092_00136"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As long as you don't have anywhere you can call home, you're going against the law of the land, and you share the same end goal as us...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果没有容身之处，与条例反目成仇，抱持相同志向的话——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果沒有容身之處，與條例反目成仇，抱持相同志向的話——」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00135",
		linknext = "0092_00137",
		line = 1783,
	},
	["0092_00137"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's enough to officially make you our comrade.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从今天开始，你也是我们的同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從今天開始，你也是我們的同伴。」",
