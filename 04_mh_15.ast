	["0092_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course it did! What I did was directly opposed to my own values and principles. Of course she's gonna tear me apart over it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过因为我的言行不一致……所以就算受到责备也是理所当然。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過因為我的言行不一致……所以就算受到責備也是理所當然。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00239",
