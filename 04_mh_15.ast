	["0092_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the same bullshit as always for us, but Onabuta's here now, and it looks like she's having fun.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是和平常一样无聊的对话——但女部田融入了圈子里很是开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是和平常一樣無聊的對話——但女部田融入了圈子裡很是開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00180",
		linknext = "0092_00182",
		line = 2429,
	},
	["0092_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure we could never replace the friends she lost from the SS, but seeing her enjoy herself like this makes me glad I brought her here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我们不能代替FS，但如果她能这样笑的话，我把她带来就有意义了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我們不能代替FS，但如果她能這樣笑的話，我把她帶來就有意義了。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00181",
		linknext = "0092_00183",
		line = 2439,
	},
	["0092_00183"] = {
		{"bgm", stop=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
