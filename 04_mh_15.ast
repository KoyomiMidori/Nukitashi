	["0092_00245"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if she understood the circumstances, I never expected her to accept it so readily.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使知道事情的来龙去脉——但在一般情况下，也不是那么简单就能原谅的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使知道事情的來龍去脈——但在一般情況下，也不是那麼簡單就能原諒的。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00244",
		linknext = "0092_00246",
		line = 3282,
	},
	["0092_00246"] = {
		{"text"},
		text = {
