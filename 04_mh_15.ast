	["0092_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She pokes her head out from behind me and bows her head anxiously.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她从我背后探出脸来，不安地低下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她從我背後探出臉來，不安地低下了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00141",
		linknext = "0092_00143",
		line = 1891,
	},
	["0092_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why are you hiding?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在躲什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你在躲什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00142",
		linknext = "0092_00144",
		line = 1903,
	},
	["0092_00144"] = {
		{"fg", file="ikuko_01l_00002", file1="ikuko_01l_00106", file2="ikuko_01l_00202", path=":fg/ikuko_01l/", id=10, lv=5, head="ikuko_01l", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=700, y=0},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0416", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well... I've been your enemy for so long, right? Can they really accept me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为……到现在为止和大家发生了很多事……大家不生气吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為……到現在為止和大家發生了很多事……大家不生氣嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00143",
		linknext = "0092_00145",
		line = 1918,
	},
	["0092_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're worrying too much. We're not such an intolerant organization. Right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你想太多了。我们不是那种不宽容的组织，对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你想太多了。我們不是那種不寬容的組織，對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00144",
		linknext = "0092_00146",
		line = 1930,
	},
	["0092_00146"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00119", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2046", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? Uh, sure... I'm not sure I really get it, though. Is this really Onabuta? Was she like this all along?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶？啊，嗯……应该说我还没跟上状况……那个孩子，真的是女部田同学？她是那样的角色吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸？啊，嗯……應該說我還沒跟上狀況……那個孩子，真的是女部田同學？她是那樣的角色嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00145",
		linknext = "0092_00147",
		line = 1943,
	},
	["0092_00147"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, a lot of shit happened. She's a bit... unstable at the moment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“发生了很多事……所以有点不稳定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「發生了很多事……所以有點不穩定。」",
					{"rt2"},
				},
