	["0092_00092"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's not like any sexual activity at all is gonna make me turn on the waterworks, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我并不是因为讨厌色情而哭的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我並不是因為討厭色情而哭的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00091",
		linknext = "0092_00093",
		line = 1285,
	},
	["0092_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't think she can understand my point of view.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使说明了，女部田也无法理解吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使說明了，女部田也無法理解吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00092",
		linknext = "0092_00094",
		line = 1295,
	},
	["0092_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's incomprehensible to her how someone could hate something that feels so good.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是舒服的事为什么会讨厌——首先这点她就不理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是舒服的事為什麼會討厭——首先這點她就不理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00093",
		linknext = "0092_00095",
		line = 1305,
	},
	["0092_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not like I don't get it. She grew up with the island's value system, so it's the only way of life she knows.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果在肯定性爱的青蓝岛长大，会有那种价值观也不能怪她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果在肯定性愛的青藍島長大，會有那種價值觀也不能怪她。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00094",
		linknext = "0092_00096",
		line = 1315,
	},
	["0092_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Misaki was similar when I first met her too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚相遇时的美岬也差不多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛相遇時的美岬也差不多。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00095",
		linknext = "0092_00097",
		line = 1325,
	},
	["0092_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In any case, at least this time it seemed to come from a good place, rather than forcing me into it like before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么样——她好像没有打算像以前那样用武力强迫我做些什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼樣——她好像沒有打算像以前那樣用武力強迫我做些什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00096",
		linknext = "0092_00098",
		line = 1335,
	},
	["0092_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I consider that, I don't feel the urge to condemn her for it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一想到这里，就不太想严厉地批评她了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一想到這裡，就不太想嚴厲地批評她了。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00097",
		linknext = "0092_00099",
		line = 1345,
	},
	["0092_00099"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, just keep this in mind, Onabuta. From now on, no more trying to pull that shit with me! Got that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之……女部田。今后对我的一切性行为都禁止！知道吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之……女部田。今後對我的一切性行為都禁止！知道嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00098",
		linknext = "0092_00100",
		line = 1357,
	},
	["0092_00100"] = {
		{"bgm", stop=1},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00129", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0403", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yes, loud and clear... Heh... Ahaha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯，我知道了……呵呵……啊哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯，我知道了……呵呵……啊哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00099",
		linknext = "0092_00101",
		line = 1374,
	},
	["0092_00101"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's so funny?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有什么奇怪的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有什麼奇怪的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00100",
		linknext = "0092_00102",
		line = 1386,
	},
	["0092_00102"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0404", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well... You kinda made me think of how Rei would always get mad at me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没有……我只是觉得，好像是惹礼酱生气了一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒有……我只是覺得，好像是惹禮醬生氣了一樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00101",
		linknext = "0092_00103",
		line = 1398,
	},
	["0092_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fair enough... I certainly recall the disciplinary committee prez giving Onabuta a figurative dressing-down on numerous occasions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼酱——指的就是风纪委员长。我记得她经常教训女部田。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮醬——指的就是風紀委員長。我記得她經常教訓女部田。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00102",
		linknext = "0092_00104",
		line = 1408,
	},
	["0092_00104"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Onabuta... I know this kinda goes against what I said last night, but I'm still curious about what happened to you. You feel all right telling me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“女部田……虽然昨天说了那样的话……但我可以问吗？问发生了什么事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「女部田……雖然昨天說了那樣的話……但我可以問嗎？問發生了什麼事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00103",
		linknext = "0092_00105",
		line = 1420,
	},
	["0092_00105"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00124", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0405", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah... I wouldn't really know where to start, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯……但是要从什么地方开始说才好呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯……但是要從什麼地方開始說才好呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00104",
		linknext = "0092_00106",
		line = 1434,
	},
	["0092_00106"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll cut to the chase, then. Is the SS in cahoots with the yakuza now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我开门见山地问。SS……成为黑社会的手下了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我開門見山地問。SS……成為黑社會的手下了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00105",
		linknext = "0092_00107",
		line = 1446,
	},
	["0092_00107"] = {
		{"bgm", file="bgm21", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0406", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah... I'm pretty sure they are. After Fumino got abducted, they sent out everyone they could after her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“说的、也是……一定是这样的。文乃酱被抢走之后，为了夺回她，FS的大家一直都在追查，但……。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「說的、也是……一定是這樣的。文乃醬被搶走之後，為了奪回她，FS的大家一直都在追查，但……。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00106",
		linknext = "0092_00108",
		line = 1459,
	},
	["0092_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And I'm guessing that didn't end well for them, did it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“输了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「輸了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00107",
		linknext = "0092_00109",
		line = 1470,
	},
	["0092_00109"] = {
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=7.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0407", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah... Days of nonstop fighting wore everybody out, but we were up against an enemy who's sharp as tacks. And once they took Fumino hostage... it was checkmate for us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯……大家都因为连续好几天的捉捕作战而疲惫不堪……可是，对方却是准备万全……而且还把文乃酱当成了人质……我们只能投降。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯……大家都因為連續好幾天的捉捕作戰而疲憊不堪……可是，對方卻是準備萬全……而且還把文乃醬當成了人質……我們只能投降。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00108",
		linknext = "0092_00110",
		line = 1483,
	},
	["0092_00110"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So since the yakuza has Fumino as a hostage, the SS and OSS have no choice but to obey them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为文乃成了人质……所以FS和SHO都开始服从黑社会的指示吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為文乃成了人質……所以FS和SHO都開始服從黑社會的指示嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00109",
		linknext = "0092_00111",
		line = 1495,
	},
	["0092_00111"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00124", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0408", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“No. We intended to get her back once we had an opening. But before we could act... everyone got brainwashed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不是的。其实是打算找到空隙抢回来的……但是在实行之前，大家就被洗脑了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不是的。其實是打算找到空隙搶回來的……但是在實行之前，大家就被洗腦了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00110",
		linknext = "0092_00112",
		line = 1509,
	},
	["0092_00112"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00109", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Brainwashed?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说洗脑……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說洗腦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00111",
		linknext = "0092_00113",
		line = 1521,
	},
	["0092_00113"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0409", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah. By some guy named Teshima. He did them all, one by one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯。是个叫手嶋的男人……按顺序对每一个人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯。是個叫手嶋的男人……按順序對每一個人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00112",
		linknext = "0092_00114",
		line = 1533,
	},
	["0092_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And now his name comes up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个名字在这里出现了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個名字在這裡出現了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00113",
		linknext = "0092_00115",
		line = 1543,
	},
	["0092_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's almost too crazy to believe, but after seeing how Hanamaru acted to me yesterday, it seems plausible enough.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然像是个玩笑般的故事——但一想到那个花丸委员长的言行，我就无法一笑置之了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然像是個玩笑般的故事——但一想到那個花丸委員長的言行，我就無法一笑置之了。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00114",
		linknext = "0092_00116",
		line = 1553,
	},
	["0092_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Guess he wasn't lying about his psychological prowess.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋说学过心理学的那句话好像不是谎言。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋說學過心理學的那句話好像不是謊言。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00115",
		linknext = "0092_00117",
		line = 1563,
	},
	["0092_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the perverted sex law is any indication, Seiran Islanders have more than proven how weak they are in the face of coercion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"变态条例的存在就像其象征一样，青蓝岛的人本来就有容易屈服于同调压力倾向。",
					{"rt2"},
				},
			},
			tw = {
				{
					"變態條例的存在就像其像徵一樣，青藍島的人本來就有容易屈服於同調壓力傾向。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00116",
		linknext = "0092_00118",
		line = 1573,
	},
	["0092_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For Teshima, taking advantage of that and using his knowledge of psychology to control them would probably be child's play.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通过这一弱点去控制集体心理——对手嶋来说，或许是件轻而易举的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通過這一弱點去控制集體心理——對手嶋來說，或許是件輕而易舉的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00117",
		linknext = "0092_00119",
		line = 1583,
	},
	["0092_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With his silver tongue, it wouldn't be hard for him to get the OSS and SS to dance in the palm of his hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他用花言巧语让所有人信奉自己，轻易地将FS和SHO化为了棋子吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"他用花言巧語讓所有人信奉自己，輕易地將FS和SHO化為了棋子嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00118",
		linknext = "0092_00120",
		line = 1593,
	},
	["0092_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The same way he so easily gained my trust the first time we met.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就好像只花了几分钟，就得到了我的信任时一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就好像只花了幾分鐘，就得到了我的信任時一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00119",
		linknext = "0092_00121",
		line = 1603,
	},
	["0092_00121"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0410", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I didn't get brainwashed myself. But that meant everyone else started treating me like the black sheep.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我没有中他的洗脑……但是，也因为这个原因，而变成了碍事者……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我沒有中他的洗腦……但是，也因為這個原因，而變成了礙事者……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00120",
		linknext = "0092_00122",
		line = 1615,
	},
	["0092_00122"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0411", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“So Tokie basically told me to get the hell out of the SS... and now I'm all on my own again, just like before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“所以桐香酱叫我退出FS……我又像以前那样变回孤身一人了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「所以桐香醬叫我退出FS……我又像以前那樣變回孤身一人了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00121",
		linknext = "0092_00123",
		line = 1627,
	},
	["0092_00123"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是这样吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是這樣嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00122",
		linknext = "0092_00124",
		line = 1639,
	},
	["0092_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even being slightly different from those around you is enough to get you shunned.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只因为和周围的人有些不同，就被排除在外。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只因為和周圍的人有些不同，就被排除在外。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00123",
		linknext = "0092_00125",
		line = 1649,
	},
	["0092_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Brainwashing is a hell of a situation to get wrapped up in, but her current predicament isn't too unlike how I was in the past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为是和洗脑这一特殊现象有关联，所以严格上来说应该不太一样——但我还是将她和以前的我或者那个人的状况重叠在了一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為是和洗腦這一特殊現像有關聯，所以嚴格上來說應該不太一樣——但我還是將她和以前的我或者那個人的狀況重疊在了一起。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00124",
		linknext = "0092_00126",
		line = 1659,
	},
	["0092_00126"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00106", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0412", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I've always been a spoiled and self-indulgent little hellion... But all the same... everybody there was like family to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然我既不听话，又任性，还一直给别人添麻烦……但我真的，把大家当成家人一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然我既不聽話，又任性，還一直給別人添麻煩……但我真的，把大家當成家人一樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00125",
		linknext = "0092_00127",
		line = 1673,
	},
	["0092_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In spite of all the run-ins we've had, I feel an almost quizzically strong sense of empathy towards her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对这个此前敌对过好几次的女部田，我心中浮现出不可思议的强烈共鸣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對這個此前敵對過好幾次的女部田，我心中浮現出不可思議的強烈共鳴。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00126",
		linknext = "0092_00128",
		line = 1683,
	},
	["0092_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps it's because of who I am right now that I'm able to feel this way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是现在的我，能做到吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是現在的我，能做到嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00127",
		linknext = "0092_00129",
		line = 1693,
	},
	["0092_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I couldn't help that woman who was persecuted to her death... but right now, maybe I can at least help this girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时，没能触及因为遭到迫害而去世的那个人的手——如果是现在，能够到吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時，沒能觸及因為遭到迫害而去世的那個人的手——如果是現在，能構到嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00128",
		linknext = "0092_00130",
		line = 1703,
	},
	["0092_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I close my eyes, and take a slow, quiet breath.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我闭上眼，默默地叹了一口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我閉上眼，默默地嘆了一口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00129",
		linknext = "0092_00131",
		line = 1713,
	},
	["0092_00131"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00121", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Onabuta... I want you to promise me that you won't go doing any more wanton sexual acts. Can you do that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——女部田。你能保证今后不再毫无节制地做爱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——女部田。你能保證今後不再毫無節制地做愛嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00130",
		linknext = "0092_00132",
		line = 1725,
	},
	["0092_00132"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00109", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0413", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huh? But why? That'd be breaking the law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“诶？……为什么？那不是违反条例吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸？……為什麼？那不是違反條例嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00131",
		linknext = "0092_00133",
		line = 1739,
	},
	["0092_00133"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn straight. We're the Anti-Copulation Front—abolishing the law is what we've been working towards.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那还用说吗？我们是反交尾势力——为了摧毁条例而行动的组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那還用說嗎？我們是反交尾勢力——為了摧毀條例而行動的組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00132",
		linknext = "0092_00134",
		line = 1751,
	},
	["0092_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes go as wide as dinner plates.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女部田睁大了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"女部田睜大了眼睛。",
					{"rt2"},
				},
			},
