	["0102_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You'd think abductions would be enough of a big deal that the authorities would be doing something about it...",
					{"rt2"},
				},
			},
