		linkback = "0102_00203",
		linknext = "0102_00205",
		line = 2956,
	},
	["0102_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course they'd be packing real heat if they were yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是黑社会，拿着手枪便不足为奇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是黑社會，拿著手槍便不足為奇。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00204",
		linknext = "0102_00206",
		line = 2966,
	},
	["0102_00206"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think Hotori was assaulted by some suspicious-looking characters not far from that place too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这么说来，畔曾经在那附近被奇怪的家伙袭击过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這麼說來，畔曾經在那附近被奇怪的傢伙襲擊過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00205",
		linknext = "0102_00207",
		line = 2978,
	},
	["0102_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The ones who said they were filming uncensored porn and putting it on the dark web.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些家伙说要拍摄无修正AV，并贩卖出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些傢伙說要拍攝無修正AV，並販賣出去。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00206",
		linknext = "0102_00208",
		line = 2988,
	},
	["0102_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not exactly obscure knowledge that the yakuza would be pulling the strings of a business operation like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我经常会听到有人说黑社会会从这些东西当中获取收益——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我經常會聽到有人說黑社會會從這些東西當中獲取收益——",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00207",
		linknext = "0102_00209",
		line = 2998,
	},
	["0102_00209"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that means there's an organization apart from the OSS on this island taking hold?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……也就是说这个岛上，有个和SHO不同的大组织盘踞在此吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……也就是說這個島上，有個和SHO不同的大組織盤踞在此嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00208",
		linknext = "0102_00210",
		line = 3010,
	},
	["0102_00210"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes flicker ever so slightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"少女微微晃动着视线。",
