		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2089", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Man, I sure am glad we got through that Shootdown King event fine! Everybody made it through without much hassle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊〜‘击坠王’活动平安结束真是太好了。大家都没有受伤，一切平安。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊〜『擊墜王』活動平安結束真是太好了。大家都沒有受傷，一切平安。」",
					{"rt2"},
				},
			},
		},
		linknext = "0102_00002",
		line = 24,
	},
	["0102_00002"] = {
