		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She quietly sits down and wipes my cheek with a wet towel.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她静静地坐下来，把湿手巾贴在我的脸颊上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她靜靜地坐下來，把濕手巾貼在我的臉頰上。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00189",
		linknext = "0102_00191",
		line = 2782,
	},
	["0102_00191"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks... I can taste blood. Must have a cut in my mouth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起……里面好像割伤了，有血的味道……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起……裡面好像割傷了，有血的味道……」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00190",
		linknext = "0102_00192",
		line = 2794,
	},
	["0102_00192"] = {
		{"fg", file="fumino_02l_00001", file1="fumino_02l_00113", path=":fg/fumino_02l/", id=7, lv=5, head="fumino_02l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
