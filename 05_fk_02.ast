		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2091", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, best that we don't dwell on it, since it's over. Now we can get around to fulfilling our sponsor's demand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“算了，结束的事先放一边……现在应该回应出资者的要求了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「算了，結束的事先放一邊……現在應該回應出資者的要求了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00016",
		linknext = "0102_00018",
		line = 236,
	},
	["0102_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase shrugs her little comment off as inconsequential. Probably for the best.",
					{"rt2"},
				},
			},
			cn = {
				{
					"粗暴地挥挥手结束了话题的奈奈濑帮了我大忙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"粗暴地揮揮手結束了話題的奈奈瀨幫了我大忙。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00017",
		linknext = "0102_00019",
		line = 246,
	},
	["0102_00019"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1941", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sponsor's demand... You mean that whole thing about finding a girl named Kotoyose Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“说到出资者的要求……我记得是要保护叫‘琴寄文乃’的少女对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「說到出資者的要求……我記得是要保護叫『琴寄文乃』的少女對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00018",
		linknext = "0102_00020",
		line = 260,
	},
	["0102_00020"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2092", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Right. If we can find her before anyone else, we'll apparently be able to crush the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对。如果能比任何人都先找到那个女孩的话——就可以毁掉这个岛的变态条例了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對。如果能比任何人都先找到那個女孩的話——就可以毀掉這個島的變態條例了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00019",
		linknext = "0102_00021",
		line = 274,
	},
	["0102_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's what our sponsor told us when we first came to this base.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的，第一次来到这个基地时，出资的老人是这么说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的，第一次來到這個基地時，出資的老人是這麼說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00020",
		linknext = "0102_00022",
		line = 284,
	},
	["0102_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Though, it honestly sounds bogus to me. I honestly doubt one highly developed law could be brought down by just one girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说实话，这确实令人难以置信。发展到如此地步的条例，很难想象一位少女能有什么影响。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說實話，這確實令人難以置信。發展到如此地步的條例，很難想像一個少女能有什麼影響。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00021",
		linknext = "0102_00023",
		line = 296,
	},
	["0102_00023"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But it's our only glimmer of hope, and we have to act on it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但现在只能抱着一线希望行动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但現在只能抱著一線希望行動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00022",
		linknext = "0102_00024",
		line = 314,
	},
	["0102_00024"] = {
		{"text"},
		text = {
