		linkback = "0102_00198",
		linknext = "0102_00200",
		line = 2889,
	},
	["0102_00200"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="fumino_02l_00001", file1="fumino_02l_00119", path=":fg/fumino_02l/", id=7, lv=5, head="fumino_02l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She flinches and looks as though she'd like to pull away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她像要逃避般的微微动了动身子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她像要逃避般的微微動了動身子。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00199",
		linknext = "0102_00201",
		line = 2903,
	},
	["0102_00201"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00110", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she doesn't, and closes her eyes in resignation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我还是不肯放弃，于是她看似死心了一般闭上了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我還是不肯放棄，於是她看似死心了一般閉上了眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00200",
		linknext = "0102_00202",
		line = 2915,
	},
	["0102_00202"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00113", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0372", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Those men... They were members of a large chivalrous organization, headquartered on the mainland.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“我觉得他们……是本体位处于本岛的、大型侠义团体。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「我覺得他們……是本體位處於本島的、大型俠義團體。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00201",
		linknext = "0102_00203",
		line = 2930,
	},
	["0102_00203"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Chivalrous... So you're saying they're yakuza.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“侠义——是指黑社会吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「俠義——是指黑社會嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00202",
		linknext = "0102_00204",
		line = 2942,
	},
	["0102_00204"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She pulls her hand away.",
					{"rt2"},
				},
