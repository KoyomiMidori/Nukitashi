					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When Wata was almost abducted, their actions were pretty sloppy, considering it was a calculated assault.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱差点被诱拐的时候，虽然是计划好的犯罪行为，但袭击的人自己却不怎么熟练。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬差點被誘拐的時候，雖然是計劃好的犯罪行為，但襲擊的人自己卻不怎麼熟練。",
					{"rt2"},
