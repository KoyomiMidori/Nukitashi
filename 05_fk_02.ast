	},
	["0102_00230"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0375", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“The abducted girls usually return... but there are a number of cases where they haven't...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“被掳走的男女、基本上都会回来……但也有几个、没有回来的例子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「被擄走的男女、基本上都會回來……但也有幾個、沒有回來的例子……」",
					{"rt2"},
				},
			},
