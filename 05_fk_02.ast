	["0102_00222"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If she doesn't want to say, she could have just dodged the question, but she doesn't.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不想说的话糊弄过去就可以了，但她却没有。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不想說的話糊弄過去就可以了，但她卻沒有。",
					{"rt2"},
