	},
	["0102_00003"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00110", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1561", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“There were some teething problems, but overall I'd say it was a success... Plus Nanase managed to score a brilliant title for herself hee hee hee.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然发生了很多问题，但是姑且算是成功了吧……而且奈奈濑同学还光荣地获得了击坠王的称号嘿嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然發生了很多問題，但是姑且算是成功了吧……而且奈奈瀨同學還光榮地獲得了擊墜王的稱號嘿嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00002",
		linknext = "0102_00004",
		line = 47,
	},
	["0102_00004"] = {
