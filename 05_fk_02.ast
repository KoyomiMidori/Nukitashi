	},
	["0102_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She didn't say anything, but I take that as acknowledgement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然她什么都没说，但我觉得可以将那个动作认定为肯定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然她什麼都沒說，但我覺得可以將那個動作認定為肯定。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00210",
		linknext = "0102_00212",
		line = 3033,
	},
	["0102_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, even though she appears perturbed, she doesn't move to say anything, just sitting there silently.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过即使感到动摇，她也没有打算用言语掩饰，只是保持着沉默。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過即使感到動搖，她也沒有打算用言語掩飾，只是保持著沉默。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00211",
		linknext = "0102_00213",
		line = 3043,
	},
	["0102_00213"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But they didn't have a reason to be chasing you, did they?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……但是，那些人没有理由追你吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……但是，那些人沒有理由追你吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00212",
		linknext = "0102_00214",
		line = 3055,
	},
	["0102_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Let alone with guns drawn.",
