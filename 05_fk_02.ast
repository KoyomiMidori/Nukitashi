	["0102_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe I should wake up Asa and ask her for directions?",
					{"rt2"},
				},
			},
			cn = {
				{
					"把麻沙酱叫起来，让她引导我过去吧？",
