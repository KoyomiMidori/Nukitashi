		{"se", id=1, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a035"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asane, come in! Do you copy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——喂麻沙音，听得到吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——喂麻沙音，聽得到嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00090",
		linknext = "0102_00092",
		line = 1180,
	},
	["0102_00092"] = {
		{"fg", file="asane_01f_00007", file1="asane_01f_00116", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1564", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yes, I copy that floppy. Whaddaya want, Bro? I'm trying to get some sleep, and here you woke me up. OK, so I was making a comprehensive list of 3D animated pornos, but that doesn't have anything to—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喂我是麻沙酱。干嘛啊哥哥，麻沙酱可是好好在睡觉哦。这可是哥哥喊我起来的哦，所以就算3DCG色情动画的名单做好了也不是妹妹的错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喂我是麻沙醬。幹嘛啊哥哥，麻沙醬可是好好在睡覺哦。這可是哥哥喊我起來的哦，所以就算3DCG色情動畫的名單做好了也不是妹妹的錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00091",
		linknext = "0102_00093",
		line = 1193,
	},
	["0102_00093"] = {
		{"se", id=0, loop=0, file="se_b045"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Never mind that, just glad to hear you're awake. We got a disturbance in area A10.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那都无所谓，你还醒着真是太好了。发生了骚动，区域是R10地点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那都無所謂，你還醒著真是太好了。發生了騷動，區域是R10地點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00092",
		linknext = "0102_00094",
		line = 1206,
	},
	["0102_00094"] = {
		{"fg", file="asane_01f_00007", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1565", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Acknowledged. System activation complete, Communications coming in loud and clear. Ready on your mark.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“——了解。系统启动完成。通讯灵敏度良好。请随时开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「——了解。系統啟動完成。通訊靈敏度良好。請隨時開始。」",
					{"rt2"},
				},
			},
		},
