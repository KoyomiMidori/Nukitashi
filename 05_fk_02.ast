					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, right... My sense of direction sucks, that's why.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……对了，我是个路痴啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……對了，我是個路痴啊……」",
