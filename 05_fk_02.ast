		linkback = "0102_00215",
		linknext = "0102_00217",
		line = 3087,
	},
	["0102_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If that's the case, then why on earth did she expose herself to such grave risk to do that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话，这个女孩不顾自身安危做这种事情的理由到底是……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話，這個女孩不顧自身安危做這種事情的理由到底是……？",
					{"rt2"},
				},
