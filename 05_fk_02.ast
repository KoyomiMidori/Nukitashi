		line = 2835,
	},
	["0102_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then I ask her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从我则从上面按住，向她问道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從我則從上面按住，向她問道。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00194",
		linknext = "0102_00196",
		line = 2845,
	},
	["0102_00196"] = {
		{"bgm", file="bgm22", vol=100},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who the hell were those people?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那些家伙到底是什么人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那些傢伙到底是什麼人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00195",
		linknext = "0102_00197",
		line = 2857,
	},
	["0102_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They were clearly some kind of ruffians.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那怎么看都不像一般人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那怎麼看都不像一般人。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00196",
		linknext = "0102_00198",
		line = 2867,
	},
	["0102_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they were carrying real guns, clearly they're a much more lowdown bunch than the OSS or SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为拿着真枪，所以大概比SHO和FS还要恶劣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為拿著真槍，所以大概比SHO和FS還要惡劣。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00197",
		linknext = "0102_00199",
		line = 2877,
	},
	["0102_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you know who they are?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你……知道那些男人的真实身份吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你……知道那些男人的真實身份嗎？」",
					{"rt2"},
				},
