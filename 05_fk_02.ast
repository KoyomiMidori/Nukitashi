		linkback = "0102_00226",
		linknext = "0102_00228",
		line = 3218,
	},
	["0102_00228"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0374", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“There are incidents of boys and girls going missing... quite often... in this area... in the hillside near the settlement...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“……这一带……村落附近的山之手……少年少女的失踪事件……经常发生……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「……這一帶……村落附近的山之手……少年少女的失踪事件……經常發生……」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00227",
		linknext = "0102_00229",
		line = 3232,
	},
	["0102_00229"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did you say...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你說什麼？」",
					{"rt2"},
