					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Do not speak. Conserve your energy for recovery...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“请先静养……好好、让身体恢复……”",
					{"rt2"},
				},
			},
			tw = {
