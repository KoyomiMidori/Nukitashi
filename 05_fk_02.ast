		linkback = "0102_00223",
		linknext = "0102_00225",
		line = 3182,
	},
	["0102_00225"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I won't breathe a word to anyone. Cross my heart. So could you tell me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我答应你不会说出去。所以，能告诉我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我答應你不會說出去。所以，能告訴我嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00224",
		linknext = "0102_00226",
		line = 3194,
	},
	["0102_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
