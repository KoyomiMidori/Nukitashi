	["0102_00142"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0138", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "ヤクザA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Yakuza A"},
					"“Owww... Christ, those OSS weapons do a number on yer 'ead. But we finally caught 'er. That little bitch's been nothin' but a stumblin' block in our way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "黑社会A"},
					"“疼疼疼……操，SHO的武器对脑袋很有效果啊……但是终于抓到你了。你这总是来打扰我们的混蛋死小鬼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "黑社會A"},
					"「痛痛痛……操，SHO的武器對腦袋很有效果啊……但是終於抓到你了。你這總是來打擾我們的混蛋死小鬼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00141",
		linknext = "0102_00143",
		line = 1992,
	},
	["0102_00143"] = {
		{"se", id=0, loop=0, file="se_a035"},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0123", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "ヤクザB"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Yakuza B"},
					"“Sir! What do we do with her? They won't know a thing if we ice her and bury her right here...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "黑社会B"},
					"“大哥！该怎么做？我觉得先分尸后埋起来应该不会暴露……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "黑社會B"},
					"「大哥！該怎麼做？我覺得先分屍後埋起來應該不會暴露……」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00142",
		linknext = "0102_00144",
		line = 2005,
	},
	["0102_00144"] = {
