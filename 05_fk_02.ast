		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I put my hand on hers, as she holds a cold cloth to my cheek.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她拿着冰冷的布，帮我压在微微肿胀的脸颊上。",
					{"rt2"},
				},
			},
			tw = {
