			},
		},
		text = {
			vo = {
				{"vo", file="bmobd0139", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "ヤクザA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Yakuza A"},
					"“I say we let the boss decide... Huh, fer such a li'l shit, she looks awful grown-up. Maybe I oughta see if she's grown-up down there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "黑社会A"},
					"“虽然决定的人是代理老大……哎，明明只是个小鬼，却一副大人的样子。要不要确认一下那里是不是也是大人啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "黑社會A"},
					"「雖然決定的人是代理老大……哎，明明只是個小鬼，卻一副大人的樣子。要不要確認一下那裡是不是也是大人啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00143",
		linknext = "0102_00145",
		line = 2022,
	},
	["0102_00145"] = {
