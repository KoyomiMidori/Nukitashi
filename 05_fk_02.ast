		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the NLNS gather at the base the following week after school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"隔周下课后，NLNS的成员来到秘密基地。",
