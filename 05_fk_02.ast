	["0102_00224"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“After all this, I don't think you can view me as an outsider anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……都到了这个地步，我也不是局外人了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……都到了這個地步，我也不是局外人了。」",
					{"rt2"},
				},
