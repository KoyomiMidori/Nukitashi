		},
		linkback = "0102_00076",
		linknext = "0102_00078",
		line = 1016,
	},
	["0102_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm puzzled when I find myself at a place in the mountains that I didn't plan to visit, nor do I have any recollection of.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我歪着头，这里是既没有预计要来也没有来过的山中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我歪著頭，這裡是既沒有預計要來也沒有來過的山中。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00077",
		linknext = "0102_00079",
		line = 1026,
	},
	["0102_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's weird. I planned to take a detour and approach the Mutable Membrane from the residential district.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奇怪，我本来是打算绕个大圈子，从住宅区那边去一时的皮膜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奇怪，我本來是打算繞個大圈子，從住宅區那邊去一時的皮膜。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00078",
		linknext = "0102_00080",
		line = 1036,
	},
	["0102_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So why am I in the middle of treesville now?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但现在为什么会这样被树木包围呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但現在為什麼會這樣被樹木包圍呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00079",
		linknext = "0102_00081",
		line = 1046,
	},
	["0102_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
