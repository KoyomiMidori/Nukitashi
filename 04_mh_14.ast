		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1411", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I see, so even the SS are in on it... We've really got our work cut out for us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是吗，连FS都……那还真是困扰呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是嗎，連FS都……那還真是困擾呢。」",
