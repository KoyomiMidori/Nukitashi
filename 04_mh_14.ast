		line = 2680,
	},
	["0091_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those black emotions within me dissipate like mist in the breeze.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一直笼罩在胸口的黑色情感像雾一样消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一直籠罩在胸口的黑色情感像霧一樣消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00215",
		linknext = "0091_00217",
		line = 2690,
	},
	["0091_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Surely her tears are in lieu of the ones I couldn't cry myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些泪，可能是我那一天没能流下的眼泪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些淚，可能是我那一天沒能流下的眼淚。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00216",
		linknext = "0091_00218",
		line = 2700,
	},
	["0091_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was so deep in despair, wallowing in misery and hatred for this island, that I'd practically forgotten to cry.",
					{"rt2"},
				},
			},
			cn = {
				{
					"绝望，自闭，对岛上充满了憎恨——让我连哭都忘了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"絕望，自閉，對島上充滿了憎恨——讓我連哭都忘了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00217",
		linknext = "0091_00219",
		line = 2710,
	},
	["0091_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels like Misaki is weeping on my behalf.",
					{"rt2"},
				},
			},
			cn = {
				{
					"美岬似乎代替了那时的我，在哭泣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"美岬似乎代替了那時的我，在哭泣。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00218",
		linknext = "0091_00220",
		line = 2720,
	},
	["0091_00220"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1425", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sorry... I said I'd hear you out, and here I am bawling over spilled milk...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对不起……呜呜……我明明说要听你讲……结果却在哭……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對不起……嗚嗚……我明明說要聽你講……結果卻在哭……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00219",
		linknext = "0091_00221",
		line = 2732,
	},
	["0091_00221"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's fine... Thanks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没关系的——谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒關係的——謝謝。」",
