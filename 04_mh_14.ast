		{"text"},
		delay = {
			[2000] = {
				{"fg", file="misaki_01ll_00001", file1="misaki_01ll_00113", file2="misaki_01ll_00205", path=":fg/misaki_01ll/", id=6, lv=5, head="misaki_01ll", ch="美岬", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1434", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Talk about jumping the gun! Augh... Sorry. I just wanted to do it so badly... Aaagh, what have I done?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“大幅超前了诶！？啊呜……对不起。因为我就是很想这样……啊啊啊，又搞砸了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「大幅超前了欸！？啊嗚……對不起。因為我就是很想這樣……啊啊啊，又搞砸了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00266",
		linknext = "0091_00268",
		line = 3323,
	},
	["0091_00268"] = {
		{"fg", file="misaki_01ll_00001", file1="misaki_01ll_00106", file2="misaki_01ll_00205", path=":fg/misaki_01ll/", id=6, lv=5, head="misaki_01ll", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1435", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You don't think I'm a dirty girl, do you? I mean, I totally am, no argument there, but I really don't want you to think of me that way...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你会认为我是个不检点的女人吗……？不，实际上也许不检点，但即使没有，我也不想被淳之介君觉得是不检点的女人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你會認為我是個不檢點的女人嗎……？不，實際上也許不檢點，但即使沒有，我也不想被淳之介君覺得是不檢點的女人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00267",
		linknext = "0091_00269",
		line = 3337,
	},
	["0091_00269"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't think that, so don't worry. Perhaps I couldn't restrain myself either...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我没有那么觉得，所以你放心……我自己大概也受不了了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我沒有那麼覺得，所以你放心……我自己大概也受不了了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00268",
		linknext = "0091_00270",
		line = 3349,
	},
	["0091_00270"] = {
		{"fg", file="misaki_01ll_00001", file2="misaki_01ll_00203", file3="misaki_01ll_00308", path=":fg/misaki_01ll/", id=6, lv=5, head="misaki_01ll", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1436", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That's good, then. Hearing that makes me kinda happy slash embarrassed, teehee...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那就好……听你这么一说，我觉得又高兴又不好意思，诶嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那就好……聽你這麼一說，我覺得又高興又不好意思，欸嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00269",
		linknext = "0091_00271",
		line = 3363,
	},
	["0091_00271"] = {
		{"fg", file="misaki_01ll_00001", file2="misaki_01ll_00203", file3="misaki_01ll_00307", path=":fg/misaki_01ll/", id=6, lv=5, head="misaki_01ll", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1437", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But to think you planned for nine months and we did it in three days... It feels like we're barreling through things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“可是，9个月的预定竟然变成了3天……我们车也开得蛮快的呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「可是，9個月的預定竟然變成了3天……我們車也開得蠻快的呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00270",
