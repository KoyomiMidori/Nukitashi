	["0091_00472"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even I don't understand how things ended up like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我自己也不知道现在是什么情况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我自己也不知道現在是什麼情況。",
					{"rt2"},
