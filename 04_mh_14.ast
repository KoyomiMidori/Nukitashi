	["0091_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The law condones intercourse, and everyone openly welcomes it as much as they can, so I definitely can't forgive the islanders for that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要鼓励性行为的条例还存在，而且大家也继续欢迎它，我就绝对没办法打从心底原谅岛民。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要鼓勵性行為的條例還存在，而且大家也繼續歡迎它，我就絕對沒辦法打從心底原諒島民。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00237",
