			},
		},
		text = {
			vo = {
				{"vo", file="misaki1405", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ooh, Oo'noh'he' hee'! Gulp, ehehe, Junnosuke's here! Hee hee hee...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呼啊！哼嘿哼！呜咕……咕噜。诶嘿嘿……是淳之介君啊……诶嘿嘿嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呼啊！哼嘿哼！嗚咕……咕嚕。欸嘿嘿……是淳之介君啊……欸嘿嘿嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00021",
		linknext = "0091_00023",
		line = 305,
	},
	["0091_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
