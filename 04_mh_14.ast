		linkback = "0091_00209",
		linknext = "0091_00211",
		line = 2622,
	},
	["0091_00211"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki? Why are you crying?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“美岬……？你为什么在哭？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「美岬……？你為什麼在哭？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00210",
		linknext = "0091_00212",
		line = 2634,
	},
	["0091_00212"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1423", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, it's just so horrible! You were teased, and suffered so much, and then when someone finally came along to help you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为……那不是太过分了吗……！淳之介君、被人欺负、受尽了苦头，然后明明终于得救了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為……那不是太過分了嗎……！淳之介君、被人欺負、受盡了苦頭，然後明明終於得救了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00211",
		linknext = "0091_00213",
		line = 2646,
	},
	["0091_00213"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1424", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“She was torn away from you by death... That's so sad!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“结果却和她死别了……这种事，怎么可以……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「結果卻和她死別了……這種事，怎麼可以……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00212",
		linknext = "0091_00214",
		line = 2658,
	},
	["0091_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She sobs uncontrollably, tears running down her cheeks, as though it's her own problem.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她呜咽不止，就像在诉说自己的事情一样不断涌出眼泪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她嗚咽不止，就像在訴說自己的事情一樣不斷湧出眼淚。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00213",
		linknext = "0091_00215",
		line = 2668,
	},
	["0091_00215"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
