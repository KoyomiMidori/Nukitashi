	["0091_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wanted to wait nine months for this. And yet it took us just three days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然想等9个月后再接吻，但没想到第3天就亲上去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然想等9個月後再接吻，但沒想到第3天就親上去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00272",
		linknext = "0091_00274",
		line = 3399,
	},
	["0091_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thinking about it, Misaki and I have probably had nine months' worth of love in the last three days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反过来说——我和美岬只在3天的时间里就恋爱了9个月的程度吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反過來說——我和美岬只在3天的時間裡就戀愛了9個月的程度吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00273",
