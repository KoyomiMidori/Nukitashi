	["0091_00149"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1416", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, sorry for acting the role of the dating girlfriend! Was I too annoying?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……才刚交往就摆出女朋友的架子真是抱歉！你会觉得我很烦吗……？”",
