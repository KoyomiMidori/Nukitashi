		line = 5939,
	},
	["0091_00473"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I brought Onabuta into my house, nursed her, let her use our bath, and now she's in my living room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把那个女部田带到家里，照顾她，让她洗澡，现在还一起在客厅。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把那個女部田帶到家裡，照顧她，讓她洗澡，現在還一起在客廳。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00472",
		linknext = "0091_00474",
		line = 5949,
	},
	["0091_00474"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If this were any other situation, I wouldn't even let her get her foot in the door.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是平常的女部田，我应该连跨过门槛都不会允许吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是平常的女部田，我應該連跨過門檻都不會允許吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00473",
		linknext = "0091_00475",
		line = 5959,
	},
	["0091_00475"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But having seen her in such a deplorable state, there was no way I could just leave her there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但看着完全失去霸气，软绵绵的她，我怎么也无法放着她不管。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但看著完全失去霸氣，軟綿綿的她，我怎麼也無法放著她不管。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00474",
		linknext = "0091_00476",
		line = 5969,
	},
	["0091_00476"] = {
		{"fg", file="asane_02l_00002", file1="asane_02l_00111", file2="asane_02l_00204", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1474", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bro, what do I do? Onabuta is actually here, but I have nothing to talk to her about... She's gonna hate me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥，怎么办……好不容易女部田前辈能大驾光临却没有话题可以聊……要被讨厌了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥，怎麼辦……好不容易女部田前輩能大駕光臨卻沒有話題可以聊……要被討厭了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00475",
		linknext = "0091_00477",
		line = 5983,
	},
	["0091_00477"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see your autism and sexual frustration have really caught up with you tonight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这精神病处男的精神面也太脆弱了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你這精神病處男的精神面也太脆弱了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00476",
		linknext = "0091_00478",
		line = 5995,
	},
	["0091_00478"] = {
		{"fg", file="asane_02l_00002", file1="asane_02l_00112", file2="asane_02l_00204", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1475", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I know... We should liven things up by watching anime together! I learned that from the eroges you let me borrow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对了……这种时候只要一起看动画片就会情绪高涨了我从哥哥那里借来的色情游戏中学到过……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對了……這種時候只要一起看動畫片就會情緒高漲了我從哥哥那裡借來的色情遊戲中學到過……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00477",
		linknext = "0091_00479",
		line = 6009,
	},
	["0091_00479"] = {
