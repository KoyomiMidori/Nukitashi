	["0091_00527"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0397", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You haven't asked about what happened to me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……你不问发生了什么吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……你不問發生了什麼嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00526",
		linknext = "0091_00528",
		line = 6724,
	},
	["0091_00528"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I do, it might end up getting me mixed up in something I'm not ready for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为问了可能会被卷入麻烦的事情里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為問了可能會被捲入麻煩的事情裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00527",
		linknext = "0091_00529",
		line = 6735,
	},
	["0091_00529"] = {
		{"fg", file="ikuko_01l_00003", file1="ikuko_01l_00129", path=":fg/ikuko_01l/", id=10, lv=5, head="ikuko_01l", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0398", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I see... You're too kind, Darling...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这样啊……亲爱的真温柔呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這樣啊……親愛的真溫柔呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00528",
		linknext = "0091_00530",
		line = 6749,
	},
	["0091_00530"] = {
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's the last thing she says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之后，女部田就什么都没说了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之後，女部田就什麼都沒說了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00529",
		linknext = "0091_00531",
		line = 6761,
	},
	["0091_00531"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A long time ago, back when I was bullied...",
					{"rt2"},
				},
			},
			cn = {
				{
					"很久以前——我被欺负的时候，",
					{"rt2"},
				},
			},
			tw = {
				{
					"很久以前——我被欺負的時候，",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00530",
		linknext = "0091_00532",
		line = 6771,
	},
	["0091_00532"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was overjoyed to have someone lend me a hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有人对我伸出援手让我非常高兴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有人對我伸出援手讓我非常高興。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00531",
		linknext = "0091_00533",
		line = 6781,
	},
	["0091_00533"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I saw her being assailed by the rain, I saw myself in her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我将被雨淋着的女部田的身影，与那时候的自己重叠了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我將被雨淋著的女部田的身影，與那時候的自己重疊了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00532",
		linknext = "0091_00534",
		line = 6791,
	},
	["0091_00534"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I made a conscious decision to help her. That's all there is to it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以才伸出了手——就只是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以才伸出了手——就只是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00533",
		linknext = "0091_00535",
		line = 6801,
	},
	["0091_00535"] = {
		{"fg", file="ikuko_01f_00003", file1="ikuko_01f_00108", file2="ikuko_01f_00204", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0399", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“No... Please, don't...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……唔……啊……呜呜……大家……不要啊……呜呜……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……唔……啊……嗚嗚……大家……不要啊……嗚嗚……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00534",
		linknext = "0091_00536",
		line = 6814,
	},
	["0091_00536"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
