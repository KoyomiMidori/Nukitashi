	["0091_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even now when I think of the past, those emotions well up inside me. I indiscriminately despise those fucks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使是现在，只要想起以前的事，这种感情就会喷发。我还是讨厌那些不在乎地方随意做爱的人们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使是現在，只要想起以前的事，這種感情就會噴發。我還是討厭那些不在乎地方隨意做愛的人們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00230",
		linknext = "0091_00232",
		line = 2861,
	},
	["0091_00232"] = {
