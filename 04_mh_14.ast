	},
	["0091_00198"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00108", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And the moment I heard that, I thought to myself... This is all that goddamn law's fault.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“听到那些话时，我有了这样的想法。错的，是这个条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「聽到那些話時，我有了這樣的想法。錯的，是這個條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00197",
		linknext = "0091_00199",
		line = 2484,
	},
	["0091_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If it weren't for that, she wouldn't have died.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果没有这种条例，那她就不会死了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果沒有這種條例，那她就不會死了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00198",
		linknext = "0091_00200",
		line = 2495,
	},
	["0091_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If it weren't for that, an illegal sex industry couldn't operate on the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果没有这种条例，岛上也就不会有地下风俗了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果沒有這種條例，島上也就不會有地下風俗了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00199",
		linknext = "0091_00201",
		line = 2506,
	},
	["0091_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She wouldn't have gone down that road.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她也会有其他的路可以走，一定是这样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她也會有其他的路可以走，一定是這樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00200",
		linknext = "0091_00202",
		line = 2517,
	},
	["0091_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, this island allowing such a thing to be morally acceptable... I refuse to forgive it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以……我不能容许把整个岛变成风俗产业的条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以……我不能容許把整個島變成風俗產業的條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00201",
		linknext = "0091_00203",
		line = 2528,
	},
	["0091_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I've started, nothing can stop me letting loose.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知不觉中，自己也阻止不了自己的嘴巴了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知不覺中，自己也阻止不了自己的嘴巴了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00202",
		linknext = "0091_00204",
		line = 2538,
	},
	["0091_00204"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I despised the people who accepted that law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我讨厌那些认同这个条例的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我討厭那些認同這個條例的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00203",
		linknext = "0091_00205",
		line = 2550,
	},
	["0091_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Those churls who tormented her into a grave, all the while coveting sex themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我讨厌那些一边逼着她去死，还一边贪求性爱的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我討厭那些一邊逼著她去死，還一邊貪求性愛的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00204",
		linknext = "0091_00206",
		line = 2561,
	},
	["0091_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even after I left the island, that feeling persisted indefinitely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使离开过一次岛，这个念头也一直燃烧着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使離開過一次島，這個念頭也一直燃燒著。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00205",
		linknext = "0091_00207",
		line = 2572,
	},
	["0091_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So when I returned here, and I stumbled into that base, I decided what I wanted to do. I want to fucking destroy that law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，当我回到岛上，并找到那个基地时——我就决定一定要毁掉这个条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，當我回到島上，並找到那個基地時——我就決定一定要毀掉這個條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00206",
		linknext = "0091_00208",
		line = 2583,
	},
	["0091_00208"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is where it all began. This island... it's always done nothing but—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一切都是从那个时候开始的。我，一直一直对这个岛——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一切都是從那個時候開始的。我，一直一直對這個島——」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00207",
		linknext = "0091_00209",
		line = 2595,
	},
	["0091_00209"] = {
		{"cgdel", id=2, lv=5, time=300, alphadel=1},
		{"bg", id=1, file="bg10_2_00000", x=0, y=0, path=":bg/", sync=0, time=1, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00108", file2="misaki_02m_00201", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
