				{"vo", file="misaki1433", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh... is that so? But, like, we've only been going out for three days... I didn't push it, did I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊、哈啊……这样啊。但是但是，才刚开始交往3天……没问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊、哈啊……這樣啊。但是但是，才剛開始交往3天……沒問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00264",
		linknext = "0091_00266",
		line = 3296,
	},
	["0091_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ideally, it should have been about nine months...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的理想是9个月左右……”",
					{"rt2"},
