		line = 1740,
	},
	["0091_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Caving to the hivemind opinion yet again... I swear, this island is full of nothing but fucking rubes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“又输给了同调压力……所以我才说这群岛上的人……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「又輸給了同調壓力……所以我才說這群島上的人……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00134",
