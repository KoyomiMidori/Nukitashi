	["0091_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So right now, when it comes to the islanders... I don't really know what I think. Will that answer do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我心里是怎么想岛上的人……现在，连我自己都还不知道……这样的回答也行吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我心裡是怎麼想島上的人……現在，連我自己都還不知道……這樣的回答也行嗎？」",
					{"rt2"},
				},
			},
		},
