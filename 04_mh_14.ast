					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Junnosuke... Am I weird? Did I do something wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“淳之介君……我很奇怪吗……是不是有哪里弄错了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「淳之介君……我很奇怪嗎……是不是有哪裡弄錯了呢……」",
