		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The people have already accepted the perverted sex law, and now they plan to accept this bullshit too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“接受了变态条例，这次连这样胡来的条例也要接受吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「接受了變態條例，這次連這樣胡來的條例也要接受嗎——」",
