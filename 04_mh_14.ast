					{"rt2"},
				},
			},
			en = {
				{
					"But I said we'd wait one year before we... y'know. So how's that going to work?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，第一次的……虽然之前说了要等一年之类的话，但是这样下去会怎么样呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，第一次的……雖然之前說了要等一年之類的話，但是這樣下去會怎麼樣呢？",
					{"rt2"},
				},
