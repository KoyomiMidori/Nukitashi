	["0091_00350"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0370", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I dunno... But in a way, maybe I did... I had a feeling everyone was acting weird... But maybe I'm the weird one...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我也不知道……不过，说不定是那样没错……我还以为是大家都变奇怪了……原来是我变奇怪了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我也不知道……不過，說不定是那樣沒錯……我還以為是大家都變奇怪了……原來是我變奇怪了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00349",
		linknext = "0091_00351",
		line = 4325,
	},
	["0091_00351"] = {
		{"text"},
		text = {
