		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If anything, she was happy to know that I went out of my way to help Onabuta, considering I told her about how I despised the islanders.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她笑着说憎恨岛的我会向女部田伸出援手，令她很高兴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她笑著說憎恨島的我會向女部田伸出援手，令她很高興。",
					{"rt2"},
				},
			},
