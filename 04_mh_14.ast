		linkback = "0091_00027",
		linknext = "0091_00029",
		line = 375,
	},
	["0091_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't let my relationship get in the way of things.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不能一味地沉浸在情爱当中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不能一味地沉浸在情愛當中。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00028",
		linknext = "0091_00030",
		line = 385,
	},
	["0091_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm still the leader of the NLNS. I gotta act like it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在这里依然是NLNS的队长，必须转换心态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在這裡依然是NLNS的隊長，必須轉換心態。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00029",
		linknext = "0091_00031",
		line = 395,
	},
	["0091_00031"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's assess the situation first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先，先整理情况吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先，先整理情況吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00030",
		linknext = "0091_00032",
		line = 411,
	},
	["0091_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So yesterday, Hitoura announced the new perverted sex law. It's pretty obvious that the yakuza are pulling the strings here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“前几天仁浦先生发表了新・变态条例——但这一定是有黑社会的人在幕后操纵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「前幾天仁浦先生髮表了新・變態條例——但這一定是有黑社會的人在幕後操縱。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00031",
		linknext = "0091_00033",
		line = 422,
	},
	["0091_00033"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2043", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The timing would definitely suggest that. They used Fumino to force him into holding that press conference.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“时机也对得上呢。只要使用文乃威胁仁浦先生，让他举办昨天的记者会……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「時機也對得上呢。只要使用文乃威脅仁浦先生，讓他舉辦昨天的記者會……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00032",
		linknext = "0091_00034",
		line = 434,
	},
	["0091_00034"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00105", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1463", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“And not only that, but placing a price on perverted sex acts... If they're just aiming to make money, isn't this method a little too obvious? Even the islanders seem skeptical about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“就算是那样，变态做爱收费制计划什么的……赚钱的方法也太露骨了吧……？好像连岛民都抱有疑问……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「就算是那樣，變態做愛收費制計劃什麼的……賺錢的方法也太露骨了吧……？好像連島民都抱有疑問……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00033",
		linknext = "0091_00035",
		line = 447,
	},
	["0091_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Surely the yakuza couldn't care less about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对黑社会的人们来说，结果不管倒向哪边他们都没关系吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對黑社會的人們來說，結果不管倒向哪邊他們都沒關係吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00034",
		linknext = "0091_00036",
		line = 459,
	},
	["0091_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If this works out and they can turn a profit from this, they'll be happy just to sit back lining their coffers. If the law gets abolished due to backlash, they can just get back to the mainland and revive their sex industry there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要成功赚到钱就行了，而如果因为被反对而废除了条例，那么本岛的风俗产业就可以复活……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要成功賺到錢就行了，而如果因為被反對而廢除了條例，那麼本島的風俗產業就可以復活……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00035",
		linknext = "0091_00037",
		line = 470,
	},
	["0091_00037"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00116", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1464", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So they don't see Seiran Island as anything other than a tool for turning a profit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“他们只把青蓝岛当成赚钱的工具呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「他們只把青藍島當成賺錢的工具呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00036",
		linknext = "0091_00038",
		line = 483,
	},
	["0091_00038"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2046", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But Governor Hitoura announced the new law to protect everyone. He said the reason the public order has been worsening of late is because they allow everything free of charge.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是，仁浦先生说了是为了保护大家的新条例哦？他说最近青蓝岛治安恶化的原因就是因为什么都是免费的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是，仁浦先生說了是為了保護大家的新條例哦？他說最近青藍島治安惡化的原因就是因為什麼都是免費的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00037",
		linknext = "0091_00039",
		line = 497,
	},
	["0091_00039"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2047", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I have heard some pretty bad things lately, and Misaki, you experienced a dangerous situation yourself, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“最近也确实都是一些不好的消息……美岬酱也遇到过危险对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「最近也確實都是一些不好的消息……美岬醬也遇到過危險對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00038",
		linknext = "0091_00040",
		line = 511,
	},
	["0091_00040"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3300] = {
				{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3300, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1406", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah. Some people tried to force themselves on me and film it, but Junnosuke valiantly appeared and saved me. Maybe that's when I first fell in love with him...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的，差点被强制拍摄……当时英姿飒爽的淳之介君及时出现拯救了我……回想起来，大概那个时候我就已经恋爱了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的，差點被強制拍攝……當時英姿颯爽的淳之介君及時出現拯救了我……回想起來，大概那個時候我就已經戀愛了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00039",
		linknext = "0091_00041",
		line = 527,
	},
	["0091_00041"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00103", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1465", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Who the fuck asked you bitch I'mma murder you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“谁问你那些事了宰了你哦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「誰問你那些事了宰了你哦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00040",
		linknext = "0091_00042",
		line = 540,
	},
	["0091_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's a bit of a strong reaction to someone who's clearly just talking to herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱对畔的自我揭露杀意太强了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬對畔的自我揭露殺意太強了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00041",
		linknext = "0091_00043",
		line = 550,
	},
	["0091_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So because it's free, we get a lot of riffraff and outlaws. If they start charging for it, they can create a controlled market, and make the islanders safer. That's definitely a plausible enough way to pitch it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为是免费的所以出现了不法者，因此改为收费制保护岛民的安全——这么说的确很正确。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為是免費的所以出現了不法者，因此改為收費制保護島民的安全——這麼說的確很正確。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00042",
		linknext = "0091_00044",
		line = 561,
	},
	["0091_00044"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But who was it that upset the public order on the island in the first place?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是——说到底，扰乱青蓝岛治安的是谁？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是——說到底，擾亂青藍島治安的是誰？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00043",
		linknext = "0091_00045",
		line = 573,
	},
	["0091_00045"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami2048", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Umm... the yakuza! Huh? So you're saying they came up with the solution to a problem they created in the first place?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃……啊，是黑社会的人！……诶？那他们是一边自己做着不好的事情，还一边说着自己在做好事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃……啊，是黑社會的人！……欸？那他們是一邊自己做著不好的事情，還一邊說著自己在做好事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00044",
		linknext = "0091_00046",
		line = 589,
	},
	["0091_00046"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1407", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That's like... cunny capitalism!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那……不是自摸自爽吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那……不是自摸自爽嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00045",
		linknext = "0091_00047",
		line = 603,
	},
	["0091_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You mean crony capitalism.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是自導自演。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是自導自演。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00046",
		linknext = "0091_00048",
		line = 614,
	},
	["0091_00048"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1408", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That's like crony capitalism!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不是自導自演吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不是自導自演嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00047",
		linknext = "0091_00049",
		line = 628,
	},
	["0091_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Precisely. This has probably been what they've been aiming to do for ages. So how could you take people like that at their word?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错。也许他们从一开始就想到了这一步。那种家伙所说的话能信吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯。也許他們從一開始就想到了這一步。那種傢伙所說的話能信嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00048",
		linknext = "0091_00050",
		line = 640,
	},
	["0091_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“First of all, thinking that charging for it is going to improve the public order is wrong in itself. That just gives them a pretext.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先，如果收费治安就会变好的想法本身就有问题。这种事，只是给对方制造借口而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先，如果收費治安就會變好的想法本身就有問題。這種事，只是給對方製造藉口而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00049",
		linknext = "0091_00051",
		line = 652,
	},
	["0091_00051"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2049", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pretext...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“借口……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「藉口……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00050",
		linknext = "0091_00052",
		line = 666,
	},
	["0091_00052"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The pretext of being able to put a price on anything, that is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我付钱了所以要做什么都可以——像这样的借口。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我付錢了所以要做什麼都可以——像這樣的藉口。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00051",
		linknext = "0091_00053",
		line = 678,
	},
	["0091_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everything relating to sex on the island just appears to be complete chaos, but there are certain rules associated with it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"乍看之下对性毫无秩序的青蓝岛，其实也有着各种规定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"乍看之下對性毫無秩序的青藍島，其實也有著各種規定。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00052",
		linknext = "0091_00054",
		line = 688,
	},
	["0091_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Namely, that sex has to be happy, fun and consensual. That's what they keep telling people in classrooms and on TV.",
					{"rt2"},
				},
			},
			cn = {
				{
					"例如做爱必须要幸福快乐才行什么的，我在课堂上或电视上听过好几次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"例如做愛必須要幸福快樂才行什麼的，我在課堂上或電視上聽過好幾次。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00053",
		linknext = "0091_00055",
		line = 698,
	},
	["0091_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The people of the island that seem to just care about debauchery have their own preferred kinks and physical attributes, and the current law pays deference to that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“乍看之下淫乱的岛民，也有自己喜欢的play和体位，现在的条例是非常尊重那部分的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「乍看之下淫亂的島民，也有自己喜歡的play和體位，現在的條例是非常尊重那部分的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00054",
		linknext = "0091_00056",
		line = 709,
	},
	["0091_00056"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But once the new law takes effect, a girl that prefers vaginal could be forced to take it in the back door if they pay for it. That kind of act that ignores the person's wishes could become rampant.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，如果适用新条例，就有可能发生这样的事情——付钱给只愿意用正常位的女孩，强迫她用后入位——会出现这种无视对方意愿的行为也说不定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，如果適用新條例，就有可能發生這樣的事情——付錢給只願意用正常位的女孩，強迫她用後入位——會出現這種無視對方意願的行為也說不定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00055",
		linknext = "0091_00057",
		line = 721,
	},
	["0091_00057"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1409", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Talk about cashbacks, huh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这就是真正的Cash back吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這就是真正的Cash back吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00056",
		linknext = "0091_00058",
		line = 735,
	},
	["0091_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So if you prefer the back door, and you try to pay in cash, you'd get your cash back?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果这么说的话，所有花钱进行后入位的人就都是Cash back了吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果這麼說的話，所有花錢進行後入位的人就都是Cash back了吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00057",
		linknext = "0091_00059",
		line = 745,
	},
	["0091_00059"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2044", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Governor Hitoura said that a portion of the money collected from sex would be taxed, and that would go back into maintenance of the public order. But that's a sham too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……仁浦先生说要把通过做爱赚来的钱的一部分作为税收，拿来维持治安……这也很可疑呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……仁浦先生說要把通過做愛賺來的錢的一部分作為稅收，拿來維持治安……這也很可疑呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00058",
		linknext = "0091_00060",
		line = 757,
	},
	["0091_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The yakuza hold all the actual power on this island right now. It's plain to see it's just another one of their rackets.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在掌握岛上实权的是黑社会，他们的资金来源是显而易见的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在掌握島上實權的是黑社會，他們的資金來源是顯而易見的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00059",
		linknext = "0091_00061",
		line = 768,
	},
	["0091_00061"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00116", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1466", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So this whole island... it's basically a way for them to make bank off the sex industry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“简单来说……他们就是想把整个青蓝岛都变成风俗产业来经营就对了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「簡單來說……他們就是想把整個青藍島都變成風俗產業來經營就對了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00060",
		linknext = "0091_00062",
		line = 781,
	},
	["0091_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm disgusted. Just thinking about it makes me seethe with anger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真是令人恶心的话题。光想，肠子就像要打结似的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真是令人噁心的話題。光想，腸子就像要打結似的。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00061",
		linknext = "0091_00063",
		line = 791,
	},
	["0091_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Up until now I'd already thought it was the worst possible law, but now that evil bunch is intervening, it's going to get even worse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本以为这已经是最糟糕的条例了，没想到现在黑社会居然又介入其中，让情况变得更糟了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本以為這已經是最糟糕的條例了，沒想到現在黑社會居然又介入其中，讓情況變得更糟了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00062",
		linknext = "0091_00064",
		line = 801,
	},
	["0091_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And a particular amount of my disgust is reserved for Toshihide Teshima.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最应该憎恨的——就是手嶋俊英。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最應該憎恨的——就是手嶋俊英。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00063",
		linknext = "0091_00065",
		line = 811,
	},
	["0091_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why the hell did I take him at his word?",
					{"rt2"},
				},
			},
			cn = {
				{
					"你以前到底是抱着什么样的想法和我说话的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"你以前到底是抱著什麼樣的想法和我說話的。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00064",
		linknext = "0091_00066",
		line = 821,
	},
	["0091_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Great genitalia breakthrough, he said. Nobel Prize in Onanism, he said.",
					{"rt2"},
				},
			},
			cn = {
				{
					"什么性世纪的大发现。什么诺贝尔看着撸奖？",
					{"rt2"},
				},
			},
			tw = {
				{
					"什麼性世紀的大發現。什麼諾貝爾看著擼獎？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00065",
		linknext = "0091_00067",
		line = 831,
	},
	["0091_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, fuck him. His lips are unfit to speak those words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“如果没有爱，就不做爱”——亏你说得出这些话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「如果沒有愛，就不做愛」——虧你說得出這些話。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00066",
		linknext = "0091_00068",
		line = 841,
	},
	["0091_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That motherfucker! So he wants to turn this island into a sex industry conduit? Not if I can fuckin' help it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶的家伙……！竟然要把整个岛当成风俗产业？这种事能原谅吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡的傢伙……！竟然要把整個島當成風俗產業？這種事能原諒嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00067",
		linknext = "0091_00069",
		line = 853,
	},
	["0091_00069"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1410", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But Junnosuke... what can we do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“淳之介君……但是，该怎么办……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「淳之介君……但是，該怎麼辦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00068",
		linknext = "0091_00070",
		line = 867,
	},
	["0091_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There must be something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该有什么对策才对……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該有什麼對策才對……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00069",
		linknext = "0091_00071",
		line = 879,
	},
	["0091_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Easier said than done, though. We're up against OSS guards and the yakuza. And the latter are packing real heat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这样说，但对方是拿着真枪的黑社会以及SHO的警卫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這樣說，但對方是拿著真槍的黑社會以及SHO的警衛。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00070",
		linknext = "0091_00072",
		line = 889,
	},
	["0091_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having taken possession of Fumino and made Governor Hitoura their puppet, they're probably brazenly taking refuge in OSS HQ.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把文乃掌握在手中，把仁浦先生当成傀儡的现在，那些人恐怕正堂而皇之地把SHO总部当成大本营吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把文乃掌握在手中，把仁浦先生當成傀儡的現在，那些人恐怕正堂而皇之地把SHO總部當成大本營吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00071",
		linknext = "0091_00073",
		line = 899,
	},
	["0091_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We certainly can't put the earless strategy to use, because the OSS HQ is too close to the water. If we try to come in via boat, they'll apprehend us instantly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无法对海上的SHO总部使用无耳作战。因为即便想驾船靠近，也会被瞬间抓到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無法對海上的SHO總部使用無耳作戰。因為即便想駕船靠近，也會被瞬間抓到。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00072",
		linknext = "0091_00074",
		line = 909,
	},
	["0091_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The NLNS has only five heads in it. There's no sugarcoating this: the difference in capability between the enemy and us is almost depressingly massive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"NLNS是只有5个人的组织——这个绝望的实力差距，没有那么容易颠覆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"NLNS是只有5個人的組織——這個絕望的實力差距，沒有那麼容易顛覆。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00073",
		linknext = "0091_00075",
		line = 919,
	},
	["0091_00075"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00111", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2050", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I wonder what Rei's team is up to?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱他们现在怎么样了呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬他們現在怎麼樣了呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00074",
		linknext = "0091_00076",
		line = 933,
	},
	["0091_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00075",
		linknext = "0091_00077",
		line = 945,
	},
	["0091_00077"] = {
		{"fg", file="hinami_02m_00001", file3="hinami_02m_00301", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2051", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well, all the SS were trying to capture Fumino, but she was abducted by the yakuza. So I was just wondering what they're gonna do now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为FS的大家也都想抓捕文乃吧？但是文乃被黑社会抓走了……所有我在想他们现在怎么样了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為FS的大家也都想抓捕文乃吧？但是文乃被黑社會抓走了……所有我在想他們現在怎麼樣了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00076",
		linknext = "0091_00078",
		line = 959,
	},
	["0091_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Good point. It wasn't just us, but the SS they stole Fumino away from. Did the disciplinary committee prez say anything?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对了，被夺走文乃的不仅是我们，还有FS——渡酱，风纪委员长有说过什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對了，被奪走文乃的不僅是我們，還有FS——渡醬，風紀委員長有說過什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00077",
		linknext = "0091_00079",
		line = 971,
	},
	["0091_00079"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
