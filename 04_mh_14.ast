		linkback = "0091_00103",
		linknext = "0091_00105",
		line = 1303,
	},
	["0091_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Being class rep and SS, you should know, right? That fucking stupid law they announced yesterday was just the yakuza using Fumino to make the governor—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“委员长是FS的话也应该知道吧？昨天发表的那可笑的条例……那是本岛的黑社会用文乃威胁县知事让他说的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「委員長是FS的話也應該知道吧？昨天發表的那可笑的條例……那是本島的黑社會用文乃威脅縣知事讓他說的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00104",
		linknext = "0091_00106",
		line = 1314,
	},
