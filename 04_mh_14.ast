	["0091_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm so glad I have this girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟她在一起真好——我打从心底这样想。",
