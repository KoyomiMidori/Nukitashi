				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I already knew that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我早就知道了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我早就知道了。",
