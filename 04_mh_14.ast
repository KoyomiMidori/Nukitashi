	["0091_00137"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, I didn't mean you, Misaki. My bad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……抱歉，我不是想对美岬说的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……抱歉，我不是想對美岬說的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00136",
		linknext = "0091_00138",
		line = 1777,
	},
	["0091_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm just ridiculously frustrated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我很着急。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我很著急。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00137",
		linknext = "0091_00139",
		line = 1787,
	},
	["0091_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino got taken from us, they announced that new law, the SS are in cahoots with the yakuza... and yet we have nothing to go on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃被抢走，新条例被发表，FS被黑社会吞噬——但想不到对策。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃被搶走，新條例被發表，FS被黑社會吞噬——但想不到對策。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00138",
		linknext = "0091_00140",
		line = 1797,
	},
	["0091_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The frustration is overwhelming.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这让我越来越焦躁不安。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這讓我越來越焦躁不安。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00139",
		linknext = "0091_00141",
		line = 1807,
	},
	["0091_00141"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1413", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um... it may just be that I'm not imaginative enough to figure this out... but once the new law is being enforced, things won't change that much, will they?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……也许是因为我的想象力不足，才会有这样的想法……不过，如果实施新条例的话，会有什么变化呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個……也許是因為我的想像力不足，才會有這樣的想法……不過，如果實施新條例的話，會有什麼變化呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00140",
		linknext = "0091_00142",
		line = 1821,
	},
	["0091_00142"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1414", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I mean, I do understand what you said before, but on the surface, I doubt things will change very much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“当然淳之介刚才说的话我也明白……我也觉得从表面上来看，大概不会和现在有太大的区别。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「當然淳之介剛才說的話我也明白……我也覺得從表面上來看，大概不會和現在有太大的區別。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00141",
		linknext = "0091_00143",
		line = 1835,
	},
	["0091_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's understandable that she'd say that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"美岬这么说也不是没有道理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"美岬這麼說也不是沒有道理。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00142",
		linknext = "0091_00144",
		line = 1845,
	},
	["0091_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Making money from sex probably won't make things look that different when it comes to how things work on the island, at least on the surface.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，即使性爱需要付费，表面上岛的存在方式也不会有太大的变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，即使性愛需要付費，表面上島的存在方式也不會有太大的變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00143",
		linknext = "0091_00145",
		line = 1855,
	},
	["0091_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even now, there are special options available depending on the facility where money is required.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是现在，根据设施的不同，也有一些需要付费的特别项目。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是現在，根據設施的不同，也有一些需要付費的特別項目。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00144",
		linknext = "0091_00146",
		line = 1865,
	},
	["0091_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With the new law, there'll be a lot of funds generated for the yakuza, which is a huge problem... but that's not where my concern lies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是新条例的话，产生的钱大多会成为黑社会的资金，这是个大问题——但这不是我在意的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是新條例的話，產生的錢大多會成為黑社會的資金，這是個大問題——但這不是我在意的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00145",
		linknext = "0091_00147",
		line = 1875,
	},
	["0091_00147"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
