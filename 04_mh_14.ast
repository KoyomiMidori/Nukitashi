					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps she worried about her figure and looked up at the sky like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她大概也曾因为自己的体型而失落，仰望着暮色的天空吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她大概也曾因為自己的體型而失落，仰望著暮色的天空吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00156",
		linknext = "0091_00158",
		line = 2002,
	},
	["0091_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe she was looking up at the same sky I was?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们都在青蓝岛上仰望过同样的天空吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們都在青藍島上仰望過同樣的天空嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00157",
		linknext = "0091_00159",
		line = 2012,
	},
	["0091_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe if we'd met earlier than we did, we might have gone down different paths?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果早点相遇，现在的我们，或许正过着不一样的生活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果早點相遇，現在的我們，或許正過著不一樣的生活。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00158",
		linknext = "0091_00160",
		line = 2022,
	},
	["0091_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, there's no point being lost in hypotheticals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，这种假设毫无意义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，這種假設毫無意義。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00159",
		linknext = "0091_00161",
		line = 2032,
	},
	["0091_00161"] = {
		{"se", id=1, stop=1, time=3000},
		{"se", id=2, loop=1, file="se_d031", vol=20},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The most important thing is that she's by my side right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最重要的是——现在，美岬就在我的身旁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最重要的是——現在，美岬就在我的身旁。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00160",
		linknext = "0091_00162",
		line = 2044,
	},
	["0091_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't want to just dredge up old memories, but they weren't all bad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过去的事虽然大多都不是什么好事，但也不是全部都非常糟糕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過去的事雖然大多都不是什麼好事，但也不是全部都非常糟糕。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00161",
		linknext = "0091_00163",
		line = 2054,
	},
	["0091_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel that I want to tell her everything, so she can know me better.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是她的话，一切都可以告诉她——我想让她知道我的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是她的話，一切都可以告訴她——我想讓她知道我的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00162",
		linknext = "0091_00164",
		line = 2064,
	},
	["0091_00164"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bgm", file="bgm21", vol=100},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you remember what I once told you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“之前我说过的话，你还记得吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「之前我說過的話，你還記得嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00163",
		linknext = "0091_00165",
		line = 2081,
	},
	["0091_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I quietly speak as we walk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边走，一边安静地开口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊走，一邊安靜地開口。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00164",
		linknext = "0091_00166",
		line = 2091,
	},
	["0091_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why it is that I loathe being seen naked?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有关为什么，我极端讨厌……被看到裸体。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有關為什麼，我極端討厭……被看到裸體。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00165",
		linknext = "0091_00167",
		line = 2103,
	},
	["0091_00167"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1417", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes... Because they said awful things to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的……因为以前被说了很过分的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的……因為以前被說了很過分的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00166",
		linknext = "0091_00168",
		line = 2115,
	},
	["0091_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There's more to that story. When I was being teased, it's not like anyone and everyone was my enemy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个故事还有后续。被欺负的时候……并不是所有人都是我的敌人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個故事還有後續。被欺負的時候……並不是所有人都是我的敵人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00167",
		linknext = "0091_00169",
		line = 2126,
	},
	["0091_00169"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1418", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Was there someone who helped you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……有人向你伸出援手吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……有人向你伸出援手嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00168",
		linknext = "0091_00170",
		line = 2140,
	},
	["0091_00170"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, a really nice girl. I was badly hurt, but she told me not to worry about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……是个很棒的孩子。她告诉受到伤害的我，不用在意那种事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……是個很棒的孩子。她告訴受到傷害的我，不用在意那種事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00169",
		linknext = "0091_00171",
		line = 2152,
	},
	["0091_00171"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But it turned out badly. I wanted to accept her hand... but in the end, all I did was hurt her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然而，结果并不理想。当我想回报她对我的帮助时……最终却伤害了她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然而，結果並不理想。當我想回報她對我的幫助時……最終卻傷害了她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00170",
		linknext = "0091_00172",
		line = 2164,
	},
	["0091_00172"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought that wound had long since healed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时候的伤口，应该很早就痊愈了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時候的傷口，應該很早就痊癒了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00171",
		linknext = "0091_00173",
		line = 2176,
	},
	["0091_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But now, my voice is somehow trembling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——为什么我的声音会颤抖呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——為什麼我的聲音會顫抖呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00172",
		linknext = "0091_00174",
		line = 2186,
	},
	["0091_00174"] = {
		{"bg", id=18, file="bg26_2l_00000", x=-100, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"bg", id=18, file="bg26_2l_00000", x=-100, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=18, act="移動", x=-105, y=-5, time=50000, lv=5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought it was just how the kids teasing me said it would be. I thought I was so worthless, I'd be better off dead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我觉得欺辱我的那些人说的话是对的。自己真的是个无可救药的家伙，甚至觉得干脆消失了更好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我覺得欺辱我的那些人說的話是對的。自己真的是個無可救藥的傢伙，甚至覺得乾脆消失了更好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00173",
		linknext = "0091_00175",
		line = 2201,
	},
	["0091_00175"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And then, I met another woman. A different one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就在那时……我又遇到了不同于那个女孩子的女性。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就在那時……我又遇到了不同於那個女孩子的女性。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00174",
		linknext = "0091_00176",
		line = 2213,
	},
	["0091_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She forgave me for what I did, and listened to everything I had to say. In spite of how beside myself I was, she still accepted me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个人，原谅了我所做的事，我说的话她都愿意听……不断肯定无可救药的我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個人，原諒了我所做的事，我說的話她都願意聽……不斷肯定無可救藥的我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00175",
		linknext = "0091_00177",
		line = 2224,
	},
	["0091_00177"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00107", file2="misaki_01f_00201", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
