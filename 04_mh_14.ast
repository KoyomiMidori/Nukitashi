	["0091_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Here I was starting to feel down, but just seeing her face cheers me right up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"消沉的心情，看到她的脸后也自然变得开朗。",
