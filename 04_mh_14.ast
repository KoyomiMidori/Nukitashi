			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Junnosuke, you look really on edge, so I'm worried. Please tell me if there's something bothering you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“淳之介君好像非常烦躁，所以我很在意……如果有什么事的话，我希望你能告诉我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「淳之介君好像非常煩躁，所以我很在意……如果有什麼事的話，我希望你能告訴我。」",
					{"rt2"},
				},
