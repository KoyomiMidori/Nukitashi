		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you know where the bathroom is, right? If you get thirsty during the night, help yourself to whatever you want from the fridge.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你知道厕所在哪里吗？如果半夜渴了，随便喝点什么没关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你知道廁所在哪裡嗎？如果半夜渴了，隨便喝點什麼沒關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00498",
		linknext = "0091_00500",
		line = 6348,
	},
	["0091_00500"] = {
