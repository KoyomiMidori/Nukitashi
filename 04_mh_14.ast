	["0091_00118"] = {
		{"bg", id=1, file="bg15_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0298", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Most admirable. My, there are so many misguided churls skeptical of the new law, it's enough to drive me mad. I must return to my patrol now. See you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“很好。真是的，对新条例抱有疑问的不懂规矩之人真多，真让我为难。我必须继续巡查……那么再见了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「很好。真是的，對新條例抱有疑問的不懂規矩之人真多，真讓我為難。我必須繼續巡查……那麼再見了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00117",
		linknext = "0091_00119",
		line = 1549,
	},
