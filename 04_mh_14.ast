		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But... the girl I fell in love with lives on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……我喜欢上的也是住在这个岛上的女孩。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……我喜歡上的也是住在這個島上的女孩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00231",
		linknext = "0091_00233",
		line = 2873,
	},
	["0091_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whatever the case is with the others, I love you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管别人怎么样，我都喜欢美岬。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管別人怎麼樣，我都喜歡美岬。」",
