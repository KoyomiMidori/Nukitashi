			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hanamaru, perfect timing. I want to have a word with the student council president, or the disciplinary committee president, whoever's available. Can you put in the word for me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“花丸委员长——正好。学生会长——或者风纪委员长也没关系。我想找她们，能帮我叫来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「花丸委員長——正好。學生會長——或者風紀委員長也沒關係。我想找她們，能幫我叫來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00097",
		linknext = "0091_00099",
		line = 1229,
	},
	["0091_00099"] = {
		{"bg", id=1, file="bg15_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0292", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Unfortunately, neither of them are here, but if you tell me what your business is, I can pass it onto them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“很遗憾，她们两位都不在，如果你能告诉我的话，我可以帮你转告哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「很遺憾，她們兩位都不在，如果你能告訴我的話，我可以幫你轉告哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00098",
		linknext = "0091_00100",
		line = 1244,
	},
	["0091_00100"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is something best told to them firsthand, actually...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可以的话，我希望能直接对谈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可以的話，我希望能直接對談……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00099",
		linknext = "0091_00101",
		line = 1256,
	},
	["0091_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't feel comfortable entrusting the message to Hanamaru.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这样说不好，但我觉得拜托花丸委员长传话不可靠。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這樣說不好，但我覺得拜託花丸委員長傳話不可靠。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00100",
		linknext = "0091_00102",
		line = 1266,
	},
	["0091_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Actually, there's something else I want to confirm first.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——现在应该先确认那件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——現在應該先確認那件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00101",
		linknext = "0091_00103",
		line = 1276,
	},
	["0091_00103"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, if neither of them are here... I'm guessing that has to do with Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“两个人都不在的话——果然是和文乃有关吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「兩個人都不在的話——果然是和文乃有關嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00102",
		linknext = "0091_00104",
		line = 1288,
	},
	["0091_00104"] = {
		{"bgm", stop=1},
