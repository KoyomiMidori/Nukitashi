		{"bg", id=18, file="bg26_2l_00000", x=100, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"bg", id=18, file="bg26_2l_00000", x=100, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=18, act="移動", x=-205, y=-5, time=50000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I sigh and look up at the sky.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我叹了口气，仰望天空。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我嘆了口氣，仰望天空。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00150",
		linknext = "0091_00152",
		line = 1942,
	},
	["0091_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sun in the west is burning red.",
					{"rt2"},
				},
			},
			cn = {
				{
					"倾斜于西方天空的夕阳，正火红地燃烧着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"傾斜於西方天空的夕陽，正火紅地燃燒著。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00151",
		linknext = "0091_00153",
		line = 1952,
	},
	["0091_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I used to live on this island a long time ago, back when my parents were still alive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很久以前——父母还活着，我还在青蓝岛的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"很久以前——父母還活著，我還在青藍島的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00152",
		linknext = "0091_00154",
		line = 1962,
	},
	["0091_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Back then, whenever I was teased incessantly about my big phallus, I'd look up at the sky like this and groan pathetically.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为巨根被欺辱得很惨的我，曾像这样仰望暮色的天空，发出无奈的叹息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為巨根被欺辱得很慘的我，曾像這樣仰望暮色的天空，發出無奈的嘆息。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00153",
		linknext = "0091_00155",
		line = 1972,
	},
	["0091_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I seem to remember the evening sun being this same color.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时候抬头看着的夕阳，好像就是这种颜色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時候抬頭看著的夕陽，好像就是這種顏色。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00154",
