			},
		},
		linkback = "0091_00126",
		linknext = "0091_00128",
		line = 1664,
	},
	["0091_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No shit. This new perverted sex law... No sane society would accept anything like it. What the hell are the SS and OSS thinking?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错……新・变态条例——那种东西怎么能被接受，FS和SHO都在想些什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯……新・變態條例——那種東西怎麼能被接受，FS和SHO都在想些什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00127",
		linknext = "0091_00129",
		line = 1676,
	},
	["0091_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Organizations which are supposed to safeguard the island must be out of their mind to make their bed with a bunch of criminals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本应守护岛的他们，怎么会站到不法者那一边呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"本應守護島的他們，怎麼會站到不法者那一邊呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00128",
		linknext = "0091_00130",
		line = 1686,
	},
	["0091_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps they have a weakness like Governor Hitoura that they're exploiting as well?",
					{"rt2"},
				},
			},
			cn = {
				{
					"难道和仁浦先生一样，他们也都被抓到了把柄吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"難道和仁浦先生一樣，他們也都被抓到了把柄嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00129",
		linknext = "0091_00131",
		line = 1696,
	},
	["0091_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unless they're aware they're just puppets, but just plan to follow whatever Hitoura orders.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或者说，即使知道是傀儡，但只要是仁浦先生说的话，就会无条件服从吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者說，即使知道是傀儡，但只要是仁浦先生說的話，就會無條件服從嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00130",
		linknext = "0091_00132",
		line = 1706,
	},
	["0091_00132"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So for us to change this situation, does that mean we have to defeat the yakuza, the SS and the OSS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要想改变这个状况，我们就必须打倒黑社会、FS和SHO——打倒所有人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要想改變這個狀況，我們就必須打倒黑社會、FS和SHO——打倒所有人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00131",
		linknext = "0091_00133",
		line = 1718,
	},
	["0091_00133"] = {
