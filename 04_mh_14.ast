	},
	["0091_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm jolted back to my senses.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到那个声音，我回过神来。",
