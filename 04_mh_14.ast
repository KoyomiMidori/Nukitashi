	["0091_00186"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00115", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1421", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“…………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「…………」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00185",
		linknext = "0091_00187",
		line = 2344,
	},
	["0091_00187"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She was working for the illegal sex industry on the island. Apparently, she was working somewhere that let people do things even the perverted sex law wouldn't allow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她曾在青蓝岛的地下风俗工作。是可以进行条例中不允许的行为的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她曾在青藍島的地下風俗工作。是可以進行條例中不允許的行為的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00186",
		linknext = "0091_00188",
		line = 2356,
	},
	["0091_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even now I'm not sure why she worked there... or rather, why she had to work there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么那个人在那样的地方工作……还是不得不在那样的地方工作，现在已经无从得知了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼那個人在那樣的地方工作……還是不得不在那樣的地方工作，現在已經無從得知了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00187",
		linknext = "0091_00189",
		line = 2367,
	},
	["0091_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She knew that she was working for an industry that was against the law, and the people of the island persecuted her for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被别人知道在违反条例的地下风俗工作的她，开始受到岛上人们的迫害。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被別人知道在違反條例的地下風俗工作的她，開始受到島上人們的迫害。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00188",
		linknext = "0091_00190",
		line = 2379,
	},
	["0091_00190"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even I, dumb kid that I was, thought they were being ridiculous. They were all fucking their brains out anyway, so why target her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“连愚蠢的我都觉得奇怪。岛上的人明明也天天都在做爱，为什么只有她要受到谴责。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「連愚蠢的我都覺得奇怪。島上的人明明也天天都在做愛，為什麼只有她要受到譴責。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00189",
		linknext = "0091_00191",
		line = 2391,
	},
	["0091_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eventually, I guess she just couldn't take it anymore... She fell ill, grew weaker and weaker...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最终，大概是她无法忍受周围人的迫害吧……她的身体逐渐生病，变得越来越虚弱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最終，大概是她無法忍受周圍人的迫害吧……她的身體逐漸生病，變得越來越虛弱……」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00190",
		linknext = "0091_00192",
		line = 2402,
	},
	["0091_00192"] = {
		{"ex", time=500, func="wait"},
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And then, she was gone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后，就死了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後，就死了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00191",
		linknext = "0091_00193",
		line = 2415,
	},
	["0091_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't even think I was sad about her. I just fell deeper into despair.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那时我大概没有悲伤，只是已经陷入了绝望。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那時我大概沒有悲傷，只是已經陷入了絕望。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00192",
		linknext = "0091_00194",
		line = 2426,
	},
	["0091_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And when I was deep in despair, I overheard somebody say...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在绝望之中……我听到了这样的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在絕望之中……我聽到了這樣的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00193",
		linknext = "0091_00195",
		line = 2437,
	},
	["0091_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“'Serves her right for defying the law. She finally snuffed it, huh? About fuckin' time. Thank you, God.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是违反条例的家伙不对。终于死了啊，这是上天的惩罚——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是違反條例的傢伙不對。終於死了啊，這是上天的懲罰——」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00194",
		linknext = "0091_00196",
		line = 2448,
	},
	["0091_00196"] = {
