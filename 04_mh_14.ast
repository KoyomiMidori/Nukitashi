	},
	["0091_00304"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fuck... And here I was feeling so elated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可恶……明明好不容易才能心情舒畅地回家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可惡……明明好不容易才能心情舒暢地回家。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00303",
		linknext = "0091_00305",
		line = 3807,
	},
	["0091_00305"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Goddamn it, I literally just kissed Misaki...! I vowed I'd never wipe my lips again, and now you're fucking everything up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才刚和美岬接吻呢……！我发誓不会再洗嘴唇了，怎么能被这样的雨洗掉呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才剛和美岬接吻呢……！我發誓不會再洗嘴唇了，怎麼能被這樣的雨洗掉呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00304",
		linknext = "0091_00306",
		line = 3819,
	},
	["0091_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I shout to the heavens, only to have the passing shower intensify.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使我向天空吼叫，雨势还是越来越大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使我向天空吼叫，雨勢還是越來越大。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00305",
		linknext = "0091_00307",
		line = 3829,
	},
	["0091_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe it's telling me to get my head out of the clouds and chill the fuck out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是想叫我不要太得意，冷静下来吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是想叫我不要太得意，冷靜下來嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00306",
		linknext = "0091_00308",
		line = 3839,
	},
	["0091_00308"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All right, so all I did was kiss her, and I dunno where we go from here, but it's none of YOUR goddamn business!",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然的确和美岬接吻了，可是今后的方针一点都没考虑，但也不干你的事啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然的確和美岬接吻了，可是今後的方針一點都沒考慮，但也不關你的事啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00307",
		linknext = "0091_00309",
		line = 3849,
	},
	["0091_00309"] = {
		{"text"},
		text = {
