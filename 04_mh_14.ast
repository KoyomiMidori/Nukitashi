	["0091_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Do I still hate the islanders? Even in this moment?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——你现在还讨厌这个岛上的人吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"——你現在還討厭這個島上的人嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00364",
		linknext = "0091_00366",
		line = 4512,
	},
	["0091_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Misaki's question from before floats back into my mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"美岬说过的话，仿佛在我面前现形般向我询问着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"美岬說過的話，彷彿在我面前現形般向我詢問著。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00365",
		linknext = "0091_00367",
		line = 4522,
	},
	["0091_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since that day, I've despised the people of this island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那天开始，我一直憎恨着岛上的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從那天開始，我一直憎恨著島上的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00366",
		linknext = "0091_00368",
		line = 4532,
	},
	["0091_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fucking themselves silly day after day, hammering down the nails that stick out through peer pressure, never allowing anything but complete conformity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们在日常生活中交配，并认为这是理所当然的事情，还用同调压力吞噬周围，不允许出现例外——这就是岛上的人们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們在日常生活中交配，並認為這是理所當然的事情，還用同調壓力吞噬周圍，不允許出現例外——這就是島上的人們。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00367",
		linknext = "0091_00369",
		line = 4542,
	},
	["0091_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That hatred has never faded. With time, it has gotten twisted more and more, welling up and boiling inside me, with no outlet for release.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对此的憎恨一直没有被消除，而是不停扭曲着，无处发泄的愤怒一点一点累积，最后——",
					{"rt2"},
				},
			},
			tw = {
				{
					"對此的憎恨一直沒有被消除，而是不停扭曲著，無處發洩的憤怒一點一點累積，最後——",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00368",
		linknext = "0091_00370",
		line = 4552,
	},
	["0091_00370"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My savior was persecuted ruthlessly by those non-virgins. And so, their very existence disgusted me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——我开始强烈厌恶迫害她的非处女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——我開始強烈厭惡迫害她的非處女。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00369",
		linknext = "0091_00371",
		line = 4562,
	},
	["0091_00371"] = {
