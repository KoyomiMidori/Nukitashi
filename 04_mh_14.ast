					{"rt2"},
				},
			},
			en = {
				{
					"When she finally stops crying, she lets go and stares at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"终于停止哭泣的美岬，放开双臂凝视着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"終於停止哭泣的美岬，放開雙臂凝視著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00226",
		linknext = "0091_00228",
		line = 2816,
	},
	["0091_00228"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1427", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Junnosuke... Do you still hate non-virgins— the people on this island? Even now, do you still bear a grudge?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“淳之介君……现在也还对非处女……对岛上的人感到厌恶吗……？觉得很可恨吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「淳之介君……現在也還對非處女……對島上的人感到厭惡嗎……？覺得很可恨嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00227",
		linknext = "0091_00229",
		line = 2828,
	},
	["0091_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her bloodshot eyes stare directly into my own.",
					{"rt2"},
				},
