			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“She must have been very kind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是个非常善良的人呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是個非常善良的人呢。」",
