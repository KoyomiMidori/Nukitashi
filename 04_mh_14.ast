		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay, I'm sorry, all right? I was joking! I don't see any problem with the new law at all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好意思！我只是开玩笑的……！新条例不错，我也不是没有这么觉得过——的确没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好意思！我只是開玩笑的……！新條例不錯，我也不是沒有這麼覺得過——的確沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00114",
		linknext = "0091_00116",
		line = 1509,
	},
	["0091_00116"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0297", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“So you do agree with it, then? I shall overlook this for now, but if I hear you voicing complaints about the new law again... you do understand what will happen, yes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“……？你的意思是赞成对吧？这次我特别放过你，但要是你下次再说出对抗新条例的言辞……知道了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「……？你的意思是讚成對吧？這次我特別放過你，但要是你下次再說出對抗新條例的言辭……知道了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00115",
		linknext = "0091_00117",
		line = 1522,
	},
	["0091_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
