	["0091_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And almost comically quickly, it turns into a downpour.",
					{"rt2"},
				},
			},
			cn = {
				{
					"瞬间就成了倾盆大雨。",
