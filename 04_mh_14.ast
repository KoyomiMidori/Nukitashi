				{"vo", file="misaki1428", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That's good enough. Heh heh, Asane says I'm pretty crazy, even for this island. If you managed to fall for someone like me, I think you'll be fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“足够了。诶嘿嘿……听麻沙音酱说，我在这个岛上也算是脑袋最奇怪的人，既然能喜欢上这样的我，那一定没问题的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「足夠了。欸嘿嘿……聽麻沙音醬說，我在這個島上也算是腦袋最奇怪的人，既然能喜歡上這樣的我，那一定沒問題的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00234",
		linknext = "0091_00236",
