	["0091_00519"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I told Misaki about what happened, she told me to just keep Onabuta company for the night.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听了情况的美岬叫我跟她一起睡。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽了情況的美岬叫我跟她一起睡。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00518",
		linknext = "0091_00520",
		line = 6635,
	},
	["0091_00520"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I doubted she'd worry too much, having been raised on the island, but I did detect some hints of jealousy over the phone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我以为从小在青蓝岛长大的她不会介意，但似乎有些吃醋了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我以為從小在青藍島長大的她不會介意，但似乎有些吃醋了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00519",
		linknext = "0091_00521",
		line = 6645,
	},
	["0091_00521"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Like, when I told her about the suppository thing, she must have yelled “Next time me too!!” in my ear about 50,000 times.",
					{"rt2"},
				},
			},
			cn = {
				{
					"特别是当我提到插坐药的时候，她说了5万次左右“下次我也要！！”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"特別是當我提到插坐藥的時候，她說了5萬次左右「下次我也要！！」。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00520",
		linknext = "0091_00522",
		line = 6655,
	},
	["0091_00522"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she still didn't mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——尽管如此，她还是原谅了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——儘管如此，她還是原諒了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00521",
		linknext = "0091_00523",
		line = 6665,
	},
	["0091_00523"] = {
