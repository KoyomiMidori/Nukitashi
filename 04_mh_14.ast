			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei? Hmm... I haven't seen her since then. She seems to be taking time off from school too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱？嗯……那之后就没见过面啊。学校好像也请假了。”",
					{"rt2"},
				},
			},
			tw = {
				{
