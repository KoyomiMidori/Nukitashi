		linkback = "0091_00535",
		linknext = "0091_00537",
		line = 6826,
	},
	["0091_00537"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All that time she spent having sex would make you think she didn't give any thought to anything. But everyone has their own circumstances.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与性爱为伍，乍看之下似乎什么都没在想的人，也都各自抱持着烦恼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與性愛為伍，乍看之下似乎什麼都沒在想的人，也都各自抱持著煩惱。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00536",
		linknext = "0091_00538",
		line = 6836,
	},
	["0091_00538"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I realized that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这我早该知道了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這我早該知道了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00537",
		linknext = "0091_00539",
		line = 6846,
	},
	["0091_00539"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The way I generalized all the islanders as non-virgins, as sex seekers, as objects of my hatred... I was a fool to do that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把岛上的人概括成非处女或者性触者，然后憎恨这一切——这是非常荒唐的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把島上的人概括成非處女或者性觸者，然後憎恨這一切——這是非常荒唐的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00538",
		linknext = "0091_00540",
		line = 6856,
	},
	["0091_00540"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It made me no different from them— the people who persecuted that woman all those years ago, without knowing anything about her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种想法——和很久以前，明明不知道那个人的事情就迫害她的人们没什么区别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種想法——和很久以前，明明不知道那個人的事情就迫害她的人們沒什麼區別。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00539",
		linknext = "0091_00541",
		line = 6866,
	},
	["0091_00541"] = {
