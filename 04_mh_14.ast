	["0091_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was thanks to our earless strategy that the SS was unable to secure Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS未能捕捉到文乃，说到底是因为我们的无耳作战。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS未能捕捉到文乃，說到底是因為我們的無耳作戰。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00090",
		linknext = "0091_00092",
		line = 1153,
	},
	["0091_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And even if they were to overlook that, we have diametrically opposing objectives to them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使得到了原谅，我们和FS的最终目的也是相反的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使得到了原諒，我們和FS的最終目的也是相反的。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00091",
		linknext = "0091_00093",
		line = 1163,
	},
	["0091_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this isn't the time to be saying that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，现在不是说这种话的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，現在不是說這種話的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00092",
		linknext = "0091_00094",
		line = 1173,
	},
	["0091_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the status quo continues, and the yakuza keep squeezing the island for all it's worth, things will surely get worse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"黑社会掌控岛屿的现状，如果放任不管，肯定会变得更糟。",
					{"rt2"},
				},
			},
			tw = {
				{
					"黑社會掌控島嶼的現狀，如果放任不管，肯定會變得更糟。",
					{"rt2"},
				},
			},
