					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right, I'm gonna turn out the lights. I'll be sleeping in the living room, so if you need anything...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那我关灯了。我会在客厅睡觉，如果有什么事——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那我關燈了。我會在客廳睡覺，如果有什麼事——」",
					{"rt2"},
				},
			},
		},
