	["0087_00156"] = {
		{"bgm", stop=1},
		{"fg", file="misaki_01f_00000", file2="misaki_01f_00204", file3="misaki_01f_00307", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
