	["0087_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My current hypothesis is that she's hiding in the cave during the day to avoid notice by the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为某种原因被FS追赶的文乃，白天就躲在这个洞穴里生活——这是我的假设。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為某種原因被FS追趕的文乃，白天就躲在這個洞穴裡生活——這是我的假設。",
					{"rt2"},
				},
