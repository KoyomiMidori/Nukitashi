		},
		linkback = "0087_00103",
		linknext = "0087_00105",
		line = 1337,
	},
	["0087_00105"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0107", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I might give ya some kinda good luck charm. Hmm... how 'bout this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“机会难得，我想给你个护身符呢……嗯……这种的也行吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「機會難得，我想給你個護身符呢……嗯……這種的也行吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00104",
