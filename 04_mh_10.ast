	},
	["0087_00019"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wha... How'd you know I'm having girl troubles?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你……为什么知道是恋爱的烦恼！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你……為什麼知道是戀愛的煩惱！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00018",
		linknext = "0087_00020",
		line = 241,
	},
	["0087_00020"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00116", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1378", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You weren't exactly making it difficult for us to notice. So you're head over heels for her now, huh. Fuck. Guess I wasn't vigilant enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“倒不如说我惊讶你居然以为没人察觉到……这样啊，终于对那家伙沦陷了吗……切，警戒果然还是不够吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「倒不如說我驚訝你居然以為沒人察覺到……這樣啊，終於對那傢伙淪陷了嗎……切，警戒果然還是不夠嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00019",
		linknext = "0087_00021",
		line = 255,
	},
	["0087_00021"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Real talk, though... I still don't know exactly how Hotori feels about me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……我不知道畔是怎么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……我不知道畔是怎麼想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00020",
		linknext = "0087_00022",
		line = 267,
	},
	["0087_00022"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00120", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1379", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Says the asshole who keeps fuckin' tellin' himself that the feeling's mutual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“说得倒好听，你心里明明想着那家伙一定喜欢我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「說得倒好聽，你心裡明明想著那傢伙一定喜歡我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00021",
		linknext = "0087_00023",
		line = 281,
	},
	["0087_00023"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the fuck is it to you, huh? For all I know, it probably IS mutual!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错啊实际上她就是很迷恋我吧！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯啊實際上她就是很迷戀我吧！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00022",
		linknext = "0087_00024",
		line = 293,
	},
	["0087_00024"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00116", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1380", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Your 'I've never been fucked' energy is astounding. I swear, just one lousy titwank and you go right off the deep end.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所有我才说处男啊……稍微被乳交了一下就开始动摇了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所有我才說處男啊……稍微被乳交了一下就開始動搖了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00023",
		linknext = "0087_00025",
		line = 307,
	},
	["0087_00025"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00024",
		linknext = "0087_00026",
		line = 319,
	},
	["0087_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How'd she even know about that!?",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱看到那个了吗……！",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬看到那個了嗎……！",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00025",
		linknext = "0087_00027",
		line = 329,
	},
	["0087_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's wrong, anyway! It's not like I've fallen for her because she gave me a titwank or anything!!",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是不对。我决不是因为被乳交而喜欢上畔的——！！",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是不對。我決不是因為被乳交而喜歡上畔的——！！",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00026",
		linknext = "0087_00028",
		line = 339,
	},
	["0087_00028"] = {
		{"bgm", stop=1},
		{"fg", file="asane_01m_00002", file1="asane_01m_00106", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1381", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“In all seriousness, it's amazing that you were able to keep your cool like you did. Especially considering the circumstances and how many people were watching.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……不过哥哥，你还真冷静啊，在那种地方，还那么受人瞩目……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……不過哥哥，你還真冷靜啊，在那種地方，還那麼受人矚目……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00027",
		linknext = "0087_00029",
		line = 354,
	},
	["0087_00029"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well... I couldn't afford to pass out then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为……我不能在那个场合失去意识。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是因為……我不能在那個場合失去意識。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00028",
		linknext = "0087_00030",
		line = 366,
	},
	["0087_00030"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With that more sincere comment, she doesn't bring it up anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"认真回答后，麻沙酱就不再提起这个话题了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"認真回答後，麻沙醬就不再提起這個話題了。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00029",
		linknext = "0087_00031",
		line = 378,
	},
	["0087_00031"] = {
		{"bgm", file="bgm01", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having this heart-to-heart with Asa helped me calm down a lot.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当把所有的想法都倾泻在麻沙酱身上后，我渐渐冷静下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當把所有的想法都傾瀉在麻沙醬身上後，我漸漸冷靜下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00030",
		linknext = "0087_00032",
		line = 389,
	},
	["0087_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As much as I keep bringing Hotori up, I need to stop mulling over what happened and get my head in the game.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然嘴里一直喊着畔，但我不能为此永远烦恼下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然嘴裡一直喊著畔，但我不能為此永遠煩惱下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00031",
		linknext = "0087_00033",
		line = 399,
	},
	["0087_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's my duty as leader of the NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是NLNS的领导者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是NLNS的領導者。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00032",
		linknext = "0087_00034",
		line = 409,
	},
	["0087_00034"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since it's the weekend, I might as well put my day off to good use and do some searching for Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难得的休息日——至少得去搜索一下文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難得的休息日——至少得去搜索一下文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00033",
		linknext = "0087_00035",
		line = 421,
	},
	["0087_00035"] = {
		{"fg", file="asane_02l_00002", file1="asane_02l_00101", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=100},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1382", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, I had a hunch you might, so I put this together. Here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，我就知道你会这么说，所以才输出了……给你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，我就知道你會這麼說，所以才輸出了……給你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00034",
		linknext = "0087_00036",
		line = 435,
	},
	["0087_00036"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00035",
		linknext = "0087_00037",
		line = 448,
	},
	["0087_00037"] = {
		{"fg", file="asane_02l_00002", file1="asane_02l_00129", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1383", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The SS have been tracking eyewitness reports of Fumino. The X marks are places where she's been found, and the darker it is, the more times she's been seen there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“文乃的目击情报。刚刚从FS的数据库里抽出来的东西……打叉记号是目击到的地方，颜色深的地方好像表示发现过好几次……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「文乃的目擊情報。剛剛從FS的數據庫裡抽出來的東西……打叉記號是目擊到的地方，顏色深的地方好像表示發現過好幾次……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00036",
		linknext = "0087_00038",
		line = 462,
	},
	["0087_00038"] = {
