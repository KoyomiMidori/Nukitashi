	["0087_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His understanding of psychology is really something. Maybe he could help me understand Hotori better.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好厉害啊，心理学……如果用心理学的话，也能明白畔的想法吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"好厲害啊，心理學……如果用心理學的話，也能明白畔的想法嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00074",
		linknext = "0087_00076",
		line = 965,
	},
	["0087_00076"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00110", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
