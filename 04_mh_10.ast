	["0087_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I always looked down on romcom protagonists getting so flustered when they'd walk in on a naked heroine, but I think I get it now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"迄今为止，我每次都会嘲笑爱情喜剧的主人公看到女主角的裸体而惊慌失措的样子——我现在终于理解他们的心情了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"迄今為止，我每次都會嘲笑愛情喜劇的主角看到女主角的裸體而驚慌失措的樣子——我現在終於理解他們的心情了。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00145",
		linknext = "0087_00147",
		line = 1880,
	},
	["0087_00147"] = {
