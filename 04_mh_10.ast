		line = 1005,
	},
	["0087_00079"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh... Really? Do my thoughts show on my face or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔……是吗……那么一清二楚吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔……是嗎……那麼一清二楚嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00078",
		linknext = "0087_00080",
		line = 1017,
	},
	["0087_00080"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0097", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, I'm sure you'll be fine. Any chick'd easily fall fer a straight-arrow guy like you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“没什么不好的。女孩子应该比较喜欢像淳之介君这样单纯的男孩子吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「沒什麼不好的。女孩子應該比較喜歡像淳之介君這樣單純的男孩子吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00079",
		linknext = "0087_00081",
		line = 1031,
	},
	["0087_00081"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hopefully. Sigh... What am I supposed to do about it, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果是这样就好了。唉……我该怎么办才好呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果是這樣就好了。唉……我該怎麼辦才好呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00080",
		linknext = "0087_00082",
		line = 1043,
	},
	["0087_00082"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0098", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Yer really losin' sleep over if she likes ya, eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你就那么在意她是否喜欢你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你就那麼在意她是否喜歡你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00081",
		linknext = "0087_00083",
		line = 1057,
	},
	["0087_00083"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess, but I've got more important shit that I have to deal with right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那部份当然也有，不过现在也不是思考那种事情的时候……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那部份當然也有，不過現在也不是思考那種事情的時候……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00082",
		linknext = "0087_00084",
		line = 1069,
	},
	["0087_00084"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How'd I even end up falling for her in the first place... Siiigh. What's wrong with me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说到底，我就连为什么会喜欢上都不知道……唉，我到底是怎么了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說到底，我就連為什麼會喜歡上都不知道……唉，我到底是怎麼了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00083",
		linknext = "0087_00085",
		line = 1081,
	},
	["0087_00085"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0099", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ah, youth. I'm a bit jealous.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真是青春啊……好令人羡慕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真是青春啊……好令人羨慕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00084",
		linknext = "0087_00086",
		line = 1095,
	},
	["0087_00086"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? I'd rather be in your position, honestly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我还想要跟你交换呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我還想要跟你交換呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00085",
		linknext = "0087_00087",
		line = 1107,
	},
	["0087_00087"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0100", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ah, it ain't all that. Ya wanna talk about it, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“那我可办不到。如果可以的话能说给我听吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「那我可辦不到。如果可以的話能說給我聽嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00086",
		linknext = "0087_00088",
		line = 1121,
	},
	["0087_00088"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks. I think I told you this earlier, but the girls on this island make me uncomfortable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢……之前我也说过，基本上我不擅长应付这个岛上的女生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝……之前我也說過，基本上我不擅長應付這個島上的女生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00087",
		linknext = "0087_00089",
		line = 1133,
	},
	["0087_00089"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0101", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Makes sense. Chicks here ain't got no inhibitions 'bout sex, and no modesty either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……我知道。虽说对性奔放，但大家都缺乏深度。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「……我知道。雖說對性奔放，但大家都缺乏深度。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00088",
		linknext = "0087_00090",
		line = 1147,
	},
	["0087_00090"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right! Exactly! But... the girl I fell for is like them. A full-fledged islander.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊！——但是……我喜欢上的孩子，完全是个青蓝岛女孩。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊！——但是……我喜歡上的孩子，完全是個青藍島女孩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00089",
		linknext = "0087_00091",
		line = 1159,
	},
	["0087_00091"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At first I thought she was a nice, kinda docile girl, but once I got to know her, I learned she was into the same shit all the other girls are. She even started fapping in my living room once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚开始我还以为她是个听话的女孩子……但一聊天，却发现她非常喜欢无可救药的黄段子，还在我家的客厅里自慰——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剛開始我還以為她是個聽話的女孩子……但一聊天，卻發現她非常喜歡無可救藥的黃段子，還在我家的客廳裡自慰——」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00090",
		linknext = "0087_00092",
		line = 1171,
	},
	["0087_00092"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I asked her about her weakness once, and with a totally straight face, she told me it was her anus. She even talked about having a foot in her vagina while having anal sex and got everyone to start calling me the Six Million Glory Hole Man.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果问她弱点，她就会严肃地回答是肛门，还说过可以一边把脚插到阴道里一边把男性器插入肛门里，甚至还放传言说橘淳之介是个会焊接阴道的男人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果問她弱點，她就會嚴肅地回答是肛門，還說過可以一邊把腳插到陰道裡一邊把男性器插入肛門裡，甚至還放傳言說橘淳之介是個會焊接陰道的男人——」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00091",
		linknext = "0087_00093",
		line = 1184,
	},
	["0087_00093"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0102", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Damn, Junnosuke, this chick sounds even more straight-up than all the others around here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“淳之介君……那个女孩子，应该比一般的青蓝岛女孩更极端吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「淳之介君……那個女孩子，應該比一般的青藍島女孩更極端吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00092",
		linknext = "0087_00094",
		line = 1198,
	},
	["0087_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You think so too? She's on an entirely different level from everyone else around here. She's like a goddamn minefield sometimes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“手嶋先生也这么认为吗……嗯，她就像是从青蓝岛女生的最尖端——被推下来的孩子。身上真的有大量的地雷元素……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「手嶋先生也這麼認為嗎……嗯，她就像是從青藍島女生的最尖端——被推下來的孩子。身上真的有大量的地雷元素……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00093",
		linknext = "0087_00095",
		line = 1209,
	},
	["0087_00095"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, she's got a passionate streak. Even now I don't understand how I ended up starting to like her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，她也有相当一心一意的地方——不知道为什么……等我意识到的时候，就已经喜欢上她了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，她也有相當一心一意的地方——不知道為什麼……等我意識到的時候，就已經喜歡上她了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00094",
		linknext = "0087_00096",
		line = 1221,
	},
	["0087_00096"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sorry, I'm rambling here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……总觉得有点对不起，说的话太不得要领了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……總覺得有點對不起，說的話太不得要領了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00095",
		linknext = "0087_00097",
		line = 1233,
	},
	["0087_00097"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0103", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ah, no worries. Heh, I got a real good picture of yer feelin's fer this chick.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不不不……呵呵，淳之介君有多喜欢那个女孩子我已经明白了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「不不不……呵呵，淳之介君有多喜歡那個女孩子我已經明白了。」",
