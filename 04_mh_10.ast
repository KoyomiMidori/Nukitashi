				{"vo", file="teshima0095", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hey now, I can't tell how a chick feels when I've never even seen 'er before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“不，再怎样都没办法知道没见过面的女孩子的想法的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「不，再怎樣都沒辦法知道沒見過面的女孩子的想法的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00075",
		linknext = "0087_00077",
		line = 979,
	},
	["0087_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
