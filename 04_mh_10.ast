			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Well shit, if it ain't Junnosuke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“咦？这不是淳之介君吗？”",
