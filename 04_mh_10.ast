					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Kotoyose Fumino! Can you hear me!? Don't be scared, I'm your ally.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“琴寄文乃——！你听见了吗？不用警戒，我是站在你这边的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「琴寄文乃——！你聽見了嗎？不用警戒，我是站在你這邊的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00124",
		linknext = "0087_00126",
		line = 1625,
