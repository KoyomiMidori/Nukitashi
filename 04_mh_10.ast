	["0087_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hesitate for a moment, unsure if I should be telling him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不知道该不该跟手嶋先生说这些，所以瞬间变得吞吞吐吐的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不知道該不該跟手嶋先生說這些，所以瞬間變得吞吞吐吐的。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00053",
		linknext = "0087_00055",
		line = 703,
	},
	["0087_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, it should be fine. He's a like-minded soul. As long as I leave out some details, it shouldn't be a problem.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——应该没问题吧。手嶋先生是和我拥有同样想法的人，只要不说得那么详细就好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——應該沒問題吧。手嶋先生是和我擁有同樣想法的人，只要不說得那麼詳細就好。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00054",
		linknext = "0087_00056",
		line = 713,
	},
	["0087_00056"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Have you seen a girl around this area?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“手嶋先生在这附近有没有见过女孩子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「手嶋先生在這附近有沒有見過女孩子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00055",
		linknext = "0087_00057",
		line = 725,
	},
	["0087_00057"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0087", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Girl? Yeah, sure, but what kind?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“女孩子？呃，是有看过……什么样的女孩子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「女孩子？呃，是有看過……什麼樣的女孩子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00056",
		linknext = "0087_00058",
		line = 737,
	},
	["0087_00058"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Umm... a couple of years younger than me. That's about all I know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……大概比我小两岁的女孩子……就这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……大概比我小兩歲的女孩子……就這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00057",
		linknext = "0087_00059",
		line = 749,
	},
	["0087_00059"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00113", file2="teshima_01m_00202", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0088", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, ain't much to go on, is it? Maybe yer lookin' fer that ghost chick everyone's been talkin' 'bout lately?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……呃，真是服了你了。光是这条件很难找吧。难道你是在找最近成为传言的幽灵少女？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「……呃，真是服了你了。光是這條件很難找吧。難道你是在找最近成為傳言的幽靈少女？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00058",
		linknext = "0087_00060",
		line = 763,
	},
	["0087_00060"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gh-Ghost? What's that about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“幽、幽灵？那是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「幽、幽靈？那是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00059",
		linknext = "0087_00061",
		line = 775,
	},
	["0087_00061"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0089", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ah, never 'eard of 'er? It's just been recently, but word is ya think ya see some weird chick there, but ya blink and she's gone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哎呀，你是第一次听说吗？这是最近的传言。好像是说看到了一个不可思议的女孩子，但却一眨眼就不见了这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哎呀，你是第一次聽說嗎？這是最近的傳言。好像是說看到了一個不可思議的女孩子，但卻一眨眼就不見了這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00060",
		linknext = "0087_00062",
		line = 789,
	},
	["0087_00062"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Was the girl riding a bicycle?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……难不成那个女孩骑着自行车？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……難不成那個女孩騎著自行車？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00061",
		linknext = "0087_00063",
		line = 801,
	},
	["0087_00063"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00112", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0090", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“A bike? Nah, I don't think.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“骑自行车？不，我没听说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「騎自行車？不，我沒聽說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00062",
		linknext = "0087_00064",
		line = 815,
	},
	["0087_00064"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see, so it's not Hotori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……那就不是畔了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……那就不是畔了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00063",
		linknext = "0087_00065",
		line = 827,
	},
	["0087_00065"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0091", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hmm? Whazzat? Ya know someone who's like a ghost?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嗯？怎么了？你认识像幽灵的人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嗯？怎麼了？你認識像幽靈的人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00064",
		linknext = "0087_00066",
		line = 839,
	},
	["0087_00066"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not so much a ghost, she's just got a real weak presence. Once I got to know her, I learned she's apparently always been hanging around.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“该说是像幽灵吗……总之就是存在感很薄弱……刚认识的时候，还经常发生不知道她什么时候出现的的情况……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「該說是像幽靈嗎……總之就是存在感很薄弱……剛認識的時候，還經常發生不知道她什麼時候出現的的情況……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00065",
		linknext = "0087_00067",
		line = 851,
	},
	["0087_00067"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0092", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“'Zat so... Junnosuke, do you maybe like this chick?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“原来如此啊……淳之介君，你喜欢那个女孩子对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「原來如此啊……淳之介君，你喜歡那個女孩子對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00066",
		linknext = "0087_00068",
		line = 865,
	},
	["0087_00068"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00067",
		linknext = "0087_00069",
		line = 877,
	},
	["0087_00069"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
