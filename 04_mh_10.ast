	["0087_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not many people know the cave connects with the hills, making it perfect for a hiding place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"连接学校和山的这个洞穴鲜为人知，是最好的藏身地点。",
