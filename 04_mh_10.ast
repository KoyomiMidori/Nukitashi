		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This isn't the first time I've seen her naked, and we did some crazy stuff yesterday, but my heart is still pounding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也不是我第一次看到畔的裸体了，而且我昨天还做了不得了的事情……即便如此，我的心跳还是不停加速。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也不是我第一次看到畔的裸體了，而且我昨天還做了不得了的事情……即便如此，我的心跳還是不停加速。",
