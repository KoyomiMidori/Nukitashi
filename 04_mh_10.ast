	["0087_00098"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's happening to me? Has the island corrupted me and made me lose my mind?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我到底是怎么了……是不是被这岛给毒害到脑子变奇怪了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我到底是怎麼了……是不是被這島給毒害到腦子變奇怪了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00097",
		linknext = "0087_00099",
		line = 1259,
	},
	["0087_00099"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0104", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“'Zat a bad thing? Ya gotta be a little crazy ta fall in love, ya know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“没什么，这是正常的。如果脑袋不多少变得有点奇怪的话，就算不上是恋爱了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「沒什麼，這是正常的。如果腦袋不多少變得有點奇怪的話，就算不上是戀愛了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00098",
		linknext = "0087_00100",
		line = 1271,
	},
	["0087_00100"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Being crazy is natural?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是说变奇怪是理所当然的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是說變奇怪是理所當然的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00099",
		linknext = "0087_00101",
		line = 1283,
	},
	["0087_00101"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00102", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0105", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Yeah, but I guess it don't mean much comin' from a bachelor like me, huh? Still, yer still young, so why not just let yerself barrel down the highway of youth?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“是啊。只是由单身的我来说也没什么说服力对吧？不过我认为淳之介君还年轻，你就这样在青春大道上勇往直前就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「是啊。只是由單身的我來說也沒什麼說服力對吧？不過我認為淳之介君還年輕，你就這樣在青春大道上勇往直前就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00100",
		linknext = "0087_00102",
		line = 1297,
	},
	["0087_00102"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You know, hearing you say that takes a real load off my shoulders.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……听你这么说，我心里就舒服多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……聽你這麼說，我心裡就舒服多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00101",
		linknext = "0087_00103",
		line = 1309,
	},
	["0087_00103"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[500] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0106", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hey, as one of yer friends, I wish ya luck with yer girl. Actually, I think I've got a little somethin' for ya here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“那太好了。作为一位朋友，我会祈祷淳之介君的情路园满的。嗯……有没有什么呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「那太好了。作為一位朋友，我會祈禱淳之介君的情路園滿的。嗯……有沒有什麼呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00102",
		linknext = "0087_00104",
		line = 1325,
	},
	["0087_00104"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
