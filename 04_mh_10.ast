				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“因为很让人在意不是吗？美少女的幽灵……不觉得很浪漫吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「因為很讓人在意不是嗎？美少女的幽靈……不覺得很浪漫嗎？」",
					{"rt2"},
				},
