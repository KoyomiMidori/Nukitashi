		linkback = "0087_00122",
		linknext = "0087_00124",
		line = 1603,
	},
	["0087_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So far we've never seen anyone else here, but that might just mean she's wary of us as well and remained out of sight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然到目前为止一次都没见过类似的人，但不难想象她是因为警戒着我们而不露面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然到目前為止一次都沒見過類似的人，但不難想像她是因為警戒著我們而不露面。",
					{"rt2"},
				},
