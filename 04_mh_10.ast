		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0109", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Yeah, I'm rootin' fer ya. Oh, and... 'bout that ghost I mentioned before. If ya happen to see her, let me know, 'kay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“嗯，我会替你加油的。对了，还有……关于刚才的幽灵的事，如果你看到了，能告诉我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「嗯，我會替你加油的。對了，還有……關於剛才的幽靈的事，如果你看到了，能告訴我嗎？」",
					{"rt2"},
				},
			},
		},
