				{"vo", file="teshima0096", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hahaha! Yer way too easy ta read, kid.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈哈哈！只是淳之介君的想法很好懂而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈哈哈！只是淳之介君的想法很好懂而已。」",
					{"rt2"},
				},
			},
