		linkback = "0087_00159",
		linknext = "0087_00161",
		line = 2100,
	},
	["0087_00161"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1224", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ta-Tachibana? What's wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“橘、橘同学？你怎么了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「橘、橘同學？你怎麼了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00160",
		linknext = "0087_00162",
		line = 2112,
	},
	["0087_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"非表示", "淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Junnosuke"},
					"“Maybe he's right... I must have lost my mind after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "淳之介"},
					"“嗯……我可能是怎么了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "淳之介"},
					"「嗯……我可能是怎麼了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00161",
		linknext = "0087_00163",
		line = 2123,
	},
	["0087_00163"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1225", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00162",
		linknext = "0087_00164",
		line = 2135,
	},
	["0087_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mr. Teshima said something about needing to be a bit crazy to fall in love. I guess this is what he meant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"多少变得有点奇怪才是恋爱——虽然手嶋先生是这么说的，但这是在‘多少有点’的范围内吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"多少變得有點奇怪才是戀愛——雖然手嶋先生是這麼說的，但這是在『多少有點』的範圍內嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00163",
		linknext = "0087_00165",
		line = 2145,
	},
	["0087_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, stark naked mixed bathing with the person is more than just a bit, I'd say.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与意中人一对一、一丝不挂地混浴，这绝对有些脱离了现实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與意中人一對一、一絲不掛地混浴，這絕對有些脫離了現實。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00164",
		linknext = "0087_00166",
		line = 2155,
	},
	["0087_00166"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="mcg01021-1", x=-5, y=-5, path=":cg/mcg01/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1226", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I'm sure you don't want to have to see my body, so please look away. Although, I guess you, uh, already had a good look before, didn't you? Haha... sorry for making you see all my flab.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“很辣眼睛，所以请不要往这边看……虽然刚刚才被看了一遍……哈哈……对不起，身上这么多油……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「很辣眼睛，所以請不要往這邊看……雖然剛剛才被看了一遍……哈哈……對不起，身上這麼多油……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00165",
		linknext = "0087_00167",
		line = 2171,
	},
	["0087_00167"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"非表示", "淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Junnosuke"},
					"“You still haven't gotten over that, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "淳之介"},
					"“你还在在意吗……我还以为你已经不在意了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "淳之介"},
					"「你還在在意嗎……我還以為你已經不在意了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00166",
		linknext = "0087_00168",
		line = 2182,
	},
	["0087_00168"] = {
