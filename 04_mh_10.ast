	["0087_00070"] = {
		{"bgm", file="bgm02", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00122", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"se", id=0, loop=0, file="se_a106"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=1, size=5, time=75, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
					{"exfont"},
				},
			},
			en = {
				{
					{"exfont", size="f4"},
					name = {"淳之介", "Junnosuke"},
					"“Huh!?”",
					{"rt2"},
					{"exfont"},
				},
			},
			cn = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"“嗯！？”",
					{"rt2"},
					{"exfont"},
				},
			},
			tw = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"「嗯！？」",
					{"rt2"},
					{"exfont"},
				},
			},
		},
		linkback = "0087_00069",
		linknext = "0087_00071",
		line = 906,
	},
	["0087_00071"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00109", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0093", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hey, easy there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哦哦，吓了我一跳……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哦哦，嚇了我一跳……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00070",
		linknext = "0087_00072",
		line = 920,
	},
	["0087_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, sorry, I'm just surprised! H-How'd you know!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“吓……吓了一跳的人是我吧！为、为什么你知道……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嚇……嚇了一跳的人是我吧！為、為什麼你知道……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00071",
		linknext = "0087_00073",
		line = 931,
	},
	["0087_00073"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00102", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0094", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Heh, didn't I tell ya? I studied psychology, 'member? Just by how ya talk 'bout this chick I can tell you've got the hots fer her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈哈，之前也说过吧？我有学过心理学啊。只要听说话方式就可以察觉到了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈哈，之前也說過吧？我有學過心理學啊。只要聽說話方式就可以察覺到了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00072",
		linknext = "0087_00074",
		line = 945,
	},
	["0087_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"First Asa, and now Mr. Teshima saw right through me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"继麻沙酱之后，又被手嶋先生看穿了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"繼麻沙醬之後，又被手嶋先生看穿了。",
					{"rt2"},
