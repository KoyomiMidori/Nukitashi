	["0087_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despite all she says, I'm guessing she was sad to see Hotori fail yesterday, after doing so much to support her on-mission.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎么说，麻沙酱在畔晕倒时也会为她哭泣，昨天她也尽了最大的努力辅助了畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎麼說，麻沙醬在畔暈倒時也會為她哭泣，昨天她也盡了最大的努力輔助了畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00040",
		linknext = "0087_00042",
		line = 512,
	},
	["0087_00042"] = {
		{"text"},
		text = {
