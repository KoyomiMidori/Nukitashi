		line = 1349,
	},
	["0087_00106"] = {
		{"se", id=0, loop=0, file="se_a185"},
		{"fg", mode=-1, id=8, ch="手嶋", lv=5, time=300},
		{"bg", id=2, file="blackback_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=9, file="pm1_00007", x=0, y=0, path=":cg/pm1/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A vibrator? And an anal one, at that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是……按摩棒吗？而且还是肛门用的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是……按摩棒嗎？而且還是肛門用的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00105",
		linknext = "0087_00107",
		line = 1366,
	},
	["0087_00107"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00113", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0108", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ya said her anus is her weakness, right? This is a kinda good luck charm fer a successful romance. Bit of a Seiran Island kinda gift, I know, but it's all I got.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“因为听你说那女孩的肛门好像很脆弱，我就想说这从某种意义上来说应该也算是保佑恋爱的护身符……不过很抱歉是青蓝岛的形式，毕竟我这里是这样的店……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「因為聽你說那女孩的肛門好像很脆弱，我就想說這從某種意義上來說應該也算是保佑戀愛的護身符……不過很抱歉是青藍島的形式，畢竟我這裡是這樣的店……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00106",
		linknext = "0087_00108",
		line = 1379,
	},
	["0087_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normally this would make me wildly uncomfortable, but since I see this as Mr. Teshima's way of looking out for me, it actually doesn't bother me at all.",
					{"rt2"},
				},
			},
			cn = {
				{
