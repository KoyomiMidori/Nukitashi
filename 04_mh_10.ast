				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, uhh... i-it must've been destiny or fate or something for us to meet here. Why don't you come in with me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊——嗯——在、在这里相遇也是命运——不对，一定是某种缘分……要一起泡吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊——嗯——在、在這裡相遇也是命運——不對，一定是某種緣分……要一起泡嗎？」",
					{"rt2"},
				},
			},
		},
