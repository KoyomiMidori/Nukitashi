	["0087_00050"] = {
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00107", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0085", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Here fer some more shoppin'? Well, yer in luck! I just got in a new batch of Dutch wives from a top-of-the-line manufacturer today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“又来买东西吗？太好了，今天早上我刚从充气娃娃的顶级制造商那里进了新品。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「又來買東西嗎？太好了，今天早上我剛從充氣娃娃的頂級製造商那裡進了新品。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00049",
		linknext = "0087_00051",
		line = 655,
	},
	["0087_00051"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You did!? Oh, uh, sorry. I'm not here for shopping today, I'm just passing through, is all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的吗！？……啊，抱歉，今天我不是来买东西的，只是偶然路过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的嗎！？……啊，抱歉，今天我不是來買東西的，只是偶然路過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00050",
		linknext = "0087_00052",
		line = 667,
	},
	["0087_00052"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00101", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0086", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“'Zat so? I know it ain't me place to ask, but what brings ya all the way out here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“偶然？虽然开这家店的我说这话有点奇怪……但有什么事会需要来这种地方？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「偶然？雖然開這家店的我說這話有點奇怪……但有什麼事會需要來這種地方？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00051",
		linknext = "0087_00053",
		line = 681,
	},
	["0087_00053"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“其实————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「其實————」",
