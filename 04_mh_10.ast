	["0087_00150"] = {
		{"fg", file="misaki_01f_00000", file1="misaki_01f_00113", file2="misaki_01f_00204", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1221", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh... for the hot springs, as you can see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“唔……就像你看到的，我来泡温泉的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「唔……就像你看到的，我來泡溫泉的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00149",
		linknext = "0087_00151",
		line = 1928,
	},
	["0087_00151"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00150",
		linknext = "0087_00152",
		line = 1940,
	},
	["0087_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, duh. Why else would she be here?",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷静地想一想，好像也就只有这个可能。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷靜地想一想，好像也就只有這個可能。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00151",
		linknext = "0087_00153",
		line = 1950,
	},
	["0087_00153"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm really sorry. I'll get out of here, so you enjoy yourself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的很抱歉……那我先走了……你慢慢来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的很抱歉……那我先走了……你慢慢來吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00152",
		linknext = "0087_00154",
		line = 1962,
	},
	["0087_00154"] = {
		{"fg", file="misaki_01f_00000", file1="misaki_01f_00109", file2="misaki_01f_00204", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
