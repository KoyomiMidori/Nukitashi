					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's always shittalking her, and deep down she probably really does despise her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然嘴上不认同，实际上心里大概也不喜欢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然嘴上不認同，實際上心裡大概也不喜歡——",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00041",
		linknext = "0087_00043",
		line = 522,
