		text = {
			vo = {
				{"vo", file="misaki1233", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I've heard it so many times that I think I've been starting to feel some connection.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是被说了那么多次之后，好像也有了点亲近感。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是被說了那麼多次之後，好像也有了點親近感。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00191",
		linknext = "0087_00193",
		line = 2472,
	},
	["0087_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're around here a lot. Have you run into her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你经常去山里吧？没见过吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你經常去山裡吧？沒見過嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00192",
		linknext = "0087_00194",
		line = 2483,
	},
	["0087_00194"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="mcg01021-1", x=-5, y=-5, path=":cg/mcg01/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1234", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, apparently she's mostly been seen around where the SS and OSS are, and I usually try to stay away from them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没有呢……不知为什么，好像是FS和SHO的人在的时候比较容易出现，但我都尽量避开他们……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒有呢……不知為什麼，好像是FS和SHO的人在的時候比較容易出現，但我都盡量避開他們……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00193",
		linknext = "0087_00195",
		line = 2498,
	},
	["0087_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ooh. Perhaps she's a bound ghost with a grudge against authority.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……也许是怨恨体制的地缚灵吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……也許是怨恨體制的地縛靈吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00194",
		linknext = "0087_00196",
		line = 2509,
	},
	["0087_00196"] = {
		{"text"},
		text = {
