	["0068_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're intending to hold a sting operation to find out more regarding the illegal sex industry, so we need Hinami to be a decoy, and by extension, put on her best loli routine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了找出地下风俗，我们采取的手段是诱饵搜查，也就是充当诱饵的雏见必须装成萝莉少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了找出地下風俗，我們採取的手段是誘餌搜查，也就是充當誘餌的雛見必須裝成蘿莉少女。",
