			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, you didn't do anything wrong. I understand now; that's why you work so hard to protect us all... Thank you so much...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，淳一点错也没有哦。这样啊……因为发生了那样的事情，所以你才想努力保护好我们……真了不起啊……”",
