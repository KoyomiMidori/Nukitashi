		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1471", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"淳之介", "ヒナミ＆淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Hinami & Junnosuke"},
					"“But I'm not a loli!” “But I'm not a pedo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介", "雏见＆淳之介"},
					"“我不是萝莉！”“我不是萝莉控！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介", "雛見＆淳之介"},
