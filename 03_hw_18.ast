		linkback = "0068_00114",
		linknext = "0068_00116",
		line = 1536,
	},
	["0068_00116"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[800] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1465", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah! The illegal sex trade is targeting little girls, right? If we use a little girl as bait, maybe we could learn a bunch of stuff from the Yakuza who come to take her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！地下风俗的目标是小女孩对吧？所以，只要伪装成小女孩，就能从上钩的黑社会那边打听出各种信息！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！地下風俗的目標是小女孩對吧？所以，只要偽裝成小女孩，就能從上鉤的黑社會那邊打聽出各種資訊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00115",
		linknext = "0068_00117",
		line = 1553,
	},
	["0068_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, that's... awfully bold.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那还真是……大胆的作战呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那還真是……大膽的作戰呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00116",
		linknext = "0068_00118",
		line = 1565,
	},
	["0068_00118"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00103", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1466", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sure, but if it works, we could learn where their base is, plus then we'd already have someone on the inside!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过，如果顺利的话，就能知道地下风俗的所在地，说不定还能潜入黑社会们的老巢呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過，如果順利的話，就能知道地下風俗的所在地，說不定還能潛入黑社會們的老巢呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00117",
		linknext = "0068_00119",
		line = 1579,
	},
	["0068_00119"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=6, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0244", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“In that case, I can be our decoy. I already have plenty of experience fighting against them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那么，我来充当诱饵……因为我已经习惯和他们战斗了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那麼，我來充當誘餌……因為我已經習慣和他們戰鬥了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00118",
		linknext = "0068_00120",
		line = 1593,
	},
	["0068_00120"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, that wouldn't work. Too many people are targeting you; it'd be too risky.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那可不行。文乃现在依然被多股势力盯着……作为诱饵太危险了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那可不行。文乃現在依然被多股勢力盯著……作為誘餌太危險了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00119",
		linknext = "0068_00121",
		line = 1605,
	},
	["0068_00121"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00106", path=":fg/fumino_02m/", id=6, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0245", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But I owe you my life. This would allow me to at least partly repay that debt...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是……我得到了许多各位给我的恩情。所以至少要多少让我回报一下……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是……我得到了許多各位給我的恩情。所以至少要多少讓我回報一下……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00120",
		linknext = "0068_00122",
		line = 1619,
	},
	["0068_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You've done more than enough already. Hell, just that tea you make is priceless. You'll more than make it up just by letting us drink that every day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们已经收到很充足的回报了。文乃泡的茶是没人比得过的。光是每天喝着那样的茶，就足够了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們已經收到很充足的回報了。文乃泡的茶是沒人比得過的。光是每天喝著那樣的茶，就足夠了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00121",
		linknext = "0068_00123",
		line = 1631,
	},
	["0068_00123"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0246", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But if not me, then who will be the decoy...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是……那样的话，诱饵是……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是……那樣的話，誘餌是……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00122",
		linknext = "0068_00124",
		line = 1643,
	},
	["0068_00124"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=3, size=12.5, time=175, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1467", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hehehe! I thought you might ask! We just happen to have the ideal candidate right here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哼哼哼——！不用担心！这里不是有个适任者吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哼哼哼——！不用擔心！這裡不是有個適任者嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00123",
		linknext = "0068_00125",
		line = 1658,
	},
	["0068_00125"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00114", path=":fg/fumino_02m/", id=6, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
