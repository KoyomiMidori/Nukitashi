		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1444", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“All right, Tachibana, it's ready. Would you mind bringing it to the table?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好……做好了喔，橘君。能帮我拿到桌子上吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好……做好了喔，橘君。能幫我拿到桌子上嗎？」",
					{"rt2"},
				},
			},
		},
		linknext = "0068_00002",
		line = 22,
	},
	["0068_00002"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sure thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00001",
		linknext = "0068_00003",
		line = 34,
	},
	["0068_00003"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I pick up the tray carrying Wata's homemade breakfast and carry it to the dining table.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把渡酱做的早餐放在盘子里，端到餐桌上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我把渡醬做的早餐放在盤子裡，端到餐桌上。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00002",
		linknext = "0068_00004",
		line = 46,
	},
	["0068_00004"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bacon, eggs, frozen sausages, and miso soup with tofu.",
					{"rt2"},
				},
			},
			cn = {
				{
					"培根鸡蛋，冷冻香肠，还有豆腐味增汤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"培根雞蛋，冷凍香腸，還有豆腐味噌湯。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00003",
		linknext = "0068_00005",
		line = 57,
	},
	["0068_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ooh, this looks good.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“早餐看起来好好吃啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「早餐看起來好好吃啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00004",
		linknext = "0068_00006",
		line = 68,
	},
	["0068_00006"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00115", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1445", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ehehe, thanks. Ever since I've been looking after Asane, I had Mom teach me lots of things to cook.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿，谢谢你。自从开始照顾麻沙音酱，妈妈教了我很多东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿，謝謝你。自從開始照顧麻沙音醬，媽媽教了我很多東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00005",
		linknext = "0068_00007",
		line = 81,
	},
	["0068_00007"] = {
		{"fgact", ch="ヒナミ", id=5, act="移動", x=400, y=0, time=500},
		{"fg", file="asane_02m_00007", file1="asane_02m_00105", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1132", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mmm... what's this? Something smells nice. I thought we finished all of Nanase's prepared meals...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呜呜……怎么……好香啊……奈奈濑同学做的菜应该都被我吃得一干二净了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗚嗚……怎麼……好香啊……奈奈瀨同學做的菜應該都被我吃得一乾二淨了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00006",
		linknext = "0068_00008",
		line = 96,
	},
	["0068_00008"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1446", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Morning, Asane. Breakfast is ready if you'd like to join us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“早上好，麻沙音酱。太好了，要开始吃早饭了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「早啊麻沙音醬。太好了，要開始吃早飯了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00007",
		linknext = "0068_00009",
		line = 110,
	},
	["0068_00009"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look who's up before noon for once. I'm surprised your first words haven't been bitching about how no one lets you sleep in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“起得真早啊。平常这时间就算叫醒你你也在发牢骚呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「起得真早啊。平常這時間就算叫醒你你也在發牢騷呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00008",
		linknext = "0068_00010",
		line = 122,
	},
	["0068_00010"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00115", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1133", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, uh... Wata's, like, always lecturing me about how terrible it is to always stay up late. I've been nagged into a healthier lifestyle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——那个啥，渡酱总是唠叨我不要熬夜……虽然我不怎么情愿，但一直被强迫着要过健康的生活……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊——那個啥，渡醬總是嘮叨我不要熬夜……雖然我不怎麼情願，但一直被強迫著要過健康的生活……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00009",
		linknext = "0068_00011",
		line = 136,
	},
	["0068_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And that's a bad thing because...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“健康是好事吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「健康是好事吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00010",
		linknext = "0068_00012",
		line = 148,
	},
	["0068_00012"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00116", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1134", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I mean, yeah, my skin is better, but at this rate I'll never be able to take care of myself, with all this pampering.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“才不是……托她的福，最近气色好而且没有倦意……这样的话，就不能让哥哥疼我了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「才不是……托她的福，最近氣色好而且沒有倦意……這樣的話，就不能讓哥哥疼我了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00011",
		linknext = "0068_00013",
		line = 162,
	},
	["0068_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I guess I could take one for the team and eat your breakfast for you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“信不信为了让你不健康我把你早饭全吃了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「信不信為了讓你不健康我把你早飯全吃了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00012",
