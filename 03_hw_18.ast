					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's weird. Like, she was a total loli before, right? Has she been looking more mature since we started going out?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好奇怪啊，以前确实很萝莉的……难道是因为恋爱了才变得成熟……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好奇怪啊，以前確實很蘿莉的……難道是因為戀愛了才變得成熟……？」",
					{"rt2"},
				},
			},
		},
