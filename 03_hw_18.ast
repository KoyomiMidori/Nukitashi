	["0068_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Isn't the confession supposed to come first? Then you ask to call her by her first name, and I think the 'stay with me forever' usually comes a bit later.",
					{"rt2"},
				},
			},
			cn = {
				{
					"喊名字，说这种事情——通常都是在告白之后进行的——我有这种感觉。",
