			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, wait... What if we have a girl and she ends up with big boobs!? It would make me feel unfit to be a mom... Waaah, what should we do, Jun!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哈……要是生了女孩，比我还巨乳怎么办……！？要是我嫉妒了，是不是就不够格当母亲了……？哇——怎么办啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哈……要是生了女孩，比我還巨乳怎麼辦……！？要是我嫉妒了，是不是就不夠格當母親了……？哇——怎麼辦啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00226",
		linknext = "0068_00228",
		line = 2941,
	},
	["0068_00228"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just cool your jets a bit. You're jumping the gun a bit, don't you think? We haven't even... uh... done THAT... yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“镇、镇定点雏见……别说要生孩子了，我们就连那之前的那个……都还没做过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「鎮、鎮定點雛見……別說要生孩子了，我們就連那之前的那個……都還沒做過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00227",
		linknext = "0068_00229",
		line = 2953,
	},
	["0068_00229"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00201", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1484", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah... y-you're right! We can't have a baby if we don't even have sex first!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……也、也对！不和淳君做爱的话，连小孩都生不了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……也、也對！不和淳君做愛的話，連小孩都生不了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00228",
		linknext = "0068_00230",
		line = 2967,
	},
	["0068_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Damn, she really just came out and said it, didn't she? This girl's out here dropping bombshells left and right like a damn terrorist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么这孩子的发言每句都这么爆炸！？恐怖分子吗！？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼這孩子的發言每句都這麼爆炸！？恐怖分子嗎！？",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00229",
		linknext = "0068_00231",
		line = 2977,
	},
	["0068_00231"] = {
		{"text"},
		text = {
