	},
	["0068_00140"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase1899", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“All right, Misaki, that's enough. Still, though, Jun and Wata, eh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好了好了美岬，放过他们吧……不过没想到……淳和渡酱会……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好了好了美岬，放過他們吧……不過沒想到……淳和渡醬會……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00139",
		linknext = "0068_00141",
		line = 1874,
	},
	["0068_00141"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=1, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1900", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, that checks out. Jun's a reckless idiot, so a girl like Wata offsets him pretty well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……我觉得挺般配的。淳有些鲁莽的地方……如果是像渡酱这样的女孩，一定不会错的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……我覺得挺般配的。淳有些魯莽的地方……如果是像渡醬這樣的女孩，一定不會錯的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00140",
		linknext = "0068_00142",
		line = 1889,
	},
	["0068_00142"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase looks slightly wistfully at Hinami. Her look is admiring, but also a bit sad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑凝视着雏见的瞳孔里，流露出一种乡愁般的温柔色彩——然而，却也有些寂寞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨凝視著雛見的瞳孔裡，流露出一種鄉愁般的溫柔色彩——然而，卻也有些寂寞。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00141",
		linknext = "0068_00143",
		line = 1901,
	},
	["0068_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must have a soft spot for Hinami, like a mom watching her daughter go off and get married.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为奈奈濑一直都很疼爱雏见，所以应该有各种想法吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為奈奈瀨一直都很疼愛雛見，所以應該有各種想法吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00142",
		linknext = "0068_00144",
		line = 1911,
	},
	["0068_00144"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00107", path=":fg/fumino_02m/", id=6, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0248", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I would also like to express my congratulations and best wishes for the happy couple.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“两位的良缘……我也由衷地祝贺您们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「兩位的良緣……我也由衷地祝賀您們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00143",
		linknext = "0068_00145",
		line = 1925,
	},
	["0068_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
