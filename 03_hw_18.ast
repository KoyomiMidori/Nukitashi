	["0068_00166"] = {
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00120", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=5000, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0438", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, indubitably! What an amazing word! W-Would you mind if I nicked that for myself!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“原来原来……！你还有那么可爱的隐藏口头禅吗……！我、我可以模仿吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「原來原來……！你還有那麼可愛的隱藏口頭禪嗎……！我、我可以模仿嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00165",
		linknext = "0068_00167",
		line = 2204,
	},
	["0068_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My head's killing me... Somebody remind me what we were talking about again?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“头好痛……刚刚说了什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「頭好痛……剛剛說了什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00166",
		linknext = "0068_00168",
		line = 2216,
	},
	["0068_00168"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1472", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Umm... It was because we mentioned we started going out, right...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……我想应该是说了淳君和我开始交往了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……我想應該是說了淳君和我開始交往了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00167",
		linknext = "0068_00169",
		line = 2230,
	},
	["0068_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that's right...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，对了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，對了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00168",
		linknext = "0068_00170",
		line = 2241,
	},
	["0068_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In any case, progress has been made. We've got the shell of a plan, and everyone knows we're going out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"报告已经结束了，方针也定下来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"報告已經結束了，方針也定下來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00169",
		linknext = "0068_00171",
		line = 2251,
	},
	["0068_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I felt it would be best to nip that discussion in the bud, lest our resident background fatty get carried away and go any further off the rails.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再继续说下去的话，只会让站在右边的不知道是路人还是胖子的不明角色得意地说出欠揍的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再繼續說下去的話，只會讓站在右邊的不知道是路人還是胖子的不明角色得意地說出欠揍的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00170",
		linknext = "0068_00172",
		line = 2261,
	},
	["0068_00172"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aaaaanyway, back on topic. Let's discuss Hinami's sting plan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之——今后就按照雏见所说的诱饵调查路线进行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之——今後就按照雛見所說的誘餌調查路線進行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00171",
		linknext = "0068_00173",
		line = 2274,
	},
	["0068_00173"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
