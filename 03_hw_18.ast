					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“R-Really? Ehehe... That's a little embarrassing, but no matter how many times you say you love me, it always makes me happy... Go on, keep talking!”",
					{"rt2"},
