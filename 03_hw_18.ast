	["0068_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The feeling of her soft, springy skin on my fingertips makes me feel unusually nervous.",
					{"rt2"},
				},
			},
			cn = {
				{
					"指尖的触感十分柔软——不知为什么，我莫名地紧张了起来。",
