			},
		},
		linkback = "0068_00503",
		linknext = "0068_00505",
		line = 6389,
	},
	["0068_00505"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"About how it all led to me being disgusted with my dick, despising it to the point where it became a potent complex. That's how I ended up how I am now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"年幼时的自己非常厌恶、憎恨这个鸡巴，最后演变成了强烈的自卑感——变成了如今的状态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"年幼時的自己非常厭惡、憎恨這個肉棒，最後演變成了強烈的自卑感——變成瞭如今的狀態。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00504",
		linknext = "0068_00506",
		line = 6399,
	},
	["0068_00506"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I already told Rei this much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——到这里，是对礼前辈说过的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——到這裡，是對禮前輩說過的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00505",
		linknext = "0068_00507",
		line = 6409,
	},
	["0068_00507"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, the next part isn't known to anyone except Asa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后接下来——是对麻沙酱以外的人第一次说起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後接下來——是對麻沙醬以外的人第一次說起。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00506",
		linknext = "0068_00508",
		line = 6419,
	},
	["0068_00508"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all that, I fell into a deep, almost suicidal despair, but I was saved by a kind girl who reached out to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是对生活感到绝望的我，也有愿意对我伸出手的孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是對生活感到絕望的我，也有願意對我伸出手的孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00507",
		linknext = "0068_00509",
		line = 6429,
	},
	["0068_00509"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She tried to reassure me. She told me it was just a physical characteristic, and she tried to help me feel better.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她对我说“那是橘君的个性”，鼓励我，帮助我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她對我說「那是橘君的個性」，鼓勵我，幫助我。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00508",
		linknext = "0068_00510",
		line = 6439,
	},
	["0068_00510"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was the first time I'd ever received anything but ridicule about it.",
