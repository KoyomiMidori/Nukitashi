		{"bgm", file="bgm11", vol=100},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00126", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1897", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But still... Fumino or not, being a decoy will be dangerous. This is the yakuza we're talking about— hard-boiled criminals.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是，要成为诱饵……就算不是文乃也很危险啊……对方可是目无法纪的黑社会哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是，要成為誘餌……就算不是文乃也很危險啊……對方可是目無法紀的黑社會哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00127",
		linknext = "0068_00129",
		line = 1712,
	},
	["0068_00129"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="浮遊横", loop=1, size=12.5, time=300, ease="inout"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1469", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Nah, it'll be fine! Jun will protect me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，没关系的！因为淳君会保护我呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，沒關係的！因為淳君會保護我呀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00128",
		linknext = "0068_00130",
		line = 1727,
	},
	["0068_00130"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00202", file3="misaki_01m_00305", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0430", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Jun!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“淳君！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「淳君！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00129",
		linknext = "0068_00131",
		line = 1742,
	},
	["0068_00131"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1898", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I know Jun has combat training from the SS, but the Yakuza are gonna be a cut above that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……就算淳有在FS训练过，但以黑社会为对手还是太危险了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……就算淳有在FS訓練過，但以黑社會為對手還是太危險了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00130",
		linknext = "0068_00132",
		line = 1756,
	},
	["0068_00132"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1470", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Then I'll protect Jun, too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那就由我来保护淳君啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那就由我來保護淳君啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00131",
		linknext = "0068_00133",
		line = 1770,
	},
	["0068_00133"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00124", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0431", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huuh!? Wh-Wh-What's this...? Could this be... just maybe, or perhaps not...!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶！？这这这、这是……难道、难不成……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸！？這這這、這是……難道、難不成……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00132",
		linknext = "0068_00134",
		line = 1784,
	},
	["0068_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, after that, there's no point in hiding it anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"都被说到这个地步了，也藏不下去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"都被說到這個地步了，也藏不下去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00133",
		linknext = "0068_00135",
		line = 1794,
	},
	["0068_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were kinda planning on telling them anyway.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说到底，这也不是需要对同伴隐瞒的事情。",
