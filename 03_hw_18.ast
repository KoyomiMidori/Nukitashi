				{"vo", file="fumino0251", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Oh, no, I mean... umm... I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“啊，不……呃……原来如此，原来如此……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「啊，不……呃……原來如此，原來如此……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00164",
		linknext = "0068_00166",
