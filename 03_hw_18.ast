		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="eyecatch2_00000", x=0, y=0, path=":bg/", lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"ex", time=1000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg19_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"bgm", file="bgm03", vol=100},
		{"bg", id=1, file="bg19_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1473", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sigh... I know it was my idea, but now I'm not sure how I feel about it. I'm not a loli, but I'll have to pretend to be one if I want to be our decoy... siiiigh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唉……可是太复杂了。虽然不是萝莉，但是为了充当诱饵，必须要变得像萝莉……唉——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唉……可是太複雜了。雖然不是蘿莉，但是為了充當誘餌，必須要變得像蘿莉……唉——」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00172",
		linknext = "0068_00174",
		line = 2324,
	},
	["0068_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How many times has she sighed now?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这句台词，这已经是第几次听到了呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這句臺詞，這已經是第幾次聽到了呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00173",
		linknext = "0068_00175",
		line = 2334,
	},
	["0068_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's been mumbling to herself about that and sighing over and over on our way home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从回家的路上到现在，她一直重复说着同样的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從回家的路上到現在，她一直重複說著同樣的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00174",
		linknext = "0068_00176",
		line = 2344,
	},
	["0068_00176"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know it's probably a bit late to be asking you this now, but... why does being called a loli bother you so much?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然事到如今了……但我还是想问，是不是萝莉有让你那么在意吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然事到如今了……但我還是想問，是不是蘿莉有讓你那麼在意嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00175",
		linknext = "0068_00177",
		line = 2356,
	},
	["0068_00177"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00116", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1474", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Why wouldn't it bother me!? Even more since I'm your girlfriend now. Doesn't it bother you to know they think you're dating a loli?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“在意啊！而且我都成为淳君的女朋友了，那就更不用说了……如果女朋友被误认为是萝莉的话，会让其他人对淳君有不好的印象啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「在意啊！而且我都成為淳君的女朋友了，那就更不用說了……如果女朋友被誤認為是蘿莉的話，會讓其他人對淳君有不好的印象啦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00176",
		linknext = "0068_00178",
		line = 2370,
	},
	["0068_00178"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've got more important things to worry about than what others think of me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我可不介意别人怎么想哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我可不介意別人怎麼想哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00177",
		linknext = "0068_00179",
		line = 2382,
	},
	["0068_00179"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1475", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You really think so? What if they think you're a pedo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……是这样吗？真的？会让人觉得是萝莉控哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……是這樣嗎？真的？會讓人覺得是蘿莉控哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00178",
		linknext = "0068_00180",
		line = 2396,
	},
	["0068_00180"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't care what they think. I know I'm not a pedo, so why should it bother me if some others think I am?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他们怎么想都行。不管别人怎么想，事实上我并不是萝莉控。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他們怎麼想都行。不管別人怎麼想，事實上我並不是蘿莉控。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00179",
		linknext = "0068_00181",
		line = 2408,
	},
	["0068_00181"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's not why I fell in love with you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我……喜欢的是雏见的心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我……喜歡的是雛見的心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00180",
		linknext = "0068_00182",
		line = 2420,
	},
	["0068_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wow, I didn't think that through before I said it. Was it too cheesy?",
					{"rt2"},
				},
			},
			cn = {
				{
