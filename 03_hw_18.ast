		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it's just... is it just me, or does she look more mature than before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是的……怎么说呢……雏见看起来很成熟。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是的……怎麼說呢……雛見看起來很成熟。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00288",
		linknext = "0068_00290",
		line = 3720,
	},
	["0068_00290"] = {
