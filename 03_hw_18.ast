	["0068_00308"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00116", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1494", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Frig it, I'm just a grown-ass lady, and no spring chicken, and past my prime, and reeking of adult pheromones anyway...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“反正我年纪大了，又不年轻，连童心都忘记了，还散发出大人的霍尔蒙……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「反正我年紀大了，又不年輕，連童心都忘記了，還散發出大人的霍爾蒙……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00307",
		linknext = "0068_00309",
		line = 3993,
	},
	["0068_00309"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That sounds like something the bizarro version of you would say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“平常这么说你明明很高兴的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「平常這麼說你明明很高興的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00308",
		linknext = "0068_00310",
		line = 4005,
	},
	["0068_00310"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00106", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1495", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I know... Like, I'm happy to know I seem grown-up now and all, but... Right now, I'm supposed to be putting on a childish front here...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是没错……虽然被说成熟我很开心，但是现在……要像个小孩子才行啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是沒錯……雖然被說成熟我很開心，但是現在……要像個小孩子才行啊……」",
					{"rt2"},
				},
			},
		},
