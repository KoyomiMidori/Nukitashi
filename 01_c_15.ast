	["0016_00215"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Qué tenemos aquí... ¿Es como un gel?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是……什么，看起来像是凝胶状的液体……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是……什麼，看起來像是凝膠狀的液體……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00214",
		linknext = "0016_00216",
		line = 2930,
	},
	["0016_00216"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=100},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=500},
		{"text"},
		delay = {
			[8500] = {
				{"se", id=0, loop=0, file="se_b009", delay2=8500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0530", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es una nueva sustancia llamada d10o. Normalmente está floja, pero si recibe un golpe fuerte, las moléculas se juntan y se pone dura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“据说是最近改良的d10o，平常像这样软绵绵的，但当它受到强烈冲击时，分子会结合然后变硬……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「據說是最近改良的d10o，平常像這樣軟綿綿的，但當它受到強烈衝擊時，分子會結合然後變硬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00215",
		linknext = "0016_00217",
		line = 2945,
	},
	["0016_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oh, vaya. No sabía que existía algo así.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来如此，这个世界上居然有这种东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來如此，這個世界上居然有這種東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00216",
		linknext = "0016_00218",
		line = 2955,
	},
	["0016_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y en forma de gel, se le puede dar cualquier forma...",
					{"rt2"},
