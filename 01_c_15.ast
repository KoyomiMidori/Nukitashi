		{"fgact", ch="美岬", id=6, act="移動", x=-400, y=0, time=500},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=800, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0321", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Anyway, Misaki-chan. I guess you must've gone to pretty great lengths to avoid sex, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是美岬酱非常想逃离色情的事情对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是美岬醬非常想逃離色情的事情對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00092",
		linknext = "0016_00094",
		line = 1332,
	},
	["0016_00094"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0322", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So I'm guessing Misaki-chan must have a pretty big reason for doing that yourself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那美岬酱一定也有无论如何都不想做爱的重要的理由吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那美岬醬一定也有無論如何都不想做愛的重要的理由吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00093",
		linknext = "0016_00095",
