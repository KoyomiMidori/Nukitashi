		linkback = "0016_00130",
		linknext = "0016_00132",
		line = 1847,
	},
	["0016_00132"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0046", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, well, I knew that you were my senpai... it's just that I heard about you skipping years...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，我知道你是前辈……但听说是跳级来的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，我知道你是前輩……但聽說是跳級來的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00131",
		linknext = "0016_00133",
		line = 1861,
	},
	["0016_00133"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0330", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Are the rumors that widespread!? I am your senpai! I am older than you! I am the elder in this conversation!”",
					{"rt2"},
				},
			},
			cn = {
				{
