	["0016_00171"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_01m_00001", file1="asane_01m_00113", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0522", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Heh heh... Oh, Nanaseee... Didja find anything interesting today?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嘿嘿，奈奈濑同学……有什么有趣的内容吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嘿嘿，奈奈瀨同學……有什麼有趣的內容嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00170",
		linknext = "0016_00172",
		line = 2361,
	},
	["0016_00172"] = {
		{"se", id=0, loop=0, file="se_a122"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0517", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Let's see... Huh, apparently an SHO guard was found unconscious on the beach this morning.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我看看……咦，据说今天早上在海滩上发现了昏倒的SHO警卫。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我看看……咦，據說今天早上在海灘上發現了昏倒的SHO警衛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00171",
		linknext = "0016_00173",
		line = 2374,
	},
	["0016_00173"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0518", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“When asked for comment, the guard responded, 'That's never happened before.' An investigation to determine possibility of criminal motive is underway... That's the meat of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“SHO警卫对采访评论说‘第一次碰到那样的’，目前正在调查是否有任何事件的可能性……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「SHO警衛對採訪評論說『第一次碰到那樣的』，目前正在調查是否有任何事件的可能性……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00172",
		linknext = "0016_00174",
		line = 2386,
	},
	["0016_00174"] = {
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=500},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=400, y=0, time=500},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=-800, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0052", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“'That's never happened before'? What did she mean by that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“‘第一次碰到那样的？’到底是什么意思呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「『第一次碰到那樣的？』到底是什麼意思呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00173",
		linknext = "0016_00175",
		line = 2402,
	},
	["0016_00175"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0519", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, at any rate, I'm not seeing anything about Jun in the news, so we're in the clear for now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“看起来，淳的事情没有成为新闻呢。可以暂时放心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「看起來，淳的事情沒有成為新聞呢。可以暫時放心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00174",
		linknext = "0016_00176",
		line = 2416,
	},
	["0016_00176"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00175",
		linknext = "0016_00177",
		line = 2434,
	},
	["0016_00177"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0332", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, hey Tachibana-kun. Tachibana-kun, you were the one who fought those bad guys and that SHO guard, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，橘君。橘君也有和坏人，和SHO警卫战斗过对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，橘君。橘君也有和壞人，和SHO警衛戰鬥過對嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00176",
		linknext = "0016_00178",
		line = 2448,
	},
	["0016_00178"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0053", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Plus, when you ran into me, you were kind of a wreck, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我碰到你的时候……你已经整个人破烂不堪了不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我碰到你的時候……你已經整個人破爛不堪了不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00177",
		linknext = "0016_00179",
		line = 2461,
	},
	["0016_00179"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0520", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, I'm kinda curious myself. You didn't have any of your little spy gadgets or anything, so how'd you manage to beat them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我也有在意过。你不是没带间谍道具吗？怎么打倒的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我也有在意過。你不是沒帶間諜道具嗎？怎麼打倒的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00178",
		linknext = "0016_00180",
		line = 2474,
	},
	["0016_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everyone stares me down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家的视线集中到我这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家的視線集中到我這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00179",
		linknext = "0016_00181",
		line = 2484,
	},
	["0016_00181"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
