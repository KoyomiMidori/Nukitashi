	},
	["0016_00133"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0330", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Tanto han esparcido esos rumores?! ¡Soy la senpai! ¡Soy mayor que tú! ¡Soy la mayor en esta conversación!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“居然连你也这么听说！？我可是真正的前辈哦！比你大哦！是姐姐哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「居然連你也這麼聽說！？我可是真正的前輩哦！比你大哦！是姐姐哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00132",
		linknext = "0016_00134",
		line = 1876,
	},
	["0016_00134"] = {
