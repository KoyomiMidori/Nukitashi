			},
			ja = {
				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“Uh, bueno... No sabía cómo entrar a la base, así que seguí a Tachibana-san hasta aquí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“不、不是……因为我不知道怎么来基地，所以我是跟着橘君一起进来的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「不、不是……因為我不知道怎麼來基地，所以我是跟著橘君一起進來的……」",
					{"rt2"},
