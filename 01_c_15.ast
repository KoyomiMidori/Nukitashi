	},
	["0016_00117"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0509", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Encima de tu nivel? Yo no creo que mi figura sea nada del otro mundo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“有很好吗……？我的身材也不是那种非常好的啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「有很好嗎……？我的身材也不是那種非常好的啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00116",
		linknext = "0016_00118",
		line = 1648,
	},
	["0016_00118"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0518", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Creo que yo tengo una complexión más o menos normal...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我也是……觉得自己很一般……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我也是……覺得自己很一般……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00117",
		linknext = "0016_00119",
		line = 1661,
	},
	["0016_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sinceramente, no creo que esta isla sea especial en ese aspecto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从我看来也不觉得这个岛很特别啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從我看來也不覺得這個島很特別啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00118",
		linknext = "0016_00120",
		line = 1673,
	},
	["0016_00120"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0324", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun, tú ves a Nanase-chan y Asane-chan todos los \ndías, ¡así que tu percepción está alterada!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君是因为看惯了奈奈濑同学和麻沙音同学感官变奇怪了啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君是因為看慣了奈奈瀨同學和麻沙音同學感官變奇怪了啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00119",
		linknext = "0016_00121",
		line = 1688,
	},
	["0016_00121"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0325", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Y es en serio! ¿Cinturas delgadas como un lápiz? ¿Pechos y traseros voluptuosos? ¡Esta isla es el único lugar donde todos comparten esas características!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“听好了哦！四处都是腰又细，胸和屁股还这么大的人的地方，只有这个岛哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「聽好了哦！四處都是腰又細，胸和屁股還這麼大的人的地方，只有這個島哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00120",
		linknext = "0016_00122",
		line = 1703,
	},
	["0016_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero Asa-chan y yo no nacimos en esta isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但，我和麻沙酱原本不是这个岛上的人哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但，我和麻沙醬原本不是這個島上的人哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00121",
		linknext = "0016_00123",
		line = 1715,
	},
	["0016_00123"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0510", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Y yo soy una estudiante de tranferencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我也是转校生啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我也是轉學生啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00122",
		linknext = "0016_00124",
		line = 1729,
	},
	["0016_00124"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0519", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Y actualmente tenemos una proporción de 2 x 3 de tetonas en nuestra organización.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“都这样了，我们还有2／3是巨乳……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「都這樣了，我們還有2／3是巨乳……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00123",
		linknext = "0016_00125",
		line = 1742,
	},
	["0016_00125"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0326", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Qu...?! ¡U-Uuugh...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇啊……！？呜呜，呜呜呜……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇啊……！？嗚嗚，嗚嗚嗚……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00124",
		linknext = "0016_00126",
		line = 1759,
	},
	["0016_00126"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0044", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡P-Pero en serio, tener tetas no es una ventaja! Aunque sí te amortiguan una caída y son bastante prácticas para apoyar la tablet o algo así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但、但是光胸大也没什么用哦……！就只能在摔倒的时候用来缓冲一下，还有在胸上摆平板之类的而已……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但、但是光胸大也沒什麼用哦……！就只能在摔倒的時候用來緩衝一下，還有在胸上擺平板之類的而已……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00125",
		linknext = "0016_00127",
		line = 1773,
	},
	["0016_00127"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0327", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¡Muerte a las tetazas!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“巨乳去死！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「巨乳去死！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00126",
		linknext = "0016_00128",
		line = 1790,
	},
	["0016_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Basta. Una loli como tú no puede decir eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不可以哦渡酱，贫乳萝莉怎么能说出这么粗鲁的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不可以哦渡醬，貧乳蘿莉怎麼能說出這麼粗魯的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00127",
		linknext = "0016_00129",
		line = 1802,
	},
	["0016_00129"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0328", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Pero no soy una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00128",
		linknext = "0016_00130",
		line = 1817,
	},
	["0016_00130"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0045", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Qué? ¡¿En serio no eres una loli?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶，不是萝莉吗……！？”",
