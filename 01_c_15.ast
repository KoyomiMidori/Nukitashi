	["0016_00047"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0501", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡¿Eh, cómo?! ¡¿Cuánto tiempo llevabas detrás de Jun?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啥，什么！？什么时候在淳背后的……！？”",
