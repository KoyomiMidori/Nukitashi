		linknext = "0016_00158",
		line = 2187,
	},
	["0016_00158"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why didn't you say anything, dammit!? I went and made a logo and everything!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么你们不告诉我啊！？我连标志都做好了哦！？”",
