				{
					"Parece estar revisando las últimas noticias de la Isla Seiran.",
					{"rt2"},
				},
			},
			cn = {
				{
					"似乎是要查看青蓝岛的新闻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"似乎是要查看青藍島的新聞。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00168",
		linknext = "0016_00170",
		line = 2336,
	},
	["0016_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
