		linkback = "0016_00169",
		linknext = "0016_00171",
		line = 2346,
	},
	["0016_00171"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_01m_00001", file1="asane_01m_00113", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0522", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Jeje... Nanase-saan... ¿Viste algo interesante hoy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嘿嘿，奈奈濑同学……有什么有趣的内容吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嘿嘿，奈奈瀨同學……有什麼有趣的內容嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00170",
		linknext = "0016_00172",
		line = 2361,
	},
	["0016_00172"] = {
		{"se", id=0, loop=0, file="se_a122"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0517", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“A ver... Mmm, al parecer, esta mañana encontraron inconsciente en la playa a una guardia de la OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我看看……咦，据说今天早上在海滩上发现了昏倒的SHO警卫。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我看看……咦，據說今天早上在海灘上發現了昏倒的SHO警衛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00171",
		linknext = "0016_00173",
		line = 2374,
	},
	["0016_00173"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0518", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Cuando se le pidió su opinión, la guardia respondió: Eso nunca había pasado antes. Se está llevando a cabo una investigación para determinar la posibilidad de que haya motivos criminales... Eso es lo que pasó.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“SHO警卫对采访评论说‘第一次碰到那样的’，目前正在调查是否有任何事件的可能性……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「SHO警衛對採訪評論說『第一次碰到那樣的』，目前正在調查是否有任何事件的可能性……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00172",
		linknext = "0016_00174",
		line = 2386,
	},
	["0016_00174"] = {
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=500},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=400, y=0, time=500},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00128", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=-800, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0052", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Que nunca pasó? ¿A qué se refería?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“‘第一次碰到那样的？’到底是什么意思呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「『第一次碰到那樣的？』到底是什麼意思呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00173",
		linknext = "0016_00175",
		line = 2402,
	},
	["0016_00175"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0519", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, sea como sea, no veo nada sobre Jun en las noticias, así que por ahora estamos a salvo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“看起来，淳的事情没有成为新闻呢。可以暂时放心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「看起來，淳的事情沒有成為新聞呢。可以暫時放心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00174",
		linknext = "0016_00176",
		line = 2416,
	},
	["0016_00176"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
