			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, but... Wouldn't that also mean that if there's no love, then it's not sex?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个……呃……这个句子的意思应该是‘没有爱就不是做爱’吧？”",
