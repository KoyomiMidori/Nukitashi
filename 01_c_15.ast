	},
	["0016_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, what!? So you came down in the elevator with me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶，那你和我一起坐电梯了！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸，那你和我一起坐電梯了！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00048",
		linknext = "0016_00050",
		line = 710,
	},
	["0016_00050"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0024", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "???"},
					"“Yes. I tried talking to you, but... you really didn't seem to notice me the whole time...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬", "？ ？ ？"},
					"“是的。我有向你打招呼……但你好像没注意到……所以就那样，一直……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬", "？？？"},
					"「是的。我有向你打招呼……但你好像沒注意到……所以就那樣，一直……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00049",
		linknext = "0016_00051",
		line = 724,
	},
	["0016_00051"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
