			},
		},
		text = {
			vo = {
				{"vo", file="misaki0038", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Cómo lo digo... Es lo que me permite estar intacta, pero \ntambién me hace sentir un poco insegura... Ajaja.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎么说……因为这样，我才能逃跑到现在，但心情却有些复杂呢……啊哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「怎麼說……因為這樣，我才能逃跑到現在，但心情卻有些複雜呢……啊哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00085",
		linknext = "0016_00087",
		line = 1246,
	},
	["0016_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siento una gran culpa al ver a una chica tan reservada como ella, tan diferente de toda la gente bulliciosa de la isla, \nesforzándose por esbozar una amarga sonrisa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不像岛上那些耀眼的女孩，懦弱的女孩苦笑的样子，让我有一种强烈的内疚感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不像島上那些耀眼的女孩，懦弱的女孩苦笑的樣子，讓我有一種強烈的內疚感。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00086",
		linknext = "0016_00088",
		line = 1256,
	},
	["0016_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me siento mal por lo que hice, pero creo que ella es... bastante encantadora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为我们做了不好的事情，还有……她看起来非常率真可爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為我們做了不好的事情，還有……她看起來非常率真可愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00087",
