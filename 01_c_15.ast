			},
		},
		linkback = "0016_00142",
		linknext = "0016_00144",
		line = 2006,
	},
	["0016_00144"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can't accept perverted sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我无法原谅变态做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我無法原諒變態做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00143",
		linknext = "0016_00145",
		line = 2018,
	},
	["0016_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm gonna escape from the unmitigated evil of those assholes and their forceful perverted sex, and live for true love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“逃离巨大的恶——也就是那群人强制大家进行的变态做爱，在真正的爱中生活……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「逃離巨大的惡——也就是那群人強制大家進行的變態做愛，在真正的愛中生活……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00144",
		linknext = "0016_00146",
		line = 2030,
	},
	["0016_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And I will lead all other people who feel the same way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了成为与我们有共同想法的人们的先锋。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了成為與我們有共同想法的人們的先鋒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00145",
		linknext = "0016_00147",
		line = 2041,
	},
	["0016_00147"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's what our organization — the NLNS — is all about. No love, no sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这就是我们‘No Love，No Sex’——NLNS的存在意义。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這就是我們『No Love，No Sex』——NLNS的存在意義。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00146",
		linknext = "0016_00148",
		line = 2053,
	},
	["0016_00148"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0048", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um... So that's what 'NLNS' stands for, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……NLNS，是这个意思吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸……NLNS，是這個意思嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00147",
		linknext = "0016_00149",
		line = 2068,
	},
	["0016_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. It's a name crystallizing our principle that sex without love is absolutely inconceivable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。‘没有爱就不可能做爱’的意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。『沒有愛就不可能做愛』的意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00148",
		linknext = "0016_00150",
		line = 2080,
	},
	["0016_00150"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00110", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0049", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
