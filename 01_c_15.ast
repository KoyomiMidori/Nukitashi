					"「有很好嗎……？我的身材也不是那種非常好的啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00116",
		linknext = "0016_00118",
		line = 1648,
	},
	["0016_00118"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0518", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I think I'm more or less normally built myself...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我也是……觉得自己很一般……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我也是……覺得自己很一般……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00117",
		linknext = "0016_00119",
		line = 1661,
	},
	["0016_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Honestly, I don't think this island is anything special in that regard.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从我看来也不觉得这个岛很特别啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從我看來也不覺得這個島很特別啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00118",
		linknext = "0016_00120",
		line = 1673,
	},
	["0016_00120"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0324", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well Tachibana-kun, you get to see Nanase-chan and Asane-chan every day, so his perception is messed up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君是因为看惯了奈奈濑同学和麻沙音同学感官变奇怪了啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君是因為看慣了奈奈瀨同學和麻沙音同學感官變奇怪了啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00119",
		linknext = "0016_00121",
		line = 1688,
	},
	["0016_00121"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0325", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Like, real talk! Pencil-thin waists? Voluptuous breasts and asses? It's only on this island that everyone has those traits in common!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“听好了哦！四处都是腰又细，胸和屁股还这么大的人的地方，只有这个岛哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「聽好了哦！四處都是腰又細，胸和屁股還這麼大的人的地方，只有這個島哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00120",
		linknext = "0016_00122",
		line = 1703,
	},
	["0016_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But Asa-chan and I weren't born on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但，我和麻沙酱原本不是这个岛上的人哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但，我和麻沙醬原本不是這個島上的人哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00121",
		linknext = "0016_00123",
		line = 1715,
	},
	["0016_00123"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0510", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“And I'm a transfer student.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我也是转校生啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我也是轉學生啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00122",
		linknext = "0016_00124",
		line = 1729,
	},
	["0016_00124"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0519", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“And we currently have a two for three hooter-haver ratio in our organization.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“都这样了，我们还有2／3是巨乳……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「都這樣了，我們還有2／3是巨乳……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00123",
		linknext = "0016_00125",
		line = 1742,
	},
	["0016_00125"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
