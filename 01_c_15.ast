					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, let's not get into that... But anyway, I really think you should save that for when you have a special someone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但哥哥觉得完全不行……所以说，这还是留着给重要的人吧。”",
