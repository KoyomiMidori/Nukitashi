		},
		linkback = "0016_00180",
		linknext = "0016_00182",
		line = 2496,
	},
	["0016_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I raise a finger and avoid the question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不说清楚，竖起食指。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不說清楚，豎起食指。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00181",
		linknext = "0016_00183",
		line = 2506,
	},
	["0016_00183"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
