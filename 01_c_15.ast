					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But she's pretty late... I told her to come to the base right after school let out.”",
					{"rt2"},
				},
			},
			cn = {
