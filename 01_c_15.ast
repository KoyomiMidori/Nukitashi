	},
	["0016_00126"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0044", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“B-But really, just having tits isn't a perk in itself! Like, they end up cushioning you if you fall down, and they're fairly convenient for resting your tablet or something on...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但、但是光胸大也没什么用哦……！就只能在摔倒的时候用来缓冲一下，还有在胸上摆平板之类的而已……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但、但是光胸大也沒什麼用哦……！就只能在摔倒的時候用來緩衝一下，還有在胸上擺平板之類的而已……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00125",
		linknext = "0016_00127",
		line = 1773,
	},
	["0016_00127"] = {
