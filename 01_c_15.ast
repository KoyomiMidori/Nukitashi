		linkback = "0016_00051",
		linknext = "0016_00053",
		line = 749,
	},
	["0016_00053"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0025", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“Sorry, I basically melt into crowds... I'm terribly plain, so this sort of thing happens all the time. Really, I'm so sorry... Ahaha.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“对不起，我是路人脸……不起眼，所以这很常见……真的……很抱歉……啊哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「對不起，我是路人臉……不起眼，所以這很常見……真的……很抱歉……啊哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00052",
		linknext = "0016_00054",
		line = 763,
	},
