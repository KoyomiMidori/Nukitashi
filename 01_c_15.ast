		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=500},
		{"text"},
		delay = {
			[8500] = {
				{"se", id=0, loop=0, file="se_b009", delay2=8500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0530", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It's a newly developed substance called d10o. Normally, it's all limp like this, but if it receives a hard impact, the molecules combine and it becomes stiff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“据说是最近改良的d10o，平常像这样软绵绵的，但当它受到强烈冲击时，分子会结合然后变硬……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「據說是最近改良的d10o，平常像這樣軟綿綿的，但當它受到強烈衝擊時，分子會結合然後變硬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00215",
		linknext = "0016_00217",
		line = 2945,
	},
