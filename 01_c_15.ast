	},
	["0016_00034"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00114", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I shake my head like an eroge protagonist and Nanase folds her arms.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑像色情游戏的主人公般无奈地摇摇头，把手臂交叉在胸前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨像色情遊戲的主角般無奈地搖搖頭，把手臂交叉在胸前。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00033",
		linknext = "0016_00035",
		line = 509,
	},
	["0016_00035"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0499", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So anyway, Asa-chan told us you took on an SHO guard and then blacked out? How'd you manage to get home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以，根据麻沙酱说的，你和SHO警卫战斗后失去了意识对吧？你是怎么回来的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以，根據麻沙醬說的，你和SHO警衛戰鬥後失去了意識對吧？你是怎麼回來的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00034",
		linknext = "0016_00036",
		line = 526,
	},
	["0016_00036"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, about that. The girl I helped out came back for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，那是——那个我帮助的女孩回来帮我了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，那是——那個我幫助的女孩回來幫我了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00035",
		linknext = "0016_00037",
		line = 538,
	},
	["0016_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She tended to me after I passed out, and she was able to get me back home after she found my student ID in my pocket.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她照顾晕倒的我，看到了我口袋里的学生证，然后把我送到了我家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她照顧暈倒的我，看到了我口袋裡的學生證，然後把我送到了我家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00036",
		linknext = "0016_00038",
		line = 549,
	},
	["0016_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I would've just laid on the beach until morning if she hadn't found me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果没有她，我会一直倒在岛上的海滩到早上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果沒有她，我會一直倒在島上的海灘到早上。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00037",
		linknext = "0016_00039",
		line = 559,
	},
	["0016_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That would've led me to be captured by the SHO for sure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那样的话，我肯定会被SHO抓住。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那樣的話，我肯定會被SHO抓住。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00038",
		linknext = "0016_00040",
		line = 569,
	},
	["0016_00040"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0500", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I see. That certainly makes her a godsend for our organization. So, what's your plan for her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“原来如此，没想到居然是我们团队的救命恩人……所以，那个孩子你打算怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「原來如此，沒想到居然是我們團隊的救命恩人……所以，那個孩子你打算怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00039",
		linknext = "0016_00041",
		line = 581,
	},
	["0016_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
