		linknext = "0016_00135",
		line = 1889,
	},
	["0016_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Deja esas risas tan artificiales, convertirlo en una comedia es cruel.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别笑啊，靠着发笑让人以为在听笑话的做法太残忍了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別笑啊，靠著發笑讓人以為在聽笑話的做法太殘忍了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00134",
		linknext = "0016_00136",
		line = 1901,
	},
	["0016_00136"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00116", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0331", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Uguuu...! Pero soy una senpai... Aunque tenga los pechos más pequeños de todas las chicas de esta sala, y aunque sea \npequeña, sigo siendo una senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜呜呜……我明明是前辈……就算是这群人里唯一的贫乳我也是前辈啊……就算我矮我也是前辈啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚嗚嗚……我明明是前輩……就算是這群人裡唯一的貧乳我也是前輩啊……就算我矮我也是前輩啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00135",
		linknext = "0016_00137",
		line = 1916,
	},
	["0016_00137"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0511", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“A ver. Deja de molestar tanto a Wata-chan. Aunque supongo que en realidad es lo de siempre...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂，你们。别太欺负渡酱了哦？虽然每次都这样——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂，你們。別太欺負渡醬了哦？雖然每次都這樣——」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00136",
		linknext = "0016_00138",
		line = 1930,
	},
	["0016_00138"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=500},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=500},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=500},
		{"text"},
		text = {
