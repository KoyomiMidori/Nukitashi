					name = {"淳之介", "Junnosuke"},
					"“SHIIIIIIIIIT!!!!!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啥！！！！！！？？？？”",
					{"rt2"},
				},
			},
			tw = {
