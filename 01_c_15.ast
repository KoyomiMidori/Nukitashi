	["0016_00153"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0521", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“O sea, si lo interpretaste así, parecería que somos un grupo a favor del sexo pervertido. Algo así como: ¡no hay amor, no hay sexo, no hay problemas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“按照这个理论的话，好像是在推荐‘没有爱的话就不算做爱所以ok！’这种轻率行为的组织……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「按照這個理論的話，好像是在推薦『沒有愛的話就不算做愛所以ok！』這種輕率行為的組織……」",
					{"rt2"},
				},
