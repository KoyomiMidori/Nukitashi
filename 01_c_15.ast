		linkback = "0016_00024",
		linknext = "0016_00026",
		line = 369,
	},
	["0016_00026"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0509", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Por favor, las cosas entre padres e hijas son lo habitual en las colecciones de CGs eróticos! ¡Y ya ni hablemos de lo que pasa con las hermanitas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但在色情CG集中，经常有父亲开发女儿的内容呢……！顺便说一下，妹妹觉得完全ok……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但在色情CG集中，經常有父親開發女兒的內容呢……！順便說一下，妹妹覺得完全ok……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00025",
		linknext = "0016_00027",
		line = 383,
	},
	["0016_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, mejor no hablemos de eso... Pero sí, creo que deberías guardarlo para cuando conozcas a alguien especial.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但哥哥觉得完全不行……所以说，这还是留着给重要的人吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但哥哥覺得完全不行……所以說，這還是留著給重要的人吧。」",
					{"rt2"},
				},
			},
