		},
		linkback = "0016_00183",
		linknext = "0016_00185",
		line = 2563,
	},
	["0016_00185"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I heave a sigh and bury my head in my hands.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后在房间大大地叹了口气，垂下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後在房間大大地嘆了口氣，垂下了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00184",
		linknext = "0016_00186",
		line = 2574,
	},
	["0016_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never would have figured my name for the team could be construed that way...",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到，队伍名居然是那种意思……",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到，隊伍名居然是那種意思……",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00185",
		linknext = "0016_00187",
		line = 2584,
	},
	["0016_00187"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was just thinking of it like, we're a team that believes there's no such thing as sex without love, so we don't have sex that doesn't involve love...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，这是‘没有爱就不是性爱，所以除此之外的做爱都不考虑队伍’……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，這是『沒有愛就不是性愛，所以除此之外的做愛都不考慮隊伍』……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00186",
		linknext = "0016_00188",
		line = 2596,
	},
	["0016_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's what the damn name's SUPPOSED to mean...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是这种意思啦……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是這種意思啦……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00187",
		linknext = "0016_00189",
