	},
	["0016_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I try to convince myself of the validity of my choice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我这么说给自己听，转换心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我這麼說給自己聽，轉換心情。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00188",
		linknext = "0016_00190",
		line = 2617,
	},
	["0016_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But really, I've got better things to do right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"比起这个，我有事情必须要做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"比起這個，我有事情必須要做。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00189",
		linknext = "0016_00191",
		line = 2627,
	},
	["0016_00191"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"fg", file="asane_01m_00003", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0523", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Brooo, there's a little spider in the bathroom, can you kill it...? Alternatively, can you come into the bath with me and wash me from head to toe...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥〜浴室里出现了只小蜘蛛，帮我抓一下〜或者跟我一起洗澡帮我从头洗到尾〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥〜浴室裡出現了隻小蜘蛛，幫我抓一下〜或者跟我一起洗澡幫我從頭洗到尾〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00190",
		linknext = "0016_00192",
		line = 2642,
	},
	["0016_00192"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No killing spiders. They're useful bugs. Also, I think you're more than capable of washing your damn self.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“蜘蛛是益虫所以不可以杀哦。还有自己的身体自己洗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「蜘蛛是益蟲所以不可以殺哦。還有自己的身體自己洗。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00191",
		linknext = "0016_00193",
		line = 2654,
	},
	["0016_00193"] = {
		{"bg", id=1, file="bg18_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0524", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hmm...? What's that? What are you doing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯——那个，在干什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯——那個，在幹什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00192",
		linknext = "0016_00194",
		line = 2669,
	},
	["0016_00194"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This? I was thinking of developing a new weapon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔……我想要开发新武器。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔……我想要開發新武器。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00193",
		linknext = "0016_00195",
		line = 2681,
	},
	["0016_00195"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00128", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0525", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Weapon? It's not a spy gadget this time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“武器……？不是间谍道具？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「武器……？不是間諜道具？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00194",
		linknext = "0016_00196",
		line = 2695,
	},
	["0016_00196"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I already told you to call 'em TAEs... But yeah, this is a combat weapon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请称之为T-A-E ……对，作为战斗手段的武器。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請稱之為T-A-E ……對，作為戰鬥手段的武器。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00195",
		linknext = "0016_00197",
		line = 2707,
	},
	["0016_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That fight yesterday demonstrated just how weak I am.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从昨天的事情中，我意识到自己没有战斗的能力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從昨天的事情中，我意識到自己沒有戰鬥的能力。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00196",
		linknext = "0016_00198",
		line = 2717,
	},
	["0016_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter how much I train my body, I freeze when someone brings out a knife.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论怎么锻炼身体，一旦对方拿出刀子，身体就会紧绷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論怎麼鍛煉身體，一旦對方拿出刀子，身體就會緊繃。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00197",
		linknext = "0016_00199",
		line = 2727,
	},
	["0016_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It just takes one thrust.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果被刺到就完了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果被刺到就完了。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00198",
		linknext = "0016_00200",
		line = 2737,
	},
	["0016_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I'll need to have some kind of weapon on me as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以我们也应该配备一些武器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以我們也應該配備一些武器。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00199",
		linknext = "0016_00201",
		line = 2747,
	},
	["0016_00201"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Though, if it actually looks like a knife or a gun, they'd confiscate that right away at the inspections.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽说是这样，但带着小刀或者手枪的话会被查到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖說是這樣，但帶著小刀或者手槍的話會被查到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00200",
		linknext = "0016_00202",
		line = 2759,
	},
	["0016_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I guess I have to make some weapon that imitates a sex toy?",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然，必须模仿成人用品，但能成为武器的有……",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然，必須模仿成人用品，但能成為武器的有……",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00201",
		linknext = "0016_00203",
		line = 2769,
	},
	["0016_00203"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0526", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Then how about something like a onahole that shoots out an arrow tipped with anesthetic?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那哥哥，可以发射涂着麻醉药弓箭的飞机杯怎么样……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那哥哥，可以發射塗著麻醉藥弓箭的飛機杯怎麼樣……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00202",
		linknext = "0016_00204",
		line = 2783,
	},
	["0016_00204"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hm, that's not a bad idea. But I can't see that having much offensive capability.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，不错，但攻击力可能会有些低……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，不錯，但攻擊力可能會有些低……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00203",
		linknext = "0016_00205",
		line = 2795,
	},
	["0016_00205"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0527", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Then make a whole lot of them, and wrap them around your arms.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那就做一堆然后绑在双臂上。”",
