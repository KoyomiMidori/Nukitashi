			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ahora sí hagámoslo bien... Me llamo Hotori Misaki. Estoy en la clase 2-2. ¡Es un placer conocerlos...!”",
					{"rt2"},
				},
			},
			cn = {
