	["0016_00082"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0036", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“O sea, soy tan básica que si la vida fuera un manga, solo sería un personaje secundario genérico.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我非常不起眼……如果用漫画来讲，基本就是框中角落里的路人女……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我非常不起眼……如果用漫畫來講，基本就是框中角落裡的路人女……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00081",
		linknext = "0016_00083",
		line = 1197,
	},
	["0016_00083"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0037", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Así que si me quedo quieta y no llamo la atención, nadie se fija en mí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“所以我只需要站在那里，除非做了一些奇葩的事情，否则基本是不会被发现的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「所以我只需要站在那裡，除非做了一些奇葩的事情，否則基本是不會被發現的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00082",
		linknext = "0016_00084",
		line = 1209,
	},
	["0016_00084"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um... Bueno, no estamos en posición de poner en duda tu palabra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……我们也不得不相信呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……我們也不得不相信呢……」",
					{"rt2"},
