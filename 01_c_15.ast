					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, uh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是，呃——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是，呃——」",
					{"rt2"},
				},
