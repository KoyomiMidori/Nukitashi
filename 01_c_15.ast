		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=17.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0508", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Jaa, solo escúchala! ¡Le daría a besos a cualquiera! ¡Es una zorra de operaciones psicológicas! ¡Tenemos que echarla de aquí!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啥——！哥哥你看……！她和谁都接吻……！是婊子啊婊子……！必须早点肃清……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啥——！哥哥你看……！她和誰都接吻……！是婊子啊婊子……！必須早點肅清……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00023",
		linknext = "0016_00025",
		line = 357,
	},
	["0016_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
