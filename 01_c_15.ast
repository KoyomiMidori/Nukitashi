	["0016_00177"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0332", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oye, Tachibana-kun. Fuiste tú quien peleó contra ese gente mala y la guardia de la OSS, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，橘君。橘君也有和坏人，和SHO警卫战斗过对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，橘君。橘君也有和壞人，和SHO警衛戰鬥過對嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00176",
		linknext = "0016_00178",
		line = 2448,
	},
	["0016_00178"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0053", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Además, cuando te encontraste conmigo, estabas en aprietos, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我碰到你的时候……你已经整个人破烂不堪了不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我碰到你的時候……你已經整個人破爛不堪了不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00177",
		linknext = "0016_00179",
		line = 2461,
	},
	["0016_00179"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0520", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí, yo también tengo curiosidad. No tenías ninguno de tus pequeños artilugios de espionaje ni nada por el estilo, ¿cómo conseguiste vencerlos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我也有在意过。你不是没带间谍道具吗？怎么打倒的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我也有在意過。你不是沒帶間諜道具嗎？怎麼打倒的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00178",
		linknext = "0016_00180",
		line = 2474,
	},
	["0016_00180"] = {
		{"text"},
		text = {
