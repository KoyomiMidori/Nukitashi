				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Uh, sí, lo mismo digo! ¡Gracias por darme la oportunidad!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……好的，请多多关照……！”",
					{"rt2"},
				},
			},
			tw = {
