					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I seriously didn't...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我真的没注意到……”",
