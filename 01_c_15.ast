					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, bueno, mi cara es tan básica que de alguna manera me salvo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，因为我的脸实在太平庸了，所以没什么事。”",
