			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Por favor, las cosas entre padres e hijas son lo habitual en las colecciones de CGs eróticos! ¡Y ya ni hablemos de lo que pasa con las hermanitas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但在色情CG集中，经常有父亲开发女儿的内容呢……！顺便说一下，妹妹觉得完全ok……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但在色情CG集中，經常有父親開發女兒的內容呢……！順便說一下，妹妹覺得完全ok……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00025",
		linknext = "0016_00027",
		line = 383,
	},
	["0016_00027"] = {
