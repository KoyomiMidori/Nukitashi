		linkback = "0016_00139",
		linknext = "0016_00141",
		line = 1966,
	},
	["0016_00141"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues eso, este es nuestro equipo... Es un placer tenerte a nuestro lado, Hotori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然是这样的团队……但今后请多指教，畔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然是這樣的團隊……但今後請多指教，畔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00140",
		linknext = "0016_00142",
		line = 1979,
	},
	["0016_00142"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
			},
		},
