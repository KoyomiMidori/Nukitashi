					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Y siguiendo el modus tollens, al decir que Y, y luego X... ¿no podrías decir que si tienes relaciones sexuales, entonces hay amor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且从相反角度来看的话，也可以理解为既然是Y就有X……也就是说做爱了就是有爱的意思对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且從相反角度來看的話，也可以理解為既然是Y就有X……也就是說做愛了就是有愛的意思對吧……？」",
					{"rt2"},
				},
			},
		},
