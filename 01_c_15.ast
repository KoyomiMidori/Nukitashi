	["0016_00096"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks clearly frightened and hesitant.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她明显地害怕起来，露出了躊躇的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她明顯地害怕起來，露出了躊躇的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00095",
		linknext = "0016_00097",
		line = 1369,
	},
	["0016_00097"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks to me for validation, and I nod.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用视线向我寻求帮助，我点点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用視線向我尋求幫助，我點點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00096",
		linknext = "0016_00098",
		line = 1381,
	},
	["0016_00098"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't worry. You're in good company. Everyone here has their own personal baggage to tend to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没关系，这里的大家都是和你一样拥有困扰的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒關係，這裡的大家都是和你一樣擁有困擾的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00097",
		linknext = "0016_00099",
		line = 1393,
	},
	["0016_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As long as you're on the side of the NLNS... we'll surely accept you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果是NLNS的同伴——一定会接受你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果是NLNS的同伴——一定會接受你的。」",
					{"rt2"},
