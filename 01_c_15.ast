	["0016_00052"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0511", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“None of us did...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“谁都没有……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「誰都沒有……」",
					{"rt2"},
