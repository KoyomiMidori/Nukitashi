	},
	["0016_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ni siquiera nos dimos cuenta de que ya estaba aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事实上，我们也真的没有发现她的存在……",
					{"rt2"},
				},
			},
			tw = {
				{
					"事實上，我們也真的沒有發現她的存在……",
					{"rt2"},
