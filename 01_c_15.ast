	["0016_00185"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Suspiro y me tapo la cara con las manos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后在房间大大地叹了口气，垂下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後在房間大大地嘆了口氣，垂下了頭。",
					{"rt2"},
