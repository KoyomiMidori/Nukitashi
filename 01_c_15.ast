		linknext = "0016_00143",
		line = 1994,
	},
	["0016_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Honestly, I'm pretty happy to welcome even one more like-minded person into our group.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我很开心又多了一名同志。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我很開心又多了一名同志。」",
					{"rt2"},
