	},
	["0016_00065"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How could you do that to a would-be team-mate?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你怎么可以对要成为我们队友的人做这样的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你怎麼可以對要成為我們隊友的人做這樣的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00064",
		linknext = "0016_00066",
		line = 964,
	},
	["0016_00066"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0516", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Shitty virgin brother! Doesn't she seem like your type, you untouched virgin!? The plain, subservient type right? ”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“混蛋处男哥哥喜欢这样的妹子对吧……！？低调又很听话的这种……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「混蛋處男哥哥喜歡這樣的妹子對吧……！？低調又很聽話的這種……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00065",
		linknext = "0016_00067",
		line = 976,
	},
	["0016_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That shitty virgin brother of yours will take your life!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在混蛋处男被夺走之前，我先断了你的命根子吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在混蛋處男被奪走之前，我先斷了你的命根子吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00066",
		linknext = "0016_00068",
		line = 987,
	},
	["0016_00068"] = {
		{"fgact", id=3, ch="麻沙音", act="stopact"},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=100},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, mode=3, x=400, y=0},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, mode=3, x=-400, y=0},
		{"msgoff", time=1},
		{"extrans", sync=0, time=200, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0502", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Umm... sorry about this, Hotori-san. Whenever there is a new person that girl always acts like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“额——对不起畔同学。这个孩子每次有新人加入都会这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「額——對不起畔同學。這個孩子每次有新人加入都會這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00067",
		linknext = "0016_00069",
		line = 1008,
	},
	["0016_00069"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0030", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“N-No, it's fine... Your sister seems, how to put it, kinda spicy... and funky, I guess...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，没事……怎么说，该说是火辣……还是奇特的妹妹呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，沒事……怎麼說，該說是火辣……還是奇特的妹妹呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00068",
		linknext = "0016_00070",
		line = 1024,
	},
	["0016_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks for finding the politest possible way to describe my sister.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你尽可能温和地形容我妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你盡可能溫和地形容我妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00069",
		linknext = "0016_00071",
		line = 1036,
	},
	["0016_00071"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0503", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, anyway. I'm guessing Jun's given you the basics on what exactly our organization's about, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不管怎么样，那么……你应该有从淳那边听到我们组织是干什么的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不管怎麼樣，那麼……你應該有從淳那邊聽到我們組織是幹什麼的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00070",
		linknext = "0016_00072",
		line = 1050,
	},
	["0016_00072"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00113", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0031", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes, um... You're a group of anti-copulators who run away from sex and are trying to crush the perverted sex law, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，那个……打破变态条例逃避做爱的，反交尾势力组队……对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯，那個……打破變態條例逃避做愛的，反交尾勢力組隊……對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00071",
		linknext = "0016_00073",
		line = 1064,
	},
	["0016_00073"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0504", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah. So since you found your way here on your own, I'm presuming you agree with our objective?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你在知道这一切后也来到了这里……也就是说我可以认为你也是和我们做着同样的事情对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你在知道這一切後也來到了這裡……也就是說我可以認為你也是和我們做著同樣的事情對嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00072",
		linknext = "0016_00074",
		line = 1076,
	},
	["0016_00074"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=7.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0032", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Uh, yes, that's right. Ever since I reached the age of consent, I've been keeping low and running around on my own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，是的，嗯……在成为条例法定年龄之后，我就一直一个人在逃避着……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，是的，嗯……在成為條例法定年齡之後，我就一直一個人在逃避著……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00073",
		linknext = "0016_00075",
		line = 1091,
	},
	["0016_00075"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0033", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I get around by bicycle... I like to wait until it's completely dark, and then ride straight down the mountain path home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“基本上，我都是等到天黑了之后……用自行车一口气从山坡上冲下去回家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「基本上，我都是等到天黑了之後……用自行車一口氣從山坡上衝下去回家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00074",
		linknext = "0016_00076",
		line = 1103,
	},
	["0016_00076"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0505", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So those tire tracks really were from your bike, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那，那个轮胎的痕迹……真的是自行车啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那，那個輪胎的痕跡……真的是自行車啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00075",
		linknext = "0016_00077",
		line = 1117,
	},
	["0016_00077"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm surprised you're able to ride that thing around in pitch darkness. You must have some crazy skills.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在那种视野差的地方，亏你可以骑车直接冲下去呢。很需要技巧吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在那種視野差的地方，虧你可以騎車直接衝下去呢。很需要技巧吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00076",
		linknext = "0016_00078",
		line = 1129,
	},
	["0016_00078"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0034", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I have pretty good eyesight, and I can see pretty well in the dark. I guess it just comes naturally when I ride my bike, or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“其实我晚上可以看得很清楚。而且视力也很好……自行车是骑着骑着，自然就熟练了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「其實我晚上可以看得很清楚。而且視力也很好……自行車是騎著騎著，自然就熟練了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00077",
		linknext = "0016_00079",
		line = 1143,
	},
	["0016_00079"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00115", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0506", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, if you're doing all right getting to and from school, how do you manage when you're actually at school? I mean, there's the events and whatnot...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“上学放学可以这样，那你在学校里面怎么办？毕竟还有活动……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「上學放學可以這樣，那你在學校裡面怎麼辦？畢竟還有活動……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00078",
		linknext = "0016_00080",
		line = 1157,
	},
	["0016_00080"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0035", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, well, my face is just so ridiculously plain that I can somehow manage.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，因为我的脸实在太平庸了，所以没什么事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，因為我的臉實在太平庸了，所以沒什麼事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00079",
		linknext = "0016_00081",
		line = 1171,
	},
	["0016_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太平庸了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太平庸了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00080",
		linknext = "0016_00082",
		line = 1183,
	},
	["0016_00082"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0036", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Like, I'm so plain that if life were a manga, I'd just be a generic background character.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我非常不起眼……如果用漫画来讲，基本就是框中角落里的路人女……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我非常不起眼……如果用漫畫來講，基本就是框中角落裡的路人女……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00081",
		linknext = "0016_00083",
		line = 1197,
	},
	["0016_00083"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0037", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So if I just stand around and don't deliberately draw any attention to myself, basically no one ever notices me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“所以我只需要站在那里，除非做了一些奇葩的事情，否则基本是不会被发现的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「所以我只需要站在那裡，除非做了一些奇葩的事情，否則基本是不會被發現的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00082",
		linknext = "0016_00084",
		line = 1209,
	},
	["0016_00084"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um... Well, we're certainly in no position to doubt your word.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……我们也不得不相信呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……我們也不得不相信呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00083",
		linknext = "0016_00085",
		line = 1221,
	},
	["0016_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We didn't even notice she was in here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事实上，我们也真的没有发现她的存在……",
					{"rt2"},
				},
			},
			tw = {
				{
					"事實上，我們也真的沒有發現她的存在……",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00084",
		linknext = "0016_00086",
		line = 1231,
	},
	["0016_00086"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine", delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0038", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“How to put it... it's what allows me to get away unscathed, but at the same time, I kinda feel ambivalent about it... Ahaha.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎么说……因为这样，我才能逃跑到现在，但心情却有些复杂呢……啊哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「怎麼說……因為這樣，我才能逃跑到現在，但心情卻有些複雜呢……啊哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00085",
		linknext = "0016_00087",
		line = 1246,
	},
	["0016_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seeing a reserved girl like her, so unlike all the boisterous people on the island, forcing a bitter smile brings out quite strong feelings of guilt.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不像岛上那些耀眼的女孩，懦弱的女孩苦笑的样子，让我有一种强烈的内疚感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不像島上那些耀眼的女孩，懦弱的女孩苦笑的樣子，讓我有一種強烈的內疚感。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00086",
		linknext = "0016_00088",
		line = 1256,
	},
	["0016_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel bad about what I did, but it makes me honestly think she's... quite charming.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为我们做了不好的事情，还有……她看起来非常率真可爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為我們做了不好的事情，還有……她看起來非常率真可愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00087",
		linknext = "0016_00089",
		line = 1266,
	},
	["0016_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She reminds me of the human emotions I almost forgot about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我觉得自己好像重新取回了一些快被遗忘的人类情感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我覺得自己好像重新取回了一些快被遺忘的人類情感。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00088",
		linknext = "0016_00090",
		line = 1276,
	},
	["0016_00090"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Totally different from the slut and loli...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，她与婊子和萝莉不同是吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，她與婊子和蘿莉不同是吧——」",
					{"rt2"},
				},
