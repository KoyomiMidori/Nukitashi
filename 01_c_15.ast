		line = 1946,
	},
	["0016_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso en medio de un evento tan peligroso, podemos reírnos y continuar con nuestra rutina habitual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样，即使在危险活动期间中，也可以天天欢笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣，即使在危險活動期間中，也可以天天歡笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00138",
		linknext = "0016_00140",
		line = 1956,
	},
	["0016_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me siento muy agradecido por eso.",
