		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"se", id=0, loop=0, file="se_a112"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al día siguiente, después de clases, me dirijo a la base y me encuentro con que todos me están esperando para darme la bienvenida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第二天放学后去基地时，大家一起簇拥了上来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第二天放學後去基地時，大家一起簇擁了上來。",
					{"rt2"},
				},
			},
		},
		linknext = "0016_00002",
		line = 40,
	},
	["0016_00002"] = {
		{"bgm", file="bgm02", vol=100},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0309", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana-kun, oí que ayer te salvó una desconocida. ¡Es \nincreíble! ¡Estoy impresionada!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我听说了橘君，昨天你救了陌生的女孩对吗？好厉害啊，不愧是橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我聽說了橘君，昨天你救了陌生的女孩對嗎？好厲害啊，不愧是橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00001",
		linknext = "0016_00003",
		line = 56,
	},
	["0016_00003"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí... ¿Asa-chan se los dijo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……是从麻沙酱那里听到的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……是從麻沙醬那裡聽到的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00002",
		linknext = "0016_00004",
		line = 68,
	},
	["0016_00004"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0493", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Cuando perdió el contacto contigo, nos llamó a todos a la vez. Estaba muy nerviosa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“当她和你失去联系的时候，突然联系上了我们。那个时候的麻沙酱可慌乱了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「當她和你失去聯繫的時候，突然聯繫上了我們。那個時候的麻沙醬可慌亂了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00003",
		linknext = "0016_00005",
		line = 81,
	},
	["0016_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Es eso cierto, manita?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样的吗，妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣的嗎，妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00004",
		linknext = "0016_00006",
		line = 93,
	},
	["0016_00006"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0504", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Manito tú eres mi genio y vas a concederme los deseos de todo un milenio, si te mueres mi vida se acabaría, así que no te mueras hasta que hayas tenido un trío conmigo y con una zorra gyaru maldito virgen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对我来说哥哥可是实现我1000年愿望的宝箱可不能让他就死在这里也就是说和辣妹3P为止不可以死哦混蛋处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對我來說哥哥可是實現我1000年願望的寶箱可不能讓他就死在這裡也就是說和辣妹3P為止不可以死哦混蛋處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00005",
		linknext = "0016_00007",
		line = 106,
	},
	["0016_00007"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0310", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Toda eso significa que estabas muy preocupada por él.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“说了这么多，其实是在说自己很担心对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「說了這麼多，其實是在說自己很擔心對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00006",
		linknext = "0016_00008",
		line = 120,
	},
	["0016_00008"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0505", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Claro que no! ¡No es verdad! Solo quiero follar con una zorra gyaru mayor que yo, ¿vale...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不是的——不是这样的——我只是想和色情的长辈辣妹打炮而已——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不是的——不是這樣的——我只是想和色情的長輩辣妹打炮而已——」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00007",
		linknext = "0016_00009",
		line = 135,
	},
	["0016_00009"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0494", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, ya olvidemos eso... Jun, ¿estás bien? ¿No tienes ninguna herida?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“算了，这事先这样……淳，所以你还好吗？没受伤吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「算了，這事先這樣……淳，所以你還好嗎？沒受傷吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00008",
		linknext = "0016_00010",
		line = 149,
	},
	["0016_00010"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, solo es un rasguño... Parece que te preocupé...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没事。只是擦伤了——让你担心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒事。只是擦傷了——讓你擔心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00009",
		linknext = "0016_00011",
		line = 161,
	},
	["0016_00011"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00107", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0495", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Idiota... Eres bien terco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“笨蛋……真是的，叫你乱来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「笨蛋……真是的，叫你亂來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00010",
		linknext = "0016_00012",
		line = 176,
	},
	["0016_00012"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0311", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero me parece genial, Tachibana-kun. ¡Como soy tu senpai, te daré una recompensa!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的很棒呢，很了不起哦橘君。这种时候前辈就必须夸夸你！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的很棒呢，很了不起哦橘君。這種時候前輩就必須誇誇你！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00011",
		linknext = "0016_00013",
		line = 190,
	},
	["0016_00013"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Más caricias en la cabeza, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你又要摸我头了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你又要摸我頭了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00012",
		linknext = "0016_00014",
		line = 202,
	},
	["0016_00014"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0312", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Veamos... Bueno, este momento es especial, ¿hay algo en particular que te gustaría?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“说的也是，你这次特别棒，我该怎么夸你呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「說的也是，你這次特別棒，我該怎麼夸你呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00013",
		linknext = "0016_00015",
		line = 216,
	},
	["0016_00015"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0506", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Como construirle un castillo de arena como regalo o algo así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“用沙堆堆个山送他怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「用沙堆堆個山送他怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00014",
		linknext = "0016_00016",
		line = 230,
	},
	["0016_00016"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0496", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
