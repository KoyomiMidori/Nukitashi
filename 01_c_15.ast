	["0016_00152"] = {
		{"fgact", ch="美岬", id=6, act="移動", x=400, y=0, time=700},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00114", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=400, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0512", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Took you long enough to notice that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“终于发现了吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「終於發現了嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00151",
		linknext = "0016_00153",
		line = 2122,
	},
	["0016_00153"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0521", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I mean, if you took it that way, we'd basically sound like we're a pro-perverted sex group. Like, 'no love, not sex, no problem!'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“按照这个理论的话，好像是在推荐‘没有爱的话就不算做爱所以ok！’这种轻率行为的组织……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「按照這個理論的話，好像是在推薦『沒有愛的話就不算做愛所以ok！』這種輕率行為的組織……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00152",
		linknext = "0016_00154",
		line = 2135,
	},
	["0016_00154"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“OOOOOOOOOOOOOOHHHHH!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂喂喂喂！！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂喂喂喂！！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00153",
		linknext = "0016_00155",
		line = 2147,
	},
	["0016_00155"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0050", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“And going by modus tollens, if you're basically saying 'if Y, then X'... then couldn't you also say that if you're having sex, then love is there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且从相反角度来看的话，也可以理解为既然是Y就有X……也就是说做爱了就是有爱的意思对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且從相反角度來看的話，也可以理解為既然是Y就有X……也就是說做愛了就是有愛的意思對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00154",
		linknext = "0016_00156",
		line = 2161,
	},
	["0016_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
