		},
		linkback = "0016_00098",
		linknext = "0016_00100",
		line = 1405,
	},
	["0016_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
