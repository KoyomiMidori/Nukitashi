		linkback = "0053_00078",
		linknext = "0053_00080",
		line = 992,
	},
	["0053_00080"] = {
		{"bgm", file="bgm24", vol=100},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00107", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0750", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Asane-chan está en sus días, ¿verdad? Bueno, yo sé mucho sobre eso, ¡así que te enseñaré todo lo que sé!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“麻沙音酱月经很严重很难受对吧？我对这些很了解，可以指导橘君！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「麻沙音醬生理期很嚴重很難受對吧？我對這些很了解，可以指導橘君！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00079",
		linknext = "0053_00081",
		line = 1007,
	},
	["0053_00081"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um, pues... Agradezco que te preocupes, pero prefiero que me ayude una chica a la que realmente le llegue el período...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，但是……你的好意我心领了，不过还是该找个已经开始来例假的人比较……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
