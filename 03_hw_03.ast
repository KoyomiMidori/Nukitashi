	["0053_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Stepping into a pharmacy, we're greeted by one of the employees.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在药房外面整理商品的店员喊着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在藥房外面整理商品的店員喊著。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00140",
		linknext = "0053_00142",
		line = 1847,
	},
	["0053_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's stocking the shelves with lube, condoms, and other hygiene products. Admittedly, I've gotten used to the sight now, this island being what it is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"将润滑液、保险套、生理用品等像在炫耀般陈列在外面的光景，可以说很契合青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"將潤滑液、保險套、生理用品等像在炫耀般陳列在外面的光景，可以說很契合青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00141",
		linknext = "0053_00143",
		line = 1857,
	},
	["0053_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never really noticed before, but feminine hygiene products have a lot more variety to them than I expected.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我从来没有注意过生理用品——好像有很多种类。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我從來沒有注意過生理用品——好像有很多種類。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00142",
		linknext = "0053_00144",
		line = 1867,
	},
	["0053_00144"] = {
		{"bg", id=1, file="bg22_1l_00000", x=-300, y=0, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00110", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0769", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hmm... What should we get for her cramps, then? Would Asane prefer her medicine in pills, or in powder form?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯——止痛药哪个好呢？麻沙音酱有没有比较喜欢吃药粉还是胶囊啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯——止痛藥哪個好呢？麻沙音醬有沒有比較喜歡吃藥粉還是膠囊啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00143",
		linknext = "0053_00145",
		line = 1881,
	},
	["0053_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's see... Honestly, she's gonna whine about taking any kind of medicine, but I think the powdered stuff's gonna be a definite no-go for her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……不管哪个她都有意见，但是药粉特别不行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……不管哪個她都有意見，但是藥粉特別不行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00144",
		linknext = "0053_00146",
		line = 1893,
	},
	["0053_00146"] = {
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00120", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
