				},
			},
			cn = {
				{
					"这么说来，昨天她也说有在吃避孕药——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，昨天她也說有在吃避孕藥——",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00085",
		linknext = "0053_00087",
		line = 1082,
	},
	["0053_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si la está usando evitar el embarazo... tampoco es tan raro que le llegue el período.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有吃避孕药的话——就表示也会来例假是吗？",
