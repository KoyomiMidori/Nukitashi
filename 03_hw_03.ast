				{"vo", file="hinami0780", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh... So mainlanders don't do that, do they? You learn something new every day... Still, no need to fear! Not with me taking the lead for you, no sir!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔——本岛也没有这种事吗？学习到了……不过不用担心，前辈会好好带你的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔——本島也沒有這種事嗎？學習到了……不過不用擔心，前輩會好好帶你的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00172",
		linknext = "0053_00174",
		line = 2266,
	},
	["0053_00174"] = {
