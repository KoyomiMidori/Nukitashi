	},
	["0053_00122"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0763", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? You mean you really don't know? So you never had a class when you were younger about how to change a girl's pad while she's having her strawberry week?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……？难道你真的不知道？你在成为性人前没上过给生理期的女孩子换卫生巾的课吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……？難道你真的不知道？你在成為性人前沒上過給生理期的女孩子換衛生棉的課嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00121",
		linknext = "0053_00123",
		line = 1586,
	},
	["0053_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
