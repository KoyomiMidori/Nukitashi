	},
	["0053_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yo también me lo pregunto... Dijo que se sentía pesada, así que tal vez sí. Encima, ha estado muy malhumorada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是不是呢……她说例假很严重……那应该算多吧……脸色实际上也很差……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是不是呢……她說生理期很嚴重……那應該算多吧……臉色實際上也很差……」",
					{"rt2"},
				},
			},
