			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, my cramps can get pretty brutal as well. So if Asane's going through the same thing, of course I'd be worried.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，我也比较严重，所以更担心麻沙音酱了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，我也比較嚴重，所以更擔心麻沙音醬了。」",
					{"rt2"},
				},
			},
		},
