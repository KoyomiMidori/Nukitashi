					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me paso todo el día sin poder concentrarme en las clases, me siento angustiado hasta que por fin termina la jornada escolar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那天上课的内容完全进不到脑海里。就在发愁的时候，终于放学了。",
