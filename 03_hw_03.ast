	["0053_00177"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um... Is it just me, or does something feel off? It's kinda dimly lit in here. Plus, the air feels weirdly steamy...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个……不感觉有点奇怪吗？莫名地暗，总觉得飘着一股粉色的气息……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個……不感覺有點奇怪嗎？莫名地暗，總覺得飄著一股粉色的氣息……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00176",
		linknext = "0053_00178",
		line = 2349,
	},
	["0053_00178"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00123", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
