		},
		linkback = "0053_00007",
		linknext = "0053_00009",
		line = 130,
	},
	["0053_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No hay ni una pizca de jocosidad en sus palabras. Me está hablando con seriedad. Esto me preocupa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不是平常的玩笑，而是真正的态度差——看来是真的难受。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不是平常的玩笑，而是真正的態度差——看來是真的難受。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00008",
		linknext = "0053_00010",
		line = 140,
	},
	["0053_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Estás bien? Deberíamos llevarte al médico si...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你没事吧？还是去看医生比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你沒事吧？還是去看醫生比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00009",
		linknext = "0053_00011",
		line = 151,
	},
	["0053_00011"] = {
		{"fg", file="asane_02f_00007", file1="asane_02f_00115", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1016", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ya te dije que no me molestes... Dame cinco días y se me pasará...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我说了没关系……过5天就会好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我說了沒關係……過5天就會好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00010",
		linknext = "0053_00012",
		line = 164,
	},
	["0053_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cinco días?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“5天，怎么可能……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「5天，怎麼可能……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00011",
		linknext = "0053_00013",
		line = 175,
	},
	["0053_00013"] = {
		{"fg", file="asane_01f_00007", file1="asane_01f_00127", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1017", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Maldito intenso, ¿no entiendes la indirecta? Estoy en mis días. Tengo el período. ¿Ahora sí lo entiendes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊烦死了……为什么你就不明白呢……来例假了啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊煩死了……為什麼你就是不明白呢……來生理期了啦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00012",
		linknext = "0053_00014",
		line = 188,
	},
	["0053_00014"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿B-Bueno...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“例假……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「生理期……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00013",
		linknext = "0053_00015",
		line = 200,
	},
	["0053_00015"] = {
		{"fg", file="asane_01f_00007", file1="asane_01f_00104", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1018", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí. Y me temo que no puedes ayudarme, así que date prisa y vete a la escuela. Voy a descansar un poco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对……你在也什么都做不到，赶紧去学校吧……我请假……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對……你在也什麼都做不到，趕緊去學校吧……我請假……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00014",
		linknext = "0053_00016",
		line = 213,
	},
	["0053_00016"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Umm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00015",
		linknext = "0053_00017",
		line = 225,
	},
	["0053_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ah... Conque era eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"例假……啊，生理期啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"生理期……啊，是生理期啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00016",
		linknext = "0053_00018",
		line = 235,
	},
	["0053_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso, hace unos años solía tener momentos de mal humor cada mes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说起来，几年前开始就每个月都有这样的时期。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說起來，幾年前開始就每個月都有這樣的時期。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00017",
		linknext = "0053_00019",
		line = 245,
	},
	["0053_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya lo había olvidado, pero ¿por qué le está volviendo a pasar esto?",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前的事情我都忘记了，但为什么突然又……",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前的事情我都忘記了，但為什麼突然又……",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00018",
		linknext = "0053_00020",
		line = 255,
	},
	["0053_00020"] = {
		{"fg", file="asane_01f_00007", file1="asane_01f_00127", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1019", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Um... Estar parado todo el día como un tonto no me va a ayudar a relajarme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
