					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“O-Oh... Is that a fact.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是、是哦……是这样啊。”",
