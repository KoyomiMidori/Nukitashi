			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Geez, you really caught me off guard with that one, I'm dying over here! Uh... Is something the matter? Your eyes are kinda darting every which way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哈哈——因为橘君突然说了有趣的话，所以笑出来了……橘君？怎么了？眼睛转来转去的呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哈哈——因為橘君突然說了有趣的話，所以笑出來了……橘君？怎麼了？眼睛轉來轉去的呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00119",
		linknext = "0053_00121",
