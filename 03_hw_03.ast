					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm, ya veo. Le compraremos la misma marca que yo uso. No le molesta que tengan alas, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯，是那种感觉啊……那样的话跟我用一样的会比较好。卫生巾选带着翅膀的也没问题吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯，是那種感覺啊……那樣的話跟我用一樣的會比較好。衛生棉選帶著翅膀的也沒問題吧？」",
					{"rt2"},
				},
			},
		},
