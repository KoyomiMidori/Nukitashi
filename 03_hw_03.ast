	["0053_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When you're a guy on this island expected to have sex as part of your daily routine, I guess knowing the ins and outs of the female body is an essential perk to have.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然日常生活都在做爱，那男人也有必要了解生理期是吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然日常生活都在做愛，那男人也有必要了解生理期是嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00129",
		linknext = "0053_00131",
		line = 1687,
	},
	["0053_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Teaching guys how to change a girl's pad, though? That's pretty out there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但就算是这样，在课堂上给女孩子交换卫生巾也太奇怪了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但就算是這樣，在課堂上給女孩子交換衛生棉也太奇怪了。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00130",
		linknext = "0053_00132",
		line = 1697,
	},
	["0053_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But still, leaving reason and methods aside... the guys on this island seem to be knowledgeable about menstruation, and they do well enough at looking after their women when they're having it rough...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——无论理由和方法如何，岛上的男生有生理方面的知识，并能藉此关心女孩子也是事实……",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——無論理由和方法如何，島上的男生有生理方面的知識，並能藉此關心女孩子也是事實……",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00131",
		linknext = "0053_00133",
		line = 1707,
	},
	["0053_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And here I am, not knowing shit. It almost makes me feel like I've failed as a man somehow...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我则对那方面完全不清楚，感觉作为一个男人，有种输了的感觉……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我則對那方面完全不清楚，感覺作為一個男人，有種輸了的感覺……",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00132",
		linknext = "0053_00134",
		line = 1717,
	},
	["0053_00134"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shit, what's with this feeling of inferiority? Am I actually falling behind these goddamn horny apes!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶，这种自卑感怎么回事……这个我，居然输给了只会说怀孕吧喂的家伙们……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡，這種自卑感怎麼回事……這個我，居然輸給了只會說懷孕吧喂的傢伙們……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00133",
		linknext = "0053_00135",
		line = 1729,
	},
	["0053_00135"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00113", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0767", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“T-Tachibana? What're you clutching your head for? C-Could it be menstrual pains?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘、橘君……？突然抱着头怎么了……经痛吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘、橘君……？突然抱著頭怎麼了……經痛嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00134",
		linknext = "0053_00136",
		line = 1743,
	},
	["0053_00136"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, sorry, it's nothing... Let's just call it a touch of dysphoria, or something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……对不起，我有点无法控制‘自己’……混乱了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……對不起，我有點無法控制『自己』……混亂了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00135",
		linknext = "0053_00137",
		line = 1755,
	},
	["0053_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But anyway, I feel like I ought to know a little more about this sort of thing. Better to be more prepared for next time it happens, and all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，以后也会有像这次一样的事情——我也要学习一下例假之类的事情比较好啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，以後也會有像這次一樣的事情——我也要學習一下生理期之類的事情比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00136",
		linknext = "0053_00138",
		line = 1766,
	},
	["0053_00138"] = {
