	},
	["0053_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es muy adorable... Se me sale una pequeña sonrisa al ver cómo se esfuerza para parecer mayor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真是可爱啊——小孩子装姐姐的样子很招人喜欢。",
