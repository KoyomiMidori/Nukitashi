					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mmm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個嘛……」",
