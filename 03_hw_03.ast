				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Jeje! ¡Me apliqué un poco del maquillaje de mamá esta mañana! ¿No me veo mayor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哼哼。其实，我今天早上用了妈妈的化妆水！比平时更成熟了吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哼哼。其實，我今天早上用了媽媽的化妝水！比平時更成熟了吧！」",
					{"rt2"},
				},
