	["0053_00243"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0800", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“And when the medicine does start to work, don't overdo it too much. Try and get to bed by 10 o'clock.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不能因为吃了药恢复了健康就乱来哦。10点就到被子里吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不能因為吃了藥恢復了健康就亂來哦。10點就到被子裡吧。」",
					{"rt2"},
				},
			},
		},
