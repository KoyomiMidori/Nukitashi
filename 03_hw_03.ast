	["0053_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa finally pipes down and washes down the pill with some mineral water.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱终于死心了，她将绿色的胶囊连同矿泉水吞进肚子里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬終於死心了，她將綠色的膠囊連同礦泉水吞進肚子裡。",
