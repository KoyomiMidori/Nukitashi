				{"vo", file="hinami0782", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No problemo! I know Seiran Island like the back of my hand! Just hop on the S.S. Hinami and leave all your troubles behind!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事！青蓝岛就跟我的庭院一样，你就当是坐上豪华大船跟我来就好！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒事！青藍島就跟我的庭院一樣，你就當是坐上豪華大船跟我來就好！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00177",
		linknext = "0053_00179",
		line = 2362,
	},
	["0053_00179"] = {
