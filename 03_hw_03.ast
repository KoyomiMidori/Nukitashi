		{"extrans", sync=0, time=400, rule="eff_012_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0205", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "店員"},
					"*テキスト*",
