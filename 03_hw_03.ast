	["0053_00207"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="asane_01m_00007", file1="asane_01m_00124", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1024", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nghh... Bro, you're late... Your adorable li'l sis is out here with one foot in her grave, where the hell you been...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯——哥哥好慢哦……放着痛苦的可爱妹妹跑到哪里去了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯——哥哥好慢哦……放著痛苦的可愛妹妹跑到哪裡去了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00206",
		linknext = "0053_00208",
		line = 2764,
	},
	["0053_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like yesterday, she's laying down on the sofa, languidly staring at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和昨天一样，她躺在沙发上疲倦地看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和昨天一樣，她躺在沙發上疲倦地看著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00207",
		linknext = "0053_00209",
		line = 2774,
	},
	["0053_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Did she come out to the living room to wait for me?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是特地在客厅等我回家吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是特地在客廳等我回家嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00208",
		linknext = "0053_00210",
		line = 2784,
	},
	["0053_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just went out for a little shopping. Didn't you get my text about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“买了一点东西……不是跟你联系过了吗？你没看吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「買了一點東西……不是跟你聯繫過了嗎？你沒看嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00209",
		linknext = "0053_00211",
		line = 2795,
	},
	["0053_00211"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1025", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh yeah, look at an electronic device spewing blue light from its screen that makes me feel even more like shit, great idea. Sorry, but that's a hard pass from me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“本来就状况不好还要叫我读汉字是在拷问我吗……不全部写平假名我才不看……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「本來就狀況不好還要叫我讀漢字是在拷問我嗎……不全部寫平假名我才不看……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00210",
		linknext = "0053_00212",
		line = 2807,
	},
	["0053_00212"] = {
