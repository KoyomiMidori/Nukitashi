		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0756", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mm, vayamos a la farmacia. ¿Cuántas toallas sanitarias tienes en casa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……总之先去药店。橘君，现在卫生巾还剩多少？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……總之先去藥店。橘君，現在衛生棉還剩多少？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00105",
		linknext = "0053_00107",
		line = 1381,
	},
	["0053_00107"] = {
