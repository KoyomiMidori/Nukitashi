				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... I suppose you do look like the type of person who'd hate that sort of thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊——渡酱一看就让人感觉吃不了苦的药。”",
