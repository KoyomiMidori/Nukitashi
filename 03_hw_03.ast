	["0053_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The more I think about it, the more I realize just how little I know about this stuff... And it's my own sister we're talking about here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“越想越发现自己什么都不知道呢……明明是妹妹的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「越想越發現自己什麼都不知道呢……明明是妹妹的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00156",
		linknext = "0053_00158",
		line = 2043,
	},
	["0053_00158"] = {
