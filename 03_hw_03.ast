					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Heh heh! No biggie. Anyway, if you want a recommendation from me, I'd go with these green pills here. I take them pretty often myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哼哼，这是理所当然的。然后啊橘君，我推荐这个绿色胶囊！这是我也经常用的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哼哼，這是理所當然的。然後啊橘君，我推薦這個綠色膠囊！這是我也經常用的。」",
					{"rt2"},
				},
			},
		},
