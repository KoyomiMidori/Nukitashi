			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Por qué te sorprendes tanto?! ¡Me viene todos los meses! ¡Incluso puedo quedar embarazada! ¡Soy una adulta hecha y derecha!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“为什么那么吃惊！我每个月都来例假，是可以怀孕的哦！是大人哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「為什麼那麼吃驚！？我每個月都來生理期，是可以懷孕的哦！是大人哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00083",
		linknext = "0053_00085",
		line = 1060,
