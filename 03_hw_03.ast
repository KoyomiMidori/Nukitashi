				{"vo", file="hinami0774", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hmm... Well, you didn't learn about it in school, so don't beat yourself up. Heck, if you ask me, I think you're doing pretty well at trying to learn this stuff for her sake!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……不过，因为橘君在学校没有学过所以也没办法。倒不如说，为了麻沙音酱努力学习是很伟大的事情哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……不過，因為橘君在學校沒有學過所以也沒辦法。倒不如說，為了麻沙音醬努力學習是很偉大的事情哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00157",
		linknext = "0053_00159",
		line = 2057,
	},
	["0053_00159"] = {
