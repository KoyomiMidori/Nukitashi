				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo. Bueno, mejor elegimos una decente para estar seguros. Por cierto... ¿suele salir mucho?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊，原来如此，那必须选个不错的……还有……麻沙音酱算比较多的那种吗？”",
