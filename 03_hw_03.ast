	["0053_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Voy a despertar a Asa-chan. Al entrar, escucho un gemido que proviene de la cama.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本想来叫醒妹妹，结果床上传来了呻吟的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本想來叫醒妹妹，結果床上傳來了呻吟的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00004",
		linknext = "0053_00006",
		line = 93,
	},
	["0053_00006"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan... ¿Sigues sintiéndote mal?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱……？你还不舒服吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬……？你還不舒服嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00005",
		linknext = "0053_00007",
		line = 105,
	},
	["0053_00007"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", file="asane_02f_00007", file1="asane_02f_00127", file2="asane_02f_00202", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1015", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Te parece que estoy bien? Con solo mirarme ya deberías darte cuenta...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……不要一一问我啦……看了就知道了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……不要一一問我啦……看了就知道了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00006",
		linknext = "0053_00008",
		line = 119,
	},
	["0053_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo siento...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，不好意思……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，不好意思……」",
					{"rt2"},
