	["0053_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oigan... ¡¿Por qué se está riendo?! ¿Dije algo raro?",
