		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"ex", time=500, func="wait"},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bgm", file="bgm07", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0742", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, Tachibana-kun! Te estaba esperando. ¡Intentemos buscar a Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，橘君！一直在等着你呢！今天也要努力寻找文乃酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，橘君！一直在等著你呢！今天也要努力尋找文乃醬！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00044",
		linknext = "0053_00046",
		line = 584,
	},
	["0053_00046"] = {
		{"text"},
		text = {
