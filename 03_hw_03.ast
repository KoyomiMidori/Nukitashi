		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Cuando era más joven, solía sufrir mucho con los calambres y esas cosas. Pero hacía años que no la veía tan afectada por eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。从以前开始就蛮严重的……但是，这几年倒是没什么问题……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。從以前開始就蠻嚴重的……但是，這幾年倒是沒什麼問題……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00061",
		linknext = "0053_00063",
		line = 791,
	},
	["0053_00063"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1842", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Por qué habrá vuelto a afectarle tan rápido?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过……为什么突然又这样了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過……為什麼突然又這樣了……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00062",
		linknext = "0053_00064",
		line = 803,
	},
	["0053_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues yo creo que... se siente así por los cambios tan grandes que nos ha dado la vida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大概是……生活习惯改变了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大概是……生活習慣改變了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00063",
		linknext = "0053_00065",
		line = 814,
	},
	["0053_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cuando mamá seguía viva, se encargaba de cocinar y la cuidaba cuando se ponía muy mal... También debe ser por eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“妈妈在的时候，还会注意麻沙酱的饮食习惯……但那也已经是以前的事了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「媽媽在的時候，還會注意麻沙醬的飲食習慣……但那也已經是以前的事了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00064",
		linknext = "0053_00066",
		line = 825,
	},
	["0053_00066"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00126", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1843", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya veo... Lo siento, debí haberle prestado más atención...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“原来是这样啊……对不起……我没有注意到那么细……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「原來是這樣啊……對不起……我沒有注意到那麼細……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00065",
		linknext = "0053_00067",
		line = 839,
	},
	["0053_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tranquila, no hiciste nada malo. La comida que nos preparas todos los días nos salvó la vida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这不是奈奈濑需要在意的事情。你亲手做的饭菜她每天都吃得很开心……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這不是奈奈瀨需要在意的事情。你親手做的飯菜她每天都吃得很開心……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00066",
		linknext = "0053_00068",
		line = 850,
	},
	["0053_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es más, probablemente se sentiría mucho peor si no fuera por ti.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“倒不如说，如果没有那些饭菜，可能会更糟糕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「倒不如說，如果沒有那些飯菜，可能會更糟糕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00067",
		linknext = "0053_00069",
		line = 861,
	},
	["0053_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Además, el problema no es solo la comida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，问题不只是饮食生活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，問題不只是飲食生活。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00068",
		linknext = "0053_00070",
		line = 871,
	},
	["0053_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuando nuestros padres murieron, nuestras vidas se volvieron bastante agitadas. Encima, hemos hecho hasta lo imposible para evadir a los buscadores de sexo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父母去世后，本来就容易乱的生活变得更加不规律，而且为了逃离性触者，也稍微有些勉强她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父母去世後，本來就容易亂的生活變得更加不規律，而且為了逃離性觸者，也稍微有些勉強她。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00069",
		linknext = "0053_00071",
		line = 881,
	},
	["0053_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Todo el estrés acumulado debe estar afectándole ahora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许——是这一切加总所造成的结果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許——是這一切加總所造成的結果。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00070",
		linknext = "0053_00072",
		line = 891,
	},
	["0053_00072"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin, ya que estamos... ¿Les parece bien si damos por terminado el día? Quiero volver a casa rápido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我很抱歉……今天的活动可以请假吗？我想尽量早点回家……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我很抱歉……今天的活動可以請假嗎？我想盡量早點回家……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00071",
		linknext = "0053_00073",
		line = 903,
	},
	["0053_00073"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1844", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Claro, no me molesta. Yo también tengo cosas que hacer en mi casa... Pero ¿qué piensas hacer cuando vuelvas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那当然没关系……我也积累了点家里的事情……但是，早点回家后你打算怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那當然沒關係……我也積累了點家裡的事情……但是，早點回家後你打算怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00072",
		linknext = "0053_00074",
		line = 917,
	},
	["0053_00074"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No sé, siento que debería comprarle algo para que se sienta un poco mejor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在回家途中买些对生理期好的东西之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在回家途中買些對生理期好的東西之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00073",
		linknext = "0053_00075",
		line = 929,
	},
	["0053_00075"] = {
		{"text"},
		text = {
