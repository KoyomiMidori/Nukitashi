	},
	["0053_00101"] = {
		{"bg", id=1, file="bg22_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0755", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ay, no digas eso. Mi kouhai está en aprietos, ¿verdad? ¡Mi deber como senpai es echarle una mano!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你在说什么啊。帮助有困难的后辈，是作为前辈应该做的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你在說什麼啊。幫助有困難的後輩，是作為前輩應該做的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00100",
		linknext = "0053_00102",
		line = 1325,
	},
	["0053_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso está tarareando un poco. Debe estar muy emocionada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱一直得意洋洋，偶尔还会哼歌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬一直得意洋洋，偶爾還會哼歌。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00101",
		linknext = "0053_00103",
		line = 1335,
	},
	["0053_00103"] = {
		{"text"},
		text = {
