		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0778", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Right, that should be everything... Oh, I just remembered. That store next to the pharmacy sells underwear... Why don't we get Asane a little something to warm her up while we're here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，大概都买齐了……啊，对了。隔壁店里也有卖内衣……顺便给麻沙音酱买一件暖和的吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，大概都買齊了……啊，對了。隔壁店裡也有賣內衣……順便給麻沙音醬買一件暖和的吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00168",
		linknext = "0053_00170",
		line = 2212,
	},
	["0053_00170"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“U-Underwear? I'll pass, a guy walking around looking at women's underwear would be kinda weird...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“内、内衣？不，作为男人的我去看女性的内衣有些……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「內、內衣？不，作為男人的我去看女性的內衣有些……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00169",
		linknext = "0053_00171",
		line = 2224,
	},
	["0053_00171"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0779", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? How's that weird? Guys buy underwear they want to see girls wearing all the time, don't they?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……？有什么奇怪的吗？大家经常会挑要给女人穿的内衣吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……？有什麼奇怪的嗎？大家經常會挑要給女人穿的內衣吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00170",
		linknext = "0053_00172",
		line = 2238,
	},
	["0053_00172"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They what!? Ugh, fuck me, I hate this fucking island so much...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有这种事……！？可恶，所以我才说青蓝岛——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有這種事……！？可惡，所以我才說青藍島——」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00171",
		linknext = "0053_00173",
		line = 2250,
	},
	["0053_00173"] = {
