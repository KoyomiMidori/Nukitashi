			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ever heard of night mode?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“写了你又会抱怨说不好读吧。”",
