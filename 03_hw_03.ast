					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, I'm just trying to figure this out... What exactly are winged pads supposed to do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，虽然其他的都能大概猜到……但翅膀是什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，雖然其他的都能大概猜到……但翅膀是什麼……？」",
