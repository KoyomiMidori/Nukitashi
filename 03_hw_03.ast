	["0053_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's as bitchy as usual, but I'm just glad she's feeling better enough to joke around like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还是一如既往地让人没办法的妹妹，但她已经恢复到可以开个小玩笑的程度了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還是一如既往地讓人沒辦法的妹妹，但她已經恢復到可以開個小玩笑的程度了。",
					{"rt2"},
				},
			},
		},
