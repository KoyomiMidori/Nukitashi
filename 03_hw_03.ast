					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Th-They don't do that on the mainland!? Huh... I see, I thought it was kinda weird how you don't know much about this stuff, but I guess that explains it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“本、本岛没有吗！？诶——这样啊……我本来还觉得对月经不了解的人真是少见，原来是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「本、本島沒有嗎！？欸——這樣啊……我本來還覺得對月經不了解的人真是少見，原來是這樣啊。」",
