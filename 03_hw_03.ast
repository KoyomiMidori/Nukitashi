	["0053_00245"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Crikey. Asa the wild child, tamed by a loli.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好厉害……那个凶暴的麻沙酱被萝莉驯服了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好厲害……那個兇暴的麻沙醬被蘿莉馴服了。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00244",
		linknext = "0053_00246",
		line = 3249,
	},
	["0053_00246"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Man, I can't believe it. You really do seem like a grown-up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱，真的像姐姐一样呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬，真的像姐姐一樣呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00245",
		linknext = "0053_00247",
		line = 3261,
	},
	["0053_00247"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0801", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahaha, surely you jest! I don't seem like a grown-up, I am one! I'm the elder to all of you, aren't I?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈，你在说什么。不是像姐姐，是就是姐姐啊。我比大家的年纪都要大哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈，你在說什麼。不是像姐姐，是就是姐姐啊。我比大家的年紀都要大哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00246",
		linknext = "0053_00248",
		line = 3275,
	},
	["0053_00248"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=7.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2200] = {
				{"fg", file="asane_01m_00007", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=2200, time=1, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", delay2=2200},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1039", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mm... Huh!? Was I just taking orders from a loli? How on earth... Here I thought Nanase was supposed to be the only top for me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……啥……！？我居然被萝莉……到底为什么……姐姐栏位应该早就被奈奈濑填满了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……啥……！？我居然被蘿莉……到底為什麼……姐姐欄位應該早就被奈奈瀨填滿了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00247",
		linknext = "0053_00249",
		line = 3291,
	},
	["0053_00249"] = {
		{"text"},
		text = {
