	["0053_00241"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0799", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Now, you need to take these pills three times a day, so try and take them on a full stomach.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“一天吃3粒药，要没饿的时候吃哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「一天吃3粒藥，要沒餓的時候吃哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00240",
		linknext = "0053_00242",
		line = 3201,
	},
	["0053_00242"] = {
