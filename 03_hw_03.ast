		linkback = "0053_00075",
		linknext = "0053_00077",
		line = 953,
	},
	["0053_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al ser un chico que no tiene novia, esa pregunta es bastante difícil de responder. No se me ocurre nada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有交过女朋友的男人，怎么可能懂这种事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有交過女朋友的男人，怎麼可能懂這種事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00076",
		linknext = "0053_00078",
		line = 963,
	},
	["0053_00078"] = {
		{"bgm", stop=1},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
