	},
	["0053_00047"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0743", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mira esto, se me ocurrió una estrategia especial para que no se repita lo de ayer. ¿Sabes qué es?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“所以呢……为了不重蹈昨天的覆辙，我今天准备了对策。你知道是什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「所以呢……為了不重蹈昨天的覆轍，我今天準備了對策。你知道是什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00046",
		linknext = "0053_00048",
		line = 608,
	},
	["0053_00048"] = {
