	["0053_00128"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0766", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, well... I don't have any guy friends besides you, but I think so, yeah. Like, I see guys tend to be a lot nicer to a girl when she's going through her period, y'know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯？嗯……虽然我的男生朋友只有橘君……不过大概是吧。我觉得大家基本上都对生理期的女孩们很温柔哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯？嗯……雖然我的男生朋友只有橘君……不過大概是吧。我覺得大家基本上都對生理期的女孩們很溫柔哦？」",
					{"rt2"},
				},
			},
		},
