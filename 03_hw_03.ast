					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Gulp, bleh... There, happy now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯、唔……呃……好了，这样就可以了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯、唔……呃……好了，這樣就可以了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00237",
		linknext = "0053_00239",
		line = 3161,
	},
	["0053_00239"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0798", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yes, yes! Well done, that's a good girl. And as promised, here's your yogurt for a reward! Open wiiiide!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯，你吞下去了呢，好伟大哦……瞧，这是奖励努力了的麻沙音的酸奶哦。啊——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯，你吞下去了呢，好偉大哦……瞧，這是獎勵努力了的麻沙音的酸奶哦。啊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00238",
		linknext = "0053_00240",
		line = 3176,
	},
	["0053_00240"] = {
