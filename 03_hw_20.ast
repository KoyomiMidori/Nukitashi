		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1692", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“The Mutable Membrane? Hmm... I've lived on this island for my whole life, and I know it really well, but I've never heard of it... What kind of store is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“一时的皮膜……？嗯——？我还以为自己对岛蛮熟的，但没听说过呢……是什么店呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「一時的皮膜……？嗯——？我還以為自己對島蠻熟的，但沒聽說過呢……是什麼店呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00125",
		linknext = "0070_00127",
		line = 1540,
	},
	["0070_00127"] = {
