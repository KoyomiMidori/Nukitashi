		{"bg", id=1, file="bg22_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All alone, I walk along the path home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我开始一个人踏上回家的路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我開始一個人踏上回家的路。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00188",
		linknext = "0070_00190",
		line = 2349,
	},
	["0070_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My heart is still pounding, but I can't do anything about that. I need to think.",
					{"rt2"},
				},
			},
			cn = {
				{
					"胸口的心跳还在默默骚动着——但我现在必须想别的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"胸口的心跳還在默默騷動著——但我現在必須想別的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00189",
		linknext = "0070_00191",
		line = 2359,
	},
	["0070_00191"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The illegal sex trade even puts Hinami at risk. That makes it all the more important to come up with a plan to bring it down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"地下风俗是可能危害到雏见的存在，必须要制定对抗方法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"地下風俗是可能危害到雛見的存在，必須要制定對抗方法。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00190",
		linknext = "0070_00192",
		line = 2370,
	},
	["0070_00192"] = {
		{"se", id=0, loop=1, file="se_d015", vol=30},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The outback road I know so well echoes with the sound of moans of pleasure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"走惯了的田园道路，今天也回响着娇喘的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"走慣了的田園道路，今天也迴響著嬌喘的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00191",
		linknext = "0070_00193",
		line = 2381,
	},
	["0070_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I gotta do something about the perverted sex law, too, don't I...",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，变态条例也不能就此置之不理——",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，變態條例也不能就此置之不理——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00192",
		linknext = "0070_00194",
		line = 2391,
	},
	["0070_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear a car approaching from behind and get out of the middle of the road, bracing myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边注意着从后方靠近的汽车声音，一边小心地走在路上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊注意著從後方靠近的汽車聲音，一邊小心地走在路上。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00193",
		linknext = "0070_00195",
		line = 2401,
	},
	["0070_00195"] = {
		{"se", id=0, stop=1, time=1500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0025", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "???"},
					"“Hey, young man.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦", "？ ？ ？"},
					"“——呀，少年。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦", "？？？"},
					"「——呀，少年。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00194",
		linknext = "0070_00196",
		line = 2414,
	},
	["0070_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The car pulls up beside me and I see a familiar, unwelcome face through the window.",
					{"rt2"},
				},
			},
			cn = {
				{
					"接近的汽车停在旁边，从窗户探出头来的是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"接近的汽車停在旁邊，從窗戶探出頭來的是——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00195",
		linknext = "0070_00197",
		line = 2424,
	},
	["0070_00197"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"bg", id=1, file="bg22_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"ex", time=500, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Prefectural Governor... You surprised me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事———吓了我一跳。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事———嚇了我一跳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00196",
		linknext = "0070_00198",
		line = 2440,
	},
	["0070_00198"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0026", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Heh, is that so? Is that your surprised face?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……瞧你说的。你吃惊的时候会板着一张脸吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……瞧你說的。你吃驚的時候會板著一張臉嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00197",
		linknext = "0070_00199",
		line = 2454,
	},
	["0070_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, I've been living here too long. Whenever something unexpected happens, it's rarely a good thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……对不起，我习惯警戒平常不常发生的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……對不起，我習慣警戒平常不常發生的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00198",
		linknext = "0070_00200",
		line = 2466,
	},
	["0070_00200"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0027", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I see. I assume that's Tadasugawa's instruction at work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“原来如此，是糺川的教诲吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「原來如此，是糺川的教誨嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00199",
		linknext = "0070_00201",
		line = 2480,
	},
	["0070_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He hit the nail on the head, but I keep a poker face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然突然被指中了要害，但我还是保持着扑克脸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然突然被指中了要害，但我還是保持著撲克臉。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00200",
		linknext = "0070_00202",
		line = 2490,
	},
	["0070_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In all likelihood, he's still looking for Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他现在恐怕也还在寻找文乃吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他現在恐怕也還在尋找文乃吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00201",
		linknext = "0070_00203",
		line = 2500,
	},
	["0070_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter what, I can't let him know we're holding her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她在我们手里的事——不能被发现。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她在我們手裡的事——不能被發現。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00202",
		linknext = "0070_00204",
		line = 2510,
	},
	["0070_00204"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you doing here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在这种地方做什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在這種地方做什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00203",
		linknext = "0070_00205",
		line = 2522,
	},
	["0070_00205"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0028", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I had some spare time, so since it's such a nice evening, I thought I'd go for a little drive. It gives me a chance to check out the island I personally changed, plus there's the excitement of being potentially suddenly abducted.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为有了些空闲，正在开车兜风。想说看看自己改变的岛的样子也不错——虽然也有突然被绑架的风险。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為有了些空閒，正在開車兜風。想說看看自己改變的島的樣子也不錯——雖然也有突然被綁架的風險。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00204",
		linknext = "0070_00206",
		line = 2536,
	},
	["0070_00206"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Quite the hobby you've got.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……但你看起来好像很开心呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……但你看起來好像很開心呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00205",
		linknext = "0070_00207",
		line = 2548,
	},
	["0070_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't know how seriously to take him. He's as unreadable as ever.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到底哪些是他的真心话。还是一样是个看不见底的男人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到底哪些是他的真心話。還是一樣是個看不見底的男人。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00206",
		linknext = "0070_00208",
		line = 2558,
	},
	["0070_00208"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0029", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Is Fumino well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——文乃过得好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——文乃過得好嗎？」",
					{"rt2"},
				},
			},
