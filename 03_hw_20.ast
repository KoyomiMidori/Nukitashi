		linkback = "0070_00091",
		linknext = "0070_00093",
		line = 1114,
	},
	["0070_00093"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00110", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1689", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei... were you really trying to protect me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱……是真的吗？你想要保护我吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬……是真的嗎？你想要保護我嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00092",
		linknext = "0070_00094",
		line = 1128,
	},
	["0070_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn't answer. She's not even looking Hinami in the eye.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈没有回答，也不将目光移向雏见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩沒有回答，也不將目光移向雛見。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00093",
		linknext = "0070_00095",
		line = 1138,
	},
	["0070_00095"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00105", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0714", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“...Why do you want to know who supplied us with the aphrodisiac?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“——问媚药的来历想做什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「——問媚藥的來歷想做什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00094",
		linknext = "0070_00096",
		line = 1152,
	},
	["0070_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's so loath to answer she returns to the discussion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她似乎不想回答，所以回到了原来的话题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她似乎不想回答，所以回到了原來的話題。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00095",
		linknext = "0070_00097",
		line = 1162,
	},
	["0070_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just as planned. Now it's time to tell her the facts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是我希望的。这次一定要确实打听出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是我希望的。這次一定要確實打聽出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00096",
		linknext = "0070_00098",
		line = 1172,
	},
	["0070_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure you're already aware of this, but that aphrodisiac is already in public circulation on the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“或许你已经知道了，现在青蓝岛上到处都有这种媚药。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「或許你已經知道了，現在青藍島上到處都有這種媚藥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00097",
		linknext = "0070_00099",
		line = 1183,
	},
	["0070_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's been lauded for allowing even children to have sex, if it's used on them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要用这个，就可以跟小孩做爱——他们是这么说的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要用這個，就可以跟小孩做愛——他們是這麼說的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00098",
		linknext = "0070_00100",
		line = 1195,
	},
	["0070_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She just responds with a disdainful, uncaring look.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那又怎么样——她的视线仿佛在这么对我说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那又怎麼樣——她的視線彷彿在這麼對我說。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00099",
		linknext = "0070_00101",
		line = 1205,
	},
	["0070_00101"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If that's the case, then there's a real risk that your siblings could be exposed to danger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……请仔细想想。礼前辈的弟弟妹妹，这次真的也可能会受到伤害。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……請仔細想想。禮前輩的弟弟妹妹，這次真的也可能會受到傷害。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00100",
		linknext = "0070_00102",
		line = 1217,
	},
	["0070_00102"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's glowering at me yet again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"射穿眼球的强烈目光。",
					{"rt2"},
				},
			},
			tw = {
				{
					"射穿眼球的強烈目光。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00101",
		linknext = "0070_00103",
		line = 1229,
	},
	["0070_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't flinch. I just unwaveringly return her gaze.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我一步也不退缩，也不挪开视线——而是与那目光对视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我一步也不退縮，也不挪開視線——而是與那目光對視。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00102",
		linknext = "0070_00104",
		line = 1239,
	},
	["0070_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If those who supplied the drug are connected to the illegal sex trade, and helped trigger the public order problem, then they need to be shut down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果，供应这个媚药的人与地下风俗有关联，而且正在煽动这次的事件——就一定要摧毁他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果，供應這個媚藥的人與地下風俗有關聯，而且正在煽動這次的事件——就一定要摧毀他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00103",
		linknext = "0070_00105",
		line = 1250,
	},
	["0070_00105"] = {
		{"text"},
		text = {
