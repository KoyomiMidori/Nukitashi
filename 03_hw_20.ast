		{"eval", exp="g.03_hw_20=1"},
		{"fg", mode=-1, id=30},
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"se", id=0, loop=0, file="se_a084"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Excuse me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——打扰了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——打擾了。」",
					{"rt2"},
				},
			},
		},
		linknext = "0070_00002",
		line = 22,
	},
	["0070_00002"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="桐香", id=8, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0607", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes? Oh my, it's been a while, hasn't it? Are you perhaps here to inquire about returning to us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“来了……哎呀，真是令人怀念的人啊。难道你要回FS吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「來了……哎呀，真是令人懷念的人啊。難道你要回FS嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00001",
		linknext = "0070_00003",
		line = 37,
	},
	["0070_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami and I are at the student council office together, where we're greeted with a smile by the student council president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我与雏见白天一起来到学生会室，学生会长以微笑迎接了我们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我與雛見白天一起來到學生會室，學生會長以微笑迎接了我們。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00002",
		linknext = "0070_00004",
		line = 47,
	},
	["0070_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's the only one in the relatively open-concept office. Thankfully, Rei isn't here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"玻璃墙面的室内只有她一人——幸好礼前辈不在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"玻璃牆面的室內只有她一人——幸好禮前輩不在。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00003",
		linknext = "0070_00005",
		line = 57,
	},
	["0070_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, we're here to ask you something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，今天来这里是有事想问一下学生会长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，今天來這裡是有事想問一下學生會長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00004",
		linknext = "0070_00006",
		line = 69,
	},
	["0070_00006"] = {
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0608", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I see. I'm sorry to hear that. If you were to come back, you'd be an obvious pick for a squad leader.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是吗……真冷淡呢，如果你现在回来的话，我明明想给你准备班长的位置呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是嗎……真冷淡呢，如果你現在回來的話，我明明想給你準備班長的位置呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00005",
		linknext = "0070_00007",
		line = 84,
	},
	["0070_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn't look the least bit disheartened, keeping her usual otherworldly aura. It makes her frustratingly difficult to read.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她看起来也没有特别沮丧——还是老样子，看不出她的真意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她看起來也沒有特別沮喪——還是老樣子，看不出她的真意。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00006",
		linknext = "0070_00008",
		line = 94,
	},
	["0070_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ideally, we'd be able to bargain to extract some information from her, but I doubt that would work on her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然打听信息需要用到讨价还价，但我不觉得这招能对付得了她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然打聽訊息需要用到討價還價，但我不覺得這招能對付得了她。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00007",
		linknext = "0070_00009",
		line = 104,
	},
	["0070_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess all I can do is ask her directly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——那么，就直接单刀直入吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——那麼，就直接單刀直入吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00008",
		linknext = "0070_00010",
		line = 114,
	},
	["0070_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Would you be able to tell me who supplied the experimental aphrodisiac the SS has been using lately?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS曾经使用过的媚药试用品——你能告诉我它的来历吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS曾經使用過的媚藥試用品——你能告訴我它的來歷嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00009",
		linknext = "0070_00011",
		line = 125,
	},
	["0070_00011"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0609", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Aphrodisiac? Ah, you mean the one you took during the entrance examination?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“媚药——啊，是前辈在入队考试时喝的对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「媚藥——啊，是前輩在入隊考試時喝的對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00010",
		linknext = "0070_00012",
		line = 141,
	},
	["0070_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. Am I correct in assuming it's the same one that was used in the school's water fountains?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。还有，进货处和掺入给水器里的改进品的是一样的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。還有，進貨處和摻入給水器裡的改進品的是一樣的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00011",
		linknext = "0070_00013",
		line = 152,
	},
	["0070_00013"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0610", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, that's correct.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，你说的没错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，你說的沒錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00012",
		linknext = "0070_00014",
		line = 164,
	},
	["0070_00014"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00103", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1684", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Do you happen to know who supplied it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你知道那些色色的药都是从哪里得到的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你知道那些色色的藥都是從哪裡得到的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00013",
		linknext = "0070_00015",
		line = 178,
	},
	["0070_00015"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0611", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Of course I know. Unfortunately, as per regulations, that information is classified. I cannot reveal it to civilians.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“当然知道……不过按照规定，不能向外人公开资料。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「當然知道……不過按照規定，不能向外人公開資料。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00014",
		linknext = "0070_00016",
		line = 192,
	},
	["0070_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Based on the cool expression on her face, regulations aren't the only reason she won't tell me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那张清爽的脸——看起来不像会对规定之类的事情感到在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那張清爽的臉——看起來不像會對規定之類的事情感到在意。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00015",
		linknext = "0070_00017",
		line = 202,
	},
	["0070_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Isn't there some way to extract the information from her?",
					{"rt2"},
				},
			},
			cn = {
				{
					"难道就不能想办法打听出来吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"難道就不能想辦法打聽出來嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00016",
		linknext = "0070_00018",
		line = 212,
	},
	["0070_00018"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's a bit strange for you to be here by yourself, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……话说回来，只有学生会长一个人在还真是少见啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……話說回來，只有學生會長一個人在還真是少見啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00017",
		linknext = "0070_00019",
		line = 224,
	},
	["0070_00019"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[8500] = {
				{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0612", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. The majority of our resources are occupied with combating the outside organization and recapturing Fumino. However, there is something about the situation that is out of the ordinary.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。因为和那个外部组织的战斗和夺回‘琴寄文乃’的事情，现在很忙……但是，有件事情很不可思议呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。因為和那個外部組織的戰鬥和奪回『琴寄文乃』的事情，現在很忙……但是，有件事情很不可思議呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00018",
		linknext = "0070_00020",
		line = 241,
	},
	["0070_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Out of the ordinary?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不可思议的事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不可思議的事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00019",
		linknext = "0070_00021",
		line = 253,
	},
	["0070_00021"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0613", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That organization seems to think that we have Fumino. Does that not seem strange to you? We don't have her; she was taken out from under us on that day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对方组织深信文乃在我们这边呢。很奇怪对吧？我们那天明明让她逃了，肯定是在对方手上才对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對方組織深信文乃在我們這邊呢。很奇怪對吧？我們那天明明讓她逃了，肯定是在對方手上才對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00020",
		linknext = "0070_00022",
		line = 267,
	},
	["0070_00022"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0614", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I wonder why they'd think that. What do you think, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这是怎么回事呢？前辈，你怎么想？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這是怎麼回事呢？前輩，你怎麼想？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00021",
		linknext = "0070_00023",
		line = 281,
	},
	["0070_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No idea. You'd probably know better than me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谁知道呢……我已经是外人了，所以不知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「誰知道呢……我已經是外人了，所以不知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00022",
		linknext = "0070_00024",
		line = 293,
	},
	["0070_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She just responds with a subtle smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到这个回答，学生会长带着浅笑回答。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到這個回答，學生會長帶著淺笑回答。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00023",
		linknext = "0070_00025",
		line = 303,
	},
	["0070_00025"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0615", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That's not all we have to deal with, either. There's also a bit of a mutiny going on, as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“现在真的有许多麻烦……还有关于背叛的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「現在真的有許多麻煩……還有關於背叛的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00024",
		linknext = "0070_00026",
		line = 317,
	},
	["0070_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mutiny?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“背叛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「背叛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00025",
		linknext = "0070_00027",
		line = 329,
	},
	["0070_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I respond immediately, almost involuntarily.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对这意想不到的回复，我的回答不知不觉变快了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對這意想不到的答覆，我的回答不知不覺變快了。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00026",
		linknext = "0070_00028",
		line = 339,
	},
	["0070_00028"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="touka0616", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. It seems as though there has been some brainwashing within the SS. I wonder how that happened. Were you aware of it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯。SHO的一部分人被洗脑后倒向了敌人那边……怎么了？你知道的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯。SHO的一部分人被洗腦後倒向了敵人那邊……怎麼了？你知道的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00027",
		linknext = "0070_00029",
		line = 355,
	},
	["0070_00029"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes... I'd heard a few things, but just by coincidence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……因为很突然，所以就问了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……因為很突然，所以就問了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00028",
		linknext = "0070_00030",
		line = 367,
	},
	["0070_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just how much does she know about me?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人到底知道多少我的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個人到底知道多少我的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00029",
		linknext = "0070_00031",
		line = 377,
	},
	["0070_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We came here looking for information, but it feels like we're the ones being probed instead.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是来打听药的来源，却反而感觉自己被试探了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是來打聽藥的來源，卻反而感覺自己被試探了。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00030",
		linknext = "0070_00032",
		line = 387,
	},
	["0070_00032"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0617", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You two are both quite close with Rei, are you not? Isn't she most fascinating? Hehe, as are you, Watarai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你们俩都和礼很亲近吧？虽然前辈是个非常有趣的人……呵呵，不过渡会同学也是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你們倆都和禮很親近吧？雖然前輩是個非常有趣的人……呵呵，不過渡會同學也是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00031",
		linknext = "0070_00033",
		line = 401,
	},
	["0070_00033"] = {
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00109", file2="hinami_02l_00201", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="touka_01l_00001", file1="touka_01l_00101", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-100, y=0},
		{"bg", id=2, file="bg16_1l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1685", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Eeek!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呀啊……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呀啊……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00032",
		linknext = "0070_00034",
		line = 418,
	},
	["0070_00034"] = {
		{"fg", file="touka_01l_00001", file1="touka_01l_00112", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-100, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0618", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Ever since I first met you, I've been thinking that there's more to you than meets the eye. There's something hiding within you, that doesn't show on the outside.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“见到的时候我就有感觉了……感觉渡会同学藏着什么秘密。一种看不出来……秘藏的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「見到的時候我就有感覺了……感覺渡會同學藏著什麼秘密。一種看不出來……秘藏的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00033",
		linknext = "0070_00035",
		line = 432,
	},
	["0070_00035"] = {
		{"bgm", stop=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"se", id=0, loop=0, file="se_a084"},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="touka_01m_00001", file1="touka_01m_00112", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=500, mode=3, x=-800, y=0},
		{"fgact", ch="礼", id=9, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0705", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Excuse me. Miss Touka, I've received word from the OSS top brass...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“——失礼了。桐香大人，刚才收到了来自SHO上层的报告……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「——失禮了。桐香大人，剛才收到了來自SHO上層的報告……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00034",
		linknext = "0070_00036",
		line = 454,
	},
	["0070_00036"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1686", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah... Rei...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……礼酱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……禮醬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00035",
		linknext = "0070_00037",
		line = 468,
	},
	["0070_00037"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As soon as she sees us, she freezes in her tracks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈看到我们的身影，只是一瞬间停下了动作——",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩看到我們的身影，只是一瞬間停下了動作——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00036",
		linknext = "0070_00038",
		line = 480,
	},
	["0070_00038"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shortly afterwards, though, she turns back toward the president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，接下来又马上转身朝向学生会长。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，接下來又馬上轉身朝向學生會長。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00037",
		linknext = "0070_00039",
		line = 492,
	},
	["0070_00039"] = {
		{"fgact", ch="礼", id=9, act="移動", x=200, y=0, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She whispers something in the president's ear. I can't make it out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"用我们听不到的声音，悄悄与学生会长说着什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"用我們聽不到的聲音，悄悄與學生會長說著什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00038",
		linknext = "0070_00040",
		line = 503,
	},
	["0070_00040"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0619", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Very well. I'm terribly sorry, but I have to take my leave. Enjoy your stay.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“好，我明白了——很抱歉，我先离开一下。请慢慢来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「好，我明白了——很抱歉，我先離開一下。請慢慢來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00039",
		linknext = "0070_00041",
		line = 517,
	},
	["0070_00041"] = {
		{"se", id=0, loop=0, file="se_a058", vol=50},
		{"fgact", ch="桐香", id=8, act="移動", x=-200, y=0, time=700},
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=500},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her uniform flutters as she turns and gracefully strides out of the office.",
					{"rt2"},
				},
			},
			cn = {
				{
					"拨了一下身穿的制服，她凛然地离开了学生会室。",
					{"rt2"},
				},
			},
			tw = {
				{
					"撥了一下身穿的制服，她凜然地離開了學生會室。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00040",
		linknext = "0070_00042",
		line = 532,
	},
	["0070_00042"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With that, the only ones left in the room are Rei, Hinami, and myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后——房间里，我和雏见和礼前辈3人被留了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後——房間裡，我和雛見和禮前輩3人被留了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00041",
		linknext = "0070_00043",
		line = 543,
	},
	["0070_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The situation is suddenly extremely tense. It feels like time has stopped.",
					{"rt2"},
				},
			},
			cn = {
				{
					"紧张的线被拉着，感觉时间都停了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"緊張的線被拉著，感覺時間都停了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00042",
		linknext = "0070_00044",
		line = 553,
	},
	["0070_00044"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=2, file="bg16_1l_00000", x=500, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0706", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well? What are a pair of traitors doing here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……叛徒，到底还有什么事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……叛徒，到底還有什麼事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00043",
		linknext = "0070_00045",
		line = 571,
	},
	["0070_00045"] = {
		{"se", id=0, loop=0, file="se_a185", vol=50},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her tone is hostile and curt as she rummages through some documents.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈一边翻着资料，一边用充满敌意的冰冷语气询问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩一邊翻著資料，一邊用充滿敵意的冰冷語氣詢問。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00044",
		linknext = "0070_00046",
		line = 582,
	},
	["0070_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her pressure is overwhelming, but I can't back down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感觉要被压制住了——但我不能退缩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感覺要被壓制住了——但我不能退縮。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00045",
		linknext = "0070_00047",
		line = 592,
	},
	["0070_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Can you tell us who supplied the SS with aphrodisiac? The one used in our entrance examination, and the water fountains, and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请你告诉我以前使用过的媚药的来历。我入队考试时和给水器时的那个，还有——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請你告訴我以前使用過的媚藥的來歷。我入隊考試時和給水器時的那個，還有——」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00046",
		linknext = "0070_00048",
		line = 604,
	},
	["0070_00048"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0707", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我拒绝。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我拒絕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00047",
		linknext = "0070_00049",
		line = 616,
	},
	["0070_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She flatly refuses, without room for negotiation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"非常果断，看起来完全无法沟通。",
					{"rt2"},
				},
			},
			tw = {
				{
					"非常果斷，看起來完全無法溝通。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00048",
		linknext = "0070_00050",
		line = 626,
	},
	["0070_00050"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00106", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1687", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei... this is really important. Won't you tell us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱……这是非常重要的大事。能告诉我们吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬……這是非常重要的大事。能告訴我們嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00049",
		linknext = "0070_00051",
		line = 639,
	},
	["0070_00051"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0708", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I'm under no obligation to tell you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我没有义务告诉你们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我沒有義務告訴你們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00050",
		linknext = "0070_00052",
		line = 653,
	},
	["0070_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's ruthless even with Hinami.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是雏见也毫不留情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是雛見也毫不留情。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00051",
		linknext = "0070_00053",
		line = 663,
	},
	["0070_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Given what we did to her, it's not surprising. Hell, it's a shock she's even giving us this much attention.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想想我们干过的事情，其实这一点都不过分。愿意听我们讲话就已经很不错了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想想我們幹過的事情，其實這一點都不過分。願意聽我們講話就已經很不錯了。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00052",
		linknext = "0070_00054",
		line = 673,
	},
	["0070_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, we can't back down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即便如此——我也不能退缩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即便如此——我也不能退縮。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00053",
		linknext = "0070_00055",
		line = 683,
	},
	["0070_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This has concerned us for ages now; it's time we finally confront her directly over it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事到如今了——把以前就很在意的事情直接说出口吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"事到如今了——把以前就很在意的事情直接說出口吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00054",
		linknext = "0070_00056",
		line = 693,
	},
	["0070_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You remember when the SS put the aphrodisiac in the water fountains?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你还记得在给水器里放媚药的时候的事情吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你還記得在給水器裡放媚藥的時候的事情吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00055",
		linknext = "0070_00057",
		line = 704,
	},
	["0070_00057"] = {
		{"se", id=0, loop=0, file="se_a142"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn't respond. She just writes something on the documents in her hands.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈没有回答，安静地在文件上写着什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩沒有回答，安靜地在文件上寫著什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00056",
		linknext = "0070_00058",
		line = 715,
	},
	["0070_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, whatever. I'll just keep talking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管了。继续吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管了。繼續吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00057",
		linknext = "0070_00059",
		line = 725,
	},
	["0070_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That was my suggestion. And, in fact, the Anti-Copulation Front did end up getting somewhat caught up in it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那本来就是我提出的方案，所以你应该觉得反交尾势力没有中招——但事实并不是那样的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那本來就是我提出的方案，所以你應該覺得反交尾勢力沒有中招——但事實並不是那樣的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00058",
		linknext = "0070_00060",
		line = 737,
	},
	["0070_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At the time, it didn't seem like the plan would actually be enacted, so I didn't get the chance to warn my companions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
