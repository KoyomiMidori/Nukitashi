			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hah. I see that really is your surprised expression.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哈哈。原来如此，当你感到惊讶时会露出那种表情是吗，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哈哈。原來如此，當你感到驚訝時會露出那種表情是嗎，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00209",
		linknext = "0070_00211",
		line = 2598,
	},
	["0070_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How much does he know?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个男人——知道文乃在我们身边吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個男人——知道文乃在我們身邊嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00210",
		linknext = "0070_00212",
		line = 2608,
	},
	["0070_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I doubt Rei would've told him what happened that day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不认为是礼前辈说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不認為是禮前輩說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00211",
		linknext = "0070_00213",
		line = 2618,
	},
	["0070_00213"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0031", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That day, the SS lost track of Fumino. However, for some reason, the external organization is under the impression that she's in my possession.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那天FS没能找到文乃。但是不知为什么，外部组织的人都认为文乃就在我们手里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那天FS沒能找到文乃。但是不知為什麼，外部組織的人都認為文乃就在我們手裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00212",
		linknext = "0070_00214",
		line = 2632,
	},
	["0070_00214"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0032", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Then, by some freak coincidence, a promising cadet quit the SS immediately afterwards, despite being on the cusp of their formal appointment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“还有一件事——不知道为什么，那天有一名训练生脱离了FS。明明就快被正式录用了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「還有一件事——不知道為什麼，那天有一名訓練生脫離了FS。明明就快被正式錄用了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00213",
		linknext = "0070_00215",
		line = 2644,
	},
	["0070_00215"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0033", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I think anyone could connect those dots, don't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你不觉得这个状况说明了文乃的所在地吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你不覺得這個狀況說明了文乃的所在地嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00214",
		linknext = "0070_00216",
		line = 2656,
	},
	["0070_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't argue with his reasoning.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无法反驳。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無法反駁。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00215",
		linknext = "0070_00217",
		line = 2666,
	},
	["0070_00217"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0034", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Now, young man, I would like you to join me for a little chat. Won't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“少年。我想和你谈谈……怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「少年。我想和你談談……怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00216",
		linknext = "0070_00218",
		line = 2680,
	},
	["0070_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The passenger door suddenly opens.",
					{"rt2"},
				},
			},
			cn = {
				{
					"副驾驶席的门自动打开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"副駕駛席的門自動打開。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00217",
		linknext = "0070_00219",
		line = 2690,
	},
	["0070_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His tone is cordial enough, but considering what he said about Fumino, I might as well have a gun to my head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他的语气虽然温和，但听了文乃的话后，我就像被枪口对准了一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他的語氣雖然溫和，但聽了文乃的話後，我就像被槍口對準了一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00218",
		linknext = "0070_00220",
		line = 2700,
	},
	["0070_00220"] = {
		{"bgm", stop=1},
		{"se", id=1, stop=1, time=1500},
