					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Even if they're organized crime?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“即使对方是黑道？”",
