				},
			},
		},
		linkback = "0070_00142",
		linknext = "0070_00144",
		line = 1737,
	},
	["0070_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wet my throat with Fumino's hot roasted barley tea as I formulate a plan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我用热乎乎的煎茶润喉，在脑中推敲策略。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我用熱呼呼的煎茶潤喉，在腦中擬定策略。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00143",
		linknext = "0070_00145",
		line = 1747,
	},
	["0070_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If that place is as much of a crime hotbed as it looks like, then it's likely at least one of the main Yakuza hives on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"假如那家店有地下室，那里成了犯罪的温床的话——应该会有不少黑社会常驻在那里吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"假如那家店有地下室，那裡成了犯罪的溫床的話——應該會有不少黑社會常駐在那裡吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00144",
		linknext = "0070_00146",
		line = 1757,
	},
	["0070_00146"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00112", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=200},
		{"fgact", ch="文乃", id=7, act="移動", x=0, y=-200, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Based on their numbers when we engaged them over Fumino, there's obviously a lot of them. How should we approach this?",
					{"rt2"},
				},
			},
			cn = {
				{
					"在确保文乃安全的时候交战过，可以看出他们的数量绝对不少。应该采取什么手段呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"在確保文乃安全的時候交戰過，可以看出他們的數量絕對不少。應該採取什麼手段呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00145",
		linknext = "0070_00147",
		line = 1769,
	},
	["0070_00147"] = {
