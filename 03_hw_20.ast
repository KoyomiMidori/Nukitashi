	["0070_00141"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You fought the Yakuza quite often. What was it actually like?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃经常和黑社会交战对吧……实际上有什么感觉？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃經常和黑社會交戰對吧……實際上有什麼感覺？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00140",
		linknext = "0070_00142",
		line = 1711,
	},
	["0070_00142"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0254", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I recall that hillside was the location of a disproportionate amount of my encounters with them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……我记得很常和他们在山之手交战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……我記得很常和他們在山之手交戰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00141",
		linknext = "0070_00143",
		line = 1725,
	},
	["0070_00143"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That adult shop is smelling more foul by the minute.",
					{"rt2"},
				},
			},
			cn = {
				{
					"终于，那个成人商店变得越来越可疑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"終於，那個成人商店變得越來越可疑了。",
