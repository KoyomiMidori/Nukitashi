			tw = {
				{
					"也許是在威嚇我——但也就是說，我說中了她的要害。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00082",
		linknext = "0070_00084",
		line = 1011,
	},
	["0070_00084"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You look down on the Anti-Copulation Front with contempt, while still trying to protect just Hinami. At the same time, you indiscriminately approved the use of the aphrodisiac on the students.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“敌视反交尾势力的同时，另一方面却在保护着雏见，但却又干出无差别播散媚药这种事情——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「敵視反交尾勢力的同時，另一方面卻在保護著雛見，但卻又幹出無差別播散媚藥這種事情——」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00083",
		linknext = "0070_00085",
		line = 1023,
	},
	["0070_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that not a bit of an inconsistency?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈干的事情，不奇怪吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩幹的事情，不奇怪嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00084",
		linknext = "0070_00086",
		line = 1034,
	},
	["0070_00086"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0711", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It would be, if it were true. I made no effort to protect Hinami's chastity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……这是当然的。因为你的前提是错误的。我并没有想要保护雏见的贞操。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……這是當然的。因為你的前提是錯誤的。我並沒有想要保護雛見的貞操。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00085",
		linknext = "0070_00087",
		line = 1048,
	},
	["0070_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then why didn't you make her have sex during the entrance examination?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“入队考试时也没有让雏见做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「入隊考試時也沒有讓雛見做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00086",
		linknext = "0070_00088",
		line = 1059,
	},
	["0070_00088"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0712", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I just took the appropriate action based on her disposition.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我只是采取了最能看出资质的方法而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我只是採取了最能看出資質的方法而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00087",
		linknext = "0070_00089",
		line = 1071,
	},
	["0070_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then can you truthfully say, right now, that you'd be fine with any random dude off the street taking Hinami away and having sex with her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那如果要你现在随便叫一个男生过来，让他跟雏见做爱——你也办得到吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那如果要你現在隨便叫一個男生過來，讓他跟雛見做愛——你也辦得到嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00088",
		linknext = "0070_00090",
		line = 1082,
	},
	["0070_00090"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0713", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I can...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“…………办得到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「…………辦得到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00089",
		linknext = "0070_00091",
		line = 1094,
	},
	["0070_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There was a definite pause.",
					{"rt2"},
				},
			},
			cn = {
				{
					"慢了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"慢了。",
					{"rt2"},
				},
