					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's an adult goods shop. It's kinda out in the middle of nowhere, so it makes sense that you wouldn't know it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是成人用品店。因为在人少的地方，所以雏见不知道也很正常。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是成人用品店。因為在人少的地方，所以雛見不知道也很正常。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00126",
		linknext = "0070_00128",
		line = 1552,
	},
	["0070_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Actually, thinking about it logically, it doesn't make sense to have a store out there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，的确——冷静地想想，那个店有一些奇怪的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，的確——冷靜地想想，那個店有一些奇怪的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00127",
		linknext = "0070_00129",
		line = 1562,
	},
	["0070_00129"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For one thing, it's not in a place where anyone ever really goes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"首先，在那么没人潮的地方这点很奇怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"首先，在那麼沒人潮的地方這點很奇怪。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00128",
		linknext = "0070_00130",
		line = 1574,
	},
	["0070_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While it would make sense for an adult shop somewhere discreet on the mainland, there's no reason to do that on Seiran Island, where people fuck freely in public. Hell, it would probably be a big box store here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是本岛还可以理解，但在四面八方都是色情的青蓝岛上，成人商店没有必要在意别人的目光。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是本島還可以理解，但在四面八方都是色情的青藍島上，成人商店沒有必要在意別人的目光。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00129",
		linknext = "0070_00131",
		line = 1584,
	},
	["0070_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Plus, whenever I've gone there, it's been pretty deserted. I'm shocked it's been able to survive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，到目前为止我去的时候，人也都非常少——没有倒闭这点反而令人怀疑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，到目前為止我去的時候，人也都非常少——沒有倒閉這點反而令人懷疑。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00130",
		linknext = "0070_00132",
		line = 1594,
	},
	["0070_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Where is its funding coming from?",
					{"rt2"},
				},
			},
			cn = {
				{
					"它的营运资金到底是从哪里来的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"它的營運資金到底是從哪裡來的。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00131",
		linknext = "0070_00133",
		line = 1604,
	},
	["0070_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why would it be so remote, and serving a virtually nonexistent market?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么会在在那种避人耳目的地方，贩卖在青蓝岛上没有需求的商品。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼會在在那種避人耳目的地方，販賣在青藍島上沒有需求的商品。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00132",
		linknext = "0070_00134",
		line = 1614,
	},
	["0070_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If it's that far from civilization, in a place where no one goes, the logical conclusion is that its owners would object to its existence being widely known.",
					{"rt2"},
				},
			},
			cn = {
				{
					"会在人少的地方，难道就是因为在干一些不想被别人知道的事情吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"會在人少的地方，難道就是因為在幹一些不想被別人知道的事情嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00133",
		linknext = "0070_00135",
		line = 1624,
	},
	["0070_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you think the Mutable Membrane also serves the illegal sex industry?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一时的皮膜也营运着地下风俗——你觉得有这种可能性吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一時的皮膜也營運著地下風俗——你覺得有這種可能性嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00134",
		linknext = "0070_00136",
		line = 1636,
	},
	["0070_00136"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1163", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Maybe... actually, yeah, probably. Here's the stuff you scanned from the disciplinary committee office.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不是没有……应该说可能性相当高吧。这个，之前哥哥在风纪委员室扫描的数据……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不是沒有……應該說可能性相當高吧。這個，之前哥哥在風紀委員室掃描的數據……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00135",
		linknext = "0070_00137",
		line = 1649,
	},
	["0070_00137"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"bg", id=2, file="bg12_1l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"se", id=0, loop=0, file="se_b030", vol=70},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a map displayed on the monitor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"显示器上显示出地图。",
					{"rt2"},
				},
			},
			tw = {
				{
					"顯示器上顯示出地圖。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00136",
		linknext = "0070_00138",
		line = 1663,
	},
	["0070_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a map of incidents where the external organization is known to have been involved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是把有外部组织参与可能性的事件总结在上面的地图。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是把有外部組織參與可能性的事件總結在上面的地圖。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00137",
		linknext = "0070_00139",
		line = 1673,
	},
	["0070_00139"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00103", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1164", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Look at where they're concentrated. Most of the incidents have been up in the hills, around the Mutable Membrane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“山那边……一时的皮膜周围，和其他地方比起来数量多了很多对吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「山那邊……一時的皮膜周圍，和其他地方比起來數量多了很多對吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00138",
		linknext = "0070_00140",
		line = 1686,
	},
	["0070_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thinking of what all those little X marks mean makes my stomach turn.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一想到地图上红叉所表示的意思——就觉得恶心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一想到地圖上紅叉所表示的意思——就覺得噁心。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00139",
