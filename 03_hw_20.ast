		{"bg", id=1, file="bg04_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm04.5", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I get in, and he drives me to his residence in the hills.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我坐着汽车来到了为于高处的仁浦先生的宅邸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我坐著汽車來到了為於高處的仁浦先生的宅邸。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00219",
		linknext = "0070_00221",
		line = 2746,
	},
	["0070_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The house is old, but just briefly walking through it, I can tell it must've cost a fortune.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说是古色古香的房子，但光是走着就能知道每一处都很精致。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說是古色古香的房子，但光是走著就能知道每一處都很精緻。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00220",
		linknext = "0070_00222",
		line = 2756,
	},
	["0070_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The corridor has massive rooms opening off from it left and right. There's even a gym.",
					{"rt2"},
				},
			},
			cn = {
				{
					"沿着走廊相连的房间每个都宽广得不得了，甚至有个像是道场的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沿著走廊相連的房間每個都寬廣得不得了，甚至有個像是道場的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00221",
		linknext = "0070_00223",
		line = 2766,
	},
	["0070_00223"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You use this alone?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……在这里一个人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……在這裡一個人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00222",
		linknext = "0070_00224",
		line = 2778,
	},
	["0070_00224"] = {
		{"bg", id=1, file="bg04_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0035", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Yeah. Kendo is a bit of a hobby of mine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊，我喜欢剑术。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊，我喜歡劍術。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00223",
		linknext = "0070_00225",
		line = 2792,
	},
	["0070_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wonder if the swords hung up there are fake?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那里的摆设是仿造刀吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡的擺設是仿造刀吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00224",
		linknext = "0070_00226",
		line = 2802,
	},
	["0070_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They look absolutely priceless, but there's a certain unusual aura coming from them that I can notice from here, so I can't say for sure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我根本不懂物品的价值——但远远地就能感受到异样气氛，感觉就像真刀一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我根本不懂物品的價值——但遠遠地就能感受到異樣氣氛，感覺就像真刀一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00225",
		linknext = "0070_00227",
		line = 2812,
	},
	["0070_00227"] = {
		{"se", id=0, loop=0, file="se_a250"},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=100},
		{"bg", id=1, file="bg24_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, what did you want to talk about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——那么，你是想和我说什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——那麼，你是想和我說什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00226",
		linknext = "0070_00228",
		line = 2831,
	},
	["0070_00228"] = {
		{"bg", id=1, file="bg24_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He takes me to the innermost room and has me sit across from him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"来到最深处的房间，我和仁浦先生面对面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"來到最深處的房間，我和仁浦先生面對面。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00227",
		linknext = "0070_00229",
		line = 2843,
	},
	["0070_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you want me to hand over Fumino, then we're done here. I can't do that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果要我把文乃交给你，我做不到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果要我把文乃交給你，我做不到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00228",
		linknext = "0070_00230",
		line = 2854,
	},
	["0070_00230"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0036", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oh my, so hasty. No, she's not the reason I brought you here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……别这么急。我不是为了文乃才叫你来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……別這麼急。我不是為了文乃才叫你來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00229",
		linknext = "0070_00231",
		line = 2868,
	},
	["0070_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then what...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么到底是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼到底是——」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00230",
		linknext = "0070_00232",
		line = 2879,
	},
	["0070_00232"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0037", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“There are a number of issues on the island that are causing the citizens to lose faith. I want to dedicate all available human resources to counter it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为种种问题而让青蓝岛的信用动摇是事实……现在确实该把人手花在那边的对策上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為種種問題而讓青藍島的信用動搖是事實……現在確實該把人手花在那邊的對策上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00231",
		linknext = "0070_00233",
		line = 2893,
	},
	["0070_00233"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You say that, but aren't you ignoring the biggest one? You aren't exactly being proactive in dealing with the illegal sex trade.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但你好像把最大的问题——地下风俗的事情置之不理呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但你好像把最大的問題——地下風俗的事情置之不理呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00232",
		linknext = "0070_00234",
		line = 2905,
	},
	["0070_00234"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0038", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“All in time. There's a proper order of operations. If we were to shut it down, and its existence were to come to light, it would jeopardize the entire culture of the island. Before dealing with it, we must make sure that doesn't happen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“事物是有顺序的。现在把他们摧毁，让事情浮出水面的话，岛的问题会更加引人注目吧。所以有必要先考虑一下善后方案。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「事物是有順序的。現在把他們摧毀，讓事情浮出水面的話，島的問題會更加引人注目吧。所以有必要先考慮一下善後方案。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00233",
		linknext = "0070_00235",
		line = 2917,
	},
	["0070_00235"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if it means allowing it to go unchecked longer?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算在这段期间里出现了更多的受害者？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算在這段期間裡出現了更多的受害者？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00234",
		linknext = "0070_00236",
		line = 2929,
	},
	["0070_00236"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0039", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Rushing to deal with the immediate problem would expose us to heavy external criticism. That would damage the island far more than the illegal sex trade's existence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果只盯着眼前的事情采取行动，最终只会让青蓝岛背上没来由的罪名。到那个时候，受害者的数量将会远远超过地下风俗吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果只盯著眼前的事情採取行動，最終只會讓青藍島背上沒來由的罪名。到那個時候，受害者的數量將會遠遠超過地下風俗吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00235",
		linknext = "0070_00237",
		line = 2941,
	},
	["0070_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's as thoroughly pragmatic as ever. I'm starting to doubt whether he has any human emotions whatsoever.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仍然是贯彻到底的合理主义。让人怀疑他到底有没有作为人的感情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仍然是貫徹到底的合理主義。讓人懷疑他到底有沒有作為人的感情。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00236",
		linknext = "0070_00238",
		line = 2951,
	},
	["0070_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, though, that pragmatic approach has its inherent logic, which pisses me off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，正因为合理，所以这个男人说的话很有一惯性——这让我很不爽。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，正因為合理，所以這個男人說的話很有一慣性——這讓我很不爽。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00237",
		linknext = "0070_00239",
		line = 2961,
	},
	["0070_00239"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0040", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You have Fumino, and I can see how you look at me. I assume you object to the perverted sex law I created and wish to have it abolished.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“得到了文乃，还用那样的眼神看我。你……是想改变这个条例对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「得到了文乃，還用那樣的眼神看我。你……是想改變這個條例對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00238",
		linknext = "0070_00240",
		line = 2975,
	},
	["0070_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00239",
		linknext = "0070_00241",
		line = 2986,
	},
	["0070_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no point in trying to hide it at this point.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事到如今，已经没必要隐瞒了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"事到如今，已經沒必要隱瞞了。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00240",
		linknext = "0070_00242",
		line = 2996,
	},
	["0070_00242"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0041", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I see. Then why haven't you used it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这样啊……那么，你为什么不使用？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這樣啊……那麼，你為什麼不使用？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00241",
		linknext = "0070_00243",
		line = 3010,
	},
	["0070_00243"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you talking about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你在说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你在說什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00242",
		linknext = "0070_00244",
		line = 3021,
	},
	["0070_00244"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0042", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“As much as you reject random sex, I'm sure you know that you could use THAT to easily subjugate every woman on the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你似乎在拒绝毫无秩序的性……那你只要使用",
					{"ruby", text="・・"},
					"那个",
					{"/ruby"},
					"，就可以轻易让岛上的女人们屈服不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你似乎在拒絕毫無秩序的性……那你只要使用",
					{"ruby", text="・・"},
					"那個",
					{"/ruby"},
					"，就可以輕易讓島上的女人們屈服不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00243",
		linknext = "0070_00245",
		line = 3035,
	},
	["0070_00245"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「————」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00244",
		linknext = "0070_00246",
		line = 3047,
	},
	["0070_00246"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0043", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I believe I told you when we first met that I've been investigating you. I know you've already had Onabuta and Tadasugawa, two of the top three in the SS, succumb to its power.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我稍微调查了一下你的事情。女部田和糺川——FS引以为荣的三人内的两人已经被你用",
					{"ruby", text="・・・・"},
					"那个力量",
					{"/ruby"},
					"击退了不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我稍微調查了一下你的事情。女部田和糺川——FS引以為榮的三人內的兩人已經被你用",
					{"ruby", text="・・・・"},
					"那個力量",
					{"/ruby"},
					"擊退了不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00245",
		linknext = "0070_00247",
		line = 3059,
	},
	["0070_00247"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He even knows that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个男人，连那种事情也知道吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個男人，連那種事情也知道嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00246",
		linknext = "0070_00248",
		line = 3069,
	},
	["0070_00248"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0044", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If you're so dedicated to change the island — to crush the perverted sex law — then why not make use of it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“想要改变岛——想要破坏变态条例的话，为什么不使用那个力量？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「想要改變島——想要破壞變態條例的話，為什麼不使用那個力量？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00247",
		linknext = "0070_00249",
		line = 3081,
	},
	["0070_00249"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not like you. I won't do whatever it takes in order to achieve my objectives.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我与你不同。并不是只要能达成目的，就什么都可以做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我與你不同。並不是只要能達成目的，就什麼都可以做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00248",
		linknext = "0070_00250",
		line = 3093,
	},
	["0070_00250"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0045", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Have you not already with how you used the SS? I told you before that to succeed is to perform evil to get ahead, then doing it again to stay there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是，你利用了FS，还背叛了他们……我之前也说了。所谓的成功，就是做出了恶行而得胜，然后再用更多的恶去守护它。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是，你利用了FS，還背叛了他們……我之前也說了。所謂的成功，就是做出了惡行而得勝，然後再用更多的惡去守護它。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00249",
		linknext = "0070_00251",
		line = 3107,
	},
	["0070_00251"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0046", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Young man. You betrayed the SS. You performed an evil act, and you won Fumino. If you are unwilling to continue to perform acts of evil, you will not be able to retain her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“少年。你背叛了FS——做出了恶行而得到了文乃。如果想继续守护下去，就只能继续犯下罪恶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「少年。你背叛了FS——做出了惡行而得到了文乃。如果想繼續守護下去，就只能繼續犯下罪惡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00250",
		linknext = "0070_00252",
		line = 3119,
	},
	["0070_00252"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, I am familiar with your views. I don't see why you need to impose them on everyone else.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那只是你的想法。你只是把自己的成功经验当成世间的常识而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那隻是你的想法。你只是把自己的成功經驗當成世間的常識而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00251",
		linknext = "0070_00253",
		line = 3131,
	},
	["0070_00253"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0047", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Perhaps. However, you're trying to destroy my law. Is that not evil in itself?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“可能是吧。但是，你能断言想要破坏条例的你的作为，不是邪恶的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「可能是吧。但是，你能斷言想要破壞條例的你的作為，不是邪惡的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00252",
		linknext = "0070_00254",
		line = 3145,
	},
	["0070_00254"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0048", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You see and hear all the moans of pleasure from the people. Can you truly say that trying to take that away from them is not evil?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你总是有看到吧。有听到吧。沉沦于快乐中的人们的呻吟……将那些从他们身上夺走，难道你能断言那是正确的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你總是有看到吧。有聽到吧。沉淪於快樂中的人們的呻吟……將那些從他們身上奪走，難道你能斷言那是正確的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00253",
		linknext = "0070_00255",
		line = 3157,
	},
	["0070_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What he's saying is totally correct. I find myself feeling somewhat shaken by it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他说的，完全没有任何错误。正因为如此，这些话很有效，差点动摇了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他說的，完全沒有任何錯誤。正因為如此，這些話很有效，差點動搖了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00254",
		linknext = "0070_00256",
		line = 3167,
	},
	["0070_00256"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, what I object to is what has gone unsaid.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，说到底——只是没有错误。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，說到底——只是沒有錯誤。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00255",
		linknext = "0070_00257",
		line = 3177,
	},
	["0070_00257"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sure, but that's just looking at the surface.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你只是看着这个条例的表面在说话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你只是看著這個條例的表面在說話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00256",
		linknext = "0070_00258",
		line = 3189,
	},
	["0070_00258"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're ignoring all the people who are suffering just below that. You think they're just a necessary sacrifice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“轻视在这背后痛苦的人们。认为一些牺牲是理所当然的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「輕視在這背後痛苦的人們。認為一些犧牲是理所當然的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00257",
		linknext = "0070_00259",
		line = 3200,
	},
	["0070_00259"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“However, I've seen those people. I've seen how they're persecuted.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……拯救我的，就是那些深受其害的人们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……拯救我的，就是那些深受其害的人們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00258",
		linknext = "0070_00260",
		line = 3212,
	},
	["0070_00260"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That kind girl who reached out to me when I was bullied, and supported me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小时候被欺负、被弄哭的时候，善良的女孩向我伸出了友谊之手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小時候被欺負、被弄哭的時候，善良的女孩向我伸出了友誼之手。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00259",
		linknext = "0070_00261",
		line = 3222,
	},
	["0070_00261"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The woman who acknowledged me, even though she was a victim of marginalization.",
					{"rt2"},
				},
			},
			cn = {
				{
					"伤害了她而感到绝望的时候，也有人肯定了那样的我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"傷害了她而感到絕望的時候，也有人肯定了那樣的我。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00260",
		linknext = "0070_00262",
		line = 3232,
	},
	["0070_00262"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even now, after I returned to the island, the senior I befriended, used, and betrayed for the sake of my own goals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"时隔数年回到岛上——为了破坏条例这个目的，我利用了对我很亲切的前辈，背叛了她——",
					{"rt2"},
				},
			},
			tw = {
				{
					"時隔數年回到島上——為了破壞條例這個目的，我利用了對我很親切的前輩，背叛了她——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00261",
		linknext = "0070_00263",
		line = 3242,
	},
	["0070_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hell, even when I said I didn't want anyone else to be hurt and attempted to take it all on myself, the girl who shed tears for me once more and said she'd be there for me, no matter what.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我不愿意再伤害任何一个人，想要背负所有事情的时候——希望我不要这么做，想成为我的力量——出现了愿意为我流泪的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我不願意再傷害任何一個人，想要背負所有事情的時候——希望我不要這麼做，想成為我的力量——出現了願意為我流淚的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00262",
		linknext = "0070_00264",
		line = 3252,
	},
	["0070_00264"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll never let them be forsaken again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我是绝对不会舍弃他们的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我是絕對不會捨棄他們的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00263",
		linknext = "0070_00265",
		line = 3264,
	},
	["0070_00265"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0049", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Is that so? Meh, what a pity to let such a power go to waste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是吗……真可惜。明明你有那种力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是嗎……真可惜。明明你有那種力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00264",
		linknext = "0070_00266",
		line = 3278,
	},
	["0070_00266"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Governor. If you're going to a blind eye to the Yakuza's operations in the name of the island's security, then I'll take it upon myself to crush them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事。如果你害怕岛上出现恶评而对黑社会的行径视而不见的话——就由我来打垮他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事。如果你害怕島上出現惡評而對黑社會的行徑視而不見的話——就由我來打垮他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00265",
		linknext = "0070_00267",
		line = 3290,
	},
	["0070_00267"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0050", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oho? With what resources, manpower, and combat capability you have, you plan to challenge them? How reckless of you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哦？一边说着不舍弃同伴，一边还想用那种战斗力去挑战他们？会不会太有勇无谋了点？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哦？一邊說著不捨棄同伴，一邊還想用那種戰鬥力去挑戰他們？會不會太有勇無謀了點？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00266",
		linknext = "0070_00268",
		line = 3304,
	},
	["0070_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wow, he even knows our combat capabilities. Forgive me if I'm not surprised.",
					{"rt2"},
				},
			},
			cn = {
				{
					"连我们的战斗力都知道了——我甚至已经连吃惊都忘了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連我們的戰鬥力都知道了——我甚至已經連吃驚都忘了。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00267",
		linknext = "0070_00269",
		line = 3314,
	},
	["0070_00269"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0051", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Still, let's see. If that's what you want, then I can let you have some of the SS forces at your disposal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不过，也是。如果你如此希望的话——我可以把FS的一部分战力借给你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不過，也是。如果你如此希望的話——我可以把FS的一部分戰力借給你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00268",
		linknext = "0070_00270",
		line = 3328,
	},
	["0070_00270"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? What for?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……你在盘算什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……你在盤算什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00269",
		linknext = "0070_00271",
		line = 3340,
	},
	["0070_00271"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0052", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Didn't I tell you? It's such a shame for such a potent power to go to waste. You won't respond to money or threats, but you're an emotional one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我不是说过吗？要抛弃你的力量实在可惜……虽然你不是那种会向金钱或威胁屈服的人——但你似乎重情重义。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我不是說過嗎？要拋棄你的力量實在可惜……雖然你不是那種會向金錢或威脅屈服的人——但你似乎重情重義。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00270",
		linknext = "0070_00272",
		line = 3354,
	},
	["0070_00272"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0053", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So that's why I'll loan them to you. What a villain I am, don't you agree?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“正因为如此，我才会想让你欠我一次。呵……很像恶人的作风吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「正因為如此，我才會想讓你欠我一次。呵……很像惡人的作風吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00271",
		linknext = "0070_00273",
		line = 3370,
	},
	["0070_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The man who created the perverted sex law puts on a dauntless smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"制订变态条例的男人露出大胆的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"制訂變態條例的男人露出大膽的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00272",
		linknext = "0070_00274",
		line = 3380,
	},
	["0070_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why is this man, who possesses money and authority, so obsessed with a simple student like me?",
					{"rt2"},
				},
			},
			cn = {
				{
					"既有钱又有地位的男人，为什么会执着于只是一介学生的我呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"既有錢又有地位的男人，為什麼會執著於只是一介學生的我呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00273",
		linknext = "0070_00275",
		line = 3390,
	},
	["0070_00275"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What do those cold, analytical eyes see in me?",
					{"rt2"},
				},
			},
			cn = {
				{
					"究竟，那双冰冷的眼睛，在盯着一条怎样的道路——",
					{"rt2"},
				},
			},
			tw = {
				{
					"究竟，那雙冰冷的眼睛，在盯著一條怎樣的道路——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00274",
		linknext = "0070_00276",
		line = 3400,
	},
	["0070_00276"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
