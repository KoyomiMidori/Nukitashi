		},
		linkback = "0070_00090",
		linknext = "0070_00092",
		line = 1104,
	},
	["0070_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She took a long time to respond.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回答得太慢了。",
					{"rt2"},
				},
