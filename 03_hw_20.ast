			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I like that look. That's why I'm lending her to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“表情不错。所以，我就——把她借给你吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「表情不錯。所以，我就——把她借給你吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00275",
		linknext = "0070_00277",
		line = 3414,
	},
