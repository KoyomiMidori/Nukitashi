		linknext = "0070_00114",
		line = 1355,
	},
	["0070_00114"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0717", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“As I'm sure you know, I'm a very busy woman. I don't have time to continue entertaining your inane questions. Get out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我很忙。没时间一直回答你们无聊的问题——出去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我很忙。沒時間一直回答你們無聊的問題——出去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00113",
		linknext = "0070_00115",
		line = 1369,
	},
