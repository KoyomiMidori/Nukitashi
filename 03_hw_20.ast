	},
	["0070_00148"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00120", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0255", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“B... But I'm not a loli...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我……我不是萝莉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我……我不是蘿莉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00147",
		linknext = "0070_00149",
		line = 1796,
	},
	["0070_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What was that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到底怎么了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到底怎麼了……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00148",
		linknext = "0070_00150",
		line = 1808,
	},
	["0070_00150"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00106", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0256", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Oh, um... I was just wondering if you would allow me to accompany you on the next operation...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“呃，嗯……下次战斗的时候，能不能带我一起去……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「呃，嗯……下次戰鬥的時候，能不能帶我一起去……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00149",
		linknext = "0070_00151",
		line = 1822,
	},
	["0070_00151"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I appreciate the offer, but we've got other plans for you. Sorry, I'm sure it's frustrating to just be watching the base all the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我很高兴你能这么说……但对不起。一直负责看家，事情还没有什么进展，的确会让人着急对吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我很高興你能這麼說……但對不起。一直負責看家，事情還沒有什麼進展，的確會讓人著急對吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00150",
		linknext = "0070_00152",
		line = 1834,
	},
	["0070_00152"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00115", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0257", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No, that's not true. Keeping watch is a respectable task, as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不，不是的……看家也是很重要的责任。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不，不是的……看家也是很重要的責任。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00151",
		linknext = "0070_00153",
		line = 1848,
	},
	["0070_00153"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00115", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00106", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0442", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hrmph... I thought maybe if she imitated Wata, it would've worked...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“唔唔……我还以为只要学渡酱就能行了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「唔唔……我還以為只要學渡醬就能行了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00152",
		linknext = "0070_00154",
		line = 1864,
	},
	["0070_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the hell are you making her do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是想让文乃做什么啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是想讓文乃做什麼啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00153",
		linknext = "0070_00155",
		line = 1875,
	},
	["0070_00155"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=-400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0443", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Everyone's keeping me out of the loop! Fumino is the only one on my side... indubitably.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为大家都把我排除在外啊！只有文乃酱是我的同伴……原来原来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為大家都把我排除在外啊！只有文乃醬是我的同伴……原來原來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00154",
		linknext = "0070_00156",
		line = 1891,
	},
	["0070_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't get her wrapped up in your bullshit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要对文乃说太多奇怪的话哦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要對文乃說太多奇怪的話哦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00155",
		linknext = "0070_00157",
		line = 1903,
	},
	["0070_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I sigh and resume my brainstorming.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我叹了口气，转换个思考方式。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我嘆了口氣，轉換個思考方式。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00156",
		linknext = "0070_00158",
		line = 1913,
	},
	["0070_00158"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Let's assume for now that the Mutable Membrane is the home base of either the Yakuza, the illegal sex trade, or possibly both.",
					{"rt2"},
				},
			},
			cn = {
				{
					"假设“一时的皮膜”是黑社会的基地或者是地下风俗——或者两者兼具。",
					{"rt2"},
				},
			},
			tw = {
				{
					"假設「一時的皮膜」是黑社會的基地或者是地下風俗——或者兩者兼具。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00157",
		linknext = "0070_00159",
		line = 1927,
	},
	["0070_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if we have some idea of where they're based, that still doesn't solve the issue of what to do about them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然从以前就是个重要的课题——如何战胜他们，这是最大的问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然從以前就是個重要的課題——如何戰勝他們，這是最大的問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00158",
		linknext = "0070_00160",
		line = 1937,
	},
	["0070_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they're holed up underground, then that's an enclosed area. We could blind them all with smoke grenades, then use the goggles...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果他们藏在地下室，那就用烟雾弹夺去他们的视线，依靠护目镜的力量——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果他們藏在地下室，那就用煙霧彈奪去他們的視線，依靠護目鏡的力量——",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00159",
		linknext = "0070_00161",
		line = 1947,
	},
	["0070_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, we've only got one pair. Hinami would never allow me to go alone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，护目镜只有一个。独自一人去的风险太大了，这种事雏见绝对不会允许的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，護目鏡只有一個。獨自一人去的風險太大了，這種事雛見絕對不會允許的。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00160",
		linknext = "0070_00162",
		line = 1957,
	},
	["0070_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think back on the assault on the hill to rescue Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在才想起为了确保文乃安全而在山里奔跑时的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在才想起為了確保文乃安全而在山裡奔跑時的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00161",
		linknext = "0070_00163",
		line = 1967,
	},
	["0070_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were able to hold them off without much difficulty that day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时明明很容易就摆脱了碰到的黑社会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時明明很容易就擺脫了碰到的黑社會。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00162",
		linknext = "0070_00164",
		line = 1977,
	},
	["0070_00164"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How were we able to do that so easily?",
					{"rt2"},
