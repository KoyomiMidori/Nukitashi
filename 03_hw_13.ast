					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是的。」",
