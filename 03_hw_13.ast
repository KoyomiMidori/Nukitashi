					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's true...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“确实——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「確實——」",
					{"rt2"},
