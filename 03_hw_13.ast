			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There's only one thing I know about her: she poses a threat to both the perverted sex law and the island as a whole.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“目前就只知道一件事……她是能威胁到这个岛——威胁到变态条例的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「目前就只知道一件事……她是能威脅到這個島——威脅到變態條例的存在。」",
					{"rt2"},
				},
