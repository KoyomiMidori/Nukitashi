		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El documento que escaneé antes con mis gafas tiene un anexo, así que debería contener toda la información más reciente e interesante del comercio sexual ilegal.",
					{"rt2"},
