		},
		linkback = "0063_00175",
		linknext = "0063_00177",
		line = 2264,
	},
	["0063_00177"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1277", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hmm... Companion, friend, family? Any of those would be precious to someone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……同伴、朋友、家人，大家都很重要吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……同伴、朋友、家人，大家都很重要吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00176",
		linknext = "0063_00178",
		line = 2278,
	},
	["0063_00178"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Family...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“家人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「家人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00177",
		linknext = "0063_00179",
		line = 2290,
	},
	["0063_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's single and has never been married.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生是单身，没有妻子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生是單身，沒有妻子。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00178",
		linknext = "0063_00180",
		line = 2300,
	},
	["0063_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino is younger than us, so there's no way she's his sibling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，文乃比我们年轻——从这一点来看，仁浦先生的血缘关系这条线就消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，文乃比我們年輕——從這一點來看，仁浦先生的血緣關係這條線就消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00179",
		linknext = "0063_00181",
		line = 2310,
	},
	["0063_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, if she were his family...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即便如此，如果假定文乃是仁浦先生的家人的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即便如此，如果假定文乃是仁浦先生的家人的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00180",
		linknext = "0063_00182",
		line = 2320,
	},
	["0063_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...And her existence poses an existential threat to the law...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说文乃的存在与条例的瓦解息息相关的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說文乃的存在與條例的瓦解息息相關的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00181",
		linknext = "0063_00183",
		line = 2330,
	},
	["0063_00183"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If, hypothetically, Fumino happened to be the governor's illegitimate child, it opens a lot of questions, but it would make some things make sense.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“假如，文乃是县知事的私生女的话——虽然还有很多疑问，不过能说得通。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「假如，文乃是縣知事的私生女的話——雖然還有很多疑問，不過能說得通。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00182",
		linknext = "0063_00184",
		line = 2342,
	},
	["0063_00184"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1278", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“So he'd want to protect Fumino because he's her dad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果是那样，那他是作为父亲在担心，所以才想要保护文乃吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果是那樣，那他是作為父親在擔心，所以才想要保護文乃嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00183",
		linknext = "0063_00185",
		line = 2356,
	},
	["0063_00185"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's not necessarily what I was thinking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那……到底是不是呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那……到底是不是呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00184",
		linknext = "0063_00186",
		line = 2368,
	},
	["0063_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Could someone like him even have feelings like that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个男人真的有那样的感情吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個男人真的有那樣的感情嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00185",
		linknext = "0063_00187",
		line = 2378,
	},
	["0063_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't pretend to know him well, since we've only spoken once, but he came across as an intense pragmatist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然只说过一次话——但我从他身上得到的印象，是过于清爽的合理主义者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然只說過一次話——但我從他身上得到的印象，是過於清爽的合理主義者。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00186",
		linknext = "0063_00188",
		line = 2388,
	},
	["0063_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If he saw his illegitimate child as a fatal weakness, then he'd want to secure her to keep that info from leaking. That's the kind of filth I'm smelling here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说私生子的存在是他的致命弱点，所以他才想先找出来再将其藏起来——这个说法很吻合呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說私生子的存在是他的致命弱點，所以他才想先找出來再將其藏起來——這個說法很吻合呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00187",
		linknext = "0063_00189",
		line = 2398,
	},
	["0063_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is all totally hypothetical, of course. Maybe she's a complete stranger after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过不管怎么想都只是假设……实际上他们也可能是毫无血缘关系的陌生人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過不管怎麼想都只是假設……實際上他們也可能是毫無血緣關係的陌生人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00188",
		linknext = "0063_00190",
		line = 2410,
	},
	["0063_00190"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But, since we now know that both the SS and Yakuza are hunting for her, we really need to secure her as quickly as possible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，既然知道文乃被FS和黑社会盯上了，我们也应该赶紧找出她来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，既然知道文乃被FS和黑社會盯上了，我們也應該趕緊找出她來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00189",
		linknext = "0063_00191",
		line = 2422,
	},
	["0063_00191"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1279", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah! The illegal sex trade worries me, but now I'm even more scared for Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是啊……虽然也很在意地下风俗的事情，但现在要先找文乃酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是啊……雖然也很在意地下風俗的事情，但現在要先找文乃醬！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00190",
		linknext = "0063_00192",
		line = 2436,
	},
	["0063_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Till now I haven't been able to learn anything about her, but now I think I have an idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。虽然到目前为止几乎没有得到文乃的情报……但其实我有一个想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。雖然到目前為止幾乎沒有得到文乃的情報……但其實我有一個想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00191",
		linknext = "0063_00193",
		line = 2447,
	},
	["0063_00193"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1280", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooh, that's awesome! What are you going to do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦哦，不愧是橘君！什么想法呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦哦，不愧是橘君！什麼想法呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00192",
		linknext = "0063_00194",
		line = 2461,
	},
	["0063_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The SS are putting their full resources behind the search for her. That means we've got a chance to follow their search and take Fumino right from under their noses.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS似乎加大了搜索文乃的力度——所以我想找个机会欺骗FS，将‘文乃’带到这边。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS似乎加大了搜索文乃的力度——所以我想找個機會欺騙FS，將『文乃』帶到這邊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00193",
		linknext = "0063_00195",
		line = 2472,
	},
	["0063_00195"] = {
		{"bgm", stop=1},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1281", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00194",
		linknext = "0063_00196",
		line = 2487,
	},
	["0063_00196"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……有什么问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……有什麼問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00195",
		linknext = "0063_00197",
		line = 2499,
	},
	["0063_00197"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1282", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, no, nothing... but are you sure?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，不……不是那样的，只是……没问题吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，不……不是那樣的，只是……沒問題嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00196",
		linknext = "0063_00198",
		line = 2513,
	},
	["0063_00198"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“About what?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没问题是指……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒問題是指……？」",
					{"rt2"},
