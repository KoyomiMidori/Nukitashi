					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I kinda took the liberty of reading it, sorry...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，我擅自看了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，我擅自看了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00091",
		linknext = "0063_00093",
		line = 1210,
	},
	["0063_00093"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0622", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It's fine. You already tentatively have full membership. Whether you learn that now or inevitably hear about it later, it doesn't really make a difference.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别放在心上。橘已经被内定为正式成员了。应该不会有什么问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別放在心上。橘已經被內定為正式成員了。應該不會有什麼問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00092",
		linknext = "0063_00094",
		line = 1224,
	},
	["0063_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once more, I'm getting off scot-free.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这次似乎不用被责怪了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這次似乎不用被責怪了。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00093",
		linknext = "0063_00095",
		line = 1234,
	},
	["0063_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since I've been building up her trust, she doesn't doubt me anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到今天为止充分构筑起的信赖关系，已经让礼前辈对我的行动不抱有疑问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到今天為止充分構築起的信賴關係，已經讓禮前輩對我的行動不抱有疑問。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00094",
		linknext = "0063_00096",
		line = 1244,
	},
	["0063_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"God, thinking about it in that cynical way kinda hurts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么一想——我稍微有点心痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼一想——我稍微有點心痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00095",
		linknext = "0063_00097",
		line = 1254,
	},
	["0063_00097"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei... Who's this Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈……这个‘文乃’是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩……這個『文乃』是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00096",
		linknext = "0063_00098",
		line = 1266,
	},
	["0063_00098"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0623", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ah, I suppose the cadets wouldn't know. We were given orders to find and secure her some time ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊，训练生不知道啊……很久以前，我们就收到找到那个少女并保护起来的命令了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊，訓練生不知道啊……很久以前，我們就收到找到那個少女並保護起來的命令了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00097",
		linknext = "0063_00099",
		line = 1280,
	},
	["0063_00099"] = {
		{"text"},
		text = {
