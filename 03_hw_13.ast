	["0063_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My heart is pounding. I try to calm myself down and choose my words carefully.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我冷静地压抑住心跳的加速，慎重选择词语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我冷靜地壓抑住心跳的加速，慎重選擇詞語。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00100",
