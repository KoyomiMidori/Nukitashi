	["0063_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El sudor me resbala por la frente al leer esa frase inquietante, pero sigo leyendo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着令人不安的文字，我一边咽着口水，一边将目光投向纸上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著令人不安的文字，我一邊咽著口水，一邊將目光投向紙上。",
					{"rt2"},
				},
			},
		},
