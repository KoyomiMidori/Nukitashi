					name = {"淳之介"},
					"「不是地下風俗啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00110",
		linknext = "0063_00112",
		line = 1428,
	},
	["0063_00112"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0627", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No. Como ya leíste, es posible que esos desgraciados también la estén persiguiendo. No podemos permitir que la atrapen primero, o pondrán en peligro a toda la isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……你读了那个应该就知道了，大概黑社会的人也盯上了文乃。如果真的落到他们手里，这个岛将陷入困境。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……你讀了那個應該就知道了，大概黑社會的人也盯上了文乃。如果真的落到他們手裡，這個島將陷入困境。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00111",
		linknext = "0063_00113",
		line = 1442,
	},
	["0063_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En pocas palabras, están dándole prioridad a Fumino para proteger la ley.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，为了保护条例，文乃将处于优先位置。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，為了保護條例，文乃將處於優先位置。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00112",
		linknext = "0063_00114",
		line = 1452,
	},
	["0063_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las necesidades de la mayoría prevalecen sobre las necesidades de unos pocos. Para el gobierno, las víctimas del comercio sexual ilegal son mucho menos numerosas que las personas que se verían afectadas por el colapso de la ley. Típica tontería política y pragmática.",
					{"rt2"},
				},
			},
			cn = {
				{
					"杀小虫养大虫——比起挽救受害者揭发地下风俗，条例的顺位更前面，不愧是合理主义的县知事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"殺小蟲養大蟲——比起挽救受害者揭發地下風俗，條例的順位更前面，不愧是合理主義的縣知事。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00113",
		linknext = "0063_00115",
		line = 1462,
	},
	["0063_00115"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0628", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sinceramente, la SS deberían ocuparse del Frente Anticopulación, pero también tenemos que lidiar con el problema del lavado de cerebro en la OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“本来，我们打算在反交尾势力问题解决后转向对付地下风俗……但现在SHO的洗脑问题浮上了台面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「本來，我們打算在反交尾勢力問題解決後轉向對付地下風俗……但現在SHO的洗腦問題浮上了檯面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00114",
		linknext = "0063_00116",
		line = 1476,
	},
	["0063_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, los que intentaron secuestrar al senador...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，有人试图绑架仁浦先生——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，有人試圖綁架仁浦先生——」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00115",
		linknext = "0063_00117",
		line = 1488,
	},
	["0063_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aún se desconoce cómo se llevó a cabo el lavado de cerebro que provocó el motín, y ya se está investigando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"洗脑的方法至今不明，现在正在调查中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"洗腦的方法至今不明，現在正在調查中。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00116",
		linknext = "0063_00118",
		line = 1498,
	},
	["0063_00118"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00124", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0629", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pero sí, por eso estamos posponiendo el problema del comercio sexual ilegal. Sé que es importante para ti, así que lo siento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以，地下风俗的事情之后再解决。很抱歉……你明明一直很在意这事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以，地下風俗的事情之後再解決。很抱歉……你明明一直很在意這事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00117",
		linknext = "0063_00119",
		line = 1512,
	},
	["0063_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No... No es tu culpa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不会……这也是没办法的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不會……這也是沒辦法的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00118",
		linknext = "0063_00120",
		line = 1524,
	},
	["0063_00120"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0630", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Vale. Por cierto, hay otra cosa por la que quiero disculparme... Discúlpame por lo de ayer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊……对了，我顺便要对你道个歉……那个，昨天……抱歉了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣啊……對了，我順便要對你道個歉……那個，昨天……抱歉了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00119",
		linknext = "0063_00121",
		line = 1538,
	},
	["0063_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Ayer?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“昨天？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「昨天？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00120",
		linknext = "0063_00122",
		line = 1550,
	},
	["0063_00122"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0631", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Bueno... No lo recuerdo muy bien, pero... creo que me comporté de manera un poco inapropiada contigo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不，怎么说……其实我也几乎不记得了……但似乎在你面前出了些洋相……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不，怎麼說……其實我也幾乎不記得了……但似乎在你面前出了些洋相……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00121",
		linknext = "0063_00123",
		line = 1562,
	},
	["0063_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, cuando estabas borracha... No fue solo un poquito...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，是喝醉的时候……不只出了些，应该说是相当多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，是喝醉的時候……不只出了些，應該說是相當多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00122",
		linknext = "0063_00124",
		line = 1574,
	},
	["0063_00124"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00123", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0632", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡¿T-Tan malo fue?! ¡¿Ikuko no estaba exagerando?! ¡¿De verdad maullaba después de cada frase...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“有、有那么超过吗！？原来郁子没有夸大吗！？我是真的……在句尾加上了‘喵’在说话……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「有、有那麼超過嗎！？原來郁子沒有誇大嗎！？我是真的……在句尾加上了『喵』在說話……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00123",
		linknext = "0063_00125",
		line = 1588,
	},
	["0063_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eso sí se lo inventó.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那倒是夸大的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那倒是誇大的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00124",
		linknext = "0063_00126",
		line = 1600,
	},
	["0063_00126"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", file2="rei_01l_00203", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0633", path=":vo/", ch="rei"},
			},
			ja = {
				{
					{"exfont", size="f4"},
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
					{"exfont"},
				},
			},
			en = {
				{
					{"exfont", size="f4"},
					name = {"礼", "Rei"},
					"“¡¡IKUKOOOOOOOOOOO!!”",
					{"rt2"},
					{"exfont"},
				},
			},
			cn = {
				{
					{"exfont", size="f4"},
					name = {"礼"},
					"“郁子！！！！！！！！！！！”",
					{"rt2"},
					{"exfont"},
				},
			},
			tw = {
				{
					{"exfont", size="f4"},
					name = {"礼", "禮"},
					"「郁子！！！！！！！！！！！」",
					{"rt2"},
					{"exfont"},
				},
			},
		},
		linkback = "0063_00125",
		linknext = "0063_00127",
		line = 1615,
	},
	["0063_00127"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“T-Tranquila... Solo te descontrolaste un poco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好了好了……先冷静下来。实际上真的……有点过头。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好了好了……先冷靜下來。實際上真的……有點過頭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00126",
		linknext = "0063_00128",
		line = 1627,
	},
	["0063_00128"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1900] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00124", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1900, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0634", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ugh... ¿en serio? ¿E-Estás decepcionado de tu instructora?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔……是吗……幻、幻灭了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔……是嗎……幻、幻滅了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00127",
		linknext = "0063_00129",
		line = 1643,
	},
	["0063_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por supuesto que no. Estabas borracha. Todo el mundo hace cosas raras cuando está borracho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，没有那回事……喝醉了也是没有办法的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，沒有那回事……喝醉了也是沒有辦法的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00128",
		linknext = "0063_00130",
		line = 1655,
	},
	["0063_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo que vi fue algo precioso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从某种意义上来说，看到了珍贵的画面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從某種意義上來說，看到了珍貴的畫面。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00129",
		linknext = "0063_00131",
		line = 1665,
	},
	["0063_00131"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0635", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Qué alivio, eres muy amable. Me avergüenza que después de todo lo que hiciste por nosotros, haya tenido que someterte a tal espectáculo. Te agradezco que no estés disgustado ni enojado conmigo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“太好了……你真善良。明明是立功者却被醉汉搭上，还不生气也不厌烦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「太好了……你真善良。明明是立功者卻被醉漢搭上，還不生氣也不厭煩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00130",
		linknext = "0063_00132",
		line = 1679,
	},
	["0063_00132"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, fue un poco tierno verte así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种程度只算的上可爱而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種程度只算的上可愛而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00131",
		linknext = "0063_00133",
		line = 1691,
	},
	["0063_00133"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=-12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00103", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0636", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡¿Tierno?! ¡¿D-De qué estás hablando?! ¡No te burles de tu oficial superior!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可爱——！？傻、傻瓜！别戏弄长官！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可愛——！？傻、傻瓜！別戲弄長官！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00132",
		linknext = "0063_00134",
		line = 1708,
	},
	["0063_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero es la verdad...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我并没有那个打算……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我並沒有那個打算……",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00133",
		linknext = "0063_00135",
		line = 1718,
	},
	["0063_00135"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0637", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ejem, e-en fin. Sé que esto no es suficiente para disculparme, pero... me gustaría que lo aceptaras.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“然、然后……怎么说。也说不上是作为赔偿……橘、君……这个给你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「然、然後……怎麼說。也說不上是作為賠償……橘、君……這個給你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00134",
		linknext = "0063_00136",
		line = 1732,
	},
	["0063_00136"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Es... una pistola de la SS? Y de las nuevas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是——FS的手枪吗？还是全新的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是——FS的手槍嗎？還是全新的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00135",
		linknext = "0063_00137",
		line = 1745,
	},
	["0063_00137"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0638", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí. Quedó dinero de la recompensa por rescatar al senador Hitoura. Creo que te la ganaste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯。因为帮助仁浦大人时拿到的奖金还剩一些……所以我想给你这个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯。因為幫助仁浦大人時拿到的獎金還剩一些……所以我想給你這個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00136",
		linknext = "0063_00138",
		line = 1759,
	},
	["0063_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me dijeron a que todos los miembros oficiales de la SS se les entrega una pistola reglamentaria para uso personal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据我所知，FS的正式成员们会得到各自的专用手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據我所知，FS的正式成員們會得到各自的專用手槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00137",
		linknext = "0063_00139",
		line = 1769,
	},
	["0063_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, por lo que sé, es habitual que los miembros que se gradúan entreguen sus armas a los nuevos miembros, pero esta es nueva. No parece que se haya disparado nunca.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说毕业生使用过的二手货会转给后辈，但这显然是全新的，没有使用过的痕迹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說畢業生使用過的二手貨會轉給後輩，但這顯然是全新的，沒有使用過的痕跡。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00138",
		linknext = "0063_00140",
		line = 1779,
	},
	["0063_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Estás segura? Tú te ganaste ese dinero.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可以吗？难得的奖金，居然为了我这种人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可以嗎？難得的獎金，居然為了我這種人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00139",
		linknext = "0063_00141",
		line = 1791,
	},
	["0063_00141"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0639", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tranquilo. Solo fue por una normativa que prohíbe dar recompensas a los cadetes. Tú te lo mereces más que yo. Es tu propio logro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没关系。规定上说不能给训练生奖金，所以就全都给我了。这本来就是你可以收下的东西，就把这当成是自己的功劳吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒關係。規定上說不能給訓練生獎金，所以就全都給我了。這本來就是你可以收下的東西，就把這當成是自己的功勞吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00140",
		linknext = "0063_00142",
		line = 1805,
	},
	["0063_00142"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00107", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=5000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0640", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Además, um... te esforzaste muchísimo... así que ya sabes. Es un regalo anticipado. Felicidades por tu ascenso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“还有就是……因为橘很努力了……嗯。虽然有点早，不过这是我的预祝，恭喜你升职。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「還有就是……因為橘很努力了……嗯。雖然有點早，不過這是我的預祝，恭喜你升職。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00141",
		linknext = "0063_00143",
		line = 1821,
	},
	["0063_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei-senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩——」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00142",
		linknext = "0063_00144",
		line = 1833,
	},
	["0063_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Intento darle las gracias, pero no me salen las palabras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想说些感谢的台词——但话却在喉头卡住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想說些感謝的臺詞——但話卻在喉頭卡住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00143",
		linknext = "0063_00145",
		line = 1843,
	},
	["0063_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿De verdad puedo darle las gracias?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我该谢谢她吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"我該謝謝她嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00144",
		linknext = "0063_00146",
		line = 1853,
	},
	["0063_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy engañándola.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明明在骗她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明明在騙她。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00145",
		linknext = "0063_00147",
		line = 1863,
	},
	["0063_00147"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0641", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Uff... ¿Sabes? Darte esa pistola me recuerda a tu primera práctica de tiro al blanco. ¿Te acuerdas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呵……像这样把枪交给你，就会让我想起第一次练习射击时的情景……还记得吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呵……像這樣把槍交給你，就會讓我想起第一次練習射擊時的情景……還記得嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00146",
		linknext = "0063_00148",
		line = 1877,
	},
	["0063_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, ¿cómo podría olvidar la sensación de tus nudillos en mi cara cuando me diste un puñetazo por sorpresa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……因为突然被揍了一顿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……因為突然被揍了一頓。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00147",
		linknext = "0063_00149",
		line = 1889,
	},
	["0063_00149"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0642", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡D-Decirlo así solo me hace quedar mal! Fue culpa tuya.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别、别说得那么难听……那是因为你不好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別、別說得那麼難聽……那是因為你不好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00148",
		linknext = "0063_00150",
		line = 1903,
	},
	["0063_00150"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es verdad...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00149",
		linknext = "0063_00151",
		line = 1915,
	},
	["0063_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En retrospectiva, parece ridículo, pero cuando me puso la pistola en las manos por primera vez, simplemente la apunté hacia ella con indiferencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在连我自己都很难相信，当时我什么都没想就把枪口瞄准了礼前辈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在連我自己都很難相信，當時我什麼都沒想就把槍口瞄準了禮前輩。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00150",
		linknext = "0063_00152",
		line = 1925,
	},
	["0063_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si volviera a hacerlo, me expulsarían de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——如果再次把枪对准同伴，就会立即被驱逐出FS。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——如果再次把槍對準同伴，就會立即被驅逐出FS。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00151",
		linknext = "0063_00153",
		line = 1935,
	},
	["0063_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca olvidaré el tono de su voz cuando me lo dijo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我至今还清楚地记得她这么说过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我至今還清楚地記得她這麼說過。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00152",
		linknext = "0063_00154",
		line = 1945,
	},
	["0063_00154"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0643", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Aun así, pensar que nuestra pequeña y desesperada cuota de impotencia pasaría el entrenamiento de selección... En todos los años que llevo en la SS, esto es lo más increíble que he visto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过，那个没用的橘居然通过了选拔训练……成为FS这么长时间了，这可能是最让我吃惊的事情吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不過，那個沒用的橘居然通過了選拔訓練……成為FS這麼長時間了，這可能是最讓我吃驚的事情吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00153",
		linknext = "0063_00155",
		line = 1959,
	},
	["0063_00155"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vaya, gracias por suavizar las cosas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得真过分……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得真過分……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00154",
		linknext = "0063_00156",
		line = 1971,
	},
	["0063_00156"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1700] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0644", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Jaja, estoy bromeando. Sé muy bien lo duro que has trabajado para llegar aquí. Disfruta de tu descanso. A partir de ahora, vas a trabajar tan duro que no tendrás tiempo de deprimirte.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈，开玩笑的。我知道你很努力……现在先好好休息……今后也要好好努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈，開玩笑的。我知道你很努力……現在先好好休息……今後也要好好努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00155",
		linknext = "0063_00157",
		line = 1987,
	},
	["0063_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
