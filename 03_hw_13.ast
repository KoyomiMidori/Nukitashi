	["0063_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Destroying the perverted sex law is the only way to protect these girls and keep them smiling like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我知道——变态条例是连她们的笑容都能剥夺的邪恶条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我知道——變態條例是連她們的笑容都能剝奪的邪惡條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00053",
		linknext = "0063_00055",
		line = 741,
	},
	["0063_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if I have comrades in the SS, and even if I can understand Senator Hitoura's standpoint, my resolve is still firm.",
