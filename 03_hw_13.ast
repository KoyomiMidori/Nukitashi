	["0063_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't imagine why, but she's the lynchpin for everything on this island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道理由，但“文乃”确实是这样的存在。",
					{"rt2"},
				},
