	["0063_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's something I'd never even considered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃自身有可能就是仁浦先生的弱点——",
					{"rt2"},
