		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=3, size=-12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0398", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Ah, Tachibana-san llegó! ¡Te estábamos esperanding!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，橘君来了美！等好久了美！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，橘君來了美！等好久了美！」",
					{"rt2"},
				},
			},
		},
		linknext = "0063_00002",
		line = 25,
	},
	["0063_00002"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, perdón por la demora.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，让你久等了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，讓你久等了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00001",
		linknext = "0063_00003",
		line = 37,
	},
	["0063_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es hora de comer. Hoy tenemos la base llena.",
					{"rt2"},
				},
			},
			cn = {
				{
					"午休时间，基地里的人已经全部到齐了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"午休時間，基地裡的人已經全部到齊了。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00002",
		linknext = "0063_00004",
		line = 47,
	},
	["0063_00004"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00126", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1878", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wata-chan nos contó que secuestraron al gobernador... ¿Estás bien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我听渡酱说了绑架县知事的事……你没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我聽渡醬說了綁架縣知事的事……你沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00003",
		linknext = "0063_00005",
		line = 61,
	},
	["0063_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, ese asunto ya está resuelto. Ya no hay más problemas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，这件事已经解决了，没有问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，這件事已經解決了，沒有問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00004",
		linknext = "0063_00006",
		line = 73,
	},
	["0063_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hablando de eso, ¿tuvieron algún problema mientras su líder estuvo ausente?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个，奈奈濑们是不是因为我这个队长不在而感到很辛苦呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個，奈奈瀨們是不是因為我這個隊長不在而感到很辛苦呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00005",
		linknext = "0063_00007",
		line = 85,
	},
	["0063_00007"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1879", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pues a saber. Hasta diría que nos ha ido bastante bien desde que cierta persona empezó a querer unirse a la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……谁知道呢。不过，因为有人会告诉我们FS的动向，所以反而比以前轻松多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……誰知道呢。不過，因為有人會告訴我們FS的動向，所以反而比以前輕鬆多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00006",
		linknext = "0063_00008",
		line = 99,
	},
	["0063_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Entonces no...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00007",
		linknext = "0063_00009",
		line = 111,
	},
	["0063_00009"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1264", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, quería preguntarte algo, Tachibana-kun. ¿Te gustó la fiesta de anoche?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对了，橘君，昨天的聚会开心吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對了，橘君，昨天的聚會開心嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00008",
		linknext = "0063_00010",
		line = 125,
	},
	["0063_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thinking about the party last night, I falter a bit, but I manage to keep my cool.",
					{"rt2"},
				},
			},
			cn = {
				{
					"昨晚发生的事在脑海中闪过，我顿时语塞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"昨晚發生的事在腦海中閃過，我頓時語塞。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00009",
		linknext = "0063_00011",
		line = 135,
	},
	["0063_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Diría que fue un descanso muy agradable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。是个不错的休息。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。是個不錯的休息。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00010",
		linknext = "0063_00012",
		line = 147,
	},
	["0063_00012"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Siento que me he ganado la confianza de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS对我的信任大概已经稳定了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS對我的信任大概已經穩定了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00011",
		linknext = "0063_00013",
		line = 159,
	},
	["0063_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me detengo antes de seguir hablando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在说出下一句话之前，我稍微停顿了一下。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在說出下一句話之前，我稍微停頓了一下。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00012",
		linknext = "0063_00014",
		line = 169,
	},
	["0063_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No debería haber ningún problema...",
					{"rt2"},
				},
			},
			cn = {
				{
					"——好，没问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——好，沒問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00013",
		linknext = "0063_00015",
		line = 179,
	},
	["0063_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tengo entendido que este incidente está acelerando el proceso para convertirme en miembro oficial de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“听说因为这次的功劳，我可以开始进行成为FS正式成员的手续了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「聽說因為這次的功勞，我可以開始進行成為FS正式成員的手續了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00014",
		linknext = "0063_00016",
		line = 190,
	},
	["0063_00016"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0399", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Eh... ¡¿De verdad vas a unirte a la SS, Tachibana-san?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……那么橘同学，真的要变成FS了美！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸……那麼橘同學，真的要變成FS了美！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00015",
		linknext = "0063_00017",
		line = 205,
	},
	["0063_00017"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No. Solo me uní a ellos para obtener información sobre la industria sexual ilegal y sobre Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——我呆在FS里，就只是为了探听关于地下风俗和‘文乃’的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——我待在FS裡，就只是為了探聽關於地下風俗和『文乃』的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00016",
		linknext = "0063_00018",
		line = 217,
	},
	["0063_00018"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cuando termine todo eso, no tendré motivos para quedarme. Simplemente inventaré una buena excusa y renunciaré tan pronto como pueda.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果这两件事有了解决的头绪——就没FS的事情了。我会马上找个理由退出的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果這兩件事有了解決的頭緒——就沒FS的事情了。我會馬上找個理由退出的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00017",
		linknext = "0063_00019",
		line = 229,
	},
	["0063_00019"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1114", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pero ser cadete no es lo mismo que ser miembro oficial. Puede que no sea tan fácil renunciar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是，如果是训练生期间的话倒还好，一旦成为了正式成员，要辞职也会相当费工夫吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是，如果是訓練生期間的話倒還好，一旦成為了正式成員，要辭職也會相當費工夫吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00018",
		linknext = "0063_00020",
		line = 242,
	},
	["0063_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tienes razón...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也许吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也許吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00019",
		linknext = "0063_00021",
		line = 254,
	},
	["0063_00021"] = {
		{"bgm", stop=1},
		{"bg", id=2, file="bg12_1l_00000", x=-340, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00111", file2="misaki_01l_00202", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0400", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Esperen! ¡Cállense todos! ¡¿Por qué no me hacen caso?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“能稍等一下吗美！？为什么！没有人要！对我！说些什么美！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「能稍等一下嗎美！？為什麼！沒有人要！對我！說些什麼美！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00020",
		linknext = "0063_00022",
		line = 274,
	},
	["0063_00022"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Entonces... ¿nadie ha respondido todavía?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……没人要吐槽你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……沒人要吐槽你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00021",
		linknext = "0063_00023",
		line = 292,
	},
	["0063_00023"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1880", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Pensé que era mejor no tocar el tema...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我觉得还是不要扯上关系比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我覺得還是不要扯上關係比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00022",
		linknext = "0063_00024",
		line = 306,
	},
	["0063_00024"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00125", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0401", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Pero es mejor que toquemos el tema! ¡Ahora me veo como una tonta!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“请跟我扯上关系美！不然我不就只像个笨蛋吗美！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「請跟我扯上關係美！不然我不就只像個笨蛋嗎美！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00023",
		linknext = "0063_00025",
		line = 322,
	},
	["0063_00025"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1115", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Eres tonta. Además, eres un barril de manteca andante y que habla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“实际上就是个笨蛋还是个胖子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「實際上就是個笨蛋還是個胖子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00024",
		linknext = "0063_00026",
		line = 335,
	},
	["0063_00026"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1265", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Eh?! ¡Esperen, está hablando chistoso! ¿En serio? ¡Increíble!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊！？被这么一说，美岬酱的说话方式和平时不一样呢！为什么？好厉害！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊！？被這麼一說，美岬醬的說話方式和平時不一樣呢！為什麼？好厲害！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00025",
		linknext = "0063_00027",
		line = 350,
	},
	["0063_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El hecho de que apenas te hayas dado cuenta es peor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样都没注意到的渡酱反而觉得很厉害……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣都沒注意到的渡醬反而覺得很厲害……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00026",
		linknext = "0063_00028",
		line = 362,
	},
	["0063_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Nos explicas qué estás haciendo? ¿Has estado viendo animes para niños o qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你怎么了？难道看了什么面向小女孩的奇妙动画片吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你怎麼了？難道看了什麼面向小女孩的奇妙動畫片嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00027",
		linknext = "0063_00029",
		line = 374,
	},
	["0063_00029"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0402", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Vamos... ¡Ya no puedo más! Siempre me dejan fuera, e incluso cuando estoy en el grupo, siguen olvidándose de mí... ¡Necesito tener algún rasgo memorable para que mi personaje destaque!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为……前几天只有我被排挤啊！？而且平常就很容易被忘记……如果不能再多创造点特色就糟了不是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為……前幾天只有我被排擠啊！？而且平常就很容易被忘記……如果不能再多創造點特色就糟了不是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00028",
		linknext = "0063_00030",
		line = 386,
	},
	["0063_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No te preocupes tanto por eso. Creo que tienes suficientes rasgos memorables.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使不用那么在意，我也觉得畔很有特色了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使不用那麼在意，我也覺得畔很有特色了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00029",
		linknext = "0063_00031",
		line = 398,
	},
	["0063_00031"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0403", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Dime uno!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“例如！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「例如！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00030",
		linknext = "0063_00032",
		line = 412,
	},
	["0063_00032"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh... ¿ratón de biblioteca?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文学少女之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文學少女之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00031",
		linknext = "0063_00033",
		line = 424,
	},
	["0063_00033"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00122", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0404", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿De verdad piensas eso? Bueno, dime algo: ¿alguna vez me habías considerado un ratón de biblioteca antes de esto?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你真的那么想吗！？那我反过来问你，到现在为止你有曾经认为我是文学少女过吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你真的那麼想嗎！？那我反過來問你，到現在為止你有曾經認為我是文學少女過嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00032",
		linknext = "0063_00034",
		line = 438,
	},
	["0063_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Joder, ¿por qué está tan molesta...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这人为什么生气了啊……",
					{"rt2"},
				},
			},
			tw = {
				{
					"這人為什麼生氣了啊……",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00033",
		linknext = "0063_00035",
		line = 448,
	},
	["0063_00035"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1266", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, umm... No sé de qué estás hablando, pero ¿te pasó algo malo? Soy tu senpai, así que te escucharé.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃、呃……虽然我不太清楚，可是美岬酱有遇到什么讨厌的事吗？前辈会听你说话哦。”",
