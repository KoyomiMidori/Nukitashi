			},
		},
		linkback = "0063_00101",
		linknext = "0063_00103",
		line = 1322,
	},
	["0063_00103"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0624", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We weren't told anything. The order came down to us directly from Senator Hitoura to find and secure her ASAP.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我们也不知道详细情况。不过，迅速找出并保护起来——这是仁浦大人亲自下的命令。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我們也不知道詳細情況。不過，迅速找出並保護起來——這是仁浦大人親自下的命令。」",
					{"rt2"},
				},
			},
		},
