			},
			cn = {
				{
					"即使对FS有亲近感，对仁浦先生的话产生共鸣——但我坚决废除条例的决心是不会改变的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使對FS有親近感，對仁浦先生的話產生共鳴——但我堅決廢除條例的決心是不會改變的。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00054",
		linknext = "0063_00056",
		line = 751,
	},
	["0063_00056"] = {
