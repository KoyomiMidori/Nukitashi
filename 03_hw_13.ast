		linkback = "0063_00184",
		linknext = "0063_00186",
		line = 2368,
	},
	["0063_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Alguien como él puede tener sentimientos así?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个男人真的有那样的感情吗？",
					{"rt2"},
