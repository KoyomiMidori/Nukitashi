		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=3, size=-12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0398", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, Tachibana! Meesa glad you came! Weesa waiting for you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，橘君来了美！等好久了美！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，橘君來了美！等好久了美！」",
					{"rt2"},
				},
			},
		},
		linknext = "0063_00002",
		line = 25,
	},
	["0063_00002"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Kept you waiting, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，让你久等了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，讓你久等了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00001",
		linknext = "0063_00003",
		line = 37,
	},
	["0063_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lunch time. We've got a full house in the base today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"午休时间，基地里的人已经全部到齐了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"午休時間，基地裡的人已經全部到齊了。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00002",
		linknext = "0063_00004",
		line = 47,
	},
	["0063_00004"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00126", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1878", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wata told us about the governor's kidnapping... Are you okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我听渡酱说了绑架县知事的事……你没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我聽渡醬說了綁架縣知事的事……你沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00003",
		linknext = "0063_00005",
		line = 61,
	},
	["0063_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that issue's all taken care of now. No more problems there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，这件事已经解决了，没有问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，這件事已經解決了，沒有問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00004",
		linknext = "0063_00006",
		line = 73,
	},
	["0063_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“More importantly, did you guys run into any big problems while I wasn't here to be the leader?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个，奈奈濑们是不是因为我这个队长不在而感到很辛苦呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個，奈奈瀨們是不是因為我這個隊長不在而感到很辛苦呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00005",
		linknext = "0063_00007",
		line = 85,
	},
	["0063_00007"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1879", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I wonder about that. Hell, I'd say we've been doing pretty well ever since a certain somebody started leaning towards joining the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……谁知道呢。不过，因为有人会告诉我们FS的动向，所以反而比以前轻松多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……誰知道呢。不過，因為有人會告訴我們FS的動向，所以反而比以前輕鬆多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00006",
		linknext = "0063_00008",
		line = 99,
	},
	["0063_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll take that answer as a no, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00007",
		linknext = "0063_00009",
		line = 111,
	},
	["0063_00009"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1264", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, I've been meaning to ask, Tachibana. Did you enjoy the party last night?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对了，橘君，昨天的聚会开心吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對了，橘君，昨天的聚會開心嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00008",
		linknext = "0063_00010",
		line = 125,
	},
	["0063_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thinking about the party last night, I falter a bit, but I manage to keep my cool.",
					{"rt2"},
				},
			},
			cn = {
				{
					"昨晚发生的事在脑海中闪过，我顿时语塞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"昨晚發生的事在腦海中閃過，我頓時語塞。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00009",
		linknext = "0063_00011",
		line = 135,
	},
	["0063_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. It was a nice little respite, I'd say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。是个不错的休息。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。是個不錯的休息。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00010",
		linknext = "0063_00012",
		line = 147,
	},
	["0063_00012"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I feel like I've basically cemented the SS's trust in me now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS对我的信任大概已经稳定了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS對我的信任大概已經穩定了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00011",
		linknext = "0063_00013",
		line = 159,
	},
	["0063_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I briefly pause before my next comment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在说出下一句话之前，我稍微停顿了一下。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在說出下一句話之前，我稍微停頓了一下。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00012",
		linknext = "0063_00014",
		line = 169,
	},
	["0063_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They should be fine with it...",
					{"rt2"},
				},
			},
			cn = {
				{
					"——好，没问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——好，沒問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00013",
		linknext = "0063_00015",
		line = 179,
	},
	["0063_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's my understanding that this whole incident is spurring on the process of making me an official SS member.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“听说因为这次的功劳，我可以开始进行成为FS正式成员的手续了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「聽說因為這次的功勞，我可以開始進行成為FS正式成員的手續了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00014",
		linknext = "0063_00016",
		line = 190,
	},
	["0063_00016"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0399", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh... So yoosa really going to join SS, Tachibana!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……那么橘同学，真的要变成FS了美！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸……那麼橘同學，真的要變成FS了美！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00015",
		linknext = "0063_00017",
		line = 205,
	},
	["0063_00017"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No. I only teamed up with them to get info on the illegal sex industry, and on Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——我呆在FS里，就只是为了探听关于地下风俗和‘文乃’的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——我待在FS裡，就只是為了探聽關於地下風俗和『文乃』的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00016",
		linknext = "0063_00018",
		line = 217,
	},
	["0063_00018"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Once both those things are sorted out, I'll have no reason to stay. I'll just make up a good excuse and quit as soon as I'm able.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果这两件事有了解决的头绪——就没FS的事情了。我会马上找个理由退出的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果這兩件事有了解決的頭緒——就沒FS的事情了。我會馬上找個理由退出的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00017",
		linknext = "0063_00019",
		line = 229,
	},
	["0063_00019"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1114", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But being a trainee isn't the same kettle of fish as being an official member. You might have a lot more trouble quitting that way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是，如果是训练生期间的话倒还好，一旦成为了正式成员，要辞职也会相当费工夫吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是，如果是訓練生期間的話倒還好，一旦成為了正式成員，要辭職也會相當費工夫吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00018",
		linknext = "0063_00020",
		line = 242,
	},
	["0063_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
