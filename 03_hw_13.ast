					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Argh! See, you've got your own recurring catchphrase and everything! Not to mention, you've got cute, ditzy, and 'carries chair' all rolled into one... You're such a Mary Sue! Gimme some of your traits!”",
