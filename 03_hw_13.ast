	["0063_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No puedo decir que lo conozca bien, ya que solo hemos hablado una vez, pero me pareció un pragmático intenso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然只说过一次话——但我从他身上得到的印象，是过于清爽的合理主义者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然只說過一次話——但我從他身上得到的印象，是過於清爽的合理主義者。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00186",
		linknext = "0063_00188",
		line = 2388,
	},
	["0063_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si consideraba a su hija ilegítima como una debilidad fatal, se habría asegurado de que esa información no se filtrara. Ese es el tipo de inmundicia que percibo aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说私生子的存在是他的致命弱点，所以他才想先找出来再将其藏起来——这个说法很吻合呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說私生子的存在是他的致命弱點，所以他才想先找出來再將其藏起來——這個說法很吻合呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00187",
		linknext = "0063_00189",
		line = 2398,
	},
	["0063_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A ver, solo es una hipótesis. Quizás sea una completa desconocida después de todo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过不管怎么想都只是假设……实际上他们也可能是毫无血缘关系的陌生人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過不管怎麼想都只是假設……實際上他們也可能是毫無血緣關係的陌生人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00188",
		linknext = "0063_00190",
		line = 2410,
	},
	["0063_00190"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero ahora sabemos que la SS y la yakuza la están buscando, tenemos que protegerla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，既然知道文乃被FS和黑社会盯上了，我们也应该赶紧找出她来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，既然知道文乃被FS和黑社會盯上了，我們也應該趕緊找出她來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00189",
		linknext = "0063_00191",
		line = 2422,
	},
	["0063_00191"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1279", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Sí! ¡El comercio sexual ilegal me preocupa, pero ahora estoy aún más preocupada por Fumino-chan!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是啊……虽然也很在意地下风俗的事情，但现在要先找文乃酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是啊……雖然也很在意地下風俗的事情，但現在要先找文乃醬！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00190",
		linknext = "0063_00192",
		line = 2436,
	},
	["0063_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí. Hasta ahora no había podido descubrir nada sobre ella, pero creo que ahora tengo una idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。虽然到目前为止几乎没有得到文乃的情报……但其实我有一个想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。雖然到目前為止幾乎沒有得到文乃的情報……但其實我有一個想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00191",
		linknext = "0063_00193",
		line = 2447,
	},
	["0063_00193"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1280", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ohh, genial! ¿Qué vas a hacer?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦哦，不愧是橘君！什么想法呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦哦，不愧是橘君！什麼想法呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00192",
		linknext = "0063_00194",
		line = 2461,
	},
	["0063_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La SS está dedicando todos sus recursos a buscarla. Eso significa que tenemos la oportunidad de seguir su búsqueda y llevarnos a Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS似乎加大了搜索文乃的力度——所以我想找个机会欺骗FS，将‘文乃’带到这边。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS似乎加大了搜索文乃的力度——所以我想找個機會欺騙FS，將『文乃』帶到這邊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00193",
		linknext = "0063_00195",
		line = 2472,
	},
	["0063_00195"] = {
		{"bgm", stop=1},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1281", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00194",
		linknext = "0063_00196",
		line = 2487,
	},
	["0063_00196"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué pasa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……有什么问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……有什麼問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00195",
		linknext = "0063_00197",
		line = 2499,
	},
	["0063_00197"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1282", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, nada... pero ¿estás seguro...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，不……不是那样的，只是……没问题吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，不……不是那樣的，只是……沒問題嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00196",
		linknext = "0063_00198",
		line = 2513,
	},
	["0063_00198"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Por qué lo dices...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没问题是指……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒問題是指……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00197",
		linknext = "0063_00199",
		line = 2525,
	},
	["0063_00199"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1283", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Bueno, por fin eres amigo de Rei-chan, y ella habla mucho de ti. ¿Qué pasaría si traicionaras a la SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为橘君好不容易和礼酱成了好朋友……礼酱也经常说橘君的事情……现在背叛FS的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為橘君好不容易和禮醬成了好朋友……禮醬也經常說橘君的事情……現在背叛FS的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00198",
		linknext = "0063_00200",
		line = 2537,
	},
	["0063_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de preguntar eso, me mira.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱把话打住，用担心的目光看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬把話打住，用擔心的目光看著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00199",
		linknext = "0063_00201",
		line = 2547,
	},
	["0063_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En mi bolsillo tengo la correa con forma de oso que me regaló, está enganchada a mi tableta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"口袋里的平板上挂的是渡酱给我的小熊挂件。",
					{"rt2"},
				},
			},
			tw = {
				{
					"口袋裡的平板上掛的是渡醬給我的小熊挂件。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00200",
		linknext = "0063_00202",
		line = 2557,
	},
	["0063_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En mi bolso tengo la pistola nueva que Rei-senpai me dio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"包里是礼前辈送的新手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"包裡是禮前輩送的新手槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00201",
		linknext = "0063_00203",
		line = 2567,
	},
	["0063_00203"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00202",
		linknext = "0063_00204",
		line = 2579,
	},
	["0063_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pase lo que pase, nunca se me ocurrió que mi determinación pudiera debilitarse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我——从一开始，就决定不管发生什么，都不会改变信念。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我——從一開始，就決定不管發生什麼，都不會改變信念。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00203",
		linknext = "0063_00205",
		line = 2589,
	},
	["0063_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La ley súperpervertida es retorcida y malvada, y no puedo permitir que exista.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个条例是扭曲的，是绝对不能放置不管的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個條例是扭曲的，是絕對不能放置不管的。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00204",
		linknext = "0063_00206",
		line = 2599,
	},
	["0063_00206"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pase lo que pase, tengo que hacer lo que me propuse al principio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我一开始——就做好觉悟了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我一開始——就做好覺悟了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00205",
		linknext = "0063_00207",
		line = 2611,
	},
	["0063_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras hablo, puedo oír cómo me tiemba la voz.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我回答的声音，有些颤抖。",
					{"rt2"},
				},
			},
			tw = {
