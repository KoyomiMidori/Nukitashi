			en = {
				{
					name = {"礼", "Rei"},
					"“Correct. As you've read, those monsters are probably hunting her as well. We can't allow them to get ahold of her first, or it'll put the entire island at risk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……你读了那个应该就知道了，大概黑社会的人也盯上了文乃。如果真的落到他们手里，这个岛将陷入困境。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……你讀了那個應該就知道了，大概黑社會的人也盯上了文乃。如果真的落到他們手裡，這個島將陷入困境。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00111",
		linknext = "0063_00113",
		line = 1442,
	},
	["0063_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In other words, they're prioritizing Fumino in order to protect the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，为了保护条例，文乃将处于优先位置。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，為了保護條例，文乃將處於優先位置。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00112",
		linknext = "0063_00114",
		line = 1452,
	},
	["0063_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The needs of the many outweigh the needs of the few. From the government's point of view, the victims of the illegal sex trade are far fewer than those who'd be impacted by the collapse of the perverted sex law. Typical pragmatic political bullshit, if you ask me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"杀小虫养大虫——比起挽救受害者揭发地下风俗，条例的顺位更前面，不愧是合理主义的县知事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"殺小蟲養大蟲——比起挽救受害者揭發地下風俗，條例的順位更前面，不愧是合理主義的縣知事。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00113",
		linknext = "0063_00115",
		line = 1462,
	},
	["0063_00115"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0628", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Realistically, the SS should deal with the Anti-Copulation Front before anything else, but we also need to contend with the brainwashing issue in the OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“本来，我们打算在反交尾势力问题解决后转向对付地下风俗……但现在SHO的洗脑问题浮上了台面。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「本來，我們打算在反交尾勢力問題解決後轉向對付地下風俗……但現在SHO的洗腦問題浮上了檯面。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00114",
		linknext = "0063_00116",
		line = 1476,
	},
	["0063_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, the ones who tried to abduct Senator Hitoura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，有人试图绑架仁浦先生——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，有人試圖綁架仁浦先生——」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00115",
		linknext = "0063_00117",
		line = 1488,
	},
	["0063_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's still unknown how the brainwashing behind the mutiny was carried out, and it's under investigation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"洗脑的方法至今不明，现在正在调查中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"洗腦的方法至今不明，現在正在調查中。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00116",
		linknext = "0063_00118",
		line = 1498,
	},
	["0063_00118"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00124", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0629", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But yeah, that's why we're postponing dealing with the illegal sex trade. I know it's important to you, so sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以，地下风俗的事情之后再解决。很抱歉……你明明一直很在意这事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以，地下風俗的事情之後再解決。很抱歉……你明明一直很在意這事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00117",
		linknext = "0063_00119",
		line = 1512,
	},
	["0063_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, I get it. It's not your fault, anyway.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不会……这也是没办法的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不會……這也是沒辦法的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00118",
		linknext = "0063_00120",
		line = 1524,
	},
	["0063_00120"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0630", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“All right. Also, there's something else I want to apologize for... I'm sorry about yesterday.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊……对了，我顺便要对你道个歉……那个，昨天……抱歉了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣啊……對了，我順便要對你道個歉……那個，昨天……抱歉了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00119",
		linknext = "0063_00121",
		line = 1538,
	},
	["0063_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yesterday?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“昨天？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「昨天？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00120",
		linknext = "0063_00122",
		line = 1550,
	},
	["0063_00122"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0631", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well... I don't really remember it that well, but... I believe I behaved somewhat inappropriately toward you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不，怎么说……其实我也几乎不记得了……但似乎在你面前出了些洋相……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不，怎麼說……其實我也幾乎不記得了……但似乎在你面前出了些洋相……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00121",
		linknext = "0063_00123",
		line = 1562,
	},
	["0063_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh yeah, when you were drunk. 'Somewhat' is the understatement of the year, there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，是喝醉的时候……不只出了些，应该说是相当多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，是喝醉的時候……不只出了些，應該說是相當多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00122",
		linknext = "0063_00124",
		line = 1574,
	},
	["0063_00124"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00123", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0632", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“W-Was I that bad!? Ikuko wasn't exaggerating!? Did... did I really meow after every sentence...!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“有、有那么超过吗！？原来郁子没有夸大吗！？我是真的……在句尾加上了‘喵’在说话……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「有、有那麼超過嗎！？原來郁子沒有誇大嗎！？我是真的……在句尾加上了『喵』在說話……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00123",
		linknext = "0063_00125",
		line = 1588,
	},
	["0063_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That part she was.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那倒是夸大的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那倒是誇大的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00124",
		linknext = "0063_00126",
		line = 1600,
	},
	["0063_00126"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", file2="rei_01l_00203", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0633", path=":vo/", ch="rei"},
			},
			ja = {
				{
					{"exfont", size="f4"},
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
					{"exfont"},
				},
			},
			en = {
				{
					{"exfont", size="f4"},
					name = {"礼", "Rei"},
					"“IKUKOOOOOOOOOOO!!”",
					{"rt2"},
					{"exfont"},
				},
			},
			cn = {
				{
					{"exfont", size="f4"},
					name = {"礼"},
					"“郁子！！！！！！！！！！！”",
					{"rt2"},
					{"exfont"},
				},
			},
			tw = {
				{
					{"exfont", size="f4"},
					name = {"礼", "禮"},
					"「郁子！！！！！！！！！！！」",
					{"rt2"},
					{"exfont"},
				},
			},
		},
		linkback = "0063_00125",
		linknext = "0063_00127",
		line = 1615,
	},
	["0063_00127"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“N-Now, now... calm down. You just got a bit out of control, that's all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好了好了……先冷静下来。实际上真的……有点过头。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好了好了……先冷靜下來。實際上真的……有點過頭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00126",
		linknext = "0063_00128",
		line = 1627,
	},
	["0063_00128"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1900] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00124", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1900, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0634", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ugh... really? A-Are you disillusioned in your instructor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔……是吗……幻、幻灭了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔……是嗎……幻、幻滅了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00127",
		linknext = "0063_00129",
		line = 1643,
	},
	["0063_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course not. You were drunk. Everyone does weird shit when they're drunk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，没有那回事……喝醉了也是没有办法的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，沒有那回事……喝醉了也是沒有辦法的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00128",
		linknext = "0063_00130",
		line = 1655,
	},
	["0063_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What I got to see was something truly precious.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从某种意义上来说，看到了珍贵的画面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從某種意義上來說，看到了珍貴的畫面。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00129",
		linknext = "0063_00131",
		line = 1665,
	},
	["0063_00131"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0635", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Thank goodness, you're too kind. It's shameful to me that, after all you did for us, I had to subject you to such a display, but I'm grateful to see that you aren't disgusted or angry with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“太好了……你真善良。明明是立功者却被醉汉搭上，还不生气也不厌烦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「太好了……你真善良。明明是立功者卻被醉漢搭上，還不生氣也不厭煩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00130",
		linknext = "0063_00132",
		line = 1679,
	},
	["0063_00132"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, it was kinda... cute.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种程度只算的上可爱而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種程度只算的上可愛而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00131",
		linknext = "0063_00133",
		line = 1691,
	},
	["0063_00133"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=-12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00103", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0636", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Cute!? Wh-What are you talking about!? Don't tease your superior officer!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可爱——！？傻、傻瓜！别戏弄长官！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可愛——！？傻、傻瓜！別戲弄長官！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00132",
		linknext = "0063_00134",
		line = 1708,
	},
	["0063_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the truth, though...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我并没有那个打算……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我並沒有那個打算……",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00133",
		linknext = "0063_00135",
		line = 1718,
	},
	["0063_00135"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0637", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ahem, a-anyway. I know this isn't enough to fully apologize, but... I'd like you to have it regardless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“然、然后……怎么说。也说不上是作为赔偿……橘、君……这个给你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「然、然後……怎麼說。也說不上是作為賠償……橘、君……這個給你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00134",
		linknext = "0063_00136",
		line = 1732,
	},
	["0063_00136"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is... an SS handgun? A brand new one, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是——FS的手枪吗？还是全新的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是——FS的手槍嗎？還是全新的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00135",
		linknext = "0063_00137",
		line = 1745,
	},
	["0063_00137"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0638", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yes. There was money left over from the reward for rescuing Senator Hitoura. I believe you've earned it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯。因为帮助仁浦大人时拿到的奖金还剩一些……所以我想给你这个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯。因為幫助仁浦大人時拿到的獎金還剩一些……所以我想給你這個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00136",
		linknext = "0063_00138",
		line = 1759,
	},
	["0063_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've been told that all full SS members are given a standard-issue handgun for personal use.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据我所知，FS的正式成员们会得到各自的专用手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據我所知，FS的正式成員們會得到各自的專用手槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00137",
		linknext = "0063_00139",
		line = 1769,
	},
	["0063_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From what I've heard, though, it's common for graduating members to hand their guns down to upcoming members, but this is clearly new. It doesn't look like it's ever even been fired.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说毕业生使用过的二手货会转给后辈，但这显然是全新的，没有使用过的痕迹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說畢業生使用過的二手貨會轉給後輩，但這顯然是全新的，沒有使用過的痕跡。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00138",
		linknext = "0063_00140",
		line = 1779,
	},
	["0063_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you sure? You were the one given the reward money.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可以吗？难得的奖金，居然为了我这种人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可以嗎？難得的獎金，居然為了我這種人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00139",
		linknext = "0063_00141",
		line = 1791,
	},
	["0063_00141"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0639", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It's fine. That was just because of a regulation requiring rewards not be given to cadets. Realistically, you're the one who deserves it. This is your achievement.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没关系。规定上说不能给训练生奖金，所以就全都给我了。这本来就是你可以收下的东西，就把这当成是自己的功劳吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒關係。規定上說不能給訓練生獎金，所以就全都給我了。這本來就是你可以收下的東西，就把這當成是自己的功勞吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00140",
		linknext = "0063_00142",
		line = 1805,
	},
	["0063_00142"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00107", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=5000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0640", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Also, um... you worked so hard for this... that's right. It's a preemptive gift. Congratulations on your promotion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“还有就是……因为橘很努力了……嗯。虽然有点早，不过这是我的预祝，恭喜你升职。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「還有就是……因為橘很努力了……嗯。雖然有點早，不過這是我的預祝，恭喜你升職。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00141",
		linknext = "0063_00143",
		line = 1821,
	},
	["0063_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩——」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00142",
		linknext = "0063_00144",
		line = 1833,
	},
	["0063_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I try to thank her, but I can't get the words out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想说些感谢的台词——但话却在喉头卡住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想說些感謝的臺詞——但話卻在喉頭卡住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00143",
		linknext = "0063_00145",
		line = 1843,
	},
	["0063_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Can I really thank her?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我该谢谢她吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"我該謝謝她嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00144",
		linknext = "0063_00146",
		line = 1853,
	},
	["0063_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm deceiving her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明明在骗她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明明在騙她。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00145",
		linknext = "0063_00147",
		line = 1863,
	},
	["0063_00147"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0641", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Phew... You know, giving you that gun kind of reminds me of your first target practice. Do you remember that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呵……像这样把枪交给你，就会让我想起第一次练习射击时的情景……还记得吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呵……像這樣把槍交給你，就會讓我想起第一次練習射擊時的情景……還記得嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00146",
		linknext = "0063_00148",
		line = 1877,
	},
	["0063_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, how could I possibly forget the feeling of your knuckles on my face when you sucker-punched me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……因为突然被揍了一顿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……因為突然被揍了一頓。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00147",
		linknext = "0063_00149",
		line = 1889,
	},
	["0063_00149"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00106", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0642", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“P-Putting it like that just makes me look bad! It was your own fault.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别、别说得那么难听……那是因为你不好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別、別說得那麼難聽……那是因為你不好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00148",
		linknext = "0063_00150",
		line = 1903,
	},
	["0063_00150"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's true...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00149",
		linknext = "0063_00151",
		line = 1915,
	},
	["0063_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems ridiculous in retrospect, but when she first put the gun in my hands, I just casually pointed it at her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在连我自己都很难相信，当时我什么都没想就把枪口瞄准了礼前辈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在連我自己都很難相信，當時我什麼都沒想就把槍口瞄準了禮前輩。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00150",
		linknext = "0063_00152",
		line = 1925,
	},
	["0063_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I did that again, I would be kicked out of the SS on the spot.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——如果再次把枪对准同伴，就会立即被驱逐出FS。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——如果再次把槍對準同伴，就會立即被驅逐出FS。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00151",
		linknext = "0063_00153",
		line = 1935,
	},
	["0063_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could never forget her tone of voice when she told me that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我至今还清楚地记得她这么说过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我至今還清楚地記得她這麼說過。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00152",
		linknext = "0063_00154",
		line = 1945,
	},
	["0063_00154"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0643", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Still, to think our hopeless little impotence quota would go on to pass the selection training... In all my years in the SS, I don't think I've seen anything more surprising.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过，那个没用的橘居然通过了选拔训练……成为FS这么长时间了，这可能是最让我吃惊的事情吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不過，那個沒用的橘居然通過了選拔訓練……成為FS這麼長時間了，這可能是最讓我吃驚的事情吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00153",
		linknext = "0063_00155",
		line = 1959,
	},
	["0063_00155"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, thanks for sugar-coating it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说得真过分……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說得真過分……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00154",
		linknext = "0063_00156",
		line = 1971,
	},
	["0063_00156"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1700] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1700, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0644", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Haha, I'm kidding. I know very well how hard you've been working to get this far. Enjoy your rest. From now on, you'll be working so hard that you won't have the time to get yourself down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈，开玩笑的。我知道你很努力……现在先好好休息……今后也要好好努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈，開玩笑的。我知道你很努力……現在先好好休息……今後也要好好努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00155",
		linknext = "0063_00157",
		line = 1987,
	},
	["0063_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00156",
		linknext = "0063_00158",
		line = 1999,
	},
	["0063_00158"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Success is to win by any means necessary, no matter how evil they may be, and to continue to do so to protect that success.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——所谓的成功，就是做出了恶行而得胜，然后再用更多的恶去守护它。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——所謂的成功，就是做出了惡行而得勝，然後再用更多的惡去守護它。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00157",
		linknext = "0063_00159",
		line = 2010,
	},
	["0063_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Senator Hitoura's words echo in my head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生的话在脑海里回响着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生的話在腦海裡迴響著。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00158",
		linknext = "0063_00160",
		line = 2020,
	},
	["0063_00160"] = {
