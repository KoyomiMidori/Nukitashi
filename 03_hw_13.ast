		linkback = "0063_00156",
		linknext = "0063_00158",
		line = 1999,
	},
	["0063_00158"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El éxito consiste en ganar por cualquier medio necesario, sin importar lo perverso que sea, y seguir haciéndolo para proteger ese éxito.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——所谓的成功，就是做出了恶行而得胜，然后再用更多的恶去守护它。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——所謂的成功，就是做出了惡行而得勝，然後再用更多的惡去守護它。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00157",
		linknext = "0063_00159",
		line = 2010,
	},
	["0063_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las palabras del senador Hitoura resuenan en mi cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生的话在脑海里回响着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生的話在腦海裡迴響著。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00158",
		linknext = "0063_00160",
		line = 2020,
	},
	["0063_00160"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
