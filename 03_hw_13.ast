			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No nos dijeron nada. Fue una orden directa del senador Hitoura: encontrarla y protegerla lo antes posible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我们也不知道详细情况。不过，迅速找出并保护起来——这是仁浦大人亲自下的命令。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我們也不知道詳細情況。不過，迅速找出並保護起來——這是仁浦大人親自下的命令。」",
					{"rt2"},
