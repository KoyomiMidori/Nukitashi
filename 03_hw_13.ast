					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那、那种事情……能分我也想分啊！美岬酱的身高和胸部，就像摘瘤爷爷一样分给我啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那、那種事情……能分我也想分啊！美岬醬的身高和胸部，就像摘瘤爺爺一樣分給我啊！」",
					{"rt2"},
				},
