	["0063_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, perdón...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，對不起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00165",
		linknext = "0063_00167",
		line = 2144,
	},
	["0063_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así, la orden vino del propio senador Hitoura. Si le importa lo suficiente como para dar la orden de buscarla, debe tener algo comprometedor, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，仁浦先生的搜索命令一直发布着——也就是说，文乃或许掌握了仁浦先生的弱点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，仁浦先生的搜索命令一直發佈著——也就是說，文乃或許掌握了仁浦先生的弱點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00166",
		linknext = "0063_00168",
		line = 2156,
	},
	["0063_00168"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan me mira con curiosidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱微微地歪着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬微微地歪著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00167",
		linknext = "0063_00169",
		line = 2168,
	},
	["0063_00169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tal vez sabe algo que podría poner en peligro su posición.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“例如……掌握了威胁仁浦先生地位的情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「例如……掌握了威脅仁浦先生地位的情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00168",
		linknext = "0063_00170",
		line = 2180,
	},
	["0063_00170"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1275", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahh, me imagino que sí... O tal vez ella misma sea su debilidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦，原来如此，看起来确实是这样……或许文乃本身就是仁浦先生的弱点也说不定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦，原來如此，看起來確實是這樣……或許文乃本身就是仁浦先生的弱點也說不定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00169",
		linknext = "0063_00171",
		line = 2194,
	},
	["0063_00171"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cómo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么说？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼說？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00170",
		linknext = "0063_00172",
		line = 2206,
	},
	["0063_00172"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1276", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Bueno, tal vez Fumino-chan sea importante para él. Por eso no quiere que la yakuza la encuentre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你想想，如果文乃是仁浦先生最重要的人的话，如果被黑社会们抢走不是会很困扰吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你想想，如果文乃是仁浦先生最重要的人的話，如果被黑社會們搶走不是會很困擾嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00171",
		linknext = "0063_00173",
		line = 2220,
	},
	["0063_00173"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es posible...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“确实——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「確實——」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00172",
		linknext = "0063_00174",
		line = 2232,
	},
	["0063_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No lo había considerado...",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃自身有可能就是仁浦先生的弱点——",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃自身有可能就是仁浦先生的弱點——",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00173",
		linknext = "0063_00175",
		line = 2242,
	},
	["0063_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Fumino es la debilidad del senador Hitoura?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从来没这样想过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從來沒這樣想過。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00174",
		linknext = "0063_00176",
		line = 2252,
	},
	["0063_00176"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tal vez, pero ¿cómo...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果真是这样的话……文乃对仁浦先生来说是什么呢——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果真是這樣的話……文乃對仁浦先生來說是什麼呢——」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00175",
		linknext = "0063_00177",
		line = 2264,
	},
	["0063_00177"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1277", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm... ¿Compañera amiga, familia? Todo eso es valioso para una persona.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……同伴、朋友、家人，大家都很重要吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……同伴、朋友、家人，大家都很重要吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00176",
		linknext = "0063_00178",
		line = 2278,
	},
	["0063_00178"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Familia...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“家人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「家人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00177",
		linknext = "0063_00179",
		line = 2290,
	},
	["0063_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está soltero y nunca se casó.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生是单身，没有妻子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生是單身，沒有妻子。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00178",
		linknext = "0063_00180",
		line = 2300,
	},
	["0063_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino es menor que nosotros, así que no puede ser su hermana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，文乃比我们年轻——从这一点来看，仁浦先生的血缘关系这条线就消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，文乃比我們年輕——從這一點來看，仁浦先生的血緣關係這條線就消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00179",
		linknext = "0063_00181",
		line = 2310,
	},
	["0063_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, si fuera parte de su familia...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即便如此，如果假定文乃是仁浦先生的家人的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即便如此，如果假定文乃是仁浦先生的家人的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00180",
		linknext = "0063_00182",
		line = 2320,
	},
	["0063_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"... Y si su existencia representa una amenaza para la ley...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说文乃的存在与条例的瓦解息息相关的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說文乃的存在與條例的瓦解息息相關的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00181",
		linknext = "0063_00183",
		line = 2330,
	},
	["0063_00183"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Suponiendo que Fumino fuera la hija ilegítima del gobernador, tendría muchas preguntas, pero algunas cosas tendrían sentido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“假如，文乃是县知事的私生女的话——虽然还有很多疑问，不过能说得通。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「假如，文乃是縣知事的私生女的話——雖然還有很多疑問，不過能說得通。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00182",
		linknext = "0063_00184",
		line = 2342,
	},
	["0063_00184"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1278", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Quiere proteger a Fumino-chan porque es su papá?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果是那样，那他是作为父亲在担心，所以才想要保护文乃吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果是那樣，那他是作為父親在擔心，所以才想要保護文乃嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00183",
		linknext = "0063_00185",
		line = 2356,
	},
	["0063_00185"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No tiene que ser eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那……到底是不是呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那……到底是不是呢。」",
					{"rt2"},
				},
