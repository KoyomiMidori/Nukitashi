		linkback = "0063_00197",
		linknext = "0063_00199",
		line = 2525,
	},
	["0063_00199"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1283", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well, you're finally friends with Rei, and she talks about you a lot. What would happen if you betrayed the SS now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为橘君好不容易和礼酱成了好朋友……礼酱也经常说橘君的事情……现在背叛FS的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為橘君好不容易和禮醬成了好朋友……禮醬也經常說橘君的事情……現在背叛FS的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00198",
		linknext = "0063_00200",
		line = 2537,
	},
	["0063_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After asking that, she looks up at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱把话打住，用担心的目光看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬把話打住，用擔心的目光看著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00199",
		linknext = "0063_00201",
		line = 2547,
	},
	["0063_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In my pocket I have the bear strap she gave me, attached to my tablet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"口袋里的平板上挂的是渡酱给我的小熊挂件。",
					{"rt2"},
				},
			},
			tw = {
				{
					"口袋裡的平板上掛的是渡醬給我的小熊挂件。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00200",
		linknext = "0063_00202",
		line = 2557,
	},
	["0063_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In my bag I have the brand-new handgun that Rei gave me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"包里是礼前辈送的新手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"包裡是禮前輩送的新手槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00201",
		linknext = "0063_00203",
		line = 2567,
	},
	["0063_00203"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00202",
		linknext = "0063_00204",
		line = 2579,
	},
	["0063_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter what, I never even considered that my conviction could waver.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我——从一开始，就决定不管发生什么，都不会改变信念。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我——從一開始，就決定不管發生什麼，都不會改變信念。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00203",
		linknext = "0063_00205",
		line = 2589,
	},
	["0063_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The perverted sex law is twisted and evil, and I cannot allow it to exist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个条例是扭曲的，是绝对不能放置不管的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個條例是扭曲的，是絕對不能放置不管的。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00204",
		linknext = "0063_00206",
		line = 2599,
	},
	["0063_00206"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No matter what, I have to do what I set out to do at the start.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我一开始——就做好觉悟了。”",
