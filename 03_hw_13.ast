		{"bgm", file="bgm03", vol=100},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1272", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see. We're not the only ones looking for Fumino, the SS and Yakuza are, too? Wow, she's so popular.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是吗。FS的所有人，还有黑社会的所有人都在寻找文乃。好厉害啊，真有人气……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是嗎。FS的所有人，還有黑社會的所有人都在尋找文乃。好厲害啊，真有人氣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00159",
		linknext = "0063_00161",
		line = 2068,
	},
	["0063_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The SS also believes that her existence is key to bringing down the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘文乃’无疑是瓦解条例的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『文乃』無疑是瓦解條例的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00160",
		linknext = "0063_00162",
		line = 2080,
	},
	["0063_00162"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I still don't understand how, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，一个少女怎么能办到那种事呢——这部份还不清楚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，一個少女怎麼能辦到那種事呢——這部份還不清楚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00161",
		linknext = "0063_00163",
		line = 2092,
	},
	["0063_00163"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1273", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hmm, I wonder. Maybe she's just really good at abolishing laws?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“为什么呢……？她是一个擅长破坏条例的孩子吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「為什麼呢……？她是一個擅長破壞條例的孩子嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00162",
		linknext = "0063_00164",
		line = 2106,
	},
	["0063_00164"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh, who the hell would be like that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“噗……那是什么啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「噗……那是什麼啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00163",
		linknext = "0063_00165",
		line = 2118,
	},
	["0063_00165"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1274", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, why are you laughing!? That was a real suggestion!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊——你笑了！我明明很认真在想！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊——你笑了！我明明很認真在想！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00164",
		linknext = "0063_00166",
		line = 2132,
	},
	["0063_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, sorry...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，對不起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00165",
		linknext = "0063_00167",
		line = 2144,
	},
	["0063_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, the order came from Senator Hitoura himself. If he cares enough to personally make a standing order to search for her, maybe she's got some dirt on him?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，仁浦先生的搜索命令一直发布着——也就是说，文乃或许掌握了仁浦先生的弱点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，仁浦先生的搜索命令一直發佈著——也就是說，文乃或許掌握了仁浦先生的弱點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00166",
		linknext = "0063_00168",
		line = 2156,
	},
	["0063_00168"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata looks at me quizzically.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱微微地歪着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬微微地歪著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00167",
		linknext = "0063_00169",
		line = 2168,
	},
	["0063_00169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like maybe she knows something that could threaten his standing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“例如……掌握了威胁仁浦先生地位的情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「例如……掌握了威脅仁浦先生地位的情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00168",
		linknext = "0063_00170",
		line = 2180,
	},
	["0063_00170"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1275", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooh, yeah, maybe. Or maybe she herself is his weakness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦，原来如此，看起来确实是这样……或许文乃本身就是仁浦先生的弱点也说不定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦，原來如此，看起來確實是這樣……或許文乃本身就是仁浦先生的弱點也說不定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00169",
		linknext = "0063_00171",
		line = 2194,
	},
	["0063_00171"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么说？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼說？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00170",
		linknext = "0063_00172",
		line = 2206,
	},
	["0063_00172"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1276", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Well, maybe Fumino is personally important to him. Then he really wouldn't want the Yakuza to get ahold of her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你想想，如果文乃是仁浦先生最重要的人的话，如果被黑社会们抢走不是会很困扰吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你想想，如果文乃是仁浦先生最重要的人的話，如果被黑社會們搶走不是會很困擾嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00171",
		linknext = "0063_00173",
		line = 2220,
	},
	["0063_00173"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
