	["0063_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino herself as Senator Hitoura's weakness?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从来没这样想过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從來沒這樣想過。",
					{"rt2"},
