					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si se les ordeno encontrarla, ¿fue por algo que hizo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“找出并保护也就是说……那个‘文乃’做了什么吗？”",
