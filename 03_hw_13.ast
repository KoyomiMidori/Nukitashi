		linkback = "0063_00174",
		linknext = "0063_00176",
		line = 2252,
	},
	["0063_00176"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Maybe, but how?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果真是这样的话……文乃对仁浦先生来说是什么呢——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果真是這樣的話……文乃對仁浦先生來說是什麼呢——」",
					{"rt2"},
				},
