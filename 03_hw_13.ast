	["0063_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde que he ido ganándome su confianza, ya no duda de mí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到今天为止充分构筑起的信赖关系，已经让礼前辈对我的行动不抱有疑问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到今天為止充分構築起的信賴關係，已經讓禮前輩對我的行動不抱有疑問。",
					{"rt2"},
				},
