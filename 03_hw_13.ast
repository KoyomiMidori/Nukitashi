					"“Me puse a leerlo, perdón...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，我擅自看了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，我擅自看了……」",
