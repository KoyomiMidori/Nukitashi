		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm03", vol=100},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1272", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo. ¿No somos los únicos que buscamos a Fumino, sino también la SS y la yakuza? Se nota que es popular.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是吗。FS的所有人，还有黑社会的所有人都在寻找文乃。好厉害啊，真有人气……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是嗎。FS的所有人，還有黑社會的所有人都在尋找文乃。好厲害啊，真有人氣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00159",
		linknext = "0063_00161",
		line = 2068,
	},
	["0063_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La SS también cree que su existencia es clave para acabar con la ley súperpervertida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘文乃’无疑是瓦解条例的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『文乃』無疑是瓦解條例的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00160",
		linknext = "0063_00162",
		line = 2080,
	},
	["0063_00162"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero no entiendo cómo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，一个少女怎么能办到那种事呢——这部份还不清楚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，一個少女怎麼能辦到那種事呢——這部份還不清楚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00161",
		linknext = "0063_00163",
		line = 2092,
	},
	["0063_00163"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1273", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm, quién sabe. ¿Quizás solo sea muy buena aboliendo leyes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“为什么呢……？她是一个擅长破坏条例的孩子吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「為什麼呢……？她是一個擅長破壞條例的孩子嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00162",
		linknext = "0063_00164",
		line = 2106,
	},
	["0063_00164"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
