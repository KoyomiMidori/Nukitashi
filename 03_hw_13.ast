					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Je... ¿Quién es capaz de semejante cosa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“噗……那是什么啊。”",
