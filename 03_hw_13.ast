		line = 1310,
	},
	["0063_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you were ordered to secure her, does that mean she did something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“找出并保护也就是说……那个‘文乃’做了什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「找出並保護也就是說……那個『文乃』做了什麼嗎？」",
