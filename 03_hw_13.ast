	["0063_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi corazón late con fuerza. Intento calmarme y elegir cuidadosamente mis palabras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我冷静地压抑住心跳的加速，慎重选择词语。",
