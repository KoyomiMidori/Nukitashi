	["0063_00038"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00125", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0406", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Argh! ¡Hasta tienes tu propia frase y todo! Eres lindísima, despistada y llevas una silla... ¡Eres perfecta! ¡Dame algunos de tus rasgos de personaje!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，你看，还有这样的固定台词……！再加上简单可爱又总是拿着钢管椅……太过分了！请把特色分给我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，你看，還有這樣的固定臺詞……！再加上簡單可愛又總是拿著鋼管椅……太過分了！請把特色分給我！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00037",
		linknext = "0063_00039",
		line = 508,
	},
	["0063_00039"] = {
