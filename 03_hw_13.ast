					name = {"美岬"},
					"“啊，你看，还有这样的固定台词……！再加上简单可爱又总是拿着钢管椅……太过分了！请把特色分给我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，你看，還有這樣的固定臺詞……！再加上簡單可愛又總是拿著鋼管椅……太過分了！請把特色分給我！」",
					{"rt2"},
				},
			},
		},
