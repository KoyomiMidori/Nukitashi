	["0063_00021"] = {
		{"bgm", stop=1},
		{"bg", id=2, file="bg12_1l_00000", x=-340, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00111", file2="misaki_01l_00202", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0400", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wait! All yoosa shut up a minute! Why! The hell! Is nobody! Acknowledging meesa!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“能稍等一下吗美！？为什么！没有人要！对我！说些什么美！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「能稍等一下嗎美！？為什麼！沒有人要！對我！說些什麼美！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00020",
		linknext = "0063_00022",
		line = 274,
	},
	["0063_00022"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So... nobody's clapped back about this yet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……没人要吐槽你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……沒人要吐槽你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00021",
		linknext = "0063_00023",
		line = 292,
	},
	["0063_00023"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1880", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I figured we were better off not broaching the subject...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我觉得还是不要扯上关系比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我覺得還是不要扯上關係比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00022",
		linknext = "0063_00024",
		line = 306,
	},
	["0063_00024"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00125", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0401", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But meesa WANT you to broach subject! Meesa just look stupid now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“请跟我扯上关系美！不然我不就只像个笨蛋吗美！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「請跟我扯上關係美！不然我不就只像個笨蛋嗎美！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00023",
		linknext = "0063_00025",
		line = 322,
	},
	["0063_00025"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1115", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You ARE stupid. And a walking, talking tub of lard to boot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“实际上就是个笨蛋还是个胖子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「實際上就是個笨蛋還是個胖子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00024",
		linknext = "0063_00026",
		line = 335,
	},
	["0063_00026"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1265", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh!? Wait a minute, she's talking all funny! Seriously? That's incredible!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊！？被这么一说，美岬酱的说话方式和平时不一样呢！为什么？好厉害！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊！？被這麼一說，美岬醬的說話方式和平時不一樣呢！為什麼？好厲害！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00025",
		linknext = "0063_00027",
		line = 350,
	},
	["0063_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The fact that you only just noticed is more incredible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样都没注意到的渡酱反而觉得很厉害……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣都沒注意到的渡醬反而覺得很厲害……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00026",
		linknext = "0063_00028",
		line = 362,
	},
	["0063_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, care to explain yourself? Have you been binge-watching space wizard movies for toddlers or what?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你怎么了？难道看了什么面向小女孩的奇妙动画片吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你怎麼了？難道看了什麼面向小女孩的奇妙動畫片嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00027",
		linknext = "0063_00029",
		line = 374,
	},
	["0063_00029"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0402", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Come on... I can't take this anymore! You always leave me out, and even when I'm in the group, you still forget about me anyway... I need to have SOME kind of memorable trait to make my character stand out!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为……前几天只有我被排挤啊！？而且平常就很容易被忘记……如果不能再多创造点特色就糟了不是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為……前幾天只有我被排擠啊！？而且平常就很容易被忘記……如果不能再多創造點特色就糟了不是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00028",
		linknext = "0063_00030",
		line = 386,
	},
	["0063_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't worry about it so much. I think you've got enough memorable character traits.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使不用那么在意，我也觉得畔很有特色了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使不用那麼在意，我也覺得畔很有特色了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00029",
		linknext = "0063_00031",
		line = 398,
	},
	["0063_00031"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0403", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Name one!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“例如！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「例如！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00030",
		linknext = "0063_00032",
		line = 412,
	},
	["0063_00032"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh... bookworm?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文学少女之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文學少女之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00031",
		linknext = "0063_00033",
		line = 424,
	},
	["0063_00033"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00122", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0404", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So you really think that, do you? Okay, answer me this—have you ever thought of me as a bookworm even once before now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你真的那么想吗！？那我反过来问你，到现在为止你有曾经认为我是文学少女过吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你真的那麼想嗎！？那我反過來問你，到現在為止你有曾經認為我是文學少女過嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00032",
		linknext = "0063_00034",
		line = 438,
	},
	["0063_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Good grief, who pissed in her cornflakes today?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这人为什么生气了啊……",
					{"rt2"},
				},
			},
			tw = {
				{
					"這人為什麼生氣了啊……",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00033",
		linknext = "0063_00035",
		line = 448,
	},
	["0063_00035"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1266", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, umm... I don't quite understand what you're talking about, but did something unpleasant happen to you? I'm your senior, I can hear you out if you want.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃、呃……虽然我不太清楚，可是美岬酱有遇到什么讨厌的事吗？前辈会听你说话哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
