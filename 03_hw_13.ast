	["0063_00093"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0622", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tranquilo. Ya eres un miembro hecho y derecho. Da igual si te enteras ahora o si inevitablemente te enteras después, realmente no importa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别放在心上。橘已经被内定为正式成员了。应该不会有什么问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別放在心上。橘已經被內定為正式成員了。應該不會有什麼問題。」",
					{"rt2"},
				},
			},
		},
