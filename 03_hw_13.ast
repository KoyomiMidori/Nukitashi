				{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=3800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0621", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ah, um... ¿qué estás leyendo? Ah, ese documento. Uff... Parece que a Ran se le olvidó archivarlo otra vez... Santo cielo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊，呃……你又在看什么了？那是——啊，那份报告吗？唉……兰那家伙又忘了收起来了……真是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊，呃……你又在看什麼了？那是——啊，那份報告嗎？唉……蘭那傢伙又忘了收起來了……真是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00090",
		linknext = "0063_00092",
		line = 1198,
	},
	["0063_00092"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
