		linkback = "0063_00096",
		linknext = "0063_00098",
		line = 1266,
	},
	["0063_00098"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0623", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ah, supongo que los cadetes no lo saben. Hace tiempo nos dieron órdenes de encontrarla y protegerla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊，训练生不知道啊……很久以前，我们就收到找到那个少女并保护起来的命令了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊，訓練生不知道啊……很久以前，我們就收到找到那個少女並保護起來的命令了。」",
					{"rt2"},
				},
			},
		},
