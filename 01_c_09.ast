		linkback = "0010_00465",
		linknext = "0010_00467",
		line = 6040,
	},
	["0010_00467"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0002", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "ヒナミ祖父"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Abuelo de Hinami"},
					"“Vaya, cómo pasa el tiempo... Esta isla solía ser un montón de nada. Y luego el gran profesor Hitoura la convirtió en un lugar tan animado y próspero.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "雏见的祖父"},
					"“时间过得真快……在过去，这岛上什么都没有……是仁浦大人把它变成了这样一个充满活力的岛屿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "雛見的祖父"},
					"「時間過得真快……在過去，這島上什麼都沒有……是仁浦大人把它變成了這樣一個充滿活力的島嶼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00466",
		linknext = "0010_00468",
		line = 6052,
	},
	["0010_00468"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0022", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "ヒナミ祖母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Abuela de Hinami"},
					"“Asi es, todas las personas de nuestra edad lo consideran una especie de dios. Le debemos mucho...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "雏见的祖母"},
					"“是啊，这附近的老人都认为他是上帝……真感谢，真感谢啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "雛見的祖母"},
					"「是啊，這附近的老人都認為他是上帝……真感謝，真感謝啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00467",
		linknext = "0010_00469",
		line = 6064,
	},
	["0010_00469"] = {
