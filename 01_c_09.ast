		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0019", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Están grabando a todo el mundo mientras practican sexo pervertido. Si van a la oficina principal de la SHO y les dicen la hora y el lugar, pueden comprar la grabación correspondiente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“我们一直记录着每个人的变态做爱。通过告诉SHO总部日期和时间，可以购买做爱时的视频哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「我們一直記錄著每個人的變態做愛。通過告訴SHO總部日期和時間，可以購買做愛時的影片哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00424",
		linknext = "0010_00426",
		line = 5481,
	},
	["0010_00426"] = {
