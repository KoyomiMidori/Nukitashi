	["0010_00281"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00102", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0028", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Eh? Ah, Hinami. ¿Ya te vas a casa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊……哦，是雏见啊。要回家了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊……哦，是雛見啊。要回家了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00280",
		linknext = "0010_00282",
		line = 3669,
	},
	["0010_00282"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00102", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0062", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sip. ¿Estás trabajando?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯。礼酱在工作吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯。禮醬在工作嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00281",
		linknext = "0010_00283",
		line = 3682,
	},
	["0010_00283"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00113", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0029", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí. Recibimos un comentario en el buzón de sugerencias que decía que, con el aumento de las prácticas sexuales pervertidas habituales, la moral está en decadencia. Es tarea del comité proporcionar orientación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，意见箱里有人投诉说最近常有惰性做爱，这有乱风纪。所以风纪委员在指导大家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，意見箱裡有人投訴說最近常有惰性做愛，這有亂風紀。所以風紀委員在指導大家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00282",
		linknext = "0010_00284",
		line = 3696,
	},
	["0010_00284"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0063", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo... Debe ser bastante difícil escuchar tantas perspectivas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊……要听大家的意见还真是辛苦呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊……要聽大家的意見還真是辛苦呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00283",
		linknext = "0010_00285",
		line = 3708,
	},
	["0010_00285"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0030", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Bueno, la SS tiene un amplio margen de trabajo. El consejo estudiantil y el comité disciplinario son prácticamente dominio exclusivo de los miembros de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，其中一个原因是因为SS的工作范围很广——毕竟学生会和委员会基本上都是由SS构成的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，其中一個原因是因為SS的工作範圍很廣——畢竟學生會和委員會基本上都是由SS構成的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00284",
		linknext = "0010_00286",
		line = 3722,
	},
	["0010_00286"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00102", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0064", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero oí que nadie en el comité disciplinario está tan ocupada como tú.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是，我有听说礼酱在风纪委员里是最忙的哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
