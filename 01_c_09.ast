		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_032_00000"},
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0068", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "教師"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Profesora"},
					"“Buenos días. Vamos a empezar la clase. Por ahora, permanezcan en sus asientos, que tengo algo que decirles... ¿Qué pasa? ¿Hay algún problema?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "老师"},
					"“早上好。那么让我们开始班会，就那样听就好了……嗯？怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
