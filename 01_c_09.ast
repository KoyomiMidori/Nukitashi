			cn = {
				{
					"在获得SHO奖学金的人当中，她也是拥有“特别奖学生”这个特殊资格的学生，并被托付了许多工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在獲得SHO獎學金的人當中，她也是擁有「特別獎學生」這個特殊資格的學生，並被託付了許多工作。",
