	["0010_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei-chan es mi compañera, una estudiante muy diligente y la presidenta del comité disciplinario.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的同学礼酱是个很努力的学生，她是学校的风纪委员长。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的同學禮醬是個很努力的學生，她是學校的風紀委員長。",
					{"rt2"},
				},
			},
		},
