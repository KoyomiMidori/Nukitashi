	["0010_00421"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al levantar la vista, veo a un grupo de turistas hablando con un guardia mientras contemplan la playa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"抬头一看，是一群团体游客一边眺望着海滩，一边听着SHO小姐姐说话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"抬頭一看，是一群團體遊客一邊眺望著海灘，一邊聽著SHO大姐姐說話。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00420",
		linknext = "0010_00422",
		line = 5427,
	},
	["0010_00422"] = {
		{"bg", id=1, file="bg22_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="kouki_01m_00002", file1="kouki_01m_00101", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0017", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Ahora, si miran por allí, verán la famosa cámara de seguridad espía de la Isla Seiran.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“呃——在那里的是青蓝岛有名的针孔防犯摄像机。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「呃——在那裡的是青藍島有名的針孔防犯攝影機。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00421",
		linknext = "0010_00423",
		line = 5441,
	},
	["0010_00423"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00102", path=":fg/kouki_01m/", id=11, lv=5, head="kouki_01m", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0018", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“Más de 200 cámaras vigilan la calle principal de la Isla Seiran. Supervisan el centro de la ciudad las 24 horas del día para garantizar su seguridad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“在青蓝岛，以主街道为中心总共设有200多个摄像头，中央中心24小时监控以保证大家的人身安全。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「在青藍島，以主街道為中心總共設有200多個攝影機，中央中心24小時監控以保證大家的人身安全。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00422",
		linknext = "0010_00424",
		line = 5455,
	},
	["0010_00424"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0026", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "男C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Hombre C"},
					"“¿Por qué las llaman espías si son cámaras de seguridad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "C男"},
					"“明明是防犯用摄像机，却是针孔摄像头吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "C男"},
					"「明明是防犯用攝影機，卻是針孔攝影機嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00423",
