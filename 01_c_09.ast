	["0010_00372"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0079", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Qué hago? ¡Tengo que alistarme e ir a la escuela!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“怎么办，我要赶快准备去学校。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「怎麼辦，我要趕快準備去學校。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00371",
		linknext = "0010_00373",
		line = 4832,
	},
	["0010_00373"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0080", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ母", "Madre de Hinami"},
					"“¿Hinami? ¿Ya estás despierta? Necesito un favor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ母", "雏见妈妈"},
					"“喂雏见——？你已经起来了吗——？我有事想拜托你——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ母", "雛見媽媽"},
					"「喂雛見——？你已經起來了嗎——？我有事想拜託你——」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00372",
		linknext = "0010_00374",
		line = 4845,
	},
	["0010_00374"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0081", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Mamááá! ¡¿Por qué no me despertaste?! ¡Voy a llegar tarde!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“妈——妈——！为什么不叫我起来啊〜！我都要迟到了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「媽——媽——！為什麼不叫我起來啊〜！我都要遲到了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00373",
		linknext = "0010_00375",
		line = 4857,
	},
	["0010_00375"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0082", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ母", "Madre de Hinami"},
					"“¿De qué estás hablando? Santo cielo... Hoy es el Día de la Orgía de la Isla, no tienes que ir a la escuela.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ母", "雏见妈妈"},
					"“在说什么呢，你这个孩子……今天是奸港纪念日，学校放假不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ母", "雛見媽媽"},
					"「在說什麼呢，你這個孩子……今天是姦港紀念日，學校放假不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00374",
		linknext = "0010_00376",
		line = 4869,
	},
	["0010_00376"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ah... Ahhhh, cierto...",
					{"rt2"},
				},
			},
			cn = {
				{
					"啊……啊——对诶……",
					{"rt2"},
				},
			},
			tw = {
				{
					"啊……啊——對欸……",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00375",
		linknext = "0010_00377",
		line = 4879,
	},
	["0010_00377"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hoy es festivo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天是休息日啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天是休息日啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00376",
		linknext = "0010_00378",
		line = 4889,
	},
	["0010_00378"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0083", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ母", "Madre de Hinami"},
					"“Vaya, ¿cómo pudiste olvidarte de la única festividad pervertida que conmemora el establecimiento de la ley?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ母", "雏见妈妈"},
					"“真是的，这个孩子居然把这个岛的条例成立变态纪念日给忘了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ母", "雛見媽媽"},
					"「真是的，這個孩子居然把這個島的條例成立變態紀念日給忘了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00377",
		linknext = "0010_00379",
		line = 4901,
	},
	["0010_00379"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0084", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Lo siento... Me quedé despierta hasta tarde haciéndome masajes. Mmmm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对不起……对了，所以我昨天才会熬夜按摩……呼啊啊啊〜〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對不起……對了，所以我昨天才會熬夜按摩……呼啊啊啊〜〜」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00378",
		linknext = "0010_00380",
		line = 4913,
	},
	["0010_00380"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0085", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ母", "Madre de Hinami"},
					"“No vas a crecer más si no te acuestas a la hora apropiada, jovencita... En fin, necesito un favor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ母", "雏见妈妈"},
					"“不早点睡对成长不好哦……啊，对了，我有事想拜托雏见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ母", "雛見媽媽"},
					"「不早點睡對成長不好哦……啊，對了，我有事想拜託雛見。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00379",
		linknext = "0010_00381",
		line = 4925,
	},
	["0010_00381"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0086", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ母", "Madre de Hinami"},
					"“¿Podrías ir a casa de los abuelos por mí? Quiero que les lleves algo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ母", "雏见妈妈"},
					"“你能帮我把这些东西带到爷爷奶奶家吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ母", "雛見媽媽"},
					"「你能幫我把這些東西帶到爺爺奶奶家嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00380",
		linknext = "0010_00382",
		line = 4937,
	},
	["0010_00382"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0087", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vale. No tengo nada que hacer, así que está bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，好啊。我今天也没有打算出去玩。我会去的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，好啊。我今天也沒有打算出去玩。我會去的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00381",
		linknext = "0010_00383",
		line = 4949,
	},
	["0010_00383"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0088", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ母", "Madre de Hinami"},
					"“Está en la ladera, así que puedes usar el autobús. Te daré algo de cambio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ母", "雏见妈妈"},
					"“因为在山上，你就坐公交车上去吧。我会给你钱搭车的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ母", "雛見媽媽"},
					"「因為在山上，你就坐巴士上去吧。我會給你錢搭車的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00382",
		linknext = "0010_00384",
		line = 4961,
	},
	["0010_00384"] = {
		{"text"},
		text = {
