	},
	["0010_00464"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0021", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "ヒナミ祖母"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Abuela de Hinami"},
					"“Eso no es cierto. Hinami-chan ya es una chica mayor. Ya ha prestado sus servicios a mucha gente en nombre de la ley pervertida, ¿no es así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "雏见的祖母"},
					"“没有那种事，雏见酱已经是大姐姐了。有遵守‘变态条例’在岛上服务了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "雛見的祖母"},
					"「沒有那種事，雛見醬已經是大姐姐了。有遵守『變態條例』在島上服務了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00463",
		linknext = "0010_00465",
		line = 6017,
	},
	["0010_00465"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siento un dolor en el pecho.",
					{"rt2"},
