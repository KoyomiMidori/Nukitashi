	["0010_00275"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No pude deshacerme de la inquietud que me causaba durante el resto del día. Las clases ya terminaron y siento que el tiempo se me echó encima.",
					{"rt2"},
				},
			},
			cn = {
				{
					"抱着这样郁闷的心情，放学了。",
					{"rt2"},
