	["0010_00073"] = {
		{"se", id=0, loop=0, file="se_a003"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0014", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "女子生徒B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Estudiante B"},
					"“Ahh, qué calor, qué calor... ¿Crees que con todo este semen me vas a satisfacer? ¡Lame tu propio semen, bastardo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "女学生B"},
					"“嗯哈、啊、啊……你以为射这么多还能装没事吗……？来，把自己射出来的都舔干净你这条土狗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "女學生B"},
					"「嗯哈、啊、啊……你以為射這麼多還能裝沒事嗎……？來，把自己射出來的都舔乾淨你這條土狗！」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00072",
		linknext = "0010_00074",
		line = 912,
	},
