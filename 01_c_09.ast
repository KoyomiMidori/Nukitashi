	["0010_00200"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0020", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "男A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Hombre A"},
					"“Vaya, el cerebro detrás de la Isla Seiran está haciendo un poco de promoción para su candidatura a gobernador, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "A男"},
					"“啊，这个自推党的人就是造出青蓝岛的县知事啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "A男"},
					"「啊，這個自推黨的人就是造出青藍島的縣知事啊。」",
