		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si lo estuviera usando, vería que se enciende la luz del piso en el que se detuvo, pero no veo nada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果用电梯下去了，显示楼层的灯会亮，但是现在哪层都没有亮。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果用電梯下去了，顯示樓層的燈會亮，但是現在哪層都沒有亮。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00270",
		linknext = "0010_00272",
		line = 3458,
	},
	["0010_00272"] = {
