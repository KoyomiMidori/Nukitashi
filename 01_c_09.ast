		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0105", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uno no creería que está a punto de reventar...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“刚才的喧闹，就好像假的一样……”",
