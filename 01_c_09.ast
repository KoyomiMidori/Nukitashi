		linkback = "0010_00445",
		linknext = "0010_00447",
		line = 5777,
	},
	["0010_00447"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El lado de la playa con el puerto deportivo en medio, donde los turistas bajan de los barcos que los llevan hasta allí, siempre está lleno de gente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以游客下船的港口为中心的海滩方向，人潮一直络绎不绝。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以遊客下船的港口為中心的海灘方向，人潮一直絡繹不絕。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00446",
		linknext = "0010_00448",
		line = 5787,
	},
	["0010_00448"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se han establecido numerosas tiendas e instalaciones para su comodidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了方便游客，还开了许多商店和设施。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了方便遊客，還開了許多商店和設施。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00447",
		linknext = "0010_00449",
		line = 5797,
	},
	["0010_00449"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero esta parte más montañosa de la isla prácticamente no ha sido tocada, salvo por alguna que otra casa imponente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是山的另一边却没有被开发，偶尔只会遇到几栋老宅在这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是山的另一邊卻沒有被開發，偶爾只會遇到幾棟老建築在這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00448",
		linknext = "0010_00450",
		line = 5807,
	},
	["0010_00450"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los lugareños llaman a esta zona sin urbanizar de la isla la ladera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛屿上未被开发的靠山处，被镇上的人们称为“山之手”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島嶼上未被開發的靠山處，被鎮上的人們稱為「山之手」。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00449",
