		{"se", id=0, stop=1, time=1000},
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mamá debió a mis abuelitos antes de que yo llegara, pues me están esperando en la puerta para darme una cálida bienvenida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是母亲打电话联系了，爷爷和奶奶都热情地出门迎接了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是母親打電話聯繫了，爺爺和奶奶都熱情地出門迎接了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00454",
		linknext = "0010_00456",
		line = 5908,
	},
	["0010_00456"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0000", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "ヒナミ祖父"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Abuelo de Hinami"},
					"“¡Oh, Hinami! ¡Por fin llegaste! Debió ser duro cargar todo eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "雏见的祖父"},
					"“哦哦雏见，来得好来得好！拿了这么多行李，很辛苦吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "雛見的祖父"},
					"「哦哦雛見，來得好來得好！拿了這麼多行李，很辛苦吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00455",
		linknext = "0010_00457",
		line = 5920,
	},
	["0010_00457"] = {
		{"fg", file="hinami_01f_00002", file1="hinami_01f_00102", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
