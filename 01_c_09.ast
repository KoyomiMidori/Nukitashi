		line = 5817,
	},
	["0010_00451"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No hay carreteras en la ladera y es complicado orientarse, por lo que no hay guardias de la SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
