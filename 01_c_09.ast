				},
			},
			en = {
				{
					name = {"モブ女A", "Mujer A"},
					"“¿Cómo? ¿Esta isla calenturienta tiene su propio gobierno provincial?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "A女"},
					"“诶，什么？这个变态岛是县知事造的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "A女"},
					"「欸，什麼？這個變態島是縣知事造的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00200",
		linknext = "0010_00202",
		line = 2586,
	},
	["0010_00202"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0021", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "男A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Hombre A"},
					"“Pues sí. En la tele dijeron que propuso la ley sobre sexo pervertido como una forma de abordar el problema de la despoblación en la isla. El tipo tiene un historial impecable de décadas como gobernador.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "A男"},
					"“是啊。电视上说因为这个岛人口减少，所以他提交了变态条例作为城镇复兴的方案。他好像已经当了好几十年的县知事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "A男"},
					"「是啊。電視上說因為這個島人口減少，所以他提交了變態條例作為城鎮復興的方案。他好像已經當了好幾十年的縣知事了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00201",
		linknext = "0010_00203",
		line = 2598,
	},
