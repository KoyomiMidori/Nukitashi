				{"vo", file="hinami0107", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Realmente no. Es fácil para mí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事的哦。这种程度对我来说是小菜一碟。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒事的哦。這種程度對我來說是小菜一碟。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00456",
		linknext = "0010_00458",
		line = 5933,
	},
	["0010_00458"] = {
