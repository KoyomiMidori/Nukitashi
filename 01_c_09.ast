		{"bg", id=1, file="bg15_1_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg06_00001", x=0, y=0, path=":cg/kcg06/", ev=1, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"bgm", file="bgm08", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0026", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Oye! Ni siquiera te molestas en lamer el pezón mientras te hacen una paja, ¿verdad? ¡A ver si usas bien la lengua y le das placer a tu pareja!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你！帮人撸管的时候怎么能不去舔乳头！用你的舌头去舔遍全身满足对方！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你！幫人打手槍的時候怎麼能不去舔乳頭！用你的舌頭去舔遍全身滿足對方！」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00277",
		linknext = "0010_00279",
		line = 3605,
	},
	["0010_00279"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0027", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Y tú! ¡No pienses que la penetración por sí sola es suficiente para satisfacer a tu pareja! ¡Lo mejor es que frotes suavemente el clítoris mientras empujas hacia adentro y hacia afuera!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“还有你……！别以为插入就能满足对方！记住要一边轻抚阴核一边抽插！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「還有你……！別以為插入就能滿足對方！記住要一邊輕撫陰核一邊抽插！」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00278",
		linknext = "0010_00280",
		line = 3617,
	},
