		line = 834,
	},
	["0010_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debería tomar agua... Mamá siempre me dice que debo estar hidratada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要听母亲说的多喝点水才行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要聽媽媽說的多喝點水才行。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00067",
		linknext = "0010_00069",
		line = 844,
	},
	["0010_00069"] = {
		{"fg", mode=-1, id=30, ch="ヒナミ", lv=5},
		{"bg", id=1, file="bg15_1_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"se", id=1, loop=0, file="se_d012", vol=50},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0066", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“¡Vamos, córrete, córrete para mí! ¡Suéltalo en mi coño como lo haría esta fuente de agua si su grifo estuviera roto!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“射吧？射出来吧？像这个坏掉的水龙头一样把精液射入我的阴道里面吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「射吧？射出來吧？像這個壞掉的水龍頭一樣把精液射入我的陰道裡面吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00068",
		linknext = "0010_00070",
		line = 862,
	},
	["0010_00070"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0028", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "男子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Estudiante A"},
					"“¿Te gusta tanto el agua del grifo? ¡Pues bébetela por el culo! ¡Te voy a dar por ambos agujeros, zorra!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "男学生A"},
					"“你那么喜欢自来水的话，我就喂给你屁眼喝吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "男學生A"},
					"「你那麼喜歡自來水的話，我就餵給你屁眼喝吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00069",
		linknext = "0010_00071",
		line = 874,
	},
	["0010_00071"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0067", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“O¡h nooooo! Me estás sacando todo lo que goteaaaaa ",
					{"gaiji", text="①"},
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“不行啊啊啊啊啊……！水龙头的弯曲部分会卡住的啦啊啊啊",
					{"gaiji", text="①"},
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「不行啊啊啊啊啊……！水龍頭的彎曲部分會卡住的啦啊啊啊",
					{"gaiji", text="①"},
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00070",
		linknext = "0010_00072",
		line = 886,
	},
	["0010_00072"] = {
