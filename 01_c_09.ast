	},
	["0010_00390"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La dejo apoyada contra la pared y salgo rápidamente de mi casa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把常用的钢管椅立靠在墙上，小跑着离开了家。",
					{"rt2"},
				},
			},
