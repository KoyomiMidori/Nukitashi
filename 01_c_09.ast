	},
	["0010_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dudo que alguien discuta si dices que este tipo de clima es propio del verano.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说今天是夏天也肯定没人会生气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說今天是夏天也肯定沒人會生氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00033",
		linknext = "0010_00035",
		line = 435,
	},
	["0010_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que este año llegó julio en un abrir y cerrar de ojos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"注意到时，今年也已经7月了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"注意到時，今年也已經7月了。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00034",
		linknext = "0010_00036",
		line = 445,
	},
	["0010_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los rayos del sol me pican la piel, y toda la ciudad está increíblemente caliente y húmeda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"阳光晒得皮肤发疼，蒸汽的热量覆盖着整个城镇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"陽光曬得皮膚發痛，蒸汽的熱量覆蓋著整個城鎮。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00035",
		linknext = "0010_00037",
		line = 455,
	},
	["0010_00037"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00106", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0009", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hiyaaa, la punta de mi cabeza está caliente..”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇——头顶变得好热呀——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇——頭頂變得好熱呀——」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00036",
		linknext = "0010_00038",
		line = 468,
	},
	["0010_00038"] = {
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Recuerdo que papá me dijo una vez que, como en esta isla no hay muchos edificios altos, la luz del sol es más intensa que en Tokio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我记得爸爸曾经说过，这个岛上没有多少高楼，所以这里的阳光比东京强。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我記得爸爸曾經說過，這個島上沒有多少高樓，所以這裡的陽光比東京強。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00037",
		linknext = "0010_00039",
		line = 479,
	},
	["0010_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nunca he salido de esta isla, así que no lo sé, pero admiro mucho a mi padre por todo el conocimiento del mundo que tiene.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从来没有离开这个岛所以不怎么清楚，但我觉得了解各种世界的爸爸看起来很酷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從來沒有離開這個島所以不怎麼清楚，但我覺得了解各種世界的爸爸看起來很酷。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00038",
		linknext = "0010_00040",
		line = 489,
	},
	["0010_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dicho esto, sin duda siento curiosidad por Tokio, el corazón de Japón. Me pregunto cómo serán las personas de allá.",
					{"rt2"},
				},
			},
			cn = {
				{
					"东京——日本的中心，我很好奇那是什么样的地方，很好奇那里住着什么样的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"東京——日本的中心，我很好奇那是什麼樣的地方，很好奇那裡住著什麼樣的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00039",
		linknext = "0010_00041",
		line = 499,
	},
	["0010_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero realmente me encanta esta isla, con su enorme y hermoso mar azul y sus verdes montañas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我喜欢这个拥有一望无际的美丽蓝色大海，和许多绿色山坡的岛屿。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我喜歡這個擁有一望無際的美麗藍色大海，和許多綠色山坡的島嶼。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00040",
		linknext = "0010_00042",
		line = 509,
	},
	["0010_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si nada cambia en este lugar, probablemente viviré aquí hasta mis últimos años.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果什么都没发生的话，我大概会永远留在这里，直到变成老奶奶吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果什麼都沒發生的話，我大概會永遠留在這裡，直到變成老奶奶吧。",
					{"rt2"},
				},
