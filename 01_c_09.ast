					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“La casa del abuelo, eh... Qué divertido, hace rato que no voy por allá...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“爷爷家吗……已经好久没去了，好期待啊。”",
