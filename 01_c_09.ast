		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0076", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "教師"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Profesora"},
					"“Veamos... Últimamente hemos tenido algunos problemas en la isla, por lo que el director nos ha pedido que repasemos las leyes de la isla antes de la clase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "老师"},
					"“呃——最近岛上似乎有很多争吵事件发生……所以校长拜托我在上课前跟大家再说一遍有关青蓝岛条例的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "老師"},
					"「呃——最近島上似乎有很多爭吵事件發生……所以校長拜託我在上課前跟大家再說一遍有關青藍島條例的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00213",
		linknext = "0010_00215",
		line = 2765,
	},
	["0010_00215"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0077", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "教師"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Profesora"},
					"“Dicho esto, sé que tienen muchas ganas de follar, así que les contaré lo importante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "老师"},
					"“话是这么说，但大家一定都迫不及待地想做爱了吧？所以我就只说几项要点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "老師"},
					"「話是這麼說，但大家一定都迫不及待地想做愛了吧？所以我就只說幾項要點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00214",
		linknext = "0010_00216",
		line = 2777,
	},
	["0010_00216"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0078", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "教師"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Profesora"},
					"“Primero, creo que todos lo saben, pero existe una edad mínima legal para la ley del sexo pervertido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "老师"},
					"“首先，我想每个人都知道……这个‘变态条例’中有一个对象年龄。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "老師"},
					"「首先，我想每個人都知道……這個『變態條例』中有一個對象年齡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00215",
		linknext = "0010_00217",
		line = 2789,
	},
	["0010_00217"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0079", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "教師"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Profesora"},
					"“La ley no permite que puedan tener relaciones sexuales con todo el mundo; cualquier persona menor a la edad mínima establecida se encuentra protegida. Esto tiene como objetivo garantizar un crecimiento saludable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "老师"},
					"“并不是每个人都是条例的对象，必须超过一定的年龄。据说这是为了不去阻碍到健康的成长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "老師"},
					"「並不是每個人都是條例的對象，必須超過一定的年齡。據說這是為了不去阻礙到健康的成長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00216",
		linknext = "0010_00218",
		line = 2801,
	},
	["0010_00218"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0080", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "教師"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Profesora"},
					"“Aquellos que no alcanzan la edad mínima son el futuro de la Isla Seiran. Son fundamentales para el crecimiento de la isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "老师"},
					"“条例年龄以下的儿童是承载青蓝岛未来的重要存在。岛屿全体必须要非常爱护他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "老師"},
					"「條例年齡以下的兒童是承載青藍島未來的重要存在。島嶼全體必須要非常愛護他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00217",
		linknext = "0010_00219",
		line = 2813,
	},
	["0010_00219"] = {
		{"text"},
		text = {
