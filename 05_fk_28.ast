					name = {"美岬", "Misaki"},
					"“Roger! Ah, but Fumino's not on board yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“了解！啊，不过文乃酱还没上来——”",
