		line = 828,
	},
	["0128_00064"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1260", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I slept... I need to be prepared for battle at any time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“在睡觉……为了能够随时战斗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「在睡覺……為了能夠隨時戰鬥……」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00063",
		linknext = "0128_00065",
		line = 842,
	},
	["0128_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's got a little bit of mud on her, but her skin looks pristine from bathing often in the hot springs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然沾了点泥巴，但也许是因为经常泡温泉的缘故，她的皮肤很有光泽。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然沾了點泥巴，但也許是因為經常泡溫泉的緣故，她的皮膚很有光澤。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00064",
		linknext = "0128_00066",
		line = 852,
	},
	["0128_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Virtually all the wounds she got from being tortured by the old man have completely healed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在老人那里受到的拷问伤口也几乎全都愈合了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在老人那裡受到的拷問傷口也幾乎全都癒合了。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00065",
		linknext = "0128_00067",
		line = 862,
	},
	["0128_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's the result of taking her every day to the back-alley doctor for treatment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是每天都去老地下医生那里治疗的成效。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是每天都去老地下醫生那裡治療的成效。",
					{"rt2"},
				},
			},
		},
