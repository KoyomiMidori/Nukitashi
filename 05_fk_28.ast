			},
		},
		linkback = "0128_00025",
		linknext = "0128_00027",
		line = 355,
	},
	["0128_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. But I still don't see any evidence of their determination. Buncha two-bit thugs... ow-ow-ow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是他们还没有找到确凿的证据，那些愚蠢的家伙……疼疼疼疼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是他們還沒有找到確鑿的證據，那些愚蠢的傢伙……裡裡裡裡……」",
					{"rt2"},
				},
			},
		},
