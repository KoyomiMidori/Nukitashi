					name = {"防人老人"},
					"“——情况怎么样，小鬼？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——情況怎麼樣，小鬼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00466",
		linknext = "0128_00468",
		line = 6158,
	},
	["0128_00468"] = {
		{"bgm", file="bgm12", vol=100},
		{"se", id=0, loop=0, file="se_a105"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sakimori!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“防人——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「防人——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00467",
		linknext = "0128_00469",
		line = 6172,
	},
	["0128_00469"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How did he get my number?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么他会知道我的平板号码——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼他會知道我的平板號碼——？",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00468",
		linknext = "0128_00470",
		line = 6182,
	},
	["0128_00470"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00110", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0195", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I did some investigation into you. After all, my minions did ask you a few questions, so you should hardly be surprised.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“我稍为调查了一下。你不是也接受了我手下的讯问，会很奇怪吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「我稍為調查了一下。你不是也接受了我手下的訊問，會很奇怪嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00469",
		linknext = "0128_00471",
		line = 6195,
	},
	["0128_00471"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You sneaky old bastard... Is doxxing people all you can do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是个狡猾的老头……你能做的就只有偷偷摸摸地窃取个人信息吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是個狡猾的老頭……你能做的就只有偷偷摸摸地竊取個人資訊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00470",
		linknext = "0128_00472",
		line = 6207,
	},
	["0128_00472"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0196", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Just wanted to say hello. I hear that someone has been hindering the demolition progress of facilities on the island, and they're falling behind schedule.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“我想来打个招呼。我听说有人妨碍了青蓝岛内设施的拆除工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「我想來打個招呼。我聽說有人妨礙了青藍島內設施的拆除工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00471",
		linknext = "0128_00473",
		line = 6220,
	},
	["0128_00473"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0197", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“And it seems to be the criminal activity of some sort of experienced group.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“好像是老练的集团所为？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「好像是老練的集團所為？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00472",
		linknext = "0128_00474",
		line = 6232,
	},
	["0128_00474"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“First I've heard of it. You have any proof to show me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事我不清楚。你是有什么证据吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種事我不清楚。你是有什麼證據嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00473",
		linknext = "0128_00475",
		line = 6244,
	},
	["0128_00475"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0198", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Hahaha, how childish of you. There is no resistance left, save for your little clique.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“哈哈哈哈，说辞跟个小孩子一样……反叛组织已经只剩下你们了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「哈哈哈哈，說辭跟個小孩子一樣……反叛組織已經只剩下你們了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00474",
		linknext = "0128_00476",
		line = 6257,
	},
	["0128_00476"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00110", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0199", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You are the one last hope remaining for the islanders. Which makes this all the more simple.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“对于岛上的人来说，你是唯一的希望。那么事情就容易了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「對於島上的人來說，你是唯一的希望。那麼事情就容易了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00475",
		linknext = "0128_00477",
		line = 6270,
	},
	["0128_00477"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00476",
		linknext = "0128_00478",
		line = 6282,
	},
	["0128_00478"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0200", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I need only crush you all. That will destroy the last glimmer of hope on this island. Simply doing that will unleash the most terrific despair.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“只要摧毁你们就可以了。只要这样，可以把岛上所有的希望之芽都摧毁。要想让全部人都陷入最深的绝望，只需这么做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「只要摧毀你們就可以了。只要這樣，可以把島上所有的希望之芽都摧毀。要想讓全部人都陷入最深的絕望，只需這麼做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00477",
		linknext = "0128_00479",
		line = 6294,
	},
	["0128_00479"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Does that mean he's just allowed us to move unhindered till now?",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，才会在这之前放任我们是吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，才會在這之前放任我們是嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00478",
		linknext = "0128_00480",
		line = 6304,
	},
	["0128_00480"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Was he allowing us to develop hope in order to feel more despair?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了加深绝望，才故意制造出希望的是吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了加深絕望，才故意製造出希望的是嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00479",
		linknext = "0128_00481",
		line = 6314,
	},
	["0128_00481"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sore loser much? Maybe try walking the walk instead of just talking the talk!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“根本是在嘴硬。能说出那种话来还真是厉害呢——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「根本是在嘴硬。能說出那種話來還真是厲害呢——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00480",
		linknext = "0128_00482",
		line = 6326,
	},
	["0128_00482"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0201", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Give me Fumino, and I shall give you a pass for everything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“把文乃还给我。这样我就放过你们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「把文乃還給我。這樣我就放過你們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00481",
		linknext = "0128_00483",
		line = 6339,
	},
	["0128_00483"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The answer's still no, asshole. Besides, she serves no more purpose to you, so why are you so obsessed with her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我应该拒绝过了。你不是已经利用完文乃了吗？为什么还要坚持到这个地步？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我應該拒絕過了。你不是已經利用完文乃了嗎？為什麼還要堅持到這個地步？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00482",
		linknext = "0128_00484",
		line = 6351,
	},
	["0128_00484"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0202", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I have no interest in my granddaughter. But it is better she be with me, to serve as a lesson to the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“我对外孙女本身没有兴趣。只是，作为对岛的杀鸡儆猴，我需要她生活在我面前。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「我對外孫女本身沒有興趣。只是，作為對島的殺雞儆猴，我需要她生活在我面前。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00483",
		linknext = "0128_00485",
		line = 6364,
	},
	["0128_00485"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And you think I'm gonna hand her over to a hellhound like you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有谁会把重要的人交给恶魔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有誰會把重要的人交給惡魔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00484",
		linknext = "0128_00486",
		line = 6376,
	},
	["0128_00486"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0203", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“If you will not, I shall crush you and your companions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“那我就摧毁你，连同你的同伴们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「那我就摧毀你，連同你的同伴們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00485",
		linknext = "0128_00487",
		line = 6389,
	},
	["0128_00487"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Finally deciding to take real action, eh? Prove it, then. Come find me, and bring those troops you're so proud of with you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你想使用正当的手段，就拿着证据和你引以为豪的士兵一起来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你想使用正當的手段，就拿著證據和你引以為豪的士兵一起來吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00486",
		linknext = "0128_00488",
		line = 6401,
	},
	["0128_00488"] = {
		{"bgm", stop=1},
