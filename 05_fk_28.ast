			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No... This is from yet another order you gave me. It is every bit a precious memory.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不……这也是淳之介同学……给予文乃命令的、珍贵回忆之一……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不……這也是淳之介同學……給予文乃命令的、珍貴回憶之一……」",
