				},
			},
			en = {
				{
					"Of course, he also enjoys leering at Misaki and Nanase a lot. He's a shrewd old fart, that's for sure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且还会同时对美岬和奈奈濑性骚扰，真是个不能小看的老头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且還會同時對美岬和奈奈瀨性騷擾，真是個不能小看的老頭。",
					{"rt2"},
				},
