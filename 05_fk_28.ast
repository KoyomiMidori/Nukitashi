	["0128_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If this status quo continues, the end will be in sight for us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"继续这样战斗下去，总有一天会耗尽资源的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"繼續這樣戰鬥下去，總有一天會耗盡資源的——",
