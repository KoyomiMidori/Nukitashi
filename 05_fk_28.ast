	["0128_00460"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The old codger even shed tears once and said, “it feels like I finally got meself grandkids!” So he evidently enjoys doing this for us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"健藏老人对此也很高兴，他经常说“有孙子就是这样的感觉啊……！”并落下眼泪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"健藏老人對此也很高興，他經常說「有孫子就是這樣的感覺啊……！」並落下眼淚。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00459",
		linknext = "0128_00461",
		line = 6066,
	},
