		{"msgoff", time=1},
		{"extrans", sync=0, time=500, rule="eff_008_00000"},
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I lock the door and we head to school as per usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我锁好钥匙，像往常一样去学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我鎖好鑰匙，像往常一樣去學校。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00002",
		linknext = "0128_00004",
		line = 55,
	},
	["0128_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Most of the world would be taking summer vacations right now, but despite that, Seiran Island is thickly shrouded in silence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"世间即将开始休长假，本应该迎来盛夏的青蓝岛，今天仍然一片寂静。",
					{"rt2"},
				},
			},
			tw = {
				{
					"世間即將開始休長假，本應該迎來盛夏的青藍島，今天仍然一片寂靜。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00003",
		linknext = "0128_00005",
		line = 65,
	},
	["0128_00005"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1811", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The pigs are still hounding us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……今天也在监视我们呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……今天也在監視我們呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00004",
		linknext = "0128_00006",
		line = 79,
	},
	["0128_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't look at them. Just keep going.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“把视线转向别处。就这样往前走——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「把視線轉向別處。就這樣往前走——」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00005",
		linknext = "0128_00007",
		line = 91,
	},
	["0128_00007"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We pass the guards fixed outside our house and head along the normal route to school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"让呆在自己家附近监视的警备兵先走过去后，我们就这样走向正常的上学路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"讓待在自己家附近監視的警備兵先走過去後，我們就這樣走向正常的上學路。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00006",
		linknext = "0128_00008",
		line = 102,
	},
	["0128_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I got thoroughly interrogated as part of the pro-copulation still on the island for what happened the other day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"前几天的事件发生后，我作为留在岛上的“交尾势力”受到了严厉的盘问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"前幾天的事件發生後，我作為留在島上的「交尾勢力」受到了嚴厲的盤問。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00007",
		linknext = "0128_00009",
		line = 112,
	},
	["0128_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, as long as ECM was active, there remained no record of Tachibana Junnosuke on any footage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，只要启动了ECM，记录媒介就照不到橘淳之介的身影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，只要啟動了ECM，記錄媒介就照不到橘淳之介的身影。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00008",
		linknext = "0128_00010",
		line = 122,
	},
	["0128_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was eventually released, thanks to the old folks giving falsified testimony, and also due to lack of evidence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"由于健藏老人们的虚假证词，我以证据不足这个原因被释放。",
					{"rt2"},
				},
			},
			tw = {
				{
					"由於健藏老人們的虛假證詞，我以證據不足這個原因被釋放。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00009",
		linknext = "0128_00011",
		line = 132,
	},
	["0128_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, the guards kept a close watch on us, hoping to catch us red-handed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，警备兵们总是盯着我们，企图把我们作为现行犯逮捕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，警備兵們總是盯著我們，企圖把我們作為現行犯逮捕。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00010",
		linknext = "0128_00012",
		line = 142,
	},
	["0128_00012"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, under their watch, we've been perfectly well-behaved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但就算这样——我们也不可能默默地乖乖待着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但就算這樣——我們也不可能默默地乖乖待著。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00011",
		linknext = "0128_00013",
		line = 153,
	},
	["0128_00013"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"colortone", style="sepia"},
		{"bg", id=1, file="bg24_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, mode=3, x=600, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, mode=3, x=-600, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, mode=3, x=-200, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, mode=3, x=200, y=0},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_024_00000"},
		{"bgm", file="bgm11", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think back to the discussion we had with the old folks, or the 'Retiree Resistance', as they half-jokingly called themselves.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这让我想起了和健藏老人们——反叛组织“老人原力”的谈话内容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這讓我想起了和健藏老人們——反叛組織「老人原力」的談話內容。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00012",
		linknext = "0128_00014",
		line = 176,
	},
	["0128_00014"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0065", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“That bigshot politician Sakimori from the mainland's taken the initiative now. All them perverted facilities on the island are gettin' demolished.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“……现在本岛的主导权由自称防人的政治家老头掌握了，青蓝岛上的设施也正在被拆除。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「……現在本島的主導權由自稱防人的政治家老頭掌握了，青藍島上的設施也正在被拆除。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00013",
		linknext = "0128_00015",
		line = 189,
	},
	["0128_00015"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0066", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“From Lewd Land to Baby Me Creche, to the Grand Cock Shrine and even all them Ass Walls— S'all goin' down faster'n a Thai hooker.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“实际上，包括‘变态游乐园’在内的‘奶嘴幼儿园’、‘鸡巴大社’、‘尻壁体’等都已经被拆除了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「實際上，包括『變態遊樂園』在內的『奶嘴幼兒園』、『肉棒大社』、『尻壁體』等都已經被拆除了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00014",
		linknext = "0128_00016",
		line = 201,
	},
	["0128_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He spreads out a map.",
					{"rt2"},
				},
			},
			cn = {
				{
					"扩大地图。",
					{"rt2"},
				},
			},
			tw = {
				{
					"擴大地圖。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00015",
		linknext = "0128_00017",
		line = 211,
	},
	["0128_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are a number of X marks drawn on the map.",
					{"rt2"},
				},
			},
			cn = {
				{
					"×记号被画在了多个地点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"×記號被畫在了多個地點。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00016",
		linknext = "0128_00018",
		line = 221,
	},
	["0128_00018"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0067", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“An' with each one that goes down, every resistance force that keeps poppin' up dies just as quickly. Maybe 'cos o' hesitation, or despondence, or somethin' else.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“与此同时，以前经常出现的各种反叛组织……也不知道是踌躇不前，还是绝望了……似乎正在逐渐瓦解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「與此同時，以前經常出現的各種反叛組織……也不知道是躊躇不前，還是絕望了……似乎正在逐漸瓦解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00017",
		linknext = "0128_00019",
		line = 233,
	},
	["0128_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As each resistance is exposed to guerilla tactics, one by one they're eventually driven to ruin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果一个一个独立的反叛组织受到游击攻击的话，终究会疲惫不堪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果一個一個獨立的反叛組織受到游擊攻擊的話，終究會疲憊不堪。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00018",
		linknext = "0128_00020",
		line = 243,
	},
	["0128_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once even the ostentatious facilities are being torn down, the citizens will naturally lose morale. So they just stop caring.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们故意从豪华设施开始破坏，以此降低居民们的战意，让他们自行毁灭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們故意從豪華設施開始破壞，以此降低居民們的戰意，讓他們自行毀滅。",
					{"rt2"},
				},
