			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Good morning, Nanase! Looking good again today!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“早上好，奈奈濑同学……！你今天也很美。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「早安，奈奈瀨同學……！你今天也很美。」",
