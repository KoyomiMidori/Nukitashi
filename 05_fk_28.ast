		linknext = "0128_00106",
		line = 1351,
	},
	["0128_00106"] = {
		{"se", id=0, loop=0, file="se_a141", vol=50},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But they're all just weird photos of you. Even the group photo has you doing a double peace sign...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但对你本人来说都是些奇怪的照片对吧。连集体照都是双剪刀手……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但對你本人來說都是些奇怪的照片對吧。連集體照都是雙剪刀手……」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00105",
		linknext = "0128_00107",
		line = 1364,
	},
	["0128_00107"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, this is hardly worthy of being fond memories.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……抱歉，没有能作为回忆留下的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……抱歉，沒有能作為回憶留下的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00106",
		linknext = "0128_00108",
		line = 1376,
	},
	["0128_00108"] = {
