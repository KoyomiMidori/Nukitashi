	["0128_00494"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0206", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“The weak point of your organization is not you, nor that scout girl. It is your sister, who provides all your information.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“你的组织的中枢，不是你这小鬼，也不是那个侦察的姑娘，而是掌控所有情报的你的妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「你的組織的中樞，不是你這小鬼，也不是那個偵察的姑娘，而是掌控所有情報的你的妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00493",
		linknext = "0128_00495",
		line = 6489,
	},
	["0128_00495"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0207", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“If I destroy that girl, responsible as she is for everything from your escape routes to searching for enemies... that will leave your organization completely powerless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“只要摧毁那个掌握了从逃跑到索敌的一切事物的女孩……你的组织，就会完全失去战斗能力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「只要摧毀那個掌握了從逃跑到索敵的一切事物的女孩……你的組織，就會完全失去戰鬥能力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00494",
		linknext = "0128_00496",
		line = 6501,
	},
	["0128_00496"] = {
