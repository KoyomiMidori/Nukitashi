			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I can do whatever you desire... whether it be a smile... or a double peace sign... or anything else.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不管是笑容……还是双剪刀手……只要是您希望的……文乃什么都会做……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不管是笑容……還是雙剪刀手……只要是您希望的……文乃什麼都會做……」",
					{"rt2"},
				},
			},
		},
