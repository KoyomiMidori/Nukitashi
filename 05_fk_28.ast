	},
	["0128_00411"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I will become strong.",
					{"rt2"},
				},
			},
			cn = {
				{
					"获得强大的力量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"獲得強大的力量。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00410",
		linknext = "0128_00412",
		line = 5282,
	},
	["0128_00412"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter what it takes, I know what I need. And I'll do whatever I must to get it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此所必要的任何事，我都能克服。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此所必要的任何事，我都能克服。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00411",
		linknext = "0128_00413",
		line = 5292,
	},
	["0128_00413"] = {
		{"bgm", stop=1},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00115", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2700] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=2700, time=300, mode=3, x=0, y=0},
				{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine", delay2=2700},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0369", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“If ya cash in yer chips, I'll at least make sure yer bones are in order. Right... here it comes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“要是你死了，我会帮你捡骨头的。那么……来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「要是你死了，我會幫你撿骨頭的。那麼……來吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00412",
		linknext = "0128_00414",
		line = 5310,
	},
	["0128_00414"] = {
		{"fg", mode=-1, id=8, ch="手嶋", lv=5, time=500},
		{"bg", id=18, file="pm301-1", x=-5, y=-5, path=":cg/pm3/", lv=5, ev=1, time=1, bx=800, by=450},
		{"se", id=0, loop=0, file="se_b076"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The cold steel needle pierces my vein.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冰冷的注射器，进入血管。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冰冷的注射器，進入血管。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00413",
		linknext = "0128_00415",
		line = 5324,
	},
	["0128_00415"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel something spreading out from my arm.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像有什么东西从胳膊上扩散开来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像有什麼東西從手臂上擴散開來。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00414",
		linknext = "0128_00416",
