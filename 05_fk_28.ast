			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Was giving Fumino to me not your original plan? If you will not return her... then I shall have your sister in her stead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“这不是你原本用的战术吗？如果不把文乃交给我——那我就收下你妹妹了。”",
