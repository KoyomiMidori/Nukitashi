	["0128_00629"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0167", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "警備兵C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guard C"},
					"“Guard squad leaders are permitted to have handguns whose firepower is as good as the real deal! We need those to deal with brainwashed deviants like you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "警备兵C"},
					"“警备队长等级可是被允许持有接近实枪威力的手枪……！要面对像你们这种被洗脑的疯子变态，这是理所当然的吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "警備兵C"},
					"「警備隊長等級可是被允許持有接近實槍威力的手槍……！要面對像你們這種被洗腦的瘋子變態，這是理所當然的吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00628",
		linknext = "0128_00630",
		line = 8695,
	},
	["0128_00630"] = {
		{"se", id=0, loop=0, file="se_a018"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
