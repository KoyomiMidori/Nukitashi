		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, they're frantically trying to escape too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是他们也在拼命逃跑。",
					{"rt2"},
