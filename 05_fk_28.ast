				},
			},
		},
		linkback = "0128_00030",
		linknext = "0128_00032",
		line = 423,
	},
	["0128_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And right now, our biggest issue has become a shortage of TAEs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"成为重大问题的是——T-A-E。",
					{"rt2"},
				},
			},
			tw = {
				{
					"成為重大問題的是——T-A-E。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00031",
		linknext = "0128_00033",
		line = 433,
	},
	["0128_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We can no longer use the underground secret base.",
					{"rt2"},
				},
			},
			cn = {
				{
					"地下秘密基地已经不能使用了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"地下秘密基地已經不能使用了。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00032",
		linknext = "0128_00034",
		line = 443,
	},
	["0128_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were using the cutting-edge 3D printer there to make our best ones. It was our lifeline.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基地里的新型3D打印机，是我们制作T-A-E的生命线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"基地裡的新型3D列印機，是我們製作T-A-E的生命線。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00033",
		linknext = "0128_00035",
		line = 453,
	},
	["0128_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, I can make blueprints and simple designs at home, but most of them needed the printer in the base to be effective.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然设计图和简单的东西在家也能做，但其他部份几乎都是在地下基地做出来的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然設計圖和簡單的東西在家也能做，但其他部份幾乎都是在地下基地做出來的。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00034",
		linknext = "0128_00036",
		line = 463,
	},
	["0128_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All I can make at home are the sticky condoms for climbing, and the Eggs for depositing into capsule machines in town.",
					{"rt2"},
				},
			},
			cn = {
				{
					"黏着式安全套用完了，“Egg”也只剩下胶囊玩具机里面的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"黏著式保險套用完了，「Egg」也只剩下膠囊玩具機裡面的。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00035",
		linknext = "0128_00037",
		line = 473,
	},
	["0128_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not only that, but my hardening anal vibrator, the Penetrator, is starting to show cracks from lack of maintenance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"硬化式肛门按摩棒“贯穿丸”也因整备不良而有裂痕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"硬化式肛門按摩棒「貫穿丸」也因整備不良而有裂痕。",
					{"rt2"},
