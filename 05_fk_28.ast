	["0128_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Was it my imagination that she was emotionless for a moment?",
					{"rt2"},
				},
			},
