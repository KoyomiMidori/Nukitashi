	["0128_00582"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As this is a large vehicle without a small turning circle, they're taking numerous side streets with tight corners.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们急转弯开进各种小巷，想借此甩掉我们这边的笨重大型车。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們急轉彎開進各種小巷，想藉此甩掉我們這邊的笨重大型車。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00581",
		linknext = "0128_00583",
		line = 7975,
	},
	["0128_00583"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they meet up with their main force, we may never see Asane again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果让他们就这样和本队汇合的话，麻沙音就再也回不来了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果讓他們就這樣和本隊會合的話，麻沙音就再也回不來了——",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00582",
		linknext = "0128_00584",
		line = 7985,
	},
	["0128_00584"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But they still haven't been on this island that long! Misaki, entice them towards the hillside!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过他们来岛的时间还短——美岬，把他们引到山之手去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過他們來島的時間還短——美岬，把他們引到山之手去！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00583",
		linknext = "0128_00585",
		line = 7997,
	},
	["0128_00585"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgact", file="cgact", id=1, act="stopact"},
		{"evset", file="mci_m", set="mci_m", path=":ev/mci_m/"},
		{"evset", file="mci_m-103", set="mci_m-103", path=":ev/mci_m-103/"},
		{"bg", id=16, file="mci_m-103", x=-5, y=-5, path=":cg/mci_m/", lv=5, ev=1, bx=800, by=450},
		{"bg", id=1, file="bg22_2l_00000", x=0, y=0, path=":bg/", sync=0, style="blur", blurx=45, blury=1, ax=1280, ay=730, bx=-480, by=-280},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_009_00000"},
		{"text"},
		delay = {
			[1000] = {
				{"se", id=0, loop=0, file="se_b065", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2132", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Roger! Oh my!? If they head that way and are charged from the side they'd be doing the hard luck dance and made into mincemeat!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“了解……！喂喂喂——！你们要是往那边去的话，我就从旁边撞过去让你们遭遇不幸成为肉饼哦！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「了解……！喂喂喂——！你們要是往那邊去的話，我就從旁邊撞過去讓你們遭遇不幸成為肉餅哦！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00584",
		linknext = "0128_00586",
		line = 8019,
	},
	["0128_00586"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thanks to diversions and feints, the van loses its escape route and we're gradually gaining on them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"受牵制和假动作的影响，箱型车失去了退路，渐渐被我们逼得走投无路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"受牽制和假動作的影響，箱型車失去了退路，漸漸被我們逼得走投無路。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00585",
		linknext = "0128_00587",
		line = 8030,
	},
	["0128_00587"] = {
