	["0128_00062"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've recently made it part of my routine to come here and visit Fumino after school, to kill time before my training.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最近放学后，我都会来到文乃身边，并和文乃一起进行修行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最近放學後，我都會來到文乃身邊，並和文乃一起進行修行。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00061",
		linknext = "0128_00063",
		line = 816,
	},
	["0128_00063"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did you do today?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天做了什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天做了什麼？」",
					{"rt2"},
				},
