	["0128_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Come to think of it, she did say she was a short sleeper.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来……我本来还以为文乃是个短眠者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來……我本來還以為文乃是個短眠者。",
