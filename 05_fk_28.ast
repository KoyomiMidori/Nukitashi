					name = {"淳之介", "Junnosuke"},
					"“Don't you DARE touch her, you fucking cowardly piece of shit!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“住手，太卑鄙了——！！”",
