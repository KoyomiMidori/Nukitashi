		line = 7729,
	},
	["0128_00569"] = {
		{"se", id=1, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00125", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", mwframe="mwframe", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2334", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Are you okay, Jun!? We got message from Fumino that Asa was taken away, and we brought an OSS vehicle!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没事吧，淳！？文乃联系我说麻沙酱被绑架了，所以我带了一辆SHO的车来——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒事吧，淳！？文乃聯繫我說麻沙醬被綁架了，所以我帶了一輛SHO的車來——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00568",
		linknext = "0128_00570",
		line = 7745,
	},
	["0128_00570"] = {
		{"se", id=0, loop=0, file="se_a005"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They got out through the back door! Get after them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他们刚才开车从后门逃出去了！！追上去吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他們剛才開車從後門逃出去了！！追上去吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00569",
		linknext = "0128_00571",
		line = 7758,
