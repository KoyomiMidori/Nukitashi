					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm gonna fight them head on! You stay back here and cover me! Turn the house into Swiss cheese if you have to, I don't care!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我直接去击倒他们！你从这里进行掩护射击！就算把房子弄得乱七八糟也没关系——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我直接去擊倒他們！你從這裡進行掩護射擊！就算把房子弄得亂七八糟也沒關係——！」",
					{"rt2"},
				},
			},
		},
