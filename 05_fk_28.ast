					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“What's this...? Ah, photos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这是……啊……照片吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這是……啊……照片嗎……？」",
					{"rt2"},
				},
