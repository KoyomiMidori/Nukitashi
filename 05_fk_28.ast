	["0128_00573"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They're driving a van, and they just went down that road! Get on their asses!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“绑架麻沙音的人开车逃走了！——就是刚刚从那条路出来的车子，快追上去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「綁架麻沙音的人開車逃走了！——就是剛剛從那條路出來的車子，快追上去！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00572",
		linknext = "0128_00574",
		line = 7814,
	},
	["0128_00574"] = {
