		linkback = "0128_00079",
		linknext = "0128_00081",
		line = 1030,
	},
	["0128_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Asa developed the rest of them for me, but she did complain there were too many.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对对对。麻沙酱把剩下的都冲洗出来了。虽然被抱怨说太多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對對對。麻沙醬把剩下的都沖洗出來了。雖然被抱怨說太多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00080",
		linknext = "0128_00082",
		line = 1042,
	},
	["0128_00082"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=500},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg13_1l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I spread the bundle of pictures out, and we reminisce.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我打开一叠照片，两个人沉浸在回忆里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我打開一疊照片，兩個人沉浸在回憶裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00081",
		linknext = "0128_00083",
		line = 1058,
	},
	["0128_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look at these. They're all photos of you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看，这个胶卷都只有文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看，這個膠卷都只有文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00082",
		linknext = "0128_00084",
		line = 1070,
	},
	["0128_00084"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00101", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1264", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“You're right. I was knitting... When did you take them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“真的呢……是织东西的时候……什么时候拍的呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「真的呢……是織東西的時候……什麼時候拍的呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00083",
		linknext = "0128_00085",
		line = 1084,
	},
	["0128_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I took them while you were concentrating. Your concentration was so intense you didn't notice at all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在你集中精神的时候。你的注意力太集中了，完全没注意到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在你集中精神的時候。你的注意力太集中了，完全沒注意到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00084",
		linknext = "0128_00086",
		line = 1096,
	},
	["0128_00086"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00111", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
