	["0128_00031"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=700},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Without funding, we can't take action as a team.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果没有资金，队伍就无法进行活动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果沒有資金，隊伍就無法進行活動。",
