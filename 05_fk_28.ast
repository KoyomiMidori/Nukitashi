			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm ready to be useful to you... whenever you need me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文乃……已经准备好了，无论什么时候，都能帮上你的忙……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「文乃……已經準備好了，無論什麼時候，都能幫上你的忙……」",
