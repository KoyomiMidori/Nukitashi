		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase fires her nipple rotor-shaped taser and Hinami fights with her folding chair and defeat the men.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑的乳头跳蛋型电击枪，和雏见的钢管椅发挥了很大的作用，男人们被打倒了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨的乳頭跳蛋型電擊槍，和雛見的鋼管椅發揮了很大的作用，男人們被打倒了。",
					{"rt2"},
				},
			},
		},
