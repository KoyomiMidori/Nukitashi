			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think you're the brainwashed one. Society's pressuring you to conform to what it wants. That's all it is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被洗脑的应该是你吧。说白了你只是被社会上的同调压力操控了——”",
