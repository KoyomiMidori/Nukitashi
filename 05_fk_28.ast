		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2329", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So what do you plan to do, Jun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“——所以淳，这种状况下你打算怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「——所以淳，這種狀況下你打算怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00038",
		linknext = "0128_00040",
		line = 508,
	},
	["0128_00040"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1813", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, Bro. We've pretty much already achieved our main objective.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是啊，哥哥……我们的目的其实已经达成了吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是啊，哥哥……我們的目的其實已經達成了吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00039",
		linknext = "0128_00041",
		line = 522,
	},
	["0128_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our objective was to crush the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的目的，也就是变态条例的崩溃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的目的，也就是變態條例的崩潰。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00040",
		linknext = "0128_00042",
		line = 532,
	},
	["0128_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We realized that objective long ago.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个目标，我们早就达成了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個目標，我們早就達成了。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00041",
		linknext = "0128_00043",
		line = 542,
	},
	["0128_00043"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2330", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Then, wouldn't the next step be to take Fumino with you and escape the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那么……就这样带着文乃逃出岛，不也是一个手段吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那麼……就這樣帶著文乃逃出島，不也是一個手段嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00042",
		linknext = "0128_00044",
		line = 556,
	},
	["0128_00044"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1814", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The only way off the island is through the sea gate. Judging from our last battle, the two of you could probably get out on your own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然要出岛必须经过海门……但把这当成最后的决战……我想如果只有哥哥和文乃，应该是可以逃出去的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然要出島必須經過海門……但把這當成最後的決戰……我想如果只有哥哥和文乃，應該是可以逃出去的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00043",
		linknext = "0128_00045",
		line = 568,
	},
	["0128_00045"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2331", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Considering our capabilities, it's the most realistic option. Better that than a war of attrition. I'm sure Kenzou and the others know that too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“站在考量作战的立场，这是最实际的。至少比消耗战实际……我想健藏先生们一定也能明白……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「站在考量作戰的立場，這是最實際的。至少比消耗戰實際……我想健藏先生們一定也能明白……」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00044",
		linknext = "0128_00046",
		line = 582,
	},
	["0128_00046"] = {
