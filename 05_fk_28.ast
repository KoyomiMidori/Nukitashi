				},
			},
			en = {
				{
					"I nod.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我點了點頭。",
					{"rt2"},
