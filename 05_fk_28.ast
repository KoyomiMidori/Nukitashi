	["0128_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps she's the sort of person that can sleep anytime, anywhere?",
					{"rt2"},
				},
			},
			cn = {
				{
					"难不成她是无论何时何地都能睡好的类型？",
					{"rt2"},
				},
			},
			tw = {
				{
					"難不成她是無論何時何地都能睡好的類型？",
					{"rt2"},
				},
