		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_024_00000"},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg11_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Teshima told me that I haven't fully adapted to it yet, so manifestation would be difficult.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为身体的神经还没有完全习惯，所以很难发挥力量——手嶋先生是这么说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為身體的神經還沒有完全習慣，所以很難發揮力量——手嶋先生是這麼說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00453",
