		text = {
			vo = {
				{"vo", file="teshima0358", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Ever heard o' limb lengthening surgery? It's supposed t' help make ya taller, but the pain's so intense that ya may as well ask t'have yer limbs cut off instead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“有种叫骨延长的手术。虽然是拉高身高的手术，但其剧痛程度，甚至会有人希望把自己的胳膊切下来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「有種叫骨延長的手術。雖然是拉高身高的手術，但其劇痛程度，甚至會有人希望把自己的手臂切下來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00396",
		linknext = "0128_00398",
		line = 5107,
	},
	["0128_00398"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00124", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0359", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“I used to be a manlet. Had it done to both me legs. But the pain from that don't even compare to this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我以前个子很矮，有在双腿上动过手术——但是，在疼痛程度上，根本无法与这个做比较。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我以前個子很矮，有在雙腿上動過手術——但是，在疼痛程度上，根本無法與這個做比較。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00397",
		linknext = "0128_00399",
		line = 5121,
	},
	["0128_00399"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He looks upon the syringe with intense revulsion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋先生将视线投向注射器，好像看到了什么让人不快的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋先生將視線投向注射器，好像看到了什麼讓人不快的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00398",
		linknext = "0128_00400",
		line = 5131,
	},
	["0128_00400"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0360", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“When it comes to this shit, strength of will is key. If ya know what ya want, the effect gets magnified.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“使用这种药物，重要的是精神力。根据自己的想法，效果会有很大的变化。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「使用這種藥物，重要的是精神力。根據自己的想法，效果會有很大的變化。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00399",
		linknext = "0128_00401",
		line = 5145,
	},
	["0128_00401"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0361", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Y'know how they say that the results of yer training can improve according t' whether or not ya can visualize yer future self? Same idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“训练也会根据有没有对未来进行设想，而让结果产生很大的变化，这种说法你也有听说过吧？和那个是一样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「訓練也會根據有沒有對未來進行設想，而讓結果產生很大的變化，這種說法你也有聽說過吧？和那個是一樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00400",
		linknext = "0128_00402",
		line = 5157,
	},
	["0128_00402"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0362", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Yer body's gotta be strong an' tenacious. So ya gotta imagine somethin' strong an' tenacious in yer mind's eye.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你需要强靱的肉体。为此，你必须想象某种强韧的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你需要強靱的肉體。為此，你必須想像某種強韌的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00401",
		linknext = "0128_00403",
		line = 5169,
	},
	["0128_00403"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00123", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0363", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“It's why ya already got a junk o' steel. You've been imagining somethin' much stronger while you've been trainin' it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“所以一直以来，我才会让你通过锻炼已经拥有的钢铁鸡巴，来让你得到更加强大的想像能力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「所以一直以來，我才會讓你通過鍛煉已經擁有的鋼鐵肉棒，來讓你得到更加強大的想像能力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00402",
		linknext = "0128_00404",
		line = 5183,
	},
	["0128_00404"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0364", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“But in order t' get the strength of will ya need, ya gotta come ta terms wit' yer weaknesses.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“但是，为了那样的强大精神力——你必须先完全接受自己的弱点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「但是，為了那樣的強大精神力——你必須先完全接受自己的弱點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00403",
		linknext = "0128_00405",
		line = 5197,
	},
	["0128_00405"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0365", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Any deep-seated complexes or emotional traumas are gonna hinder the medicine from doin' its job.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“强烈的自卑感、严重的心理阴影，这些东西对这个药来说只会碍事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「強烈的自卑感、嚴重的心理陰影，這些東西對這個藥來說只會礙事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00404",
		linknext = "0128_00406",
		line = 5209,
	},
	["0128_00406"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0366", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Fer me, I hadda come t' terms wit' me tiny-ass phimosis dick. An' now I got a junk to control any broad I wanna control with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“我的情况是需要面对自己的短小包茎……所以，才会得到这个能让所有女人服从的鸡巴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「我的情況是需要面對自己的短小包莖……所以，才會得到這個能讓所有女人服從的肉棒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00405",
		linknext = "0128_00407",
		line = 5221,
	},
	["0128_00407"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00123", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0367", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“But starin' yer own weaknesses in the face ain't gonna be no disco dance. The stronger they are, the tougher it'll be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“但是，面对自己的自卑感，不是那么简单的事情。自卑感越强，难度就越高——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「但是，面對自己的自卑感，不是那麼簡單的事情。自卑感越強，難度就越高——」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00406",
		linknext = "0128_00408",
		line = 5235,
	},
	["0128_00408"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He remains silent for a while and then puts on a serious expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋先生沉默之后，露出认真的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋先生沉默之後，露出認真的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00407",
		linknext = "0128_00409",
		line = 5245,
	},
	["0128_00409"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0368", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You ready fer this, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“——橘，你有觉悟吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「——橘，你有覺悟嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00408",
		linknext = "0128_00410",
		line = 5260,
	},
	["0128_00410"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
