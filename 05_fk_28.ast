				{"vo", file="fumino1262", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Not at all. Nothing could make me happier... than the fact that you come to visit me like this all the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“怎么会……淳之介同学总是会来看我……对文乃来说，这已经无比幸福了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「怎麼會……淳之介同學總是會來看我……對文乃來說，這已經無比幸福了……」",
					{"rt2"},
				},
			},
