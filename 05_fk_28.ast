		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's reassuring that you can have a restful sleep in this place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
