		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino trots over from the shadow of the rocks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃从岩石的影子里啪嗒啪嗒地走过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃從岩石的影子裡啪嗒啪嗒地走過來。",
					{"rt2"},
