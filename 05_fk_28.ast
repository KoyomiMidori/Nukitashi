			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Hahaha... As you wish. I expect they will be arriving right about now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“哈哈哈，可以……现在应该正好到了吧。”",
					{"rt2"},
				},
			},
			tw = {
