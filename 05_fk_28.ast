	["0128_00459"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since the settlement is about as far as it would be safe for Fumino to come out, we've all been gathering together for dinner.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃可以行走的范围以村落为界限，所以晚饭时大家会聚在一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃可以行走的範圍以村落為界限，所以晚飯時大家會聚在一起。",
					{"rt2"},
				},
