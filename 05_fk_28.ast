				{"vo", file="misaki2133", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But the roads from here on are too narrow for the Magical Mirror to traverse! They're going to get away! What do we do!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“可是从这里开始就是魔镜号很难开进去的小胡同！会被甩掉的！怎么办——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「可是從這裡開始就是魔鏡號很難開進去的小胡同！會被甩掉的！怎麼辦——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00587",
		linknext = "0128_00589",
		line = 8064,
	},
	["0128_00589"] = {
