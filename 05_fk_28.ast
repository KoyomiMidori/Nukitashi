					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm terribly sorry... I'm not aware of anything when I'm concentrating.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“非常抱歉……只要集中精神，我就只看得到眼前的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「非常抱歉……只要集中精神，我就只看得到眼前的事情……」",
