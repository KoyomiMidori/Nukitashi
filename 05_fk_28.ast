		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0355", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“This 'ere is medicine fer physical transformation. This ain't yer typical cheap-ass steroid shit, either. Ya can't get it outside of the black market. Honest-to-fuck illegal drug, right here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“……这是改造身体的药。可不是什么兴奋剂小玩意。是只在地下流通的真正非法药物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「……這是改造身體的藥。可不是什麼興奮劑小玩意。是只在地下流通的真正非法藥物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00391",
		linknext = "0128_00393",
		line = 5044,
	},
	["0128_00393"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0356", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“It's some kinda accidental byproduct from Nazi experimentation or some shit. They was doin' research ta create th' ultimate soldiers or somethin'. I dunno the details, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“这是在纳粹的奥斯维辛实验中偶然制造出来的产物。好像是为了量产强悍士兵而研究的，我也不太了解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「這是在納粹的奧斯維辛實驗中偶然製造出來的產物。好像是為了量產強悍士兵而研究的，我也不太了解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00392",
		linknext = "0128_00394",
		line = 5056,
	},
