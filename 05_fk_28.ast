	["0128_00635"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=500},
		{"bg", id=1, file="bg27_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0169", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "警備兵C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guard C"},
					"“Hahaha, so you wanna beat my face in!? I'd love to see you try, asshole!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "警备兵C"},
					"“哈哈哈哈哈，说要揍死我！？那你试试啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "警備兵C"},
					"「哈哈哈哈哈，說要揍死我！？那你試試啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00634",
		linknext = "0128_00636",
		line = 8782,
	},
	["0128_00636"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0170", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "警備兵C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guard C"},
					"“I'm not like you! I volunteered because I wanted to save the world, to save the people! I did it to keep fuckers like you from getting to the mainland!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "警备兵C"},
					"“我与你们不同！我是为了社会，为了民众才志愿加入的！就为了让你们这种人进不了本岛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "警備兵C"},
					"「我與你們不同！我是為了社會，為了民眾才志願加入的！就為了讓你們這種人進不了本島！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00635",
		linknext = "0128_00637",
		line = 8794,
	},
	["0128_00637"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0171", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "警備兵C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Guard C"},
					"“If I die in the name of justice, so be it! Even if I have to meet my end at the hands of a subhuman, kid-whoring degenerate fuck like you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "警备兵C"},
					"“如果是为了正义，要我死也没关系！比起被你们这种用小孩子做生意的禽兽变态打倒要好！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "警備兵C"},
					"「如果是為了正義，要我死也沒關係！比起被你們這種用小孩子做生意的禽獸變態打倒要好！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00636",
		linknext = "0128_00638",
		line = 8806,
	},
	["0128_00638"] = {
