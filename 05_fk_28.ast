	["0128_00491"] = {
		{"bgm", file="bgm13", vol=100},
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait! What the fuck does my sister have to do with this!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……等等，这跟我妹妹没关系吧！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……等等，這跟我妹妹沒關係吧！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00490",
		linknext = "0128_00492",
		line = 6451,
	},
	["0128_00492"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00110", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0205", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Pull your head out of your ass. That sister of yours is a resistance member, is she not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“说什么梦话。你妹妹也是反叛组织的一员吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「說什麼夢話。你妹妹也是反叛組織的一員吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0128_00491",
		linknext = "0128_00493",
		line = 6464,
	},
	["0128_00493"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
