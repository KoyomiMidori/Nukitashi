		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The illegal sex industry has been dealt with, and scandals have sprung up everywhere, but time doesn't stand still.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使地下风俗被摧毁、社会被丑闻笼罩，时间也自然而然地流逝着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使地下風俗被摧毀、社會被醜聞籠罩，時間也自然而然地流逝著。",
					{"rt2"},
				},
			},
		},
		linknext = "0074_00002",
		line = 19,
	},
	["0074_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, the illegal sex industry incident made for big news on Seiran Island as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，地下风俗的事件在青蓝岛也引起了很大的关注。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，地下風俗的事件在青藍島也引起了很大的關注。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00001",
		linknext = "0074_00003",
		line = 29,
	},
	["0074_00003"] = {
		{"se", id=0, loop=1, file="se_d011", vol=50},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this doesn't affect daily life for most people, and the island is filled with the echoes of moans again today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但岛上的日常生活依然没有发生变化，今天也充满了娇声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但島上的日常生活依然沒有發生變化，今天也充滿了嬌喘。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00002",
