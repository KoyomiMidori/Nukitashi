		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As much as she likes to make jokes about threesomes, she really does like girls.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然总是半开玩笑地说着3P3P，但麻沙酱是真的喜欢女孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然總是半開玩笑地說著3P3P，但麻沙醬是真的喜歡女孩子。",
					{"rt2"},
