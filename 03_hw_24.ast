	["0074_00038"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0065", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Knowing you were on your way to school and that you avoid copulation, you make yourself easy to find. Can we have a word, just the two of us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“只要知道你正一边逃避性行为一边上学，要找你就不怎么困难——要不要跟我谈谈，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「只要知道你正一邊逃避性行為一邊上學，要找你就不怎麼困難——要不要跟我談談，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00037",
		linknext = "0074_00039",
		line = 482,
	},
	["0074_00039"] = {
