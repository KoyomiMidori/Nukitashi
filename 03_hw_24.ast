			cn = {
				{
					"或许也会有其他人，正默默地对性行为感到抗拒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許也會有其他人，正默默地對性行為感到抗拒。",
					{"rt2"},
				},
