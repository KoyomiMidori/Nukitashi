		linkback = "0074_00072",
		linknext = "0074_00074",
		line = 929,
	},
	["0074_00074"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Control the entire nation with my cock? Bullshit. That's the kind of delusional idea a 14-year-old would cook up. How could you even believe I can do that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是说要拿鸡巴来统治国家？太可笑了，那只不过是初中男生的妄想。即使能实现——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是說要拿肉棒來統治國家？太可笑了，那隻不過是初中男生的妄想。即使能實現——」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00073",
		linknext = "0074_00075",
		line = 941,
	},
	["0074_00075"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0079", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I know you can. Why is this country currently in the midst of chaos? Because government officials have given in to their carnal desires, and thrown themselves in with the illegal sex industry. Am I mistaken?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“能实现的。现在这个国家闹得沸沸扬扬的是什么？是屈服于下半身的欲望，染指地下风俗的官员们……对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「能實現的。現在這個國家鬧得沸沸揚揚的是什麼？是屈服於下半身的慾望，染指地下風俗的官員們……對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00074",
		linknext = "0074_00076",
		line = 953,
	},
	["0074_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00075",
		linknext = "0074_00077",
		line = 965,
	},
	["0074_00077"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0080", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Even those who control the nation are powerless in the face of their lust. If you were to turn that around, you could control the nation through lust. An ideal natural order.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“即便是掌控国家的家伙，也敌不过肉欲。反过来说，只要利用肉欲就能掌控国家——这非常合情合理吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「即便是掌控國家的傢伙，也敵不過肉慾。反過來說，只要利用肉慾就能掌控國家——這非常合情合理吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00076",
		linknext = "0074_00078",
		line = 977,
	},
	["0074_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's delusional.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是谬论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是謬論。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00077",
		linknext = "0074_00079",
		line = 987,
	},
	["0074_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But in his eyes, he sees his little delusion as destined to play out in reality.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，这个男人的眼睛——这眼神——已经看到了实现的未来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，這個男人的眼睛——這眼神——已經看到了實現的未來。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00078",
		linknext = "0074_00080",
		line = 997,
	},
	["0074_00080"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0081", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I want you to assist me in fulfilling this great ambition of mine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“为了实现这个大愿——希望你能帮助我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「為了實現這個大願——希望你能幫助我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00079",
		linknext = "0074_00081",
		line = 1009,
	},
	["0074_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you insane? You'd tell this to someone you know is an anti-copulator?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你是认真的吗？明知道我是反交尾势力，还说出那种话来？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你是認真的嗎？明知道我是反交尾勢力，還說出那種話來？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00080",
		linknext = "0074_00082",
		line = 1021,
	},
	["0074_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you think you're in any position to negotiate just because you helped bring down the illegal sex industry, you're wasting your time. I've already saved you once. I don't owe you a damn thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你想用之前协助我摧毁地下风俗的事来交涉也没用。我以前也帮助过你，这样应该就两不相欠了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你想用之前協助我摧毀地下風俗的事來交涉也沒用。我以前也幫助過你，這樣應該就兩不相欠了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00081",
		linknext = "0074_00083",
		line = 1032,
	},
	["0074_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've always been fighting for one cause—for Asa-chan, Hinami, Nanase, Hotori, and myself to be able to live in peace without sex involved.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我一直是为了让大家可以不被强迫做爱而战斗，为了麻沙音、雏见、奈奈濑、畔，还有我自己。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我一直是為了讓大家可以不被強迫做愛而戰鬥，為了麻沙音、雛見、奈奈瀨、畔，還有我自己。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00082",
		linknext = "0074_00084",
		line = 1043,
	},
	["0074_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And now you have the audacity to come to me for help?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你以为这样的我，现在怎么可能帮你干那种——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你以為這樣的我，現在怎麼可能幫你幹那種——」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00083",
		linknext = "0074_00085",
		line = 1054,
	},
	["0074_00085"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0082", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I have ways of dealing with that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我可以斟酌处理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我可以斟酌處理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00084",
		linknext = "0074_00086",
		line = 1068,
	},
	["0074_00086"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00085",
		linknext = "0074_00087",
		line = 1080,
	},
	["0074_00087"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0083", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I greatly admire people who don't yield to the situation they're placed in, and seek to live life according to their ideals.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我爱那些不把所处环境当作理所当然，以理性选择自己生活方式的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我愛那些不把所處環境當作理所當然，以理性選擇自己生活方式的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00086",
		linknext = "0074_00088",
		line = 1092,
	},
	["0074_00088"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0084", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If you disapprove of your sister and that cute girlfriend of yours being exposed to depraved sex, then I can provide you special protection from it. I have that power.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果你拒绝让妹妹或那位可爱的女朋友置身于无秩序的性爱之中——我可以使用特例保护她们。我有这样的力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果你拒絕讓妹妹或那位可愛的女朋友置身於無秩序的性愛之中——我可以使用特例保護她們。我有這樣的力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00087",
		linknext = "0074_00089",
		line = 1104,
	},
	["0074_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He says he'll protect Asa-chan, Hinami, and all my companions from the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙音和雏见——可以保护同伴们不受变态条例的侵害。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙音和雛見——可以保護同伴們不受變態條例的侵害。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00088",
		linknext = "0074_00090",
		line = 1114,
	},
	["0074_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He says we can reject sex without love.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他说我们可以拒绝没有爱的性爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他說我們可以拒絕沒有愛的性愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00089",
		linknext = "0074_00091",
		line = 1124,
	},
	["0074_00091"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0085", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So why not create a nation with me, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“所以——和我一起建立国家吧，少年！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「所以——和我一起建立國家吧，少年！」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00090",
		linknext = "0074_00092",
		line = 1138,
	},
	["0074_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What exactly is this nation he envisions, anyway?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那到底是——仁浦先生所说的国家到底是什么样的呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那到底是——仁浦先生所說的國家到底是什麼樣的呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00091",
		linknext = "0074_00093",
		line = 1148,
	},
	["0074_00093"] = {
		{"se", id=0, loop=1, file="se_d011", vol=30},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear moaning from somewhere in the distance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知从哪里传来了呻吟的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知從哪裡傳來了呻吟的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00092",
		linknext = "0074_00094",
		line = 1159,
	},
	["0074_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since I returned to this island, I've seen it through varying lenses.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回到青蓝岛以后，我盯着这个岛看了很久。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回到青藍島以後，我盯著這個島看了很久。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00093",
		linknext = "0074_00095",
		line = 1169,
	},
	["0074_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As an individual person, as an Anti-Copulation Front member, and as an SS member.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有时作为一个岛上的人，有时作为反交尾势力——有时作为SS的一员。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有時作為一個島上的人，有時作為反交尾勢力——有時作為SS的一員。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00094",
		linknext = "0074_00096",
		line = 1179,
	},
	["0074_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The islanders all seem to be happy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上的人们看似每天都很幸福。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上的人們看似每天都很幸福。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00095",
		linknext = "0074_00097",
		line = 1189,
	},
	["0074_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure there are those who have had no choice but to conform. But the majority of them are grateful for their lot in life, and seem to enjoy living their lives.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许也有人是屈服于同调压力，但大多数人都在感谢这个条例，快乐地生活着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許也有人是屈服於同調壓力，但大多數人都在感謝這個條例，快樂地生活著。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00096",
		linknext = "0074_00098",
		line = 1199,
	},
	["0074_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If people like me were to be permitted to reject sex, perhaps it wouldn't be such a bad thing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说我们这样的人可以拒绝做爱的话，这或许不一定是件不好的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說我們這樣的人可以拒絕做愛的話，這或許不一定是件不好的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00097",
		linknext = "0074_00099",
		line = 1209,
	},
	["0074_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00098",
		linknext = "0074_00100",
		line = 1219,
	},
	["0074_00100"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"bgm", file="bgm21", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can't help you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——我不能帮你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——我不能幫你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00099",
		linknext = "0074_00101",
		line = 1234,
	},
	["0074_00101"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0086", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00100",
		linknext = "0074_00102",
		line = 1248,
	},
	["0074_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll give you one thing. The islanders do seem to be happy living under your law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“确实，这个岛上的人因为你的条例而生活得很幸福。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「確實，這個島上的人因為你的條例而生活得很幸福。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00101",
		linknext = "0074_00103",
		line = 1260,
	},
	["0074_00103"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But, you know... that doesn't mean everyone is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是——并不是所有人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是——並不是所有人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00102",
		linknext = "0074_00104",
		line = 1272,
	},
	["0074_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There are people who can't adapt to this law, but they certainly can't reject it. So they have no choice but to put their bodies on discount in order to survive, like it or not.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不适应变态条例，也无法拒绝——即使不希望，也有为了生存下去而牺牲自己的人在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不適應變態條例，也無法拒絕——即使不希望，也有為了生存下去而犧牲自己的人在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00103",
		linknext = "0074_00105",
		line = 1283,
	},
	["0074_00105"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0087", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But does that not allow them to a long life? Better that than dying a beggar's death, I would say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“可是，只要那样做就可以活下去了吧？这不是比横死野外好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「可是，只要那樣做就可以活下去了吧？這不是比橫死野外好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00104",
		linknext = "0074_00106",
		line = 1297,
	},
	["0074_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This man is no less persistent than I expected...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个男人果然——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個男人果然——",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00105",
		linknext = "0074_00107",
		line = 1307,
	},
	["0074_00107"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0088", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“There's no way to please everyone, no matter what method you use. There's nothing to be done about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“无论使用什么样的方法，都不能拯救所有人。这是没有办法的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「無論使用什麼樣的方法，都不能拯救所有人。這是沒有辦法的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00106",
		linknext = "0074_00108",
		line = 1319,
	},
	["0074_00108"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes... Nothing indeed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……",
					{"ruby", text="・・・・"},
					"没有办法",
					{"/ruby"},
					"。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……",
					{"ruby", text="・・・・"},
					"沒有辦法",
					{"/ruby"},
					"。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00107",
		linknext = "0074_00109",
		line = 1331,
	},
	["0074_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You really can't make everyone in society happy, no matter how you try to control them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无论怎么努力，也不会有方法让所有人都幸福。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無論怎麼努力，也不會有方法讓所有人都幸福。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00108",
		linknext = "0074_00110",
		line = 1343,
	},
	["0074_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If a method to make everyone happy existed, things would never have gotten like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果有那种方法，一开始就不会发生这些事情了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果有那種方法，一開始就不會發生這些事情了。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00109",
		linknext = "0074_00111",
		line = 1353,
	},
	["0074_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you let things get this way for the sake of the silent majority. And I'm sure you intend to keep the status quo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因此你才会制造出对很多人来说是不错的选择——迎合多数派的机制。你今后一定也会这么做吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因此你才會製造出對很多人來說是不錯的選擇——迎合多數派的機制。你今後一定也會這麼做吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00110",
		linknext = "0074_00112",
		line = 1364,
	},
	["0074_00112"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0089", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Yes. I do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊。你说的没错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊。你說的沒錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00111",
		linknext = "0074_00113",
		line = 1376,
	},
	["0074_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if he were to scoop up and provide special protection for people like me, there is bound to be some kind of cost.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使想从中找出像我这样的一部分少数派进行特别保护，也一定会有人被漏掉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使想從中找出像我這樣的一部分少數派進行特別保護，也一定會有人被漏掉。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00112",
		linknext = "0074_00114",
		line = 1386,
	},
	["0074_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That too will be something unavoidable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也是不可避免的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也是不可避免的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00113",
		linknext = "0074_00115",
		line = 1396,
	},
	["0074_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're not necessarily in the wrong. For a statesman like yourself, it's the right thing to do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说的话并没有错。可以说是作为政治家的正确选择吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說的話並沒有錯。可以說是作為政治家的正確選擇吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00114",
		linknext = "0074_00116",
		line = 1407,
	},
	["0074_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But my companions, those who I'm trying to save... they do not comprise the entirety of the minority.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，我的同伴，我想帮助的人——并没有包含在那个多数派里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，我的同伴，我想幫助的人——並沒有包含在那個多數派裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00115",
		linknext = "0074_00117",
		line = 1418,
	},
	["0074_00117"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0090", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So you won't take my side, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“所以你才不服从我是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「所以你才不服從我是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00116",
		linknext = "0074_00118",
		line = 1432,
	},
	["0074_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00117",
		linknext = "0074_00119",
		line = 1443,
	},
	["0074_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Under this law, some people have been persecuted so much that it's taken their lives.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这个条例下，有受到了无情的迫害而失去生命的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這個條例下，有受到了無情的迫害而失去生命的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00118",
		linknext = "0074_00120",
		line = 1453,
	},
	["0074_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are still people suffering from that law now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就连现在，也有人因为这个条例而痛苦着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就連現在，也有人因為這個條例而痛苦著。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00119",
		linknext = "0074_00121",
		line = 1463,
	},
	["0074_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This minority has been utterly forsaken by the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个条例做的，就是不断抛弃那些少数派的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個條例做的，就是不斷拋棄那些少數派的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00120",
		linknext = "0074_00122",
		line = 1473,
	},
	["0074_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if some are granted exemptions, it won't change the underlying nature of the law. The needs of the many will continue to outweigh the needs of the few.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使设置了一些例外，养大虫杀小虫的根本思想是不会改变的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使設置了一些例外，養大蟲殺小蟲的根本思想是不會改變的。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00121",
		linknext = "0074_00123",
		line = 1483,
	},
	["0074_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I cannot take his side.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此——才和我水火不容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此——才和我水火不容。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00122",
		linknext = "0074_00124",
		line = 1493,
	},
	["0074_00124"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0091", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Are you saying you don't care if you bring misery to many for the sake of your few companions?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“为了为数不多的队友，就算很多人因此变得不幸也无妨，你是这个意思吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「為了為數不多的隊友，就算很多人因此變得不幸也無妨，你是這個意思嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00123",
		linknext = "0074_00125",
		line = 1507,
	},
	["0074_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You said it yourself. There's no method to run society which will make everyone happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……就像你说的，让所有人信服的方法——让所有人幸福的方法一开始就不存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……就像你說的，讓所有人信服的方法——讓所有人幸福的方法一開始就不存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00124",
		linknext = "0074_00126",
		line = 1518,
	},
	["0074_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If someone important to me is going to face hardship... then I'm going to want to save them more than anyone else. That's all there is to it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果有人遭遇着痛苦，而且还是对自己来说很重要的人的话——我就比任何人都想帮助那个人。仅此而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果有人遭遇著痛苦，而且還是對自己來說很重要的人的話——我就比任何人都想幫助那個人。僅此而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00125",
		linknext = "0074_00127",
		line = 1529,
	},
	["0074_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If you took a poll of a thousand people, I imagine 999 would agree with Hitoura here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"1000人听到的话，会有999人说仁浦先生的主张是正确的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"1000人聽到的話，會有999人說仁浦先生的主張是正確的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00126",
		linknext = "0074_00128",
		line = 1539,
	},
	["0074_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the one I want to protect... was the one who reached out to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我想守护的——就是唯一一个为了我伸出援助之手的那个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我想守護的——就是唯一一個為了我伸出援助之手的那個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00127",
		linknext = "0074_00129",
		line = 1549,
	},
	["0074_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to be that sort of person.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想成为那唯一的一个人——我是这样想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想成為那唯一的一個人——我是這樣想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00128",
		linknext = "0074_00130",
		line = 1559,
	},
	["0074_00130"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0092", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Very well. You've made your position clear. But how do you intend to crush the law?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“原来如此……你的主张我明白了。但是，你要如何摧毁条例？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「原來如此……你的主張我明白了。但是，你要如何摧毀條例？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00129",
		linknext = "0074_00131",
		line = 1573,
	},
	["0074_00131"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“By any means necessary. If I don't have a way now, I'll figure something out soon enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——用尽任何办法。就算现在没有办法，也一定会找出破绽。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——用盡任何辦法。就算現在沒有辦法，也一定會找出破綻。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00130",
		linknext = "0074_00132",
		line = 1585,
	},
	["0074_00132"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0093", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You are nothing if not determined... In that case, what say we bet on it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你的决心无法动摇，是吗——那么，要不要赌一赌？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你的決心無法動搖，是嗎——那麼，要不要賭一賭？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00131",
		linknext = "0074_00133",
		line = 1601,
	},
	["0074_00133"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“赌……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「賭……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00132",
		linknext = "0074_00134",
		line = 1613,
	},
	["0074_00134"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0094", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Right. I've seen the illegal sex industry shut down, and the public order problem settled. The only remaining problem... is Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是的。地下风俗被摧毁，治安问题也将被解决。剩下的问题……只有文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是的。地下風俗被摧毀，治安問題也將被解決。剩下的問題……只有文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00133",
		linknext = "0074_00135",
		line = 1625,
	},
	["0074_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00134",
		linknext = "0074_00136",
		line = 1636,
	},
	["0074_00136"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0095", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If I told you to come quietly and hand her over, you most likely wouldn't listen. So I would have to take her back by force. If you object to that, you'll have to defeat me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“就算要你乖乖交出来，你也不可能照做吧。既然这样，那我就使用力量从你手中夺回文乃。如果你不愿意，就试着打倒我吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「就算要你乖乖交出來，你也不可能照做吧。既然這樣，那我就使用力量從你手中奪回文乃。如果你不願意，就試著打倒我吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00135",
		linknext = "0074_00137",
		line = 1650,
	},
	["0074_00137"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0096", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If you can do that, you can consider the law effectively abolished.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果你办得到——那我可以考虑废除变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果你辦得到——那我可以考慮廢除變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00136",
		linknext = "0074_00138",
		line = 1664,
	},
	["0074_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you serious?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你是说真的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你是說真的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00137",
		linknext = "0074_00139",
		line = 1676,
	},
	["0074_00139"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0097", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Of course. Lies are the sole domain of the virtuous... are they not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊，说谎的人总是好人。对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊，說謊的人總是好人。對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00138",
		linknext = "0074_00140",
		line = 1688,
	},
	["0074_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, if we're betting on this, just tell me one thing. If I lose, what happens then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你说是打赌。那如果我们输了，到时会怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你說是打賭。那如果我們輸了，到時會怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00139",
		linknext = "0074_00141",
		line = 1699,
	},
	["0074_00141"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0098", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Heh... do you really need to ask?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……那种事，你不用问也知道吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……那種事，你不用問也知道吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00140",
		linknext = "0074_00142",
		line = 1713,
	},
	["0074_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suppose not.",
					{"rt2"},
				},
			},
			cn = {
				{
					"嗯——说得对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"嗯——說得對。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00141",
		linknext = "0074_00143",
		line = 1723,
	},
	["0074_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's a villain. He wouldn't balk at achieving his objectives by any means necessary.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个男人是个坏人，为了达到目的，会不惜动用一切手段。",
					{"rt2"},
				},
