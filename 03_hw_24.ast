				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There could be countless people out there that moan loudly while despising depraved sex, and she might only be the tip of the iceberg.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈只是冰山一角。一边发出娇声一边厌恶无秩序的性行为，这样的人应该多多少少都还找得到吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩只是冰山一角。一邊發出嬌喘一邊厭惡無秩序的性行為，這樣的人應該多多少少都還找得到吧——",
					{"rt2"},
				},
			},
		},
