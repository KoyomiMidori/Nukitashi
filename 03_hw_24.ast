			tw = {
				{
					name = {"淳之介"},
					"「……我也正想和你談談。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00038",
		linknext = "0074_00040",
		line = 493,
	},
	["0074_00040"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=100},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"ex", time=2000, func="wait"},
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00107", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0066", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Phew... it's quiet. You certainly don't see many people walking around at this hour.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……不过这里还真是安静啊。你应该没什么机会在这种时间出们行走吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……不過這裡還真是安靜啊。你應該沒什麼機會在這種時間出們行走吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00039",
		linknext = "0074_00041",
		line = 540,
	},
	["0074_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that's true.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00040",
		linknext = "0074_00042",
		line = 552,
	},
	["0074_00042"] = {
		{"se", id=0, loop=0, file="se_a053"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I see Asa-chan off to school, and find myself walking a familiar route with Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"目送麻沙酱离开后，我跟着仁浦先生沿着熟悉的道路前行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"目送麻沙醬離開後，我跟著仁浦先生沿著熟悉的道路前行。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00041",
		linknext = "0074_00043",
		line = 563,
	},
	["0074_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's well past the start of normal business hours, and there are no excitable throngs of students around either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为早就过了上课时间，所以平时热闹非凡的学生们也都不在了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為早就過了上課時間，所以平時熱鬧非凡的學生們也都不在了。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00042",
		linknext = "0074_00044",
		line = 573,
	},
	["0074_00044"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You sure this is a good idea? The whole country's talking about what's happened on this island, and you're here taking a stroll like it's nothing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要紧吗？明明全日本都在探讨青蓝岛发生的事件，你却这样到处走动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要緊嗎？明明全日本都在探討青藍島發生的事件，你卻這樣到處走動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00043",
		linknext = "0074_00045",
		line = 586,
	},
	["0074_00045"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0067", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If anything, that's precisely why I can. They wouldn't expect the governor of this prefecture to be walking around in broad daylight, would they?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“正因为如此啊。谁会想到传言中的县知事会这样堂堂正正地在外面散步呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「正因為如此啊。誰會想到傳言中的縣知事會這樣堂堂正正地在外面散步呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00044",
		linknext = "0074_00046",
		line = 600,
	},
	["0074_00046"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're quite bold, aren't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真大胆啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真大膽啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00045",
		linknext = "0074_00047",
		line = 612,
	},
	["0074_00047"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0068", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I wouldn't have this job if I weren't.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不这样可干不了县知事哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不這樣可幹不了縣知事哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00046",
		linknext = "0074_00048",
		line = 626,
	},
	["0074_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He says that in a completely detached manner.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生随意地回答。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生隨意地回答。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00047",
		linknext = "0074_00049",
		line = 636,
	},
	["0074_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As much as I try to read him, I can't get a bearing on what he really feels deep down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算想深究，也无法理解他到底在想什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算想深究，也無法理解他到底在想什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00048",
		linknext = "0074_00050",
		line = 646,
	},
	["0074_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So. You wanted to talk, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——想和我说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——想和我說什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00049",
		linknext = "0074_00051",
		line = 658,
	},
	["0074_00051"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0069", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Yes... I suppose I'll cut right to the chase. I would like for you to become my right-hand man.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊……开门见山地说吧。我——希望你能成为我的左右手。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊……開門見山地說吧。我——希望你能成為我的左右手。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00050",
		linknext = "0074_00052",
		line = 672,
	},
	["0074_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……左右手？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……左右手？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00051",
		linknext = "0074_00053",
		line = 683,
	},
	["0074_00053"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0070", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Yes. Do you not think the people of this nation are gullible fools?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊。你不认为这个国家的人们很愚蠢吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊。你不認為這個國家的人們很愚蠢嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00052",
		linknext = "0074_00054",
		line = 695,
	},
	["0074_00054"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0071", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Give them red meat in the form of a political scandal, and they'll pounce right on it. Keep giving them bait, and they will continue to bite. Like wild animals.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“轻而易举地扑向挂在鱼钩上的丑闻，给出其他饵后又马上往另一边游去……就跟野兽一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「輕而易舉地撲向掛在魚鉤上的醜聞，給出其他餌後又馬上往另一邊游去……就跟野獸一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00053",
		linknext = "0074_00055",
		line = 709,
	},
	["0074_00055"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0072", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“They criticize our law, while lusting insatiably for the bait they're offered. They lack facts, logic and reason. They are no different from the people living on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“一边批判着变态条例，还一边贪婪地渴求着被给予的诱饵——根本毫无理性可言。他们和这个岛上的人没有任何不同。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「一邊批判著變態條例，還一邊貪婪地渴求著被給予的誘餌——根本毫無理性可言。他們和這個島上的人沒有任何不同。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00054",
		linknext = "0074_00056",
		line = 721,
	},
	["0074_00056"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0073", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Do you not think it prudent to control the ignorant masses with sex, just as we do on this island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这等愚民——就和这个岛一样，用性支配、操纵他们就好了——你不这么觉得吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這等愚民——就和這個島一樣，用性支配、操縱他們就好了——你不這麼覺得嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00055",
		linknext = "0074_00057",
		line = 735,
	},
	["0074_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你是什么意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你是什麼意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00056",
		linknext = "0074_00058",
		line = 747,
	},
	["0074_00058"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0074", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I mean what I said. If we take the perverted sex law on this island, and broaden its scope... we can control all of Japan through sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“就是字面上的意思。将铺设在青蓝岛上的变态条例往外推广……用性爱统治全日本。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「就是字面上的意思。將鋪設在青藍島上的變態條例往外推廣……用性愛統治全日本。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00057",
		linknext = "0074_00059",
		line = 759,
	},
	["0074_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's crazy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"开什么玩笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"開什麼玩笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00058",
		linknext = "0074_00060",
		line = 769,
	},
	["0074_00060"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's ridiculous. Controlling the entire country through sex? If that's your idea of a joke, I'm not laughing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在说什么傻话……用性爱来统治国家？还真是个难笑的笑话呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在說什麼傻話……用性愛來統治國家？還真是個難笑的笑話呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00059",
		linknext = "0074_00061",
		line = 781,
	},
	["0074_00061"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0075", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So I see. But it's hardly a joking matter how the islanders have so readily accepted such a law. Why don't you think it could be applied to the nation as a whole?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊。因为这不是开玩笑——现在这个岛上的人，都把变态条例当成理所当然的事了。你为什么觉得这在国家上行不通？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊。因為這不是開玩笑——現在這個島上的人，都把變態條例當成理所當然的事了。你為什麼覺得這在國家上行不通？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00060",
		linknext = "0074_00062",
		line = 795,
	},
	["0074_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He has a point... there was a period on Seiran Island when this law didn't exist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"的确——青蓝岛曾经也有过没有什么变态条例的时代。",
					{"rt2"},
				},
			},
			tw = {
				{
					"的確——青藍島曾經也有過沒有什麼變態條例的時代。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00061",
		linknext = "0074_00063",
		line = 805,
	},
	["0074_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this man — Hitoura Toshiaki — is singlehandedly responsible for bringing about all the massive changes the law helped to cultivate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而带来这一变革的正是这个男人——仁浦俊明。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而帶來這一變革的正是這個男人——仁浦俊明。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00062",
		linknext = "0074_00064",
		line = 815,
	},
	["0074_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The thought of him actually being able to achieve such a thing is rather terrifying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果他认真想做的话——应该有能力做到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果他認真想做的話——應該有能力做到。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00063",
		linknext = "0074_00065",
		line = 825,
	},
	["0074_00065"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0076", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If I were to do that, I would require a hero. One who could overwhelm these imbeciles through sheer sexual power.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是，要成就大事就需要英雄。用压倒性的力量来驯服愚民的英雄。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是，要成就大事就需要英雄。用壓倒性的力量來馴服愚民的英雄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00064",
		linknext = "0074_00066",
		line = 839,
	},
	["0074_00066"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0077", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“And that hero would be you, Tachibana Junnosuke-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“而那个英雄——就是你，橘淳之介君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「而那個英雄——就是你，橘淳之介君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00065",
		linknext = "0074_00067",
		line = 853,
	},
	["0074_00067"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? You're overestimating me. I don't have that kind of power...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——你太看重我了。我没有那种能力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——你太看重我了。我沒有那種能力……」",
					{"rt2"},
				},
			},
