	["0074_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I manage a laugh.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，还是让自己笑了出来。",
					{"rt2"},
