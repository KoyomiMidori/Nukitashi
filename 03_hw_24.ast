		linkback = "0074_00066",
		linknext = "0074_00068",
		line = 865,
	},
	["0074_00068"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0078", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oh, but you do. I've told you before. It's a crying shame how you keep that incredible power of yours hidden away. If you were to use it, everyone would obey you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——你有。我之前不是说过吗？你所拥有的压倒性的力量……藏起来实在是太可惜了。如果你行使它，那么谁都会听从你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——你有。我之前不是說過嗎？你所擁有的壓倒性的力量……藏起來實在是太可惜了。如果你行使它，那麼誰都會聽從你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00067",
		linknext = "0074_00069",
		line = 877,
	},
	["0074_00069"] = {
