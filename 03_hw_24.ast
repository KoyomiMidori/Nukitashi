	},
	["0074_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's not the easiest to approach, so she's been avoiding sex up until now... but that lifestyle is not one which this island permits.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然她以野性的直觉和让其他人不想接近的兽性一直避免性行为直到今天，但这在青蓝岛上本来就是不被允许的存在方式。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然她以野性的直覺和讓其他人不想接近的獸性一直避免性行為直到今天，但這在青藍島上本來就是不被允許的存在方式。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00021",
		linknext = "0074_00023",
		line = 274,
	},
	["0074_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In order to be a respectable member of society on this island, you have to have sex even if you don't want to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果想在这个岛上认真生活，即使不愿意也要做爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果想在這個島上認真生活，即使不願意也要做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00022",
		linknext = "0074_00024",
		line = 284,
	},
	["0074_00024"] = {
		{"text"},
		text = {
