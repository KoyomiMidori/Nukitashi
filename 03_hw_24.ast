	["0074_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Up until now I've only regarded the sex-seekers as my enemy, but now I'm very curious.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然过去只单纯地把性触者视为敌人，但现在却莫名地在意起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然過去只單純地把性觸者視為敵人，但現在卻莫名地在意起來。",
					{"rt2"},
				},
			},
		},
