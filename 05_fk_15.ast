	},
	["0115_00244"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The water temperature's perfect, my change of clothes is all ready for me, and even the towels are freshly washed and quite fluffy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"温度设定得绝妙，换洗的衣物也很干净，毛巾也是才刚洗好，摸起来软绵绵的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"溫度設定得絕妙，換洗的衣物也很乾淨，毛巾也是才剛洗好，摸起來軟綿綿的。",
					{"rt2"},
