	["0115_00065"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's none of that usual sense of relief, with him having had a much more pleasant composure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许是因为老人的气氛比以前柔和，现场没有以往的气氛变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許是因為老人的氣氛比以前柔和，現場沒有以往的氣氛變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00064",
		linknext = "0115_00066",
		line = 863,
	},
	["0115_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Instead, there's the heightened sense of being on a mission.",
					{"rt2"},
				},
			},
			cn = {
				{
					"取而代之的是宛如作战行动中的一触即发的气氛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"取而代之的是宛如作戰行動中的一觸即發的氣氛。",
					{"rt2"},
				},
			},
		},
