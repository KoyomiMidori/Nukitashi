					"“Fumino? I'm done with my bath. Finish up with your housework so you can have... yours?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃——我洗完了。你早点结束家务，去洗澡……诶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃——我洗完了。你家事告一個段落就早點去洗澡……欸。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00245",
