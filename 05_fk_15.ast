	},
	["0115_00063"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0152", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Excellent! Oh, wondrous day. I am looking forward to the favorable outcome of your hard-fought battles. That is all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“好好好……！今天真是个好日子……那么，期待你们的奋战和幸运。就这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「好好好……！今天真是個好日子……那麼，期待你們的奮戰和幸運。就這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00062",
		linknext = "0115_00064",
		line = 835,
	},
	["0115_00064"] = {
