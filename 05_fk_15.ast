					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You need to develop it first and get it printed out. You won't know until then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在洗出来之前是无法确认的。在印到纸上之前是不知道的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在洗出來之前是無法確認的。在印到紙上之前是不知道的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00136",
		linknext = "0115_00138",
		line = 1784,
	},
	["0115_00138"] = {
