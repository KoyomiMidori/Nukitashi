	["0115_00074"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You know Reizeiin Touka, the student council president and head honcho of the SS? She stopped by my house on the weekend.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS的最高领袖——冷泉院桐香，休息日特地到我家来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS的最高領袖——冷泉院桐香，休息日特地到我家來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00073",
		linknext = "0115_00075",
		line = 983,
	},
	["0115_00075"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2210", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? That's strange, though. If they know we've secured Fumino, why won't they try to make their move?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶，不过，不觉得很奇怪吗……？为什么FS知道是我们正在保护文乃，却没有采取行动？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸，不過，不覺得很奇怪嗎……？為什麼FS知道是我們正在保護文乃，卻沒有採取行動？」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00074",
		linknext = "0115_00076",
		line = 998,
	},
	["0115_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She said herself that she wasn't planning on informing them, provided I accept her conditions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她本人说她并没有要报告的打算。只要我答应她的要求——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她本人說她並沒有要報告的打算。只要我答應她的要求——」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00075",
		linknext = "0115_00077",
		line = 1010,
	},
	["0115_00077"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just have to become hers, and she'll keep quiet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——如果我成为学生会长的东西的话，她就不会说出去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——如果我成為學生會長的東西的話，她就不會說出去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00076",
		linknext = "0115_00078",
		line = 1022,
	},
	["0115_00078"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
