			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But such a lifestyle is one I am unworthy of.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是对我来说，那样的生活是不适合我的。”",
