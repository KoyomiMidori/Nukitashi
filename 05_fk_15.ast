				{"vo", file="hinami2158", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Umm... so what does that actually mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃……那是……怎么回事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃……那是……怎麼回事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00077",
		linknext = "0115_00079",
		line = 1036,
	},
	["0115_00079"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hell if I know, honestly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……说实话，我也不知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……說實話，我也不知道。」",
