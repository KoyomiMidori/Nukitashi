			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'd only heard his voice... once when I was little... but if he knows Mother's name... then I am certain.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……小时候、只听过……一次声音……但如果连我母亲的名字都知道……那就没有错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……小時候、只聽過……一次聲音……但如果連我母親的名字都知道……那就沒有錯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00034",
		linknext = "0115_00036",
		line = 494,
	},
	["0115_00036"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00007", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So it seems the old man wasn't lying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然文乃这么说了，那老人说的话里应该没有谎言吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然文乃這麼說了，那老人說的話裡應該沒有謊言吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00035",
		linknext = "0115_00037",
		line = 510,
	},
	["0115_00037"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0144", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You've grown so much indeed... Ah, I have never been so delighted in all my life...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“居然都这么大了……啊啊，我从没有像今天这么高兴过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「居然都這麼大了……啊啊，我從沒有像今天這麼高興過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00036",
		linknext = "0115_00038",
		line = 523,
	},
	["0115_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She stares fixedly with those strangely colored eyes of her at her grandfather.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用那奇特颜色的眼睛盯着自己的外祖父。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用那奇特顏色的眼睛盯著自己的外祖父。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00037",
		linknext = "0115_00039",
		line = 533,
	},
	["0115_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess I should more or less believe him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么，某种程度上应该可以信任——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼，某種程度上應該可以信任——",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00038",
		linknext = "0115_00040",
		line = 543,
	},
	["0115_00040"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=100},
		{"bg", id=1, file="bg12_1l_00000", x=300, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0145", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“At last, you have safely secured her. Hahaha, splendid, splendid! I shall reward you now. What do you desire?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“——看来你们成功保护了文乃。哈哈哈哈，太好了太好了……！让我给予你们奖励吧。你们有什么希望？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「——看來你們成功保護了文乃。哈哈哈哈，太好了太好了……！讓我給予你們獎勵吧。你們有什麼希望？」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00039",
		linknext = "0115_00041",
		line = 560,
	},
	["0115_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Information that will determine our course of action.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就给我们决定文乃去留的情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就給我們決定文乃去留的情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00040",
		linknext = "0115_00042",
		line = 572,
	},
	["0115_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please tell us what you plan to do with this girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老爷爷，请你再次告诉我们，你今后打算如何处置这个孩子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「老爺爺，請你再次告訴我們，你今後打算如何處置這個孩子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00041",
		linknext = "0115_00043",
		line = 584,
	},
	["0115_00043"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00104", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0146", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What do you think? Obviously, I intend to take her in! I wish to bring my granddaughter up in a good environment, one she never had.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“那还用说！当然是想领养啊……！代替我的女儿，我会让孙女在更好的环境里长大。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「那還用說！當然是想領養啊……！代替我的女兒，我會讓孫女在更好的環境裡長大。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00042",
		linknext = "0115_00044",
		line = 597,
	},
	["0115_00044"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0147", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“She is Hitoura's illegitimate child, so it is not difficult to discern how the OSS and that chivalrous organization would use her as a hostage to further their own plans.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“文乃是仁浦的私生女。SHO和侠义团体很有可能将这个孩子当作人质来策划计谋。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「文乃是仁浦的私生女。SHO和俠義團體很有可能將這個孩子當作人質來策劃計謀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00043",
		linknext = "0115_00045",
		line = 609,
	},
	["0115_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if we hand her over, that risk disappears.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是只要文乃被接走，危险就不存在了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是只要文乃被接走，危險就不存在了。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00044",
		linknext = "0115_00046",
		line = 619,
	},
	["0115_00046"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0148", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“With her on my side, nothing will stand in the way of the destruction of the perverted sex law. So I will fulfill your desire and proceed with doing so at once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“既然如此，就没有人能阻止我破坏变态条例。按照你当初的愿望，我就把它全部破坏掉吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「既然如此，就沒有人能阻止我破壞變態條例。按照你當初的願望，我就把它全部破壞掉吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00045",
		linknext = "0115_00047",
		line = 631,
	},
	["0115_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00046",
		linknext = "0115_00048",
		line = 643,
	},
	["0115_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's always been my desire to abolish the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"破坏变态条例是我的夙愿。",
					{"rt2"},
				},
			},
			tw = {
				{
					"破壞變態條例是我的夙願。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00047",
		linknext = "0115_00049",
		line = 653,
	},
	["0115_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For my sister, and for my companions... This law must be destroyed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了妹妹，为了同伴们，这个条例绝对要摧毁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了妹妹，為了同伴們，這個條例絕對要摧毀。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00048",
		linknext = "0115_00050",
		line = 663,
	},
	["0115_00050"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0149", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Now, your next task is to bring Fumino to me without injury. Within 6 days, I shall send someone to create a blind spot in the OSS's surveillance network.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“下一个任务就是将文乃完整交给我。明天开始5天之后，我会突破SHO的监视网派接送人过去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「下一個任務就是將文乃完整交給我。明天開始5天之後，我會突破SHO的監視網派接送人過去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00049",
		linknext = "0115_00051",
		line = 676,
	},
	["0115_00051"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0150", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“During that interval, please keep her safe, and bring her to the rendezvous point safely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“希望你们在这段时间里能保护文乃，并平安抵达集合地点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「希望你們在這段時間裡能保護文乃，並平安抵達集合地點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00050",
		linknext = "0115_00052",
		line = 689,
	},
	["0115_00052"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And then she'll be safe in your hands, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那么，你能保证这孩子的安全是吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那麼，你能保證這孩子的安全是吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00051",
		linknext = "0115_00053",
		line = 701,
	},
	["0115_00053"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0151", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Correct. I have already prepared a boarding party, to secure her without any hassles.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“当然。我早就做好了随时随地都可以接收她的准备。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「當然。我早就做好了隨時隨地都可以接收她的準備。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00052",
		linknext = "0115_00054",
		line = 714,
	},
	["0115_00054"] = {
