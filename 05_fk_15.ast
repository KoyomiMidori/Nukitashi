					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“With everything that has happened up until now... being able to live out an ordinary existence is best for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“因为一直以来发生了很多事情……所以如果能过上普通人的生活，那就最好不过了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「因為一直以來發生了很多事情……所以如果能過上普通人的生活，那就最好不過了……」",
					{"rt2"},
