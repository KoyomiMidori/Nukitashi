					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You won't have to put up with this for much longer, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
