	["0115_00212"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0827", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm terribly sorry. I will prepare your bedding immediately.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“对不起……我马上为您准备床铺……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「對不起……我馬上為您準備床鋪……」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00211",
		linknext = "0115_00213",
		line = 2943,
	},
	["0115_00213"] = {
		{"se", id=0, loop=0, file="se_a002"},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=600},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is that why she hasn't been staying up late at night and waking up bright and early lately?",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来最近麻沙酱变得不熬夜，早上也能很快起床的原因……是这样啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來最近麻沙醬變得不熬夜，早上也能很快起床的原因……是這樣啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00212",
		linknext = "0115_00214",
		line = 2957,
	},
	["0115_00214"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel so sorry for her endlessly following us around every day for our daily activities.",
					{"rt2"},
				},
			},
			cn = {
				{
					"让她过着被日常琐事束缚的生活，让我对那个孩子充满了歉意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"讓她過著被日常瑣事束縛的生活，讓我對那個孩子充滿了歉意。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00213",
		linknext = "0115_00215",
		line = 2969,
	},
	["0115_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want her to live more for herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……我希望她能活得更自我一些。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……我希望她能活得更自我一些。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00214",
		linknext = "0115_00216",
		line = 2979,
	},
	["0115_00216"] = {
		{"se", id=0, loop=0, file="se_a079"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0828", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Thanks for waiting. I've laid out your bedding with crisp sheets that smell of the sunshine, and fluffed up your futon as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“让您久等了。为您准备了干净的床单以及散发着太阳公公香味的棉被。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「讓您久等了。為您準備了乾淨的床單以及散發著太陽公公香味的棉被。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00215",
		linknext = "0115_00217",
		line = 2994,
	},
	["0115_00217"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
