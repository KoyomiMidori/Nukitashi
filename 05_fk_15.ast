					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wipe that smug look off your face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别摆出一副理所应当的表情。”",
