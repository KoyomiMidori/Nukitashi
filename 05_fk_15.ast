					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seems like it... She evidently came all the way to my house to barter with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
