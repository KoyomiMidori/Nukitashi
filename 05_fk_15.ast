		linkback = "0115_00105",
		linknext = "0115_00107",
		line = 1409,
	},
	["0115_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there's only so much we can do to make our weapons imitate adult goods.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是，我们有必须模拟成成人用品的束缚。",
					{"rt2"},
				},
