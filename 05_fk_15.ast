	["0115_00073"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The SS have already caught wind of Fumino. More to the point, they know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——FS已经察觉到文乃的存在。不，应该说是已经知道了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——FS已經察覺到文乃的存在。不，應該說是已經知道了。」",
					{"rt2"},
				},
			},
