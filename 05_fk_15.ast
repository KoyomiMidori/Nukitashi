	["0115_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know better than anyone the strengths of each of my companions under my command.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些家伙的厉害，我比任何人都清楚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些傢伙的厲害，我比任何人都清楚。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00099",
		linknext = "0115_00101",
		line = 1347,
	},
	["0115_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's why I had to consult with Nanase to decide on how to proceed with the development and design of our new multi-floor enemy search system.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，之前和奈奈濑商量后决定开发的多楼层索敌系统新装置，必须加紧脚步——",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，之前和奈奈瀨商量後決定開發的多樓層索敵系統新裝置，必須加緊腳步——",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00100",
		linknext = "0115_00102",
		line = 1357,
	},
	["0115_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm... The question is, what basic form should it take?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……问题是要选哪个基本造型——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……問題是要選哪個基本造型——」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00101",
		linknext = "0115_00103",
		line = 1369,
	},
	["0115_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've already given it some consideration.",
					{"rt2"},
				},
			},
			cn = {
				{
					"某种程度的想法已经有了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"某種程度的想法已經有了。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00102",
		linknext = "0115_00104",
		line = 1379,
	},
	["0115_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I can link it with 'that', it'd be feasible to make it more than capable enough for our purposes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果将“那个”与之结合，那么多楼层索敌系统就能完美实装，但是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果將「那個」與之結合，那麼多樓層索敵系統就能完美實裝，但是——",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00103",
		linknext = "0115_00105",
		line = 1389,
	},
	["0115_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But therein lies the issue. How do we construct 'that'?",
					{"rt2"},
				},
			},
			cn = {
				{
					"说实话，制作“那个”这件事本身没有问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說實話，製作「那個」這件事本身沒有問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00104",
		linknext = "0115_00106",
		line = 1399,
	},
	["0115_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all, I can just order it online and have it delivered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想买的话，在网上也能买到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想買的話，在網上也能買到。",
					{"rt2"},
				},
