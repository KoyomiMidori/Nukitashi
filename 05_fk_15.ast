		linknext = "0115_00067",
		line = 873,
	},
	["0115_00067"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2209", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So now our objective is to keep Fumino safe to the very last, and deliver her to the meeting place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样一来，我们最大的目的就是保护文乃到期限，然后把她送到指定的位置——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣一來，我們最大的目的就是保護文乃到期限，然後把她送到指定的位置——」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00066",
		linknext = "0115_00068",
		line = 888,
	},
	["0115_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If we're to take him at his word, then doing this means we'll finally see the end of the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果老人的说法可信，并且能如愿达成——变态条例就终于要迎来终结了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果老人的說法可信，並且能如願達成——變態條例就終於要迎來終結了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00067",
		linknext = "0115_00069",
		line = 900,
	},
	["0115_00069"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2157", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, that's all we have to do? It's not too different from how we've been protecting her up until now! This should be easier than I thought!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“什么嘛，就这么简单啊！保护文乃酱就跟我们一直以来都在做的一样，意外地没什么大不了的啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「什麼嘛，就這麼簡單啊！保護文乃醬就跟我們一直以來都在做的一樣，意外地沒什麼大不了的啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00068",
		linknext = "0115_00070",
		line = 914,
	},
	["0115_00070"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2032", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes. I also don't think it will be that hard getting to the designated location if we use our items.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没错。就算是前往指定的地点，只要有我们的道具，应该也不是什么难事——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒錯。就算是前往指定的地點，只要有我們的道具，應該也不是什麼難事——」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00069",
		linknext = "0115_00071",
		line = 928,
	},
	["0115_00071"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually, we have one kinda serious problem now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，关于那个，我有很大的疑虑。”",
					{"rt2"},
				},
			},
			tw = {
