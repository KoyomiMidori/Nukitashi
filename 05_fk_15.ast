				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She always at least cracks a smile (I think?) at my jokes, no matter how shitty they are.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是平时，无论是多么无聊的笑话，她都会保持没有笑容的脸笑给我看呢（？）。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是平時，無論是多麼無聊的笑話，她都會保持沒有笑容的臉笑給我看呢（？）。",
