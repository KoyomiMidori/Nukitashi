				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If I'm to be indulgent... that would be passing every day... with the people I wish to faithfully serve.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果再奢侈一点……那就是在真心想要侍奉的人身边……度过每一天……”",
