				},
			},
		},
		linkback = "0115_00106",
		linknext = "0115_00108",
		line = 1419,
	},
	["0115_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And 'that' has a certain amount of mass. It outputs power. It can't be made lighter without reducing its capability.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“那个”需要点质量，还需要点输出。而且不轻便就不实用。",
