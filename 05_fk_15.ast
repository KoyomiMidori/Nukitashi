					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm trying to destroy the perverted sex law here! You think I'd just throw my dignity away and do something like that when I'm halfway to my goal!?”",
