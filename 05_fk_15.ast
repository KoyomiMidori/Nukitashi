		linkback = "0115_00133",
		linknext = "0115_00135",
		line = 1748,
	},
	["0115_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So she's never seen a proper SLR camera before...",
					{"rt2"},
				},
			},
			cn = {
				{
					"是吗，没见过单反相机啊……",
					{"rt2"},
				},
			},
			tw = {
				{
					"是嗎，沒見過單反相機啊……",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00134",
		linknext = "0115_00136",
		line = 1758,
	},
	["0115_00136"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0806", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Once you have taken a picture with this... how do you view it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这个……拍的东西要在哪个画面上确认呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這個……拍的東西要在哪個畫面上確認呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00135",
		linknext = "0115_00137",
		line = 1772,
	},
	["0115_00137"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
