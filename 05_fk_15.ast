					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No no, you look like an upper-class girl by any measure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
