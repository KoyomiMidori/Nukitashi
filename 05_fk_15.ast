	["0115_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks up at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一问，文乃抬起头看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一問，文乃抬起頭看著我。",
					{"rt2"},
