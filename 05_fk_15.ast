	["0115_00255"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like, what kinda cave have you been living in? Bathing in a river all this time, and not a proper bath like a civilized human being! Bwahaha!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过当听说到你目前为止都在河的上游洗澡时我还以为是哪里的原始人呢，啊哈哈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過當聽說到你目前為止都在河的上游洗澡時我還以為是哪裡的原始人呢，啊哈哈。」",
					{"rt2"},
				},
			},
		},
