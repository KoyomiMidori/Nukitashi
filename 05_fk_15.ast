	["0115_00243"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels invigorating, getting to wash all my weariness away like this at the end of a long day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为一天的最后，我结束了生命的洗涤，以清爽的心情走了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為一天的最後，我結束了生命的洗滌，以清爽的心情走了出來。",
					{"rt2"},
