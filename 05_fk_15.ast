		line = 3088,
	},
	["0115_00224"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Knowing how wealthy he is, you'll probably have servants of your own to wait on you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个老人很有钱，说不定会反过来变成有人服侍你呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個老人很有錢，說不定會反過來變成有人服侍你呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0115_00223",
