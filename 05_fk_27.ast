		{"bg", id=1, file="bg11_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00125", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0342", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“That's twenty-one, eh... Well, not bad fer a first-timer. 'Specially a greenhorn punk like you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“21次是吗……以第一次来说还算能忍呢，以一个乳臭未干的小鬼来说也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「21次是嗎……以第一次來說還算能忍呢，以一個乳臭未乾的小鬼來說也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00168",
