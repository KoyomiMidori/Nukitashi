	["0127_00223"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0143", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "警備兵A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Guard A"},
					"“We are from the security group entrusted with maintaining public order on Seiran Island! We want a word with you! Open this door, now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "警备兵A"},
					"“我们是被委托进行青蓝岛治安管理的保安公司的人！有话要跟你说。马上打开门！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "警備兵A"},
					"「我們是被委託進行青藍島治安管理的保安公司的人！有話要跟你說。馬上打開門！」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00222",
		linknext = "0127_00224",
		line = 3143,
	},
	["0127_00224"] = {
		{"text"},
		text = {
