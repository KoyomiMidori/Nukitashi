		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You shouldn't have shown up out of the blue like that and scared her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是的，都是因为麻沙酱突然出现害她吓了一跳。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是的，都是因為麻沙醬突然出現害她嚇了一跳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00036",
		linknext = "0127_00038",
		line = 539,
	},
	["0127_00038"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1808", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh come on here I managed to get up by myself for the first time in forever and I expected a compliment or two but here you're scolding me when you oughta be smothering me with praise and hugging me and rubbing my damn head!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“什么啊我还想说偶尔自己起床了却还被骂你倒是夸我啊妹妹一个人起床了你倒是夸啊然后再抱着妹妹摸摸头一整天啊～……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「什麼啊我還想說偶爾自己起床了卻還被罵你倒是誇我啊妹妹一個人起床了你倒是誇啊然後再抱著妹妹摸摸頭一整天啊～……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00037",
		linknext = "0127_00039",
		line = 553,
	},
	["0127_00039"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm almost starting to think all those 'millennials are lazy' jokes have a kernel of truth to them...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你自己起床我反而还比较费劲是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你自己起床我反而還比較費勁是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00038",
		linknext = "0127_00040",
		line = 565,
	},
