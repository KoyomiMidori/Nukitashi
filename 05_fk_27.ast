		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We walk off aimlessly together.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我和仁浦先生两个人漫无目的地走着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我和仁浦先生兩個人漫無目的地走著。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00410",
		linknext = "0127_00412",
		line = 5912,
	},
	["0127_00412"] = {
		{"bgm", file="bgm23", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you doing here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……为什么，你会在这里呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……為什麼，你會在這裡呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00411",
		linknext = "0127_00413",
		line = 5925,
	},
	["0127_00413"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0296", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Nothing that would surprise you. I'm hiding from Sakimori's little posse. They don't know the layout of the land, so they wouldn't know about this place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“跟你想的一样。我正在躲避防人的追兵。这里的话，不会被不熟悉当地情况的人发现。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「跟你想的一樣。我正在躲避防人的追兵。這裡的話，不會被不熟悉當地情況的人發現。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00412",
		linknext = "0127_00414",
		line = 5940,
	},
	["0127_00414"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00123", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then why don't you just leave the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……既然如此，逃到岛外不就好了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……既然如此，逃到島外不就好了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00413",
		linknext = "0127_00415",
		line = 5952,
	},
	["0127_00415"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0297", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I can't do that. I still have supporters and benefactors here. Well, really, it's not so much that I can't, per se...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那我做不到。这里还有我的支持者和支援者。虽然能做到的事情很有限——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那我做不到。這裡還有我的支持者和支援者。雖然能做到的事情很有限——」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00414",
		linknext = "0127_00416",
		line = 5966,
	},
	["0127_00416"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He stops walking and stares ahead into empty space.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生停下脚步，突然凝视着前方的虚空。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生停下腳步，突然凝視著前方的虛空。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00415",
		linknext = "0127_00417",
		line = 5977,
	},
	["0127_00417"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0298", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Are you and Fumino... an item now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你和文乃……在一起了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你和文乃……在一起了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00416",
		linknext = "0127_00418",
		line = 5991,
	},
	["0127_00418"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y... Yes. We are. I treasure her as much as my sister, if not more so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯、嗯……是的。我把她当成和妹妹一样……或者说更加珍惜的对象——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯、嗯……是的。我把她當成和妹妹一樣……或者說更加珍惜的對象——」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00417",
		linknext = "0127_00419",
		line = 6003,
	},
	["0127_00419"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
