	["0127_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the islanders were a minority in themselves.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上的人终究也只是少数派。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上的人終究也只是少數派。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00108",
		linknext = "0127_00110",
		line = 1526,
	},
	["0127_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They were under extreme restrictions on the mainland; bound hand and foot by what the mainland considered law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是当初受到本岛严格的限制，无法动弹的人们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是當初受到本島嚴格的限制，無法動彈的人們。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00109",
		linknext = "0127_00111",
		line = 1536,
	},
	["0127_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For people trying to escape such a suffocating existence, coming here was like coming to a utopia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了摆脱那种窒息感，才会来到这个",
					{"ruby", text="乌托邦"},
					"乐园",
					{"/ruby"},
					"。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了擺脫那種窒息感，才會來到這個",
					{"ruby", text="烏托邦"},
					"樂園",
					{"/ruby"},
					"。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00110",
		linknext = "0127_00112",
		line = 1546,
	},
	["0127_00112"] = {
