		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg10_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0061", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“So, ain't there somewhere we can hide that li'l slip of a girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“……所以说，有什么地方能让那女孩藏身吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「……所以說，有什麼地方能讓那女孩藏身嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00353",
		linknext = "0127_00355",
		line = 5122,
	},
	["0127_00355"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0011", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "老人A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Old Man A"},
					"“Yeah, how's about that old battleground no one goes near? That'll provide shelter from the elements for now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "老人A"},
					"“啊，那里怎么样。不是有个谁也不靠近的战场遗址吗？应该多少能避下雨吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "老人A"},
					"「啊，那裡怎麼樣。不是有個誰也不靠近的戰場遺址嗎？應該多少能避下雨吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00354",
		linknext = "0127_00356",
		line = 5134,
	},
	["0127_00356"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think that's out of the question.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那里……大概不行吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那裡……大概不行吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00355",
		linknext = "0127_00357",
		line = 5146,
	},
	["0127_00357"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The mastermind behind this whole situation knows the details of those facilities on this island. There's a definite possibility she could be found out there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这次的幕后操纵者好像很了解青蓝岛的这些设施，很有可能会被发现。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這次的幕後操縱者好像很了解青藍島的這些設施，很有可能會被發現。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00356",
		linknext = "0127_00358",
		line = 5158,
	},
	["0127_00358"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0062", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Wot? A mastermind, ya say!? You whippersnappers're up agin' a helluva formidable force! Whaddaya say, boys?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“什么，居然有那样的家伙……！？你们在和那么厉害的东西战斗啊……！是吧大家！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「什麼，居然有那樣的傢伙……！？你們在和那麼厲害的東西戰鬥啊……！是吧大家！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00357",
		linknext = "0127_00359",
		line = 5170,
	},
	["0127_00359"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0012", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "老人B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Old Man B"},
					"“He's right! Yer best off leavin' the island but fast. I imagine ol' Kenzou 'ere could fix up that Seiran plane thinger an' get 'er flyin' agin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "老人B"},
					"“哦哦，是啊！喂，干脆离开岛上怎么样？健藏的话，应该可以把那架晴岚修好吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "老人B"},
					"「哦哦，是啊！喂，乾脆離開島上怎麼樣？健藏的話，應該可以把那架晴嵐修好吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00358",
		linknext = "0127_00360",
		line = 5182,
	},
	["0127_00360"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0063", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“I kin definitely fix 'er, but she's a seaplane. She's gotta have a catapult, or she ain't gonna be able t' shoot 'er shot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“虽然我有信心修理，可是那是水上飞机。如果没有弹射器可飞不了哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「雖然我有信心修理，可是那是水上飛機。如果沒有彈射器可飛不了哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00359",
		linknext = "0127_00361",
		line = 5194,
	},
	["0127_00361"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A noisy directionless conversation breaks out amongst the old folks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人们七嘴八舌地开始随意讨论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人們七嘴八舌地開始隨意討論。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00360",
		linknext = "0127_00362",
		line = 5206,
	},
	["0127_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Their excitement is somewhat hard for me to deal with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……老人们的情绪，我很难融入。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……老人們的情緒，我很難融入。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00361",
		linknext = "0127_00363",
		line = 5216,
	},
	["0127_00363"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I now know the reason why.",
					{"rt2"},
				},
			},
			cn = {
				{
					"理由我是知道的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"理由我是知道的。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00362",
		linknext = "0127_00364",
		line = 5226,
	},
	["0127_00364"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I used to despise these people from the bottom of my heart, but...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我心里明白，这些人是我应该怨恨的对象——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我心裡明白，這些人是我應該怨恨的對象——",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00363",
		linknext = "0127_00365",
		line = 5236,
	},
	["0127_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I've come to understand them, I can't hate them anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但实在恨不起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但實在恨不起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00364",
		linknext = "0127_00366",
		line = 5246,
	},
	["0127_00366"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2127", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah, I know a place! You know how's there's hot springs connected to that cave?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……那里怎么样！？就是那个跟洞窟相连的温泉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……那裡怎麼樣！？就是那個跟洞窟相連的溫泉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00365",
		linknext = "0127_00367",
		line = 5262,
	},
	["0127_00367"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... there should be a cabin there, and it's pretty much out of sight. It's still low tide right now, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……确实那里应该会有小屋，也不太引人注目，退潮路线也还可以用——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……確實那裡應該會有小屋，也不太引人注目，退潮路線也還可以用——」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00366",
		linknext = "0127_00368",
		line = 5274,
	},
	["0127_00368"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2128", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“And she'll be able to bathe whenever she wants! Let's go with there, then!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且如果想洗澡的话，还随时都可以泡温泉……！就这么办吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且如果想洗澡的話，還隨時都可以泡溫泉……！就這麼辦吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00367",
		linknext = "0127_00369",
		line = 5289,
	},
	["0127_00369"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can't rule out any pursuers making their way here to the settlement. I'll take Fumino there myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“追兵也可能来这里。我马上带文乃赶过去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「追兵也可能來這裡。我馬上帶文乃趕過去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00368",
		linknext = "0127_00370",
		line = 5301,
	},
	["0127_00370"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0064", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“If ya ever git inta a real tight spot, just holler and we'll help ya's! Even if we go senile, least we kin still do's feed ya! Hee hee hee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“有困难的话随时依靠我们哦！我们虽然老了，但一两顿饭还是能让你们吃上的，嘿嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「有困難的話隨時依靠我們哦！我們雖然老了，但一兩頓飯還是能讓你們吃上的，嘿嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00369",
		linknext = "0127_00371",
		line = 5315,
	},
	["0127_00371"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——————」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00370",
		linknext = "0127_00372",
		line = 5327,
	},
	["0127_00372"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't even know what to say, except...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不知道该说些什么——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不知道該說些什麼——",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00371",
		linknext = "0127_00373",
		line = 5337,
