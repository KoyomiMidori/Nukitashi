		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0295", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Shall we have a little chat?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“能说几句话吗？橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「能說幾句話嗎？橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00409",
		linknext = "0127_00411",
