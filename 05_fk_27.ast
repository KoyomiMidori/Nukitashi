		linkback = "0127_00140",
		linknext = "0127_00142",
		line = 1969,
	},
	["0127_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He said he'd get to that as soon as I did some basic warm-up exercises first.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手嶋先生在完成一连串的准备运动后如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手嶋先生在完成一連串的準備運動後如此說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00141",
		linknext = "0127_00143",
		line = 1979,
	},
	["0127_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Up until now I've been doing fundamentals, but it's been a little different to that of the physical approach of the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前一直在进行着基础训练，但那与FS的体力训练有所不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之前一直在進行著基礎訓練，但那與FS的體力訓練有所不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00142",
		linknext = "0127_00144",
		line = 1989,
	},
	["0127_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This person has been taking serious consideration of how many enemies there are, how to outwit them psychologically, and catch them by surprise.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人教的是窥视对方的心理，重视如何攻其不备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個人教的是窺視對方的心理，重視如何攻其不備。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00143",
		linknext = "0127_00145",
		line = 1999,
	},
	["0127_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How to fool your opponent in actual battle and strategy, and how to get the better of them in ways beside fighting fair and square— these ideas form the basis of his approach.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不仅仅是实际战斗方面，在战略方面也很重视“如何欺骗对方，用正攻法以外的方式获胜”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不僅僅是實際戰鬥方面，在戰略方面也很重視「如何欺騙對方，用正攻法以外的方式獲勝」。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00144",
		linknext = "0127_00146",
		line = 2009,
	},
	["0127_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At last, my villainous training has begun in earnest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后反派角色的特训，终于要正式开始了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後反派角色的特訓，終於要正式開始了。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00145",
		linknext = "0127_00147",
		line = 2019,
	},
	["0127_00147"] = {
