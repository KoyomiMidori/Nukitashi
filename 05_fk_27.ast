	["0127_00421"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00111", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0300", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Well, that's what I would like to say, but as you just saw, I mean nothing to her now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……虽然我想这样说，但就像你看到的那样，我和她已经没有任何关系了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……雖然我想這樣說，但就像你看到的那樣，我和她已經沒有任何關係了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00420",
