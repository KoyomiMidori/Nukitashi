	["0127_00499"] = {
		{"bgm", file="bgm26", vol=100},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1248", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I've lived my whole life... watching this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“——我一直……都是看着这个岛生活的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「——我一直……都是看著這個島生活的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00498",
		linknext = "0127_00500",
		line = 7018,
	},
	["0127_00500"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1249", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I know what the islanders look like... smiling and living happily.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“然后，我注意到了……岛上人们的笑容……还有他们过得很开心……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「然後，我注意到了……島上人們的笑容……還有他們過得很開心……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00499",
		linknext = "0127_00501",
		line = 7030,
	},
	["0127_00501"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1250", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I do not doubt that this island became a place which granted them all happiness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这个岛，一定是……为了大家的幸福而被创造出来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這個島，一定是……為了大家的幸福而被創造出來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00500",
		linknext = "0127_00502",
		line = 7042,
	},
	["0127_00502"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1251", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Mother knew that... That's why she didn't hold any grudges against anyone...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“妈妈也知道这件事……正因为如此，她才没有责怪任何人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「媽媽也知道這件事……正因為如此，她才沒有責怪任何人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00501",
		linknext = "0127_00503",
		line = 7056,
	},
	["0127_00503"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
