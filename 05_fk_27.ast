				{
					"被外祖父執著地盯著。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00508",
		linknext = "0127_00510",
		line = 7137,
	},
	["0127_00510"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now the entire country knows about her, and she has no privacy to speak of.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在个人信息还被全体国民知道了，失去了所谓的个人隐私。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在個人資訊還被全體國民知道了，失去了所謂的個人隱私。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00509",
		linknext = "0127_00511",
		line = 7147,
	},
	["0127_00511"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She has faced endless hardships.",
					{"rt2"},
				},
			},
			cn = {
				{
					"甚至经历了很多痛苦的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"甚至經歷了很多痛苦的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00510",
		linknext = "0127_00512",
		line = 7157,
	},
	["0127_00512"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1254", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But I still... harbor no resentment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“可是，我……果然没有……怨恨的心情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「可是，我……果然沒有……怨恨的心情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00511",
		linknext = "0127_00513",
		line = 7171,
	},
	["0127_00513"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet, she can still say that with such calmness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但，文乃还是一直保持着面无表情，极度平静地说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但，文乃還是一直保持著面無表情，極度平靜地說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00512",
		linknext = "0127_00514",
		line = 7181,
	},
	["0127_00514"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1255", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm eternally grateful... to the mother who gave birth to me, the Shinto priest who raised me, the islanders, and all of the NLNS as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“生下我的母亲、养育我的宫司大人、岛上的人们、NLNS的各位……我打从心底感谢您们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「生下我的母親、養育我的宮司大人、島上的人們、NLNS的各位……我打從心底感謝您們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00513",
		linknext = "0127_00515",
		line = 7193,
	},
	["0127_00515"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gives thanks to everyone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感谢着所有的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感謝著所有的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00514",
		linknext = "0127_00516",
		line = 7203,
	},
	["0127_00516"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And why?",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00515",
		linknext = "0127_00517",
		line = 7213,
	},
	["0127_00517"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00107", file2="fumino_02m_00203", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=600, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1256", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Because they are all responsible... for bringing us together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所有的，这些事情……都是把文乃引导到淳之介同学身边的事物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所有的，這些事情……都是把文乃引導到淳之介同學身邊的事物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00516",
		linknext = "0127_00518",
		line = 7228,
	},
	["0127_00518"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
