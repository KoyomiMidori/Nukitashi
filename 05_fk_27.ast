		linkback = "0127_00518",
		linknext = "0127_00520",
		line = 7255,
	},
	["0127_00520"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's saying she really doesn't need anything more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要有那个，文乃真的什么都不需要。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要有那個，文乃真的什麼都不需要。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00519",
		linknext = "0127_00521",
		line = 7265,
	},
	["0127_00521"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That if there is no greater happiness than this...",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有比这更幸福的了，所以没有必要抱怨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有比這更幸福的了，所以沒有必要抱怨。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00520",
