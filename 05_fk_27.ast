		{"fg", file="fumino_02f_00001", file1="fumino_02f_00101", path=":fg/fumino_02f/", id=30, ch="文乃", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1242", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Junnosuke...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……淳之介、同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……淳之介、同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00466",
		linknext = "0127_00468",
		line = 6635,
	},
	["0127_00468"] = {
		{"se", id=0, stop=1, time=3000},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And Fumino steps in to take his place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像代替了他的位置一样，文乃走了过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像代替了他的位置一樣，文乃走了過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00467",
		linknext = "0127_00469",
		line = 6648,
	},
	["0127_00469"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She probably heard the whole discussion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概，刚才的话她都听到了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概，剛才的話她都聽到了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00468",
		linknext = "0127_00470",
		line = 6658,
	},
	["0127_00470"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How long have you known?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃是从什么时候开始注意到的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃是從什麼時候開始注意到的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00469",
		linknext = "0127_00471",
		line = 6670,
	},
	["0127_00471"] = {
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", file2="fumino_02m_00202", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1243", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I first suspected as much... when you spoke to me at the shrine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那时，您在神社跟我搭话的时候……我就在想，应该是这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那時，您在神社跟我搭話的時候……我就在想，應該是這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00470",
		linknext = "0127_00472",
		line = 6686,
	},
	["0127_00472"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you kept quiet about it for me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没说出来……是为了我，对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒說出來……是為了我，對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00471",
		linknext = "0127_00473",
		line = 6698,
	},
	["0127_00473"] = {
		{"text"},
		delay = {
			[12500] = {
				{"bg", id=1, file="bg13_1l_00000", x=0, y=0, path=":bg/", sync=0, delay2=12500, time=300, ax=1280, ay=730, bx=-480, by=-280},
				{"fg", file="fumino_01l_00001", file2="fumino_01l_00202", file3="fumino_01l_00313", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, delay2=12500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine", delay2=12500},
				{"se", id=0, loop=0, file="se_a098", delay2=12500},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino1244", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I thought it might unnecessarily bring up... harsh old memories... I'm terribly sorr— mmph.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我认为……没必要再次提起……您过去痛苦的事情……对不起——呜啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我認為……沒必要再次提起……您過去痛苦的事情……對不起——嗚啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00472",
		linknext = "0127_00474",
		line = 6716,
	},
	["0127_00474"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00116", file2="fumino_01l_00203", path=":fg/fumino_01l/", id=7, lv=5, head="fumino_01l", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=2, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
