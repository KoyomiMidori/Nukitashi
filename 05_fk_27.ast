	["0127_00400"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Uncharacteristically, she has a very clear frown on her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃难得露骨地皱起了眉头。",
					{"rt2"},
