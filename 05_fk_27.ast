					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女D", "Female A"},
					"“So sex is punishable by violence now? This government's lost its fucking mind! What a bunch of fascists!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女D", "A女"},
					"“做爱会遭受暴力什么的……！这样的政治太奇怪了……！太松弛了……！”",
