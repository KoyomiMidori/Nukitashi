	["0127_00171"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00114", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0343", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Listen. Yer trainin' goin' forward's designed ta make yer junk robust along its entire length.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“听好了，现在要进行的，是将你鸡巴的力量转化到全身的修行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「聽好了，現在要進行的，是將你肉棒的力量轉化到全身的修行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00170",
		linknext = "0127_00172",
		line = 2398,
	},
	["0127_00172"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00104", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0344", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“This'd all be fer nowt if yer junk weren't strong ta begin wit'. Ya definitely got more power in 'er now... but it still ain't anywhere near enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“但就算要这样做，也要先有坚韧的鸡巴才行。虽然你的东西原先就很强大……但还远远不够。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「但就算要這樣做，也要先有堅韌的肉棒才行。雖然你的東西原先就很強大……但還遠遠不夠。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00171",
		linknext = "0127_00173",
		line = 2412,
	},
