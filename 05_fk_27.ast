					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even those people loved the perverted sex law and revered Mr. Hitoura as a god.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就连这些人，也热爱着变态条例，并把仁浦先生赞颂为神。",
					{"rt2"},
				},
			},
			tw = {
