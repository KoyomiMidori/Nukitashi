	["0127_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I escape from the gloomy atmosphere of the classroom, and head to one particular location.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我脱离了弥漫着昏暗氛围的教室，朝某个地方走去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我脫離了瀰漫著昏暗氛圍的教室，朝某個地方走去。",
