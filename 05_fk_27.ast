			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Being with you... is the greatest privilege I could possibly have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“能在您身边……这才是我的荣耀。”",
