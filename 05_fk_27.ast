			},
			cn = {
				{
					"也许是因为各组织之间缺乏联系，所以他们才会这样一出现就受到严厉的制裁，然后消失。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許是因為各組織之間缺乏聯繫，所以他們才會這樣一出現就受到嚴厲的制裁，然後消失。",
					{"rt2"},
				},
