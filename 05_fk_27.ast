					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's not like anyone can call getting you to shoot all 10 of them through a smoke screen wise strategy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要让你在烟雾中狙击10个人，根本连作战都算不上……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要讓你在煙霧中狙擊10個人，根本連作戰都算不上……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00386",
		linknext = "0127_00388",
