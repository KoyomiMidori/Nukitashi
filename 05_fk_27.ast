		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Across the globe, the headlines scream with lament. “SEIRAN ISLAND'S 'BRAVE YOUNG GIRL' MISSING! WHERE HAS SHE GONE?”",
					{"rt2"},
				},
			},
			cn = {
				{
					"“消失的受害少女。那孩子现在在哪里？”等宣传语正引起话题。",
					{"rt2"},
				},
			},
			tw = {
				{
