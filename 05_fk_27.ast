		{"bgm", file="bgm11", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0333", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Right. Today we're gonna get to the real shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
