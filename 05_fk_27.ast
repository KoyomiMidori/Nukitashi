	["0127_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It wasn't just non-virgins, but all the islanders that hurt my savior. I loathed them all from the bottom of my heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不只是非处女，还有伤害自己恩人们的居民，我打从心底讨厌他们。",
					{"rt2"},
				},
