	["0127_00337"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So even on this island, people like him exist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……岛上也有这种人啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……島上也有這種人啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00336",
		linknext = "0127_00338",
		line = 4900,
	},
	["0127_00338"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They're nothing like those nouveau riche assholes who made money off the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人们，和所谓因为变态条例而成为富翁的青蓝暴发户不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人們，和所謂因為變態條例而成為富翁的青藍暴發戶不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00337",
		linknext = "0127_00339",
		line = 4910,
	},
	["0127_00339"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If anything, they were driven out of their homes and forced to relocate in the mountains.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反而是被赶出住处，被迫搬到深山里的原住民。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反而是被趕出住處，被迫搬到深山裡的原住民。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00338",
		linknext = "0127_00340",
		line = 4920,
	},
	["0127_00340"] = {
