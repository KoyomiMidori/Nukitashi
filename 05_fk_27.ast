				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You can't have her...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我不会把女儿交给你的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我不會把女兒交給你的……」",
