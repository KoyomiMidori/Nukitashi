	["0127_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unfortunately, every group like this that pops up is treated the same as any other— with severe violence. They then vanish just as quickly as they popped up.",
					{"rt2"},
