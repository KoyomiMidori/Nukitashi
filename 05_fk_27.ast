	},
	["0127_00475"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not that weak anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我已经没有那么脆弱了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我已經沒有那麼脆弱了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00474",
		linknext = "0127_00476",
		line = 6742,
	},
	["0127_00476"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If anything, I've always wanted to open up about my savior.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反而还想把恩人的事情告诉你呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「反而還想把恩人的事情告訴你呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00475",
		linknext = "0127_00477",
		line = 6753,
	},
	["0127_00477"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=200},
		{"bg", id=1, file="bg13_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=7, act="振動下", loop=1, size=5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It would probably have been difficult for me to accept that at the time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对以前的我来说，这应该是很难接受的事实吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對以前的我來說，這應該是很難接受的事實吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00476",
		linknext = "0127_00478",
		line = 6768,
	},
	["0127_00478"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In fact, I'd probably have felt like making up for it to my savior's daughter somehow, in a roundabout way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不对，或许——我还会一味地想要报答恩人的女儿吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不對，或許——我還會一味地想要報答恩人的女兒吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00477",
		linknext = "0127_00479",
		line = 6778,
	},
	["0127_00479"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But not anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是现在不同了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是現在不同了。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00478",
		linknext = "0127_00480",
		line = 6788,
	},
	["0127_00480"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now I can stare reality in the face and accept it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我冷静地接受了事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我冷靜地接受了事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00479",
		linknext = "0127_00481",
		line = 6798,
	},
	["0127_00481"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Your mother was a very kind person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃的母亲……真是个温柔的人啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃的母親……真是個溫柔的人啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00480",
		linknext = "0127_00482",
		line = 6810,
	},
	["0127_00482"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00107", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1245", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes, very... She was occasionally very strict, but she was a truly kind mother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……虽然也有严厉的时候……不过，真的……是个非常温柔的母亲……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……雖然也有嚴厲的時候……不過，真的……是個非常溫柔的母親……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00481",
		linknext = "0127_00483",
		line = 6824,
	},
	["0127_00483"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1246", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“She would always be with me to console me during harsh times, telling me, 'you are a strong young girl.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我痛苦的时候……她总是在我身边安慰我……说‘文乃是个坚强的女孩’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我痛苦的時候……她總是在我身邊安慰我……說『文乃是個堅強的女孩』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00482",
		linknext = "0127_00484",
		line = 6838,
	},
	["0127_00484"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=600},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The way she said that was in the manner her mother spoke.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的口头禅，是出自母亲说过的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的口頭禪，是出自母親說過的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00483",
		linknext = "0127_00485",
		line = 6850,
	},
	["0127_00485"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure she believed her words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃一定很相信母亲说的话吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃一定很相信母親說的話吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00484",
		linknext = "0127_00486",
		line = 6860,
	},
	["0127_00486"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That she was strong, so she would always be fine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为自己很坚强，所以没事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為自己很堅強，所以沒事。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00485",
		linknext = "0127_00487",
		line = 6870,
	},
	["0127_00487"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That probably kept her going after she lost her mother and was left alone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那句话——一直支撑着失去了母亲，只剩孤身一人的文乃吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那句話——一直支撐著失去了母親，只剩孤身一人的文乃吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00486",
		linknext = "0127_00488",
		line = 6880,
	},
	["0127_00488"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was always working in the illegal sex industry for Fumino's sake.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃的母亲为了生活，一直从事着地下风俗的工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃的母親為了生活，一直從事著地下風俗的工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00487",
		linknext = "0127_00489",
		line = 6890,
	},
	["0127_00489"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And the people around her looked down upon her, maligned her, and pressured her until she became ill... and she died soon after.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后受到周围的白眼，诋毁，还有压力而得病……早逝了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後受到周圍的白眼，詆毀，還有壓力而得病……早逝了。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00488",
		linknext = "0127_00490",
		line = 6900,
	},
	["0127_00490"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You were probably protecting the islanders out of a sense of atonement for the law your father created.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃对创造了条例的父亲……作为波及到大家的赎罪，一直在保护岛上的人对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……文乃對創造了條例的父親……作為波及到大家的贖罪，一直在保護島上的人對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00489",
		linknext = "0127_00491",
		line = 6913,
	},
	["0127_00491"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know that now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"知道了这件事，我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"知道了這件事，我。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00490",
		linknext = "0127_00492",
		line = 6923,
	},
	["0127_00492"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And yet at the same time, the islanders would be holding a grudge against you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但与此同时，青蓝岛的人们……对文乃来说应该也是仇人啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但與此同時，青藍島的人們……對文乃來說應該也是仇人啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00491",
		linknext = "0127_00493",
		line = 6935,
	},
	["0127_00493"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to ask her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还是忍不住想这样问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還是忍不住想這樣問。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00492",
		linknext = "0127_00494",
		line = 6945,
	},
	["0127_00494"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Whether she despises the islanders.",
					{"rt2"},
				},
			},
			cn = {
				{
					"问她“你不恨岛上的人吗？”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"問她「你不恨島上的人嗎？」。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00493",
		linknext = "0127_00495",
		line = 6955,
	},
	["0127_00495"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you okay with that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……文乃，这样没关系吗？”",
