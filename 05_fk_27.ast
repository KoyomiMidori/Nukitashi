					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I shall be going on ahead. Now, if you'll excuse me.”",
					{"rt2"},
				},
