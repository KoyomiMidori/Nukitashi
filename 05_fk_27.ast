		linknext = "0127_00496",
		line = 6968,
	},
	["0127_00496"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She didn't even show any hesitation in response to that question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对我的问题，文乃甚至没有一点犹豫。",
					{"rt2"},
