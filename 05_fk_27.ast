	["0127_00335"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00202", file3="misaki_01m_00302", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2125", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, please. All you did was shout 'Elder abuse! Help, help, I'm bein' repressed!' and make a huge scene out of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“在说什么呢，你不就是喊着‘虐待老人啊！’把现场弄得乱七八糟而已吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「在說什麼呢，你不就是喊著『虐待老人啊！』把現場弄得亂七八糟而已嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00334",
		linknext = "0127_00336",
		line = 4878,
	},
	["0127_00336"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, no. You were a lifesaver, really... Thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，真是……帮了我大忙，非常感谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，真是……幫了我大忙，非常感謝。」",
					{"rt2"},
				},
			},
		},
