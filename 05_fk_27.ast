		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Turns out, that place famous for its ultra-perverted rides is being demolished today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那里的变态专用游乐设施，今天要被撤掉了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡的變態專用遊樂設施，今天要被撤掉了。",
