		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=50000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As Senator Hitoura has been completely deposed, the media are clinging like barnacles to the school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随着仁浦先生正式辞职，学校周围到处都是媒体。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨著仁浦先生正式辭職，學校周圍到處都是媒體。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00115",
		linknext = "0127_00117",
		line = 1635,
	},
	["0127_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They also seem to have worked out the layout of the island as well, and there's even a crowd of reporters at the rear gate that connects to the forest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些人似乎也稍微习惯了岛上的地形，采访团一直站在通往森林的后门。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些人似乎也稍微習慣了島上的地形，採訪團一直站在通往森林的後門。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00116",
		linknext = "0127_00118",
		line = 1645,
	},
	["0127_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are even guards posted throughout the school grounds, and they're always unpredictable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学校里到处都有警备兵，随时都要保持警惕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學校裡到處都有警備兵，隨時都要保持警惕。",
