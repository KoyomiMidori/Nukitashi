		line = 1423,
	},
	["0127_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they demolish all the other major facilities on the island the same way, the island should return back to its former tranquility.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果按照这样的进度进行拆除，那么青蓝岛将取回原来的静谧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果按照這樣的進度進行拆除，那麼青藍島將取回原來的靜謐。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00099",
		linknext = "0127_00101",
		line = 1433,
	},
	["0127_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But at the same time, many residents will lose their jobs and be deprived of a living.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是与此同时，很多居民都将失去工作，失去生活的依靠。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是與此同時，很多居民都將失去工作，失去生活的依靠。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00100",
