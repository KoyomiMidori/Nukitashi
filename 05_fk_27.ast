	["0127_00447"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The person she desired to be with, and the woman that he would never be able to marry and live with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无法和希望呆在对方身边的人白头偕老的女性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無法和希望待在對方身邊的人白頭偕老的女性。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00446",
		linknext = "0127_00448",
		line = 6368,
	},
	["0127_00448"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She always remained in a slightly remote location, always looking into the distance, searching for someone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以才在稍远处，像在不停寻找着某个人而盯着远方的女性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以才在稍遠處，像在不停尋找著某個人而盯著遠方的女性。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00447",
		linknext = "0127_00449",
		line = 6378,
	},
	["0127_00449"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the remnants of her memory gave rise to something much bigger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"违和感的影子变得更加巨大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"違和感的影子變得更加巨大。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00448",
		linknext = "0127_00450",
		line = 6388,
	},
	["0127_00450"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0313", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It was I who killed her mother. The law I created, the money trafficking, and the people themselves— they all killed her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是我杀了她的母亲。是我创造的条例、资金流动，以及人们，杀了她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是我殺了她的母親。是我創造的條例、資金流動，以及人們，殺了她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00449",
		linknext = "0127_00451",
		line = 6402,
	},
	["0127_00451"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0314", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Even if she hadn't worked in the illegal sex industry, she intended for me to not find her. It must have been a harsh decision for her to make.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“她不得不从事地下风俗的工作，也是为了不让我发现她的身影。应该是个很痛苦的决定吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「她不得不從事地下風俗的工作，也是為了不讓我發現她的身影。應該是個很痛苦的決定吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00450",
		linknext = "0127_00452",
		line = 6414,
	},
	["0127_00452"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0315", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I was cowardly and weak, and she distanced herself from me. Tried to spur me on while raising the girl. And that eventually did her in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“她借由与不中用又软弱的我拉开距离，来激励我，并独自抚养女儿——但她却死了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「她藉由與不中用又軟弱的我拉開距離，來激勵我，並獨自撫養女兒——但她卻死了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00451",
		linknext = "0127_00453",
		line = 6428,
	},
