		},
		linkback = "0127_00096",
		linknext = "0127_00098",
		line = 1399,
	},
	["0127_00098"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0315", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female A"},
					"“That was the only source of work I had... How am I supposed to feed my family now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "A女"},
					"“唯一的工作……我们的家人……从明天开始，该怎么活下去呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "A女"},
					"「唯一的工作……我們的家人……從明天開始，該怎麼活下去呢……？」",
