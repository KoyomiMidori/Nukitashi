	["0127_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We'd done a thorough search with the Penile Investigator, but until now, it didn't look like anything more than a big chunk of rock.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许是因为最近为了制造“珍神”而彻底调查过的缘故，此前只觉得是块岩石的东西，",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許是因為最近為了製造「珍神」而徹底調查過的緣故，此前只覺得是塊岩石的東西，",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00129",
		linknext = "0127_00131",
		line = 1805,
	},
	["0127_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can definitely make out the form of a fighter plane now, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在现在的我的眼里看来，确实是一台战斗机。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在現在的我的眼裡看來，確實是一臺戰鬥機。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00130",
		linknext = "0127_00132",
		line = 1815,
	},
	["0127_00132"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come to think of it, I seem to recall a discussion about there being an old plane here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……话说回来，我好像听说过这里有老飞机是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……話說回來，我好像聽說過這裡有老飛機是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00131",
		linknext = "0127_00133",
		line = 1827,
	},
	["0127_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What was it called again? Oh yeah, the Seiran Prototype. A floatplane intended for aerial attacks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"机体名为——水上攻击机“试制晴岚”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"機體名為——水上攻擊機「試製晴嵐」。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00132",
		linknext = "0127_00134",
		line = 1837,
	},
	["0127_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They say a legendary plane rests in this spot. Perhaps because it has the same name as the island itself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知道是不是因为发音和岛的名字相同，有听说过有架梦幻机体沉睡于此地。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道是不是因為發音和島的名字相同，有聽說過有架夢幻機體沉睡於此地。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00133",
		linknext = "0127_00135",
		line = 1847,
	},
	["0127_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe it's because this dimly lit cavern connects to the open ocean?",
					{"rt2"},
				},
			},
			cn = {
				{
					"会在这么昏暗的洞穴里，是因为和大海相连吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"會在這麼昏暗的洞穴裡，是因為和大海相連嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00134",
		linknext = "0127_00136",
		line = 1857,
	},
	["0127_00136"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Looks like it's pretty neglected... Would it fly if we were able to repair it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“相当破旧啊……不过如果修理一下，能动吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「相當破舊啊……不過如果修理一下，能動嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00135",
		linknext = "0127_00137",
		line = 1870,
	},
	["0127_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I doubt there are many engineers out there who could repair it, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是这里应该没有会修理的技师吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是這裡應該沒有會修理的技師吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00136",
		linknext = "0127_00138",
		line = 1880,
	},
	["0127_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe that's why they couldn't repurpose it as a tourist attraction or something...",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛没能很好地利用旅游资源，也许也正是这个原因造成的吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島沒能很好地利用旅遊資源，也許也正是這個原因造成的吧——",
					{"rt2"},
				},
			},
		},
