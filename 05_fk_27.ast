	["0127_00184"] = {
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I drag my sorry ass out of his hideaway and finally make it home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"拖着破破烂烂的身体，终于回到了家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"拖著破破爛爛的身體，終於回到了家。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00183",
