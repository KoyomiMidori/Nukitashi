			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What I mean to say is, well...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，那个，也就是说……”",
