	},
	["0127_00384"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You'd almost never believe she's able to hold a big-ass sniper rifle in one hand. In the middle of battle, even.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我实在无法想像这孩子能够单手拿着狙击步枪大显身手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我實在無法想像這孩子能夠單手拿著狙擊步槍大顯身手。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00383",
		linknext = "0127_00385",
		line = 5526,
	},
	["0127_00385"] = {
		{"se", id=0, loop=0, file="se_a024"},
		{"fg", file="fumino_02f_00001", file1="fumino_02f_00113", file2="fumino_02f_00202", path=":fg/fumino_02f/", id=30, ch="文乃", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1237", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I apologize for what happened earlier. Not only didn't I live up to your expectations, but I ended up dragging you down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……刚才真是对不起……没能满足淳之介同学的期待……反而……成了累赘……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……剛才真是對不起……沒能滿足淳之介同學的期待……反而……成了累贅……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00384",
		linknext = "0127_00386",
		line = 5540,
	},
	["0127_00386"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you talking about? I should be sorry too. I was too dependent on your own skills.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在说什么。是我太依赖文乃的能力了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你在說什麼。是我太依賴文乃的能力了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00385",
		linknext = "0127_00387",
		line = 5552,
	},
	["0127_00387"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
