		{"fgact", ch="手嶋", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0335", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Oh. Plain t'see how an amateur little shit like you could get the fundamentals down so easily, then. Musta been trainin' every day or somethin'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啊，怪不得你明明只是个外行人，却有这么好的基础……看来每天都在训练啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啊，怪不得你明明只是個外行人，卻有這麼好的基礎……看來每天都在訓練啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00149",
		linknext = "0127_00151",
		line = 2077,
	},
	["0127_00151"] = {
