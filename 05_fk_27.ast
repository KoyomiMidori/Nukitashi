	["0127_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No doubt Sakimori's thugs are on the hunt for her too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且防人老人派遣的警备兵们又一直在寻找文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且防人老人派遣的警備兵們又一直在尋找文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00053",
		linknext = "0127_00055",
		line = 770,
	},
	["0127_00055"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I feel bad keeping you cooped up in here... I'm really sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“强迫你过难以喘息的生活，真对不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「強迫你過難以喘息的生活，真對不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00054",
		linknext = "0127_00056",
		line = 782,
	},
	["0127_00056"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1206", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No. Being able to live here is happiness incarnate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不……我只要能在这里就很幸福了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不……我只要能在這裡就很幸福了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00055",
		linknext = "0127_00057",
		line = 797,
	},
	["0127_00057"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1207", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I should be apologizing most humbly to you, for being unable to attend to your needs. I hope you can find it in your heart to forgive me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“比起那个……非常抱歉没办法照顾您……请原谅我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「比起那個……非常抱歉沒辦法照顧您……請原諒我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00056",
		linknext = "0127_00058",
		line = 812,
	},
	["0127_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gives us a bow in her usual reverent manner.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃像往常一样充满敬畏，恭恭敬敬地行了个礼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃像往常一樣充滿敬畏，恭恭敬敬地行了個禮。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00057",
		linknext = "0127_00059",
		line = 822,
	},
	["0127_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look. You really don't need to think of yourself as our servant anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……没有必要像以前那样当佣人了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……沒有必要像以前那樣當傭人了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00058",
		linknext = "0127_00060",
		line = 834,
	},
	["0127_00060"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haven't I told you? You're part of our family now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我不是说过你已经是我们的家人了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我不是說過你已經是我們的家人了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00059",
		linknext = "0127_00061",
		line = 846,
	},
	["0127_00061"] = {
