		line = 2599,
	},
	["0127_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Teshima dragged me through hell with his training regime, rendering my body, soul, and junk all limp.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那之后，我持续受到手嶋地狱般的折磨好几个小时，身心都被搞得精疲力尽。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從那之後，我持續受到手嶋地獄般的折磨好幾個小時，身心都被搞得精疲力盡。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00184",
