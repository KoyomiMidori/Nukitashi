				{"vo", file="fumino1252", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“And so, bound as I am to her by blood... I wish to accept everything in this world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以，继承了她的血液的我——想要原谅这一切。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以，繼承了她的血液的我——想要原諒這一切。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00502",
		linknext = "0127_00504",
		line = 7070,
	},
	["0127_00504"] = {
		{"text"},
		text = {
