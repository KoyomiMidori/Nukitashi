		line = 6113,
	},
	["0127_00427"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did you love about her mother?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你是爱上了文乃母亲的哪里？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你是愛上了文乃母親的哪裡？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00426",
		linknext = "0127_00428",
		line = 6125,
	},
	["0127_00428"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0303", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It's not easy to put into words, but if I had to... I admired how she held herself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“很难表达。不过硬要说的话——是她的举止。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「很難表達。不過硬要說的話——是她的舉止。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00427",
		linknext = "0127_00429",
		line = 6139,
	},
	["0127_00429"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0304", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“She was a very fragile woman. And yet, there was a powerful determination hidden within her eyes. Her eyes held unparalleled beauty, just like the girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“她是个非常纤弱的女人，可是眼睛里却隐藏着坚强的意志。和那个孩子一样，她有着绝代的眼睛——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「她是個非常纖弱的女人，可是眼睛裡卻隱藏著堅強的意志。和那個孩子一樣，她有著絕代的眼睛——」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00428",
		linknext = "0127_00430",
		line = 6153,
	},
	["0127_00430"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He waxes philosophical about her eyes, saying their color is unlike what anyone else on this earth has.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“那根本是不存在于世上的瞳色”仁浦先生说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「那根本是不存在於世上的瞳色」仁浦先生說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00429",
		linknext = "0127_00431",
		line = 6163,
	},
	["0127_00431"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And that it wasn't her pale hair, but those eyes, that left a powerful impression upon him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不是那奇特的淡色头发，而是那双眼睛，给了他深刻的印象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不是那奇特的淡色頭髮，而是那雙眼睛，給了他深刻的印象。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00430",
		linknext = "0127_00432",
		line = 6173,
	},
	["0127_00432"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As he tells me that...",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到这些，我——",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到這些，我——",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00431",
		linknext = "0127_00433",
		line = 6183,
	},
	["0127_00433"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A strong feeling of deja vu washes over me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"又受到了强烈既视感的折磨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"又受到了強烈既視感的折磨。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00432",
		linknext = "0127_00434",
		line = 6193,
	},
	["0127_00434"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I heard that you forced yourself on her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我听说……你硬是让文乃的母亲怀孕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我聽說……你硬是讓文乃的母親懷孕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00433",
		linknext = "0127_00435",
		line = 6205,
	},
	["0127_00435"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0305", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I suppose I did steal her away. I did pull such a young, naive girl away from her parents by force.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我的确夺走了她。把年纪还小，不懂事的她，从娘家强硬地夺走了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我的確奪走了她。把年紀還小，不懂事的她，從娘家強硬地奪走了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00434",
		linknext = "0127_00436",
		line = 6219,
	},
	["0127_00436"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0306", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“And yet, I believe for certain that our love was mutual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是即便如此，我们之间也确实存在着爱——我是这么认为的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是即便如此，我們之間也確實存在著愛——我是這麼認為的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00435",
		linknext = "0127_00437",
		line = 6233,
	},
	["0127_00437"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There is a wistfulness in his voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生话锋一转。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生話鋒一轉。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00436",
		linknext = "0127_00438",
		line = 6243,
	},
	["0127_00438"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0307", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But having her with me gave me thoughts of giving up on redeveloping the island. That was how much she meant to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果有那个人在，岛的发展我也可以放弃……当时致力于这一切的我，是这样想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果有那個人在，島的發展我也可以放棄……當時致力於這一切的我，是這樣想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00437",
		linknext = "0127_00439",
		line = 6255,
	},
	["0127_00439"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00115", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0308", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“She saw right through that. And then, just when she was about to finally find a normal and happy life for herself, she threw everything away, to become but an empty shell.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是她却看穿了这一切。她知道，如果我就这样放弃一切，得到一般的幸福，最终也只会成为一具空壳——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是她卻看穿了這一切。她知道，如果我就這樣放棄一切，得到一般的幸福，最終也只會成為一具空殼——」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00438",
		linknext = "0127_00440",
		line = 6269,
	},
	["0127_00440"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0309", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Do you recall how I told you that the people of this island are naught but rubes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——橘君，你还记得我说过这个岛的人很愚蠢吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——橘君，你還記得我說過這個島的人很愚蠢嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00439",
		linknext = "0127_00441",
		line = 6283,
	},
	["0127_00441"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I do recall.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我记得。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我記得。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00440",
		linknext = "0127_00442",
		line = 6293,
	},
	["0127_00442"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was his justification for allowing them to be used.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他说过正因为如此，岛上的人即使被利用也不能抱怨——",
					{"rt2"},
				},
			},
			tw = {
				{
					"他說過正因為如此，島上的人即使被利用也不能抱怨——",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00441",
		linknext = "0127_00443",
		line = 6303,
	},
	["0127_00443"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0310", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The pressure from the islanders killed that girl's mother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那孩子的母亲，是因为岛民的压力才被杀害的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那孩子的母親，是因為島民的壓力才被殺害的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00442",
		linknext = "0127_00444",
		line = 6317,
	},
	["0127_00444"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00443",
		linknext = "0127_00445",
		line = 6330,
	},
	["0127_00445"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0311", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Even after she left me, she stayed on this island. To leave the island, you have to pass an inspection. Perhaps that's why she stayed hidden away, so that I wouldn't find her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“离开我之后，她也继续在这个岛上生活着。出青蓝岛必须审查，所以她一直潜伏着，不让我发现——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「離開我之後，她也繼續在這個島上生活著。出青藍島必須審查，所以她一直潛伏著，不讓我發現——」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00444",
		linknext = "0127_00446",
		line = 6344,
	},
	["0127_00446"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00111", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0312", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Or perhaps she just wanted to observe me from afar. Heh, though that sounds more like wishful thinking on my part.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——或许她还会在远处眺望着我的身影呢。……呵，这也只是我自私的妄想而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——或許她還會在遠處眺望著我的身影呢。……呵，這也只是我自私的妄想而已。」",
					{"rt2"},
