	},
	["0127_00405"] = {
		{"se", id=0, loop=0, file="se_a024"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00128", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=600},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She turns away haughtily, like a rebellious teenage girl. Which I suppose she is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像叛逆期的女儿般——实际上就是这样——她马上转头就走。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像叛逆期的女兒般——實際上就是這樣——她馬上轉頭就走。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00404",
		linknext = "0127_00406",
		line = 5806,
	},
	["0127_00406"] = {
