		line = 1443,
	},
	["0127_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I despised the islanders.",
					{"rt2"},
				},
			},
