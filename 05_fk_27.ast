					"The only time she's been startled before was when she was showered with camera flashes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到目前为止，曾让这孩子吃惊的只有被相机的闪光灯照到的时候。",
					{"rt2"},
				},
			},
			tw = {
