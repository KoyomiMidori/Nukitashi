		{"msgoff", time=1},
		{"extrans", sync=0, time=1200, rule="eff_033_00000"},
		{"bgm", file="bgm01", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A few days later, Fumino had recovered to the point she could wake up on her own.",
					{"rt2"},
				},
			},
			cn = {
				{
					"几天后，文乃恢复到了自己能起身的状态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"幾天後，文乃恢復到了自己能起身的狀態。",
					{"rt2"},
				},
			},
		},
		linknext = "0127_00002",
		line = 19,
	},
	["0127_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her recovery was so quick that even the doctor was impressed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那恢复能力让医生也感到惊讶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那恢復能力讓醫生也感到驚訝。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00001",
		linknext = "0127_00003",
		line = 29,
	},
	["0127_00003"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you sure you're up to doing the housework?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过马上把家务交给你没关系吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過馬上把家事交給你沒關係嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00002",
		linknext = "0127_00004",
		line = 41,
	},
	["0127_00004"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00121", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1190", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Please leave it to me... I can't afford to lose my touch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“请交给文乃吧……不能让身手变迟钝……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「請交給文乃吧……不能讓身手變遲鈍……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00003",
		linknext = "0127_00005",
		line = 56,
	},
	["0127_00005"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=400},
		{"se", id=0, loop=1, file="se_a172"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can hear the rhythmical sounds.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我听到了有节奏的烹饪声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我聽到了有節奏的烹飪聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00004",
		linknext = "0127_00006",
		line = 69,
	},
	["0127_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sound brings back unusually fond memories and makes me happy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个音色莫名地令人怀念，令人高兴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個音色莫名地令人懷念，令人高興。",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00005",
		linknext = "0127_00007",
		line = 79,
	},
	["0127_00007"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a176", vol=50},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1191", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Here... I didn't have much time to prepare, so apologies for how meager it is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“请……因为没有准备的时间，所以只是个简单的料理……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「請……因為沒有準備的時間，所以只是個簡單的料理……」",
					{"rt2"},
				},
			},
		},
		linkback = "0127_00006",
		linknext = "0127_00008",
		line = 95,
	},
	["0127_00008"] = {
