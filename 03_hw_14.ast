					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事是个为了成功不惜干坏事的合理主义者。如果把文乃交给他，不知道会对她干出什么事来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事是個為了成功不惜幹壞事的合理主義者。如果把文乃交給他，不知道會對她幹出什麼事來。」",
