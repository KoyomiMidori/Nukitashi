	["0064_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As the leader of the NLNS, I infiltrated the SS with the ultimate goal of destroying the island's establishment from the inside.",
