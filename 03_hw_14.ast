		line = 331,
	},
	["0064_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Oh, sorry, I was just... thinking about something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃……？对不起……我在想事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃……？對不起……我在想事情。」",
					{"rt2"},
				},
