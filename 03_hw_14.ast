	["0064_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just waiting to hear from the strike team is incredibly frustrating. It feels like time is passing even slower than usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但等待是件令人着急的事，感觉时间比平时过得更慢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但等待是件令人著急的事，感覺時間比平時過得更慢。",
