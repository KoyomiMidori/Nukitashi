		{"bg", id=1, file="bg23_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0645", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tomorrow's your first day back. How was your time off? You rest well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“明天就要归队了。怎么样？有没有好好休息？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「明天就要歸隊了。怎麼樣？有沒有好好休息？」",
					{"rt2"},
				},
			},
		},
		linknext = "0064_00002",
		line = 44,
	},
	["0064_00002"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, it's been a while since I was able to let my hair down like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，好久没让我放松一下了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，好久沒讓我放鬆一下了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00001",
		linknext = "0064_00003",
		line = 56,
	},
	["0064_00003"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0646", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Right. I guess you haven't had much time to yourself since you joined the SS. I'm sure your sister must have been happy to have you around again, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是吗……在SS里的话有训练和活动很难休息啊……妹妹一定也很高兴吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是嗎……在SS裡的話有訓練和活動很難休息啊……妹妹一定也很高興吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00002",
		linknext = "0064_00004",
		line = 70,
	},
	["0064_00004"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not sure I'd put it that way. She was even needier than usual.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么说呢……我被她使唤得更勤了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼說呢……我被她使喚得更勤了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00003",
		linknext = "0064_00005",
		line = 82,
	},
	["0064_00005"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0647", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Haha, I'm sure she missed having you at home. Tachibana, as of tomorrow, you'll no longer be a cadet. You'll be an official SS member, which means you'll also be receiving the scholarship.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈！那不是在撒娇吗……橘，明天开始你就不再是训练生，而是SS的正式成员，这样你就可以得到奖学金了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈！那不是在撒嬌嗎……橘，明天開始你就不再是訓練生，而是SS的正式成員，這樣你就可以得到獎學金了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00004",
		linknext = "0064_00006",
		line = 98,
	},
	["0064_00006"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0648", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I'm sure it's hard for you and your sister to be living alone, and SS work isn't any easier. Knowing you, though, you'll find a way to handle it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“两个人的生活应该很辛苦，SS的工作也不轻松……不过，你的话应该不需要担心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「兩個人的生活應該很辛苦，SS的工作也不輕鬆……不過，你的話應該不需要擔心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00005",
		linknext = "0064_00007",
		line = 112,
	},
	["0064_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're giving me an awful lot of credit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你也太看重我了吧？”",
					{"rt2"},
				},
