	["0064_00286"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0412", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Aaah... That was scary, but it's so great that everyone's safe! Not only that, but we were able to save Fumino-chan, too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哇——虽然我很害怕，但是大家都平安无事真是太好了！文乃酱也平安获救了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哇——雖然我很害怕，但是大家都平安無事真是太好了！文乃醬也平安獲救了！」",
					{"rt2"},
				},
			},
		},
