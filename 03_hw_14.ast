				{"fg", file="rei_01m_00001", file1="rei_01m_00107", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0650", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Heh, maybe I'm just being coy. You're still inexperienced, but if nothing else, you're hardheaded enough to get through pretty much anything. You should be proud of that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈。因为你太谦虚了。虽然你还不成熟，但比别人更有毅力。要更有自信点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈。因為你太謙虛了。雖然你還不成熟，但比別人更有毅力。要更有自信點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00009",
		linknext = "0064_00011",
		line = 166,
	},
	["0064_00011"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, but you can just fight your way through anything no problem.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我觉得礼前辈就算面对100个人也能赢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我覺得禮前輩就算面對100個人也能贏。」",
