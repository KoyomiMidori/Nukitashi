				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Just like starting a race. On my shot, run towards 10 o'clock. Phew...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么……和赛跑一样——我一开枪，你就往10点钟方向冲出去……呼——”",
