	["0064_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The strike team will consist of the bulk of the SS forces, led by the company commander. It will lead the assault and open a path for the other squads to reach the summit and secure Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"中队长带领SS最强的攻击部队——强袭部队开辟活路，紧接着跟进的冲锋部队确保‘文乃’的安全”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"中隊長帶領SS最強的攻擊部隊——強襲部隊開闢活路，緊接著跟進的衝鋒部隊確保『文乃』的安全」。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00060",
		linknext = "0064_00062",
		line = 795,
	},
	["0064_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's it, really.",
					{"rt2"},
				},
			},
			cn = {
				{
					"简单地说就是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"簡單地說就是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00061",
		linknext = "0064_00063",
		line = 805,
	},
	["0064_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a straightforward plan, but it puts a lot of responsibility on the strike team.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然简单易懂，但强袭部队的压力很大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然簡單易懂，但強襲部隊的壓力很大。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00062",
		linknext = "0064_00064",
		line = 815,
	},
	["0064_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the strike team is unsuccessful, the entire strategy falls apart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果不相信他们的力量，是无法完成这个作战的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果不相信他們的力量，是無法完成這個作戰的。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00063",
		linknext = "0064_00065",
		line = 825,
	},
	["0064_00065"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0659", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I will be part of the second squad, heading to secure Fumino at the summit. The third squad will be dealing with the enemy forces divided by the strike team.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这次我也会跟随二队进行‘文乃’的安全确保。三队负责处理被强袭部队冲散的敌人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這次我也會跟隨二隊進行『文乃』的安全確保。三隊負責處理被強襲部隊衝散的敵人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00064",
		linknext = "0064_00066",
		line = 838,
	},
	["0064_00066"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0660", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana, you're with me. With all your one-on-one combat training, you're best suited to the second squad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘，你和我来吧。我们1对1训练了那么久，有办法联手吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘，你和我來吧。我們1對1訓練了那麼久，有辦法聯手吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00065",
		linknext = "0064_00067",
		line = 850,
	},
	["0064_00067"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Understood.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00066",
		linknext = "0064_00068",
		line = 862,
	},
	["0064_00068"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0661", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Let's get moving! Our objective is to secure Kotoyose Fumino! The future of the island rests on this operation's success! Remember, the enemy is using live ammunition, so I want to see everyone go home alive! Am I clear!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么——现在开始‘琴寄文乃确保作战’！这个作战关系着岛的去向！虽然敌人使用实枪，但大家一定要全部生还！知道了吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼——現在開始『琴寄文乃確保作戰』！這個作戰關係著島的去向！雖然敵人使用實槍，但大家一定要全部生還！知道了嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00067",
		linknext = "0064_00069",
		line = 876,
	},
	["0064_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And thus the battle for Fumino began.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这样，围绕“文乃”的战斗开始了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就這樣，圍繞「文乃」的戰鬥開始了。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00068",
		linknext = "0064_00070",
		line = 886,
