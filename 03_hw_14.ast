		linkback = "0064_00012",
		linknext = "0064_00014",
		line = 202,
	},
	["0064_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Looking back on the scornful, hostile looks she gave me during the entrance examination, being able to have a leisurely chat with her like this feels almost unreal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一想到入队考试时被充满敌意的目光瞪着，就觉得现在这样的畅谈很不真实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一想到入隊考試時被充滿敵意的目光瞪著，就覺得現在這樣的暢談很不真實。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00013",
		linknext = "0064_00015",
		line = 212,
	},
	["0064_00015"] = {
