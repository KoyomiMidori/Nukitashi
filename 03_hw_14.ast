	["0064_00049"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"ex", time=1000, func="wait"},
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, loop=1, file="se_d026", vol=60},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We use the SS and SHO's kinky play vehicle and made our way into the hills.",
					{"rt2"},
				},
			},
			cn = {
				{
					"乘坐着SS和SHO的魔镜号，我们来到了山中。",
