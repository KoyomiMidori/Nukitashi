	["0064_00244"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I need to remember that the person in front of me is evil. She's the disciplinary committee president, enforcing the perverted sex law. I can't let myself be led astray.",
					{"rt2"},
				},
			},
			cn = {
				{
					"眼前的，是推动变态条例的邪恶风纪委员长——我这样告诉自己的脑袋。",
					{"rt2"},
				},
			},
			tw = {
				{
					"眼前的，是推動變態條例的邪惡風紀委員長——我這樣告訴自己的腦袋。",
					{"rt2"},
				},
			},
		},
