		},
		linkback = "0064_00025",
		linknext = "0064_00027",
		line = 343,
	},
	["0064_00027"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00124", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0654", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You feeling all right? If you're still feeling the effects of the gunshot, your leave can be extended.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没事吧？如果中弹的影响还留着，也可以保险起见延长休息时间的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒事吧？如果中彈的影響還留著，也可以保險起見延長休息時間的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00026",
		linknext = "0064_00028",
		line = 357,
	},
