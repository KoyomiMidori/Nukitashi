		},
		linkback = "0064_00048",
		linknext = "0064_00050",
		line = 651,
	},
	["0064_00050"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg08_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0603", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“According to our lead, Kotoyose Fumino is currently engaged in battle with an external organization, and has been forced to retreat to the summit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“报告显示，‘琴寄文乃’正在与外部组织交战，被逼到了山顶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「報告顯示，『琴寄文乃』正在與外部組織交戰，被逼到了山頂。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00049",
		linknext = "0064_00051",
		line = 666,
	},
	["0064_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I assume the “external organization” in question is the Yakuza mentioned in the documents.",
					{"rt2"},
				},
			},
			cn = {
				{
					"外部组织，指的就是报告书中的黑社会吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"外部組織，指的就是報告書中的黑社會吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00050",
		linknext = "0064_00052",
		line = 676,
	},
	["0064_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But what does she mean by “engaged in battle”? Wasn't she two years younger than me?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，交战了？文乃应该是比我小两岁的少女……",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，交戰了？文乃應該是比我小兩歲的少女……",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00051",
		linknext = "0064_00053",
		line = 686,
	},
	["0064_00053"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0604", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Apparently, that same external organization also currently controls a portion of the SHO, likely linked to the brainwashing incident.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“一部分SHO似乎也跟随着外部组织行动。恐怕，是那个洗脑的影响吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「一部分SHO似乎也跟隨著外部組織行動。恐怕，是那個洗腦的影響吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00052",
		linknext = "0064_00054",
		line = 698,
	},
	["0064_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not important now. All that matters is what happens next.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再想也没用。现在要集中精神做眼前的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再想也沒用。現在要集中精神做眼前的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00053",
		linknext = "0064_00055",
		line = 708,
	},
	["0064_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the most crucial juncture.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在是关键时刻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在是關鍵時刻。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00054",
		linknext = "0064_00056",
		line = 718,
	},
	["0064_00056"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0605", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The enemy has been reported as using live ammunition. To ensure our safety, a strike team will be sent ahead to serve as a diversion. They will clear a path for the main force.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“收到对方使用实枪的报告。为了慎重起见，首先由强袭部队先行，诱导，扰乱……开辟道路。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「收到對方使用實槍的報告。為了慎重起見，首先由強襲部隊先行，誘導，擾亂……開闢道路。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00055",
		linknext = "0064_00057",
		line = 732,
	},
	["0064_00057"] = {
		{"fgact", ch="桐香", id=8, act="移動", x=-400, y=0, time=700},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00110", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="郁子", id=10, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0130", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Okay ♪ Then we can move onto the summit and capture Fumino-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“OK——♪直接到山顶去抓文乃酱就好了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「OK——♪直接到山頂去抓文乃醬就好了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00056",
		linknext = "0064_00058",
		line = 747,
	},
	["0064_00058"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00104", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0606", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, the strike team is strictly a diversion. You will lead the enemy forces away from the route to the summit and divide them up. Then, the other squads will converge on the individual groups, eliminating them one by one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不——强袭部队的目的是扰乱和诱导。让对方分不清我们前往山顶的行进路线，使敌人的战斗力分散……和各分队汇合并各个击破他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不——強襲部隊的目的是擾亂和誘導。讓對方分不清我們前往山頂的行進路線，使敵人的戰鬥力分散……和各分隊會合併各個擊破他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00057",
		linknext = "0064_00059",
		line = 761,
	},
	["0064_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The president's tone is the same as ever, even in such a serious discussion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是这种时候，说明作战的学生会长的语气也与平时没有变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是這種時候，說明作戰的學生會長的語氣也與平時沒有變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00058",
		linknext = "0064_00060",
		line = 771,
	},
	["0064_00060"] = {
