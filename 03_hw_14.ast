	["0064_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hidden in the shadows is a girl clad in traditional Japanese attire.",
					{"rt2"},
				},
			},
			cn = {
				{
					"阴影里，躲着一个穿着和服的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"陰影裡，躲著一個穿著和服的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00198",
		linknext = "0064_00200",
		line = 2821,
	},
	["0064_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks so dramatically out of place that I find myself captivated by her, despite the situation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那端正的容貌，让人几乎忘了目前的情况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那端正的容貌，讓人幾乎忘了目前的情況。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00199",
		linknext = "0064_00201",
		line = 2831,
	},
	["0064_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her hair is beautifully pale, and there's an unusual glow to her eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的头发像能透光般美丽，瞳孔闪着不可思议的色调。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的頭髮像能透光般美麗，瞳孔閃著不可思議的色調。",
					{"rt2"},
				},
			},
		},
