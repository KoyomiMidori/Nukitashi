		linkback = "0064_00015",
		linknext = "0064_00017",
		line = 233,
	},
	["0064_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not unreal, it's just artificial.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说什么很不真实——实际上，这不就是虚假的关系吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"說什麼很不真實——實際上，這不就是虛假的關係嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00016",
		linknext = "0064_00018",
		line = 243,
	},
	["0064_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can never forget that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错。唯有这点绝对不能搞错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯。唯有這點絕對不能搞錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00017",
		linknext = "0064_00019",
		line = 253,
	},
	["0064_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As the leader of the Anti-Copulation Front, Rei-senpai is my enemy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我是反交尾势力的队长，是礼前辈的敌人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我是反交尾勢力的隊長，是禮前輩的敵人。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00018",
		linknext = "0064_00020",
		line = 263,
	},
	["0064_00020"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0652", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“So, tomorrow you'll be graduating from being a cadet and you'll be stationed in a proper squad. Do you have any preferences about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么……明天橘将从训练部队毕业，然后被派到正式的部队。你有什么希望吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼……明天橘將從訓練部隊畢業，然後被派到正式的部隊。你有什麼希望嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00019",
		linknext = "0064_00021",
		line = 277,
	},
	["0064_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Consider the following: what if the perverted sex law never existed?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果，原本就没有什么变态条例的话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果，原本就沒有什麼變態條例的話——",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00020",
		linknext = "0064_00022",
		line = 287,
	},
	["0064_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Could I have been real friends with Rei?",
					{"rt2"},
				},
			},
			cn = {
				{
					"就能不这么内疚地，和礼前辈正常地谈笑吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"就能不這麼內疚地，和禮前輩正常地談笑嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00021",
		linknext = "0064_00023",
		line = 297,
	},
	["0064_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Would I be able to have casual conversations with the other members of the SS?",
					{"rt2"},
				},
			},
			cn = {
				{
					"也能和SS的人毫无顾忌地说傻话吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"也能和SS的人毫無顧忌地說傻話嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00022",
		linknext = "0064_00024",
		line = 307,
	},
	["0064_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no point thinking about it, but I can't help it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使知道这是无意义的思索，我还是不由自主地去思考。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使知道這是無意義的思索，我還是不由自主地去思考。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00023",
		linknext = "0064_00025",
		line = 317,
	},
	["0064_00025"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00120", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0653", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hey, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂，橘？”",
					{"rt2"},
				},
