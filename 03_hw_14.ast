	["0064_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's not Rei-senpai anymore. She's the disciplinary committee president.",
					{"rt2"},
