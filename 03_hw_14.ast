	["0064_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She laughs under her breath.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈笑着叹了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩笑著嘆了口氣。",
					{"rt2"},
				},
