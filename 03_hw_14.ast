	["0064_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Keep my senses sharp. I've heard that kind of thing from Rei-senpai enough times throughout training.",
					{"rt2"},
				},
