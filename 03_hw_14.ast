	["0064_00035"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0657", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“All available personnel have been ordered to assemble. Tachibana, I know you aren't technically back until tomorrow, but can you come with us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我命令所有能行动的队员马上集合。橘——虽然你还没归队，能来吗？”",
					{"rt2"},
				},
			},
			tw = {
