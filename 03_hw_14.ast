	},
	["0064_00204"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As she looks back at me, I can feel her gaze piercing through me. It's like she can see everything about me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那仿佛看穿一切的眼睛看向了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那彷彿看穿一切的眼睛看向了我。",
