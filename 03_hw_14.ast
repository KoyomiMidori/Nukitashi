		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1500, rule="eff_043_00000"},
		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg03_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_033_00000"},
		{"bg", id=1, file="bg03_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0004", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "SHO幹部"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "SHO Executive"},
					"“You're telling me that Kotoyose Fumino was taken from right under your squad's noses?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "SHO干部"},
					"“也就是说，你眼睁睁地看着‘琴寄文乃’逃脱了——是这样吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "SHO幹部"},
					"「也就是說，你眼睜睜地看著『琴寄文乃』逃脫了——是這樣吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00311",
		linknext = "0064_00313",
		line = 4299,
	},
	["0064_00313"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00111", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0691", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That's correct. I take full responsibility.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是的，没有错。一切都是我的责任。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是的，沒有錯。一切都是我的責任。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00312",
		linknext = "0064_00314",
		line = 4313,
	},
	["0064_00314"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0005", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "SHO幹部"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "SHO Executive"},
					"“Hmm, it's strange to hear that from you. I was informed you were on the front line of the operation. Was Fumino taken by the external organization we've been fighting against, or was it some other third party?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "SHO干部"},
					"“哼……大队长听了会很吃惊的。作战行动中，好像是你站在最前线的对吧。夺走文乃的是外部组织的人吗？还是其他第三势力的人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "SHO幹部"},
					"「哼……大隊長聽了會很吃驚的。作戰行動中，好像是你站在最前線的對吧。奪走文乃的是外部組織的人嗎？還是其他第三勢力的人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00313",
		linknext = "0064_00315",
		line = 4325,
	},
	["0064_00315"] = {
		{"ex", time=800, func="wait"},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0692", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“My apologies. I was unable to determine the identities of the traitors who took her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对不起，我……没能确认把文乃带走的逆贼的身份。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對不起，我……沒能確認把文乃帶走的逆賊的身份。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00314",
		linknext = "block_00315",
		line = 4340,
	},
