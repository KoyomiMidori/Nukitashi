				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是这样吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是這樣嗎……」",
					{"rt2"},
