	["0064_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Can I bring myself to tell her to trust me, too?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也相信你——如果我能这么回答的话，该有多好啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也相信你——如果我能這麼回答的話，該有多好啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00137",
		linknext = "0064_00139",
		line = 1868,
	},
	["0064_00139"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, then. I'll leave this to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我明白了。那么，这里就交给你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我明白了。那麼，這裡就交給你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00138",
		linknext = "0064_00140",
		line = 1880,
	},
	["0064_00140"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00111", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=10, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0673", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Of course, leave it to me. You'll be on your own from here. Just remember: we're here to secure Fumino, but don't put that above your own safety.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，交给我吧！接下来就只有你一个人了……比起确保‘文乃’，你更应该优先考虑自己的生命。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，交給我吧！接下來就只有你一個人了……比起確保『文乃』，你更應該優先考慮自己的生命。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00139",
		linknext = "0064_00141",
		line = 1895,
	},
	["0064_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just quietly nod my assent.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我沉默着，只点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沉默著，只點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00140",
		linknext = "0064_00142",
