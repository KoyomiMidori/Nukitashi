		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She soothes me with her voice as she tenderly strokes the backs of my hands.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说着，渡酱一直温柔地抚摸着我的手背。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說著，渡醬一直溫柔地撫摸著我的手背。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00309",
		linknext = "0064_00311",
		line = 4241,
	},
	["0064_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The whole time, I can feel her hands trembling slightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那只手——微微颤抖着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那隻手——微微顫抖著。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00310",
		linknext = "0064_00312",
		line = 4251,
	},
	["0064_00312"] = {
