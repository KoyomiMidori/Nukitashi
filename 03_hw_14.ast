		line = 579,
	},
	["0064_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This will allow us to fulfill our goal. We'll finally be able to bring down the perverted sex law.",
