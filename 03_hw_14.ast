			cn = {
				{
					"这样，我们的夙愿终于要实现了。终于可以破坏变态条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣，我們的夙願終於要實現了。終於可以破壞變態條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00043",
		linknext = "0064_00045",
		line = 589,
	},
	["0064_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just thinking about it makes my heart pound wildly and puts tears in my eye.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么想着的同时，心脏在颤抖……差点就要热泪盈眶。",
