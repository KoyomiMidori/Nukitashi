		line = 223,
	},
	["0064_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, that's not right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不对。",
					{"rt2"},
