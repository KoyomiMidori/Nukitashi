		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I really can't see her gleefully taking out such villains with just her folding chair.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不觉得光钢管椅就能摆平黑社会的家伙们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不覺得光鋼管椅就能擺平黑社會的傢伙們。",
