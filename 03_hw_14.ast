	["0064_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Here's some mineral water. Keep yourself hydrated; it's a long way to the summit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……前辈，请。这是补水用的矿泉水。到山顶还有一段距离。”",
					{"rt2"},
				},
			},
			tw = {
