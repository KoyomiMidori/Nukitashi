	},
	["0064_00078"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0663", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That makes sense. Don't let the tension make you freeze. Use it to keep your senses sharp at all times. That's how you get through combat situations.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是吗。要保持不会碍事程度的紧张感，时刻绷紧神经。这将帮助你活到最后。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是嗎。要保持不會礙事程度的緊張感，時刻繃緊神經。這將幫助你活到最後。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00077",
		linknext = "0064_00079",
		line = 1017,
	},
	["0064_00079"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Understood.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。」",
