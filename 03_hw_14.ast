		{"fg", file="hinami_02f_00001", file1="hinami_02f_00102", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1287", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, isn't it amazing? Misaki-chan drove us here in that SHO vehicle!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，很厉害哦。是美岬酱驾驶SHO的车送我们的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，很厲害哦。是美岬醬駕駛SHO的車送我們的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00184",
		linknext = "0064_00186",
		line = 2646,
	},
	["0064_00186"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hotori did?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00185",
		linknext = "0064_00187",
		line = 2658,
	},
	["0064_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"SHO vehicle... Is she talking about the Magical Mirror?",
					{"rt2"},
				},
			},
			cn = {
				{
					"说到SHO的车，应该就是魔镜号吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說到SHO的車，應該就是魔鏡號吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00186",
		linknext = "0064_00188",
		line = 2668,
	},
	["0064_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How does she know how to drive that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我可不知道畔能开那种车。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我可不知道畔能開那種車。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00187",
		linknext = "0064_00189",
		line = 2678,
	},
	["0064_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wasn't it dangerous getting here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是——到这里的路上不是相当危险吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是——到這裡的路上不是相當危險嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00188",
		linknext = "0064_00190",
		line = 2690,
	},
	["0064_00190"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00104", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1288", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Nah! Asane-chan was able to, uh... int... inter... oh, intercept the messages, I think? We were able to keep track of where the SS were and avoid them! It was totally safe!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事！麻沙音酱的那个……通讯拦截？多亏了那个，我们可以知道SS的大家都在干什么，所以安全又安心哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒事！麻沙音醬的那個……通訊攔截？多虧了那個，我們可以知道SS的大家都在幹什麼，所以安全又安心哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00189",
		linknext = "0064_00191",
		line = 2703,
	},
	["0064_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That'll get you past the SS, but what about the Yakuza?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算知道SS……那黑社会呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算知道SS……那黑社會呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00190",
		linknext = "0064_00192",
		line = 2714,
	},
	["0064_00192"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00112", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1289", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yakuza? You mean the old guys? There were a bunch of them, but they never saw us coming, so I just bashed the heck outta them with my chair!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“黑社会……你是说那些大叔们吧？虽然很吃惊他们那么多人，但我挥挥椅子就没事了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「黑社會……你是說那些大叔們吧？雖然很吃驚他們那麼多人，但我揮揮椅子就沒事了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00191",
		linknext = "0064_00193",
		line = 2727,
	},
	["0064_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
