	["0117_00198"] = {
		{"bgm", file="bgm09", vol=100},
		{"se", id=0, loop=0, file="se_a021"},
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0022", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Hmm... So you're our opponents, eh? Ooh, and I see you're the only guy in the group... Heh heh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“——哼，你们就是我们的对手吗？……哦，除了你以外全都是女生啊……呵呵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「——哼，你們就是我們的對手嗎？……哦，除了你以外全都是女生啊……呵呵。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00197",
		linknext = "0117_00199",
		line = 2808,
	},
	["0117_00199"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I speak to the nervous-looking man in glasses.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这时，一个有点神经质的眼镜男向我们搭话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這時，一個有點神經質的眼鏡男向我們搭話。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00198",
		linknext = "0117_00200",
		line = 2819,
	},
	["0117_00200"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We just happened to be together, so we formed our team that way. What's wrong with that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只是邀请偶然在附近的人一起组队而已——有什么奇怪的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只是邀請偶然在附近的人一起組隊而已——有什麼奇怪的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00199",
		linknext = "0117_00201",
		line = 2831,
	},
	["0117_00201"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0023", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Oh, nothing at all. But if you were really serious about winning, then you would've gathered a pack of ripped dudes like us!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“不，没什么奇怪的哦？只是如果真的想赢的话——我觉得应该找身体条件优秀的男人，就像我们一样！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「不，沒什麼奇怪的哦？只是如果真的想贏的話——我覺得應該找身體條件優秀的男人，就像我們一樣！」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00200",
		linknext = "0117_00202",
		line = 2843,
	},
	["0117_00202"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=2, file="bg07_1l_00000", x=-300, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=10000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's five macho-looking dudes standing behind the nerdy manlet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"身材矮小的男人后面，排着5位筋肉隆起的肌肉男。",
					{"rt2"},
				},
			},
			tw = {
				{
					"身材矮小的男人後面，排著5位肌肉隆起的肌肉男。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00201",
		linknext = "0117_00203",
		line = 2857,
	},
	["0117_00203"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0024", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Our team, Meathead Intelligence, has collated quite a bit of stats. We're in the top 8% when it comes to pure physical capability, going from events like the Olympiad and whatnot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我们‘脑肌智能’是个极其注重统计的队伍……成员都是体欲节等活动中排名前8%的纯运动人员。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我們『腦肌智能』是個極其注重統計的隊伍……成員都是體欲節等活動中排名前8%的純運動人員。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00202",
		linknext = "0117_00204",
		line = 2871,
	},
	["0117_00204"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0025", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I stand out with my relative lack of physical capability, but for me, it's brains over brawn. A guaranteed recipe for victory. After all, it is I who formulates our battle plans.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“只有我一个人不擅长运动——取而代之的是这里，我用头脑战斗。为了胜利制定方程。立定战术的都是我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「只有我一個人不擅長運動——取而代之的是這裡，我用頭腦戰鬥。為了勝利制定方程。立定戰術的都是我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00203",
		linknext = "0117_00205",
		line = 2883,
	},
	["0117_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Listen to this fuckin' nerd. If he didn't have those buff guys behind him, I'd atomic wedgie his ass in a heartbeat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙是怎么回事，简直就像体育漫画里会出现的数据至上主义者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙是怎麼回事，簡直就像體育漫畫裡會出現的數據至上主義者。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00204",
		linknext = "0117_00206",
		line = 2893,
	},
	["0117_00206"] = {
		{"bg", id=1, file="bg07_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_03m_00004", file1="nanase_03m_00120", path=":fg/nanase_03m/", id=4, lv=5, head="nanase_03m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0026", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“And as for your team... Hmm, I see how it is. At least Katagiri here has good physical abilities. Pity about everyone else, though! You've even got a loli mixed in there!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“你们队……嗯嗯，原来如此，只有片桐同学的身体素质很高，其他的人就没什么了不起的了！而且连萝莉都混在里面！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「你們隊……嗯嗯，原來如此，只有片桐同學的身體素質很高，其他的人就沒什麼了不起的了！而且連蘿莉都混在裡面！」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00205",
		linknext = "0117_00207",
		line = 2908,
	},
	["0117_00207"] = {
		{"fg", file="hinami_02m_00004", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
