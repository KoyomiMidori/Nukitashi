	["0117_00011"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2230", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Right, this would be new to you... Long story short, it's volunteering to have sex with tourists and townsfolk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对了，淳是第一次啊……简单来说就是当志愿者和游客和镇上的人做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對了，淳是第一次啊……簡單來說就是當志工和遊客和鎮上的人做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00010",
		linknext = "0117_00012",
		line = 145,
	},
	["0117_00012"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
