	["0117_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look her straight in the eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
