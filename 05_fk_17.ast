	["0117_00622"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A long time ago... my equipment made me a target for bullying.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“很久以前……我因为这个的原因，而被欺凌过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「很久以前……我因為這個的原因，而被欺凌過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00621",
		linknext = "0117_00623",
		line = 8475,
	},
	["0117_00623"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00109", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="fumino_01m_00003", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0926", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I vastly overstepped my standing as a servant... I'm terribly sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“…………区区佣人，问了如此越界的问题……我非常抱歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「…………區區傭人，問瞭如此越界的問題……我非常抱歉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00622",
		linknext = "0117_00624",
		line = 8492,
	},
	["0117_00624"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it's fine. At any rate... I'm sorry for cumming in your mouth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，没关系。比起这个……刚才，那个，射在你的嘴里，真对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，沒關係。比起這個……剛才，那個，射在你的嘴裡，真對不起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00623",
		linknext = "0117_00625",
		line = 8504,
	},
	["0117_00625"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like, y'know, mine isn't exactly normal... Must've been rough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的这个并不普通……你应该很难受吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的這個並不普通……你應該很難受吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00624",
		linknext = "0117_00626",
		line = 8516,
	},
	["0117_00626"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00104", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0927", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“No, not at all...”",
