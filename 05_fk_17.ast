					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Now, on to event number one! Cock, Paper, Scissors!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"“首先从第一个活动开始吧！名字叫做——‘棒插贞保猜拳！”。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"「首先從第一個活動開始吧！名字叫做——『棒插貞保猜拳！」。 」",
					{"rt2"},
				},
