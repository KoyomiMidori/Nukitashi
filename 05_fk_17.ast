	["0117_00258"] = {
		{"bg", id=1, file="bg07_1l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00102", path=":fg/kouki_01l/", id=11, lv=5, head="kouki_01l", ch="光姫", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0167", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“In addition, specialized Seiran Island rules permit touching the selected color if it can be found anywhere on your partner's body! For example, if their swimsuit matches the called color, that's permissible!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“然后这次作为青蓝岛的特别规则，可以触碰搭档拥有的颜色！也就是说，触碰现在穿着的泳衣什么的也OK！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「然後這次作為青藍島的特別規則，可以觸碰搭檔擁有的顏色！也就是說，觸碰現在穿著的泳衣什麼的也OK！」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00257",
		linknext = "0117_00259",
		line = 3654,
	},
	["0117_00259"] = {
		{"fg", mode=-1, id=11, ch="光姫", lv=5, time=100},
		{"bg", id=1, file="bg07_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0051", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Now, will each team pick their representatives and make your way to the mats, please!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"“那么，队伍请选出2名代表者前往垫子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"「那麼，隊伍請選出2名代表者前往墊子！」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00258",
		linknext = "0117_00260",
		line = 3670,
	},
	["0117_00260"] = {
