	["0117_00407"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0056", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Oh, wow! I couldn't quite make it out from here, but Team NLNS seems to have achieved right hand, semen! But Team Babby Formation seems to be struggling, and— oh, wow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"“哎呀，NLNS队，虽然看不太清楚，但好像完成了右手，精液！另一方面，队伍婴儿嘴的精液却出不来！接下来——啊啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"「哎呀，NLNS隊，雖然看不太清楚，但好像完成了右手，精液！另一方面，隊伍嬰兒嘴的精液卻出不來！接下來——啊啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00406",
		linknext = "0117_00408",
		line = 5616,
	},
	["0117_00408"] = {
		{"fg", file="kouki_01f_00001", file1="kouki_01f_00103", path=":fg/kouki_01f/", id=30, ch="光姫", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0177", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“They've fallen over. They've been winning all their battles up to now and having sex with their opponents, but it looks like this robbed them of the stamina they needed for this final battle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“跌倒了呢。婴儿嘴因为在之前的战斗中脱颖而出，和很多团队做过爱，结果在最后的最后射不出来了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「跌倒了呢。嬰兒嘴因為在之前的戰鬥中脫穎而出，和很多團隊做過愛，結果在最後的最後射不出來了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00407",
		linknext = "0117_00409",
		line = 5629,
	},
	["0117_00409"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
