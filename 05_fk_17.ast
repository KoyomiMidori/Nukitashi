		line = 379,
	},
	["0117_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Check this out. Asa's completed the new software I requested.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反正你看着就好，我已经叫麻沙酱去做新软件了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「反正你看著就好，我已經叫麻沙醬去做新軟體了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00029",
		linknext = "0117_00031",
		line = 391,
	},
	["0117_00031"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This'll increase our combat speed, just like you were hoping for. Hotori?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我会按照你的要求，加快战斗的速度——畔。”",
					{"rt2"},
				},
