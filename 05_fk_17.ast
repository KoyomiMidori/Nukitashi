		{"fgact", ch="光姫", id=11, act="振動下", loop=1, size=-12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0164", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Right! Now, each team will send one male and one female to stand on this mat right here, with all the colorful circles on it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“好！请每个队伍派出一对男女，排在这边的画有各种颜色的圆的垫子上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「好！請每個隊伍派出一對男女，排在這邊的畫有各種顏色的圓的墊子上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00251",
		linknext = "0117_00253",
		line = 3572,
	},
	["0117_00253"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0165", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Being the referee, it's my duty to pull cards, each with a body part and a color written on it. So one team member will need to put that part of their body on the matching color.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“作为裁判的我将抽卡，朗读写在卡上的部位和颜色，然后队伍中的一人需要把被指定的部位放在那个颜色上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「作為裁判的我將抽卡，朗讀寫在卡上的部位和顏色，然後隊伍中的一人需要把被指定的部位放在那個顏色上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00252",
		linknext = "0117_00254",
		line = 3584,
	},
	["0117_00254"] = {
