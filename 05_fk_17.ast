	},
	["0117_00103"] = {
		{"bgm", file="bgm09", vol=100},
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="touka_01m_00004", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=600, mode=3, x=0, y=100},
		{"fgact", ch="桐香", id=8, act="移動", x=0, y=-100, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0798", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Good day, everyone. I'm sure you must be surprised, to be taken here to Lewd Land instead of the beach. My sincere apologies.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“大家好。没有事先预告就从海滩换成了变态乐园，你们一定很惊讶吧？对不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「大家好。沒有事先預告就從海灘換成了變態樂園，你們一定很驚訝吧？對不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00102",
		linknext = "0117_00104",
		line = 1422,
	},
	["0117_00104"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Reizeiin!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“冷泉院——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「冷泉院——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00103",
		linknext = "0117_00105",
		line = 1435,
	},
	["0117_00105"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0799", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It was I who invited you all here. The good workers here made me a lovely offer to act as overseer for a new event they're holding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“邀请各位不是为了别的，正是变态乐园的人想拜托大家成为新活动的测试人员。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「邀請各位不是為了別的，正是變態樂園的人想拜託大家成為新活動的測試人員。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00104",
		linknext = "0117_00106",
		line = 1447,
	},
	["0117_00106"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0800", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The SS are currently handing out stamp cards, so please take them. You'll find seven locations to stamp on them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“请领取FS正在发放的印章卡片。上面有7个可以盖章的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「請領取FS正在發放的印章卡片。上面有7個可以蓋章的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00105",
		linknext = "0117_00107",
		line = 1459,
	},
	["0117_00107"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0801", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You must complete the challenges at all seven locations, and once your cards are fully stamped, today's class will be over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“各位只要参加在游乐园内举行的7个",
					{"ruby", text="・・"},
					"对战",
					{"/ruby"},
					"型活动，把这张卡全部集满的话，今天的课就结束了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「各位只要參加在遊樂園內舉行的7個",
					{"ruby", text="・・"},
					"對戰",
					{"/ruby"},
					"型活動，把這張卡全部集滿的話，今天的課就結束了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00106",
		linknext = "0117_00108",
		line = 1471,
	},
	["0117_00108"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0802", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There will be six people in each group, so we will permit one member from each group to participate and get the stamp for their group.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“另外，这个活动由6人1组举行，所以也有只要成员中有人参加了，就都可以盖章的项目。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「另外，這個活動由6人1組舉行，所以也有只要成員中有人參加了，就都可以蓋章的項目。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00107",
		linknext = "0117_00109",
		line = 1483,
	},
	["0117_00109"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00112", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2173", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, so we can all participate, but there's no real need to win?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呃，也就是说只要参加，没有赢那个对战也没关系是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呃，也就是說只要參加，沒有贏那個對戰也沒關係是嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00108",
		linknext = "0117_00110",
