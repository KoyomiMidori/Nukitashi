	["0117_00057"] = {
		{"cgdel", id=2, lv=5, time=400, alphadel=1},
		{"fg", mode=-1, id=9, ch="桐香", lv=5, time=400},
		{"bg", id=1, file="bg15_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0792", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“What brings you here? You should be on your way to volunteering... Could it be that you have a response to give me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“怎么了？等一下应该是要去做志愿者的……难道，已经可以听到之前的回复了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「怎麼了？等一下應該是要去做志工的……難道，已經可以聽到之前的答覆了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00056",
		linknext = "0117_00058",
		line = 792,
	},
	["0117_00058"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No. I'm here on a completely unrelated matter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，不是关于那件事，是别的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，不是關於那件事，是別的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00057",
		linknext = "0117_00059",
		line = 804,
	},
	["0117_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've got a question or two to ask. Feel like answering them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有件事我想问你。你有回答的意思吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有件事我想問你。你有回答的意思嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00058",
		linknext = "0117_00060",
		line = 816,
	},
	["0117_00060"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00109", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
