	["0117_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There she stands, as if it's perfectly natural for her to be there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长冷泉院桐香如理所当然般站在那里。",
