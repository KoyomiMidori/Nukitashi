	["0117_00257"] = {
		{"fg", file="asane_01f_00009", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1709", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hold up, Bro. Have a look. Something's up with the colors on that mat. It's all cold colors like blue and purple.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“等等哥哥……仔细一看，垫子的颜色有某种倾向啊……蓝、紫之类，不全是冷色系吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「等等哥哥……仔細一看，墊子的顏色有某種傾向啊……藍、紫之類，不全是冷色系嗎……？」",
					{"rt2"},
