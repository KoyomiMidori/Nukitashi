			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Ah, yes! I'm here! You noticed!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶，啊，是的！我在这里！发现我了啊……！”",
