		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"ex", time=1000, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0079", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "校内放送"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "School Broadcast"},
					"“Busses for volunteering work are currently departing. Any students who have not made their way to a bus, please proceed to the courtyard.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "校内广播"},
					"“从现在开始，校外志愿者的公交车就要发车了。还没上车的学生，请立刻赶往操场。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "校內廣播"},
					"「從現在開始，校外志工的巴士就要發車了。還沒上車的學生，請立刻趕往操場。」",
					{"rt2"},
				},
			},
		},
