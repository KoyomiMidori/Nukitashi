	["0117_00627"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Uncharacteristically, she shakes her head vigorously.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃稀奇地使劲摇了摇头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃稀奇地使勁搖了搖頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00626",
		linknext = "0117_00628",
		line = 8542,
	},
	["0117_00628"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00113", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0928", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have never really seen another gentleman's endowment... but I believe yours is bigger than others.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文乃虽然几乎没有见过那个东西……不过我觉得应该比其他的人都大。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「文乃雖然幾乎沒有見過那個東西……不過我覺得應該比其他的人都大。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00627",
		linknext = "0117_00629",
		line = 8556,
	},
	["0117_00629"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gives me her honest impression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃大概只是说出了坦率的感想吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃大概只是說出了坦率的感想吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00628",
		linknext = "0117_00630",
		line = 8566,
	},
	["0117_00630"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, I have a big hang up about that huge junk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但对我来说——巨大的鸡巴让我感到强烈的自卑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但對我來說——巨大的肉棒讓我感到強烈的自卑。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00629",
		linknext = "0117_00631",
		line = 8576,
	},
	["0117_00631"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00107", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0929", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It's not just big, but it's magnificent, imposing, and full of vigor... I'm impressed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不仅大，而且非常挺立，精力充沛……不愧是文乃的主人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不僅大，而且非常挺立，精力充沛……不愧是文乃的主人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00630",
		linknext = "0117_00632",
		line = 8591,
	},
	["0117_00632"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, she honestly compliments it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是文乃却坦率地称赞了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是文乃卻坦率地稱讚了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00631",
		linknext = "0117_00633",
		line = 8601,
	},
	["0117_00633"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her words seep into me, and give me a weird feeling of happiness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那句话很轻易地刻进了我的心，我莫名地感到高兴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那句話很輕易地刻進了我的心，我莫名地感到高興。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00632",
		linknext = "0117_00634",
		line = 8611,
	},
	["0117_00634"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's like a weight off my heart. But why?",
					{"rt2"},
				},
			},
			cn = {
				{
					"心情突然变轻松了。这是为什么呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"心情突然變輕鬆了。這是為什麼呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00633",
		linknext = "0117_00635",
		line = 8621,
	},
	["0117_00635"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe because she said it so frankly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是单纯因为文乃对我这么说吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是單純因為文乃對我這麼說嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00634",
		linknext = "0117_00636",
		line = 8631,
	},
	["0117_00636"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00101", file2="fumino_01m_00201", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0930", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Plus... I am glad... that I could make you ejaculate... It was a sign that you enjoyed it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“而且……能让您射精……文乃很高兴……因为淳之介同学舒服了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「而且……能讓您射精……文乃很高興……因為淳之介同學舒服了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00635",
		linknext = "0117_00637",
		line = 8645,
	},
	["0117_00637"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“G... Glad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你、你高兴吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你、你高興嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00636",
		linknext = "0117_00638",
		line = 8657,
	},
	["0117_00638"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00113", file2="fumino_01m_00204", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0931", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes... it gives a servant no greater pleasure than to service the person they're attending to... Besides...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……无论是怎样的事，只要为自己所侍奉的人服务，都是佣人的喜悦……而且……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……無論是怎樣的事，只要為自己所侍奉的人服務，都是傭人的喜悅……而且……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00637",
		linknext = "0117_00639",
		line = 8672,
	},
	["0117_00639"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00638",
		linknext = "0117_00640",
		line = 8684,
	},
	["0117_00640"] = {
		{"fg", file="fumino_01m_00003", file1="fumino_01m_00111", file2="fumino_01m_00201", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0932", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“As I said earlier... a servant will gladly provide service till dawn... i-if her master so desires.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“之前我也有说过……如果是主人的要求……作为佣人，我也有义务共枕眠……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「之前我也有說過……如果是主人的要求……作為傭人，我也有義務共枕眠……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00639",
		linknext = "0117_00641",
		line = 8698,
	},
	["0117_00641"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0933", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have sworn to devote myself entirely to you...”",
					{"rt2"},
				},
			},
			cn = {
