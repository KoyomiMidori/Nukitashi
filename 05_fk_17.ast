	["0117_00010"] = {
		{"se", id=0, loop=0, file="se_a122"},
		{"se", id=1, loop=0, file="se_a147"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Also, what's this volunteer work about, anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……重点是校外志愿者究竟要做什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……重點是校外志工究竟要做什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00009",
		linknext = "0117_00011",
		line = 130,
