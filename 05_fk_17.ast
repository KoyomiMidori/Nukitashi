		linkback = "0117_00030",
		linknext = "0117_00032",
		line = 403,
	},
	["0117_00032"] = {
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-400, y=0, time=800},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1000, mode=3, x=600, y=0},
		{"text"},
		delay = {
