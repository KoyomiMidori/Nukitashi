				{
					name = {"奈々瀬", "奈奈濑"},
					"“这家伙……是‘这个’吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這傢伙……是『這個』嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00017",
		linknext = "0117_00019",
		line = 240,
	},
	["0117_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I show her a black object and her eyes boggle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着我取出来的黑块，奈奈濑瞪圆了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著我取出來的黑塊，奈奈瀨瞪圓了眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00018",
		linknext = "0117_00020",
		line = 250,
	},
	["0117_00020"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00115", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2235", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wait, this thing's iron, and the surface area's pretty lacking... Can you even use this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不，可是这是铁制的，面积也不算大，不能用吧——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不，可是這是鐵製的，面積也不算大，不能用吧——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00019",
		linknext = "0117_00021",
		line = 264,
	},
	["0117_00021"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It only looks like it's iron, it's painted that way. It's actually made out of a strengthened carbon fiber alloy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“",
					{"ruby", text="・"},
					"它",
					{"/ruby"},
					"涂装前是碳素纤维强化碳素复合材料， C/C复合材料——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「",
					{"ruby", text="・"},
					"它",
					{"/ruby"},
					"塗裝前是碳素纖維強化碳素複合材料， C/C複合材料——」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00020",
		linknext = "0117_00022",
		line = 276,
	},
	["0117_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In other words, hardened carbon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，是强化碳元素。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，是強化碳元素。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00021",
		linknext = "0117_00023",
		line = 288,
	},
	["0117_00023"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2236", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Carbon... so it's lightweight and extremely strong, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“碳元素是那种轻而高强度的材料对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「碳元素是那種輕而高強度的材料對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00022",
		linknext = "0117_00024",
		line = 302,
	},
	["0117_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm anticipating a firefight with the OSS and SS for this. Don't want it to shatter like a chocolate bar on me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这次预想将与SHO和FS进行枪击战。不能轻易损坏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這次預想將與SHO和FS進行槍擊戰。不能輕易損壞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00023",
		linknext = "0117_00025",
		line = 314,
	},
	["0117_00025"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2237", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But what about the rotor thing inside it? It probably won't be able to stay airborne...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但是，那个形状的话要怎么把跳蛋藏进去？不然浮力——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但是，那個形狀的話要怎麼把跳蛋藏進去？不然浮力——」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00024",
		linknext = "0117_00026",
		line = 328,
	},
	["0117_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll use the cover.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要利用覆盖蛋的部分。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要利用覆蓋蛋的部分。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00025",
		linknext = "0117_00027",
		line = 340,
	},
	["0117_00027"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2238", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You think something as non-aerodynamic as this is gonna stay in the air?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我不认为这种不稳定的形式可以停留在半空……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我不認為這種不穩定的形式可以停留在半空……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00026",
		linknext = "0117_00028",
		line = 354,
	},
	["0117_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who said I was gonna keep it in the air?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谁说要停留在半空了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「誰說要停留在半空了？」",
