				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There is absolutely no need to win. Participation alone is enough grounds for a stamp.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对战不一定要赢，只要参加就会盖章。”",
