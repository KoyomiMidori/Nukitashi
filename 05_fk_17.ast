		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa!? What the hell are you guys doing here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱……！？大家也在，为什么会被带到这个地方……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬……！？大家也在，為什麼會被帶到這個地方……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00094",
		linknext = "0117_00096",
		line = 1296,
	},
	["0117_00096"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2172", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's what we'd like to know. It's weird, they usually always take us to the beach. Maybe the driver screwed up or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我们也不知道啊。真奇怪，平时总是在海滩的，司机先生搞错了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我們也不知道啊。真奇怪，平時總是在海灘的，司機先生搞錯了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00095",
		linknext = "0117_00097",
		line = 1310,
	},
	["0117_00097"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2049", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I don't think that's likely at all. Something must be going on here...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我觉得那个可能性很低……果然发生了什么，只能这么想……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我覺得那個可能性很低……果然發生了什麼，只能這麼想……」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00096",
		linknext = "0117_00098",
		line = 1324,
