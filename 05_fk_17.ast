	["0117_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She scrutinizes me, trying to pinpoint my real motive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"并且，像是为了窥探我的真意般上下打量着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"並且，像是為了窺探我的真意般上下打量著我。",
					{"rt2"},
