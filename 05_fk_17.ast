	["0117_00013"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2231", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, it's nothing to worry about. I've gotten through this shit a million times over, and Misaki knows all the OSS-devoid back alleys and routes to her home like the back of her hand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过你也不用担心，我已经参加过好几次这个活动了，美岬也精通没有SHO的后路和回家的路线……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過你也不用擔心，我已經參加過好幾次這個活動了，美岬也精通沒有SHO的後路和回家的路線……」",
					{"rt2"},
				},
			},
		},
