					"“I ran some quick checks on our equipment to be safe. That said, your goggles need Asa's tablet to work...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“以防万一，先确认一下现在的装备吧。话虽这么说，但也只有淳的护目镜和麻沙酱的平板吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「以防萬一，先確認一下現在的裝備吧。話雖這麼說，但也只有淳的護目鏡和麻沙醬的平板吧……」",
					{"rt2"},
				},
			},
		},
