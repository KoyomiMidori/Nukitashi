					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我有聽人說過，這種遊戲身體小比較有利……！也就是說，我這樣的胖子是不行的哈哈哈……」",
					{"rt2"},
				},
