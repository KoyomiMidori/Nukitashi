					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right, all we gotta do is make sure the calculations add up, and these blueprints are good to go!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，那么只要能计算出这个数值，设计图就完美了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
