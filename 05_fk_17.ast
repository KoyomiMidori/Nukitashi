		{"ex", time=1000, func="wait"},
		{"fg", file="ran_01m_00004", file1="ran_01m_00104", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="蘭", id=8, act="振動下", loop=2, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="ran_01m_00004", file1="ran_01m_00102", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ran0321", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“One, two... All right, you're good. Next! Oh, Tachibana. Doing all right? Have you picked out a team? If you haven't yet, you can join up with our SS team—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“一、二……好的ok。下一位！……啊，是橘君吗。还行吗？队友决定好了吗？如果没有的话，就和我们FS一起——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「一、二……好的ok。下一位！……啊，是橘君嗎。還行嗎？隊友決定好了嗎？如果沒有的話，就和我們FS一起——」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00128",
		linknext = "0117_00130",
		line = 1773,
	},
	["0117_00130"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually, I just happened to run into these guys, so I'll be with them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——这次偶然集齐了。我和这些人组队。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——這次偶然集齊了。我和這些人組隊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00129",
		linknext = "0117_00131",
		line = 1785,
	},
	["0117_00131"] = {
		{"text"},
		delay = {
			[2500] = {
				{"se", id=0, loop=0, file="se_b030", delay2=2500},
			},
			[500] = {
				{"fg", file="ran_01m_00004", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, delay2=500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ran0322", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Really? Most admirable indeed. Now, would the group representative please give me the names of all members, and I shall write them down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“是吗，那很棒呢。那么你们从代表开始依次报上姓名，我写下来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「是嗎，那很棒呢。那麼你們從代表開始依次報上姓名，我寫下來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00130",
		linknext = "0117_00132",
		line = 1800,
	},
	["0117_00132"] = {
		{"se", id=0, loop=0, file="se_b031"},
		{"text"},
		text = {
