					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"“由插入按摩棒的队伍获得胜利！马上开始吧。最初的队伍是——！‘变态护身符’对上‘NLNS’，有请！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"「由插入按摩棒的隊伍獲得勝利！馬上開始吧。最初的隊伍是——！『變態護身符』對上『NLNS』，有請！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00164",
		linknext = "0117_00166",
		line = 2302,
	},
