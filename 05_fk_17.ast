					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I give her our names and she writes them down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她依序写下我们报上的姓名。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她依序寫下我們報上的姓名。",
					{"rt2"},
				},
			},
