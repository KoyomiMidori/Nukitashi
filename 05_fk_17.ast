		linkback = "0117_00162",
		linknext = "0117_00164",
		line = 2278,
	},
	["0117_00164"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0161", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“In this event, each team's representative will play rock, paper, scissors, and the winner will try to get a vibrator up their opponent. As for the loser, they will be using a chastity belt to guard themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫", "光姬"},
					"“这个竞技是由队伍的代表来猜拳，赢的一方向对方插入按摩棒，输的一方用贞操带来防御。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫", "光姬"},
					"「這個競技是由隊伍的代表來猜拳，贏的一方向對方插入按摩棒，輸的一方用貞操帶來防禦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00163",
		linknext = "0117_00165",
		line = 2290,
	},
	["0117_00165"] = {
		{"text"},
