				{
					"第二個關卡是「時間暫停！不倒翁啪啪啪了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00190",
		linknext = "0117_00192",
		line = 2692,
	},
	["0117_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's basically just 'red light, green light'. One team's representative plays red light, and the rest of the other team has to sneak up on them from behind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是所谓的“不倒翁摔倒了”，队伍的一位代表当鬼，背对对战对手的全体队员。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是所謂的「不倒翁摔倒了」，隊伍的一位代表當鬼，背對對戰對手的全體隊員。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00191",
		linknext = "0117_00193",
		line = 2702,
	},
	["0117_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You have to win at both offense and defense to claim the victory.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最先于进攻和防守两方面都取胜才算胜利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最先於進攻和防守兩方面都取勝才算勝利。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00192",
		linknext = "0117_00194",
		line = 2712,
	},
	["0117_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, with Hotori being so incredibly plain that nobody notices her, it proves an easy victory for us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"太过朴素的畔没有任何人注意到，所以简单获胜了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"太過樸素的畔沒有任何人注意到，所以簡單獲勝了。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00193",
		linknext = "0117_00195",
		line = 2722,
	},
	["0117_00195"] = {
