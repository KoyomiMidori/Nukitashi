		linkback = "0117_00062",
		linknext = "0117_00064",
		line = 861,
	},
	["0117_00064"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0794", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I see. You really are impossible to read. I can't guess your intent. I don't understand you. Why would you question me, your enemy, directly?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“原来如此——真是个读不懂的人。看不懂的人。难以理解的人……居然会直接前来询问作为敌人的我问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「原來如此——真是個讀不懂的人。看不懂的人。難以理解的人……居然會直接前來詢問作為敵人的我問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00063",
		linknext = "0117_00065",
		line = 875,
	},
	["0117_00065"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I have nothing to offer you in return. It's all down to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然，我没有打算支付任何代价，所以就看你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然，我沒有打算支付任何代價，所以就看你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00064",
		linknext = "0117_00066",
		line = 887,
	},
	["0117_00066"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, how about it? Are you going to tell me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……好了，怎么样？能告诉我吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……好了，怎麼樣？能告訴我嗎？」",
					{"rt2"},
