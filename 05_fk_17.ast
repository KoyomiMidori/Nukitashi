		linknext = "0117_00113",
		line = 1533,
	},
	["0117_00113"] = {
		{"fg", file="touka_01m_00004", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
