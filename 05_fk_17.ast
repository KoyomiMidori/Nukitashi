	["0117_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With the camera behind them, we could see the opponent's hand. Once the first two moves were made, we could discern which shape their hand would take on the third move instantly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"用对方背面的摄像头锁定对方，在对方挥出手的途中——也就是手指已经成型了——在侦测到的瞬间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"用對方背面的攝影機鎖定對方，在對方揮出手的途中——也就是手指已經成型了——在偵測到的瞬間。",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00179",
		linknext = "0117_00181",
		line = 2518,
	},
	["0117_00181"] = {
		{"text"},
		text = {
