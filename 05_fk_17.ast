			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Now what? Obviously we're gonna have to send Jun out there, the rules being what they are. But who's gonna be his partner?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么办……？这个从人选来看大概就知道结果了吧。其中一个一定是淳，而另一个人——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼辦……？這個從人選來看大概就知道結果了吧。其中一個一定是淳，而另一個人——」",
					{"rt2"},
				},
			},
		},
