					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shit... Talk about a premature victory...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔，被早泄拯救了吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔，被早洩拯救了嗎——」",
