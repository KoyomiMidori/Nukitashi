		linkback = "0117_00033",
		linknext = "0117_00035",
		line = 442,
	},
	["0117_00035"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00122", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki2047", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“A-A perfect score!? Understood... but... why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“满、满分吗……！？知、知道了……但是……这是为什么呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
