		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2229", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yo, Jun? It's just gonna be volunteer work off grounds for the rest of today, so what should we do with Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂淳？接下来的安排是校外志愿者，文乃该怎么办？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂淳？接下來的安排是校外志工，文乃該怎麼辦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00007",
		linknext = "0117_00009",
		line = 103,
	},
	["0117_00009"] = {
		{"se", id=0, loop=0, file="se_a118"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
