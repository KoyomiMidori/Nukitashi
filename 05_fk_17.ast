		},
		linkback = "0117_00031",
		linknext = "0117_00033",
		line = 418,
	},
	["0117_00033"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How could I not notice my own teammate? I want you to try this out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不可能没发现到队员吧……我想要你帮我做这个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不可能沒發現到隊員吧……我想要你幫我做這個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0117_00032",
		linknext = "0117_00034",
		line = 430,
	},
	["0117_00034"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Got a flight sim game for ya. Don't come to school again until you've gotten a perfect score on it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是飞行模拟器。在考到满分前不要来学校。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是飛行模擬器。在考到滿分前不要來學校。」",
					{"rt2"},
				},
