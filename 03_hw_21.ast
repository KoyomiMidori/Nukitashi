	["0071_00250"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The illegal sex trade will collapse. For good this time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"地下风俗要被摧毁了——这次，完完全全地。",
					{"rt2"},
				},
			},
			tw = {
				{
					"地下風俗要被摧毀了——這次，完完全全地。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00249",
		linknext = "0071_00251",
		line = 3710,
	},
	["0071_00251"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I almost can't believe it, even seeing it happen before my eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使目睹着这样的现实，心里的某处还是觉得不怎么踏实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使目睹著這樣的現實，心裡的某處還是覺得不怎麼踏實。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00250",
		linknext = "0071_00252",
		line = 3720,
	},
	["0071_00252"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Didn't this ultimate pragmatist say that exposing the illegal sex trade would put the island at risk? I never imagined he'd do this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个冷静的和理主义者仁浦先生，会不惜让自己奠定的地基崩溃以摧毁地下风俗——这是我没有想到的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個冷靜的和理主義者仁浦先生，會不惜讓自己奠定的地基崩潰以摧毀地下風俗——這是我沒有想到的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00251",
		linknext = "0071_00253",
		line = 3730,
	},
	["0071_00253"] = {
		{"text"},
		text = {
