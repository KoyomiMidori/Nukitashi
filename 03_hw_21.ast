		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0739", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“All right, we're done here. It's not our job to investigate this. Send over the fourth squad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“——嗯，这边已经解决了。详细的调查不归我们管。比起这个，把四队派过来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「——嗯，這邊已經解決了。詳細的調查不歸我們管。比起這個，把四隊派過來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00213",
		linknext = "0071_00215",
		line = 3251,
	},
	["0071_00215"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We bring the children outside and bind the unconscious Yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们把孩子们带出去，把晕过去的黑社会都绑了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們把孩子們帶出去，把暈過去的黑社會都綁了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00214",
		linknext = "0071_00216",
		line = 3263,
	},
	["0071_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since Hotori lives nearby, I had her and Nanase take the children back there for now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为畔的家离这里很近，所以拜托奈奈濑和畔暂时把孩子们带到安全的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為畔的家離這裡很近，所以拜託奈奈瀨和畔暫時把孩子們帶到安全的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00215",
		linknext = "0071_00217",
		line = 3273,
	},
	["0071_00217"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
