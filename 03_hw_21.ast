	},
	["0071_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if Senator Hitoura promised the full power of the SS as assistance, though, going right into the enemy lair is still extremely risky.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生虽然从FS派来了比任何人都强大的帮手，但是进入敌人的据点还是伴随着很大的危险。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生雖然從FS派來了比任何人都強大的幫手，但是進入敵人的據點還是伴隨著很大的危險。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00078",
		linknext = "0071_00080",
		line = 1083,
	},
	["0071_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If Hinami could infiltrate the hideout and create an opening for us from the inside, that would give us a significant first strike advantage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果雏见能够侵入基地内部，从内部制造空隙，会对作战初期非常有利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果雛見能夠侵入基地內部，從內部製造空隙，會對作戰初期非常有利。",
					{"rt2"},
				},
			},
		},
