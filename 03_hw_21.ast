				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I must say, it's not a particularly satisfying ending.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结束之后，还真让人兴奋不起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結束之後，還真讓人興奮不起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00218",
		linknext = "0071_00220",
		line = 3308,
	},
	["0071_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't exactly feel happy, or even just better about the situation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心情没有放晴，也完全没有喜悦的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心情沒有放晴，也完全沒有喜悅的感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00219",
		linknext = "0071_00221",
		line = 3318,
	},
	["0071_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter what, we can't reverse what those kids went through. I won't be able to sleep easily, thinking about that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一想到受害的孩子们，就怎么也无法放松。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一想到受害的孩子們，就怎麼也無法放鬆。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00220",
		linknext = "0071_00222",
		line = 3328,
	},
	["0071_00222"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1722", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But... at least it means that no more kids will need to go through that anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过，这样一来……大家就不会再遭殃了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過，這樣一來……大家就不會再遭殃了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00221",
		linknext = "0071_00223",
		line = 3342,
	},
	["0071_00223"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00222",
		linknext = "0071_00224",
		line = 3354,
	},
	["0071_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I should just focus on all the children who won't be victimized in the future because of what we did here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许只能这么认为——我们成功拯救了以后可能会受到伤害的孩子们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許只能這麼認為——我們成功拯救了以後可能會受到傷害的孩子們。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00223",
		linknext = "0071_00225",
		line = 3364,
	},
	["0071_00225"] = {
		{"se", id=1, stop=1, time=2000},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00116", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0028", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Hah... Heh heh heh... You fuckin' wish.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“哈哈哈……真是天真的家伙们呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「哈哈哈……真是天真的傢伙們呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00224",
		linknext = "0071_00226",
		line = 3380,
	},
	["0071_00226"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0740", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Still conscious, are you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你，居然还有意识——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你，居然還有意識——」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00225",
		linknext = "0071_00227",
		line = 3393,
	},
	["0071_00227"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What're you talking about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“天真……你是什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「天真……你是什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00226",
		linknext = "0071_00228",
		line = 3405,
	},
	["0071_00228"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"bg", id=2, file="bg08_1l_00000", x=0, y=-200, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00116", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0029", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Seriously? Ya don't fuckin' know how any a' this shit works, do ya? We're just a local branch, dumbass.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“啥……你不明白吗！？你们干的，无非只是摧毁了一个组织的支部罢了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「啥……你不明白嗎！？你們幹的，無非只是摧毀了一個組織的支部罷了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00227",
		linknext = "0071_00229",
		line = 3422,
	},
	["0071_00229"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00117", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[10000] = {
				{"fg", file="teshima_01m_00001", file1="teshima_01m_00118", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, delay2=10000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="teshima0030", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Long as the mainland is still connected to this fucked-up island, there's always gonna be more guys like us comin' over here and fuckin' yer shit up! Enjoy yer peace while it lasts, assholes! Bwahahaha!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“这种乱七八糟的岛，只要本岛的母体还活着，今后就会一直被当作目标吧！不过说不定能暂时和平一段时间呢！呀——哈哈哈哈！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「這種亂七八糟的島，只要本島的母體還活著，今後就會一直被當作目標吧！不過說不定能暫時和平一段時間呢！呀——哈哈哈哈！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00228",
		linknext = "0071_00230",
		line = 3438,
	},
	["0071_00230"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00304", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fuck you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这家伙……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你這傢伙……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00229",
		linknext = "0071_00231",
		line = 3450,
	},
	["0071_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As much as it sickens me, he's probably right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然恶心，但这家伙说的恐怕是事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然噁心，但這傢伙說的恐怕是事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00230",
		linknext = "0071_00232",
		line = 3460,
	},
	["0071_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The illegal sex trade has been rooted on this island for a long time. If it were this easy to deal with, that would've happened long ago.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是以前在这个岛上的地下风俗，也被揭发后消失了一次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是以前在這個島上的地下風俗，也被揭發後消失了一次。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00231",
		linknext = "0071_00233",
		line = 3470,
	},
	["0071_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The fact that it still existed until today means his words are true, and it's not just spite talking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但地下风俗至今还存在着——这一事实证明了手嶋说的并不是悔恨的谎言。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但地下風俗至今還存在著——這一事實證明了手嶋說的並不是悔恨的謊言。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00232",
		linknext = "0071_00234",
		line = 3480,
	},
	["0071_00234"] = {
		{"fg", file="teshima_01m_00001", file1="teshima_01m_00117", path=":fg/teshima_01m/", id=8, lv=5, head="teshima_01m", ch="手嶋", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0031", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“If ya really wanted t' make an impact, you'd hafta bring down the main organization, not me own backwater family! As if ya could! This shit ain't over 'til the fat lady sings!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“如果想做些什么的话，就不该挑这个偏僻的支部，而是要直接搞垮本体啊！是吧！不过反正你们也不可能做到啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「如果想做些什麼的話，就不該挑這個偏僻的支部，而是要直接搞垮本體啊！是吧！不過反正你們也不可能做到啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00233",
		linknext = "0071_00235",
		line = 3494,
	},
	["0071_00235"] = {
		{"fg", mode=-1, id=8, ch="手嶋", lv=5, time=300},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0055", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦", "？？？"},
