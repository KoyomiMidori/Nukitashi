	["0071_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So why do I feel so intimidated?",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是这样——但这种快被吞噬的压迫感是怎么回事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是這樣——但這種快被吞噬的壓迫感是怎麼回事。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00130",
