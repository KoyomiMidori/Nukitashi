	},
	["0071_00241"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00128", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0032", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You... Hitoura!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你小子……仁浦……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你小子……仁浦……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00240",
		linknext = "0071_00242",
		line = 3597,
	},
	["0071_00242"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0057", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So you do know who I am. I'm almost honored.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你认识我吗？我很荣幸。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你認識我嗎？我很榮幸。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00241",
		linknext = "0071_00243",
		line = 3609,
	},
	["0071_00243"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00119", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0033", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Don't fuck wit' us, you cunt!! So you wanna destroy us? Not on my fuckin' watch!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你可不要小看我！你说想把我们弄垮！？你根本办不到吧！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你可不要小看我！你說想把我們弄垮！？你根本辦不到吧！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00242",
		linknext = "0071_00244",
		line = 3622,
	},
	["0071_00244"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Senator Hitoura doesn't so much as bat an eye as Teshima howls his lungs out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对咆哮的手嶋，仁浦先生连眉毛都纹丝不动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對咆哮的手嶋，仁浦先生連眉毛都紋絲不動。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00243",
		linknext = "0071_00245",
		line = 3632,
	},
	["0071_00245"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=2, file="bg08_1_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0058", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Gathering all the necessary evidence was quite time-consuming, but it will pay dividends.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“虽然事前处理费了很多时间……但还是有价值的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「雖然事前處理費了很多時間……但還是有價值的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00244",
		linknext = "0071_00246",
		line = 3647,
	},
	["0071_00246"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0059", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I will be publicly releasing every single piece of information we have on this incident. We'll throw everything out into the light. Including the personal information of every single customer of yours.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这次的事件将不进行报道限制。事情的始末将被全部暴露出来。还有你们所有的客户信息也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這次的事件將不進行報導限制。事情的始末將被全部暴露出來。還有你們所有的客戶資訊也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00245",
		linknext = "0071_00247",
		line = 3661,
	},
	["0071_00247"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0034", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“What? You fuckin' mental!? Go 'head an' try! The island'll be tainted forever as a hotbed of crime! Yer little foothold's gonna come crashin' down like the fuckin' World Trade!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你说什么……？你疯了吗！？你试试看！岛的名声会一落千丈！会被说是犯罪的温床！就连你建立起的立足之地都会崩塌哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「你說什麼……？你瘋了嗎！？你試試看！島的名聲會一落千丈！會被說是犯罪的溫床！就連你建立起的立足之地都會崩塌哦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00246",
		linknext = "0071_00248",
		line = 3673,
	},
	["0071_00248"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0060", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I don't give a rat's ass. If it means I can snuff out scum like yourselves, that won't even chap my hide.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“谁在意呢。只要能消灭你们这样的害虫，那种程度的事，不痛也不痒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「誰在意呢。只要能消滅你們這樣的害蟲，那種程度的事，不痛也不癢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00247",
		linknext = "0071_00249",
		line = 3687,
	},
	["0071_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Teshima's unable to respond to such a resolute declaration.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对毅然决然的言辞，手嶋无法再回嘴了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對毅然決然的言辭，手嶋無法再回嘴了。",
					{"rt2"},
				},
