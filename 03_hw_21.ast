		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I point my gun at him, but he doesn't even flinch.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把枪口对准他——但男人连紧张的迹象都没有。",
