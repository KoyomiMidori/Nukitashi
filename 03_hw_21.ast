		line = 3539,
	},
	["0071_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A helicopter is hovering overhead. The door is open, with a rope hanging down and a familiar man standing inside.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一架直升飞机滞空着——从敞开的门处垂下来的绳索上，挂着一位熟悉男人的身影。",
					{"rt2"},
