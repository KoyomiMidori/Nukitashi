					"“不乱说话就活不下去是吗？干脆我就在这里杀了你吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不亂說話就活不下去是嗎？乾脆我就在這裡殺了你吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00200",
		linknext = "0071_00202",
		line = 3032,
	},
	["0071_00202"] = {
		{"se", id=0, loop=0, file="se_b020"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn't look like she's joking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看起来不像在开玩笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看起來不像在開玩笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00201",
		linknext = "0071_00203",
		line = 3043,
	},
	["0071_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The intense hostility she's projecting makes it impossible for him to interject.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她那非比寻常的气魄，实在令人叹为观止。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她那非比尋常的氣魄，實在令人嘆為觀止。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00202",
		linknext = "0071_00204",
		line = 3053,
	},
	["0071_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can feel high levels of barely contained murderous intent emanating from her. She probably really wants to kill him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"甚至让我感受到一种真的想杀掉他的杀气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"甚至讓我感受到一種真的想殺掉他的殺氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00203",
		linknext = "0071_00205",
		line = 3063,
	},
	["0071_00205"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00126", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0735", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“So, how's it feel to know this is what you've been putting all those kids through?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“现在是什么心情？到目前为止一直给予别人恐惧的自己在恐惧中颤抖的感想是？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「現在是什麼心情？到目前為止一直給予別人恐懼的自己在恐懼中顫抖的感想是？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00204",
		linknext = "0071_00206",
		line = 3077,
	},
	["0071_00206"] = {
		{"fg", file="teshima_01f_00001", file1="teshima_01f_00120", file2="teshima_01f_00202", path=":fg/teshima_01f/", id=30, ch="手嶋", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0027", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Urgh... hah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“咿……哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「咿……哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00205",
		linknext = "0071_00207",
		line = 3090,
	},
	["0071_00207"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0736", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Savor the feeling, and know that you brought this upon yourself. Did you enjoy capturing and torturing innocent children? Did you get any joy from seeing their terrified, broken faces?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“要仔细品味哦……这就是你这混蛋干的事情。抓来无辜的孩子看着他们恐惧开心吗？看着恐怖的表情是那么舒服的事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「要仔細品味哦……這就是你這混蛋幹的事情。抓來無辜的孩子看著他們恐懼開心嗎？看著恐怖的表情是那麼舒服的事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00206",
		linknext = "0071_00208",
		line = 3104,
	},
	["0071_00208"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00118", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0737", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Because if it's anything like how I'm feeling right now, you must've been having the time of your damn life. I gotta tell you, this is really why I joined the SS. It gives me the chance to personally punish vermin and slime like you!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我现在非常开心哦。毕竟……我竟然可以亲手制裁你这种真正的人渣混蛋……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我現在非常開心哦。畢竟……我竟然可以親手制裁你這種真正的人渣混蛋……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00207",
		linknext = "0071_00209",
		line = 3118,
	},
	["0071_00209"] = {
