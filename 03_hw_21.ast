	["0071_00135"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0009", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“No response, eh? 'Cos I'm right, ain't I? Not like I'm shocked... With that piece you got, you oughta know that I got a splinter faction of the OSS followin' me orders.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“被别人说中结果说不出话来了吗？不过……你也拿着那个呢。既然拿着那把枪，那你应该至少知道一部分的SHO是跟着我们的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「被別人說中結果說不出話來了嗎？不過……你也拿著那個呢。既然拿著那把槍，那你應該至少知道一部分的SHO是跟著我們的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00134",
		linknext = "0071_00136",
		line = 2079,
	},
	["0071_00136"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0010", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "???"},
					"“That's all down ta me. I know a thing or two 'bout psychology. Yer probably not gonna believe me, but I know how to manipulate people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "？ ？ ？"},
					"“那是我造成的。因为我很擅长心理学。虽然可能很难以置信……但我可以操纵别人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "？？？"},
					"「那是我造成的。因為我很擅長心理學。雖然可能很難以置信……但我可以操縱別人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00135",
		linknext = "0071_00137",
		line = 2091,
	},
	["0071_00137"] = {
		{"text"},
		text = {
