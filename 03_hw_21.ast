	["0071_00256"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00107", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1725", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei, too, thank you! It was a little scary, but knowing that I had both you and Jun protecting me made it all okay!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱也是……谢谢你。虽然有点害怕……但只要想到和礼酱还有淳君在一起，就完全不算什么呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬也是……謝謝你。雖然有點害怕……但只要想到和禮醬還有淳君在一起，就完全不算什麼呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00255",
		linknext = "0071_00257",
		line = 3780,
	},
	["0071_00257"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0741", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It was an order from the governor himself. Our objectives just happened to align.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……只是上面的命令，目的偶然一致罢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……只是上面的命令，目的偶然一致罷了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00256",
		linknext = "0071_00258",
		line = 3794,
	},
	["0071_00258"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1726", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, but still, thanks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……即使是这样，也要谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……即使是這樣，也要謝謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00257",
		linknext = "0071_00259",
		line = 3806,
	},
	["0071_00259"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn't respond to Hinami.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈没有再回答雏见——",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩沒有再回答雛見——",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00258",
		linknext = "0071_00260",
		line = 3816,
	},
	["0071_00260"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Instead, she shoots me a piercing gaze.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而是像要把气撒在我身上一般，看向我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而是像要把氣撒在我身上一般，看向我。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00259",
		linknext = "0071_00261",
		line = 3828,
	},
	["0071_00261"] = {
		{"bgm", file="bgm22", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0742", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana... You already showed me that you'll use any means necessary to achieve your objectives, but I thought that you at least had some standards.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘……你真的是为了自己的目的而不择手段啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘……你真的是為了自己的目的而不擇手段啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00260",
		linknext = "0071_00262",
		line = 3841,
	},
	["0071_00262"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0743", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You used Hinami as a decoy, exposing her to danger. You're really willing to use your companions as pawns for your own goals?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“让雏见当诱饵遭遇危险——你说的同伴，就只是用来达成目的的棋子而已吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「讓雛見當誘餌遭遇危險——你說的同伴，就只是用來達成目的的棋子而已嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00261",
		linknext = "0071_00263",
		line = 3853,
	},
	["0071_00263"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's not...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有那种……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有那種……」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00262",
		linknext = "0071_00264",
		line = 3865,
	},
	["0071_00264"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00103", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1727", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's not true!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没那回事！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒那回事！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00263",
		linknext = "0071_00265",
		line = 3879,
	},
	["0071_00265"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1728", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I felt the same way as Jun. We couldn't allow the illegal sex trade people to run amok, and I didn't want him to just sacrifice himself to deal with it. I was the one who offered to be a decoy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我可是和淳君一样……不能原谅地下风俗，也不想让淳君一直遭受危险……所以才自愿来做诱饵的哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我可是和淳君一樣……不能原諒地下風俗，也不想讓淳君一直遭受危險……所以才自願來做誘餌的哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00264",
		linknext = "0071_00266",
		line = 3893,
	},
	["0071_00266"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00110", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1729", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jun treasures his companions more than anyone! Even you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“淳君……可是比谁都在意同伴哦？就连礼酱的事情，他也一直……一直……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「淳君……可是比誰都在意同伴哦？就連禮醬的事情，他也一直……一直……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00265",
		linknext = "0071_00267",
		line = 3907,
	},
	["0071_00267"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0744", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“...Sorry, but I have a lot of work to take care of. I don't have time to listen to this drivel.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……对不起我也很忙，没有时间再陪你开玩笑了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……對不起我也很忙，沒有時間再陪你開玩笑了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00266",
		linknext = "0071_00268",
		line = 3921,
	},
	["0071_00268"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0745", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Next time we meet, it'll be as enemies, so prepare yourself. Just know this: you will pay for what you've done. Farewell.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“下次见面的时候，我们将再次成为敌人。我是绝对不会原谅你们的。请你们做好心理准备——那么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「下次見面的時候，我們將再次成為敵人。我是絕對不會原諒你們的。請你們做好心理準備——那麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00267",
		linknext = "0071_00269",
		line = 3935,
	},
	["0071_00269"] = {
		{"se", id=0, loop=0, file="se_a069"},
		{"fgact", ch="礼", id=9, act="移動", x=-200, y=0, time=600},
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With that, the discussion is over. She turns to leave.",
					{"rt2"},
				},
			},
			cn = {
				{
					"单方面地切断对话后，礼前辈转过身去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"單方面地切斷對話後，禮前輩轉過身去。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00268",
		linknext = "0071_00270",
		line = 3949,
	},
	["0071_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even after fighting together again, it looks like that deep rift between us won't be closing any time soon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是久违的并肩作战，我们之间的巨大鸿沟还是完全没有要被填满的迹象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是久違的並肩作戰，我們之間的巨大鴻溝還是完全沒有要被填滿的跡象。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00269",
		linknext = "0071_00271",
		line = 3959,
	},
	["0071_00271"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We should get going, too. The others are waiting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我们也走吧。奈奈濑他们在等着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我們也走吧。奈奈瀨他們在等著。」",
