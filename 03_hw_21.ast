	},
	["0071_00071"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=1, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00128", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=1, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While we were debating how to shut down the illegal sex trade and deal with the Yakuza, Hinami enthusiastically thrust her hand into the air.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在关于如何与地下风俗的黑社会战斗的会议中——雏见气势汹汹地举起手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在關於如何與地下風俗的黑社會戰鬥的會議中——雛見氣勢洶洶地舉起手。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00070",
		linknext = "0071_00072",
		line = 991,
	},
	["0071_00072"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hinami... This will be really dangerous, though. Not only do we need you to lure them out, you'll be going right into their lair.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“雏见——不，但是……这次的情况太危险了。不仅要引诱，还要进入他们内部……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雛見——不，但是……這次的情況太危險了。不僅要引誘，還要進入他們內部……」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00071",
		linknext = "0071_00073",
		line = 1003,
	},
	["0071_00073"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1711", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But you know how they kidnap the kids, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……但是，已经知道他们的绑架手段了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……但是，已經知道他們的綁架手段了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00072",
		linknext = "0071_00074",
		line = 1017,
	},
	["0071_00074"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Looks like they make them drink some spiked water, which incapacitates them so they can be carried off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……嗯。好像是让孩子喝那个水，让他们无法抵抗之后再带过去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……嗯。好像是讓孩子喝那個水，讓他們無法抵抗之後再帶過去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00073",
		linknext = "0071_00075",
		line = 1029,
	},
	["0071_00075"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1712", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You said you had some kind of medicine, right? If I just take that, then I won't get horny even if I drink their water!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那么，只要有刚才说的药，喝了那个水也不会有什么反应吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那麼，只要有剛才說的藥，喝了那個水也不會有什麼反應吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00074",
		linknext = "0071_00076",
		line = 1041,
	},
	["0071_00076"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, the antidote. Just keep it hidden in your back teeth, and once they make you drink the water, you can just bite down on it to neutralize the effect. It's as proven as anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……这就是中和剂。只要装在牙槽里，被灌下水之后立刻咬开来就能中和……已经验证过了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……這就是中和劑。只要裝在牙槽裡，被灌下水之後立刻咬開來就能中和……已經驗證過了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00075",
		linknext = "0071_00077",
		line = 1053,
	},
	["0071_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS and OSS learned about how the Yakuza were kidnapping children, as well as the existence of the antidote, from Senator Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"诱拐的方法和中和剂的存在，都是从FS和部分SHO得到的情报——然后由仁浦先生告诉了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"誘拐的方法和中和劑的存在，都是從FS和部分SHO得到的情報——然後由仁浦先生告訴了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00076",
		linknext = "0071_00078",
		line = 1063,
	},
	["0071_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Its original purpose is to delay a woman's period, but it has a side effect of suppressing libido. Apparently, it can be made strong enough to even neutralize the aphrodisiac.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说中和剂本来是用来错开生理期的，但是其副作用有很强的性欲衰减效果——这似乎中合了媚药中的催淫效果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說中和劑本來是用來錯開生理期的，但是其副作用有很強的性慾衰減效果——這似乎中合了媚藥中的催淫效果。",
					{"rt2"},
				},
