					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "???"},
					"“In that case, call me Brünnhilde.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦", "？ ？ ？"},
					"“——是可能的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦", "？？？"},
					"「——是可能的。」",
