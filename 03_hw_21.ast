	["0071_00053"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0003", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示手嶋", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示手嶋", "???"},
					"“There's some real freaks in the government who're super into this shit over at the floatin' hotel. Those weirdos wanna train these brats as pets, for a helluva good price. Make sure they pay top cheddar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示手嶋", "？ ？ ？"},
					"“水上酒店不是有个猎奇的官僚老头吗？他是个喜欢处女还喜欢调教的变态……但给钱很大方。去跟他说这事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示手嶋", "？？？"},
					"「水上酒店不是有個獵奇的官僚老頭嗎？他是個喜歡處女還喜歡調教的變態……但給錢很大方。去跟他說這事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00052",
		linknext = "0071_00054",
		line = 629,
	},
