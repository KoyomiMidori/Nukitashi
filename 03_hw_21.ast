	},
	["0071_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, stay calm, and focus. He's got no escape.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——要冷静，集中精神。这个男人应该没有办法挽回这个状况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——要冷靜，集中精神。這個男人應該沒有辦法挽回這個狀況。",
					{"rt2"},
