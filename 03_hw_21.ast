				{"vo", file="bmobd0092", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男D", "ヤクザA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男D", "Yakuza A"},
					"“Hey, Boss, you sure this is okay? Should we really be doin' this shit in broad daylight?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "黑社会A"},
					"“但是……这样好吗？干得这么嚣张，就算是这个岛也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "黑社會A"},
					"「但是……這樣好嗎？幹得這麼囂張，就算是這個島也……」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00047",
		linknext = "0071_00049",
		line = 571,
	},
	["0071_00049"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0001", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"非表示手嶋", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示手嶋", "???"},
					"“Eh, who gives a fuck? The island's gonna really go to shit if we get exposed. They want us on the down-low, so that's where we gon' stay, see?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示手嶋", "？ ？ ？"},
					"“这种工作，就算没了也不痛不痒。这事要是被暴露了，受到打击的是这个岛……那反而对我们有益。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示手嶋", "？？？"},
					"「這種工作，就算沒了也不痛不癢。這事要是被暴露了，受到打擊的是這個島……那反而對我們有益。」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00048",
		linknext = "0071_00050",
		line = 583,
	},
	["0071_00050"] = {
