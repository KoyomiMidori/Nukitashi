		linkback = "0071_00234",
		linknext = "0071_00236",
		line = 3511,
	},
	["0071_00236"] = {
		{"se", id=1, loop=1, file="se_a211", vol=50},
		{"bg", id=1, file="bg08_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=2, file="bg26_1_00000", x=0, y=0, lv=5, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_033_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear a voice from above and look up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——仰望上空传来的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——仰望上空傳來的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00235",
		linknext = "0071_00237",
		line = 3526,
	},
	["0071_00237"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00109", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1723", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“A helicopter!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“直升飞机————！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「直升飛機————！？」",
