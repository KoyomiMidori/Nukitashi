				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00041",
		linknext = "0020_00043",
		line = 533,
	},
	["0020_00043"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0581", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Eh, qué... mm, ¿qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃，什……嗯，什么事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃，什……嗯，什麼事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00042",
		linknext = "0020_00044",
		line = 545,
	},
	["0020_00044"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mis dedos recorren tu monte húmedo y tus bragas negras azabache con la misma facilidad con la que los esquís bajan por una montaña.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的食指在你那遮掩湿润蜜罐的黑色内裤上，像在抚摸山坡一样滑来滑去呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的食指在你那遮掩濕潤蜜罐的黑色內褲上，像在撫摸山坡一樣滑來滑去呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00043",
		linknext = "0020_00045",
		line = 557,
	},
	["0020_00045"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="khcg04_00005", x=0, y=0, path=":cg/khcg04/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0582", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡¿Qué estás diciéndome?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你现在又在说什么……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你現在又在說什麼……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00044",
		linknext = "0020_00046",
		line = 572,
	},
	["0020_00046"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cada vez que mis dedos hacen su magia, tu hermosa piel, blanca cual nieve recién caída, tiembla. Le da forma a una gran mancha en tu ropa interior.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“每当我的指尖来回时，你像杂讯一样美丽的肌肤都会颤抖，并在内裤上留下大大的湿渍。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「每當我的指尖來回時，你像雜訊一樣美麗的肌膚都會顫抖，並在內褲上留下大大的濕漬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00045",
		linknext = "0020_00047",
		line = 584,
	},
	["0020_00047"] = {
		{"evset", file="khcg04", set="khcg04", path=":ev/khcg04/"},
		{"evset", file="khcg04_00007", set="khcg04_00", path=":ev/khcg04_00/"},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
