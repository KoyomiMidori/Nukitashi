					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“说什么像这种形状，我又看不到你的手势……用它做什么啊？除法吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「說什麼像這種形狀，我又看不到你的手勢……用它做什麼啊？除法嗎……？」",
					{"rt2"},
				},
