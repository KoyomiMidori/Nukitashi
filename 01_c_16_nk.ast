		linkback = "0020_00049",
		linknext = "0020_00051",
		line = 636,
	},
	["0020_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El tono de voz de Nanase no cambia. Le sigue costando hablar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑依旧发出被梗住的声音。",
					{"rt2"},
