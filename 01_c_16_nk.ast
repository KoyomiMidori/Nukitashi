		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0583", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oye, basta... hah... mm... uh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂，别说了……哈……啊……嗯……唔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂，別說了……哈……啊……嗯……唔……」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00046",
		linknext = "0020_00048",
		line = 602,
	},
	["0020_00048"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tus pétalos adoloridos e hinchados se contraen mientras te sumerges en un dulce placer y anhelas la carne masculina.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“感受到寂寞的花瓣里充满了水分，在颤抖地祈求肉棒的同时淹没在甜蜜的快乐中。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「感受到寂寞的花瓣裡充滿了水分，在顫抖地祈求肉棒的同時淹沒在甜蜜的快樂中。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00047",
		linknext = "0020_00049",
		line = 614,
	},
	["0020_00049"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0584", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Esto no es una novela erótica... mm... ah...”",
