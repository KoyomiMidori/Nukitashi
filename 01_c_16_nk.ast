				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero ninguno olvidará lo aterrador que era el Mural de Arte de Culos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我们是不会忘记的——不会忘记尻壁体的可怕。",
