	["0020_00108"] = {
		{"se", id=1, stop=1, time=1000},
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0541", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"So have you heard of prime number factorization? First time I've heard of it.'",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那么，你有听说过质因数分解吗？我第一次听说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那麼，你有聽說過質因數分解嗎？我第一次聽說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00107",
		linknext = "0020_00109",
		line = 1340,
	},
	["0020_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
