					"Por cierto, Asa-chan se nos adelantó. Seguro le pareció que la tensión en el ambiente era un tanto incómoda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"顺便说一句，麻沙酱似乎因为怕尴尬，所以早就切断了通话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"順便說一句，麻沙醬似乎因為怕尷尬，所以早就切斷了通話。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00159",
		linknext = "0020_00161",
		line = 2050,
	},
	["0020_00161"] = {
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0617", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya me disculpé. Dije que lo sentía.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以我不是在道歉了吗？对不起啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以我不是在道歉了嗎？對不起啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00160",
		linknext = "0020_00162",
		line = 2065,
	},
	["0020_00162"] = {
		{"fg", ch="淳之介", mode=1, path=":fg/jun_01m/", file="jun_01m_00001", size="m", file1="jun_01m_00115", file4="jun_01m_00403", mw="mw", head="jun_01m", lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues no te ves muy arrepentida. Hmph.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这哪是道歉者的态度啊。哼——————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這哪是道歉者的態度啊。哼——————」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00161",
		linknext = "0020_00163",
		line = 2078,
	},
	["0020_00163"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", file2="nanase_02m_00204", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0618", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Es normal que me sienta así... después de lo que hiciste... y q-que me metieras el dedo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那是因为你……把手、手指什么的……放进来……这个态度很正常吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那是因為你……把手、手指什麼的……放進來……這個態度很正常吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00162",
		linknext = "0020_00164",
		line = 2092,
	},
	["0020_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero me esforcé mucho por ti y me trataste como basura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但你对努力的我做了很过分的事情啊。哼——————”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但你對努力的我做了很過分的事情啊。哼——————」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00163",
