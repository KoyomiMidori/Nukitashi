	},
	["0020_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mierda, ¿lo expresé como prosa histórica anticuada?",
					{"rt2"},
