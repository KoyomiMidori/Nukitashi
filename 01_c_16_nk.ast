		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Acto seguido, sucedieron varias cosas. También saqué a Hotori y Wata-chan, y todos nos fuimos por nuestro lado a casa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那之后又发生了很多事情，畔和渡酱也成功脱困了，我们终于踏上了回家的路程。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那之後又發生了很多事情，畔和渡醬也成功脫困了，我們終於踏上了回家的路程。",
					{"rt2"},
				},
			},
		},
