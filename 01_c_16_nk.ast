	["0020_00110"] = {
		{"se", id=0, loop=0, file="se_c010"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Son los números que aparecen a ambos lados del símbolo de división. Ya sabes, el que se ve así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是用看起来跟除号相反的符号，像这种形状的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是用看起來跟除號相反的符號，像這種形狀的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00109",
