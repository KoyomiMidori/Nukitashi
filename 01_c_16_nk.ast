			},
		},
		linkback = "0020_00057",
		linknext = "0020_00059",
		line = 735,
	},
	["0020_00059"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0588", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
