	},
	["0020_00057"] = {
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=18, file="khcg04_00006", x=0, y=0, path=":cg/khcg04/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0587", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿C-Cómo así...? ¿Por qué estás haciendo esto...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你、你……在这种、时候……为什么……做这样的事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你、你……在這種、時候……為什麼……做這樣的事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00056",
		linknext = "0020_00058",
		line = 723,
	},
	["0020_00058"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Que por qué? ¡Porque tengo que hacerlo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你问我为什么……因为我别无选择啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你問我為什麼……因為我別無選擇啊……！」",
					{"rt2"},
