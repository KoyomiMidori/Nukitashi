			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Ehh? Entonces... ¿te entraron ganas de hacerlo... y ya?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“诶诶！？也就是说，你突然……那个……想、做了……吗？”",
