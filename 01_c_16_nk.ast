	["0020_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No libera gemidos sensuales como las mujeres de esta isla. Solo intenta respirar y mantiene la cabeza agachada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟这个岛上的婊子们娇喘时的样子不同，她只是像呼吸困难般低着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟這個島上的婊子們嬌喘時的樣子不同，她只是像呼吸困難般低著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00052",
		linknext = "0020_00054",
		line = 674,
	},
	["0020_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero hay algo inusualmente dulce en esa respiración agitada y entrecortada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是那声音，那温暖的吐息，让人感觉怪可爱的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是那聲音，那溫暖的吐息，讓人感覺怪可愛的。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00053",
		linknext = "0020_00055",
		line = 684,
	},
	["0020_00055"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0586", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
