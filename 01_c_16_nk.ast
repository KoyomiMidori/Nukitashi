				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure you've heard of it before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么可能第一次听说。”",
