		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"extrans", sync=0, time=300},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00121", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0227", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Uuugh, estoy harta! ¿Por qué todos me tratan como si fuera una niña...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜——为什么啊……为什么每个人都把我当小孩子看待……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚——為什麼啊……為什麼每個人都把我當小孩子看待……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00167",
		linknext = "0012_00169",
		line = 2337,
	},
	["0012_00169"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0374", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Por cierto, oí hablar de una chica que se trasladó aquí y que se está saltando cursos para estar en tercero.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话说——之前据说有一位女孩子跳级到3年级，还成为了话题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話說——之前據說有一個女孩子跳級到3年級，還成為了話題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00168",
		linknext = "0012_00170",
		line = 2351,
	},
	["0012_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"非表示", "淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Junnosuke"},
					"“Oh, yo también. Alguien me lo dijo poco después de que llegara.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "淳之介"},
					"“那个我也有听说过……转来不久就听说了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "淳之介"},
					"「那個我也有聽說過……轉來不久就聽說了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00169",
		linknext = "0012_00171",
		line = 2362,
	},
	["0012_00171"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0228", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Ese es el rumor que están difundiendo sobre mí?! ¡¿En serio creen que me salté cursos?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“居然有那样的传言……！？大家都以为我是跳级的吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「居然有那樣的傳言……！？大家都以為我是跳級的嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00170",
		linknext = "0012_00172",
		line = 2377,
	},
	["0012_00172"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, eso explica por qué las chicas de mi curso te miran así.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，所以刚刚跟我同年级的女生也没有对你用敬语……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，所以剛剛跟我同年級的女生也沒有對你用敬語……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00171",
		linknext = "0012_00173",
		line = 2389,
	},
	["0012_00173"] = {
