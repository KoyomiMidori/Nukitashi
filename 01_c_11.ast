				{"fg", file="hinami_02m_00001", file1="hinami_02m_00103", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=7500, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0223", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya veo... ¡Supongo que les ha tocado trabajar duro al ser estudiantes de transferencia...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊……两人都是转学生，所以很辛苦吧……好。”",
					{"rt2"},
				},
			},
			tw = {
