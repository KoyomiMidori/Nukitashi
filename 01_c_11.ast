			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Pero si soy la senpai... Tal vez sea pequeña, pero sigo siendo una senpai... ¡No tendré tetas, pero al menos tengo eso...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我明明是前辈……虽然很小但我是前辈……虽然胸最小但我是前辈……”",
