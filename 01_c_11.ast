		linkback = "0012_00107",
		linknext = "0012_00109",
		line = 1464,
	},
	["0012_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So what brought you here, anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在这里干什么呢？”",
					{"rt2"},
				},
