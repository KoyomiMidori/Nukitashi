	["0012_00013"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0388", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Every little bit of nanasenium I collect transforms me little by little into Nanase-san, and eventually I will turn into Nanase-san completely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“极小的奈奈濑分子在我体内积蓄与我同化最终我自己将成为奈奈濑同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「極小的奈奈瀨分子在我體內積蓄與我同化最終我自己將成為奈奈瀨同學。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00012",
		linknext = "0012_00014",
		line = 163,
	},
	["0012_00014"] = {
