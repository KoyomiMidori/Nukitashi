		linkback = "0012_00385",
		linknext = "0012_00387",
		line = 5252,
	},
	["0012_00387"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00111", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
