			tw = {
				{
					name = {"淳之介"},
					"「……就能來到這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00347",
		linknext = "0012_00349",
		line = 4703,
	},
	["0012_00349"] = {
		{"bgm", file="bgm11", vol=100},
		{"bg", id=1, file="bg31_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0259", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, salimos por la parte trasera de la escuela!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇，来到了教学楼的后面诶……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇，來到了校舍的後面欸……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00348",
		linknext = "0012_00350",
		line = 4719,
	},
	["0012_00350"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Siempre que la puerta trasera esté abierta, esta ruta garantiza que podremos salir con seguridad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这条路线的话，只要后门有开，就可以放心地离开学校。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這條路線的話，只要後門有開，就可以放心地離開學校。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00349",
		linknext = "0012_00351",
		line = 4730,
	},
	["0012_00351"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=4, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", path=":fg/hinami_02m/", id=4, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0260", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tienes razón, llegamos a la colina muy rápido! No nos encontraremos con nadie.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的诶，一下子就到后山了……而且没见到一个人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的欸，一下子就到後山了……而且沒見到一個人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00350",
		linknext = "0012_00352",
		line = 4753,
	},
	["0012_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esto se va a poner serio... ¿Asa-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“接下来才是问题……麻沙酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「接下來才是問題……麻沙醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00351",
		linknext = "0012_00353",
		line = 4765,
	},
	["0012_00353"] = {
		{"se", id=0, loop=0, file="se_b031"},
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=5, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0422", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Veamos... El despliegue de hoy es el patrón F.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯——今天的配置是模式F。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯——今天的配置是模式F。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00352",
		linknext = "0012_00354",
		line = 4780,
	},
	["0012_00354"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0422b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hay dos guardias de la SHO de la división de orden público en la base de la montaña, uno en el barrio residencial del sector C y dos en el callejón del sector D.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“在山脚下有两位治安维持部的SHO警卫，住宅区有一个人在C地区的路上，两个人在D地区的小巷中——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「在山腳下有兩個治安維持部的SHO警衛，住宅區有一個人在C地區的路上，兩個人在D地區的小巷中——」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00353",
		linknext = "0012_00355",
		line = 4792,
	},
	["0012_00355"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Implementemos el patrón de escape F.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样就用逃生模式F。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣就用逃生模式F。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00354",
		linknext = "0012_00356",
		line = 4804,
	},
	["0012_00356"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Adelante. Nanase, hoy te seguiremos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“走吧——奈奈濑，拜托你带路。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「走吧——奈奈瀨，拜託你帶路。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00355",
		linknext = "0012_00357",
		line = 4815,
	},
	["0012_00357"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0399", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bien, bien. Quién sabe dónde terminaríamos si nos liderabas tú.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好好好。毕竟如果让你带，我们不知道会走到哪儿去对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好好好。畢竟如果讓你帶，我們不知道會走到哪去對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00356",
		linknext = "0012_00358",
		line = 4828,
	},
	["0012_00358"] = {
		{"se", id=0, loop=0, file="se_a019"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=5, ch="麻沙音", lv=5, time=100},
		{"fg", mode=-1, id=3, ch="奈々瀬", lv=5, time=100},
		{"fg", mode=-1, id=4, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="bg08_2l_00000", x=300, y=-100, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=1, act="移動", x=-605, y=-5, time=6000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase recorre hábilmente el camino, el cual no es más que un sendero de animales.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑灵巧地带头走在山路上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨靈巧地帶頭走在山路上。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00357",
		linknext = "0012_00359",
		line = 4849,
	},
	["0012_00359"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00111", path=":fg/hinami_02m/", id=4, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0261", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Allí estaban los guardias de la SHO? ¿Cómo lo sabías?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“刚刚说的是SHO的大姐姐们的位置对吧？为什么你会知道……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「剛剛說的是SHO的大姐姐們的位置對吧？為什麼你會知道……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00358",
		linknext = "0012_00360",
		line = 4866,
	},
	["0012_00360"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0423", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sabes que la aplicación de Instacum puede buscar guardias cercanos, ¿verdad? Bueno, solo hackeamos la aplicación y usamos esos datos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“SHO的‘Inkeisastagram’里面有个寻找附近警卫的功能对吧？我们用了它的定位情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「SHO的『Inkeisastagram』裡面有個尋找附近警衛的功能對吧？我們用了它的定位情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00359",
		linknext = "0012_00361",
		line = 4879,
	},
	["0012_00361"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero no me dice nada de cómo son.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是这样没办法知道是什么样的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是這樣沒辦法知道是什麼樣的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00360",
		linknext = "0012_00362",
		line = 4891,
	},
	["0012_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así que analizamos la información procedente de las cámaras de seguridad instaladas en la isla, y utilizamos un programa para determinar cómo son.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我们解析了设置在青蓝岛上的防犯摄像头的录像，还添加了区分各种人的程序。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我們解析了設置在青藍島上的防犯攝影機的畫面，還添加了區分各種人的程式。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00361",
		linknext = "0012_00363",
		line = 4902,
	},
	["0012_00363"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan terminó esa aplicación después de dedicarle un mes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是麻沙酱花了将近一个月的时间，最近才完成的应用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是麻沙醬花了將近一個月的時間，最近才完成的APP。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00362",
		linknext = "0012_00364",
		line = 4912,
	},
	["0012_00364"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, la tableta no es capaz de hacer frente a tal funcionalidad por lo que está operando en su PC de forma remota..",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而由于平板没有处理能力，所以是用家里的PC进行远程操控来运行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而由於平板沒有處理能力，所以是用家裡的PC進行遠程操控來運行。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00363",
		linknext = "0012_00365",
		line = 4922,
	},
	["0012_00365"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=4, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien, llegamos a nuestro vecindario.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——很好，已经到家附近了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——很好，已經到家附近了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00364",
		linknext = "0012_00366",
		line = 4941,
	},
	["0012_00366"] = {
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0262", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Eso fue increíble! ¡De veras no vimos a nadie! ¡No nos topamos con guardias y tampoco vimos personas comunes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好厉害……！真的一个人都不在！别说是SHO的大姐姐了，连镇上的人们都没见到！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好厲害……！真的一個人都不在！別說是SHO的大姐姐了，連鎮上的人們都沒見到！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00365",
		linknext = "0012_00367",
		line = 4956,
	},
	["0012_00367"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0400", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Seguiré adelante por si acaso. Llevo años huyendo, así que puedo confiar en mi intuición.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“毕竟有我先去前面探路确认安全。靠的是我逃跑多年的直觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「畢竟有我先去前面探路確認安全。靠的是我逃跑多年的直覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00366",
		linknext = "0012_00368",
		line = 4969,
	},
	["0012_00368"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0263", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Me alegro de que no fuera para tanto. Estaba muy nerviosa, no estaba segura de lo que iba a pasar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“还好这没有我想象的那么难。我一直不知道要干什么，所以好紧张呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「還好這沒有我想像的那麼難。我一直不知道要幹什麼，所以好緊張呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00367",
		linknext = "0012_00369",
		line = 4983,
	},
	["0012_00369"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=5, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0424", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bueno... Esto es un simulacro de desastre. Es como la primera base para nosotros.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嘛……这是疏散训练，就像前戏一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嘛……這是防災演練，就像前戲一樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00368",
		linknext = "0012_00370",
		line = 4996,
	},
	["0012_00370"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0401", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí. Ya hemos tenido varias escapadas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，我们还有‘重头戏’哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，我們還有『重頭戲』哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00369",
		linknext = "0012_00371",
		line = 5010,
	},
	["0012_00371"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0264", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Escapadas...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“重头戏……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「重頭戲……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00370",
		linknext = "0012_00372",
		line = 5024,
	},
	["0012_00372"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin, hoy volvimos sanos y salvos. Deberíamos sentirnos agradecidos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管怎么样，光是今天4人安全完成行动就已经算有收获了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管怎麼樣，光是今天4人安全完成行動就已經算有收穫了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00371",
		linknext = "0012_00373",
		line = 5036,
	},
	["0012_00373"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Démomos prisa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好了，赶快走吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好了，趕快走吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00372",
		linknext = "0012_00374",
		line = 5048,
	},
	["0012_00374"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
