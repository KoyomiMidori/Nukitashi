	["0012_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La dejo de mirar por un segundo y ya se comió lo de dos días.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我稍微一不注意，这家伙就把两天份的饭全吃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我稍微一個不注意，這傢伙就把兩天份的飯菜全吃了。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00007",
		linknext = "0012_00009",
		line = 101,
	},
	["0012_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así que necesitamos que Nanase viniera todos los días.",
