		{"fg", file="hinami_01m_00001", file1="hinami_01m_00121", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0227", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uuugh, I'm so done! Why does everybody always treat me like a child...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呜——为什么啊……为什么每个人都把我当小孩子看待……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗚——為什麼啊……為什麼每個人都把我當小孩子看待……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00167",
		linknext = "0012_00169",
		line = 2337,
	},
	["0012_00169"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0374", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“That reminds me, I heard about a girl who transferred here who's skipping grades to be in third year.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话说——之前据说有一位女孩子跳级到3年级，还成为了话题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話說——之前據說有一個女孩子跳級到3年級，還成為了話題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00168",
		linknext = "0012_00170",
		line = 2351,
	},
	["0012_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"非表示", "淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Junnosuke"},
					"“Huh, I've heard that one too. Somebody mentioned it to me not long after I transferred here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "淳之介"},
					"“那个我也有听说过……转来不久就听说了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "淳之介"},
					"「那個我也有聽說過……轉來不久就聽說了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00169",
		linknext = "0012_00171",
		line = 2362,
	},
	["0012_00171"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
