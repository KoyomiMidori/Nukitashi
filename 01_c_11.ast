			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Me levanté tan temprano que me muero del sueño... Hermanito...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我今天很早起所以超想睡觉要死了无法保持自我……哥哥——”",
