	["0012_00086"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0097", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“¡Ah, Wata-chan! ¡Toma el manga que te pedí! Me gustó muchooo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“啊，渡酱！这个，你借我的漫画！超级好看的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「啊，渡醬！這個，你借我的漫畫！超級好看的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00085",
		linknext = "0012_00087",
		line = 1157,
	},
	["0012_00087"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0191", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿En serio? ¡Me alegra que te gustara! Esa confesión fue muy linda, ¿verdad...? Sentí mariposas en mi estómago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的吗？那太好了。那个告白场景很棒对吧……我都心动了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的嗎？那太好了。那個告白場景很棒對吧……我都心動了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00086",
		linknext = "0012_00088",
		line = 1171,
	},
	["0012_00088"] = {
		{"text"},
		text = {
