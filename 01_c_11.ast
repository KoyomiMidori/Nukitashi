					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Bueno, llevo aquí como un mes... Podría decirse que las circunstancias me obligaron a unirme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，进来有一个月左右了……顺其自然就加入了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，進來有一個月左右了……順其自然就加入了——」",
					{"rt2"},
				},
			},
		},
