		linknext = "0012_00156",
		line = 2135,
	},
	["0012_00156"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0221", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vaya, son hermanos muy cercanos... Qué lindo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶，兄妹两人的关系好好啊。真好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸，兄妹兩人的關係好好啊。真好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00155",
		linknext = "0012_00157",
		line = 2149,
	},
	["0012_00157"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0372", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Son únicos. Los dos forman una sola persona... o tal vez sean una persona cuando están juntos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“他们是特殊的。两个人才完整……应该说两个人在一起才算得上一个人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「他們是特殊的。兩個人才完整……應該說兩個人在一起才算得上一個人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00156",
		linknext = "0012_00158",
		line = 2163,
	},
	["0012_00158"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00125", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
