				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“Sí, fue hermoso... Pero tengo que decir que la escena de sexo después de eso fue bastante simple. Fue solo un montón de susurros, sin nadie que le diera por el culo ni nada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“嗯，很棒……但是之后的做爱太平淡了，一直在谈情说爱，没有那种狠狠冲撞的感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「嗯，很棒……但是之後的做愛太平淡了，一直在談情說愛，沒有那種狠狠衝撞的感覺。」",
					{"rt2"},
				},
			},
		},
