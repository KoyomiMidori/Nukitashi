			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡¡Mi único defecto fue nacer como la hermana menor de alguien como tú!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我唯一的错误就是作为你妹妹出生了——！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我唯一的錯誤就是作為你妹妹出生了——！！」",
					{"rt2"},
				},
			},
