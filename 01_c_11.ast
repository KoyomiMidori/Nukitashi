					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡No, no! ¡Aún estás delgado, así que podrías vestirte como una loli gótica, taparte la cara con el dorso de la mano, maquillarte un poco y bingo!”",
					{"rt2"},
