				{"vo", file="hinami0195", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Espera, me llamaste Wata-chan, ¿verdad?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……你刚刚叫我渡酱！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……你剛剛叫我渡醬！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00093",
		linknext = "0012_00095",
		line = 1274,
	},
	["0012_00095"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, Wata-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有啊渡酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有啊渡醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00094",
		linknext = "0012_00096",
		line = 1286,
	},
	["0012_00096"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0196", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Que sí! A ver, soy tu senpai, ¿bueno? ¡Respétame un poquito!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你叫了吧！喂喂，我可是前辈哦？要好好尊敬我！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你叫了吧！喂喂，我可是前輩哦？要好好尊敬我！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00095",
		linknext = "0012_00097",
		line = 1300,
	},
	["0012_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Como desees, Wata-chan-senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明白了，渡酱前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「明白了，渡醬前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00096",
		linknext = "0012_00098",
		line = 1311,
	},
	["0012_00098"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0197", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí, sí, mucho mejor. Buen chico, Tachibana-kun...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯，这就对了。做得真棒橘君，好乖好乖……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯，這就對了。做得真棒橘君，好乖好乖……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00097",
		linknext = "0012_00099",
		line = 1326,
	},
	["0012_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Solo tengo que decirle así para que esté feliz? ¿O realmente no importa?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知道是不是只要加个前辈就可以了，还是她根本没发觉？",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道是不是只要加個前輩就可以了，還是她根本沒發覺？",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00098",
		linknext = "0012_00100",
		line = 1336,
	},
	["0012_00100"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0198", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oye, no puedo acariciar tu cabecita si no te agachas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……你不弯腰我摸不到你的头哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……你不彎腰我摸不到你的頭哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00099",
		linknext = "0012_00101",
		line = 1350,
	},
	["0012_00101"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“的确。”",
