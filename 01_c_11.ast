					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Jaa... Estoy cansado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呼……有点累了。”",
