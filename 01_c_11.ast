	["0012_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It looks like all sorts of people talk down to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来她似乎被很多人当做同龄人看待。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來她似乎被很多人當做同齡人看待。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00112",
		linknext = "0012_00114",
		line = 1526,
	},
	["0012_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, with her appearance, telling them to think of her as a senpai would probably be a hard sell.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过要叫这个外貌的人前辈也是件痛苦的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過要叫這個外貌的人前輩也是件痛苦的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00113",
