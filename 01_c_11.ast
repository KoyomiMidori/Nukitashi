	["0012_00228"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00104", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0242", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Debes tener alguna razón para odiar la ley pervertida... ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你那么痛恨变态条例，是有理由的……对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「你那麼痛恨變態條例，是有理由的……對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00227",
		linknext = "0012_00229",
		line = 3165,
	},
	["0012_00229"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
