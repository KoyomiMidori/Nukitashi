	["0012_00313"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0418", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hermanito, estás idolatrando demasiado a las vírgenes. Simplemente no tienen la experiencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥你把处女过于神格化了……那只不过是没有被开通的女人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥你把處女過於神格化了……那只不過是沒有被開通的女人啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00312",
		linknext = "0012_00314",
		line = 4178,
	},
	["0012_00314"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Eso es algo que se fomenta en una mujer a través del sexo como personificación del amor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跟这样的女孩子培养感情然后做爱才是人类本该拥有的爱情表现！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跟這樣的女孩子培養感情然後做愛才是人類本該擁有的愛情表現！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00313",
		linknext = "0012_00315",
		line = 4190,
	},
	["0012_00315"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0419", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Las cosas no saldrían bien durante el coito con una virgen intacta y sería vergonzoso, pero si lo haces con una zorra con mucha experiencia igual será divertido aunque no salga bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“处女什么的根本不行那种做爱的时候会痛个半死根本无法进行在这点上辣妹的经验丰富而且就算不顺利气氛也是开朗快乐的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「處女什麼的根本不行那種做愛的時候會痛個半死根本無法進行在這點上辣妹的經驗豐富而且就算不順利氣氛也是開朗快樂的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00314",
		linknext = "0012_00316",
		line = 4204,
	},
	["0012_00316"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0420", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Además es imposible que puedas hacer que una virgen se moje con tus habilidades de preparación así que cómo esperas mejorar tu técnica antes de tu primera experiencia si solo te la pasas jugando eroges. Despierta maldito virgen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“而且就哥哥的前戏能力怎么会让处女湿啊你难道打算在破处之前学一些技巧吗你色情游戏玩太多了啦是时候看清事实了混蛋处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「而且就哥哥的前戲能力怎麼會讓處女濕啊你難道打算在破處之前學一些技巧嗎你色情遊戲玩太多了啦是時候看清事實了混蛋處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00315",
		linknext = "0012_00317",
		line = 4218,
	},
	["0012_00317"] = {
