		line = 4753,
	},
	["0012_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shit's gonna get serious now... Asa-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“接下来才是问题……麻沙酱？”",
