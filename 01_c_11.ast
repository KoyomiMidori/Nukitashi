		linkback = "0012_00354",
		linknext = "0012_00356",
		line = 4804,
	},
	["0012_00356"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let's go. Nanase, we're following you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“走吧——奈奈濑，拜托你带路。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「走吧——奈奈瀨，拜託你帶路。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00355",
		linknext = "0012_00357",
		line = 4815,
	},
	["0012_00357"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0399", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Right, right. Who knows where we'd end up if you were leading.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好好好。毕竟如果让你带，我们不知道会走到哪儿去对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好好好。畢竟如果讓你帶，我們不知道會走到哪去對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00356",
		linknext = "0012_00358",
		line = 4828,
	},
	["0012_00358"] = {
		{"se", id=0, loop=0, file="se_a019"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
