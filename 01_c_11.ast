		linkback = "0012_00390",
		linknext = "0012_00392",
		line = 5320,
	},
	["0012_00392"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Refunfuño mientras desato los molestos cordones de mis zapatos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边解开麻烦的鞋带，一边一个人呐呐自语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊解開麻煩的鞋帶，一邊一個人喃喃自語。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00391",
		linknext = "0012_00393",
		line = 5333,
	},
	["0012_00393"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pues bueno, pensé que sería más arriesgado a medida que aumentara el número de personas, pero pudimos llegar a casa sanos y salvos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我原先以为如果人数增加会很危险，但却平安无事回到了家里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我原本以為如果人數增加會很危險，但卻平安無事回到了家裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00392",
		linknext = "0012_00394",
		line = 5343,
	},
	["0012_00394"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estaremos mejor con más camaradas en nuestra lucha.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今后的战斗，同伴越多越好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今後的戰鬥，同伴越多越好。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00393",
		linknext = "0012_00395",
		line = 5353,
	},
	["0012_00395"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si no va a interferir con nuestras acciones evasivas habituales, debería pensar en aumentar nuestras filas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是不会妨碍日常的回避，也可以考虑增加一下人手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是不會妨礙日常的迴避，也可以考慮增加一下人手。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00394",
		linknext = "0012_00396",
		line = 5363,
	},
	["0012_00396"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No puedo hacer esto solo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仅凭我的力量是不够的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"僅憑我的力量是不夠的。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00395",
		linknext = "0012_00397",
		line = 5373,
	},
	["0012_00397"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A pesar de todo, tengo la obligación de destruir la ley pervertida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过即使是这样，我也有摧毁变态条例的义务——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過即使是這樣，我也有摧毀變態條例的義務——",
