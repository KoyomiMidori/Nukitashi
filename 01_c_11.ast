	["0012_00104"] = {
		{"fg", file="hinami_01ll_00001", file1="hinami_01ll_00118", path=":fg/hinami_01ll/", id=5, lv=5, head="hinami_01ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="hinami_01ll_00001", file1="hinami_01ll_00103", path=":fg/hinami_01ll/", id=5, lv=5, head="hinami_01ll", ch="ヒナミ", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine", delay2=4500},
				{"se", id=0, loop=0, file="se_a094", delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0200", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¡AAAGH!! ¡Pero si yo soy la mayor! No me tomes del pelo... ¡Ay, buen chico!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呀——！就说了我是前辈！！我要生气了，真是的！好乖好乖！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呀——！就說了我是前輩！！我要生氣了，真是的！好乖好乖！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00103",
		linknext = "0012_00105",
		line = 1411,
	},
	["0012_00105"] = {
		{"fg", file="hinami_01ll_00001", file1="hinami_01ll_00104", file2="hinami_01ll_00201", path=":fg/hinami_01ll/", id=5, lv=5, head="hinami_01ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está enfadada, pero me acaricia la cabeza de todos modos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边生气一边摸着我的头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊生氣一邊摸著我的頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00104",
		linknext = "0012_00106",
		line = 1424,
	},
	["0012_00106"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eres una loli muy tiernita y sincera, ¿lo sabías?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“多么率直可爱的萝莉啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「多麼率直可愛的蘿莉啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00105",
		linknext = "0012_00107",
		line = 1436,
	},
	["0012_00107"] = {
		{"fg", file="hinami_01ll_00001", file1="hinami_01ll_00118", file2="hinami_01ll_00201", path=":fg/hinami_01ll/", id=5, lv=5, head="hinami_01ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0201", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡No soy una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是萝莉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是蘿莉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00106",
		linknext = "0012_00108",
		line = 1450,
	},
	["0012_00108"] = {
		{"se", id=0, loop=0, file="se_a155"},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00103", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La dejo bajar y toma su bolso. También agarra una silla plegable de metal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我把渡酱放下来，她就把放到地上的书包和不知道为什么拿着的钢管椅子拿了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我把渡醬放下來，她就把放到地上的書包和不知道為什麼拿著的鋼管椅拿了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00107",
		linknext = "0012_00109",
		line = 1464,
	},
	["0012_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué haces por aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在这里干什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你在這裡做什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00108",
		linknext = "0012_00110",
		line = 1476,
	},
	["0012_00110"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0202", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vine a recoger un manga que le presté a una chica. Su salón está en este piso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“别人来还我借给她的漫画。这层楼的学生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「別人來還我借給她的漫畫。這層樓的學生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00109",
		linknext = "0012_00111",
		line = 1490,
	},
	["0012_00111"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esa chica... tiene mi edad, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说……和我同年级啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說……和我同年級啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00110",
