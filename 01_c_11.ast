					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno... digamos que sí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为……呃……没错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
