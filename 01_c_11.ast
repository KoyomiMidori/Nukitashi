				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Entendido... Eso me tranquiliza... Guh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好的……那么，我就放心……睡……”",
