			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Just came to collect a manga I lent to another girl. Her class is on this floor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“别人来还我借给她的漫画。这层楼的学生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
