		linknext = "0012_00388",
		line = 5266,
	},
	["0012_00388"] = {
		{"se", id="0遠ざかる", loop=0, file="se_a022"},
		{"fgact", ch="奈々瀬", id=3, act="移動", x=-200, y=0, time=600},
		{"fg", mode=-1, id=3, ch="奈々瀬", lv=5, time=400},
		{"text"},
		text = {
