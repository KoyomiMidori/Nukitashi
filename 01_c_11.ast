				{"vo", file="hinami0206", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see, I see... Heh heh, it's pretty cool knowing we have a secret base right here at school, isn't it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对诶，是啊……诶嘿嘿，在学校有个基地，还有点小开心呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對欸，是啊……欸嘿嘿，在學校有個基地，還有點小開心呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00118",
		linknext = "0012_00120",
		line = 1603,
	},
	["0012_00120"] = {
