		linkback = "0012_00114",
		linknext = "0012_00116",
		line = 1550,
	},
	["0012_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm... on my way to the base.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我——正准备去那个‘基地’呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我——正準備去那個『基地』呢。」",
