	},
	["0012_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I took my eyes off her for a moment and she ate two days' worth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我稍微一不注意，这家伙就把两天份的饭全吃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我稍微一個不注意，這傢伙就把兩天份的飯菜全吃了。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00007",
		linknext = "0012_00009",
		line = 101,
	},
	["0012_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So we ended up needing Nanase to come every day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最后只好让奈奈濑连续两天过来帮我们做饭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最後只好讓奈奈瀨連續兩天過來幫我們做飯。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00008",
		linknext = "0012_00010",
		line = 111,
	},
	["0012_00010"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're a gluttonous little rascal, you know that... Not like I don't understand how you feel, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这个可爱的贪吃鬼……不过你的心情我也能理解就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你這個可愛的貪吃鬼……不過你的心情我也能理解就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00009",
		linknext = "0012_00011",
		line = 123,
	},
	["0012_00011"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00113", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0387", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Look. Knowing that Nanase-san's directly touched this stuff with even a micrometer of her fingertips or skin just gives me the warm and fuzzies inside, wouldn't you agree?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是吧。一想到吃着奈奈濑同学做的这些料理时可能能以一微米为单位摄入她的手指或者皮肤到体内就感到至高无上的喜悦呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是吧。一想到吃著奈奈瀨同學做的這些料理時可能能以一微米為單位攝入她的手指或者皮膚到體內就感到至高無上的喜悅呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00010",
		linknext = "0012_00012",
		line = 137,
	},
	["0012_00012"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
