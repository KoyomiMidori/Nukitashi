		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"bgm", file="bgm04", vol=100},
		{"se", id=0, loop=0, file="se_a021"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uff... Por fin volví a mi humilde morada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呼——终于回到家了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呼——終於回到家了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00373",
		linknext = "0012_00375",
		line = 5096,
	},
	["0012_00375"] = {
		{"se", id=0, stop=1, time=1000},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0402", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí. La casa de Wata-chan quedaba más lejos de lo que pensaba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是啊。渡酱的家比我想得还要远。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是啊。渡醬的家比我想得還要遠。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00374",
		linknext = "0012_00376",
		line = 5111,
	},
	["0012_00376"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tu casa está un poco más adelante, así que no te pasará nada a estas horas. Hasta mañana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你家就在前面了，这个时间段的话应该没有问题吧。那么明天见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你家就在前面了，這個時間段的話應該沒有問題吧。那麼明天見。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00375",
		linknext = "0012_00377",
		line = 5122,
	},
	["0012_00377"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0403", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Qué? ¿Acompañaste a Wata-chan hasta su casa pero a mí sí me dejas aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“什么嘛，你把渡酱送到家，我却要在这里说再见？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「什麼嘛，你把渡醬送到家，我卻要在這裡說再見？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00376",
		linknext = "0012_00378",
		line = 5136,
	},
	["0012_00378"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sería un fastidio encontrarme con tus padres. Ya me imagino los malentendidos que tendrían.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要是碰到你家人就不好了，不知道会被误解什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要是碰到你家人就不好了，不知道會被誤會什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00377",
		linknext = "0012_00379",
		line = 5148,
	},
	["0012_00379"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0404", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Oh? ¿Y cuáles son esos malentendidos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嘿，你害怕被误解什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嘿，你害怕被誤會什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00378",
		linknext = "0012_00380",
		line = 5162,
	},
	["0012_00380"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Probablemente pensarían que soy un prostituto!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“连我都会被认为是种猪的——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「連我都會被認為是種豬的——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00379",
		linknext = "0012_00381",
		line = 5174,
	},
	["0012_00381"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00105", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
