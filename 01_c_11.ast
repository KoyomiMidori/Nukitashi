			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aaaah, sabes que uno de los únicos placeres débiles que tengo en la vida es cuando averiguas a qué distancia está el rayo calculando el tiempo entre el destello y el sonido...”",
					{"rt2"},
				},
