	},
	["0012_00233"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00129", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0244", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vamos... Somos parte del mismo equipo, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为你想想，我们……是同一个队伍的同伴对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為你想想，我們……是同一個隊伍的同伴對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00232",
		linknext = "0012_00234",
		line = 3231,
	},
	["0012_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tiene razón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"嗯——说得对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"嗯——說得對。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00233",
		linknext = "0012_00235",
		line = 3241,
	},
	["0012_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Todos son afines y tienen el mismo propósito.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她们，是与我拥有共同目的意识的同志。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她們，是與我擁有共同目的意識的同志。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00234",
		linknext = "0012_00236",
		line = 3251,
	},
	["0012_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Son camaradas que comparten el mismo objetivo y lucharán conmigo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今后将为了同样目的战斗的同伴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今後將為了同樣目的戰鬥的同伴。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00235",
		linknext = "0012_00237",
		line = 3261,
	},
	["0012_00237"] = {
