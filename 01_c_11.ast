	},
	["0012_00353"] = {
		{"se", id=0, loop=0, file="se_b031"},
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=5, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0422", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Let's see... Deployment today is pattern F.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯——今天的配置是模式F。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯——今天的配置是模式F。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00352",
		linknext = "0012_00354",
		line = 4780,
	},
	["0012_00354"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0422b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“There are two SHO guards from the public order maintenance division at the base of the mountain, one in residential district sector C, and two in the alley in sector D.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“在山脚下有两位治安维持部的SHO警卫，住宅区有一个人在C地区的路上，两个人在D地区的小巷中——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「在山腳下有兩個治安維持部的SHO警衛，住宅區有一個人在C地區的路上，兩個人在D地區的小巷中——」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00353",
		linknext = "0012_00355",
		line = 4792,
	},
	["0012_00355"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then let's implement escape pattern F.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样就用逃生模式F。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣就用逃生模式F。」",
					{"rt2"},
				},
			},
