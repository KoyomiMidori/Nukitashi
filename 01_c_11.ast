		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡O-Oye, no! ¡Solo digo que no está bien molestar a los débiles!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是，我是说不要欺负弱者啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是，我是說不要欺負弱者啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00176",
		linknext = "0012_00178",
		line = 2455,
	},
	["0012_00178"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0230", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¡No soy débil!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我才不是弱者！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我才不是弱者！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00177",
		linknext = "0012_00179",
		line = 2470,
	},
	["0012_00179"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0375", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ya, ya, tranquila... Mira, Wata-chan. ¿Sabes qué es esto?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好了好了……渡酱你看，这是什么呀？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好了好了……渡醬你看，這是什麼呀？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00178",
		linknext = "0012_00180",
		line = 2486,
	},
	["0012_00180"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0231", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Qué? ¿Qué es eso? Tiene una cosa parecida a una bola rosa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶，什么？那是什么？上头有个粉红色的球诶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸，什麼？那是什麼？上頭有個粉紅色的球欸。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00179",
		linknext = "0012_00181",
		line = 2501,
	},
	["0012_00181"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0376", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Es un rotor rosa, pero si desmontas el componente del rotor...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这叫粉红跳蛋，这个跳蛋的部分可以拆下来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這叫粉紅跳蛋，這個跳蛋的部分可以拆下來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00180",
		linknext = "0012_00182",
		line = 2515,
	},
	["0012_00182"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0232", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, la parte de la cuerda está rígida y erguida!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇，绳子的部分立起来了诶！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇，繩子的部分立起來了欸！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00181",
		linknext = "0012_00183",
		line = 2530,
	},
	["0012_00183"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0377", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Se trata de un transmisor con forma de rotor rosa. La cuerda es una antena, y puedes saber dónde estás pulsando este interruptor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这是粉红跳蛋型发信器。绳子是天线，你可以在这个开关的部分看到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這是粉紅跳蛋型訊號發射器。繩子是天線，你可以在這個開關的部分看到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00182",
		linknext = "0012_00184",
		line = 2542,
	},
	["0012_00184"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00112", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0233", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooooh, genial... Por cierto, ¿para qué se usa un rotor rosa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶诶诶——好厉害啊……话说粉红跳蛋本来是用来干什么的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸欸欸——好厲害啊……話說粉紅跳蛋本來是用來幹什麼的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00183",
		linknext = "0012_00185",
		line = 2558,
	},
	["0012_00185"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0378", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uh, bueno... De veras no conoce estas cosas, eh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃，那个……你不知道粉红跳蛋啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃，那個……你不知道粉紅跳蛋啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00184",
		linknext = "0012_00186",
		line = 2572,
	},
	["0012_00186"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0412", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Je, está mostrando su ignorancia y recibiendo miradas de desaprobación de Nanase-san...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嘿，你看那家伙的无知让奈奈濑同学都不知道说什么好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嘿，你看那傢伙的無知讓奈奈瀨同學都不知道說什麼好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00185",
		linknext = "0012_00187",
		line = 2586,
	},
	["0012_00187"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Desde cuándo eres un personaje secundario que hace comentarios y ocurrencias?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是会出现在漫画格子角落里的龙套不良少年吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是會出現在漫畫格子角落裡的龍套不良少年嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00186",
		linknext = "0012_00188",
		line = 2598,
	},
	["0012_00188"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00122", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0379", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Ahh, de veras es como una niña! Qué linda...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊啊，真的像小孩子一样可爱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊啊，真的像小孩子一樣可愛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00187",
		linknext = "0012_00189",
		line = 2613,
	},
	["0012_00189"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0413", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿La loli es una enemiga...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那个萝莉果然是‘敌人’吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那個蘿莉果然是『敵人』嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00188",
		linknext = "0012_00190",
		line = 2627,
	},
	["0012_00190"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Puedes calmarte? Es que le gustan los niños.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“住手，她只是喜欢小孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「住手，她只是喜歡小孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00189",
		linknext = "0012_00191",
		line = 2639,
	},
	["0012_00191"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0234", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ajaja, Nanase-chan, cuando oí los rumores sobre ti, pensé que serías una zorra intimidante, pero eso no es verdad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈，奈奈濑酱，当我听到谣言时，还以为你是一位可怕的婊子呢，看来并不是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈，奈奈瀨醬，當我聽到謠言時，還以為你是一個可怕的婊子呢，看來並不是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00190",
		linknext = "0012_00192",
		line = 2654,
	},
	["0012_00192"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0380", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Zorra intimidante? Ah... ¿Todo eso de que me comí a 500 vírgenes y follé durante 24 horas seguidas? Son solo rumores.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可怕的婊子……啊——吃了500位处男，还有24小时耐久做爱之类的吗……那只是谣言哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可怕的婊子……啊——吃了500個處男，還有24小時耐久做愛之類的嗎……那只是謠言哦？」",
					{"rt2"},
				},
