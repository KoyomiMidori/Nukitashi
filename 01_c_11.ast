			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The whole lot would probably set you back a cool 20 million yen or so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“光那些全部加总起来大概两千万左右吧。”",
