	["0012_00193"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0235", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ya veo! ¿Entonces no es verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，这样啊。每个都不是真的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，這樣啊。每個都不是真的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00192",
		linknext = "0012_00194",
		line = 2682,
	},
	["0012_00194"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0381", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Nop. Solo son excusas que me sirven para cuando tengo que huir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对。我只是为了方便逃跑才迎合大家的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對。我只是為了方便逃跑才迎合大家的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00193",
		linknext = "0012_00195",
		line = 2696,
	},
	["0012_00195"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es una zorra inteligente, ¿a que no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对，她是个聪明的婊子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對，她是個聰明的婊子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00194",
		linknext = "0012_00196",
		line = 2708,
	},
	["0012_00196"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=-600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0382", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Qué? Oye, ya sabes que no soy una zorra, así que deja de decirme así, ¿vale?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“什么？我说啊，你既然已经知道我不是婊子了，就别这么叫我了好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「什麼？我說啊，你既然已經知道我不是婊子了，就別這麼叫我了好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00195",
		linknext = "0012_00197",
		line = 2724,
	},
	["0012_00197"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Hmph! Que yo sepa, las no-vírgenes lo son.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼，对我来说非处女就是婊子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼，對我來說非處女就是婊子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00196",
		linknext = "0012_00198",
		line = 2736,
	},
	["0012_00198"] = {
		{"text"},
		text = {
			ja = {
