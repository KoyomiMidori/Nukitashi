		linkback = "0012_00339",
		linknext = "0012_00341",
		line = 4564,
	},
	["0012_00341"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ayer nos separamos tras confirmar que no había peligro, pero hoy escaparemos al refugio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然昨天是在确认安全之后各自解散的，但今天要逃到安全地点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然昨天是在確認安全之後各自解散的，但今天要逃到安全地點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00340",
		linknext = "0012_00342",
		line = 4576,
	},
	["0012_00342"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si sobrevivimos hoy, llegará fin de semana y tendremos dos días de seguridad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管怎么样，只要熬过今天，接来下就是周六周日的休息日，可以保证有2天是安全的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管怎麼樣，只要熬過今天，接來下就是週六週日的休息日，可以保證有2天是安全的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00341",
		linknext = "0012_00343",
		line = 4587,
	},
	["0012_00343"] = {
