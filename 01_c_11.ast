	["0012_00329"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nuestras actividades principales son la evasión y el escape.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后我们的主要活动是逃跑和回避。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後我們的主要活動是逃跑和迴避。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00328",
		linknext = "0012_00330",
		line = 4440,
	},
	["0012_00330"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0256", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿La evasión y el escape?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“逃跑和回避？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「逃跑和迴避？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00329",
		linknext = "0012_00331",
		line = 4454,
	},
	["0012_00331"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En pocas palabras, intentamos llegar a casa sin que nadie nos vea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，要在不被任何人发现的情况下逃回家里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，要在不被任何人發現的情況下逃回家裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00330",
		linknext = "0012_00332",
		line = 4465,
	},
	["0012_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Afortunadamente, la ley pervertida de la isla no se extiende a entrar en casas ajenas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再怎么说，这个岛的条例也不会进入房子调查是否正在进行性行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再怎麼說，這個島的條例也不會進入房子調查是否正在進行性行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00331",
		linknext = "0012_00333",
		line = 4475,
	},
	["0012_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso significa que estás a salvo dentro de tu casa, y que puedes incumplir las normas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以基本上，进入了房子就是安全的，而且不违反条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以基本上，進入了房子就是安全的，而且不違反條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00332",
		linknext = "0012_00334",
		line = 4485,
	},
	["0012_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En otras palabras, nuestro objetivo principal es que todos nuestros miembros vuelvan sanos y salvos a casa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"换句话说，让所有成员安全抵达家中——这是最大的目标。",
					{"rt2"},
				},
			},
			tw = {
				{
					"換句話說，讓所有成員安全抵達家中——這是最大的目標。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00333",
		linknext = "0012_00335",
		line = 4495,
	},
	["0012_00335"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Normalmente llevamos a cada miembro a su casa o los dejamos en un punto intermedio seguro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因此，我们的活动通常是将每个成员送回家，或在安全的中途地点解散。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因此，我們的活動通常是將每個成員送回家，或在安全的中途地點解散。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00334",
		linknext = "0012_00336",
		line = 4507,
	},
	["0012_00336"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El problema es cómo evitar los ojos de la SS y la SHO para llegar a nuestras casas cuanto antes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因此，如何躲过SS和SHO的眼睛然后快速回家，就是问题所在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因此，如何躲過SS和SHO的眼睛然後快速回家，就是問題所在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00335",
		linknext = "0012_00337",
		line = 4518,
	},
	["0012_00337"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0257", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ya veo! ¡En pocas palabras, somos un club de regreso a casa glorificado!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我明白了！也就是说是等级很高的回家社的感觉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我明白了！也就是說是等級很高的回家社的感覺！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00336",
		linknext = "0012_00338",
		line = 4532,
	},
	["0012_00338"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um, pues ahora que lo dices... Sí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你、你这么说，好像也没错……呃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你、你這麼說，好像也沒錯……呃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00337",
		linknext = "0012_00339",
		line = 4544,
	},
	["0012_00339"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sinceramente, suena menos genial cuando se le describe así...",
					{"rt2"},
				},
			},
			cn = {
				{
					"一被说是回家社，就感觉不帅了……",
					{"rt2"},
				},
			},
			tw = {
				{
					"一被說是回家社，就感覺不帥了……",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00338",
		linknext = "0012_00340",
		line = 4554,
	},
	["0012_00340"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero tiene razón...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然她说的没错……",
					{"rt2"},
				},
