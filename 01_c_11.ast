		{"fg", file="asane_01l_00001", file1="asane_01l_00104", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a135"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡No importa si esta persona es mi hermana o no, mientras apruebe la no virginidad, será castigada!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管这家伙是不是我妹妹，只要赞同非处女——格杀勿论！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管這傢伙是不是我妹妹，只要贊同非處女——格殺勿論！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00202",
		linknext = "0012_00204",
		line = 2825,
	},
	["0012_00204"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="asane_02l_00001", file1="asane_02l_00109", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
