				{"vo", file="hinami0216", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I-I see, hmm hmm... Tachibana-kun, you really know your stuff...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“原、原来如此，嗯嗯……橘君好专业啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「原、原來如此，嗯嗯……橘君好專業啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00137",
		linknext = "0012_00139",
		line = 1895,
	},
	["0012_00139"] = {
		{"text"},
		text = {
