					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不不不，哥哥本來就瘦，所以只要穿蘿莉塔裝把手遮起來，然後再化個妝就沒問題了……！」",
					{"rt2"},
