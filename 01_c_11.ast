	["0012_00129"] = {
		{"se", id=0, loop=0, file="se_a147"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero sí contribuí con esto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我做的只有",
					{"ruby", text="・・"},
					"这个",
					{"/ruby"},
					"。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我做的只有",
					{"ruby", text="・・"},
					"這個",
					{"/ruby"},
					"。」",
					{"rt2"},
				},
