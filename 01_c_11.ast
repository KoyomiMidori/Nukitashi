		line = 1589,
	},
	["0012_00119"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0206", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vale, vale... Jeje, se siente genial saber que tenemos una base secreta en la escuela, ¿a que sí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对诶，是啊……诶嘿嘿，在学校有个基地，还有点小开心呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對欸，是啊……欸嘿嘿，在學校有個基地，還有點小開心呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00118",
		linknext = "0012_00120",
		line = 1603,
	},
	["0012_00120"] = {
