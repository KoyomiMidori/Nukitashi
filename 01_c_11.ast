			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“THAT'S the sort of rumor they're spreading about me!? They seriously think I skipped grades!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“居然有那样的传言……！？大家都以为我是跳级的吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「居然有那樣的傳言……！？大家都以為我是跳級的嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00170",
		linknext = "0012_00172",
		line = 2377,
	},
	["0012_00172"] = {
