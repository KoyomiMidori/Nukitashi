					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es una loli tan pequeña que no la vi...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“太萝莉了完全没看到……”",
					{"rt2"},
				},
			},
			tw = {
