					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es mayor que yo, y aun así es toda una loli, eh... Je, supongo que nunca me quitarán mi puesto de hermanita.”",
					{"rt2"},
