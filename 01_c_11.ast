			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Cada pedacito de Nanasenio que recojo me transforma poco a poco en Nanase-san. Pronto me convertiré en Nanase-san.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“极小的奈奈濑分子在我体内积蓄与我同化最终我自己将成为奈奈濑同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「極小的奈奈瀨分子在我體內積蓄與我同化最終我自己將成為奈奈瀨同學。」",
					{"rt2"},
				},
			},
		},
