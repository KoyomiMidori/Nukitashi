					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I'd kinda like to know, if you wouldn't mind. If it's to do with something unpleasant from your past, I think discussing it would help.”",
					{"rt2"},
