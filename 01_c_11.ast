	["0012_00112"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0203", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Mmm? Uh, supongo que sí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……？嗯，是啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……？嗯，是啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00111",
		linknext = "0012_00113",
		line = 1516,
	},
	["0012_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que todo tipo de gente le habla desde arriba.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来她似乎被很多人当做同龄人看待。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來她似乎被很多人當做同齡人看待。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00112",
		linknext = "0012_00114",
		line = 1526,
	},
	["0012_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bueno, con esa apariencia, decirles que la vea como una senpai es un poquito complicado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过要叫这个外貌的人前辈也是件痛苦的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過要叫這個外貌的人前輩也是件痛苦的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00113",
		linknext = "0012_00115",
		line = 1536,
	},
	["0012_00115"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0204", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Qué vas a hacer, Tachibana-kun? ¿Vas a ir al baño?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那么，橘君在做什么？上厕所？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那麼，橘君在做什麼？上廁所？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00114",
		linknext = "0012_00116",
		line = 1550,
	},
	["0012_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Voy... a la base.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我——正准备去那个‘基地’呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我——正準備去那個『基地』呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00115",
		linknext = "0012_00117",
		line = 1562,
	},
	["0012_00117"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0205", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, ¿puedo acompañarte?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，那我可以一起去吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，那我可以一起去嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00116",
		linknext = "0012_00118",
		line = 1577,
	},
	["0012_00118"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por supuesto, ya eres parte de nuestra organización.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然，前辈已经是我们组织中的正式成员了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然，前輩已經是我們組織中的正式成員了。」",
