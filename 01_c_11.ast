	["0012_00020"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0391", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Don't you get it, Bro? Just imagine how cool it'd be to become a cute girl and masturbate and stuff...”",
					{"rt2"},
