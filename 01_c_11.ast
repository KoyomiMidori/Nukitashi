		line = 1362,
	},
	["0012_00102"] = {
		{"se", id=0, loop=0, file="se_a156"},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0199", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje, observa y asómbrate. Tengo algo perfecto para este tipo de—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵呵，等等哦。我有这种时候用的道具——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呵呵呵，等等哦。我有這種時候用的道具——」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00101",
		linknext = "0012_00103",
		line = 1377,
	},
	["0012_00103"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="hinami_01ll_00001", file1="hinami_01ll_00109", path=":fg/hinami_01ll/", id=5, lv=5, head="hinami_01ll", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mejor te levanto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那我把你抱起来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那我把你抱起來吧。」",
