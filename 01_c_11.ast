				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"¡¡MALDITA!! ¡¡NO ME VUELVAS A LLAMAR ASÍ!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你个混蛋！这个词今后不要再说了！”",
