	["0012_00325"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0254", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ene Ele Ene Ese... Ese es el nombre del equipo, ¿verdad? ¿Qué significa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“NLNS是队伍的名字吧？是什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「NLNS是隊伍的名字吧？是什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00324",
		linknext = "0012_00326",
		line = 4387,
	},
	["0012_00326"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“'No Love, No Sex.' (Sin amor, no hay sexo) Es bastante directo. Nuestro principio es que el sexo sin amor es inconcebible. Yo fui quien pensó en ese nombre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘No Love，No Sex’——意味着没有爱就没有性爱。我取的名字。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『No Love，No Sex』——意味著沒有愛就沒有性愛。我取的名字。」",
