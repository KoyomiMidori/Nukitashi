			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇……好黑啊……這是天然的洞穴嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00344",
		linknext = "0012_00346",
		line = 4660,
	},
	["0012_00346"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No sé si sea una cueva natural, pero está conectada a una cueva de piedra caliza.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不知道这是不是天然的，但它似乎连接到类似钟乳石洞的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不知道這是不是天然的，但它似乎連接到類似鐘乳石洞的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00345",
		linknext = "0012_00347",
		line = 4672,
	},
	["0012_00347"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Camina por la puerta y sigue este camino...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要在出门后继续往前走……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要在出門後繼續往前走……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00346",
		linknext = "0012_00348",
		line = 4683,
	},
	["0012_00348"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=4, ch="ヒナミ", lv=5, time=100},
		{"bg", id=1, file="bg31_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
