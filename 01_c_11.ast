					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está bien... No vale la pena esconderlo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样的话……我也没有必要……隐瞒吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣的話……我也沒有必要……隱瞞吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00236",
		linknext = "0012_00238",
		line = 3273,
	},
	["0012_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
