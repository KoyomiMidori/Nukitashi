		linkback = "0012_00387",
		linknext = "0012_00389",
		line = 5280,
	},
	["0012_00389"] = {
		{"se", id=0, stop=1, time=2000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y yo que confiaba en ella como si fuera mi camarada...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明明是信任同伴才说出来的……",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明明是信任同伴才說出來的……",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00388",
		linknext = "0012_00390",
		line = 5291,
	},
	["0012_00390"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
