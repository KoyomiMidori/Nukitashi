	["0012_00010"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eres muy muy glotona... Aunque entiendo cómo te sientes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这个可爱的贪吃鬼……不过你的心情我也能理解就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你這個可愛的貪吃鬼……不過你的心情我也能理解就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00009",
		linknext = "0012_00011",
		line = 123,
	},
	["0012_00011"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00113", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0387", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mira. Saber que Nanase-san ha tocado esto directamente, aunque sea con un micrómetro de sus dedos o de su piel, me pone los pelos de punta, ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是吧。一想到吃着奈奈濑同学做的这些料理时可能能以一微米为单位摄入她的手指或者皮肤到体内就感到至高无上的喜悦呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是吧。一想到吃著奈奈瀨同學做的這些料理時可能能以一微米為單位攝入她的手指或者皮膚到體內就感到至高無上的喜悅呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00010",
		linknext = "0012_00012",
		line = 137,
	},
	["0012_00012"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
