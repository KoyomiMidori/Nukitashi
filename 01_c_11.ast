	["0012_00151"] = {
		{"se", id=0, loop=0, file="se_a104"},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=3, time=200, x=0, y=0, alphadel=1, style="reset"},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=200},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=200},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se recuesta en la caja de cartón revestida de cojines y se duerme.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说完，她走进了旁边放着枕头的纸箱中，靠在上面睡着了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說完，她走進了旁邊放著枕頭的紙箱中，靠在上面睡著了。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00150",
		linknext = "0012_00152",
		line = 2084,
	},
	["0012_00152"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0220", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Se quedó dormida... Parece un gatito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“睡着了……看起来好像猫咪呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「睡著了……看起來好像貓咪呀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00151",
		linknext = "0012_00153",
		line = 2097,
	},
	["0012_00153"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Siempre le digo que se busque un lugar más grande para dormir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也有跟她说可以睡在更宽的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也有跟她說可以睡在更寬的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00152",
		linknext = "0012_00154",
		line = 2109,
	},
	["0012_00154"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0371", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Anda pegada a ti como pegamento. Le gusta estar cerca de su hermano, ¿verdad?..”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“但她说睡在哥哥旁边比较好，两个人总是黏在一起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「但她說睡在哥哥旁邊比較好，兩個人總是黏在一起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00153",
		linknext = "0012_00155",
		line = 2122,
	},
	["0012_00155"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00125", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
