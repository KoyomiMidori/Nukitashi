					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oye, no la hagas llorar. Me siento un poco triste al verla llorar.”",
					{"rt2"},
				},
			},
			cn = {
				{
