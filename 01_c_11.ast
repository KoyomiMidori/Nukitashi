			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así es como sales de aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……就能来到这里。”",
					{"rt2"},
