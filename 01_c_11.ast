		linkback = "0012_00380",
		linknext = "0012_00382",
		line = 5188,
	},
	["0012_00382"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué dijiste, ninfómana con un lunar de lágrima?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说什么呢你个变态泪痣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說什麼呢你個變態淚痣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00381",
		linknext = "0012_00383",
		line = 5200,
	},
	["0012_00383"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00204", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0406", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¡Oye, ya no molestes con mi lunar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“闭嘴，别拿我的泪痣开玩笑……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「閉嘴，別拿我的淚痣開玩笑……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00382",
		linknext = "0012_00384",
		line = 5214,
	},
	["0012_00384"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero está en el lugar perfecto para una zorra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“它的位置不是很适合婊子吗？”",
