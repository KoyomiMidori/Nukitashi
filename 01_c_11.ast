	},
	["0012_00191"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0234", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahaha, Nanase-chan, when I heard the rumors about you, I thought you'd be a scary slut, but that's not true.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈，奈奈濑酱，当我听到谣言时，还以为你是一位可怕的婊子呢，看来并不是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈，奈奈瀨醬，當我聽到謠言時，還以為你是一個可怕的婊子呢，看來並不是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00190",
		linknext = "0012_00192",
		line = 2654,
	},
	["0012_00192"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0380", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Scary slut? Oh... you know, all that talk about gobbling up 500 virgins and fucking for 24 hours straight? It's all just rumors.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可怕的婊子……啊——吃了500位处男，还有24小时耐久做爱之类的吗……那只是谣言哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可怕的婊子……啊——吃了500個處男，還有24小時耐久做愛之類的嗎……那只是謠言哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00191",
		linknext = "0012_00193",
		line = 2668,
	},
	["0012_00193"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0235", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, I see! So none of that's true, then?”",
					{"rt2"},
				},
			},
