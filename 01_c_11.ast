		line = 65,
	},
	["0012_00006"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0386", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“If I leave you to your own devices, there's a chance you'll monopolize Nanase-san's cooking and eat it all yourself...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“如果不管哥哥可能会把奈奈濑同学做的饭菜全吃了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「如果不管哥哥可能會把奈奈瀨同學做的飯菜全吃了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00005",
		linknext = "0012_00007",
		line = 79,
	},
	["0012_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
