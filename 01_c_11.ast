		line = 3190,
	},
	["0012_00231"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0243", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Me gustaría saberlo, si es que no te molesta. Si tiene que ver con algo desagradable de tu pasado, puedes desahogarte.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果你愿意，希望你告诉我。如果有什么痛苦，我希望你能吐露出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「如果你願意，希望你告訴我。如果有什麼痛苦，我希望你能吐露出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00230",
		linknext = "0012_00232",
		line = 3205,
	},
	["0012_00232"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
