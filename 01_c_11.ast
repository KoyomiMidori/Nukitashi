			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jeje, cosechas lo que siembras. Hasta mañana...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵，这是反击……那么明天见。”",
