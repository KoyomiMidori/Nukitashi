		},
		linkback = "0012_00128",
		linknext = "0012_00130",
		line = 1773,
	},
	["0012_00130"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=6, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0212", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Qué es eso? Se ve bastante grande.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这是……什么？好大一台机器呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這是……什麼？好大一臺機器呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00129",
		linknext = "0012_00131",
		line = 1789,
	},
	["0012_00131"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es una impresora 3D de las nuevas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是最新的3D打印机。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是最新的3D列印機。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00130",
		linknext = "0012_00132",
		line = 1801,
	},
	["0012_00132"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0213", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Una impresora 3D? ¿Es una esas cosas que te permiten imprimir estructuras en tres dimensiones?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“3D打印机是那个可以印刷立体物品的东西对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「3D列印機是那個可以印刷立體物品的東西對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00131",
		linknext = "0012_00133",
		line = 1815,
	},
	["0012_00133"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Así es. La uso para crear HEAs: Herramientas de Escape Asistido. Están hechas para parecerse a juguetes sexuales comunes, como los que usamos ayer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，我在制作我们昨天用过的成人用具的仿制品————Tool Assisted Escape，TAE。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，我在製作我們昨天用過的成人用具的仿製品——Tool Assisted Escape，TAE。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00132",
		linknext = "0012_00134",
		line = 1827,
	},
	["0012_00134"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0214", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, las hiciste tú solita! Vaya... Me pregunto qué tan costoso será ese equipo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，那是你们自己做的啊！太棒了，但是看起来好贵呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，那是你們自己做的啊！太棒了，但是看起來好貴呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00133",
		linknext = "0012_00135",
		line = 1842,
	},
	["0012_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esa caja de ahí utiliza el mismo sistema de laminación térmica que tengo en casa, y es relativamente barato.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个盒子跟我家那个一样使用热溶解积层式，所以相对来说比较便宜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個盒子跟我家那個一樣使用熱溶解積層式，所以相對來說比較便宜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00134",
		linknext = "0012_00136",
		line = 1854,
	},
	["0012_00136"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0215", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Térmica...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“热蓉姐……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「熱蓉姐……」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00135",
		linknext = "0012_00137",
		line = 1868,
	},
	["0012_00137"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y esa de ahí, lo bastante grande para que quepa una persona, utiliza el grabado por láser. Al lado, hay una que utiliza grabado en polvo, y la de al lado es un modelo de inyección de tinta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那里的是人可以进去的立体光刻式，旁边那个是粉末烧结式，隔壁是喷墨式。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那裡的是人可以進去的立體光刻式，旁邊那個是粉末燒結式，隔壁是噴墨式。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00136",
		linknext = "0012_00138",
		line = 1880,
	},
	["0012_00138"] = {
