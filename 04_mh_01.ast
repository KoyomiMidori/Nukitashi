		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0491", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, so, about what we were talking about earlier... I said you don't need to worry about me, but honestly, the fact that you came looking for me made me happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呃，那么……是有关刚才的事情。虽然我说不用担心我没关系……但老实说我很高兴橘同学来找我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呃，那麼……是有關剛才的事情。雖然我說不用擔心我沒關係……但老實說我很高興橘同學來找我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00190",
		linknext = "0078_00192",
		line = 2516,
	},
	["0078_00192"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It made you happy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“高兴……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「高興……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00191",
		linknext = "0078_00193",
		line = 2528,
	},
	["0078_00193"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=5000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0492", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I've been alone so long, that I forgot what it was like to have someone actually care about me. It's embarrassing, but I was happy that you came for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“虽然因为一直都是一个人待着所以忘记了，不过……能被谁注意到果然很高兴。心里有种痒痒的感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「雖然因為一直都是一個人待著所以忘記了，不過……能被誰注意到果然很高興。心裡有種癢癢的感覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00192",
		linknext = "0078_00194",
		line = 2544,
	},
	["0078_00194"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
