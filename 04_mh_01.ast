				},
			},
			tw = {
				{
					"這種時候能依靠的——果然還是色情遊戲嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00161",
		linknext = "0078_00163",
		line = 2169,
	},
	["0078_00163"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The time has come to call upon my eroge-trained conversational skills! Now, how to break the ice for a late bloomer like Hotori...",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在正是灵活运用通过色情游戏掌握的对话技巧的时候。对这样一个羞涩的女孩，应该说的台词是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在正是靈活運用通過色情遊戲掌握的對話技巧的時候。對這樣一個羞澀的女孩，應該說的臺詞是——",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00162",
		linknext = "0078_00164",
		line = 2181,
	},
	["0078_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Jeez, everyone is so blind. Why wouldn't they look at such a cute girl?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——真是的，怎么大家都那么没有眼光啊，明明有个这么可爱的女孩在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——真是的，怎麼大家都那麼沒有眼光啊，明明有個這麼可愛的女孩在。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00163",
		linknext = "0078_00165",
		line = 2191,
	},
	["0078_00165"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shit, no! That's coming on way too strong!",
					{"rt2"},
				},
			},
			cn = {
				{
					"不行！这种话我害羞得说不出口……！",
