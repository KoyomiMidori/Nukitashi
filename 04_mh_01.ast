		},
		linkback = "0078_00151",
		linknext = "0078_00153",
		line = 2031,
	},
	["0078_00153"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0483", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, it's true! Like we went on this field trip once, one night we stayed at this hotel, and when I woke up I saw that they left me behind!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不不，是真的。以前校外旅游时，我在旅馆里睡醒后，公交车和同学就都消失了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不不，是真的。以前校外旅遊時，我在旅館裡睡醒後，巴士和同學就都消失了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00152",
		linknext = "0078_00154",
		line = 2043,
	},
	["0078_00154"] = {
