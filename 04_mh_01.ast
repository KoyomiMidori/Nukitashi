		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, it's you, Hotori. I was looking for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什、什么嘛，是畔啊……找好久了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什、什麼嘛，是畔啊……找好久了呢。」",
