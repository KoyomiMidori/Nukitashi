	["0078_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ah, yes, the classic romcom trope of two people attempting to break a long silence by speaking up at exactly the same time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很常见的情况。明明一直沉默着，却不知为何会一起开口说话，这是爱情喜剧特有的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"很常見的情況。明明一直沉默著，卻不知為何會一起開口說話，這是愛情喜劇特有的——",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00172",
		linknext = "0078_00174",
		line = 2297,
	},
	["0078_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Usually they follow this up by both attempting to let the other person talk first.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——不，但如果是我所知道的模式，接下来应该会互相礼让。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——不，但如果是我所知道的模式，接下來應該會互相禮讓。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00173",
		linknext = "0078_00175",
		line = 2307,
	},
	["0078_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't let this get any more cringey. I'll be a man and take the initiative!",
