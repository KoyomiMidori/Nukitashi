			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I thought she might be, but looks like she really isn't.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然我也是这么想的……但是，好像真的不在哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然我也是這麼想的……但是，好像真的不在哦？」",
