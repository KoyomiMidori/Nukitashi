	["0078_00167"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori, has anyone ever told you how cute you are without glasses?",
					{"rt2"},
				},
			},
			cn = {
				{
					"——畔，我觉得你不戴眼镜更可爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——畔，我覺得你不戴眼鏡更可愛。",
					{"rt2"},
