		linkback = "0078_00085",
		linknext = "0078_00087",
		line = 1100,
	},
	["0078_00087"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00109", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=1, mode=3, x=400, y=0},
		{"fgact", ch="蘭", id=8, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0201", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Hmm? Ah, Tachibana. This isn't exactly my proudest moment. Between the Shootdown King event and the incident with the Anti-Copulation Front, the SS is in slight disarray right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“哈，橘君……这，让你看到出糗的地方了。最近击坠王和反交尾势力的事情让我忙得不可开交……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「哈，橘君……這，讓你看到出糗的地方了。最近擊墜王和反交尾勢力的事情讓我忙得不可開交……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00086",
		linknext = "0078_00088",
		line = 1115,
	},
	["0078_00088"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00104", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0202", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Anyway, be safe, and watch out for their forces. I've heard they have magic that makes cocks shrivel up like raisins and pussies go dry as a desert! Goodbye!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“橘君你也要小心那些反交尾势力。据传言，那些家伙会使用魔法把阴道弄干，还会让小鸡鸡枯萎！那么我们走吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「橘君你也要小心那些反交尾勢力。據傳言，那些傢伙會使用魔法把陰道弄乾，還會讓小雞雞軟掉！那麼我們走吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00087",
		linknext = "0078_00089",
		line = 1129,
	},
	["0078_00089"] = {
