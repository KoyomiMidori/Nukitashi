				{"vo", file="misaki0477", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“For me? Why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“找……你是说在找我吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「找……你是說在找我嗎……？」",
					{"rt2"},
