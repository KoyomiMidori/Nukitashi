	},
	["0078_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Plus, people who fall back on the “girl takes off her glasses and suddenly becomes super cute” trope are uncultured swines who are beyond hope.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且会说出不戴眼镜更可爱的人都是人类的敌人，我可不能变成那样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且會說出不戴眼鏡更可愛的人都是人類的敵人，我可不能變成那樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00168",
		linknext = "0078_00170",
		line = 2245,
	},
	["0078_00170"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The longer the silence drags on, the harder it'll be to break the ice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但如果继续保持沉默只会更尴尬。不管什么都可以，先说个话吧。",
					{"rt2"},
				},
			},
			tw = {
