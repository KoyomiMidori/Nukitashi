					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00193",
		linknext = "0078_00195",
		line = 2556,
	},
	["0078_00195"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0493", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes. So... thank you for looking for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的。所以……谢谢你来找我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的。所以……謝謝你來找我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00194",
		linknext = "0078_00196",
		line = 2571,
	},
	["0078_00196"] = {
