			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Haha, this is a little awkward for me. Since everyone has always just ignored me here, this is the first time anyone's actually come looking for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊哈哈……总觉得有点害羞呢！在学校里大家都不把我放在心上……我还是第一次遇到别人找我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊哈哈……總覺得有點害羞呢！在學校裡大家都不把我放在心上……我還是第一次遇到別人找我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00150",
		linknext = "0078_00152",
		line = 2019,
	},
	["0078_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? The first time? That can't be right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说第一次……怎么说都太夸张了吧？”",
