	["0078_00200"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The shootdown event was a tough week for all of us, but we did well to endure it. This battle has made our bonds stronger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“击坠王活动……虽然是痛苦的一周，但是大家都努力度过了。通过这次战斗，我们的羁绊应该会变得更紧密吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「擊墜王活動……雖然是痛苦的一周，但是大家都努力度過了。通過這次戰鬥，我們的羈絆應該會變得更緊密吧。」",
					{"rt2"},
				},
			},
		},
