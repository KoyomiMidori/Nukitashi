					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This conversation feels like we're just regular students.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样对话，让我有种我们真的只是普通的青春期男女的感觉——",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣對話，讓我有種我們真的只是普通的青春期男女的感覺——",
					{"rt2"},
