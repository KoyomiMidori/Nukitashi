					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure she's around, isn't she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她应该在吧……大概在那附近……”",
