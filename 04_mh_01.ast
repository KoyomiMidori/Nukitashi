	["0078_00033"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Espera... ¿esos son pájaros? ¡¿De verdad será el canto de los pájaros?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个叫声是……鸟？喂麻沙酱，是真的鸟在叫呢……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個叫聲是……鳥？喂麻沙醬，是真的鳥在叫呢……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00032",
		linknext = "0078_00034",
		line = 415,
	},
	["0078_00034"] = {
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00128", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1221", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es verdad... ¡Lo único que se oye aquí es gente follando! ¿Cuánto tiempo ha pasado desde la última vez que oímos a los pájaros? ¡Ya ni recuerdo cómo suenan!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“真的……平常因为呻吟完全听不到……不知道有多久没听到鸟叫了……这就是没有野战的世界……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真的……平常因為呻吟完全聽不到……不知道有多久沒聽到鳥叫了……這就是沒有野戰的世界……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00033",
		linknext = "0078_00035",
		line = 430,
	},
