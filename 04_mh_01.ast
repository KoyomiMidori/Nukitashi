		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The shootdown event was a tough week for all of us, but we did well to endure it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“击坠王活动……虽然是痛苦的一周，但总算是顺利度过了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「擊墜王活動……雖然是痛苦的一周，但總算是順利度過了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00096",
		linknext = "0078_00098",
		line = 1277,
	},
	["0078_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This battle has made our bonds stronger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“通过这场战斗，我们的羁绊会变得更加紧密吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「通過這場戰鬥，我們的羈絆會變得更加緊密吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00097",
		linknext = "0078_00099",
		line = 1288,
	},
	["0078_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We made the most of our opportunities. We're no longer going to be on the defensive. From now on we're going on the offensive.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“时机已经成熟了，我们不需要再被动行事了。以后我们也将展开攻势——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「時機已經成熟了，我們不需要再被動行事了。以後我們也將展開攻勢——」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00098",
		linknext = "0078_00100",
		line = 1300,
	},
	["0078_00100"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00119", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1923", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, uh, Jun, can I say something real quick?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂淳，可以打扰一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂淳，可以打擾一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00099",
		linknext = "0078_00101",
		line = 1314,
	},
	["0078_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Excuse me, I'm in the middle of a grand, moving speech to reaffirm our fellowship, camaraderie, and motivation. What could possibly be more important than...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“干嘛。这次的会议可是为了再次确认同伴的干劲和团队意识的重要会议啊。你为什么要妨碍——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「幹嘛。這次的會議可是為了再次確認同伴的幹勁和團隊意識的重要會議啊。你為什麼要妨礙——」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00100",
		linknext = "0078_00102",
		line = 1325,
	},
	["0078_00102"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00105", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1924", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“All right, then where's our comrade Misaki?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你说的同伴中的其中一员美岬呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你說的同伴中的其中一員美岬呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00101",
		linknext = "0078_00103",
		line = 1340,
	},
	["0078_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
