	["0078_00227"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00103", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1238", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh I bet you think you're so damn cute with those loli-ass noises like you're some eroge jailbait when you're actually just a giant fucking sack of ground pork walking around disguised as the plainest girl on this entire damn island you fucking sow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那是啥你以为很可爱吗允许使用那种状声词的只有色情游戏里的萝莉角色和你这只即将被出货的肉猪很不相配啦朴素猪头女。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那是啥你以為很可愛嗎允許使用那種狀聲詞的只有色情遊戲裡的蘿莉角色和你這只即將被出貨的肉豬很不相配啦樸素豬頭女。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00226",
		linknext = "0078_00228",
		line = 3042,
	},
	["0078_00228"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, maybe lay off Hotori a bit, okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你对畔也太具攻击性了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你對畔也太具攻擊性了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00227",
		linknext = "0078_00229",
		line = 3054,
	},
	["0078_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought it actually was pretty cute.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……而且实际上确实很可爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……而且實際上確實很可愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00228",
		linknext = "0078_00230",
		line = 3064,
	},
	["0078_00230"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, it is true that we have virtually no information on Fumino at this time other than her name.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之——目前可以说是完全没有关于文乃的信息。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之——目前可以說是完全沒有關於文乃的資訊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00229",
		linknext = "0078_00231",
		line = 3076,
	},
	["0078_00231"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1929", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Then first step is to gather information. Maybe our sponsor knows something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那么，首先从收集情报开始吧。毕竟这也是出资者的要求嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那麼，首先從收集情報開始吧。畢竟這也是出資者的要求嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00230",
		linknext = "0078_00232",
		line = 3090,
	},
	["0078_00232"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Finding Fumino is vital for the NLNS to achieve its final objective.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。而且，为了实现我们的——NLNS的目的，也有必要将文乃找出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。而且，為了實現我們的——NLNS的目的，也有必要將文乃找出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00231",
		linknext = "0078_00233",
		line = 3102,
	},
	["0078_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We can start by comparing notes tomorrow. We need to see if any of us have any useful information at all. Got it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之今天先各自调查一下有没有关于文乃的情报，然后明天再和大家分享。可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之今天先各自調查一下有沒有關於文乃的情報，然後明天再和大家分享。可以嗎？」",
					{"rt2"},
				},
			},
		},
