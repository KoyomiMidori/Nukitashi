	["0078_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was close, but at least I managed to escape.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总算逃过了一劫——怎么说呢，感觉非常微妙……",
					{"rt2"},
				},
			},
			tw = {
				{
					"總算逃過了一劫——怎麼說呢，感覺非常微妙……",
