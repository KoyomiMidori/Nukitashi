		linkback = "0078_00166",
		linknext = "0078_00168",
		line = 2223,
	},
	["0078_00168"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Shit, why would I say that!? She doesn't even wear glasses!!",
					{"rt2"},
				},
			},
			cn = {
				{
					"不行，畔没戴眼镜……！！",
					{"rt2"},
				},
			},
			tw = {
				{
					"不行，畔沒戴眼鏡……！！",
