		linkback = "0078_00143",
		linknext = "0078_00145",
		line = 1923,
	},
	["0078_00145"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1800] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=1800, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0478", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Y-You were? Sorry, I was so absorbed in this book that I didn't notice that school was already over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是、是哦。对不起……我沉迷于读书，没有注意到已经放学了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是、是哦。對不起……我沉迷於讀書，沒有注意到已經放學了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00144",
		linknext = "0078_00146",
		line = 1939,
	},
	["0078_00146"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, yeah, you're a bookworm, we get it. Well, as long as you're okay, that's fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是个了不起的文学少女啊……不过没事就好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是個了不起的文學少女啊……不過沒事就好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00145",
		linknext = "0078_00147",
		line = 1951,
	},
	["0078_00147"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0479", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sorry for worrying you, but you don't need to when I'm at school.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“让你担心了……不过，在学校的时候，你不用那么在意也没关系哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「讓你擔心了……不過，在學校的時候，你不用那麼在意也沒關係哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00146",
		linknext = "0078_00148",
		line = 1965,
	},
	["0078_00148"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0480", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I told you no one ever really notices me when I'm by myself, right? That guy having sex over there just walked right past me without saying anything a couple minutes ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我之前也说过了，一个人的话，谁都不会注意到我的存在……你看，在那里做爱的男人，刚才也从我身边走了过去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我之前也說過了，一個人的話，誰都不會注意到我的存在……你看，在那裡做愛的男人，剛才也從我身邊走了過去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00147",
		linknext = "0078_00149",
		line = 1979,
	},
	["0078_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if that's true, as a leader I can't just leave one of my comrades behind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别说傻话了，就算是那样，作为领导者的我也不能放着同伴不管。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別說傻話了，就算是那樣，作為領導者的我也不能放著同伴不管。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00148",
		linknext = "0078_00150",
		line = 1991,
	},
	["0078_00150"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0481", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Comrade...? W-Wow, thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“同、伴……谢、谢谢你……”",
