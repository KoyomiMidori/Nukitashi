			},
		},
		text = {
			vo = {
				{"vo", file="misaki0484", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I had to borrow a bike to get to the next place on the itinerary! It really sucked at the time, but at least I can laugh about it now, right? Not that I've ever had the chance to tell the story to anyone...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“然后我借了自行车努力移动到下个目的地……那是很久以前的事了，现在只是当笑话说而已。只不过，我连说话的对象都没有……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「然後我借了自行車努力移動到下個目的地……那是很久以前的事了，現在只是當笑話說而已。只不過，我連說話的對象都沒有……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00154",
		linknext = "0078_00156",
		line = 2073,
	},
	["0078_00156"] = {
