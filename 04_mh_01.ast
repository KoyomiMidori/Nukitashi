	["0078_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What am I supposed to do? Just walking in silence will probably make her think I'm boring and awkward.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么办。一直沉默的话可能会被认为是个无聊的家伙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼辦。一直沉默的話可能會被認為是個無聊的傢伙。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00159",
		linknext = "0078_00161",
		line = 2147,
	},
	["0078_00161"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm not, though! I swear I'm a sparkling conversationalist! I must just be having an off day, that's all!",
					{"rt2"},
				},
			},
			cn = {
				{
					"不是的，我其实是个很会讲有趣故事的男人。虽然现在不知道为什么没了话题，但我其实是更……！",
					{"rt2"},
				},
			},
			tw = {
				{
					"不是的，我其實是個很會講有趣故事的男人。雖然現在不知道為什麼沒了話題，但我其實是更……！",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00160",
		linknext = "0078_00162",
		line = 2159,
	},
	["0078_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At times like this, I only have one resource to fall back on: eroge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种时候能依靠的——果然还是色情游戏吗？",
