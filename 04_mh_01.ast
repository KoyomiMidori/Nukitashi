			},
		},
		linkback = "0078_00142",
		linknext = "0078_00144",
		line = 1911,
	},
	["0078_00144"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You see anyone else here? Yes, you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不然还有谁呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不然還有誰呢？」",
