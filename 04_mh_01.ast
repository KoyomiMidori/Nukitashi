				{"vo", file="asane1232", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Funny you say that, considering I seem to remember Nanase being the one who noticed...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不是奈奈濑同学注意到的吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不是奈奈瀨同學注意到的嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00206",
		linknext = "0078_00208",
		line = 2757,
	},
	["0078_00208"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0494", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Really? It wasn't Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶，是这样吗……我还以为是橘同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸，是這樣嗎……我還以為是橘同學。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00207",
		linknext = "0078_00209",
		line = 2772,
	},
	["0078_00209"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00120", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1233", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Heh, imagine thinking my brother is actually reliable. Don't like him so much now, do ya?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“并不是……哥哥没有那种能耐……嘿嘿，这下对哥哥的好感度降低了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「並不是……哥哥沒有那種能耐……嘿嘿，這下對哥哥的好感度降低了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00208",
		linknext = "0078_00210",
		line = 2785,
	},
	["0078_00210"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, okay, that's enough. No more compromising the organization's integrity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要在组织制造紧张气氛啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要在組織製造緊張氣氛啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00209",
		linknext = "0078_00211",
		line = 2797,
	},
	["0078_00211"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=100, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="移動", x=-200, y=0, time=500},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0495", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Thanks for noticing, Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“奈奈濑同学，谢谢你注意到我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「奈奈瀨同學，謝謝你注意到我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00210",
		linknext = "0078_00212",
		line = 2815,
	},
	["0078_00212"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00121", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=0, y=100},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-100, time=700},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=500},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=500},
		{"text"},
		delay = {
			[600] = {
				{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, delay2=600, time=300, mode=3, x=-600, y=0},
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=600, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1234", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Whoa, whoa, hold up there! Nanase is mine!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喂你在干什么这次的目标是奈奈濑同学吗啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喂你在幹什麼這次的目標是奈奈瀨同學嗎啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00211",
		linknext = "0078_00213",
		line = 2835,
	},
	["0078_00213"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you don't stop bitching, Nanase's gonna get creeped out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太像只疯狗了……奈奈濑都吓到了哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太像只瘋狗了……奈奈瀨都嚇到了哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00212",
		linknext = "0078_00214",
		line = 2847,
	},
	["0078_00214"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00102", file2="asane_02m_00201", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1235", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hotori and I are great friends, Nanase!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我和畔同学的关系非常好哦奈奈濑同学……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我和畔同學的關係非常好哦奈奈瀨同學……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00213",
		linknext = "0078_00215",
		line = 2861,
	},
	["0078_00215"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00119", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1927", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hmm? Sorry, were you talking to me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“咦？对不起，你说了什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「咦？對不起，你說了什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00214",
		linknext = "0078_00216",
		line = 2875,
	},
	["0078_00216"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you, an eroge protagonist?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是色情游戏的主人公吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是色情遊戲的主角嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00215",
		linknext = "0078_00217",
		line = 2887,
	},
	["0078_00217"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, where were we? Oh, that's right, going on the offensive.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我们在说什么来着——对了，我们要转守为攻。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我們在說什麼來著——對了，我們要轉守為攻。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00216",
		linknext = "0078_00218",
		line = 2899,
	},
	["0078_00218"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1928", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The place to start with that would be looking for this Fumino girl, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样的话……果然是要去找出文乃这个孩子吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣的話……果然是要去找出文乃這個孩子嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00217",
		linknext = "0078_00219",
		line = 2915,
	},
	["0078_00219"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0496", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Fumino is the girl our sponsor wanted us to find, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“文乃……那个出资者叫我们找的人是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「文乃……那個出資者叫我們找的人是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00218",
		linknext = "0078_00220",
		line = 2929,
	},
	["0078_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. However, we don't have anywhere near enough information to work on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。不过，现在的情报实在是太少了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。不過，現在的情報實在是太少了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00219",
		linknext = "0078_00221",
		line = 2940,
	},
	["0078_00221"] = {
		{"fg", file="hinami_01f_00001", file1="hinami_01f_00112", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1947", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I don't think Misaki was around when we heard. Her name is Kotoyose Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“美岬酱有没有听说过琴寄文乃这个名字……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「美岬醬有沒有聽說過琴寄文乃這個名字……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00220",
		linknext = "0078_00222",
		line = 2953,
	},
	["0078_00222"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		delay = {
			[6000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=6000, time=300, mode=3, x=600, y=0},
				{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", delay2=6000},
			},
			[10000] = {
				{"fg", file="misaki_01m_00001", file3="misaki_01m_00301", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=10000, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0497", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Kotoyose Fumino, Kotoyose Fumino... Hmm... Ah, my mother's maiden name is Fumiko Kotobuki! That's kind of similar!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“琴寄文乃、琴寄文乃……嗯……啊！母亲的旧名是琴吹史子！有点像！！”",
					{"rt2"},
				},
			},
			tw = {
