			},
			tw = {
				{
					name = {"郁子"},
					"「欸，蘭醬？怎麼喘成那樣啊，長跑窒息play嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00080",
		linknext = "0078_00082",
		line = 1032,
	},
	["0078_00082"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00103", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0199", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“No! I've been looking for you, Onabuta! I need to take you to the gymnasium immediately! We're setting things up for the Shootdown King awards ceremony!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“并不是！我是来找你的女部田同学！现在马上到体育馆来！有击坠王的表扬准备要做……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「並不是！我是來找你的女部田同學！現在馬上到體育館來！有擊墜王的表揚準備要做……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00081",
		linknext = "0078_00083",
		line = 1046,
	},
	["0078_00083"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00116", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0155", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Aww, who cares if one person is missing? I'm combat personnel anyway, I don't need to be involved with these ceremonial duties.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“咦～少一个人也没关系吧——？郁本来就是战斗员，跟我又没什么关系……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「咦～少一個人也沒關係吧——？郁本來就是戰鬥員，跟我又沒什麼關係……」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00082",
		linknext = "0078_00084",
		line = 1060,
	},
	["0078_00084"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00106", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0200", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“That doesn't matter! Please, just come on! Rei will yell at me again if I come back without you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“没有那种事……求求你了，快过来吧！如果不带你过去我会被礼前辈骂的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「沒有那種事……求求你了，快過來吧！如果不帶你過去我會被禮前輩罵的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00083",
		linknext = "0078_00085",
		line = 1074,
	},
	["0078_00085"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00115", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0156", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ugh, fine. Jeez, just when things were getting good...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唔——真是拿你没办法啊。明明刚要开始精彩而已……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「唔——真是拿你沒辦法啊。明明剛要開始精彩而已……」",
					{"rt2"},
				},
