		line = 9254,
	},
	["0075_00624"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm going to finish this for her as well... so no one is ever made to cry the way she's crying ever again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是为了她——我再也不希望有人流下那样的眼泪。",
