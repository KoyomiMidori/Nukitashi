	["0075_00354"] = {
		{"se", id=0, loop=0, file="se_b060"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine", x=395, y=95},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Gritos fuertes resuenan por el bosque durante la noche.",
