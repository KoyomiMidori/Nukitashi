	},
	["0075_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've already surmised what she wants to say from the look on her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是看了看那双瞳孔，我就差不多察觉到她想说什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是看了看那雙瞳孔，我就差不多察覺到她想說什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00082",
		linknext = "0075_00084",
		line = 1097,
	},
	["0075_00084"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0262", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This is something my father started. So please... permit me this one time to make myself useful to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这本来就是我父亲做出来的事情。所以现在，还请各位……让文乃帮忙大家吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這本來就是我父親做出來的事情。所以現在，還請各位……讓文乃幫忙大家吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00083",
		linknext = "0075_00085",
		line = 1109,
	},
	["0075_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I really could do with even just one more person right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，现在是非常需要战斗力的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，現在是非常需要戰鬥力的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00084",
		linknext = "0075_00086",
		line = 1119,
	},
	["0075_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she's the main target for them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是文乃也是对方最大的目的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是文乃也是對方最大的目的。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00085",
		linknext = "0075_00087",
		line = 1129,
	},
	["0075_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sending her out there to fight would be suicidal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"让她自己出征无疑是自杀行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"讓她自己出征無疑是自殺行為。",
