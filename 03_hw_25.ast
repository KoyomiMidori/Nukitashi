			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No point pondering it over. We don't even know that old fart's name, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“想也没有用……我们连那个人的名字都不知道。”",
