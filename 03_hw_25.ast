					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“怎么回事……真不可思议，拿着椅子什么事都很顺手。总觉得输不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「怎麼回事……真不可思議，拿著椅子什麼事都很順手。總覺得輸不了。」",
					{"rt2"},
