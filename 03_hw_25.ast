	["0075_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si bien la vanguardia debería ser responsabilidad mía, el avance constante de Hinami mientras sostiene su silla es formidable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来应该由我来打头阵的——可是拿着椅子的雏见的进攻非常猛烈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來應該由我來打頭陣的——可是拿著椅子的雛見的進攻非常猛烈。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00254",
		linknext = "0075_00256",
		line = 3584,
	},
	["0075_00256"] = {
		{"se", id=0, loop=0, file="se_b021"},
		{"cgact", file="cgact", id=2, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine", lv=5, x=395, y=95},
		{"text"},
		delay = {
			[700] = {
				{"se", id=0, loop=0, file="se_b054", delay2=700},
				{"cgact", file="cgact", id=2, act="浮遊横", loop=1, size=12.5, time=75, ease="inout", delay2=700, lv=5, x=395, y=95},
			},
		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No importa cuántos enemigos se interpongan en su camino, sus balas rebotan contra su silla y los dejan fuera de combate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论有多少敌人阻挡，椅子都会反弹防暴弹一击将对方打倒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論有多少敵人阻擋，椅子都會反彈防暴彈一擊將對方打倒。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00255",
		linknext = "0075_00257",
		line = 3598,
	},
	["0075_00257"] = {
		{"se", id=0, loop=0, file="se_b058"},
		{"cgact", file="cgact", id=2, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine", lv=5, x=395, y=95},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso en combate a corta distancia, cuando los enemigos se lanzan a atacar, la silla siempre contrarresta su ataque y deja tras de sí una estela de enemigos inconscientes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"近距离交战时，发起攻击的对手都不知为何会遭到椅子的反击，一个接一个地倒在地上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"近距離交戰時，發起攻擊的對手都不知為何會遭到椅子的反擊，一個接一個地倒在地上。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00256",
		linknext = "0075_00258",
		line = 3610,
	},
	["0075_00258"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es que estemos haciendo nada... Es más bien que los enemigos nos están disparando en un momento y al siguiente están tirados en el suelo.",
