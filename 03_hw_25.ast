			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ahh, throwing my voice like that wears me out... I'm the cyber warfare girl around here, this ain't supposed to be my job...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——喊太大声我都累了……这不是计算机人员的工作吧……”",
