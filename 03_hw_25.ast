	["0075_00762"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debía de estar funcionando solo con mi fuerza de voluntad. En cuanto termina la pelea, la fuerzas abandona mi cuerpo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"身体大概是靠毅力在动的吧——我就像断了线的人偶般，全身的力量消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"身體大概是靠毅力在動的吧——我就像斷了線的人偶般，全身的力量消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00761",
		linknext = "0075_00763",
		line = 11512,
	},
	["0075_00763"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Te gané...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我……赢了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我……贏了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00762",
		linknext = "0075_00764",
		line = 11524,
	},
	["0075_00764"] = {
		{"fg", file="hitoura_02m_00001", file1="hitoura_02m_00120", file2="hitoura_02m_00202", path=":fg/hitoura_02m/", id=10, lv=5, head="hitoura_02m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=-22},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0129", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Ja... Sigo vivo... Para mí, esto no es una derrota.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哈……我可还活着……光是这样，我可不会承认是我输了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哈……我可還活著……光是這樣，我可不會承認是我輸了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00763",
		linknext = "0075_00765",
		line = 11537,
	},
	["0075_00765"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... No seas pedante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真是强词夺理啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真是強詞奪理啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00764",
		linknext = "0075_00766",
		line = 11548,
	},
	["0075_00766"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0130", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Ja... Así son los villanos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哈……因为我是坏人啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哈……因為我是壞人啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00765",
		linknext = "0075_00767",
		line = 11560,
	},
	["0075_00767"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0131", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Pero... ya no puedo levantarme. Ser el único villano aquí me hace sentir bastante vacío... Quizás sea hora de retirarme...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“可是……到底是站不起来了……自己一个人当坏人……也很是空虚……或许是时候撤退了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「可是……到底是站不起來了……自己一個人當壞人……也很是空虛……或許是時候撤退了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00766",
		linknext = "0075_00768",
		line = 11572,
	},
	["0075_00768"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso ahora, se resiste a admitir la derrota.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来他就算硬着头皮，也不想说自己输了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來他就算硬著頭皮，也不想說自己輸了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00767",
		linknext = "0075_00769",
		line = 11582,
	},
