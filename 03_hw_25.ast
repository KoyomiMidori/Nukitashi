	["0075_00071"] = {
		{"fg", mode=-1, id=3, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan, ¿qué planea la SS ahora?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后——麻沙酱，我再问你一次，FS的情况怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後——麻沙醬，我再問你一次，FS的情況怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00070",
		linknext = "0075_00072",
		line = 949,
	},
	["0075_00072"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="asane_02m_00001", file1="asane_02m_00120", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1182", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, sí. Pues veamos... Ahhhhhhh... Ay no... ¿Quieres que te lo resuma primero?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，对对对……嗯，我看看……啊——啊——啊——这个……如果用一句话来说……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，對對對……嗯，我看看……啊——啊——啊——這個……如果用一句話來說……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00071",
		linknext = "0075_00073",
		line = 964,
	},
	["0075_00073"] = {
		{"text"},
		text = {
			ja = {
				{
