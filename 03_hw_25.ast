					{"rt2"},
				},
			},
			en = {
				{
					"Aun en una situación tan drástica, su objetivo sigue siendo el mismo. Su ojo sano está enfocado en lo que tiene delante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使陷入这样的困境，文乃也没有打偏目标——她充满生气的眼睛只是专心凝视着前方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使陷入這樣的困境，文乃也沒有打偏目標——她充滿生氣的眼睛只是專心凝視著前方。",
					{"rt2"},
				},
			},
		},
