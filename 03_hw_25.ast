				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Aunque quería protegerte... en algún momento lo olvidé...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我一直想保护雏见，可是……不知从什么时候开始，连这个都想不起来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我一直想保護雛見，可是……不知從什麼時候開始，連這個都想不起來了……」",
					{"rt2"},
