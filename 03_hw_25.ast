		line = 167,
	},
	["0075_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All I gotta do is bring down the SS and the SHO, and then kick that fucker's ass. Then everything's resolved, happy ending, roll credits.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“打倒SS和SHO,暴打那个男人——这样就可以解决全部问题然后happy end了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「打倒SS和SHO,暴打那個男人——這樣就可以解決全部問題然後happy end了。」",
					{"rt2"},
				},
			},
