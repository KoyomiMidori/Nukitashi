		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No me importa si tengo que darlo todo. Voy a seguir controlándolo hasta que encuentre el momento para vencerlo con todas mis fuerzas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算耗尽精力也没关系。为了胜利而拼尽全力到达这个地方——就是为了这一瞬间。",
