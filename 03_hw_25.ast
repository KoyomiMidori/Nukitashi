		{"bg", id=15, file="bg04_3l_00000", x=20, y=0, lv=5, path=":bg/", sync=0, ev=1, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=15, act="移動", x=-25, y=-5, time=2000, lv=5},
		{"bg", id=16, file="rci_l0108-1", x=-380, y=-130, path=":cg/rci_l/", lv=5, ev=1, time=500, bx=800, by=450},
		{"cgact", file="cgact", id=16, act="移動", x=20, y=0, time=2000, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0766", path=":vo/", ch="rei"},
