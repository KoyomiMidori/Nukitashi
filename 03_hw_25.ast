				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jaa... Tú lo dices con una facilidad...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“唉……你说得也太简单了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「唉……你說得也太簡單了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00013",
		linknext = "0075_00015",
		line = 193,
	},
	["0075_00015"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero es mejor que inventarse un plan rebuscado, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“实际上确实比想一大堆困难的事情要容易多了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「實際上確實比想一大堆困難的事情要容易多了吧？」",
					{"rt2"},
				},
			},
