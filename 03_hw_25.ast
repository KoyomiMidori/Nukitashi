	["0075_00066"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file3="misaki_01m_00309", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Este Plan Nacional de Conversión Pervertida no florecerá, No lo permitiremos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……日本全土变态化计划——这是不可能实现的，我们不会让它实现的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……日本全土變態化計劃——這是不可能實現的，我們不會讓它實現的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00065",
		linknext = "0075_00067",
		line = 880,
	},
	["0075_00067"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pueden decir todas las tonterías que quieran. Nuestro objetivo no cambiará.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管有没有那种玩笑般的计划，我们做的事情都不会改变。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管有沒有那種玩笑般的計劃，我們做的事情都不會改變。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00066",
		linknext = "0075_00068",
		line = 892,
	},
	["0075_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tenemos que acabar con el gobernador... No...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“仁浦知事——不对——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「仁浦知事——不對——」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00067",
		linknext = "0075_00069",
		line = 904,
	},
	["0075_00069"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Tenemos que acabar con el gobernador y destruir la ley súperpervertida! ¡Eso es lo que haremos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“打倒仁浦，摧毁变态条例！仅此而已！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「打倒仁浦，摧毀變態條例！僅此而已！」",
					{"rt2"},
				},
			},
