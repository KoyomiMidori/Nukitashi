		linkback = "0075_00010",
		linknext = "0075_00012",
		line = 155,
	},
	["0075_00012"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hasta debería darle las gracias. Me proporcionó una manera de destruir la ley.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“倒不如说该感激他呢，还特地自己给了我破坏条例的机会。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「倒不如說該感激他呢，還特地自己給了我破壞條例的機會。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00011",
		linknext = "0075_00013",
		line = 167,
	},
	["0075_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Todo solo tengo que acabar con la SS y la OSS, y luego le daré una paliza a ese imbécil. Todo habrá terminado y tendremos un final feliz.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“打倒FS和SHO,暴打那个男人——这样就可以解决全部问题然后happy end了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「打倒FS和SHO,暴打那個男人——這樣就可以解決全部問題然後happy end了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00012",
		linknext = "0075_00014",
		line = 178,
	},
	["0075_00014"] = {
