		linkback = "0075_00529",
		linknext = "0075_00531",
		line = 8016,
	},
	["0075_00531"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hits me so hard it tears the usually irremovable goggles from my face, forcefully deactivating the Ariadne Protocol.",
					{"rt2"},
				},
			},
			cn = {
				{
					"激烈的冲击——绝对不会脱落的护目镜锁被破坏，Ariadne协议被强制解除。",
					{"rt2"},
				},
			},
			tw = {
				{
					"激烈的衝擊——絕對不會脫落的護目鏡鎖被破壞，Ariadne協議被強制解除。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00530",
		linknext = "0075_00532",
		line = 8026,
	},
	["0075_00532"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0767", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hinami still confides in me, even for the worthless, desecrated shell of a human I am! If I couldn't keep myself safe... the least I wanted to do was keep her safe!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就算是这么脏的我，雏见也伸出了援手……所以……我想替她守护我没能守护的东西！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就算是這麼髒的我，雛見也伸出了援手……所以……我想替她守護我沒能守護的東西！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00531",
		linknext = "0075_00533",
		line = 8039,
	},
	["0075_00533"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her grip on me gradually relaxes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"锁住关节的手逐渐开始失去力量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"鎖住關節的手逐漸開始失去力量。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00532",
		linknext = "0075_00534",
		line = 8049,
	},
	["0075_00534"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00124", file2="rei_01l_00206", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0768", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I believed you... to be just like me. Someone who couldn't blend in, and was bullied for it... Bereaved of your parents, with only your sister for company...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我感觉……你跟我很像。不适应这个岛，被欺负……父母不在了，但是有个妹妹……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我感覺……你跟我很像。不適應這個島，被欺負……父母不在了，但是有個妹妹……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00533",
		linknext = "0075_00535",
		line = 8063,
	},
	["0075_00535"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0769", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And yet, even without any remarkable strengths, you're still able to sustain yourself through sheer force of will... You left an impression on me. Almost like you were a manifestation of my past self.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“明明没有什么了不起的实力，却只有毅力能够独挡一面……总觉得和以前的自己一样……我的心被吸引了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「明明沒有什麼了不起的實力，卻只有毅力能夠獨擋一面……總覺得和以前的自己一樣……我的心被吸引了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00534",
		linknext = "0075_00536",
		line = 8075,
	},
	["0075_00536"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0770", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“When I discovered how much you loathed copulation... I thought to myself, 'I want to let him travel a road that was never open to me.'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“当我知道那样的你，讨厌性行为……我想让你走自己没能走的路……我是这样想的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「當我知道那樣的你，討厭性行為……我想讓你走自己沒能走的路……我是這樣想的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00535",
		linknext = "0075_00537",
		line = 8087,
	},
	["0075_00537"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei-senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼、前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮、前輩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00536",
		linknext = "0075_00538",
		line = 8099,
	},
	["0075_00538"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", file2="rei_01l_00206", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0771", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But that's a pipe dream. Nothing but a selfish fancy. Reality isn't so kind a place to let that happen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……但是，这些都是梦中的故事，是我的自我满足。这是不可能实现的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……但是，這些都是夢中的故事，是我的自我滿足。這是不可能實現的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00537",
		linknext = "0075_00539",
		line = 8113,
	},
	["0075_00539"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=100},
		{"bg", id=1, file="bg04_3l_00000", x=-150, y=-200, path=":bg/", sync=0, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"bg", id=16, file="rci_l0106", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, bx=800, by=450},
		{"bg", id=18, file="pm301-1", x=-5, y=-5, path=":cg/pm3/", lv=5, ev=1, bx=800, by=450},
		{"bg", id=14, file="bg04_3l_00000", x=-100, y=0, lv=5, path=":bg/", sync=0, ev=1, style="blur", blurx=11, blury=11, ax=1280, ay=730, bx=-480, by=-280},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0772", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I am Tadasugawa Rei, the disciplinary committee president... I cannot show mercy to those who defy the law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我是风纪委员长，糺川礼……对背叛者……对违反条例者决不饶恕……”",
					{"rt2"},
				},
			},
			tw = {
				{
