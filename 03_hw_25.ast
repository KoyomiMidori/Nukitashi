	["0075_00007"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=5, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0445", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Tranquila! ¡No tienes que preocuparte por eso, Fumino-chan! ¡Somos un grupo criminal de forajidos, así que no culpamos a nadie!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“原来原来！这不是文乃酱要在意的事！我们是违反条例的犯罪集团，不是你一个人的责任！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「原來原來！這不是文乃醬要在意的事！我們是違反條例的犯罪集團，不是你一個人的責任！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00006",
		linknext = "0075_00008",
		line = 105,
	},
	["0075_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es verdad. Somos unos forajidos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔说的没错，我们全都违反了条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔說的沒錯，我們全都違反了條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00007",
		linknext = "0075_00009",
		line = 117,
	},
	["0075_00009"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cuando se acabó esa mierda de la industria sexual ilegal, sí o sí habrían venido por nosotros. No tienes que preocuparte por eso, Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“地下风俗的事情解决后，本来就差不多该盯上我们了。文乃不用在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「地下風俗的事情解決後，本來就差不多該盯上我們了。文乃不用在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00008",
		linknext = "0075_00010",
		line = 129,
	},
	["0075_00010"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00115", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0259", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Pero... mi padre no se detendrá conmigo. También irá por ti...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“可是……父亲他不仅想要我，连橘同学也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「可是……父親他不僅想要我，連橘同學也……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00009",
		linknext = "0075_00011",
		line = 143,
	},
	["0075_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
