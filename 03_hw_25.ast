	},
	["0075_00508"] = {
		{"cgdel", id=15, lv=5, time=100, alphadel=1},
		{"cgdel", id=16, lv=5, time=100, alphadel=1},
		{"cgact", file="cgact", id=17, act="stopact", lv=5, alpha="0,256"},
		{"cgdel", id=17, lv=5, time=100, alphadel=1},
		{"fg", file="rei_01l_00001", file1="rei_01l_00104", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0759", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Haha... Why don't I tell them, you ask? Why won't I go against them, you ask?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈……你说为什么不发出声音……？为什么不举起反旗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈……你說為什麼不發出聲音……？為什麼不舉起反旗……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00507",
		linknext = "0075_00509",
		line = 7725,
	},
	["0075_00509"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0760", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, let me ask you this! How do you survive from day to day? Do you live on air? Does your belief in destroying the law nourish your stomach?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那我问你！你每天是怎么生活的！？你是靠吃晚霞生活的吗！？破坏条例的信念能让你填饱肚子吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那我問你！你每天是怎麼生活的！？你是靠吃晚霞生活的嗎！？破壞條例的信念能讓你填飽肚子嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00508",
		linknext = "0075_00510",
		line = 7739,
	},
	["0075_00510"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0761", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Does it pay your bills and put a roof over your head? Does it keep your family safe!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那个信念能把钱汇给我吗！？能保护我的家人！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那個信念能把錢匯給我嗎！？能保護我的家人！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00509",
		linknext = "0075_00511",
		line = 7751,
	},
	["0075_00511"] = {
		{"se", id=0, loop=0, file="se_a129"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=12.5, time=75, ease="easeinout_sine"},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=75, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gah, aah!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊、啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊、啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00510",
		linknext = "0075_00512",
		line = 7766,
	},
	["0075_00512"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She twists my arm so hard with my face against the floor that I feel like it's being ripped off from the pain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被勒紧关节的同时，头部被摔在地板上，手臂上传来快被拉断的剧痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被勒緊關節的同時，頭部被摔在地板上，手臂上傳來快被拉斷的劇痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00511",
		linknext = "0075_00513",
		line = 7776,
	},
	["0075_00513"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0762", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Resentment? Sadness? I couldn't care less about those things... This is how I've survived! Don't get cocky with me when you don't know shit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“痛苦？悲伤？那种事有什么关系……这一切都是为了活下去！不要得寸进尺，你明明什么都不知道……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「痛苦？悲傷？那種事有什麼關係……這一切都是為了活下去！不要得寸進尺，你明明什麼都不知道……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00512",
		linknext = "0075_00514",
		line = 7790,
	},
	["0075_00514"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00304", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't know shit?! How am I suppose to know when you don't tell me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我当然不知道……！因为前辈什么都不告诉我啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我當然不知道……！因為前輩什麼都不告訴我啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00513",
		linknext = "0075_00515",
		line = 7802,
	},
	["0075_00515"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hit her with a barrage of words, to keep myself from screaming in pain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不发出尖叫，而是跟她对话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不發出尖叫，而是跟她對話。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00514",
		linknext = "0075_00516",
		line = 7812,
	},
	["0075_00516"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you really just gonna let Hitoura have his way!? You can't even imagine how many people will suffer just like you if he does!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你打算就这样对仁浦的恶行置之不理吗？如果让那个男人得逞，像你这样的人还会继续增加的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你打算就這樣對仁浦的惡行置之不理嗎？如果讓那個男人得逞，像你這樣的人還會繼續增加的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00515",
		linknext = "0075_00517",
		line = 7824,
	},
	["0075_00517"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00104", file2="rei_01l_00206", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0763", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I don't give a fuck! This... This was the only path in life available to me, and I had to shut up and take it! It's not my problem if everyone else goes through the same!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我哪管得着！我……我，无论多么讨厌都只能选择这条路！只要大家都有同样的感受就好了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我哪管得著！我……我，無論多麼討厭都只能選擇這條路！只要大家都有同樣的感受就好了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00516",
		linknext = "0075_00518",
		line = 7838,
	},
	["0075_00518"] = {
		{"se", id=0, loop=0, file="se_a129"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine"},
		{"fgact", ch="礼", id=9, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh...!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咕…………！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咕…………！！」",
					{"rt2"},
