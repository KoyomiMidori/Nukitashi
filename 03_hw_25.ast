			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei-chan... Thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱……谢谢你……”",
