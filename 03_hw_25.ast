	["0075_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Bien, es hora de separarnos según el plan! ¡Nanase, lleva a Hotori y Fumino por la escalera este hasta la zona designada! ¿Puedes hacerlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“按照作战计划分为两组！奈奈濑从东楼梯先行将畔和文乃带到指定地点！能做到吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「按照作戰計劃分為兩組！奈奈瀨從東樓梯先行將畔和文乃帶到指定地點！能做到嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00163",
		linknext = "0075_00165",
		line = 2196,
	},
	["0075_00165"] = {
