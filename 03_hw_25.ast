	["0075_00355"] = {
		{"se", id=0, loop=0, file="se_b019"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Regreso al Espejo Mágico para recargar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我先把身体藏回魔镜号里装子弹。",
