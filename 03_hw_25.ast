	["0075_00637"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está sentado en el piso, en posición seiza, con los ojos cerrados. Se mire por donde se mire, parece estar meditando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他跪坐着合上眼睑——仿佛在冥想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他跪坐著闔上眼皮——彷彿在冥想。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00636",
		linknext = "0075_00638",
