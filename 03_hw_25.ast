		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estamos decididos a ganar. Eso es lo único en lo que debemos pensar ahora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我下定决心一定要赢。现在，只要考虑这件事就好了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我下定決心一定要贏。現在，只要考慮這件事就好了。",
