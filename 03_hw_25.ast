	["0075_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En la oscuridad de la noche, la vía tiene una visibilidad pésima. Como el pavimento también es irregular, el vehículo se balancea constantemente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"夜幕笼罩下，葱葱郁郁的森林中视野极差，路也不好走，车辆不停地摇晃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"夜幕籠罩下，蔥蔥鬱鬱的森林中視野極差，路也不好走，車輛不停地搖晃。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00367",
		linknext = "0075_00369",
		line = 5558,
	},
	["0075_00369"] = {
