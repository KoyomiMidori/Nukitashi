	["0075_00354"] = {
		{"se", id=0, loop=0, file="se_b060"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine", x=395, y=95},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Loud screams peal through the forest at night.",
					{"rt2"},
				},
			},
			cn = {
				{
					"夜晚的森林里，传来尖锐的悲鸣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"夜晚的森林裡，傳來尖銳的悲鳴。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00353",
		linknext = "0075_00355",
		line = 5374,
	},
	["0075_00355"] = {
		{"se", id=0, loop=0, file="se_b019"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I retreat into the Magical Mirror to reload.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我先把身体藏回魔镜号里装子弹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我先把身體藏回魔鏡號裡裝子彈。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00354",
		linknext = "0075_00356",
		line = 5385,
	},
	["0075_00356"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We shoot one and another pops up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么射击都没完没了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼射擊都沒完沒了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00355",
		linknext = "0075_00357",
		line = 5397,
	},
	["0075_00357"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1196", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“We've got a huge amount of SHO running after us... Isn't this kinda overkill for just six people?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没想到这里配置了这么多的SHO警卫……只对付6个人这样会不会太没风度了啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒想到這裡配置了這麼多的SHO警衛……只對付6個人這樣會不會太沒風度了啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00356",
		linknext = "0075_00358",
		line = 5410,
	},
	["0075_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It doesn't matter who he's up against, or how many. He's not giving up. That's how he is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对方无论几个人还是是谁都不会手下留情的——他就是那样的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對方無論幾個人還是是誰都不會手下留情的——他就是那樣的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00357",
		linknext = "0075_00359",
		line = 5421,
	},
	["0075_00359"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just keep your head down and get up front with Hinami. They could target you if you stay here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个，你最好和雏见一起退到里面去——在这里可能会成为靶子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個，你最好和雛見一起退到裡面去——在這裡可能會成為靶子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00358",
		linknext = "0075_00360",
		line = 5433,
	},
	["0075_00360"] = {
		{"se", id=0, loop=0, file="se_b021"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine", x=395, y=95},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I shoot one of the pursuing guards through the wide aperture of the rear door.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从敞开的后门击倒了一个警卫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從敞開的後門擊倒了一個警衛。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00359",
		linknext = "0075_00361",
		line = 5445,
	},
	["0075_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no end to them. It's honestly a little draining to think about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论打倒多少人还是无穷无尽地涌出，真是让人郁闷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論打倒多少人還是無窮無盡地湧出，真是讓人鬱悶。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00360",
		linknext = "0075_00362",
		line = 5455,
	},
	["0075_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But we have one specific reason why they're being dealt with so efficiently.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是就算这样，我还是能如此感觉不到威胁——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是就算這樣，我還是能如此感覺不到威脅——",
					{"rt2"},
				},
			},
