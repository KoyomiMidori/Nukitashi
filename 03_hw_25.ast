	["0075_00198"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=10, time=300, alphadel=1, stop=0, lv=5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00110", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1188", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Manito, pero qué ruin eres.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥，你还真坏啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥，你還真壞啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00197",
		linknext = "0075_00199",
		line = 2672,
	},
	["0075_00199"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo intento engañarlos. Ya tienen su campo de visión obstruido, así que quiero que...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是为了逃离出去。比起那个，趁视线被封住的现在——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是為了逃離出去。比起那個，趁視線被封住的現在——」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00198",
		linknext = "0075_00200",
		line = 2684,
	},
	["0075_00200"] = {
		{"fg", file="asane_02l_00001", file1="asane_02l_00101", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
