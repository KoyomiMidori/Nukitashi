	["0075_00686"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Este hombre juró pervertir a todo Japón. Como era de esperarse, su habilidad es tan descabellada como su mentalidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不愧是说出日本全土变态化计划这种狂言的男人——头脑疯狂的家伙似乎连剑法都很疯狂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不愧是說出日本全土變態化計劃這種狂言的男人——頭腦瘋狂的傢伙似乎連劍法都很瘋狂。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00685",
		linknext = "0075_00687",
		line = 10144,
	},
