				},
			},
			cn = {
				{
					name = {"礼"},
					"“……哈……我是自己人吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……哈……我是自己人嗎……」",
