	["0075_00602"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0800", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Huh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……咦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……咦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00601",
		linknext = "0075_00603",
		line = 8946,
	},
	["0075_00603"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1812", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You've kept me safe all this time... Thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“谢谢你至今……一直守护着我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「謝謝你至今……一直守護著我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00602",
		linknext = "0075_00604",
		line = 8958,
	},
	["0075_00604"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0801", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Stop it... I couldn't do anything. I tried to protect you... but look at how I went about it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别说了……我……什么都没能做到……就算想保护雏见……这样的方式也……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別說了……我……什麼都沒能做到……就算想保護雛見……這樣的方式也……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00603",
		linknext = "0075_00605",
		line = 8970,
	},
	["0075_00605"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1813", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, that's not true. The reason I'm here now is because of you Rei-chan. So thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，没那回事。现在我能在这里……都是多亏了礼酱……所以，谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，沒那回事。現在我能在這裡……都是多虧了禮醬……所以，謝謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00604",
		linknext = "0075_00606",
		line = 8982,
	},
	["0075_00606"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei-senpai shakes her head, and desperately tries to deny what Hinami says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈摇了摇头，拼命地想否定雏见的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩搖了搖頭，拼命地想否定雛見的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00605",
		linknext = "0075_00607",
		line = 8992,
	},
	["0075_00607"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she just remains speechless, as her tears continue to flow.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她说不出话来，只是不断流泪————",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她說不出話來，只是不斷流淚————",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00606",
		linknext = "0075_00608",
		line = 9002,
	},
	["0075_00608"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0802", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hinami... Are you saying that everything I've done... wasn't in vain?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见……我的所作所为……难道不是毫无意义吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見……我的所作所為……難道不是毫無意義嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00607",
		linknext = "0075_00609",
		line = 9014,
	},
	["0075_00609"] = {
		{"cgdel", id=18, lv=5, time=100, alphadel=1},
		{"bg", id=2, file="whiteback_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=800, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="hcg04b_l01011", x=-730, y=520, path=":cg/hcg04b_l/", lv=5, time=800, bx=800, by=450},
		{"text"},
		text = {
