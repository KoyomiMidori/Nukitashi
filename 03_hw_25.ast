				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y si lo hay, una niña que lleva consigo su querida silla las veinticuatro horas del día debe de ser amada por ese dios, por lo que, a cambio, le brinda protección divina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"24小时随身携带椅子、热爱椅子的少女——也许因此受到了椅子之神的爱戴与保佑吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"24小時隨身攜帶椅子、熱愛椅子的少女——也許因此受到了椅子之神的愛戴與保佑吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00241",
		linknext = "0075_00243",
		line = 3333,
	},
	["0075_00243"] = {
