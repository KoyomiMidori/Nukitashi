					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya no tendrás que contenerte más. Ya no tendrás que afrontar las cosas sola. Estoy aquí... Estamos aquí para ti.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“从今以后，你不用再忍耐了……不用再一个人努力了……因为我……我们会陪着你的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「從今以後，你不用再忍耐了……不用再一個人努力了……因為我……我們會陪著你的……」",
					{"rt2"},
				},
			},
		},
