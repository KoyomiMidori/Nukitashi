	["0075_00491"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿De verdad me odias tanto? ¿Es porque soy un traidor? ¿Porque soy un no-copulador?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你那么恨我吗！？那么恨叛徒——那么恨反交尾势力吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你那麼恨我嗎！？那麼恨叛徒——那麼恨反交尾勢力嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00490",
		linknext = "0075_00492",
		line = 7443,
	},
	["0075_00492"] = {
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Si tanto me odias, solo dímelo! ¡Dime con tus propias palabras que me odias! ¡Dime que quieres matarme!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就说出来吧！？说你恨我，想把我杀死！！”",
