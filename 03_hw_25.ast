	["0075_00007"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=5, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0445", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Mube mube! You don't need to worry about it, Fumino-chan! We're a criminal group of outlaws, so we don't lay the blame on anyone!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“原来原来！这不是文乃酱要在意的事！我们是违反条例的犯罪集团，不是你一个人的责任！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「原來原來！這不是文乃醬要在意的事！我們是違反條例的犯罪集團，不是你一個人的責任！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00006",
		linknext = "0075_00008",
		line = 105,
	},
	["0075_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
