				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Ha... I'm still alive, you know. This isn't a defeat in my eyes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
