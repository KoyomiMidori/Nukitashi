	},
	["0075_00084"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0262", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Esto es algo que mi padre comenzó. Por favor... permíteme ser útil esta vez.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这本来就是我父亲做出来的事情。所以现在，还请各位……让文乃帮忙大家吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這本來就是我父親做出來的事情。所以現在，還請各位……讓文乃幫忙大家吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00083",
		linknext = "0075_00085",
		line = 1109,
	},
	["0075_00085"] = {
		{"text"},
		text = {
