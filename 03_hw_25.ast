	},
	["0075_00617"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1819", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“There, there. You're free to cry now. Let it all out, from all that time you spent putting up with things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好乖好乖……既然你这么努力了，就尽情哭出来吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好乖好乖……既然你這麼努力了，就盡情哭出來吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00616",
		linknext = "0075_00618",
		line = 9141,
	},
	["0075_00618"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1820", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You won't have to hold back any longer. You won't have to put up with things alone anymore. Because I'm... Because we're here for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“从今以后，你不用再忍耐了……不用再一个人努力了……因为我……我们会陪着你的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「從今以後，你不用再忍耐了……不用再一個人努力了……因為我……我們會陪著你的……」",
					{"rt2"},
				},
			},
		},
