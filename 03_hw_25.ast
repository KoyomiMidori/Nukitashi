				{
					name = {"ヒナミ", "Hinami"},
					"“Rei-chan... Siempre te has esforzado sola. Has estado trabajando muy duro para ayudar a todos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱……礼酱你一直都是一个人在努力……为了大家，自己一个人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬……禮醬你一直都是一個人在努力……為了大家，自己一個人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00591",
		linknext = "0075_00593",
		line = 8826,
	},
	["0075_00593"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0795", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No... Eso no es cierto. Nunca he hecho nada que valga la pena...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我……不对……我根本没有在努力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我……不對……我根本沒有在努力……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00592",
		linknext = "0075_00594",
		line = 8838,
	},
	["0075_00594"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1808", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Claro que sí. Sé que lo has hecho. Desde que tengo memoria, te has esforzado más que nadie.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不……没那回事。因为我知道……礼酱从以前开始……就比谁都努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不……沒那回事。因為我知道……禮醬從以前開始……就比誰都努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00593",
		linknext = "0075_00595",
		line = 8850,
	},
	["0075_00595"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0796", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No... De veras quería cambiar. Pensé que podría cambiar algo cuando me convertí en la presidenta del comité de moral pública...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不是的……我其实……想过要改变。以为成为风纪委员长，就能改变什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不是的……我其實……想過要改變。以為成為風紀委員長，就能改變什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00594",
		linknext = "0075_00596",
		line = 8862,
	},
	["0075_00596"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0797", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pero al final no pude hacer nada... Estaba limitada por las restricciones de mi cargo... Ni siquiera sabía lo que quería hacer...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是，我什么都没做到……被立场绑手绑脚……最后连自己想干什么，也越来越不明白……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是，我什麼都沒做到……被立場綁手綁腳……最後連自己想幹什麼，也越來越不明白……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00595",
		linknext = "0075_00597",
		line = 8874,
	},
	["0075_00597"] = {
		{"text"},
