			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“¡Si quieres paz y sonrisas, debes crear la nación que deseas! ¡Te prometo la paz definitiva!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“想要安稳和笑容的话就拥有自己的国家吧！这样就能维持终极的和平！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「想要安穩和笑容的話就擁有自己的國家吧！這樣就能維持終極的和平！」",
					{"rt2"},
				},
			},
		},
