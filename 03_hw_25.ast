					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ya, ya... Fue duro, ¿verdad? Aguantaste mucho... Hiciste un gran trabajo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好乖好乖……很痛苦吧……很辛苦吧……你很努力呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好乖好乖……很痛苦吧……很辛苦吧……你很努力呢……」",
