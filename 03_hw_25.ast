					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Soy una chica fuerte... Así que, no pierdan de vista su objetivo... ¡No se detengan!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文乃是个坚强的女人……所以，请为了您们的目的……不要停下脚步……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「文乃是個堅強的女人……所以，請為了您們的目的……不要停下腳步……！」",
					{"rt2"},
				},
			},
		},
