			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Of course not. You worked so hard all by yourself. You're a good girl, Rei-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，不是的……你一个人好努力了呢……真了不起啊，礼酱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，不是的……你一個人好努力了呢……真了不起啊，禮醬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00608",
		linknext = "0075_00610",
		line = 9030,
	},
	["0075_00610"] = {
		{"text"},
