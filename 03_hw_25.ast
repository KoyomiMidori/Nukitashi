		linknext = "0075_00582",
		line = 8650,
	},
	["0075_00582"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if I can't resolve everything well for everyone, if I can just choose the path that will help her, and the majority of other people...",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算不能拯救一切，但只要在上面摆着礼前辈和许多人的天平中，选择礼前辈的话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算不能拯救一切，但只要在上面擺著禮前輩和許多人的天平中，選擇禮前輩的話——",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00581",
		linknext = "0075_00583",
		line = 8660,
	},
	["0075_00583"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0792b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I've sent too many people like you to the guillotine to even count... I ignored their feelings, turned my back to them... acted like I didn't care!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我已经把好几个像你这样的人送上了断头台……我无视他们的心情……装作不知道……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我已經把好幾個像你這樣的人送上了斷頭臺……我無視他們的心情……裝作不知道……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00582",
		linknext = "0075_00584",
		line = 8672,
	},
	["0075_00584"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But even if I found a way to release her from this situation, it may only end up being a token gesture.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而——这样做即使能把她从这种情况下解放出来，那也只是表面上而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而——這樣做即使能把她從這種情況下解放出來，那也只是表面上而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00583",
		linknext = "0075_00585",
		line = 8682,
	},
	["0075_00585"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Could it even heal the deep wounds she's accumulated over the many years?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么多年来，她伤痕累累的心灵是否能被治愈呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼多年來，她傷痕累累的心靈是否能被治愈呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00584",
		linknext = "0075_00586",
		line = 8692,
	},
	["0075_00586"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If only there was a person who could do that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"假设如果有人能办到，",
					{"rt2"},
				},
			},
			tw = {
				{
					"假設如果有人能辦到，",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00585",
		linknext = "0075_00587",
		line = 8702,
	},
	["0075_00587"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Surely they'd be someone I could count on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一定不是我————",
					{"rt2"},
				},
			},
			tw = {
				{
					"那一定不是我————",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00586",
		linknext = "0075_00588",
		line = 8712,
	},
	["0075_00588"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00108", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0793", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If I try to turn around at this point... who would take me in? No matter how much I hate it, no matter how harsh it may be... There's nowhere else I belong right now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就算现在回头……又会有谁想接受这样的我……？无论多么讨厌，多么痛苦，我的容身之处……都只剩下这里了啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就算現在回頭……又會有誰想接受這樣的我……？無論多麼討厭，多麼痛苦，我的容身之處……都只剩下這裡了啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00587",
		linknext = "0075_00589",
		line = 8726,
	},
