				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“There's always been a place where you belong Rei-chan... and it's right here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“如果是礼酱的容身之处……这里一直都有哦。”",
