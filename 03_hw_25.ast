		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, Asa-chan. What are the SS doing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后——麻沙酱，我再问你一次，SS的情况怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後——麻沙醬，我再問你一次，SS的情況怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00070",
		linknext = "0075_00072",
		line = 949,
	},
	["0075_00072"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="asane_02m_00001", file1="asane_02m_00120", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1182", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, right. Let's see, now... Ahhhhhhh... This is... You wanna hear the short version first?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，对对对……嗯，我看看……啊——啊——啊——这个……如果用一句话来说……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，對對對……嗯，我看看……啊——啊——啊——這個……如果用一句話來說……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00071",
		linknext = "0075_00073",
		line = 964,
	},
	["0075_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, sure...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“用一句话来说？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「用一句話來說？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00072",
		linknext = "0075_00074",
		line = 975,
	},
	["0075_00074"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00110", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1183", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“This is bad... Now that the illegal sex industry stuff is sorted out, we've got like 90% of the whole SS posted both inside the school and around the perimeter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“很糟糕……因为地下风俗的问题也解决了……SS的人有90%以上被安排在学校及其周边……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「很糟糕……因為地下風俗的問題也解決了……SS的人有90%以上被安排在學校及其周邊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00073",
		linknext = "0075_00075",
		line = 989,
	},
	["0075_00075"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's... definitely not normal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这是平时无法想象的数字。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這是平時無法想像的數字。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00074",
		linknext = "0075_00076",
		line = 1001,
	},
	["0075_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wasn't in the SS for long, but those numbers don't sound right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然在SS的时间不是很长，但是这个数字是不可能的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然在SS的時間不是很長，但是這個數字是不可能的。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00075",
		linknext = "0075_00077",
		line = 1011,
	},
	["0075_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS aren't just posted at the school, but around the whole island. If they've got the bulk of their forces concentrated here, then—",
					{"rt2"},
				},
			},
			cn = {
				{
					"学校明明不是SS的工作场所，但却都集中在了那里——",
					{"rt2"},
				},
			},
			tw = {
				{
					"學校明明不是SS的工作場所，但卻都集中在了那裡——",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00076",
		linknext = "0075_00078",
		line = 1021,
	},
	["0075_00078"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=700},
		{"fgact", ch="麻沙音", id=3, act="移動", x=400, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1909", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Does this mean... they're standing by ready to take Fumino back?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“也就是说……这是为了夺回文乃而布置的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「也就是說……這是為了奪回文乃而佈置的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00077",
		linknext = "0075_00079",
		line = 1036,
	},
	["0075_00079"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think it'd be safe to assume that... They're quite an enemy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样想才妥当吧……真是强敌啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣想才妥當吧……真是強敵啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00078",
		linknext = "0075_00080",
		line = 1048,
	},
	["0075_00080"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's only five people between us. We're outmanned, outskilled and outgunned to a ridiculous degree.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们只有5个人——没有对策的话根本一筹莫展。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們只有5個人——沒有對策的話根本一籌莫展。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00079",
		linknext = "0075_00081",
		line = 1062,
	},
	["0075_00081"] = {
