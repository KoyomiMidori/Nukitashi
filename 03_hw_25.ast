		},
		linkback = "0075_00007",
		linknext = "0075_00009",
		line = 117,
	},
	["0075_00009"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Once all that illegal sex industry stuff got wiped up, they would've had to come for us eventually. It's nothing for you to be worried about, Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“地下风俗的事情解决后，本来就差不多该盯上我们了。文乃不用在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「地下風俗的事情解決後，本來就差不多該盯上我們了。文乃不用在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00008",
		linknext = "0075_00010",
		line = 129,
	},
	["0075_00010"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00115", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0259", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But... Father will not stop with me. He will come after Tachibana-san as well...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“可是……父亲他不仅想要我，连橘同学也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「可是……父親他不僅想要我，連橘同學也……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00009",
		linknext = "0075_00011",
		line = 143,
	},
	["0075_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
