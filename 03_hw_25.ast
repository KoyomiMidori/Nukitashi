	},
	["0075_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we were to use the route only open at low tide, we could avoid directly confronting the SS and escape into the hillside... but right now, it's not available to us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果可以使用退潮时限定的路线的话，就可以不和SS交战来到山之手——但现在那条路线不能用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果可以使用退潮時限定的路線的話，就可以不和SS交戰來到山之手——但現在那條路線不能用。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00087",
		linknext = "0075_00089",
		line = 1149,
	},
