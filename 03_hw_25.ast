		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1801", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ejeje, soy tu senpai... ¡No, soy tu novia! ¡Y por eso te apoyaré para siempre!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……因为我是淳君的前辈……不，是女朋友！所以我会一直尽全力支持淳君的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……因為我是淳君的前輩……不，是女朋友！所以我會一直盡全力支持淳君的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00447",
		linknext = "0075_00449",
		line = 6800,
	},
	["0075_00449"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami me ilumina con una sonrisa, no le asusta para nada que estemos en territorio enemigo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是在敌营的最深处，但她仍然温柔地露出了笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是在敵營的最深處，但她仍然溫柔地露出了笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00448",
		linknext = "0075_00450",
		line = 6810,
	},
	["0075_00450"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00129", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
