	["0075_00766"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0130", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Ha... What did you expect from a villain?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哈……因为我是坏人啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哈……因為我是壞人啊。」",
