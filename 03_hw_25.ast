	["0075_00615"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1818", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“There, there... It was tough, wasn't it... You really put up with a lot... You did good.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好乖好乖……很痛苦吧……很辛苦吧……你很努力呢……”",
					{"rt2"},
				},
			},
			tw = {
