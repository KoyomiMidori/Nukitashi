					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's right. We're all outlaws here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“畔说的没错，我们全都违反了条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畔說的沒錯，我們全都違反了條例。」",
					{"rt2"},
				},
