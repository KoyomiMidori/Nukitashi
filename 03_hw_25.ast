	["0075_00520"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0764", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Escúchame bien, no-copulador... El sexo es un deber para mí, me guste o no. Y tu negativa a aceptarlo... ¡es algo que no puedo permitir!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“反交尾势力……非性产者……不管愿不愿意，做爱都是必须的……做出反抗什么的……我是不会认同的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「反交尾勢力……非性產者……不管願不願意，做愛都是必須的……做出反抗什麼的……我是不會認同的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00519",
		linknext = "0075_00521",
		line = 7875,
	},
	["0075_00521"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso es lo que de verdad piensa.",
