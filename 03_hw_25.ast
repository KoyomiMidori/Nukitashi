		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't even make it out for myself, but she's been targeting the enemy snipers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我无法目视，但从刚才开始，文乃所瞄准的就是敌人的狙击手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我無法目視，但從剛才開始，文乃所瞄準的就是敵人的狙擊手。",
