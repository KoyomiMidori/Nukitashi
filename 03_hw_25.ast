					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tranquila. Puedes llorar. Desahoga todo eso por lo que luchaste y aguantaste...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好乖好乖……既然你这么努力了，就尽情哭出来吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好乖好乖……既然你這麼努力了，就盡情哭出來吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00616",
		linknext = "0075_00618",
		line = 9141,
	},
	["0075_00618"] = {
		{"text"},
		text = {
