		linkback = "0075_00203",
		linknext = "0075_00205",
		line = 2750,
	},
	["0075_00205"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The current bunch of SS are more concerned with being wary of their own allies instead of searching for the Anti-Copulation Front.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在SS的人们比起寻找反交尾势力，对同伴的警戒心更强。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在SS的人們比起尋找反交尾勢力，對同伴的警戒心更強。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00204",
		linknext = "0075_00206",
		line = 2762,
	},
	["0075_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It must be disconcerting to have your field of vision obscured and think there are subversive elements to deal with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被封住了视线的他们，认定内部藏有叛乱分子——肯定会很不安吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被封住了視線的他們，認定內部藏有叛亂分子——肯定會很不安吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00205",
		linknext = "0075_00207",
		line = 2772,
	},
	["0075_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Allow me to take away that unease.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么——我就消除你们的不安吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼——我就消除你們的不安吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00206",
		linknext = "0075_00208",
		line = 2782,
	},
	["0075_00208"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00303", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's time... Asa-chan, you're on!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是现在——麻沙音！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是現在——麻沙音！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00207",
		linknext = "0075_00209",
		line = 2794,
	},
	["0075_00209"] = {
		{"bg", id=2, file="bg15_3l_00000", x=100, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-205, y=-5, time=15000, lv=5},
		{"fg", file="asane_02f_00001", file1="asane_02f_00109", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1190", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Listen up! The spies are trying to act as decoys to lure us out! The Anti-Copulation Front has already left the building! Everyone head for the front gate! Don't let them get away!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“——听好了！间谍是用来诱骗我们的诱饵！反交尾势力已经出了教学楼！全体人员前往正门！别让他们逃走了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「——聽好了！間諜是用來誘騙我們的誘餌！反交尾勢力已經出了校舍！全體人員前往正門！別讓他們逃走了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00208",
		linknext = "0075_00210",
		line = 2809,
	},
	["0075_00210"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0015", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“You hear that!? Ugh, we ain't letting them get away and stuff!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“什么！？唔……我不会让他们逃跑的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「什麼！？唔……我不會讓他們逃跑的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00209",
		linknext = "0075_00211",
		line = 2823,
	},
	["0075_00211"] = {
		{"se", id=0, loop=0, file="se_a041"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They rush down the stairs. They definitely took that false info hook, line and sinker.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SS的人完全相信了虚假报告，争先恐后地跑下楼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SS的人完全相信了虛假報告，爭先恐後地跑下樓。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00210",
		linknext = "0075_00212",
		line = 2834,
	},
	["0075_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Being this distrustful of their group makes it easy for them to take orders from above. Good thing they're idiots.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为心中充满了怀疑和不安，才更容易接受上级的明确指示。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為心中充滿了懷疑和不安，才更容易接受上級的明確指示。",
					{"rt2"},
				},
