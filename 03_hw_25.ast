	},
	["0075_00605"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1813", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No, eso no es cierto. La razón por la que estoy aquí ahora es por ti. Gracias por todo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，没那回事。现在我能在这里……都是多亏了礼酱……所以，谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，沒那回事。現在我能在這裡……都是多虧了禮醬……所以，謝謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00604",
		linknext = "0075_00606",
		line = 8982,
	},
	["0075_00606"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei-senpai niega con la cabeza y trata de negar lo que le dice Hinami.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈摇了摇头，拼命地想否定雏见的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩搖了搖頭，拼命地想否定雛見的話。",
					{"rt2"},
				},
