	["0075_00522"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque fuera algo horrible para ella, tenía que seguir ofreciendo su cuerpo para vivir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使不愿意，也要继续为生存奉献自己的身体。",
					{"rt2"},
