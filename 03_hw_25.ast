		{"cgact", file="cgact", id=16, act="移動", x=-50, y=0, time=3000, lv=5},
		{"bg", id=14, file="bg24_3l_00000", x=-100, y=0, lv=5, path=":bg/", sync=0, ev=1, style="blur", blurx=11, blury=11, time=500, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=14, act="移動", x=45, y=-5, time=3000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
