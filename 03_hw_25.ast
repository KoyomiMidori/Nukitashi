		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=11, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"se", id=0, loop=0, file="se_b056"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me paro frente a la puerta y contengo la respiración, preparando mi pistola con el mayor silencio posible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我站在门前屏住呼吸，无声地举起手枪。",
