	["0075_00562"] = {
		{"cgdel", id=16, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=16, file="rci_l0106", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0783", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Even the superheroes who little children grow up admiring have to face conflict and make difficult decisions!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就连小孩子们所憧憬的英雄，也会因为矛盾而被迫做出选择……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就連小孩子們所憧憬的英雄，也會因為矛盾而被迫做出選擇……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00561",
		linknext = "0075_00563",
		line = 8420,
	},
	["0075_00563"] = {
		{"text"},
		delay = {
			[8300] = {
				{"cgdel", id=16, lv=5, time=100, alphadel=1, evmaskoff=1, delay2=8300},
				{"bg", id=16, file="rci_l0108", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, delay2=8300, time=300, bx=800, by=450},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0784", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But this is reality... You can't just take down the main villain and expect everything to be settled peacefully... That kind of villain doesn't exist!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“更别说这个现实世界……只要打倒就能完美解决一切的坏人什么的……根本就不存在啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「更別說這個現實世界……只要打倒就能完美解決一切的壞人甚麼的……根本就不存在啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00562",
		linknext = "0075_00564",
		line = 8435,
	},
	["0075_00564"] = {
