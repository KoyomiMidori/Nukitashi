	["0075_00568"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0786", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Por qué no usas tu propia arma...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“为什么……不用那把枪？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「為什麼……不用那把槍？」",
					{"rt2"},
				},
			},
