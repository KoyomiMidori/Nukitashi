	["0075_00546"] = {
		{"cgdel", id=16, time=0, lv=5},
		{"bg", id=16, file="rci_l0106", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0774", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What are you trying to do...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……你要干什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……你要幹什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00545",
		linknext = "0075_00547",
		line = 8229,
	},
	["0075_00547"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You can't show mercy to me, right? Then pull the trigger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你无法饶恕我，就扣下扳机吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你無法饒恕我，就扣下扳機吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00546",
		linknext = "0075_00548",
		line = 8241,
	},
	["0075_00548"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0775", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Do you really think I wouldn't shoot you here and now... just because I hesitated?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你以为你这么说，我就会踌躇……就不会射击吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你以為你這麼說，我就會躊躇……就不會射擊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00547",
		linknext = "0075_00549",
		line = 8253,
	},
	["0075_00549"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not at all. It's obvious that I can't defeat you. That's a clear and present fact.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不那么认为。我赢不了礼前辈——这是不争的事实。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不那麼認為。我贏不了禮前輩——這是不爭的事實。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00548",
		linknext = "0075_00550",
		line = 8264,
	},
	["0075_00550"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0776", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Then come quietly and surrender.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，你就干脆点放弃吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，你就乾脆點放棄吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00549",
		linknext = "0075_00551",
		line = 8276,
	},
	["0075_00551"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不会放弃的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不會放棄的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00550",
		linknext = "0075_00552",
		line = 8287,
	},
	["0075_00552"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Have you forgotten? Back when I first got into the SS, the first thing you ever complimented me on... was my perseverance.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你忘记了吗？我进入SS最初得到的评价是——不懂得放弃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你忘記了嗎？我進入SS最初得到的評價是——不懂得放棄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00551",
		linknext = "0075_00553",
		line = 8298,
	},
	["0075_00553"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0777", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Shut it... Don't bring that up now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别说了……事到如今不要再提那种事了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別說了……事到如今不要再提那種事了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00552",
		linknext = "0075_00554",
		line = 8310,
	},
	["0075_00554"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not giving up. Ever. I'm going to destroy the perverted sex law. I'm even content with knowing that destroying the law will save you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我绝对不会放弃。我要毁掉变态条例，连礼前辈都一起拯救出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我絕對不會放棄。我要毀掉變態條例，連禮前輩都一起拯救出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00553",
		linknext = "0075_00555",
		line = 8321,
	},
	["0075_00555"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0778", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Save me...? You think I deserve saving...? Don't give me that bullshit, Tachibana!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“拯救……？你说要拯救我……？开什么玩笑……橘……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「拯救……？你說要拯救我……？開什麼玩笑……橘……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00554",
		linknext = "0075_00556",
		line = 8333,
	},
	["0075_00556"] = {
		{"cgdel", id=16, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=16, file="rci_l0108", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0779", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Even after double-crossing me, you still insist on trying to win me over to your little fever dream?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那样背叛我后，还要说这种让我怀抱梦想的话吗……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那樣背叛我後，還要說這種讓我懷抱夢想的話嗎……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00555",
		linknext = "0075_00557",
		line = 8348,
	},
	["0075_00557"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0780", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I am you, and you are me. Unable to conform to this island, despising those who crave sexual acts... But we do not walk the same path. The path of resistance is the one you took!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你和我一样……没能习惯这个岛，厌恶贪求性爱……但是，你走错了路，你选择了抵抗的道路！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你和我一樣……沒能習慣這個島，厭惡貪求性愛……但是，你走錯了路，你選擇了抵抗的道路！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00556",
		linknext = "0075_00558",
		line = 8360,
	},
	["0075_00558"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0781", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I wish I could have done the same! I wanted to take that path! But I couldn't! If I had... I wouldn't have been able to keep anyone safe!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我也想这么做！我也想选择这条路！但是我办不到！如果不这样做……我就谁都没法保护……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我也想這麼做！我也想選擇這條路！但是我辦不到！如果不這樣做……我就誰都沒法保護……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00557",
		linknext = "0075_00559",
		line = 8372,
	},
	["0075_00559"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And you think that's any reason for you to just give up and become resigned to your fate?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事——成不了礼前辈能牺牲自己的理由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種事——成不了禮前輩能犧牲自己的理由。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00558",
		linknext = "0075_00560",
		line = 8383,
	},
	["0075_00560"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0782", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yes! If it weren't for this law, I would have never had anything resembling a family to live with! Believe what you will... but coexistence isn't something that can just be willed into being!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这就是我的理由！条例如果取消了，我就失去了和家人一起活下去的方法。不管你怎么想……都不可能有两全其美的办法……！”",
					{"rt2"},
