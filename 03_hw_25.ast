			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But Hinami... and even you! Even now, I still want to do something for both of you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可是，雏见也是……你也是！我想要帮你们……甚至到现在都还在想……！”",
