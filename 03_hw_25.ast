	["0075_00033"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a123"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi corazón da un brinco mientras reviso mi tablet. Dondequiera que miro en internet, solo veo una palabra: perversión.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我被内心的鼓动催促着拿起平板，一检索——全都是变态词汇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我被內心的鼓動催促著拿起平板，一檢索——全都是變態詞彙。",
					{"rt2"},
