					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Le susurro a Asane al oído.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我悄悄地对麻沙酱耳语。",
					{"rt2"},
