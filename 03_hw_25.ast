	["0075_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"By all rights the advance guard should be solely my responsibility, but Hinami's steady advance while holding her chair is formidable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来应该由我来打头阵的——可是拿着椅子的雏见的进攻非常猛烈。",
