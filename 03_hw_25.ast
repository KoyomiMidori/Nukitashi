	},
	["0075_00513"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0762", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Resentimiento? ¿Tristeza? No me importan esas cosas... ¡Así es como he sobrevivido! ¡No te pongas arrogante conmigo cuando no sabes nada!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“痛苦？悲伤？那种事有什么关系……这一切都是为了活下去！不要得寸进尺，你明明什么都不知道……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「痛苦？悲傷？那種事有什麼關係……這一切都是為了活下去！不要得寸進尺，你明明什麼都不知道……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00512",
		linknext = "0075_00514",
		line = 7790,
	},
	["0075_00514"] = {
