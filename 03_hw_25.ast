		linkback = "0075_00207",
		linknext = "0075_00209",
		line = 2794,
	},
	["0075_00209"] = {
		{"bg", id=2, file="bg15_3l_00000", x=100, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-205, y=-5, time=15000, lv=5},
		{"fg", file="asane_02f_00001", file1="asane_02f_00109", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1190", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Escuchen! ¡Los espías están tratando de actuar como señuelos para sacarnos! ¡El Frente Anticopulación ya abandonó el edificio! ¡Diríjanse todos a la puerta principal! ¡No dejen que se escapen!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“——听好了！间谍是用来诱骗我们的诱饵！反交尾势力已经出了教学楼！全体人员前往正门！别让他们逃走了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「——聽好了！間諜是用來誘騙我們的誘餌！反交尾勢力已經出了校舍！全體人員前往正門！別讓他們逃走了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00208",
		linknext = "0075_00210",
		line = 2809,
	},
	["0075_00210"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0015", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“¡¿Ya oyeron?! ¡No vamos a dejar que se salgan con la suya!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“什么！？唔……我不会让他们逃跑的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「什麼！？唔……我不會讓他們逃跑的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00209",
		linknext = "0075_00211",
		line = 2823,
	},
	["0075_00211"] = {
		{"se", id=0, loop=0, file="se_a041"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bajan corriendo las escaleras. Se tragaron esa información falsa con anzuelo, sedal y plomo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS的人完全相信了虚假报告，争先恐后地跑下楼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS的人完全相信了虛假報告，爭先恐後地跑下樓。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00210",
		linknext = "0075_00212",
		line = 2834,
	},
	["0075_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al desconfiar tanto de su grupo, les resulta fácil acatar las órdenes de sus superiores. Menos mal que son unos tontos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为心中充满了怀疑和不安，才更容易接受上级的明确指示。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為心中充滿了懷疑和不安，才更容易接受上級的明確指示。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00211",
		linknext = "0075_00213",
		line = 2844,
	},
	["0075_00213"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
