		line = 8712,
	},
	["0075_00588"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00108", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0793", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Si intento dar media vuelta en este momento... ¿quién me acogería? Por mucho que lo odie, y por más cruel que sea... ¡No existe otro lugar al que pertenezca!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就算现在回头……又会有谁想接受这样的我……？无论多么讨厌，多么痛苦，我的容身之处……都只剩下这里了啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就算現在回頭……又會有誰想接受這樣的我……？無論多麼討厭，多麼痛苦，我的容身之處……都只剩下這裡了啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00587",
		linknext = "0075_00589",
		line = 8726,
	},
