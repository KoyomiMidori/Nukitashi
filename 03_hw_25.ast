	["0075_00604"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0801", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Basta... No pude hacer nada. Intenté protegerte... ¡pero mira cómo lo hice!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别说了……我……什么都没能做到……就算想保护雏见……这样的方式也……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別說了……我……什麼都沒能做到……就算想保護雛見……這樣的方式也……！」",
