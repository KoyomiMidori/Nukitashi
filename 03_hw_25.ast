	},
	["0075_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es una sobrecarga de información, pero logro recuperar la compostura y trato de seleccionar los datos más importantes.",
					{"rt2"},
				},
			},
			cn = {
