	},
	["0075_00074"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00110", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1183", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Todo se fue a la mierda... Pues ahora que se ha resuelto el temita de la industria sexual legal, el 90 % de la SS está desplegada dentro de la escuela y sus alrededores.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“很糟糕……因为地下风俗的问题也解决了……FS的人有90%以上被安排在学校及其周边……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「很糟糕……因為地下風俗的問題也解決了……FS的人有90%以上被安排在學校及其周邊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00073",
		linknext = "0075_00075",
		line = 989,
	},
	["0075_00075"] = {
