	["0075_00717"] = {
		{"fg", file="hitoura_02m_00001", file1="hitoura_02m_00119", path=":fg/hitoura_02m/", id=10, lv=5, head="hitoura_02m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
