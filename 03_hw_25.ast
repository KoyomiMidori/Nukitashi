				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I want to protect my family... I even want to protect my SS comrades.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我想守护我的家人……也想守护SS的同伴们……”",
