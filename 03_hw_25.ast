	["0075_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In the dark of night, the road has terrible visibility, and as the pavement is rough too, the vehicle is constantly swaying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"夜幕笼罩下，葱葱郁郁的森林中视野极差，路也不好走，车辆不停地摇晃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"夜幕籠罩下，蔥蔥鬱鬱的森林中視野極差，路也不好走，車輛不停地搖晃。",
					{"rt2"},
