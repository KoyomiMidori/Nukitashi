		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Puede que solo seamos un grupo de seis... pero somos el mejor grupo de seis. No importa cuántos enemigos tengamos enfrente, no nos derrotarán.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然我们只是6人的队伍——但却是最强的6人。不管对手有多少，我们都不会输。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然我們只是6人的隊伍——但卻是最強的6人。不管對手有多少，我們都不會輸。」",
					{"rt2"},
				},
			},
		},
