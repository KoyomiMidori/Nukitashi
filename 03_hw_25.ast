			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么办……？不管这里的烟有多浓，只要往下走就会马上被发现，那样的话就会被夹击哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼辦……？不管這裡的煙有多濃，只要往下走就會馬上被發現，那樣的話就會被夾擊哦……？」",
