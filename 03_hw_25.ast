	},
	["0075_00767"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0131", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Still... I can't get back on my feet now. Being the lone villain in town feels rather hollow... Maybe it's time to retreat...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“可是……到底是站不起来了……自己一个人当坏人……也很是空虚……或许是时候撤退了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「可是……到底是站不起來了……自己一個人當壞人……也很是空虛……或許是時候撤退了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00766",
		linknext = "0075_00768",
		line = 11572,
	},
