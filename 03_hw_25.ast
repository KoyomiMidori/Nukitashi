			},
		},
		linkback = "0075_00517",
		linknext = "0075_00519",
		line = 7853,
	},
	["0075_00519"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My joints creak and I grit my teeth to endure the pain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"关节发出悲鸣，我咬紧牙关忍受疼痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"關節發出悲鳴，我咬緊牙關忍受疼痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00518",
		linknext = "0075_00520",
		line = 7863,
	},
	["0075_00520"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0764", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Listen well, anti-copulator... Sex is something I have to do, like it or not. And your refusal to accept that... is something I can't allow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“反交尾势力……非性产者……不管愿不愿意，做爱都是必须的……做出反抗什么的……我是不会认同的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「反交尾勢力……非性產者……不管願不願意，做愛都是必須的……做出反抗什麼的……我是不會認同的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00519",
		linknext = "0075_00521",
		line = 7875,
	},
	["0075_00521"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is what she really thinks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一定是她的真心话吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那一定是她的真心話吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00520",
		linknext = "0075_00522",
		line = 7885,
	},
	["0075_00522"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She had to keep offering her body in order to live whether she desired it or not.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使不愿意，也要继续为生存奉献自己的身体。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使不願意，也要繼續為生存奉獻自己的身體。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00521",
		linknext = "0075_00523",
		line = 7895,
	},
	["0075_00523"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She suppressed her emotions and desperately put up with it, even though she was compelled to do so forcefully. She can't forgive people who refused to do that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"扼杀内心，拼命忍受，明明自己也被强迫做那种行为——却还是不能原谅抗拒这件事的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"扼殺內心，拼命忍受，明明自己也被強迫做那種行為——卻還是不能原諒抗拒這件事的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00522",
		linknext = "0075_00524",
		line = 7905,
	},
	["0075_00524"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's childish in the extreme. She must know that better than anyone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那只是幼稚地将怒气发在其他人身上而已——她本人应该最明白这件事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那隻是幼稚地將怒氣發在其他人身上而已——她本人應該最明白這件事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00523",
		linknext = "0075_00525",
		line = 7915,
	},
	["0075_00525"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In that case... Why would you keep Hinami safe?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么——为什么你要保护雏见呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼——為什麼你要保護雛見呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00524",
		linknext = "0075_00526",
		line = 7927,
	},
	["0075_00526"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And not just Hinami! Even when you found out about me, you didn't try to coerce me into sex! Why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不只是雏见！即使知道我的事情，你也不强迫我进行性行为！为什么！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不只是雛見！即使知道我的事情，你也不強迫我進行性行為！為什麼！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00525",
		linknext = "0075_00527",
		line = 7939,
	},
	["0075_00527"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0765", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Do you really have to ask...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那还用说吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那還用說嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00526",
		linknext = "0075_00528",
		line = 7953,
	},
	["0075_00528"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, I do! So tell me!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么！？你说啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼！？你說啊！！」",
					{"rt2"},
				},
			},
