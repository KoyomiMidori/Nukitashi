	["0075_00591"] = {
		{"bg", id=18, file="hcg04b_l0101-1", x=-730, y=500, path=":cg/hcg04b_l/", lv=5, time=500, bx=800, by=450},
		{"cgact", file="cgact", id=18, act="移動", x=0, y=20, time=3000, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0794", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hinami?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00590",
		linknext = "0075_00592",
		line = 8814,
	},
	["0075_00592"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1807", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Rei-chan... Rei-chan has always been working so hard, all on your own. Working so selflessly to help everyone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱……礼酱你一直都是一个人在努力……为了大家，自己一个人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬……禮醬你一直都是一個人在努力……為了大家，自己一個人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00591",
		linknext = "0075_00593",
		line = 8826,
	},
	["0075_00593"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0795", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No... I haven't. I've never done anything of value...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我……不对……我根本没有在努力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我……不對……我根本沒有在努力……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00592",
		linknext = "0075_00594",
		line = 8838,
	},
	["0075_00594"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1808", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You have. I know you have Rei-chan. As far back as I can remember, you've been a harder worker than anyone else I've known.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不……没那回事。因为我知道……礼酱从以前开始……就比谁都努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不……沒那回事。因為我知道……禮醬從以前開始……就比誰都努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00593",
		linknext = "0075_00595",
		line = 8850,
	},
	["0075_00595"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0796", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No... I really wanted to change. I thought I could change something when I became the disciplinary committee president...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不是的……我其实……想过要改变。以为成为风纪委员长，就能改变什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不是的……我其實……想過要改變。以為成為風紀委員長，就能改變什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00594",
		linknext = "0075_00596",
		line = 8862,
	},
	["0075_00596"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0797", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But I couldn't do a thing in the end... I was bound by the restrictions of my position... and I knew less and less what I even wanted to do...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是，我什么都没做到……被立场绑手绑脚……最后连自己想干什么，也越来越不明白……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是，我什麼都沒做到……被立場綁手綁腳……最後連自己想幹什麼，也越來越不明白……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00595",
		linknext = "0075_00597",
		line = 8874,
	},
	["0075_00597"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1809", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Right...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……」",
					{"rt2"},
