		linkback = "0075_00567",
		linknext = "0075_00569",
		line = 8498,
	},
	["0075_00569"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Recuerdas cuando me la diste por primera vez? Me enseñaste a no apuntarle a un aliado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“第一次学枪的时候——你就告诉我绝对不要把枪口对准自己人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「第一次學槍的時候——你就告訴我絕對不要把槍口對準自己人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00568",
		linknext = "0075_00570",
		line = 8510,
	},
	["0075_00570"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0787", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Un aliado... ¿Yo...?”",
