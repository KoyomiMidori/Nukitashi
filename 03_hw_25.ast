		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not a single bullet, no matter how well-aimed, hits its mark.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管多么猛烈攻击，子弹都打不到那家伙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管多麼猛烈攻擊，子彈都打不到那傢伙。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00701",
