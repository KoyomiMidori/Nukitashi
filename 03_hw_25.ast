					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Numerous enemy genitals approaching from the west stairway... They're armed with SS style handguns and have authorization to fire.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“大量敌性器正从西楼梯接近中……装备SS式手枪，好像还允许开枪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「大量敵性器正從西樓梯接近中……裝備SS式手槍，好像還允許開槍。」",
					{"rt2"},
				},
			},
		},
