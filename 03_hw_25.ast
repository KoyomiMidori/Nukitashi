					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Bueno...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“用一句话来说？”",
