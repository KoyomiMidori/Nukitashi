		{"cgact", act="移動", id=11, lv=5, time=30000, actforce=1, x=-100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso es lo que le pedí a Hinami.",
					{"rt2"},
				},
			},
			cn = {
				{
					"钢管椅——这正是我让雏见拿着的武器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"鋼管椅——這正是我讓雛見拿著的武器。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00233",
		linknext = "0075_00235",
		line = 3245,
	},
	["0075_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El consejo estudiantil mencionó el otro día que ella lleva un 'Silla de Protección Divina'.",
					{"rt2"},
				},
			},
			cn = {
				{
					"前些日子，学生会长说过雏见有“椅子的保佑”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"前些日子，學生會長說過雛見有「椅子的保佑」。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00234",
		linknext = "0075_00236",
		line = 3255,
	},
	["0075_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No sabía de qué estaba hablando, pero pensándolo bien, realmente ha habido muchas coincidencias extrañas relacionadas con Hinami y su silla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我不明白那句话的意思，但回想起来，确实过去雏见和椅子是有奇妙的缘分的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我不明白那句話的意思，但回想起來，確實過去雛見和椅子是有奇妙的緣分的。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00235",
		linknext = "0075_00237",
		line = 3265,
	},
	["0075_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En cada batalla, e incluso en el transcurso de su vida diaria, ha hecho cosas increíbles que me llevan a una única conclusión: cuando sostiene esa silla, está protegida por algún poder especial.",
					{"rt2"},
				},
			},
			cn = {
				{
					"任何战斗中，或者说是在日常生活——拿着椅子的雏见总是拥有不可思议的力量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"任何戰鬥中，或者說是在日常生活——拿著椅子的雛見總是擁有不可思議的力量。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00236",
		linknext = "0075_00238",
		line = 3275,
	},
	["0075_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De hecho, sus momentos más desafortunados solo han ocurrido cuando no la llevaba consigo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"相反地，每次不幸降临到雏见身上时，她都没有拿着椅子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"相反地，每次不幸降臨到雛見身上時，她都沒有拿著椅子。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00237",
		linknext = "0075_00239",
		line = 3285,
	},
	["0075_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En Japón hay un dicho derivado de la creencia sintoísta— “ocho millones de dioses”.",
					{"rt2"},
				},
			},
			cn = {
				{
					"日本有个词叫“八百万神”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"日本有個詞叫「八百萬神」。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00238",
		linknext = "0075_00240",
		line = 3295,
	},
	["0075_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Representa la idea de que hay un dios que habita en todo lo que existe en la naturaleza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"意思是说万物都寄宿着神。",
					{"rt2"},
				},
			},
			tw = {
				{
					"意思是說萬物都寄宿著神。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00239",
		linknext = "0075_00241",
		line = 3305,
	},
	["0075_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bajo esa lógica, seguramente hay un dios que habita hasta en las sillas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"按照这个意思来想的话，椅子上应该也寄宿着神吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"按照這個意思來想的話，椅子上應該也寄宿著神吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00240",
		linknext = "0075_00242",
		line = 3315,
	},
	["0075_00242"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=11, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
