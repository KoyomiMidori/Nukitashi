				{"vo", file="nanase1907", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sí, lleva bastante tiempo sin dar señales de vida. ¿Le habrá pasado algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……感觉是联系不上。是不是发生了什么事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……感覺是聯繫不上。是不是發生了什麼事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00017",
		linknext = "0075_00019",
		line = 249,
	},
	["0075_00019"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No le demos tantas vueltas. Ni siquiera sabemos cómo se llama ese viejo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“想也没有用……我们连那个人的名字都不知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「想也沒有用……我們連那個人的名字都不知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00018",
		linknext = "0075_00020",
		line = 261,
	},
	["0075_00020"] = {
