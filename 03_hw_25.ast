		line = 10504,
	},
	["0075_00703"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to close in on this asshole and punch him right in the face this instant... but I grit my teeth and resist that urge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我现在就想钻进他的胸前把我全力的一拳打到他脸上，但——我咬紧牙关，忍住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我現在就想鑽進他的胸前把我全力的一拳打到他臉上，但——我咬緊牙關，忍住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00702",
		linknext = "0075_00704",
		line = 10514,
	},
	["0075_00704"] = {
