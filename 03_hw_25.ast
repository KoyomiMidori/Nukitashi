	["0075_00512"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me retuerce el brazo con tanta fuerza, con la cara contra el piso, que siento como si me lo estuvieran arrancando por el dolor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被勒紧关节的同时，头部被摔在地板上，手臂上传来快被拉断的剧痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被勒緊關節的同時，頭部被摔在地板上，手臂上傳來快被拉斷的劇痛。",
					{"rt2"},
				},
