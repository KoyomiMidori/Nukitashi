	},
	["0075_00356"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Le disparamos a una y aparece otra!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么射击都没完没了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼射擊都沒完沒了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00355",
		linknext = "0075_00357",
		line = 5397,
	},
	["0075_00357"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1196", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Tenemos a toda la OSS persiguiéndonos... ¿No es un poco exagerado para solo seis personas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没想到这里配置了这么多的SHO警卫……只对付6个人这样会不会太没风度了啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒想到這裡配置了這麼多的SHO警衛……只對付6個人這樣會不會太沒風度了啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00356",
		linknext = "0075_00358",
		line = 5410,
	},
	["0075_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No le importa a quién se enfrente, ni cuántos sean. No se va a rendir tan fácilmente. Así es él.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对方无论几个人还是是谁都不会手下留情的——他就是那样的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對方無論幾個人還是是誰都不會手下留情的——他就是那樣的男人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00357",
		linknext = "0075_00359",
		line = 5421,
	},
	["0075_00359"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Baja la cabeza y ve al frente con Hinami. Podrían estar apuntándote si te quedas aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个，你最好和雏见一起退到里面去——在这里可能会成为靶子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個，你最好和雛見一起退到裡面去——在這裡可能會成為靶子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00358",
		linknext = "0075_00360",
		line = 5433,
	},
	["0075_00360"] = {
		{"se", id=0, loop=0, file="se_b021"},
