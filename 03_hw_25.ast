	["0075_00316"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's almost like the usual crowds here were an illusion. The area's totally deserted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才的密集情形就像假的一样，这一带很冷清。",
