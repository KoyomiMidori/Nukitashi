	["0075_00571"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Termina soltando el arma. Esta cae al suelo, y su ruido inorgánico rompe el velo del silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手枪离开了前辈的手，寂静中响起了无机物的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"手槍離開了前輩的手，寂靜中響起了無機物的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00570",
		linknext = "0075_00572",
		line = 8532,
	},
	["0075_00572"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00124", file2="rei_01l_00206", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0788", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Quiero proteger a mi familia... Incluso quiero proteger a mis compañeros de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我想守护我的家人……也想守护FS的同伴们……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我想守護我的家人……也想守護FS的同伴們……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00571",
		linknext = "0075_00573",
		line = 8546,
	},
	["0075_00573"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00108", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0789", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pero Hinami... ¡e incluso tú! ¡Incluso ahora, quiero hacer algo por ustedes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可是，雏见也是……你也是！我想要帮你们……甚至到现在都还在想……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可是，雛見也是……你也是！我想要幫你們……甚至到現在都還在想……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00572",
		linknext = "0075_00574",
		line = 8560,
	},
	["0075_00574"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus lágrimas amargas y calientes salpican mis mejillas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"炙热的水滴落在我的脸颊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"炙熱的水滴落在我的臉頰。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00573",
		linknext = "0075_00575",
		line = 8570,
	},
	["0075_00575"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0790", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sé que... no hay forma de salvarlos a todos... pero no puedo aceptarlo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我知道……没有能拯救一切的方法……但是，我已经受够了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我知道……沒有能拯救一切的方法……但是，我已經受夠了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00574",
		linknext = "0075_00576",
		line = 8582,
	},
	["0075_00576"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", file2="rei_01l_00206", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0791", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“La idea de tener que seguir con esto por quién sabe cuánto tiempo... ¡No puedo aguantarlo más!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔……我不希望这种事情再继续下去了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔……我不希望這種事情再繼續下去了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00575",
		linknext = "0075_00577",
		line = 8596,
	},
	["0075_00577"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es mucho más infantil de lo que pensaba.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人，比我想得还要像个孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個人，比我想得還要像個孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00576",
		linknext = "0075_00578",
		line = 8606,
	},
	["0075_00578"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está llorando desconsoladamente. Está asustada. Quiere que la salven. No sabe qué hacer. Quiere que alguien le muestre a dónde ir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"害怕，想要受到帮助，不知道该怎么办——想让别人为自己指出道路，想放声哭泣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"害怕，想要受到幫助，不知道該怎麼辦——想讓別人為自己指出道路，想放聲哭泣。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00577",
		linknext = "0075_00579",
		line = 8616,
	},
	["0075_00579"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siempre levantaba la voz para someter ese lado vulnerable de sí misma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了隐藏那样弱小的自己，才一直大声喊叫着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了隱藏那樣弱小的自己，才一直大聲喊叫著。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00578",
		linknext = "0075_00580",
		line = 8626,
	},
	["0075_00580"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0792", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pero llegué demasiado lejos... Estoy demasiado metida en esto como para hacer otra cosa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呜……不过，我已经来到了这种地方……所以只能继续下去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗚……不過，我已經來到了這種地方……所以只能繼續下去了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00579",
		linknext = "0075_00581",
		line = 8640,
	},
	["0075_00581"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hay una manera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"方法是有的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"方法是有的。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00580",
		linknext = "0075_00582",
		line = 8650,
	},
	["0075_00582"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque no pueda salvarlos a todos, si pudiera elegir un camino que la ayude a ella y a la mayoría...",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算不能拯救一切，但只要在上面摆着礼前辈和许多人的天平中，选择礼前辈的话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算不能拯救一切，但只要在上面擺著禮前輩和許多人的天平中，選擇禮前輩的話——",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00581",
		linknext = "0075_00583",
		line = 8660,
	},
	["0075_00583"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0792b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya perdí la cuenta de cuántos como tú he mandado a la guillotina... Ignoré sus sentimientos, les di la espalda... ¡actué como si no me importaran!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我已经把好几个像你这样的人送上了断头台……我无视他们的心情……装作不知道……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我已經把好幾個像你這樣的人送上了斷頭臺……我無視他們的心情……裝作不知道……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00582",
		linknext = "0075_00584",
		line = 8672,
	},
	["0075_00584"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque encontrara una manera de liberarla de esta situación, tal vez solo sería un gesto simbólico.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而——这样做即使能把她从这种情况下解放出来，那也只是表面上而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而——這樣做即使能把她從這種情況下解放出來，那也只是表面上而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00583",
		linknext = "0075_00585",
		line = 8682,
	},
	["0075_00585"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Podría curar las heridas profundas que ha acumulado a lo largo de tantos años?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么多年来，她伤痕累累的心灵是否能被治愈呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼多年來，她傷痕累累的心靈是否能被治愈呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00584",
		linknext = "0075_00586",
		line = 8692,
	},
	["0075_00586"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ojalá hubiera alguien capaz de hacerlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"假设如果有人能办到，",
					{"rt2"},
				},
			},
			tw = {
				{
					"假設如果有人能辦到，",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00585",
		linknext = "0075_00587",
		line = 8702,
	},
	["0075_00587"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que sería alguien en quien podría confiar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一定不是我————",
					{"rt2"},
				},
			},
			tw = {
				{
					"那一定不是我————",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00586",
