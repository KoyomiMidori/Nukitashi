	["0075_00679"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Acorta la distancia en un instante. Si reacciono aunque sea un segundo más tarde, la batalla terminará.",
					{"rt2"},
				},
			},
			cn = {
				{
					"缩短距离的一闪——要是反应再晚一点，胜负就要在这一刻定下来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"縮短距離的一閃——要是反應再晚一點，勝負就要在這一刻定下來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00678",
		linknext = "0075_00680",
		line = 10004,
	},
	["0075_00680"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se me pone la piel de gallina y mi corazón late a mil por hora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"全身瞬间都冒出了鸡皮疙瘩，心脏开始着急，并且加速得令人害怕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"全身瞬間都冒出了雞皮疙瘩，心臟開始著急，並且加速得令人害怕。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00679",
		linknext = "0075_00681",
		line = 10015,
	},
	["0075_00681"] = {
		{"cgdel", id=15, lv=5, time=100, alphadel=1},
		{"cgdel", id=16, lv=5, time=100, alphadel=1},
		{"cgact", file="cgact", id=17, act="stopact", lv=5, alpha="0,256"},
		{"cgdel", id=17, lv=5, time=100, alphadel=1},
		{"cgdel", id=2, lv=5, time=100, alphadel=1},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Tu deseo de atacar te hizo olvidar tu objetivo? ¡Pensé que me querías de tu lado!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……着急到迷失自我了吗？难道你不想要我的力量了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……著急到迷失自我了嗎？難道你不想要我的力量了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00680",
		linknext = "0075_00682",
		line = 10036,
	},
	["0075_00682"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00117", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0112", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“¡Si ese ataque te hubiera matado, habrías demostrado que no eras digno!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这种程度就倒下的话，可当不上我的尖兵哦！”",
