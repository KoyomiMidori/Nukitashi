		{"fgact", ch="麻沙音", id=3, act="浮遊横", loop=2, size=12.5, time=200, ease="inout"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1176", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, no, no he podido revisarlo bien, pero parece que hay mucho debate en internet... Están hablando de un plan para promover la perversión por todo el país.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，不是……部署还没有确认……只是网络上有个奇怪的话题……日本全土变态化计划……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，不是……部署還沒有確認……只是網路上有個奇怪的話題……日本全土變態化計劃……」",
					{"rt2"},
				},
			},
		},
