				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00090",
		linknext = "0075_00092",
		line = 1185,
	},
	["0075_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Did they manage to find out about that route?",
					{"rt2"},
				},
			},
			cn = {
				{
					"难道那条路线已经暴露了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"難道那條路線已經暴露了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00091",
		linknext = "0075_00093",
		line = 1195,
	},
	["0075_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We've made use of it enough times that it wouldn't be implausible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不是不可能的事情。那是我们多次使用的道路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不是不可能的事情。那是我們多次使用的道路。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00092",
		linknext = "0075_00094",
		line = 1205,
	},
	["0075_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS are no fools. They probably managed to put two and two together.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SS也不愚蠢，有充分的可能性在某次被注意到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SS也不愚蠢，有充分的可能性在某次被注意到了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00093",
		linknext = "0075_00095",
		line = 1215,
	},
	["0075_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if they know about that route... they probably also managed to figure out about this base, since it connects to that route.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，如果那条路线暴露的话——连着那条路的这个基地也可能被察觉到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，如果那條路線暴露的話——連著那條路的這個基地也可能被察覺到了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00094",
		linknext = "0075_00096",
		line = 1225,
	},
	["0075_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They could very well be waiting for us all to exit so they can force their way in to take Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说不定他们会等我们全都离开后，强行突破进来夺回文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說不定他們會等我們全都離開後，強行突破進來奪回文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00095",
		linknext = "0075_00097",
		line = 1235,
	},
	["0075_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If that's how it is, then...",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼——",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00096",
		linknext = "0075_00098",
		line = 1245,
	},
	["0075_00098"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, can I ask for you to lend us your strength on this occasion?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃——现在可以让我们借用你的力量吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃——現在可以讓我們借用你的力量嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00097",
		linknext = "0075_00099",
		line = 1257,
	},
	["0075_00099"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=7.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0263", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Of course. I shall obey any order you give. I am a strong young woman, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“当然。请下命令……文乃是个坚强的女人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「當然。請下命令……文乃是個堅強的女人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00098",
		linknext = "0075_00100",
		line = 1270,
	},
	["0075_00100"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks. Can I ask just one thing, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你——只是，我要先跟你说一件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你——只是，我要先跟你說一件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00099",
		linknext = "0075_00101",
		line = 1282,
	},
	["0075_00101"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'd prefer if you stopped worrying about the fact that your father did this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要因为是你父亲做的事而感到在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要因為是你父親做的事而感到在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00100",
		linknext = "0075_00102",
		line = 1294,
	},
	["0075_00102"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We're all in the same boat here, as like-minded comrades. We all have an objective to achieve. Can you fight with us to help us achieve it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们是志向相同的同伴。为了达到目的，你愿意和我们一起战斗吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們是志向相同的同伴。為了達到目的，你願意和我們一起戰鬥嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00101",
		linknext = "0075_00103",
		line = 1306,
	},
	["0075_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A strange light flickers in her eyes as she stares at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那瞳孔中奇妙颜色的光点凝视着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那瞳孔中奇妙顏色的光點凝視著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00102",
		linknext = "0075_00104",
		line = 1316,
	},
	["0075_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Back when we first met, I would have called her expression emotionless. But now, I can tell that she is brimming with determination.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚相遇时觉得毫无感情的表情，现在却可以明白感受到她满满的决心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛相遇時覺得毫無感情的表情，現在卻可以明白感受到她滿滿的決心。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00103",
		linknext = "0075_00105",
		line = 1326,
	},
	["0075_00105"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00110", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0264", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Experience repeated hardships, overcome numerous difficulties, and finally attain the fulfillment of your goals through your trials and tribulations...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“尝过多重辛酸，克服无数苦难，在辛苦艰难的尽头，成就圆满夙愿——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嚐過多重辛酸，克服無數苦難，在辛苦艱難的盡頭，成就圓滿夙願——」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00104",
		linknext = "0075_00106",
		line = 1340,
	},
	["0075_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She holds her petite hand to her chest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她小小的手握在胸前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她小小的手握在胸前。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00105",
		linknext = "0075_00107",
		line = 1350,
	},
	["0075_00107"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0265", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Understood. The divine orb of protection of my eagle eyes will be with you all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我明白了——我的瞳孔，宝珠的保佑……将与各位同在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我明白了——我的瞳孔，寶珠的保佑……將與各位同在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00106",
		linknext = "0075_00108",
		line = 1364,
	},
	["0075_00108"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks. That's reassuring.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——指望你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯——指望你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00107",
		linknext = "0075_00109",
		line = 1376,
	},
	["0075_00109"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00126", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=5, act="振動下", loop=3, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0453", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Heh heh heh! Fumino-chan, take this! It's an SS sniper rifle!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呵呵呵——！文乃酱，这边请！这是SS的狙击步枪！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呵呵呵——！文乃醬，這邊請！這是SS的狙擊步槍！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00108",
		linknext = "0075_00110",
		line = 1392,
	},
	["0075_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00125", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A sniper rifle? Where'd you get that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这狙击步枪……你是从哪搞来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這狙擊步槍……你是從哪搞來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00109",
		linknext = "0075_00111",
		line = 1404,
	},
	["0075_00111"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0454", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I figured something like this might happen, so I just went and 'borrowed' one I spotted during their shooting practice the other day... I thought Fumino-chan would like it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我就想说会有这一天，所以在前几天的射击训练中借了一支……我想文乃会高兴的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我就想說會有這一天，所以在前幾天的射擊訓練中借了一支……我想文乃會高興的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00110",
		linknext = "0075_00112",
		line = 1417,
	},
	["0075_00112"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00107", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0266", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Thank you, Misaki-san. I will be sure to watch all your backs.”",
					{"rt2"},
				},
			},
			cn = {
				{
