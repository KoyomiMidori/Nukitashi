		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0648", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now this is unexpected. Heh heh, you never cease to amaze me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……没想到居然到了这种程度。呵呵，你们真的吓了我一跳呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……沒想到居然到了這種程度。呵呵，你們真的嚇了我一跳呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00290",
		linknext = "0075_00292",
		line = 4233,
	},
	["0075_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But now that reliable chair is no longer at hand. And we are facing an incredibly overpowered opponent.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，重要的椅子已经离开了手边，对方是压倒性强大的学生会长。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，重要的椅子已經離開了手邊，對方是壓倒性強大的學生會長。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00291",
		linknext = "0075_00293",
		line = 4243,
	},
	["0075_00293"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
