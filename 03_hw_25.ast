		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por más que le apunte, ni una sola bala da en el blanco.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管多么猛烈攻击，子弹都打不到那家伙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管多麼猛烈攻擊，子彈都打不到那傢伙。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00701",
		linknext = "0075_00703",
		line = 10504,
	},
	["0075_00703"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quiero acercarme a este imbécil y darle un puñetazo en la cara... pero aprieto los dientes y resisto ese impulso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我现在就想钻进他的胸前把我全力的一拳打到他脸上，但——我咬紧牙关，忍住了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我現在就想鑽進他的胸前把我全力的一拳打到他臉上，但——我咬緊牙關，忍住了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00702",
		linknext = "0075_00704",
		line = 10514,
	},
	["0075_00704"] = {
