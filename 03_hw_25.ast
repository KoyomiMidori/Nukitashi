		linkback = "0075_00605",
		linknext = "0075_00607",
		line = 8992,
	},
	["0075_00607"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Solo permanece callada mientras las lágrimas caen de sus ojos...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她说不出话来，只是不断流泪————",
