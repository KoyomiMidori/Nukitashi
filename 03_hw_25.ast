		linkback = "0075_00576",
		linknext = "0075_00578",
		line = 8606,
	},
	["0075_00578"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's sobbing nakedly. She's scared. She wants to be saved. She doesn't know what to do. She wants someone to show her the way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"害怕，想要受到帮助，不知道该怎么办——想让别人为自己指出道路，想放声哭泣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"害怕，想要受到幫助，不知道該怎麼辦——想讓別人為自己指出道路，想放聲哭泣。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00577",
		linknext = "0075_00579",
		line = 8616,
	},
	["0075_00579"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She'd always been raising her voice to beat that vulnerable side of herself into submission.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了隐藏那样弱小的自己，才一直大声喊叫着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了隱藏那樣弱小的自己，才一直大聲喊叫著。",
					{"rt2"},
				},
			},
