			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It's because I don't want to have to do this to you!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“因为不想让你们也经历这种事情啊！！”",
