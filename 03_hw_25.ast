		linkback = "0075_00213",
		linknext = "0075_00215",
		line = 2870,
	},
	["0075_00215"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00114", path=":fg/asane_01m/", id=5, lv=5, head="asane_01m", ch="麻沙音", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1191", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ahh, cambiar mi voz me agota un montón... Soy la chica que se encarga de las labores cibernéticas, este ni siquiera es mi trabajo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——喊太大声我都累了……这不是计算机人员的工作吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊——喊太大聲我都累了……這不是計算機人員的工作吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00214",
		linknext = "0075_00216",
		line = 2884,
	},
	["0075_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo siento. ¡Pero ahora tenemos una vía de escape! ¡Salgamos de la escuela mientras podamos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真抱歉——不过，托你的福活路打开了！要乘着这波离开教学楼！”",
					{"rt2"},
				},
			},
			tw = {
