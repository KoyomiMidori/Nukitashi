				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You know, back when I first joined the SS, they appraised me as being a thoroughly shitty fighter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我加入SS的时候，作为一名战斗员的评价是最差的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我加入SS的時候，作為一名戰鬥員的評價是最差的……」",
