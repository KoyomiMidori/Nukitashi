					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Sí! Pero ahora que lo mencionas... hace tiempo que no sabemos nada del viejo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊！不过话说回来……那个老爷爷怎么都没联络我们呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊！不過話說回來……那個老爺爺怎麼都沒聯絡我們呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00016",
		linknext = "0075_00018",
		line = 235,
	},
	["0075_00018"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00128", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
