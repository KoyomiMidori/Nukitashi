			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ahh... ¿Andas tramposo...? Je, deja que tu manita se haga cargo de esto...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哇……真的很坏……哼，交给妹妹吧……”",
