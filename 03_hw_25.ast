		linkback = "0075_00200",
		linknext = "0075_00202",
		line = 2712,
	},
	["0075_00202"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
