					"“Right! But now that you mention it... we haven't heard from that old man in a while.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊！不过话说回来……那个老爷爷怎么都没联络我们呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊！不過話說回來……那個老爺爺怎麼都沒聯絡我們呢？」",
					{"rt2"},
				},
