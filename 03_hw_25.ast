	},
	["0075_00577"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's much more of a child than I thought.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人，比我想得还要像个孩子。",
					{"rt2"},
				},
