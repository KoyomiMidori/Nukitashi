		linkback = "0075_00202",
		linknext = "0075_00204",
		line = 2739,
	},
	["0075_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yup. A cunning and subtle one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊——”",
					{"rt2"},
