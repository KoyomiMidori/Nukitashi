	["0075_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Evidently, there was some press conference held earlier announcing something called the National Perversion Conversion Plan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才好像举行了记者会，发表的好像是这个“日本全土变态化计划”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才好像舉行了記者會，發表的好像是這個「日本全土變態化計劃」。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00034",
		linknext = "0075_00036",
		line = 476,
	},
	["0075_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's just what it says on the tin— a plan to enact perversion throughout all of Japan by expanding the scope of the perverted sex law from local to national.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其内容就跟名字一样——在日本全国范围内制订并施行变态条例——施行“",
					{"ruby", text="・・・"},
					"变态法",
					{"/ruby"},
					"”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其內容就跟名字一樣——在日本全國範圍內制定並施行變態條例——施行「",
					{"ruby", text="・・・"},
					"變態法",
					{"/ruby"},
					"」。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00035",
		linknext = "0075_00037",
		line = 486,
	},
	["0075_00037"] = {
