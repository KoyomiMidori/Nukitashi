	["0075_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya imaginé lo que quiere decir por su mirada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是看了看那双瞳孔，我就差不多察觉到她想说什么。",
