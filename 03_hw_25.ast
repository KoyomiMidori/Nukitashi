	["0075_00523"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Reprimió sus emociones y lo soportó, pero se vio obligada a hacerlo por la fuerza. No puede perdonar a las personas que se negaron a hacerlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"扼杀内心，拼命忍受，明明自己也被强迫做那种行为——却还是不能原谅抗拒这件事的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"扼殺內心，拼命忍受，明明自己也被強迫做那種行為——卻還是不能原諒抗拒這件事的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00522",
		linknext = "0075_00524",
		line = 7905,
	},
	["0075_00524"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso es demasiado infantil. Seguramente lo sabe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那只是幼稚地将怒气发在其他人身上而已——她本人应该最明白这件事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那隻是幼稚地將怒氣發在其他人身上而已——她本人應該最明白這件事吧。",
