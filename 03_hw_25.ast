		{"cgact", file="cgact", id=17, act="stopact", lv=5, alpha="0,256"},
		{"cgdel", id=17, lv=5, time=100, alphadel=1},
		{"fg", file="rei_01l_00001", file1="rei_01l_00104", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0759", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Jaja... ¿Que por qué no les digo nada? ¿Que por qué no me opongo a lo que me piden?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈……你说为什么不发出声音……？为什么不举起反旗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈……你說為什麼不發出聲音……？為什麼不舉起反旗……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00507",
		linknext = "0075_00509",
		line = 7725,
	},
	["0075_00509"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00103", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0760", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Bueno, escúchame! ¿Cómo sobrevives todos los días? ¿Acaso vives del aire? ¿Tu idea de destruir la ley te llena el estómago?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那我问你！你每天是怎么生活的！？你是靠吃晚霞生活的吗！？破坏条例的信念能让你填饱肚子吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那我問你！你每天是怎麼生活的！？你是靠吃晚霞生活的嗎！？破壞條例的信念能讓你填飽肚子嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00508",
		linknext = "0075_00510",
		line = 7739,
	},
	["0075_00510"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0761", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Te permite pagar tus facturas y tener un techo sobre tu cabeza? ¡¿Mantiene a tu familia a salvo?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那个信念能把钱汇给我吗！？能保护我的家人！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那個信念能把錢匯給我嗎！？能保護我的家人！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00509",
