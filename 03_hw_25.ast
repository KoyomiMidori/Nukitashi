		{"bg", id=1, file="bg04_3l_00000", x=-150, y=-200, path=":bg/", sync=0, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=1, act="浮遊", loop=3, size=22.5, time=75, ease="easeinout_sine"},
		{"cgact", file="cgact", id=9, act="浮遊", loop=2, size=22.5, time=75, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a129"},
		{"se", id=1, loop=0, file="se_b060"},
		{"se", id=2, loop=0, file="se_a151"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
