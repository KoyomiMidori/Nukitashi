					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sea como sea, ahora tenemos una manera de acabar con la ley. Eso me basta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管怎样，我们现在已经有手段使条例失效了。”",
