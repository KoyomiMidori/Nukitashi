		linkback = "0075_00203",
		linknext = "0075_00205",
		line = 2750,
	},
	["0075_00205"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Este grupo de la SS está más ocupado desconfiando de sus propios aliados que buscando al Frente Anticopulación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在FS的人们比起寻找反交尾势力，对同伴的警戒心更强。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在FS的人們比起尋找反交尾勢力，對同伴的警戒心更強。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00204",
		linknext = "0075_00206",
		line = 2762,
	},
	["0075_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debe ser desconcertante tener la vista oscurecida y pensar que hay elementos subversivos al asecho.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被封住了视线的他们，认定内部藏有叛乱分子——肯定会很不安吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被封住了視線的他們，認定內部藏有叛亂分子——肯定會很不安吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00205",
		linknext = "0075_00207",
		line = 2772,
	},
	["0075_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así que voy a quitarles esa inseguridad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么——我就消除你们的不安吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼——我就消除你們的不安吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00206",
		linknext = "0075_00208",
		line = 2782,
	},
	["0075_00208"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00303", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora sí... ¡Asane!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是现在——麻沙音！”",
