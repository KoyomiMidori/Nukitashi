				{"vo", file="hinami1778", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡S-Sonó como Rei-chan! ¡¿Qué está pasando?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“刚、刚才的声音是礼酱！？怎么做到的！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「剛、剛才的聲音是禮醬！？怎麼做到的！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00212",
		linknext = "0075_00214",
		line = 2858,
	},
	["0075_00214"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Mi hermanita tiene un talento increíble para imitar voces!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我妹妹很擅长声带模仿！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我妹妹很擅長聲帶模仿！」",
