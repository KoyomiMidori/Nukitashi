	["0075_00531"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su golpe es tan fuerte que me arranca las gafas protectoras casi irremovibles. Desactivó el Protocolo Ariadna.",
					{"rt2"},
				},
			},
			cn = {
				{
					"激烈的冲击——绝对不会脱落的护目镜锁被破坏，Ariadne协议被强制解除。",
					{"rt2"},
				},
			},
			tw = {
				{
					"激烈的衝擊——絕對不會脫落的護目鏡鎖被破壞，Ariadne協議被強制解除。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00530",
		linknext = "0075_00532",
		line = 8026,
	},
	["0075_00532"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0767", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Hinami confía en mí a pesar de que soy una persona inútil y profanada! Si no podía velar por mi propia seguridad... ¡lo mínimo que podía hacer era protegerla!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就算是这么脏的我，雏见也伸出了援手……所以……我想替她守护我没能守护的东西！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就算是這麼髒的我，雛見也伸出了援手……所以……我想替她守護我沒能守護的東西！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00531",
		linknext = "0075_00533",
		line = 8039,
	},
	["0075_00533"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su fuerza se debilita poco a poco.",
