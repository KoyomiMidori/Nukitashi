					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Now what? Even with all the smoke you're stirring up, the moment we go downstairs, they're gonna spot and surround us right away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么办……？不管这里的烟有多浓，只要往下走就会马上被发现，那样的话就会被夹击哦……？”",
