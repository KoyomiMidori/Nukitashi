	["0075_00641"] = {
		{"se", id=0, loop=0, file="se_b021"},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=16, time=1, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=14, lv=5, time=1, alphadel=1, evmaskoff=1},
		{"fg", mode=-1, id=11, ch="仁浦", lv=5, time=1},
		{"bg", id=2, file="bg24_3l_00000", x=30, y=-100, lv=5, path=":bg/", sync=0, time=1, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=0, mode=3, x=0, y=0},
		{"ex", func="wait", time=0},
		{"fgact", ch="仁浦", id=10, act="移動", x=-200, y=0, time=500},
		{"fgact", ch="仁浦", id=10, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine"},
		{"cgact", file="cgact", id=2, act="浮遊", loop=1, size=12.5, time=75, ease="easeinout_sine", lv=5},
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi bala se dirige perfectamente hacia su objetivo... pero él la esquiva.",
					{"rt2"},
				},
			},
			cn = {
				{
					"子弹对准头部准确飞了过去——但，被轻易躲开了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"子彈對準頭部準確飛了過去——但，被輕易躲開了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00640",
		linknext = "0075_00642",
		line = 9508,
	},
	["0075_00642"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun con los ojos cerrados, solo necesitaba mover la cabeza un poco para esquivar la bala que se le acercaba a la velocidad del sonido. Es como si la hubiera anticipado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明闭着眼睛，却好像知道子弹要飞过来了一样，他只是稍微摆动了脖子，就躲开了音速的子弹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明閉著眼睛，卻好像知道子彈要飛過來了一樣，他只是稍微擺動了脖子，就躲開了音速的子彈。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00641",
		linknext = "0075_00643",
		line = 9518,
	},
	["0075_00643"] = {
		{"bgm", file="bgm13.5", vol=100},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0100", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Qué primer golpe tan desleal de tu parte, joven.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——没想到你会使用这么卑鄙的战术呢，少年。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——沒想到你會使用這麼卑鄙的戰術呢，少年。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00642",
		linknext = "0075_00644",
		line = 9534,
	},
	["0075_00644"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me enseñaron que tan pronto como un oponente superior tomara la delantera, era el fin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要在比自己强大的人面前制造对自己不利的状况……有人教我要在那之前解决。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要在比自己強大的人面前製造對自己不利的狀況……有人教我要在那之前解決。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00643",
		linknext = "0075_00645",
		line = 9546,
	},
	["0075_00645"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0101", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“¿Te lo enseñó Tadasugawa? Nada mal. Por desgracia, eso no va a servir conmigo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“原来如此，是糺川的教诲啊。想法不错——但很遗憾，没能如愿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「原來如此，是糺川的教誨啊。想法不錯——但很遺憾，沒能如願。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00644",
		linknext = "0075_00646",
		line = 9558,
	},
	["0075_00646"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se levanta. Incluso ese gesto desprende un aire tan intimidante que se me pone la piel de gallina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦明明只是站起来而已，威压感却让我的肌肤感到刺痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦明明只是站起來而已，威壓感卻讓我的肌膚感到刺痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00645",
		linknext = "0075_00647",
		line = 9568,
	},
	["0075_00647"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Empuña una katana con la mano derecha. Su sed de sangre es perceptible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他右手握着一把散发出不祥杀气的日本刀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他右手握著一把散發出不祥殺氣的日本刀。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00646",
		linknext = "0075_00648",
		line = 9578,
	},
	["0075_00648"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0102", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Muy bien. Aceptaré tu duelo, muchacho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那么——我来当你的对手吧，少年。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那麼——我來當你的對手吧，少年。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00647",
		linknext = "0075_00649",
		line = 9592,
	},
	["0075_00649"] = {
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=300},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"evset", file="htci_m", set="htci_m", path=":ev/htci_m/"},
		{"evset", file="htci_m0101", set="htci_m010", path=":ev/htci_m010/"},
		{"bg", id=11, file="htci_m0101", x=-105, y=-5, path=":cg/htci_m/", lv=5, ev=1, time=300, bx=800, by=450},
		{"cgact", file="cgact", id=11, act="移動", x=100, y=0, time=15000, lv=5},
		{"bg", id=2, file="bg24_3l_00000", x=-100, y=-100, lv=5, path=":bg/", sync=0, ev=1, style="blur", blurx=11, blury=11, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=95, y=-5, time=15000, lv=5},
		{"se", id=0, loop=0, file="se_b081"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desenfunda su espada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刀从鞘里拔出。",
					{"rt2"},
				},
			},
			tw = {
				{
					"刀從鞘裡拔出。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00648",
		linknext = "0075_00650",
		line = 9613,
	},
	["0075_00650"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es una espada larga de 90 centímetros de longitud.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刀刃长三尺——达90厘米的大太刀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"刀刃長三尺——達90公分的大太刀。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00649",
		linknext = "0075_00651",
		line = 9623,
	},
	["0075_00651"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El brillo siniestro que desprende es distinto a de la espada de supresión inversa que utiliza la comandante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且那妖艳的光辉，和中队长使用的镇压用的逆刃刀明显不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且那妖豔的光輝，和中隊長使用的鎮壓用的逆刃刀明顯不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00650",
		linknext = "0075_00652",
		line = 9633,
	},
	["0075_00652"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está hecha para desgarrar la carne y derramar sangre. Es una espada auténtica.",
					{"rt2"},
				},
			},
			cn = {
				{
					"挥下就能撕肉饮血——那无疑是把真刀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"揮下就能撕肉飲血——那無疑是把真刀。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00651",
		linknext = "0075_00653",
		line = 9643,
	},
	["0075_00653"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=11, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgdel", id=2, lv=5, time=300, alphadel=1, evmaskoff=1},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Eres el gobernador de una prefectura. ¿La Ley de Control de Armas Blancas y de Fuego no significa nada para ti?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——堂堂县知事连枪刀法都不知道吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——堂堂縣知事連槍刀法都不知道嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00652",
		linknext = "0075_00654",
		line = 9660,
	},
	["0075_00654"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0103", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Je... ¿Crees que la ley importa en esta isla? Soy un villano. Este es mi medio para alcanzar un fin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……都现在了，还在这个岛上谈法律吗？我是坏人——能使用的东西什么都用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……都現在了，還在這個島上談法律嗎？我是壞人——能使用的東西什麼都用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00653",
		linknext = "0075_00655",
		line = 9674,
	},
	["0075_00655"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Villano, ¿eh...? Hitoura, antes de que luchemos, quiero que me prometas algo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“坏人是吗——仁浦。在决胜负之前，答应我一件事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「壞人是嗎——仁浦。在決勝負之前，答應我一件事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00654",
		linknext = "0075_00656",
		line = 9686,
	},
	["0075_00656"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0104", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“¿Oh? ¿Quieres discutir, aun en estas circunstancias?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哦？在这种情况下谈判吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哦？在這種情況下談判嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00655",
		linknext = "0075_00657",
		line = 9698,
	},
	["0075_00657"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No voy a discutirte nada. Es una orden. Si gano, vas a abolir la ley... pero también vas a mantener a la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是谈判，而是命令。如果我赢了，就废除条例——还要让FS继续存在下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是談判，而是命令。如果我贏了，就廢除條例——還要讓FS繼續存在下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00656",
		linknext = "0075_00658",
		line = 9710,
	},
	["0075_00658"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0105", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“¿Qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00657",
		linknext = "0075_00659",
		line = 9724,
	},
	["0075_00659"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No me refiero necesariamente a la SS en sí. Pero esa beca especial que tienen... Prométeme que la vas a conservar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也不一定是要让FS继续存在。特别奖学金制度……至少要答应我留下这个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也不一定是要讓FS繼續存在。特別獎學金制度……至少要答應我留下這個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00658",
		linknext = "0075_00660",
		line = 9735,
	},
	["0075_00660"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0106", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Si se elimina la ley, el influjo de dinero a esta isla se agotará. ¿De dónde quieres que saque los fondos para algo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果条例遭到破坏，流向岛上的资金也会消失。你说要从哪里筹措这些资金？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果條例遭到破壞，流向島上的資金也會消失。你說要從哪裡籌措這些資金？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00659",
		linknext = "0075_00661",
		line = 9747,
	},
	["0075_00661"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Me lo preguntas a mí? Pensaba que acumular dinero era lo que mejor se les daba a los villanos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“关我什么事——筹钱不是坏人的专长吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「關我什麼事——籌錢不是壞人的專長嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00660",
		linknext = "0075_00662",
		line = 9758,
	},
	["0075_00662"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0107", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oh... Qué argumento tan ilógico.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哦——你还真是说了个不讲理的言论呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哦——你還真是說了個不講理的言論呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00661",
		linknext = "0075_00663",
		line = 9772,
	},
	["0075_00663"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cuando eres el bueno, tienes que mantener tu ego bajo control.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为所谓的善人，只不过是把自己的自私强加在对方身上罢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為所謂的善人，只不過是把自己的自私強加在對方身上罷了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00662",
		linknext = "0075_00664",
		line = 9784,
	},
	["0075_00664"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo tengo que darte una paliza, y todo se resolverá. Tendremos nuestro final feliz.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要打倒你，一切都会圆满结束迎来幸福的结局。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要打倒你，一切都會圓滿結束迎來幸福的結局。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00663",
		linknext = "0075_00665",
		line = 9796,
	},
	["0075_00665"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si vas a hacerte llamar villano, alguien como yo tiene que existir para equilibrar la historia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你自称恶人的话——就请你成为这样的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你自稱惡人的話——就請你成為這樣的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00664",
		linknext = "0075_00666",
		line = 9807,
	},
	["0075_00666"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, delay2=2500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0108", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Admiro tu osadía. Pero ¿y si me niego?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“大胆一点是好事……但是，如果我拒绝了你打算怎么办。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「大膽一點是好事……但是，如果我拒絕了你打算怎麼辦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00665",
		linknext = "0075_00667",
		line = 9823,
	},
	["0075_00667"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No vas a hacerlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不准拒绝。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不准拒絕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00666",
		linknext = "0075_00668",
		line = 9835,
	},
	["0075_00668"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00103", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me mira con odio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"射杀般的目光刺向我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"射殺般的目光刺向我。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00667",
		linknext = "0075_00669",
		line = 9847,
	},
	["0075_00669"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero no voy a retroceder. Puede llamarme irracional todo lo que quiera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是我没有退缩。就算被说不讲理也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是我沒有退縮。就算被說不講理也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00668",
		linknext = "0075_00670",
		line = 9857,
	},
	["0075_00670"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de todo, la lógica, los hechos y la razón desaparecieron hace mucho tiempo. Eso lo que me llevó a encontrarme cara a cara con este imbécil.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管我还是这个男人，直到现在在这里对峙为止，都已经干了很多超脱常识的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管我還是這個男人，直到現在在這裡對峙為止，都已經幹了很多超脫常識的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00669",
		linknext = "0075_00671",
		line = 9867,
	},
	["0075_00671"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hablar de razón a estas alturas es una tontería.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事到如今才谈常识——这样才不正常吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"事到如今才談常識——這樣才不正常吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00670",
		linknext = "0075_00672",
		line = 9877,
	},
	["0075_00672"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No te negarás... porque no puedes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你本来就拒绝不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你本來就拒絕不了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00671",
		linknext = "0075_00673",
		line = 9888,
	},
	["0075_00673"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00302", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sé cómo eres: un pragmático hasta la médula. Aceptarías cualquier condición con tal de alcanzar tu objetivo, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“毕竟你是个彻底的合理主义者。只要能达到目的，什么条件都可以接受——对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畢竟你是個徹底的合理主義者。只要能達到目的，什麼條件都可以接受——對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00672",
		linknext = "0075_00674",
		line = 9900,
	},
	["0075_00674"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", mwframe="mwframe", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0109", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Es posible... Quizás tengas razón... Está bien. Acepto tu propuesta. Es mi compromiso como villano.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“确实……也许就像你说的那样——好吧，我接受你的条件，这是作为坏人的职责。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「確實……也許就像你說的那樣——好吧，我接受你的條件，這是作為壞人的職責。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00673",
		linknext = "0075_00675",
		line = 9914,
	},
	["0075_00675"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0110", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Pero hay una cosa en la que estás muy equivocado, muchacho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“可是……你有一个很大的误会哦，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「可是……你有一個很大的誤會哦，少年？」",
					{"rt2"},
