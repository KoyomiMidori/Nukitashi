				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ha! I'm not worried about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈——我才不在乎呢。”",
