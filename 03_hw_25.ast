		line = 456,
	},
	["0075_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's an overwhelming flood of information, but I manage to regain my composure and try to just pick out the crucial bits.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像洪水一样袭来的词汇，让我的大脑全速运转，只选出必要的信息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像洪水一樣襲來的詞彙，讓我的大腦全速運轉，只選出必要的資訊。",
					{"rt2"},
