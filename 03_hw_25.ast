		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1767", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Mmm? ¿Eso crees? Creo que Misaki-chan tiene razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……嗯？是吗？我也觉得美岬酱说的没错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……嗯？是嗎？我也覺得美岬醬說的沒錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00053",
		linknext = "0075_00055",
		line = 709,
	},
	["0075_00055"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Hinami...? ¿Por qué lo dices...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“雏见……？为什么你会这样想——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雛見……？為什麼你會這樣想——」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00054",
		linknext = "0075_00056",
		line = 721,
	},
	["0075_00056"] = {
		{"bgm", file="bgm16", vol=100},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1768", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Porque vamos a acabar con ese idiota! ¡Si cree que puede convertir todo Japón en un territorio obsceno, se va a llevar una sorpresa!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为我们会赢啊！把日本整个变成色情国家什么的，这是绝对不可能的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為我們會贏啊！把日本整個變成色情國家甚麼的，這是絕對不可能的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00055",
		linknext = "0075_00057",
		line = 736,
	},
	["0075_00057"] = {
