				},
			},
			tw = {
				{
					"鎖住關節的手逐漸開始失去力量。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00532",
		linknext = "0075_00534",
		line = 8049,
	},
	["0075_00534"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00124", file2="rei_01l_00206", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0768", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Creí... que eras como yo. Alguien que no encajaba y que por eso sufría hostigamiento.. Habías perdido a tus padres y solo te quedaba tu hermanita...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我感觉……你跟我很像。不适应这个岛，被欺负……父母不在了，但是有个妹妹……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我感覺……你跟我很像。不適應這個島，被欺負……父母不在了，但是有個妹妹……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00533",
		linknext = "0075_00535",
		line = 8063,
	},
	["0075_00535"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0769", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Y sin ninguna fortaleza destacable, eres capaz de sobrevivir gracias a tu fuerza de voluntad... Me parece increíble. Es como si fueras una manifestación de mi pasado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“明明没有什么了不起的实力，却只有毅力能够独挡一面……总觉得和以前的自己一样……我的心被吸引了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「明明沒有什麼了不起的實力，卻只有毅力能夠獨擋一面……總覺得和以前的自己一樣……我的心被吸引了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00534",
		linknext = "0075_00536",
		line = 8075,
	},
	["0075_00536"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0770", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Cuando descubrí cuánto detestabas la copulación... pensé, 'Quiero que recorra un camino que nunca me mostraron'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“当我知道那样的你，讨厌性行为……我想让你走自己没能走的路……我是这样想的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「當我知道那樣的你，討厭性行為……我想讓你走自己沒能走的路……我是這樣想的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00535",
		linknext = "0075_00537",
		line = 8087,
	},
	["0075_00537"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei-senpai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼、前辈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮、前輩……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00536",
		linknext = "0075_00538",
		line = 8099,
	},
	["0075_00538"] = {
		{"fg", file="rei_01l_00001", file1="rei_01l_00129", file2="rei_01l_00206", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0771", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“... Pero eso es una fantasía. Nada más que una fantasía egoísta. La realidad no es tan bondadosa como para permitir que eso suceda.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……但是，这些都是梦中的故事，是我的自我满足。这是不可能实现的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……但是，這些都是夢中的故事，是我的自我滿足。這是不可能實現的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00537",
		linknext = "0075_00539",
		line = 8113,
	},
	["0075_00539"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=100},
		{"bg", id=1, file="bg04_3l_00000", x=-150, y=-200, path=":bg/", sync=0, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"bg", id=16, file="rci_l0106", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, bx=800, by=450},
		{"bg", id=18, file="pm301-1", x=-5, y=-5, path=":cg/pm3/", lv=5, ev=1, bx=800, by=450},
		{"bg", id=14, file="bg04_3l_00000", x=-100, y=0, lv=5, path=":bg/", sync=0, ev=1, style="blur", blurx=11, blury=11, ax=1280, ay=730, bx=-480, by=-280},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0772", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Soy Tadasugawa Rei, la presidenta del comité de moral pública... No puedo mostrar clemencia con aquellos que desafían la ley.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我是风纪委员长，糺川礼……对背叛者……对违反条例者决不饶恕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我是風紀委員長，糺川禮……對背叛者……對違反條例者決不饒恕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00538",
		linknext = "0075_00540",
		line = 8133,
	},
	["0075_00540"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Presiona el frío cañón de su arma contra mi nuca.",
					{"rt2"},
				},
			},
			cn = {
				{
					"枪口冷冰冰地抵住我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"槍口冷冰冰地抵住我。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00539",
		linknext = "0075_00541",
		line = 8143,
	},
	["0075_00541"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0773", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya ríndete, Tachibana. No puedes vencerme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“放弃吧，橘……你赢不了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「放棄吧，橘……你贏不了我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00540",
		linknext = "0075_00542",
		line = 8155,
	},
	["0075_00542"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tienes razón...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……也许吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……也許吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00541",
		linknext = "0075_00543",
		line = 8167,
	},
	["0075_00543"] = {
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero... no voy a rendirme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……我不会放弃的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……我不會放棄的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00542",
		linknext = "0075_00544",
		line = 8181,
	},
	["0075_00544"] = {
		{"se", id=0, loop=0, file="se_a204"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset"},
		{"cgdel", id=14, lv=5, time=300, alphadel=1, evmaskoff=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=16, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=1, file="bg04_3l_00000", x=0, y=-100, path=":bg/", sync=0, style="blur", blurx=11, blury=11, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=-12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me doy la vuelta, me giro hacia ella y le quito la pistola de las manos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我将身体翻转让脸部朝上，握住手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我將身體翻轉讓臉部朝上，握住手槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00543",
		linknext = "0075_00545",
		line = 8204,
	},
	["0075_00545"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apunto el cañón directamente a mi frente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把枪口对准了——自己的额头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把槍口對準了——自己的額頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00544",
		linknext = "0075_00546",
		line = 8214,
	},
	["0075_00546"] = {
		{"cgdel", id=16, time=0, lv=5},
		{"bg", id=16, file="rci_l0106", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0774", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Qué estás haciendo...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……你要干什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……你要幹什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00545",
		linknext = "0075_00547",
		line = 8229,
	},
	["0075_00547"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No puedes mostrarme clemencia, ¿verdad? Aprieta el gatillo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你无法饶恕我，就扣下扳机吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你無法饒恕我，就扣下扳機吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00546",
		linknext = "0075_00548",
		line = 8241,
	},
	["0075_00548"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0775", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿De verdad crees que no te dispararía ahora mismo... solo porque dudé?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你以为你这么说，我就会踌躇……就不会射击吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你以為你這麼說，我就會躊躇……就不會射擊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00547",
		linknext = "0075_00549",
		line = 8253,
	},
	["0075_00549"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Claro que no. Es obvio que no puedo derrotarte. Eso es un hecho innegable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不那么认为。我赢不了礼前辈——这是不争的事实。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不那麼認為。我贏不了禮前輩——這是不爭的事實。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00548",
		linknext = "0075_00550",
		line = 8264,
	},
	["0075_00550"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0776", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Entonces quédate quieto y ríndete.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，你就干脆点放弃吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，你就乾脆點放棄吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00549",
		linknext = "0075_00551",
		line = 8276,
	},
	["0075_00551"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不会放弃的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不會放棄的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00550",
		linknext = "0075_00552",
		line = 8287,
	},
	["0075_00552"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Ya lo olvidaste? Cuando me uní a la SS, lo primero por lo que me felicitaste... fue por mi terquedad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你忘记了吗？我进入FS最初得到的评价是——不懂得放弃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你忘記了嗎？我進入FS最初得到的評價是——不懂得放棄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00551",
		linknext = "0075_00553",
		line = 8298,
	},
	["0075_00553"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0777", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Cállate... No recuerdes eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别说了……事到如今不要再提那种事了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別說了……事到如今不要再提那種事了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00552",
		linknext = "0075_00554",
		line = 8310,
	},
	["0075_00554"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No voy a rendirme. Jamás. Voy a acabar con la ley súperpervertida. Me basta con saber que al acabar con esa ley te salvaré.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我绝对不会放弃。我要毁掉变态条例，连礼前辈都一起拯救出来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我絕對不會放棄。我要毀掉變態條例，連禮前輩都一起拯救出來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00553",
		linknext = "0075_00555",
		line = 8321,
	},
	["0075_00555"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0778", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Salvarme...? ¿Crees que merezco ser salvada...? ¡No me vengas con esas tonterías, Tachibana...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“拯救……？你说要拯救我……？开什么玩笑……橘……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「拯救……？你說要拯救我……？開什麼玩笑……橘……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00554",
		linknext = "0075_00556",
		line = 8333,
	},
	["0075_00556"] = {
		{"cgdel", id=16, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=16, file="rci_l0108", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0779", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Aun después de traicionarme, sigues insistiendo en que te acompañe en tu pequeño delirio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那样背叛我后，还要说这种让我怀抱梦想的话吗……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那樣背叛我後，還要說這種讓我懷抱夢想的話嗎……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00555",
		linknext = "0075_00557",
		line = 8348,
	},
	["0075_00557"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0780", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tú y yo somos iguales. Incapaces de adaptarnos a esta isla, despreciamos a quienes anhelan actos sexuales... Pero no seguimos el mismo camino. ¡Tú elegiste el camino de la resistencia!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你和我一样……没能习惯这个岛，厌恶贪求性爱……但是，你走错了路，你选择了抵抗的道路！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你和我一樣……沒能習慣這個島，厭惡貪求性愛……但是，你走錯了路，你選擇了抵抗的道路！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00556",
		linknext = "0075_00558",
		line = 8360,
	},
	["0075_00558"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0781", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Me habría gustado hacer eso! ¡Quería seguir ese camino, pero no pude! Si lo hubiera hecho... ¡no habría podido proteger a nadie!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我也想这么做！我也想选择这条路！但是我办不到！如果不这样做……我就谁都没法保护……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我也想這麼做！我也想選擇這條路！但是我辦不到！如果不這樣做……我就誰都沒法保護……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00557",
		linknext = "0075_00559",
		line = 8372,
	},
	["0075_00559"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Y crees que eso es motivo suficiente para rendirte y resignarte a tu suerte?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事——成不了礼前辈能牺牲自己的理由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種事——成不了禮前輩能犧牲自己的理由。」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00558",
		linknext = "0075_00560",
		line = 8383,
	},
	["0075_00560"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0782", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Sí! ¡Si no fuera por esta ley, nunca habría tenido nada parecido a una familia con la que vivir! Cree lo que quieras... ¡pero la convivencia no es algo que se pueda conseguir con solo desearlo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这就是我的理由！条例如果取消了，我就失去了和家人一起活下去的方法。不管你怎么想……都不可能有两全其美的办法……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這就是我的理由！條例如果取消了，我就失去了和家人一起活下去的方法。不管你怎麼想……都不可能有兩全其美的辦法……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00559",
		linknext = "0075_00561",
		line = 8395,
	},
	["0075_00561"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Niega con la cabeza y pone cara de resignación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"带着放弃的表情，礼前辈摇了摇头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"帶著放棄的表情，禮前輩搖了搖頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00560",
		linknext = "0075_00562",
		line = 8405,
	},
	["0075_00562"] = {
		{"cgdel", id=16, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=16, file="rci_l0106", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0783", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡Incluso los héroes que los niños admiran tienen que enfrentarse a conflictos y tomar decisiones difíciles!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就连小孩子们所憧憬的英雄，也会因为矛盾而被迫做出选择……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就連小孩子們所憧憬的英雄，也會因為矛盾而被迫做出選擇……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00561",
		linknext = "0075_00563",
		line = 8420,
	},
	["0075_00563"] = {
		{"text"},
		delay = {
			[8300] = {
				{"cgdel", id=16, lv=5, time=100, alphadel=1, evmaskoff=1, delay2=8300},
				{"bg", id=16, file="rci_l0108", x=-380, y=-180, path=":cg/rci_l/", lv=5, ev=1, delay2=8300, time=300, bx=800, by=450},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0784", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Pero esta es la realidad... No puedes simplemente acabar con el villano principal y esperar que todo se resuelva pacíficamente... ¡¡Ese tipo de villano no existe!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“更别说这个现实世界……只要打倒就能完美解决一切的坏人什么的……根本就不存在啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「更別說這個現實世界……只要打倒就能完美解決一切的壞人甚麼的……根本就不存在啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00562",
		linknext = "0075_00564",
		line = 8435,
	},
	["0075_00564"] = {
