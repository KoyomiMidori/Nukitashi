				{"vo", file="misaki0424", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wah... Sabe muy bien. ¿Esas hojas ocultaban un sabor tan increíble todo este tiempo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呼哈——哎呀，真是好茶啊……这种美味，说是果汁也不为过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「呼哈——哎呀，真是好茶啊……這種美味，說是果汁也不為過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00044",
		linknext = "0066_00046",
		line = 612,
	},
	["0066_00046"] = {
