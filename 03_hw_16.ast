		linknext = "0066_00100",
		line = 1273,
	},
	["0066_00100"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00128", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
