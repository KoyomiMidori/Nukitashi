	["0066_00102"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's a veritable mountain range of problems, each as difficult as the last.",
					{"rt2"},
				},
			},
			cn = {
				{
					"问题堆积如山，每个都非常困难。",
					{"rt2"},
				},
