	["0066_00073"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You mean because your father is the governor? Is it because he created the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——难道是因为文乃的父亲是县知事吗……？变态条例的创始人——”",
					{"rt2"},
				},
			},
			tw = {
