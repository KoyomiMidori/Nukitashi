		line = 1312,
	},
	["0066_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Avoiding sex, protecting Fumino, and bringing down that law.",
					{"rt2"},
				},
			},
			cn = {
