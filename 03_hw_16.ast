	["0066_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aún no sabemos dónde está la red de tráfico sexual ilegal de la yakuza. Aunque lo supiéramos, no es un problema que podamos resolver con lo que tenemos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"黑社会的地下风俗至今还没能查出其所在地，即使知道了也无法与之抗衡。",
					{"rt2"},
				},
			},
			tw = {
				{
					"黑社會的地下風俗至今還沒能查出其所在地，即使知道了也無法與之抗衡。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00032",
		linknext = "0066_00034",
		line = 474,
	},
	["0066_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como no vamos a entregar a Fumino, volvemos al punto de partida en lo que respecta a la ley súperpervertida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然决定不交出文乃，那么废除条例一事实际上也已经是空谈。",
