			},
			tw = {
				{
					"必須想出避開性愛，藏匿文乃，瓦解條例的手段。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00102",
		linknext = "0066_00104",
		line = 1322,
	},
	["0066_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
