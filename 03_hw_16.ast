	["0066_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We still don't know where the primary hive of the Yakuza's illegal sex trade is. Even if we did, it's not a problem we're exactly equipped to handle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"黑社会的地下风俗至今还没能查出其所在地，即使知道了也无法与之抗衡。",
					{"rt2"},
				},
			},
			tw = {
				{
					"黑社會的地下風俗至今還沒能查出其所在地，即使知道了也無法與之抗衡。",
					{"rt2"},
				},
