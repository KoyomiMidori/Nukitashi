	["0066_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Iba de camino a una tienda cuando vi a Wata-chan y a una joven llamada Yuki a punto de ser atacadas. De repente, hubo fuego de cobertura y eso las salvó.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我去便利店的时候，渡酱和年幼的少女——有希差点被袭击，在危险的时候有人帮我掩护射击。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我去便利店的時候，渡醬和年幼的少女——有希差點被襲擊，在危險的時候有人幫我掩護射擊。",
					{"rt2"},
				},
