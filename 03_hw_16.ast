	["0066_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's right. We can't allow ourselves to sacrifice anyone, even for the sake of our goals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的——虽说是为了达到目的，但如果为此有人必须牺牲，那就是错误的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的——雖說是為了達到目的，但如果為此有人必須犧牲，那就是錯誤的。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00097",
