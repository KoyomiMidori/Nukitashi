					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Back there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚才？”",
					{"rt2"},
