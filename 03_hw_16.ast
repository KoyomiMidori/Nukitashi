				},
			},
			cn = {
				{
					"虽然有既视感，但是记忆的细线还是没有连接起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然有既視感，但是記憶的細線還是沒有連接起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00056",
		linknext = "0066_00058",
		line = 768,
	},
	["0066_00058"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0231", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Previously, when Hinami-san and several other island girls have been on the verge of being assaulted, I sniped the attackers from a distance. Perhaps that is why...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……以前，在雏见同学和岛上的少女被袭击时，我从远处开枪狙击过，我想是不是那时……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……以前，在雛見同學和島上的少女被襲擊時，我從遠處開槍狙擊過，我想是不是那時……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00057",
		linknext = "0066_00059",
		line = 782,
	},
	["0066_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, right, that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，这么说来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，這麼說來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00058",
		linknext = "0066_00060",
		line = 794,
	},
	["0066_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I remember it vividly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时的事情我记得很清楚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時的事情我記得很清楚。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00059",
		linknext = "0066_00061",
		line = 804,
	},
	["0066_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was on the way to a convenience store when I saw Wata-chan and a young girl named Yuki about to be assaulted. Covering fire came out of nowhere just in time and saved them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我去便利店的时候，渡酱和年幼的少女——有希差点被袭击，在危险的时候有人帮我掩护射击。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我去便利店的時候，渡醬和年幼的少女——有希差點被襲擊，在危險的時候有人幫我掩護射擊。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00060",
		linknext = "0066_00062",
		line = 814,
	},
	["0066_00062"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that was you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是文乃啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是文乃啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00061",
		linknext = "0066_00063",
		line = 826,
	},
	["0066_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's not what I was thinking of, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我觉得这种既视感并不是那时的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我覺得這種既視感並不是那時的感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00062",
		linknext = "0066_00064",
		line = 836,
	},
	["0066_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For some reason, the feeling was stronger before she took her hat off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道理由——比起把头发放下来的时候，戴着帽子的时候更有强烈的既视感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道理由——比起把頭髮放下來的時候，戴著帽子的時候更有強烈的既視感。",
					{"rt2"},
				},
