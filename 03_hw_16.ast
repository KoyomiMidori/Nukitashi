	["0066_00076"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0234", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“El objetivo principal de esa organización era encontrarme... reclutar chicas para el comercio sexual ilegal era solo un trabajo secundario.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“他们是列岛的侠义团体，以寻找我为主要目的……作为副业，在那个地下风俗里集结少女，进行色情活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「他們是列島的俠義團體，以尋找我為主要目的……作為副業，在那個地下風俗裡集結少女，進行色情活動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00075",
		linknext = "0066_00077",
		line = 993,
	},
	["0066_00077"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0235", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Así que me vestí con ropa tradicional japonesa y actué como señuelo para alejarlos de las otras chicas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以，我每天晚上都穿着和服，充当诱饵，吸引他们的注意，帮助少女。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以，我每天晚上都穿著和服，充當誘餌，吸引他們的注意，幫助少女。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00076",
		linknext = "0066_00078",
		line = 1005,
	},
	["0066_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué demonios? ¡Tenían armas de verdad! ¡¿Has estado luchando contra ellos todo este tiempo?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……？对方是带着实枪的家伙们啊？你总是和那样的家伙……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……？對方是帶著實槍的傢伙們啊？你總是和那樣的傢伙……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00077",
		linknext = "0066_00079",
		line = 1016,
	},
	["0066_00079"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0236", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Obviamente sufrí algunas heridas, pero nada que me haya apartado de mi responsabilidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“虽然多少受了点伤……但没办法。一切都是我的责任。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「雖然多少受了點傷……但沒辦法。一切都是我的責任。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00078",
		linknext = "0066_00080",
		line = 1028,
	},
	["0066_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo dice con una actitud digna.",
					{"rt2"},
				},
			},
			cn = {
				{
					"凛然的态度。",
					{"rt2"},
				},
			},
			tw = {
				{
					"凜然的態度。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00079",
		linknext = "0066_00081",
		line = 1038,
	},
	["0066_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Solo con mirarla, sé que está diciendo la verdad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃的话里没有一丝虚假，看她的样子我就知道了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃的話裡沒有一絲虛假，看她的樣子我就知道了。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00080",
		linknext = "0066_00082",
		line = 1048,
	},
	["0066_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por la forma en que describió lo que ha estado haciendo, realmente cree que ese es su destino en la vida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“没有办法，都是我的责任”这一切都是她内心里的真心话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「沒有辦法，都是我的責任」這一切都是她內心裡的真心話。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00081",
		linknext = "0066_00083",
		line = 1058,
	},
	["0066_00083"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1365", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Eso no es cierto... ¡No es tu responsabilidad! ¡Claro que no!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没那种事……这一点都不是文乃酱的责任……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒那種事……這一點都不是文乃醬的責任……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00082",
		linknext = "0066_00084",
		line = 1072,
	},
	["0066_00084"] = {
		{"bgm", stop=1},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0237", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Gracias. Me alegra tanto haber conocido a personas tan amables como ustedes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……谢谢。能遇到像大家这样温柔的人，文乃感到很幸福。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……謝謝。能遇到像大家這樣溫柔的人，文乃感到很幸福。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00083",
		linknext = "0066_00085",
		line = 1087,
	},
	["0066_00085"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo dice como si fueran palabras de despedida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那简直就像是告别的问候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那簡直就像是告別的問候。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00084",
		linknext = "0066_00086",
		line = 1101,
	},
	["0066_00086"] = {
		{"bgm", file="bgm22", vol=100},
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0238", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Desean la destrucción de la ley que rige esta isla, ¿verdad? Entregarme puede lograrlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果将支配这个岛的条例划上句号是各位的夙愿……那么，把我交出去就能实现这个愿望。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果將支配這個島的條例劃上句號是各位的夙願……那麼，把我交出去就能實現這個願望。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00085",
		linknext = "0066_00087",
		line = 1116,
	},
	["0066_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Por qué dice eso?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么会说那样的话呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼會說那樣的話呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00086",
		linknext = "0066_00088",
		line = 1126,
	},
	["0066_00088"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0239", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Hasta ahora he podido evadirlos sin problemas. Estoy segura de que seguiré haciéndolo en el futuro. Por lo tanto, permítanme...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“到目前为止，我一直都是一个人在逃命。我想今后，一个人也一定会没事的。所以，各位，请务必让我——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「到目前為止，我一直都是一個人在逃命。我想今後，一個人也一定會沒事的。所以，各位，請務必讓我——」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00087",
		linknext = "0066_00089",
		line = 1140,
	},
	["0066_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, no te voy a entregar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不可以——绝对不会把你交出去的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不可以——絕對不會把你交出去的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00088",
		linknext = "0066_00090",
		line = 1152,
	},
	["0066_00090"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0240", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Tachibana-san... pero...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“橘同学……可是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「橘同學……可是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00089",
		linknext = "0066_00091",
		line = 1166,
	},
	["0066_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No te lo dije? Ahora eres parte de nuestro grupo. Nosotros no nos abandonamos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不是说过了吗？文乃已经是我们的同伴了。我们绝对不会抛弃同伴的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不是說過了嗎？文乃已經是我們的同伴了。我們絕對不會拋棄同伴的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00090",
		linknext = "0066_00092",
		line = 1177,
	},
	["0066_00092"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Casi todos los isleños adoran esta ley absurda. Como minoría, nos tiran como basura. Nos tratan con desprecio.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“岛上的大多数人都信奉着这个可笑的条例。我们这样的少数派一直被无视，被蔑视。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「島上的大多數人都信奉著這個可笑的條例。我們這樣的少數派一直被無視，被蔑視。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00091",
		linknext = "0066_00093",
		line = 1189,
	},
	["0066_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“La sociedad nos ha abandonado porque nos negamos a comprometer nuestros valores por la conformidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了岛的繁荣所必须的牺牲——就因为这个原因抛弃我们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了島的繁榮所必須的犧牲——就因為這個原因拋棄我們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00092",
		linknext = "0066_00094",
		line = 1200,
	},
	["0066_00094"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Lo menos que podemos hacer es seguir juntos! ¡Trabajaremos juntos y lograremos nuestro objetivo como equipo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样的我们——是绝对不会为了目的而牺牲同伴的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣的我們——是絕對不會為了目的而犧牲同伴的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00093",
		linknext = "0066_00095",
		line = 1212,
	},
	["0066_00095"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00106", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0241", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Tachibana-san...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“橘、同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「橘、同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00094",
		linknext = "0066_00096",
		line = 1226,
	},
	["0066_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No te equivoques, vamos a acabar con esa maldita ley. Pero lo haremos contigo a nuestro lado. ¿Entendido?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
