	},
	["0066_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I sip my cup of hot tea, the fragrant aroma warms me up, helping me relax a bit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我喝着热茶，扑鼻的芳香充满心头，焦躁不安的心情也平静了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我喝著熱茶，撲鼻的芳香充滿心頭，焦躁不安的心情也平靜了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00038",
		linknext = "0066_00040",
		line = 537,
	},
	["0066_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Where'd this tea come from?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦……这么说来这茶，是什么时候……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦……這麼說來這茶，是什麼時候……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00039",
		linknext = "0066_00041",
		line = 549,
	},
	["0066_00041"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00101", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
