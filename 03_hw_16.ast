		line = 1263,
	},
	["0066_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're not cold-hearted pragmatists like some people I know.",
