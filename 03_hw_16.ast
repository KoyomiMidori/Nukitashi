			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, that's great and all, but what's your plan, Jun? We can't get anywhere without one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是淳，接下来你打算怎么办？如果方针不明确的话，就没法制定作战计划了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是淳，接下來你打算怎麼辦？如果方針不明確的話，就沒法制定作戰計劃了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00099",
		linknext = "0066_00101",
		line = 1286,
