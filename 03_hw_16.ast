	},
	["0066_00114"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1367", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You know, when Fumino-chan said she'd turn herself in? Tachibana-kun was like, 'No!', stopping her in her tracks. It was so cool!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“就是……文乃酱说要把自己交出去的时候。橘君拒绝后说了很多道理……那时太帅了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「就是……文乃醬說要把自己交出去的時候。橘君拒絕後說了很多道理……那時太帥了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00113",
		linknext = "0066_00115",
		line = 1480,
	},
	["0066_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, right. I think I was just stating the obvious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……不，我只是说了理所当然的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……不，我只是說了理所當然的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00114",
		linknext = "0066_00116",
		line = 1492,
	},
	["0066_00116"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's insane that Fumino thinks she needs to take all that upon herself even though it's clearly not her fault, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃明明什么责任也没有……却想把所有的责任都一个人承担下来，这不是很奇怪的事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃明明什麼責任也沒有……卻想把所有的責任都一個人承擔下來，這不是很奇怪的事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00115",
		linknext = "0066_00117",
		line = 1504,
	},
	["0066_00117"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1368", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, of course. But... I think that part of Fumino-chan reminds me of you Tachibana-kun... just a little.”",
					{"rt2"},
				},
			},
			cn = {
				{
