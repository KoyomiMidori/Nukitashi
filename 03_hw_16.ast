	["0066_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estoy teniendo un fuerte déjà vu, pero no sé por qué.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然有既视感，但是记忆的细线还是没有连接起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然有既視感，但是記憶的細線還是沒有連接起來。",
					{"rt2"},
				},
			},
