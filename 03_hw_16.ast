	["0066_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun así, le dije que se la entregaríamos. Dar marcha atrás en este momento lo pondría en nuestra contra.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但出资的老人正在准备接手文乃吧，如果拒绝引渡的话，敌对将会不可避免。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但出資的老人正在準備接手文乃吧，如果拒絕引渡的話，敵對將會不可避免。",
