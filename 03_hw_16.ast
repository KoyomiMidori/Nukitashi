	["0066_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así es. No podemos sacrificar a nadie, ni siquiera por el fin de nuestros objetivos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的——虽说是为了达到目的，但如果为此有人必须牺牲，那就是错误的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的——雖說是為了達到目的，但如果為此有人必須犧牲，那就是錯誤的。",
					{"rt2"},
				},
