				{"vo", file="fumino0228", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I took the liberty of using the tea leaves I found here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……因为有茶叶，所以我就去泡了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……因為有茶葉，所以我就去泡了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00040",
		linknext = "0066_00042",
		line = 563,
	},
	["0066_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
