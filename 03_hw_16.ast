					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That reminds me. When the SS learned of your location, they said you were in combat with the Yakuza. Do you stuff like that a lot?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，SS得到情报的时候，文乃好像在和黑社会交战……平常就这么做吗？”",
					{"rt2"},
				},
			},
			tw = {
