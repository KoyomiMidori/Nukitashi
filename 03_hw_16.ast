	["0066_00048"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00101", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0230", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“¿Tachibana-san...? ¿Qué sucede?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“橘同学……？您怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「橘同學……？您怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00047",
		linknext = "0066_00049",
		line = 652,
	},
	["0066_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, uh, no, es solo que... ¿Nos hemos visto antes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……果然，我总感觉有在哪里见过你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……果然，我總感覺有在哪裡見過你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00048",
		linknext = "0066_00050",
		line = 664,
	},
	["0066_00050"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0425", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¿Eh? ¡T-Tachibana-san, no puedes hacer eso! ¡¿De verdad vas a activar el evento de la amiga de la infancia?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……好狡猾啊橘同学！居然立起青梅竹马flag！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸……好狡猾啊橘同學！居然立起青梅竹馬flag！」",
					{"rt2"},
				},
			},
		},
