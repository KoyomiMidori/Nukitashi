			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……那時謝謝你了，文乃醬。多虧了你，我和有希都得救了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00064",
		linknext = "0066_00066",
		line = 859,
	},
