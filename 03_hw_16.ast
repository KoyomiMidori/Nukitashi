	["0066_00038"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"se", id=0, loop=0, file="se_a178"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fuuu...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“苏苏苏——呼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「蘇蘇蘇——呼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00037",
		linknext = "0066_00039",
		line = 527,
	},
	["0066_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mientras tomo mi taza de té caliente, su fragante aroma me calienta y me ayuda a relajarme un poco.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我喝着热茶，扑鼻的芳香充满心头，焦躁不安的心情也平静了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我喝著熱茶，撲鼻的芳香充滿心頭，焦躁不安的心情也平靜了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00038",
		linknext = "0066_00040",
		line = 537,
	},
	["0066_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? ¿De dónde salió este té...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦……这么说来这茶，是什么时候……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦……這麼說來這茶，是什麼時候……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00039",
		linknext = "0066_00041",
		line = 549,
	},
	["0066_00041"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00101", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0228", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Me tomé la libertad de usar las hojas de té que encontré aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……因为有茶叶，所以我就去泡了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……因為有茶葉，所以我就去泡了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00040",
		linknext = "0066_00042",
		line = 563,
	},
	["0066_00042"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, ¿en serio? Gracias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊，文乃吗……谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊，文乃嗎……謝謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00041",
		linknext = "0066_00043",
		line = 575,
	},
	["0066_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero sabe muy bien. ¿Siempre estuvo aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，这是好茶啊……居然有这样的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，這是好茶啊……居然有這樣的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00042",
		linknext = "0066_00044",
		line = 586,
	},
	["0066_00044"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1890", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“La preparación es mucho más importante que las hojas. Una técnica adecuada y cuidadosa puede liberar los verdaderos sabores.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“泡得很好对吧。如果不是特别用心的话，是泡不出这种风味的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「泡得很好對吧。如果不是特別用心的話，是泡不出這種風味的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00043",
		linknext = "0066_00045",
		line = 599,
	},
	["0066_00045"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00126", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
