	["0066_00114"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1367", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Recuerdas cuando Fumino-chan dijo que se entregaría? Dijiste que no y la detuviste. ¡Eso fue genial!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“就是……文乃酱说要把自己交出去的时候。橘君拒绝后说了很多道理……那时太帅了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「就是……文乃醬說要把自己交出去的時候。橘君拒絕後說了很多道理……那時太帥了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00113",
		linknext = "0066_00115",
		line = 1480,
	},
	["0066_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
