		linkback = "0066_00056",
		linknext = "0066_00058",
		line = 768,
	},
	["0066_00058"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0231", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Cuando Hinami-san y otras chicas de la isla estuvieron a punto de ser atacadas, le disparé a los agresores desde la distancia. ¿Será por eso...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……以前，在雏见同学和岛上的少女被袭击时，我从远处开枪狙击过，我想是不是那时……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……以前，在雛見同學和島上的少女被襲擊時，我從遠處開槍狙擊過，我想是不是那時……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00057",
		linknext = "0066_00059",
		line = 782,
	},
	["0066_00059"] = {
