			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“What does he mean by... feet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“脚……脚指的到底是什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「腳……腳指的到底是什麼……？」",
					{"rt2"},
				},
