			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“H-Hotori, could you maybe not get into an accident, please...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“畔、畔同学……你一定要小心交通事故啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「畔、畔同學……你一定要小心交通事故啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00076",
		linknext = "0088_00078",
		line = 1066,
	},
	["0088_00078"] = {
		{"fg", file="misaki_01f_00001", file3="misaki_01f_00301", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
