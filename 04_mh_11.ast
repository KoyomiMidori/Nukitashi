					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Feet on the ground?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“脚——是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「腳——是什麼？」",
					{"rt2"},
				},
			},
