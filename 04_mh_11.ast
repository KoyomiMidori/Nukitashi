	["0088_00432"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"An astounding failure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"装失败了。",
					{"rt2"},
				},
