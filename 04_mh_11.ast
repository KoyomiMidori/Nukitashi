			[8000] = {
				{"fg", file="asane_01l_00001", file1="asane_01l_00124", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1407", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Zzz... hmm? Ngh... yawn... Hotori...? Did I die?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“唔——嗯啊？嗯嗯……呼啊……咦……？畔、同学……？……我死了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「唔——嗯啊？嗯嗯……呼啊……咦……？畔、同學……？……我死了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00395",
		linknext = "0088_00397",
		line = 5540,
	},
	["0088_00397"] = {
		{"fg", file="misaki_02l_00001", file1="misaki_02l_00102", file2="misaki_02l_00201", path=":fg/misaki_02l/", id=6, lv=5, head="misaki_02l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1290", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, you're not in hell. Come on, open up and say aaah.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这里不是地狱哦，是现实。来，张开嘴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這裡不是地獄哦，是現實。來，張開嘴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00396",
		linknext = "0088_00398",
		line = 5554,
	},
	["0088_00398"] = {
		{"fg", file="asane_01l_00001", file1="asane_01l_00105", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1408", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aaah... wait, what the fuck? Why are you feeding me? If this isn't hell, is it just a nightmare?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……？不要，等一下，这是什么状况……为什么畔同学在喂我……果然是地狱吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……？不要，等一下，這是什麼狀況……為什麼畔同學在餵我……果然是地獄嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00397",
		linknext = "0088_00399",
		line = 5568,
	},
	["0088_00399"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You passed out from lack of sleep. Hotori was worried about you, so she made some rice porridge.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，你因为睡眠不足晕倒了。畔担心你所以给你熬了粥。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，你因為睡眠不足暈倒了。畔擔心你所以給你熬了粥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00398",
		linknext = "0088_00400",
		line = 5580,
	},
	["0088_00400"] = {
		{"text"},
		delay = {
			[2700] = {
