	["0088_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Who the fuck is this guy? He's huge, and based on his attire, attitude, and particularly real-looking gun, I can tell he's gonna be a problem.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个大汉是什么人。服装、言谈举止，还有右手拿着手枪——从任何角度看都不像个正派。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個大漢是什麼人。服裝、言談舉止，還有右手拿著手槍——從任何角度看都不像個正派。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00238",
		linknext = "0088_00240",
		line = 3315,
	},
	["0088_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is this the third party other than SS or OSS we were talking about?",
					{"rt2"},
				},
			},
			cn = {
				{
					"在路上看到的既不是FS也不是SHO的神秘第三势力——他和他们是一伙的吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"在路上看到的既不是FS也不是SHO的神秘第三勢力——他和他們是一伙的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00239",
		linknext = "0088_00241",
		line = 3325,
	},
	["0088_00241"] = {
		{"text"},
		text = {
