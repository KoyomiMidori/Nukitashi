		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1297", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, the action scenes with the nightstick are so cool! I love her catchphrase during the sex scenes, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的，使用十手的动作戏很帅哦！我最喜欢做爱时的标志性台词了……”",
