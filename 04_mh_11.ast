	},
	["0088_00359"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1281", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Could we break through them with Aikaze?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“用爱风强行正面突破……之类的可行吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「用愛風強行正面突破……之類的可行嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00358",
		linknext = "0088_00360",
		line = 4988,
	},
	["0088_00360"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Too dangerous. Plus, when we stopped, we'd be like fish in a barrel.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太危险了……停下的瞬间就会成为瓮中之鳖。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太危險了……停下的瞬間就會成為甕中之鱉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00359",
		linknext = "0088_00361",
		line = 5000,
	},
	["0088_00361"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1282", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It almost makes me wish we had a biological weapon that'd lay those bastards out cold.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“如果有能让对方瞬间昏倒的生化武器就好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「如果有能讓對方瞬間昏倒的生化武器就好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00360",
		linknext = "0088_00362",
		line = 5014,
	},
	["0088_00362"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You can say some really scary shit with a straight face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要轻易说出那么可怕的事情啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要輕易說出那麼可怕的事情啦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00361",
		linknext = "0088_00363",
		line = 5026,
	},
	["0088_00363"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If only we had some means to incapacitate enemies in a large area, but that's not going to...",
					{"rt2"},
				},
			},
			cn = {
				{
					"武器暂且不谈，如果有能使广范围的敌人无力化的方法就好了，但那种方法——",
					{"rt2"},
				},
			},
			tw = {
				{
					"武器暫且不談，如果有能使廣範圍的敵人無力化的方法就好了，但那種方法——",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00362",
		linknext = "0088_00364",
		line = 5036,
	},
	["0088_00364"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wait, I've got an idea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"此时，我突然想起来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"此時，我突然想起來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00363",
		linknext = "0088_00365",
		line = 5048,
	},
	["0088_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think back to the time after school when all the students were like lust zombies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"某天的放学后，学校里的学生们都变成了只想做爱的僵尸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"某天的放學後，學校裡的學生們都變成了只想做愛的殭屍。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00364",
		linknext = "0088_00366",
		line = 5058,
	},
	["0088_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was a result of Onabuta's aphrodisiac, right? Could we use that again?",
					{"rt2"},
				},
			},
			cn = {
				{
					"原因是女部田的催淫，有没有办法利用那招——",
					{"rt2"},
				},
			},
			tw = {
				{
					"原因是女部田的催淫，有沒有辦法利用那招——",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00365",
		linknext = "0088_00367",
		line = 5068,
	},
	["0088_00367"] = {
		{"se", id=0, loop=0, file="se_a030"},
