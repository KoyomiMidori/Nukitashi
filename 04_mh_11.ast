			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥……可以打扰一下吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥……可以打擾一下嗎……？」",
					{"rt2"},
				},
