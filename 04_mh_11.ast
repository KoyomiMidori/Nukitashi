			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We can, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……可以哦？”",
