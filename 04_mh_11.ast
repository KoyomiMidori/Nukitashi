		{"fg", file="asane_02m_00001", file1="asane_02m_00114", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
