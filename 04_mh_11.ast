					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The problem is how we're going to get near Fumino now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
