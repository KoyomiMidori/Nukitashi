		{"bg", id=18, file="blackback_00000", x=0, y=0, lv=5, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori sharply turns the steering wheel and Aikaze barrels away from the combat zone with the roar of her engine and crashing of trees.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔转动方向盘后，爱风便一边大声嘶吼一边远离战区。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔轉動方向盤後，愛風便一邊大聲嘶吼一邊遠離戰區。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00322",
