	},
	["0088_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hide behind a tree, hold my breath, and eavesdrop on their conversation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我躲在树荫下，屏息倾听她们的对话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我躲在樹蔭下，屏息傾聽她們的對話。",
