					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I flash back to when she brought the six-tiered lunch box, and all she'd contributed to it herself was cooking pre-washed rice...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我记得以前带来重箱时，畔只有煮无洗米……",
					{"rt2"},
				},
			},
			tw = {
				{
