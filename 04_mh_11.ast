			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Don't worry, there's enough for all of us to have at least five helpings. Now, say aaah ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“如果是量的问题你不用担心。一个人可以吃4碗。来，张开嘴巴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「如果是量的問題你不用擔心。一個人可以吃4碗。來，張開嘴巴。」",
