					name = {"淳之介"},
					"“我没想……！想看看畔穿围裙的样子或畔洗完的盘子由我擦干净放回柜子里什么的，我都没想过——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我沒想……！想看看畔穿圍裙的樣子或畔洗完的盤子由我擦乾淨放回櫃子裡什麼的，我都沒想過——！」",
