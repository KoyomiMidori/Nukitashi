	["0088_00007"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00120", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2017", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“There's no way it could be a ghost, right? Only little kids believe in ghosts!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为怎么可能有幽灵呢！居然会相信幽灵，大家都还是小孩子呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為怎麼可能有幽靈呢！居然會相信幽靈，大家都還是小孩子呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00006",
		linknext = "0088_00008",
		line = 96,
	},
