		linkback = "0088_00152",
		linknext = "0088_00154",
		line = 2058,
	},
	["0088_00154"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Probably SS riot guns. Sounds like shit's going down!”",
					{"rt2"},
				},
			},
			cn = {
