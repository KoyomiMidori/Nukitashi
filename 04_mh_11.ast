		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that's all our current leads on Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——以上就是我现在对文乃所了解的一切。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——以上就是我現在對文乃所了解的一切。」",
					{"rt2"},
				},
			},
		},
		linknext = "0088_00002",
		line = 20,
	},
	["0088_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Once we're back at school, I tell my companions what I've learned about Fumino and the ghost story.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在周一的放学后，我向聚集在一起的同伴报告幽灵的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在周一的放學後，我向聚集在一起的同伴報告幽靈的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00001",
		linknext = "0088_00003",
		line = 30,
	},
	["0088_00003"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2014", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I see. So the ghost was Fumino, huh? I wouldn't have guessed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“原来如此……没想到那个幽灵竟然是文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「原來如此……沒想到那個幽靈竟然是文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00002",
		linknext = "0088_00004",
		line = 44,
	},
	["0088_00004"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You've heard about her, too? Am I the last one hearing about this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑你也知道啊……她那么有名是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨你也知道啊……她那麼有名是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00003",
		linknext = "0088_00005",
		line = 56,
	},
	["0088_00005"] = {
		{"fg", file="hinami_01m_00001", file3="hinami_01m_00302", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=-17.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2016", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, I've heard about her, too! I thought it was a bit weird, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我也有！我也听说过！诶，我之前就觉得很奇怪了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我也有！我也聽說過！欸，我之前就覺得很奇怪了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00004",
		linknext = "0088_00006",
		line = 70,
	},
	["0088_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
