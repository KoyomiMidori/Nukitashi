	["0088_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There were hardly any SS around the school, and we haven't seen any OSS guards around, either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学校里几乎没有FS，本该在岛上警备的SHO也不见踪影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學校裡幾乎沒有FS，本該在島上警備的SHO也不見踪影。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00136",
		linknext = "0088_00138",
		line = 1847,
	},
	["0088_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We've seen a bunch of guys hanging around, which is weird for this side of the hill. They aren't having sex, either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再加上，什么都没有的山之手附近却有很多陌生的男人——他们在这里走来走去，而且没有在做爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再加上，什麼都沒有的山之手附近卻有很多陌生的男人——他們在這裡走來走去，而且沒有在做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00137",
		linknext = "0088_00139",
		line = 1857,
	},
	["0088_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've got a bad feeling about this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我有不祥的预感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我有不祥的預感。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00138",
		linknext = "0088_00140",
		line = 1867,
	},
	["0088_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa, how are things on the hill?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱，山里的情况怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬，山裡的情況怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00139",
		linknext = "0088_00141",
		line = 1879,
	},
	["0088_00141"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1393", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Way ahead of you. First thing I noticed was that there weren't any GPS markers for the guys we passed before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我正在调查……然后，首先是……刚才擦肩而过的那些人，并没有收到他们的位置情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我正在調查……然後，首先是……剛才擦肩而過的那些人，並沒有收到他們的位置情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00140",
		linknext = "0088_00142",
		line = 1892,
	},
	["0088_00142"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do they not have tablets?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……难道他们没带平板？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……難道他們沒帶平板？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00141",
		linknext = "0088_00143",
		line = 1904,
	},
	["0088_00143"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00103", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1394", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Or they're not on Cumblr, or they're turned off. In any case, they're probably all part of some group.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“要么是没有下载淫sta要么是关机……不管怎样，把他们都当成是同一个集团的人会比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「要嘛是沒有下載淫sta要嘛是關機……不管怎樣，把他們都當成是同一個集團的人會比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00142",
		linknext = "0088_00144",
		line = 1917,
	},
	["0088_00144"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So they aren't SS or OSS, but some third group? Who?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是FS也不是SHO的第三势力？那到底——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是FS也不是SHO的第三勢力？那到底——」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00143",
		linknext = "0088_00145",
		line = 1929,
	},
	["0088_00145"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1395", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yo, we ain't got time for that. There's a shit ton of people on the hillside here. I can't use the IFF since there's no cameras around, but my money's on SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不好意思，好像没有时间思考了……山之手那边聚集了非常多人……因为没有摄像头所以没法用IFF……但我想大概是FS。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不好意思，好像沒有時間思考了……山之手那邊聚集了非常多人……因為沒有攝影機所以沒法用IFF……但我想大概是FS。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00144",
		linknext = "0088_00146",
		line = 1941,
	},
	["0088_00146"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tsk, targeting Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“切——他们盯上文乃了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嘖——他們盯上文乃了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00145",
		linknext = "0088_00147",
		line = 1953,
	},
	["0088_00147"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1396", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Unclear, but based on positioning and movements, they seem to be engaged in combat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“详情还不清楚，不过从动作和配置来看，应该已经发生了一些战斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「詳情還不清楚，不過從動作和配置來看，應該已經發生了一些戰鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00146",
		linknext = "0088_00148",
		line = 1965,
	},
	["0088_00148"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
