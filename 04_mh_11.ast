		linkback = "0088_00011",
		linknext = "0088_00013",
		line = 184,
	},
	["0088_00013"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1387", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You didn't even know yourself? That's so sad. I'll help you pass on to the afterlife so you can rest in peace. Om mani pudgy bum, om mani pudgy bum...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这样啊，你没自觉是吗……我来让你成佛吧……南无胖子南无胖子混蛋肥胖猪头……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這樣啊，你沒自覺是嗎……我來讓你成佛吧……南無胖子南無胖子混蛋肥胖豬頭……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00012",
		linknext = "0088_00014",
		line = 196,
	},
	["0088_00014"] = {
