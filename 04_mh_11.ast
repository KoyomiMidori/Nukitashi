				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, sure. Still, what's with the giant-ass pot? How fucking much did you make?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……原来是这样啊……但这个量……到底做了多少啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……原來是這樣啊……但這個量……到底做了多少啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00399",
		linknext = "0088_00401",
		line = 5594,
	},
	["0088_00401"] = {
