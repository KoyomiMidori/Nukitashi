			en = {
				{
					name = {"凛", "Younger Hanamaru"},
					"“We were, but shit's really gone sideways.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛", "花丸妹妹"},
					"“是那样没错……但这种情况，应该有问题吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "花丸妹妹"},
					"「是那樣沒錯……但這種情況，應該有問題吧……」",
