	["0088_00070"] = {
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1250", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I can. I've driven them to escape before. It's basically just two bicycles put together with an engine, so it's basically the same thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯。我以前为了逃跑有开过……其实就跟增加了轴距的巨大化自行车是差不多的东西啦，诀窍是同样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯。我以前為了逃跑有開過……其實就跟增加了軸距的巨大化自行車是差不多的東西啦，訣竅是同樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00069",
		linknext = "0088_00071",
		line = 939,
	},
	["0088_00071"] = {
