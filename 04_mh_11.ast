	},
	["0088_00103"] = {
		{"bgm", file="bgm31", vol=100},
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00102", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1258", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Only everything! You can't separate the two! It's not even just a foot fetish, it's a full-on foot obsession!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“有啊！说到脚就是谷崎，说到谷崎就是脚！那种足控的程度已经超过了足控，可以说是足疯了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「有啊！說到腳就是谷崎，說到谷崎就是腳！那種足控的程度已經超過了足控，可以說是足瘋了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00102",
		linknext = "0088_00104",
		line = 1391,
	},
	["0088_00104"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00126", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1259", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I mean, just look at his maiden work 'The Tattooer'! It's all about the tattooer himself becoming obsessed with a woman's feet!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“毕竟，他从他的处女作‘刺青’开始，开头就是纹身师迷上了一位女性的脚！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「畢竟，他從他的處女作『刺青』開始，開頭就是紋身師迷上了一位女性的腳！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00103",
		linknext = "0088_00105",
		line = 1405,
	},
	["0088_00105"] = {
		{"fg", file="misaki_01l_00001", file3="misaki_01l_00304", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3300] = {
				{"fg", file="misaki_01l_00001", file1="misaki_01l_00102", file2="misaki_01l_00201", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, delay2=3300, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1260", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Take 'I've never seen your face, but I recognize your feet'. Truly powerful words, and such a poignant, obsessive description that it sends a shiver down my spine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我虽然是第一次看到你的脸，但我记得你的脚——这是里面非常厉害的台词，他对脚几近执着的描写甚至让人感到寒意呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我雖然是第一次看到你的臉，但我記得你的腳——這是裡面非常厲害的臺詞，他對腳幾近執著的描寫甚至讓人感到寒意呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00104",
		linknext = "0088_00106",
		line = 1421,
	},
	["0088_00106"] = {
		{"fg", file="misaki_01l_00001", file2="misaki_01l_00201", file3="misaki_01l_00301", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1261", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“In his later work 'Fumiko's Feet', he says 'I'm dying so let me die as you step on me', not to mention the amazing 'Diary of a Mad Old Man'!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“在最露骨的‘富美子的脚’中，还说过‘既然快要死了，那我想被你踩着死去’这样的话，晚年的‘疯癫老人日记’就更不用说了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「在最露骨的『富美子的腳』中，還說過『既然快要死了，那我想被你踩著死去』這樣的話，晚年的『瘋癲老人日記』就更不用說了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00105",
		linknext = "0088_00107",
		line = 1435,
	},
	["0088_00107"] = {
		{"fg", file="misaki_01l_00001", file2="misaki_01l_00201", file3="misaki_01l_00304", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1262", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“He says he wants to be buried with his daughter-in-law's sole imprints, so even in death she can continue treading on him! That's a level of foot obsession beyond what ordinary people could ever imagine!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“‘取继女的脚的拓印把它做成墓碑，这样即使死了也能一直被踩着’这已经是常人无法触及的想法了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「『取繼女的腳的拓印把它做成墓碑，這樣即使死了也能一直被踩著』這已經是常人無法觸及的想法了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00106",
		linknext = "0088_00108",
		line = 1449,
	},
	["0088_00108"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00107",
		linknext = "0088_00109",
		line = 1461,
	},
	["0088_00109"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00125", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1263", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ah! S-S-S-Sorry, I was rambling, but you didn't say anything, so... Aaaargh, why do loners get carried away like that so easily!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……啊！对、对对对不起我又说了这么多你没问的话为什么像我这样的人总是会马上得意忘形呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……啊！對、對對對不起我又說了這麼多你沒問的話為什麼像我這樣的人總是會馬上得意忘形呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00108",
		linknext = "0088_00110",
		line = 1475,
	},
	["0088_00110"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haha...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……哈哈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……哈哈。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00109",
		linknext = "0088_00111",
		line = 1487,
	},
	["0088_00111"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00109", file2="misaki_01l_00204", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1264", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wh-Why are you laughing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“为、为什么要笑？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「為、為什麼要笑？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00110",
		linknext = "0088_00112",
		line = 1501,
	},
	["0088_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was kinda funny.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——我觉得很有意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——我覺得很有意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00111",
		linknext = "0088_00113",
		line = 1513,
	},
	["0088_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It wasn't just the story about Tanizaki, but Hotori's impassioned tangent really tickled me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"谷崎的话题自不必说——听着畔滔滔不绝地说着，也让我心情非常愉快。",
					{"rt2"},
				},
			},
			tw = {
				{
					"谷崎的話題自不必說——聽著畔滔滔不絕地說著，也讓我心情非常愉快。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00112",
		linknext = "0088_00114",
		line = 1523,
	},
	["0088_00114"] = {
		{"fg", file="misaki_01l_00001", file2="misaki_01l_00204", file3="misaki_01l_00307", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1265", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“For me personally, the biggest deal was 'The Little Kingdom', which predicted virtual currency, which was finally becoming a thing back when I was in elementary school... ah, no, I won't start rambling again. Never mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那真是太好了……不过，我个人还是推荐‘小王国’里在小学中出现虚拟货币的故事……啊，一说又要好久了，还是算了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那真是太好了……不過，我個人還是推薦『小王國』裡在小學中出現虛擬貨幣的故事……啊，一說又要好久了，還是算了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00113",
		linknext = "0088_00115",
		line = 1537,
	},
	["0088_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Some other time, maybe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“下次再说给我听吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「下次再說給我聽吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00114",
		linknext = "0088_00116",
		line = 1549,
	},
	["0088_00116"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, what about the name? I do think it wouldn't hurt to give her one, since you brought it up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后……回到怎么称呼它的话题。确实，我也觉得有个名字比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後……回到怎麼稱呼它的話題。確實，我也覺得有個名字比較好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00115",
		linknext = "0088_00117",
		line = 1562,
	},
	["0088_00117"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=100},
		{"cgdel", id=2, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=1, file="bg09_1l_00000", x=-5, y=-5, path=":bg/", sync=0, time=1, ax=1280, ay=730, bx=-480, by=-280},
		{"bg", id=2, file="mci_s31", x=-5, y=-5, path=":cg/mci_s/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_012_00000"},
		{"cgact", file="cgact", id=2, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine", lv=5, x=-5, y=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00105", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"bg", id=2, file="mci_s31", x=-5, y=-5, path=":cg/mci_s/", lv=5, ev=1, time=300, bx=800, by=450},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2020", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Has anyone ever named a Magical Mirror before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……我没见过有人给魔镜号起名字的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……我沒見過有人給魔鏡號起名字的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00116",
		linknext = "0088_00118",
		line = 1589,
	},
	["0088_00118"] = {
		{"bgm", file="bgm04.5", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This isn't just any Magical Mirror. It's a tool for us to stand up to the SS and OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这不是一般的魔镜号。对我们来说——它是用来对抗FS和SHO的爱驹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這不是一般的魔鏡號。對我們來說——它是用來對抗FS和SHO的愛駒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00117",
		linknext = "0088_00119",
		line = 1602,
	},
	["0088_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's common for important vehicles to be named, right? Like fighter planes and warships.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“主人公的座驾都有自己的名字不是吗？连战斗机和军舰都有各自的名字了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「主角的座駕都有自己的名字不是嗎？連戰鬥機和軍艦都有各自的名字了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00118",
		linknext = "0088_00120",
		line = 1614,
	},
	["0088_00120"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00107", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1266", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah, like Yamato, Nagato, and Yukikaze. All fantastic names.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是啊。大和、长门、雪风什么的……那些都很酷呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是啊。大和、長門、雪風什麼的……那些都很酷呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00119",
		linknext = "0088_00121",
		line = 1627,
	},
	["0088_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that's what I was thinking. Something that expresses the beliefs of the NLNS and our rejection of loveless sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。像那种感觉，把我们的信条——‘不做没有爱情的性行为’这个信念凝缩而成名字才是最理想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。像那種感覺，把我們的信條——『不做沒有愛情的性行為』這個信念凝縮而成名字才是最理想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00120",
		linknext = "0088_00122",
		line = 1639,
	},
	["0088_00122"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00114", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1267", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hmm... How about Aikaze? It means Love's Way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯——那么，爱风怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯——那麼，愛風怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00121",
		linknext = "0088_00123",
		line = 1652,
	},
	["0088_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aikaze? Not bad... actually, it's great. It perfectly extols our values.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“爱风……？嗯……还不赖——不，很好呢。爱风……很适合高歌有爱的性爱的我们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「愛風……？嗯……還不賴——不，很好呢。愛風……很適合高歌有愛的性愛的我們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00122",
		linknext = "0088_00124",
		line = 1664,
	},
	["0088_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, that settles it. Her name is Aikaze.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——决定了。这家伙的名字是‘爱风’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——決定了。這傢伙的名字是『愛風』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00123",
		linknext = "0088_00125",
		line = 1676,
	},
	["0088_00125"] = {
		{"fg", file="misaki_01f_00001", file2="misaki_01f_00201", file3="misaki_01f_00308", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1268", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ooh, my offhand suggestion was accepted. Hehehe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哦哦哦……我随便说一下就被录用了。诶嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哦哦哦……我隨便說一下就被錄用了。欸嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00124",
		linknext = "0088_00126",
		line = 1689,
	},
	["0088_00126"] = {
