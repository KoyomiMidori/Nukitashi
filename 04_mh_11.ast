		linknext = "0088_00128",
		line = 1719,
	},
	["0088_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's not lame! It's awesome! My clothes are, too! Fuck you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不土！这是最棒的名字！而且我的衣服也不土吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不土！這是最棒的名字！而且我的衣服也不土吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00127",
		linknext = "0088_00129",
		line = 1731,
	},
	["0088_00129"] = {
		{"ex", time=1000, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come on, guys, at least say something!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……为什么没有人回答我……！？”",
