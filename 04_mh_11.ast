				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Y-O-U, that's who ♪ Hee, I love it when you talk nasty to me like that. Righto, let's get those silly clothes out of the way, shall we?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲・爱・的・会♪呵呵，你喜欢上被我这么说了吗？来吧，让我把碍事的衣服脱掉〜”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「親・愛・的・會♪呵呵，你喜歡上被我這麼說了嗎？來吧，讓我把礙事的衣服脫掉〜」",
					{"rt2"},
				},
			},
		},
