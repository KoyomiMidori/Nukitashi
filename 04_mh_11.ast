				{"vo", file="misaki1252", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Of course. Safety first, maybe is the way I operate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“当然。安全第一，我有时常注意各种可能发生事故的状况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「當然。安全第一，我有時常注意各種可能發生事故的狀況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00077",
