	["0088_00350"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Worried about my injury, Hotori follows me inside.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔好像很担心我的伤，所以也来了我家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔好像很擔心我的傷，所以也來了我家。",
