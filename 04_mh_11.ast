		},
		linkback = "0088_00344",
		linknext = "0088_00346",
		line = 4791,
	},
	["0088_00346"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Realistically, that Fumino will escape isn't necessarily a safe assumption.",
					{"rt2"},
				},
			},
			cn = {
				{
					"谁也不能保证文乃真的不会被抓到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"誰也不能保證文乃真的不會被抓到。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00345",
		linknext = "0088_00347",
		line = 4801,
	},
	["0088_00347"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, taking this situation on without a plan definitely wouldn't work. This is the only chance we've got.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，如果就这样毫无对策地对抗，也没有取胜的希望——现在只能赌这种可能性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，如果就這樣毫無對策地對抗，也沒有取勝的希望——現在只能賭這種可能性。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00346",
		linknext = "0088_00348",
		line = 4811,
	},
