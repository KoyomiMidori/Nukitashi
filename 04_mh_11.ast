	["0088_00010"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00106", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1241", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, did I startle you? Sorry. I've been here all along, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，不好意思让你吓了一跳……咦？真奇怪……我一直都在吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，不好意思讓你嚇了一跳……咦？真奇怪……我一直都在吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00009",
