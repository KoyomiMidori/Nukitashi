					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tanizaki... like Junichiro Tanizaki? The author? What's he got to do with feet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谷崎……指的是作家谷崎润一郎吧？他和脚有什么关系吗？”",
