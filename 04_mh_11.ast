		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori takes the wheel, I get into the passenger seat, and the others pile into the mirrored compartment behind us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔在驾驶席，我坐在副驾驶席上，然后把其他成员安排在单间的镜子房间——镜箱里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔在駕駛席，我坐在副駕駛席上，然後把其他成員安排在單間的鏡子房間——鏡箱裡。",
					{"rt2"},
				},
			},
		},
