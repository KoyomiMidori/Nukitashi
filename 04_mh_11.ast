					name = {"淳之介", "Junnosuke"},
					"“Anyway, let's head over there and see what the deal is with these feet on the ground, or whatever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……总之，先出去吧，去确认一下脚的真实身份。”",
					{"rt2"},
