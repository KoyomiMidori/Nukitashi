					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Hah... hah... What's going on? Aren't we just here to find one girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“哈、哈……怎么回事……不是只要抓住一个女孩子而已吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「哈、哈……怎麼回事……不是只要抓住一個女孩子而已嗎……？」",
