	["0088_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're not letting them take Fumino. We've come too far to get outmaneuvered now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不会将琴寄文乃交给他们——都到这一步了，怎么能让他们夺走。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不會將琴寄文乃交給他們——都到這一步了，怎麼能讓他們奪走。",
					{"rt2"},
				},
