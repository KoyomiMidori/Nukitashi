					"“I can probably randomize our comms frequency... so they can't, uh... jam... us...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我这边也……为了应对干扰，打算让周波数随机改……变……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
