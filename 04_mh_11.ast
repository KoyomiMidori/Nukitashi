					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Got it. Hotori, floor it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“知道了——畔，能开快点吗？”",
