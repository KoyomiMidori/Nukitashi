					"Surprisingly, a familiar vehicle is approaching.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是一种似曾相识的交通工具。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是一種似曾相識的交通工具。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00050",
		linknext = "0088_00052",
		line = 694,
	},
	["0088_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's an everyday sight on the island, and even on the mainland, videos taken from it are really popular.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是在青蓝岛上常见的交通工具。并且，在本岛的成人电影上也非常受欢迎的超人气车辆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是在青藍島上常見的交通工具。並且，在本島的成人電影上也非常受歡迎的超人氣車輛。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00051",
		linknext = "0088_00053",
		line = 704,
	},
	["0088_00053"] = {
		{"evset", file="mcg03", set="mcg03", path=":ev/mcg03/"},
		{"evset", file="mcg03011", set="mcg03011", path=":ev/mcg03011/"},
		{"bg", id=19, file="mcg03011", x=-5, y=-5, path=":cg/mcg03/", lv=5, ev=1, time=300, bx=800, by=450},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's called the Magical Mirror.",
					{"rt2"},
				},
			},
			cn = {
				{
					"它的名字叫做——魔镜号。",
					{"rt2"},
				},
			},
			tw = {
				{
					"它的名字叫做——魔鏡號。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00052",
		linknext = "0088_00054",
		line = 718,
	},
	["0088_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, Magical Mirrors on this island are military vehicles. The SS and OSS use them as transports as well as for engaging in kinky play.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是在这个岛上，魔镜号是FS和SHO为了巡视和play而使用的车辆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是在這個島上，魔鏡號是FS和SHO為了巡視和play而使用的車輛。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00053",
		linknext = "0088_00055",
		line = 728,
	},
	["0088_00055"] = {
		{"cgdel", id=18, lv=5, time=1, alphadel=1, evmaskoff=1},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=19, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't the SS drive those!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“会不会是FS在驾驶……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「會不會是FS在駕駛……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00054",
		linknext = "0088_00056",
		line = 743,
	},
	["0088_00056"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1246", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Not this one, from the looks of it. The driver's seat is empty. You think it might be self-driving?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不……看起来驾驶席上没有人，难道是自动驾驶吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不……看起來駕駛席上沒有人，難道是自動駕駛嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00055",
		linknext = "0088_00057",
		line = 756,
	},
	["0088_00057"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You can see all that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你看得真清楚呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你看得真清楚呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00056",
		linknext = "0088_00058",
		line = 768,
	},
	["0088_00058"] = {
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[6100] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00115", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=6100, time=300, mode=3, x=0, y=0},
			},
			[8500] = {
				{"fg", file="misaki_01m_00001", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki1247", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hehe, I'm confident in my eyesight. Whenever there's a visual acuity test, I imagine the entire class saying 'amazing, are you part hawk or something?'”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……我对自己的视力很有自信。每次检查视力的时候，我都妄想着班上的同学称赞我‘好厉害，像马赛人一样’的场景。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……我對自己的視力很有自信。每次檢查視力的時候，我都妄想著班上的同學稱讚我『好厲害，像馬賽人一樣』的場景。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00057",
		linknext = "0088_00059",
		line = 786,
	},
	["0088_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Your imagination is really sad...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这妄想太悲伤了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這妄想太悲傷了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00058",
		linknext = "0088_00060",
		line = 798,
	},
	["0088_00060"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00118", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1248", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I never end up taking those tests, though. They always just skip over me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但实际上在被这么说之前，检查就很容易直接跳过我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但實際上在被這麼說之前，檢查就很容易直接跳過我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00059",
		linknext = "0088_00061",
		line = 812,
	},
	["0088_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Reality is even sadder.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现实更加悲伤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現實更加悲傷。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00060",
		linknext = "0088_00062",
		line = 822,
	},
	["0088_00062"] = {
		{"se", id=0, stop=1, time=3000},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Before long, the Magical Mirror pulls up and stops next to us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"终于，接近的魔镜号在我们身边停了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"終於，接近的魔鏡號在我們身邊停了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00061",
		linknext = "0088_00063",
		line = 835,
	},
	["0088_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just to be safe, I give the vehicle a cautious once-over. As Hotori said, it's empty.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以防万一我一边警戒一边观察情况，果然如畔所说，完全没有人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以防萬一我一邊警戒一邊觀察情況，果然如畔所說，完全沒有人。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00062",
		linknext = "0088_00064",
		line = 845,
	},
	["0088_00064"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess this is the feet on the ground we were sent. With this, we can get around the island without arousing suspicion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，这就是‘脚’啊。如果是魔镜号的话，就可以堂堂正正地在街上行动，也可以拿来查看外面的情况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，這就是『腳』啊。如果是魔鏡號的話，就可以堂堂正正地在街上行動，也可以拿來查看外面的情況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00063",
		linknext = "0088_00065",
		line = 857,
	},
	["0088_00065"] = {
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1389", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I can't believe it's fully self-driving. I didn't think that tech existed yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好厉害……自动驾驶功能什么的，可是连真正的魔镜号都没有啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好厲害……自動駕駛功能什麼的，可是連真正的魔鏡號都沒有啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00064",
		linknext = "0088_00066",
		line = 872,
	},
	["0088_00066"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, we can't drive, so he was probably looking out for us there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大概是担心我们不会开车吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大概是擔心我們不會開車吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00065",
		linknext = "0088_00067",
		line = 884,
	},
	["0088_00067"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ideally, we'd be able to operate it ourselves so we can make full use of it. We should just take what we can get for now, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“本来应该是用手动驾驶会比较能应付突发的事态——但我们也不能要求那么多了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「本來應該是用手動駕駛會比較能應付突發的事態——但我們也不能要求那麼多了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00066",
		linknext = "0088_00068",
		line = 896,
	},
	["0088_00068"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
