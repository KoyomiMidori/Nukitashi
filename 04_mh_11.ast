		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"bg", id=3, file="bg10_1l_00000", x=200, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=3, act="移動", x=-405, y=-5, time=50000, lv=5},
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00112", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2023", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Still, isn't this weird? I don't see anyone around having sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是，总觉得和平时不一样呢……几乎没看到做爱的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是，總覺得和平時不一樣呢……幾乎沒看到做愛的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00133",
