	["0088_00132"] = {
		{"fgact", id=4, ch="奈々瀬", act="stopact"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2022", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“As a kid, I was taught that if you can't say something nice, you shouldn't say anything at all. No comment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“如果不想受伤的话，就不要再问那个问题，专心寻找文乃吧，好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「如果不想受傷的話，就不要再問那個問題，專心尋找文乃吧，好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00131",
		linknext = "0088_00133",
		line = 1786,
	},
	["0088_00133"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
