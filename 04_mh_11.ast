		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=500},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=400, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2015", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Still, it's kinda weird that a normal girl would be reported as a ghost. You think the SS or OSS were the ones who initiated the rumor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过……一般的女孩子会成为幽灵之类的传闻也真是奇怪啊。不是FS和SHO放出的谣言吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過……一般的女孩子會成為幽靈之類的傳聞也真是奇怪啊。不是FS和SHO放出的謠言嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00014",
		linknext = "0088_00016",
		line = 229,
	},
	["0088_00016"] = {
		{"bgm", file="bgm11", vol=100},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2019", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's really mean, though. You think they'd do something like that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“为什么要做那样欺负人的事情呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「為什麼要做那樣欺負人的事情呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00015",
		linknext = "0088_00017",
		line = 244,
	},
	["0088_00017"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2016", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's just a theory, but we've got reason to believe that people learning of Fumino's existence could cause problems for them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然是假设，但‘如果有人知道文乃的存在就麻烦了’也可能是这样的原因吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然是假設，但『如果有人知道文乃的存在就麻煩了』也可能是這樣的原因吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00016",
		linknext = "0088_00018",
		line = 258,
	},
	["0088_00018"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So they're controlling the spread of information?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“情报操作是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「情報操作是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00017",
		linknext = "0088_00019",
		line = 270,
	},
	["0088_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The old man told us that Fumino is the key to crushing the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据老人说，文乃是废除变态条例的存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據老人說，文乃是廢除變態條例的存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00018",
		linknext = "0088_00020",
		line = 280,
	},
	["0088_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All I can guess is that it would be bad for Governor Hitoura and the establishment if the public learned of her existence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对仁浦先生和体制方面的人来说，连公开其存在都有可能是不利的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對仁浦先生和體制方面的人來說，連公開其存在都有可能是不利的。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00019",
		linknext = "0088_00021",
		line = 290,
	},
	["0088_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do the SS plan to do if they apprehend her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……FS到底要抓文乃做什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……FS到底要抓文乃做什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00020",
		linknext = "0088_00022",
		line = 301,
	},
	["0088_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2017", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Who knows, but if the prefectural governor doesn't want people learning of her existence, there's no way it could be good.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然只是猜测……但如果文乃对县知事来说是个棘手的存在的话……我没有什么好预感。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然只是猜測……但如果文乃對縣知事來說是個棘手的存在的話……我沒有什麼好預感。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00021",
		linknext = "0088_00023",
		line = 313,
	},
	["0088_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. We need her for our objective, but even that aside, we can't just leave her to them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……虽然是为了达到我们的目的——但就算不是这样，也不能眼睁睁地把文乃交给他。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……雖然是為了達到我們的目的——但就算不是這樣，也不能眼睜睜地把文乃交給他。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00022",
		linknext = "0088_00024",
		line = 325,
	},
	["0088_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right, let's all focus on searching today. We can use the eyewitness reports to figure out where she's likely to appear...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天我们所有人都去搜索文乃吧。根据目前为止的目击情报，预测可能出现的地点——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天我們所有人都去搜索文乃吧。根據目前為止的目擊情報，預測可能出現的地點——」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00023",
		linknext = "0088_00025",
		line = 336,
	},
	["0088_00025"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a190"},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00109", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A familiar sound echoes through the base, and everyone tenses up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为突然响起的声音，基地内的紧张感一下子高涨了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為突然響起的聲音，基地內的緊張感一下子高漲了。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00024",
		linknext = "0088_00026",
		line = 352,
	},
	["0088_00026"] = {
		{"bgm", file="bgm04.5", vol=100},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bg", id=2, file="bg12_1l_00000", x=0, y=100, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I stop talking and look at the central monitor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我闭上嘴，把目光转向中央显示器。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我閉上嘴，把目光轉向中央顯示器。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00025",
		linknext = "0088_00027",
		line = 370,
	},
	["0088_00027"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0085", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“It appears you haven't found Fumino yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——好像还没发现文乃的样子呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——好像還沒發現文乃的樣子呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00026",
		linknext = "0088_00028",
		line = 383,
	},
	["0088_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, I'm terribly sorry. After boldly declaring that we'd definitely have her by the next time you contacted us...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的……对不起，我明明保证在下次联系之前一定会找到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的……對不起，我明明保證在下次聯繫之前一定會找到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00027",
		linknext = "0088_00029",
		line = 395,
	},
	["0088_00029"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0086", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“I don't have the time to waste on punishing you for bygones. Give me a concise progress report.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“我并不想责怪过去的事情浪费时间。快点交代事情的前因后果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「我並不想責怪過去的事情浪費時間。快點交代事情的前因後果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00028",
		linknext = "0088_00030",
		line = 408,
	},
	["0088_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We were able to extract data from an SS computer terminal. Apparently, Governor Toshiaki Hitoura personally directed the SS to find and apprehend Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们成功地从FS的终端夺取了数据。县知事仁浦俊明好像下令让FS捕捉文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們成功地從FS的終端奪取了數據。縣知事仁浦俊明好像下令讓FS捕捉文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00029",
		linknext = "0088_00031",
		line = 420,
	},
	["0088_00031"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0087", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Is that so? Young man, it is vital that you find her before that man gets his hands on her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“这样啊。那个男人——少年，无论如何都要比他们先找到文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「這樣啊。那個男人——少年，無論如何都要比他們先找到文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00030",
		linknext = "0088_00032",
		line = 433,
	},
	["0088_00032"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course. The SS data includes sighting locations, and we are using that to inform our search.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我当然明白。我们会根据从FS那抢来的情报推测出文乃的所在地，然后进行搜查。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我當然明白。我們會根據從FS那搶來的情報推測出文乃的所在地，然後進行搜查。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00031",
		linknext = "0088_00033",
		line = 445,
	},
	["0088_00033"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0088", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Good timing. I've sent you some extra feet on the ground to assist your search. Make use of them.”",
