		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I try to resist, but the slightest movement sends pain surging through me. I can barely move my hands.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使想要抵抗，只要移动身体就会发出剧痛，而且手也没有力气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使想要抵抗，只要移動身體就會發出劇痛，而且手也沒有力氣。",
					{"rt2"},
				},
			},
		},
