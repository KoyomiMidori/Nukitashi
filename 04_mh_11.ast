	},
	["0088_00433"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway! It's time to think about finding Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之！现在必须要考虑的是文乃的事情！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之！現在必須要考慮的是文乃的事情！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00432",
		linknext = "0088_00434",
		line = 6016,
	},
	["0088_00434"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We need a plan to deal with being hopelessly outnumbered, as well as to deal with Onabuta herself. Plus... uh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要拟定对上多人数的作战，我个人还需要拟定对付女部田的策略，还有……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要擬定對上多人數的作戰，我個人還需要擬定對付女部田的策略，還有……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00433",
		linknext = "0088_00435",
		line = 6028,
	},
	["0088_00435"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My train of thought comes to a screeching halt and the room falls silent.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我没办法再继续说下去，便沉默了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沒辦法再繼續說下去，便沉默了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00434",
		linknext = "0088_00436",
		line = 6038,
	},
	["0088_00436"] = {
