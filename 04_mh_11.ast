			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ehehe... That's more like you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶嘿嘿……这才是橘同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸嘿嘿……這才是橘同學。」",
					{"rt2"},
