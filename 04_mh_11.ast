	["0088_00422"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shut up! I definitely wasn't thinking about how much I'd love to see her in an apron, or to be in there with her putting the dishes away as she handed them to me! I don't know why you'd even bring it up, honestly!”",
					{"rt2"},
