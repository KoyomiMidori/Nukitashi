					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, well, uh... I thought I saw a bunch of SS coming up here, so I thought it was gonna be a free-for-all, and I just...”",
					{"rt2"},
				},
			},
			cn = {
