				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But why? They look like Yakuza, but why would they be on the island? What are they doing out here?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是为什么呢？假如他们是黑社会——那为什么会在这个岛上，而且是在这样的地方……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是為什麼呢？假如他們是黑社會——那為什麼會在這個島上，而且是在這樣的地方……？",
					{"rt2"},
				},
			},
		},
