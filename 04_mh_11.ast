		line = 4916,
	},
	["0088_00354"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Right now, it's propped up on a box, above my heart to minimize any internal bleeding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了防止内出血，我把脚放在纸箱上，使其高于心脏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了防止內出血，我把腳放在紙箱上，使其高於心臟。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00353",
