		{"fg", file="ikuko_01l_00001", file1="ikuko_01l_00110", path=":fg/ikuko_01l/", id=10, lv=5, head="ikuko_01l", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
