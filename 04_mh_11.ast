			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“All bound ghosts say that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所有的地缚灵都是这么说的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所有的地縛靈都是這麼說的……」",
					{"rt2"},
