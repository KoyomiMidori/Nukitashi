		linkback = "0088_00033",
		linknext = "0088_00035",
		line = 470,
	},
	["0088_00035"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0089", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You'll see. I've directed them to stand by at the rear school gate. Use them to ensure you find Fumino first. Understood?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“你很快就会知道了。我指示了让它在学校的后门待命，你一定要用它提前将文乃找出来。一定要……知道了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「你很快就會知道了。我指示了讓它在學校的後門待命，你一定要用它提前將文乃找出來。一定要……知道了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00034",
		linknext = "0088_00036",
		line = 483,
	},
	["0088_00036"] = {
