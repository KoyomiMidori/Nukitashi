		},
		text = {
			vo = {
				{"vo", file="misaki1289", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Asane... Asaneee... I know you're sleepy, but please wake up for a bit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“麻沙音酱，麻沙音酱。虽然你很困，但是该起床了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「麻沙音醬，麻沙音醬。雖然你很睏，但是該起床了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00394",
		linknext = "0088_00396",
		line = 5524,
	},
	["0088_00396"] = {
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="asane_01l_00001", file1="asane_01l_00115", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=400, y=0},
