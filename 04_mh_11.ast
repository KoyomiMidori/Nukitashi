					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“那里的家伙！刚才的声音到底是——那个护目镜……是反交尾势力……还有仙波小姐……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「那裡的傢伙！剛才的聲音到底是——那個護目鏡……是反交尾勢力……還有仙波小姐……！？」",
					{"rt2"},
