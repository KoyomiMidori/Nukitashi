		linkback = "0088_00037",
		linknext = "0088_00039",
		line = 519,
	},
	["0088_00039"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't know. Why don't we go see? Asa, what's the rear gate situation?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不知道。先去看看吧——麻沙酱，后门的情况怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不知道。先去看看吧——麻沙醬，後門的情況怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00038",
		linknext = "0088_00040",
		line = 531,
	},
	["0088_00040"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"se", id=0, loop=0, file="se_a118"},
		{"text"},
		delay = {
			[2000] = {
				{"se", id=0, loop=0, file="se_a120", delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1388", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aye aye, captain. Chugga chugga chugga... choo choo! Theeeere's... no one there. At all. Not even any SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯嗯……咔哒咔哒……哒——！嗯……谁也不在啊。完全安全……应该说……FS几乎都不在呢”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯嗯……咔噠咔噠……噠——！嗯……誰也不在啊。完全安全……應該說……FS幾乎都不在呢」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00039",
		linknext = "0088_00041",
		line = 546,
	},
	["0088_00041"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2020", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Weird. Maybe they're off having a picnic or something!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“很少见呢，大家一起去野餐了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「很少見呢，大家一起去野餐了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00040",
		linknext = "0088_00042",
		line = 559,
	},
	["0088_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't want to imagine what a Seiran Island picnic would be. If anything, maybe they're taking a picnic break in their hunt for Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是野餐——也是寻找文乃的野餐吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是野餐——也是尋找文乃的野餐吧。",
					{"rt2"},
				},
			},
		},
