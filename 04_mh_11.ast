				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, I just did what you told me to. I'm glad you're okay.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，我只是按照你说的去做……不过，没问题的话就好。”",
