	["0088_00426"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00127", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1417", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“If you really like her that much, then I think it's all right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥那么喜欢的话……也没什么不好吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥那麼喜歡的話……也沒什麼不好吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00425",
		linknext = "0088_00427",
		line = 5938,
	},
	["0088_00427"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa says that gruffly as she shoots Hotori a sidelong glance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱侧眼看着畔的后背，语气粗暴地说着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬側眼看著畔的後背，語氣粗暴地說著。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00426",
		linknext = "0088_00428",
		line = 5948,
	},
	["0088_00428"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That response is so unexpected that my heart starts pounding. I clear my throat to try and cover it up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"意料之外的一句话让我心跳加速——我立即咳了一声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"意料之外的一句話讓我心跳加速——我立即咳了一聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00427",
		linknext = "0088_00429",
		line = 5958,
	},
	["0088_00429"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't be stupid. We don't have time to worry about that now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……别说傻话。现在可不是说这种事情的时候吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……別說傻話。現在可不是說這種事情的時候吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00428",
		linknext = "0088_00430",
		line = 5970,
	},
	["0088_00430"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I gulp down on my cup and try to calm down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我将杯子倾斜，装出平静的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我將杯子傾斜，裝出平靜的樣子。",
