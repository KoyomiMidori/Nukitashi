				{"vo", file="misaki1280", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“There's too many of them. Between the SS and OSS, we're looking at, like, 70 people.”",
					{"rt2"},
				},
			},
			cn = {
