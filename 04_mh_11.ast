	["0088_00387"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She's been tirelessly going over the SS data ever since the olympiad. I guess she hasn't even been sleeping right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“自从体欲节结束后，她一直在收集FS的数据……可能是都没怎么睡吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「自從體欲節結束後，她一直在收集FS的數據……可能是都沒怎麼睡吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00386",
		linknext = "0088_00388",
		line = 5379,
	},
	["0088_00388"] = {
