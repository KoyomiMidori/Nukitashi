		linkback = "0088_00349",
		linknext = "0088_00351",
		line = 4880,
	},
	["0088_00351"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think we'll need to lay low for a while before we can act properly again, but we got out of it thanks to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要静养一会儿就能动了吧，多亏畔的应急措施。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要靜養一下就能動了吧，多虧畔的緊急處理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00350",
		linknext = "0088_00352",
		line = 4892,
	},
	["0088_00352"] = {
		{"text"},
		delay = {
			[4200] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00201", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, delay2=4200, time=300, mode=3, x=0, y=0},
