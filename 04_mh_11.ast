	},
	["0088_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My injured shin is wrapped in an elastic bandage, and I've got ice on it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"受伤的小腿上缠着弹性绷带，还敷了冰。",
					{"rt2"},
				},
			},
			tw = {
				{
					"受傷的小腿上纏著彈性繃帶，還敷了冰。",
