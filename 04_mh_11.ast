	["0088_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I look at the monitor displaying the rear compartment and see Asa holding her head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我看了看显示后面房间的显示器，麻沙酱正抱着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我看了看顯示後面房間的顯示器，麻沙醬正抱著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00080",
		linknext = "0088_00082",
		line = 1117,
	},
	["0088_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if it's been a long time since the accident that killed our parents, it seems like she still isn't comfortable with moving vehicles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说父母的交通事故已经过去了很久，但她好像还是对车抱有恐惧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說父母的交通事故已經過去了很久，但她好像還是對車抱有恐懼。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00081",
		linknext = "0088_00083",
		line = 1127,
	},
	["0088_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase, sorry but you could please attend to Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不好意思奈奈濑，麻沙酱可以拜托你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不好意思奈奈瀨，麻沙醬可以拜託你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00082",
		linknext = "0088_00084",
		line = 1139,
	},
	["0088_00084"] = {
		{"fgact", id=5, ch="麻沙音", act="stopact"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=5, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2018", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, sure. Come here, Asa. Are you scared? There, there... everything's fine. Squeeze... don't worry, I'm right here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯嗯。来吧麻沙酱，你很不安吧？好乖好乖……不用害怕哦？你看，我抱着你……这样就放心了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯嗯。來吧麻沙醬，你很不安吧？好乖好乖……不用害怕哦？你看，我抱著你……這樣就放心了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00083",
		linknext = "0088_00085",
		line = 1154,
	},
	["0088_00085"] = {
		{"fgact", id=5, ch="奈々瀬", act="stopact"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00113", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=5, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="奈々瀬", id=5, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_c027"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2019", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh!? Hey, Jun, what do I do!? Her nose is bleeding!”",
					{"rt2"},
				},
			},
			cn = {
				{
