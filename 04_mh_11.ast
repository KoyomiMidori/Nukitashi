			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“She's been working so hard, she's earned her sleep. Do you have plans for dinner?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“麻沙音酱很努力呢。总之得让她睡在被子里……晚饭的菜单已经决定好了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「麻沙音醬很努力呢。總之得讓她睡在被子裡……晚飯的菜單已經決定好了嗎？」",
					{"rt2"},
				},
			},
		},
