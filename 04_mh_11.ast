	["0088_00101"] = {
		{"fg", file="misaki_01l_00001", file1="misaki_01l_00114", path=":fg/misaki_01l/", id=6, lv=5, head="misaki_01l", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1257", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Right. Since she's our feet, I want to call her Tanizaki, but that's my bike's name.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的。既然是脚，我其实是想取谷崎的……但那就和我的爱车撞名了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的。既然是腳，我其實是想取谷崎的……但那就和我的愛車撞名了……」",
					{"rt2"},
				},
			},
