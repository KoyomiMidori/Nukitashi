		},
		linkback = "0088_00153",
		linknext = "0088_00155",
		line = 2070,
	},
	["0088_00155"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Worrying about it isn't going to help! Our top priority is finding Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
