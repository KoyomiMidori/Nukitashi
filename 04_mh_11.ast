	["0088_00069"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? No, I mean we can't drive the Magical Mirror.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶？这可是要驾驶魔镜号哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？這可是要駕駛魔鏡號哦……？」",
