				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃，是這樣……聽說FS的人來了很多，所以我想說現在應該可以盡情做愛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00194",
		linknext = "0088_00196",
		line = 2678,
	},
	["0088_00196"] = {
