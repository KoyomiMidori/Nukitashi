	["0088_00324"] = {
		{"se", id=0, stop=1, time=1000},
		{"cgdel", id=18, lv=5, time=100, alphadel=1},
		{"bg", id=1, file="bg08_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=2, file="mci_s11", x=-5, y=-5, path=":cg/mci_s/", lv=5, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"cgact", file="cgact", id=2, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine", lv=5, x=-5, y=-5},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's the situation?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这是什么情况？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這是什麼情況？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00323",
		linknext = "0088_00325",
		line = 4531,
	},
	["0088_00325"] = {
		{"bg", id=2, file="mci_s11", x=-5, y=-5, path=":cg/mci_s/", lv=5, ev=1, time=300, bx=800, by=450},
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1400", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The SS are jamming our comms, so we thought it'd be best to pick everyone up and GTFO. You were our last stop.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为FS的电波干扰，这边的通讯被破坏了……所以我们立刻把奈奈濑同学和渡酱带了回来，然后现在也捡回了哥哥，这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為FS的電波干擾，這邊的通訊被破壞了……所以我們立刻把奈奈瀨同學和渡醬帶了回來，然後現在也撿回了哥哥，這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00324",
		linknext = "0088_00326",
		line = 4545,
	},
	["0088_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What about Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃呢……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00325",
		linknext = "0088_00327",
		line = 4556,
	},
	["0088_00327"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The stunned silence serves as my answer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"沉默——这就是答案。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沉默——這就是答案。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00326",
		linknext = "0088_00328",
		line = 4566,
	},
	["0088_00328"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They're on her ass! We need to go back for her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个孩子正被追赶着！得马上回去——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個孩子正被追趕著！得馬上回去——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00327",
		linknext = "0088_00329",
		line = 4578,
	},
	["0088_00329"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00103", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=3, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2026", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“N-No! You're badly hurt.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不、不行啦！橘君都受重伤了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不、不行啦！橘君都受重傷了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00328",
		linknext = "0088_00330",
		line = 4592,
	},
	["0088_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn't that what morphine shots are for!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种事只要注射吗啡——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這種事只要注射嗎啡——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00329",
		linknext = "0088_00331",
		line = 4603,
	},
	["0088_00331"] = {
		{"cgact", file="cgact", id=2, act="stopact", lv=5, x=-5, y=-5},
		{"cgdel", id=2, lv=5, time=100, alphadel=1, evmaskoff=1},
		{"bg", id=2, file="mci_s12", x=-5, y=-5, path=":cg/mci_s/", lv=5, ev=1, time=300, bx=800, by=450},
		{"cgact", file="cgact", id=2, act="振動下", loop=-1, size=1.5, time=500, ease="easeinout_sine", lv=5, x=-5, y=-5},
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00115", file2="misaki_01f_00202", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1276", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No!! There are people there with real guns!! You could be killed! I don't know what I'd do if that happened...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不行！！有拿着真枪的人在喔！？橘同学真的会死的……！如果发生这种事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不行！！有拿著真槍的人在喔！？橘同學真的會死的……！如果發生這種事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00330",
		linknext = "0088_00332",
		line = 4620,
	},
	["0088_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her unusually intense tone of voice makes my blazing fury cool instantly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她那比以往任何时候都强烈的语气，让我感到发热的脑袋一下子冷了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她那比以往任何時候都強烈的語氣，讓我感到發熱的腦袋一下子冷了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00331",
		linknext = "0088_00333",
		line = 4630,
	},
	["0088_00333"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2026", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun, calm down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……淳，冷静点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……淳，冷靜點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00332",
		linknext = "0088_00334",
		line = 4644,
	},
	["0088_00334"] = {
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00301", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... sorry...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——嗯……对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——嗯……對不起……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00333",
		linknext = "0088_00335",
		line = 4656,
	},
	["0088_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even with a morphine hit, we don't exactly have a plan at the moment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使打了吗啡再回去，也没有突破现况的方法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使打了嗎啡再回去，也沒有突破現況的方法。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00334",
		linknext = "0088_00336",
		line = 4666,
	},
	["0088_00336"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As Hotori said, they've got real guns. Going in without a strategy could very easily be actually suicidal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正如畔所说，对方拥有真正的手枪。如果不采取对策就回去的话，会危及同伴的生命。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正如畔所說，對方擁有真正的手槍。如果不採取對策就回去的話，會危及同伴的生命。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00335",
		linknext = "0088_00337",
		line = 4676,
	},
	["0088_00337"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was so consumed with finding Fumino that the idea of having a clear plan didn't even occur to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被文乃的事影响，我居然失去冷静到连这种事情都不知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被文乃的事影響，我居然失去冷靜到連這種事情都不知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00336",
		linknext = "0088_00338",
		line = 4686,
	},
	["0088_00338"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, I'm worried about her...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，这样文乃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，這樣文乃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00337",
		linknext = "0088_00339",
		line = 4698,
	},
	["0088_00339"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1401", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“We may still have a fighting chance. Fuck if I know why, but the SS and OSS are at each other's throats right now, so I doubt either of them will be able to find Fumino, given the situation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……还有机会的。原因我不知道，不过如果FS和SHO对立，或许两边都没办法马上抓到文乃吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……還有機會的。原因我不知道，不過如果FS和SHO對立，或許兩邊都沒辦法馬上抓到文乃吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00338",
		linknext = "0088_00340",
		line = 4712,
	},
	["0088_00340"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2027", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The sun's already gone down, too. We can't search in these conditions, let alone fight. We couldn't even see our enemies properly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“再加上太阳要下山了。要战斗的话现在是最恶劣的状况。光是在黑暗中搜索就很困难了，更何况敌人就在这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「再加上太陽要下山了。要戰鬥的話現在是最惡劣的狀況。光是在黑暗中搜索就很困難了，更何況敵人就在這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00339",
		linknext = "0088_00341",
		line = 4726,
	},
	["0088_00341"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=3, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2027", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's right. Plus, Fumino's been escaping and hiding all by herself for so long, I'm sure she'll be fine for just a little longer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯。文乃酱到现在为止一直在逃跑所以捉迷藏肯定很厉害的，一定没问题啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯。文乃醬到現在為止一直在逃跑所以捉迷藏肯定很厲害的，一定沒問題啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00340",
		linknext = "0088_00342",
		line = 4740,
	},
	["0088_00342"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks, guys...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大家……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大家……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00341",
		linknext = "0088_00343",
		line = 4752,
	},
	["0088_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Losing Fumino here was heartbreaking, but their comments give me life again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"快要挫败的内心，听了同伴的话后逐渐再生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"快要挫敗的內心，聽了同伴的話後逐漸再生。",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00342",
		linknext = "0088_00344",
		line = 4762,
	},
	["0088_00344"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right. Let's assume Fumino will escape, and once we get home, we can come up with a plan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好——我知道了。就赌他们抓不到文乃的可能性吧。回去之后马上考虑下一个方案。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好——我知道了。就賭他們抓不到文乃的可能性吧。回去之後馬上考慮下一個方案。」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00343",
		linknext = "0088_00345",
		line = 4774,
	},
	["0088_00345"] = {
		{"cgact", file="cgact", id=2, act="stopact", lv=5, x=-5, y=-5},
