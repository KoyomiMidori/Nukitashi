					"“How so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么奇怪？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼奇怪？」",
