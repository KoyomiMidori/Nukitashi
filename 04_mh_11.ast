		linknext = "0088_00368",
		line = 5084,
	},
	["0088_00368"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's up?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00367",
		linknext = "0088_00369",
		line = 5096,
	},
	["0088_00369"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1403", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The SS, the OSS, and those yaks all seem to be at an impasse. Judging from their movements, it looks like they've been unable to secure Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“FS和SHO……还有黑社会他们好像进入了胶着……从他们的动向看来，好像没能找到文乃……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「FS和SHO……還有黑社會他們好像進入了膠著……從他們的動向看來，好像沒能找到文乃……」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00368",
		linknext = "0088_00370",
		line = 5108,
	},
	["0088_00370"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? Looks like we've got our opening, then. We just need to figure out how to make the most of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗……看来我们也还有机会。为了抢先一步，得考虑作战方案——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎……看來我們也還有機會。為了搶先一步，得考慮作戰方案——」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00369",
		linknext = "0088_00371",
		line = 5120,
	},
	["0088_00371"] = {
