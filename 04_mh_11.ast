	},
	["0088_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's standing next to another girl. Given how well they go together, I'm guessing she's her little sister.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她旁边有个长得一模一样的少女——是妹妹吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"她旁邊有個長得一模一樣的少女——是妹妹嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00175",
		linknext = "0088_00177",
		line = 2446,
	},
	["0088_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The main thing we need now is intel. I assume the SS already know where Fumino is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"首先我需要信息。如果是FS的话，或许已经掌握了文乃的行踪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"首先我需要資訊。如果是FS的話，或許已經掌握了文乃的行踪。",
					{"rt2"},
				},
			},
		},
