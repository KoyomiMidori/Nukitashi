				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes, I've been trying to learn lately. Even if it doesn't turn out well, you won't need to worry about how clean the rice is!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的，最近开始学习做菜了……万一不合口味就都由我来解决，所以不用担心！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的，最近開始學習做菜了……萬一不合口味就都由我來解決，所以不用擔心！」",
