					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aceptan la ley súperpervertida y viven sus mejores vidas bajo ella. Mientras tanto, aquí estoy yo tratando de destruirla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们接受了变态条例，讴歌这里的生活，而我则试图破坏掉这些事物。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們接受了變態條例，謳歌這裡的生活，而我則試圖破壞掉這些事物。",
					{"rt2"},
				},
			},
