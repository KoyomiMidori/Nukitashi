				{"vo", file="asane1104", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah... She put me in my bed after I basically cried myself to sleep. She's been here watching over you ever since.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……然后她哄着哭累的我去睡觉后……就一直在这里照看哥哥……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……然後她哄著哭累的我去睡覺後……就一直在這裡照顧哥哥……」",
					{"rt2"},
				},
			},
		},
