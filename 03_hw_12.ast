	},
	["0062_00341"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo vine a divertirme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我来这里明明纯粹是为了享受——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我來這裡明明純粹是為了享受——」",
