	["0062_00348"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=-100, y=0},
		{"fgact", ch="仁浦", id=10, act="移動", x=100, y=0, time=700},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eres... el gobernador Hitoura?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是——仁浦县知事……？”",
