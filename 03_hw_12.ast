	["0062_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was out for a while. No wonder I'm feeling better.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我好像睡了很久。怪不得能恢复到这种状态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我好像睡了很久。怪不得能恢復到這種狀態。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00059",
		linknext = "0062_00061",
		line = 769,
	},
	["0062_00061"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shouldn't you two be at school now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来……你们俩学校呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來……你們倆學校呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00060",
		linknext = "0062_00062",
		line = 781,
	},
	["0062_00062"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1254", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ehehe... I took the day off. I couldn't just go off and leave Tachibana-kun and Asane-chan here by yourselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……我请假了。因为放心不下橘君和麻沙音酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……我請假了。因為放心不下橘君和麻沙音醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00061",
		linknext = "0062_00063",
		line = 795,
	},
	["0062_00063"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00062",
		linknext = "0062_00064",
		line = 807,
	},
	["0062_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess there's no way around it. I probably would've done the same.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也没有办法。就算立场交换，我也会做同样的事情吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也沒有辦法。就算立場交換，我也會做同樣的事情吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00063",
		linknext = "0062_00065",
		line = 817,
	},
	["0062_00065"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa-chan? You ever plan on letting go?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说，麻沙酱打算黏着哥哥到什么时候？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說，麻沙醬打算黏著哥哥到什麼時候？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00064",
		linknext = "0062_00066",
		line = 829,
	},
	["0062_00066"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="asane_02l_00007", file1="asane_02l_00122", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1106", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Shut up and headpat me while I hold on to you and don't make me worry like that anymore, or I will cry so loud it'll make everyone in the neighborhood start gossiping about us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啰嗦……在我抱着你的这段时间你要一直摸摸我的头……只要让我稍微不安我就哭到让你被附近的人指指点点的程度……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「囉嗦……在我抱著你的這段時間你要一直摸摸我的頭……只要讓我稍微不安我就哭到讓你被附近的人指指點點的程度……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00065",
		linknext = "0062_00067",
		line = 844,
	},
	["0062_00067"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're so hopeless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是个没办法的孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是個沒辦法的孩子。」",
					{"rt2"},
				},
			},
		},
