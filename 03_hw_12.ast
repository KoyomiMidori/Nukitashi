					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿Cómo sabes mi nombre?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……为什么知道我的名字。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……為什麼知道我的名字。」",
