	["0062_00220"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00109", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0174", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡¿Qué?! ¡¿Por qué me miras con asco?! ¡¿Quién responde así?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“诶！？为、为什么要生气呢！？诶诶……好可怕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「欸！？為、為什麼要生氣呢！？欸欸……好可怕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00219",
		linknext = "0062_00221",
		line = 2753,
	},
	["0062_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
