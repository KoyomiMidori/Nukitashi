					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……礼前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……禮前輩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00316",
		linknext = "0062_00318",
		line = 3989,
	},
	["0062_00318"] = {
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=5, time=600, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0618", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Zzz... zzz...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呼……呼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呼……呼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00317",
		linknext = "0062_00319",
		line = 4002,
	},
	["0062_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She fell asleep?",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像睡着了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像睡著了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00318",
		linknext = "0062_00320",
		line = 4012,
	},
	["0062_00320"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Damn it. Typical drunk trope, passing out out mid-conversation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说着说着就睡着了，真是典型的醉鬼呢，还是该说像闹别扭的孩子呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"說著說著就睡著了，真是典型的醉鬼呢，還是該說像鬧彆扭的孩子呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00319",
		linknext = "0062_00321",
		line = 4022,
	},
	["0062_00321"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0597", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh my, what a treat. I've never seen her let her guard down like this before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀……真是少见啊。我还是第一次看到礼如此毫无防备。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀……真是少見啊。我還是第一次看到禮如此毫無防備。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00320",
		linknext = "0062_00322",
		line = 4037,
	},
	["0062_00322"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Student Council President... Well, that's the alcohol talking for her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“学生会长……嗯，大概是受到酒精的影响吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「學生會長……嗯，大概是受到酒精的影響吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00321",
		linknext = "0062_00323",
		line = 4049,
	},
	["0062_00323"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0598", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, even drunk she wouldn't normally cry on someone like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不——即便如此，礼也不会像这样向谁哭诉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不——即便如此，禮也不會像這樣向誰哭訴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00322",
		linknext = "0062_00324",
		line = 4063,
	},
	["0062_00324"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是、这样吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是、這樣嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00323",
		linknext = "0062_00325",
		line = 4075,
	},
	["0062_00325"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0599", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“She must really trust you, Senpai... Hehe, to think our little impotence quota would make the mighty disciplinary committee president end up like this. Senpai is an intriguing person...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“一定是对前辈打开了心房吧……呵呵，礼竟然会变成这样……前辈真是个有意思的人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「一定是對前輩打開了心房吧……呵呵，禮竟然會變成這樣……前輩真是個有意思的人啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00324",
		linknext = "0062_00326",
		line = 4089,
	},
	["0062_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's not that big a deal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么……没什么大不了的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼……沒什麼大不了的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00325",
		linknext = "0062_00327",
		line = 4100,
	},
	["0062_00327"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0600", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei's got some emotional baggage from her past. So.. Senpai could you please help her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——礼从很久以前就一直感到寂寞，所以……请前辈帮帮她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——禮從很久以前就一直感到寂寞，所以……請前輩幫幫她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00326",
		linknext = "0062_00328",
		line = 4114,
	},
	["0062_00328"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm at a loss for words at her unexpected plea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然被这么一说，我语塞了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然被這麼一說，我語塞了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00327",
		linknext = "0062_00329",
		line = 4124,
	},
	["0062_00329"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She really admires you. I think you're much more qualified to do that then I'll ever be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那样的话，学生会长应该更合适吧？礼前辈不是崇拜你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那樣的話，學生會長應該更合適吧？禮前輩不是崇拜你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00328",
		linknext = "0062_00330",
		line = 4136,
	},
	["0062_00330"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she shakes her head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，学生会长却摇了摇头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，學生會長卻搖了搖頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00329",
		linknext = "0062_00331",
		line = 4148,
	},
	["0062_00331"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0601", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, no, I couldn't do that. Our circumstances are too similar, I think.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我一定做不到的。因为我们都遇到了同样的处境……却选错了前进的方向。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我一定做不到的。因為我們都遇到了同樣的處境……卻選錯了前進的方向。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00330",
		linknext = "0062_00332",
		line = 4160,
	},
	["0062_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't know what she means. What I do know is that it doesn't seem like a place where it would be appropriate to pry.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不明白这句话的意思——但轻率地询问似乎不是好事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不明白這句話的意思——但輕率地詢問似乎不是好事。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00331",
		linknext = "0062_00333",
		line = 4170,
	},
	["0062_00333"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0602", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Please, Senpai, could you be there for her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以，前辈……请你陪在礼的身边好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以，前輩……請你陪在禮的身邊好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00332",
		linknext = "0062_00334",
		line = 4184,
	},
	["0062_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That smile has emotions behind it that I can't make out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那笑容背后有着怎样的情感——我完全无法读懂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那笑容背後有著怎樣的情感——我完全無法讀懂。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00333",
		linknext = "0062_00335",
		line = 4194,
	},
	["0062_00335"] = {
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
		{"fg", file="rei_01l_00006", file1="rei_01l_00115", file2="rei_01l_00201", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei-senpai is propped up against me, sleeping peacefully.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈就像将我当成容身之处般，发出健康的鼾声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩就像將我當成容身之處般，發出健康的鼾聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00334",
		linknext = "0062_00336",
		line = 4207,
	},
	["0062_00336"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I notice something gripped tightly in her slender hands.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我发现那只纤细的手正紧紧地握着什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我發現那隻纖細的手正緊緊地握著什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00335",
		linknext = "0062_00337",
		line = 4217,
	},
	["0062_00337"] = {
		{"fg", file="rei_01l_00006", file1="rei_01l_00115", file2="rei_01l_00201", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, style="blur", blurx=11, blury=11, time=300, mode=3, x=0, y=0},
		{"bg", id=18, file="strap_00003", x=0, y=200, path=":cg/strap/", ev=1, time=500, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=18, act="移動", x=-5, y=-105, time=700, lv=5},
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
