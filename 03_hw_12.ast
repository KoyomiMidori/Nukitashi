				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来是这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來是這樣啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00024",
		linknext = "0062_00026",
		line = 306,
	},
	["0062_00026"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00108", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1104", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí... Me acostó en mi cama después de que me quedara dormida llorando. Ha estado aquí cuidándote desde entonces.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……然后她哄着哭累的我去睡觉后……就一直在这里照看哥哥……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……然後她哄著哭累的我去睡覺後……就一直在這裡照顧哥哥……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00025",
		linknext = "0062_00027",
		line = 321,
	},
	["0062_00027"] = {
