	["0062_00377"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gobernador, ¿qué opina de la ley súperpervertida?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事——对于变态条例，你是怎么想的呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事——對於變態條例，你是怎麼想的呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00376",
		linknext = "0062_00378",
		line = 4730,
	},
	["0062_00378"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin pensarlo dos veces, le pregunto.",
					{"rt2"},
				},
