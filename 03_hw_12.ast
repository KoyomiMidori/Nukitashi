					name = {"礼", "Rei"},
					"“Sí, lo sé. En fin, mientras te sientas mejor, está bien.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……说的也是。嗯，如果没有什么特别的问题就好了。”",
