			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¿Cómo voy a creer eso cuando tienen esas correas a juego? ¿Para qué otra cosa las tendrías?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“怎、怎么可能……平板上不是都挂着同样的挂件吗！这就是无法动摇的证据！”",
