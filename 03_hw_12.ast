					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呃……好了好了……反正我就适合一个人玩游戏然后被打得七零八落的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呃……好了好了……反正我就適合一個人玩遊戲然後被打得七零八落的……」",
					{"rt2"},
				},
			},
		},
