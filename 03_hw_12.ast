	["0062_00297"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cálmate, ¿vale? Wata-chan ni siquiera está aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“冷静……渡酱不在这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「冷靜……渡醬不在這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00296",
		linknext = "0062_00298",
		line = 3726,
	},
	["0062_00298"] = {
		{"fg", file="rei_01m_00006", file1="rei_01m_00124", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0610", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿En serio? ¿Está en tu casa? Han pasado tanto tiempo juntos... ahh... ¿No puedo unirme yo también?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么……那在橘那里吗？你们最近经常在一起啊……呜呜……只有我……被排挤吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼……那在橘那裡嗎？你們最近經常在一起啊……嗚嗚……只有我……被排擠嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00297",
		linknext = "0062_00299",
		line = 3740,
	},
	["0062_00299"] = {
