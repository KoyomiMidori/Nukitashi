					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, sí... l-lo siento. Cuando despertaste, me sentí tan aliviada que me mareé un poco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，嗯……对、对不起。看到橘君起来了，我一放心，就突然头晕了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，嗯……對、對不起。看到橘君起來了，我一放心，就突然頭暈了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00038",
		linknext = "0062_00040",
		line = 493,
	},
	["0062_00040"] = {
		{"fg", file="asane_01f_00007", file1="asane_01f_00106", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1105", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No has dormido nada, ¿verdad? Deberías irte a casa y acostarte.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“渡酱……你几乎没睡吧……还是稍微睡一下比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「渡醬……你幾乎沒睡吧……還是稍微睡一下比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00039",
		linknext = "0062_00041",
		line = 506,
	},
	["0062_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Se quedó despierta conmigo todo este tiempo?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是吗，因为一直在照顾我——",
					{"rt2"},
				},
			},
			tw = {
				{
					"是嗎，因為一直在照顧我——",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00040",
		linknext = "0062_00042",
		line = 516,
	},
	["0062_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y pensar que justo hoy pasó por esa terrible experiencia con el afrodisíaco. Debe estar agotada, tanto física como mentalmente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明渡酱自己昨天也吃了媚药做了那种事，身心都应该很疲惫的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明渡醬自己昨天也吃了媚藥做了那種事，身心都應該很疲憊的。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00041",
		linknext = "0062_00043",
		line = 526,
	},
	["0062_00043"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Muchas gracias. No solo por mí, sino también por cuidar a Asa-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的非常感谢你……为了我和麻沙酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的非常感謝你……為了我和麻沙醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00042",
		linknext = "0062_00044",
		line = 538,
	},
	["0062_00044"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1249", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tranquilo. ¡Solo estoy cumpliendo con mi deber como senpai!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，没事没事……我只是做了作为前辈该做的事而已啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不，沒事沒事……我只是做了作為前輩該做的事而已啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00043",
		linknext = "0062_00045",
		line = 552,
	},
	["0062_00045"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Infla su pecho inexistente y lo golpea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她把没有的胸挺起来拍了拍。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她把沒有的胸挺起來拍了拍。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00044",
		linknext = "0062_00046",
		line = 563,
	},
	["0062_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su personalidad siempre alegre me ayuda a calmarme.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和往常一样，开朗活泼的举止让我的心平静了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和往常一樣，開朗活潑的舉止讓我的心平靜了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00045",
		linknext = "0062_00047",
		line = 573,
	},
	["0062_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A estas alturas ya debería estar acostumbrado, pero me sigue sorprendiendo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的这些话或许说起来很简单，但却不是那么容易做到的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的這些話或許說起來很簡單，但卻不是那麼容易做到的。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00046",
		linknext = "0062_00048",
		line = 583,
	},
	["0062_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No soy rival para ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说实话，我头都抬不起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說實話，我頭都抬不起來。",
