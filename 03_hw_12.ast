					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hehe... wh-what the hell is that? Hahaha, who the hell approaches a buffet like that? Have you never done this before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呵呵……那个盘子是怎么回事……哈哈，我还是第一次看到。橘，你不是没有自助餐的才能？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呵呵……那個盤子是怎麼回事……哈哈，我還是第一次看到。橘，你不是沒有自助餐的才能？」",
					{"rt2"},
				},
			},
