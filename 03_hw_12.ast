					{"rt2"},
				},
			},
			en = {
				{
					"I can tell she wants to say more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其实，渡酱应该有其他想说的话吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其實，渡醬應該有其他想說的話吧。",
