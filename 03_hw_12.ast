		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So far so good. You know that my durability is my only redeeming quality.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到目前为止没什么变化……你应该知道吧？说到我的优点就只有身体结实而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到目前為止沒什麼變化……你應該知道吧？說到我的優點就只有身體結實而已。」",
					{"rt2"},
				},
