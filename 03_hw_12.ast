		},
		linkback = "0062_00185",
		linknext = "0062_00187",
		line = 2307,
	},
	["0062_00187"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nom...? Gulp... Commander Onabuta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嚼嚼……？嚼嚼……女部田中队长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嚼嚼……？嚼嚼……女部田中隊長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00186",
		linknext = "0062_00188",
		line = 2319,
	},
	["0062_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It doesn't matter, but whenever I see her name written down I'm tempted to read it as Commander One-butt.",
					{"rt2"},
				},
			},
			cn = {
				{
					"话说女部田中队长这个词，怎么想都觉得很像田中队长呢……",
					{"rt2"},
				},
			},
			tw = {
				{
					"話說女部田中隊長這個詞，怎麼想都覺得很像田中隊長呢……",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00187",
		linknext = "0062_00189",
		line = 2329,
	},
	["0062_00189"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0120", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hey there, Rookie ♪ Don't you get tired of being so stuffy all the time? We're the same age, so don't I keep telling you to call me Ikuko?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗨——新人君〜♪我们是同龄，所以叫我郁子就好了。我不是一直都这么说嘛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗨——新人君〜♪我們是同齡，所以叫我郁子就好了。我不是一直都這麼說嘛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00188",
		linknext = "0062_00190",
		line = 2343,
	},
	["0062_00190"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, but you're a company commander and I'm just a cadet. Gotta respect your authority and all that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……因为是训练生和中队长，所以我必须要坚守自己的立场。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……因為是訓練生和中隊長，所以我必須要堅守自己的立場。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00189",
		linknext = "0062_00191",
		line = 2355,
	},
	["0062_00191"] = {
		{"text"},
		delay = {
			[6500] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00105", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0121", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hehe, aren't you and Rei-chan just two peas in a pod? You call yourself 'just a cadet', but you were instrumental in rescuing the governor. Plus you don't even know how to eat at a buffet...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵，跟礼酱一个样呢。虽然说是训练生，但昨天表现得很出色吧？不过……虽然好像没有自助餐的才能……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵，跟禮醬一個樣呢。雖然說是訓練生，但昨天表現得很出色吧？不過……雖然好像沒有自助餐的才能……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00190",
		linknext = "0062_00192",
		line = 2369,
	},
	["0062_00192"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why does everyone care so much about how I eat at a buffet? It all goes to the same place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“自助餐不是随便就好吗……只要往肚子里装就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「自助餐不是隨便就好嗎……只要往肚子裡裝就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00191",
		linknext = "0062_00193",
		line = 2381,
	},
	["0062_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Besides, yesterday was mostly Rei-senpai. Really, I was just holding her back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且，昨天的事几乎是礼前辈的功劳。倒不如说我还拖了她的后腿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且，昨天的事幾乎是禮前輩的功勞。倒不如說我還拖了她的後腿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00192",
		linknext = "0062_00194",
		line = 2393,
	},
	["0062_00194"] = {
