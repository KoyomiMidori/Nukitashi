			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“E-Espera, ¿manito...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
