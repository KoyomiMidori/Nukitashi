			},
		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I think about it, Rei-senpai's been periodically glancing over here for a while now. She looks uncomfortable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"话说回来，刚才礼前辈就一直盯着这边看。",
					{"rt2"},
				},
			},
			tw = {
				{
					"話說回來，剛才禮前輩就一直盯著這邊看。",
