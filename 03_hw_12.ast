	["0062_00080"] = {
		{"bg", id=18, file="messageline_00001", x=0, y=0, path=":cg/messageline/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"“Buenos días, Tachibana-kun. ¿Cómo te sientes? Vi que no fuiste hoy. ¿Ya te sienes bien? Por favor, avísame si te sientes mal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"“橘君，你好。身体怎么样了？你好像跟学校请假了，那之后还有什么问题吗？只要状况有点不对劲，都请联系我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					"「橘君，你好。身體怎麼樣了？你好像跟學校請假了，那之後還有什麼問題嗎？只要有什麼不對勁，就請聯繫我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00079",
		linknext = "0062_00081",
		line = 1011,
	},
	["0062_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"“Hay una recompensa esperándote por el incidente de ayer, así que hemos decidido que la SS celebrará una fiesta esta noche.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"“昨天的事情有奖励金，所以今晚FS要办个小小的庆功宴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					"「昨天的事情有獎勵金，所以今晚FS要辦個小小的慶功宴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00080",
		linknext = "0062_00082",
		line = 1021,
	},
	["0062_00082"] = {
