					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“诶！？为、为什么要生气呢！？诶诶……好可怕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「欸！？為、為什麼要生氣呢！？欸欸……好可怕……」",
