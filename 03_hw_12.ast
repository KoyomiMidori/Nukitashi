					name = {"郁子", "Ikuko"},
					"“Ahaha! Of course it does!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊哈哈！你做说什么啊，那不是当然的吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
