			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Aun así, supongo que lo hiciste porque querías. Rei-chan me contó lo que pasó. Te esforzaste mucho, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是……即使逞强，你也有想完成的事情对吧。我听礼酱说了，橘君很努力呢……真了不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是……即使逞強，你也有想完成的事情對吧。我聽禮醬說了，橘君很努力呢……真了不起。」",
					{"rt2"},
				},
			},
		},
