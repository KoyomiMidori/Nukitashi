		linkback = "0062_00347",
		linknext = "0062_00349",
		line = 4396,
	},
	["0062_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es el responsable de establecer la ley súperpervertida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是制定变态条例的罪魁祸首。",
