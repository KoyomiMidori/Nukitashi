				},
			},
			en = {
				{
					"She looks conflicted at that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被这么说的麻沙酱，露出了复杂的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被這麼說的麻沙醬，露出了複雜的表情。",
