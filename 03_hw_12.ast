					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn, I didn't know she could do that kind of trick, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“学生会长连那种魔术也会啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「學生會長連那種魔術也會啊……」",
					{"rt2"},
