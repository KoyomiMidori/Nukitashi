	["0062_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por alguna razón, me entusiasmó mucho la idea de convertirme en un miembro oficial de la SS.",
					{"rt2"},
