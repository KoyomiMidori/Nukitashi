		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0123", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hey, is it really true that you can't get it up? If you want, I'm sure I could it a go. Come on, let's try!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我说，真的勃起不了吗？郁如果认真的话，可是有能让鸡巴心情舒畅地勃起的自信呢……要不要来试一次？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我說，真的勃起不了嗎？郁如果認真的話，可是有能讓肉棒心情舒暢地勃起的自信呢……要不要來試一次？」",
					{"rt2"},
