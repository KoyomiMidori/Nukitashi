			},
			tw = {
				{
					"沒想到，那位禮前輩——",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00100",
		linknext = "0062_00102",
		line = 1268,
	},
	["0062_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Takes all kinds of people, huh?",
					{"rt2"},
				},
			},
			cn = {
				{
					"竟然会是这么做作的角色……",
					{"rt2"},
				},
			},
			tw = {
				{
					"竟然會是這麼做作的角色……",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00101",
		linknext = "0062_00103",
		line = 1278,
	},
	["0062_00103"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="asane_02m_00007", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1109", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“She also missed a word here. She wrote 'I would pleased' instead of 'I would be pleased'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“话说，这句‘你能来我很开心’的地方……漏了个‘会’变成了‘我很开心’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「話說，這句『你能來我很開心』的地方……漏了個『會』變成了『我很開心』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00102",
		linknext = "0062_00104",
		line = 1293,
	},
	["0062_00104"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, you're right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……的确。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……的確。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00103",
		linknext = "0062_00105",
		line = 1305,
	},
	["0062_00105"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1110", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, yes, I've seen this many times before. You start out writing one thing, then change one of the words but don't change any of the ones around it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这是那个啊……麻沙酱懂了……是把最一开始的表现方式改成‘会很开心’之后多删了字……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這是那個啊……麻沙醬懂了……是把最一開始的表現方式改成『會很開心』之後多刪了字……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00104",
		linknext = "0062_00106",
		line = 1319,
	},
	["0062_00106"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So sly!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太做作了———！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太做作了———！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00105",
		linknext = "0062_00107",
		line = 1331,
	},
	["0062_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So she changed it from something to “I would pleased”? What the hell did she originally have?",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然特意又换成了“会很开心”？一开始到底写了什么啊？",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然特意又換成了「會很開心」？一開始到底寫了什麼啊？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00106",
		linknext = "0062_00108",
		line = 1341,
	},
	["0062_00108"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can't believe this...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶，开什么玩笑——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡，開什麼玩笑——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00107",
		linknext = "0062_00109",
		line = 1353,
	},
	["0062_00109"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00105", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1111", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What are you so angry about? You gonna go or not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然不太懂你为什么要生气……怎么办，要去吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然不太懂你為什麼要生氣……怎麼辦，要去嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00108",
		linknext = "0062_00110",
		line = 1367,
	},
	["0062_00110"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Go...? Oh, to the SS party.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……啊，也对……SS的庆功宴是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……啊，也對……SS的慶功宴是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00109",
		linknext = "0062_00111",
		line = 1379,
	},
	["0062_00111"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1259", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You might as well, right? After what you went through, Tachibana-kun's earned it! I think it would make Rei-chan happy, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“去看看吧？毕竟橘君都这么努力了，要去拿些奖励才行！而且礼酱也很高兴啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「去看看吧？畢竟橘君都這麼努力了，要去拿些獎勵才行！而且禮醬也很高興啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00110",
		linknext = "0062_00112",
		line = 1393,
	},
	["0062_00112"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess. I'm feeling all right after sleeping, too... Yeah, I should go.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，也对。睡眠也足了身体也不错……去看看吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，也對。睡眠也足了身體也不錯……去看看吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00111",
		linknext = "0062_00113",
		line = 1405,
	},
	["0062_00113"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wonder if they're planning on promoting me to a full member of the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说不定……可能会被升级为SS的正式成员哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說不定……可能會被升級為SS的正式成員哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00112",
		linknext = "0062_00114",
		line = 1418,
	},
	["0062_00114"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="asane_02m_00007", file1="asane_02m_00112", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"ex", time=500, func="wait"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What's that look? I was just a cadet, but I was instrumental in rescuing the governor. They really might.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你那什么表情……一个小小的训练生可是救出了县知事取得了大战果哦？也不是不可能吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你那什麼表情……一個小小的訓練生可是救出了縣知事取得了大戰果哦？也不是不可能吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00113",
		linknext = "0062_00115",
		line = 1435,
	},
	["0062_00115"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If that happens, I'll get the scholarship.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果成为正式成员的话还可以得到奖学金。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果成為正式成員的話還可以得到獎學金。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00114",
		linknext = "0062_00116",
		line = 1447,
	},
	["0062_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wouldn't that be great? We could have actual income, as opposed to just scraping by while paying off the insurance and the loan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这不是非常好吗？这样就可以跟用保险和存款过日子的生活告别了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這不是非常好嗎？這樣就可以跟用保險和存款過日子的生活告別了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00115",
		linknext = "0062_00117",
		line = 1458,
	},
	["0062_00117"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1112", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Uh, hey, Bro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“等、等一下……哥哥……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「等、等一下……哥哥……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00116",
		linknext = "0062_00118",
		line = 1472,
	},
	["0062_00118"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? Oh, right. I don't actually know how much money the scholarship is worth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么？不过，的确是还不知道能拿多少奖学金——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼？不過，的確是還不知道能拿多少獎學金——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00117",
		linknext = "0062_00119",
		line = 1484,
	},
	["0062_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's gotta be a decent chunk after all that training, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是都训练成这样了，金额可不能只有小孩子的零花钱程度吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是都訓練成這樣了，金額可不能只有小孩子的零用錢程度吧？」",
					{"rt2"},
				},
