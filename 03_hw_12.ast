	["0062_00315"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me está lloriqueando como una niña malcriada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"终于变成了闹别扭的孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"終於變成了鬧彆扭的孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00314",
		linknext = "0062_00316",
		line = 3962,
	},
	["0062_00316"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“S-Sí, no te preocupes. No voy a morir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不、不用那么担心我，我不会死的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不、不用那麼擔心我，我不會死的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00315",
		linknext = "0062_00317",
		line = 3974,
	},
	["0062_00317"] = {
		{"fg", file="rei_01l_00006", file1="rei_01l_00115", file2="rei_01l_00203", path=":fg/rei_01l/", id=9, lv=5, head="rei_01l", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"ex", time=500, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Rei-senpai...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
