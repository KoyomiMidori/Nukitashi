			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah... uuu... Anoche, el comité de moral pública y la SS te trajeron de vuelta... uuu... Al principio parecías estar bien...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……唔……昨天晚上，有个叫什么风纪委员长的FS，带着哥哥回来……唔……哥哥，最初看起来是没事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……唔……昨天晚上，有個叫什麼風紀委員長的FS，帶著哥哥回來……唔……哥哥，最初看起來是沒事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00020",
		linknext = "0062_00022",
		line = 260,
	},
	["0062_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1102", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Después de eso, ya no podías ni estar de pie... Dijiste que ibas a dormir y regresaste a tu habitación... y te caíste en la cama.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是，你渐渐开始摇摇晃晃起来……说着想睡了，准备回房间的时候……就在床前倒下了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是，你漸漸開始搖搖晃晃起來……說著想睡了，準備回房間的時候……就在床前倒下了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00021",
		linknext = "0062_00023",
		line = 272,
	},
	["0062_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No lo recuerdo del todo, pero tengo una vaga idea de lo que sucedió cuando regresé aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"完全不记得——但模糊地感觉到好像有过这些事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"完全不記得——但模糊地感覺到好像有過這些事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00022",
		linknext = "0062_00024",
		line = 282,
	},
	["0062_00024"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1103", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Te acostamos, pero no pudimos despertarte... Uuu... Yo estaba aquí llorando, así que Wata-chan dijo que se quedaría... uuu...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我想办法让你躺到了床上，可是你一直都不起来……唔……然后我哭个不停，渡酱就说她也要陪你……诶唔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我想辦法讓你躺到了床上，可是你一直都不起來……唔……然後我哭個不停，渡醬就說她也要陪你……欸唔……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00023",
		linknext = "0062_00025",
		line = 294,
	},
	["0062_00025"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
