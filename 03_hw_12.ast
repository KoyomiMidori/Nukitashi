	["0062_00199"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0166", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“No! Whenever you say that, you always keep going until they're dry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“不行！你总是这么说着，然后把人家榨干！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「不行！你總是這麼說著，然後把人家榨乾！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00198",
		linknext = "0062_00200",
		line = 2478,
	},
	["0062_00200"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00112", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0125", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hey now, aren't you the one who's always spewing all that bullshit about ejaculation regulation before going and making them cum buckets?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“噗——兰酱还不是一样，一直说什么射精管理，结果总是让人家发射！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「噗——蘭醬還不是一樣，一直說什麼射精管理，結果總是讓人家發射！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00199",
		linknext = "0062_00201",
		line = 2492,
	},
	["0062_00201"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00123", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0167", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Th-That's got nothing to do with this! I edge them sometimes, too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“一、一事归一事！我偶尔也能在射精之前停下来的……”",
					{"rt2"},
