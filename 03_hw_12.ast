					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, pero no te excedas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但还是不要太勉强的好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但還是不要太勉強的好……」",
