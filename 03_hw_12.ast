		linkback = "0062_00340",
		linknext = "0062_00342",
		line = 4315,
	},
	["0062_00342"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde que me uní a la SS, no he podido relajarme.",
