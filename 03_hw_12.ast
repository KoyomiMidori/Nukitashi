	},
	["0062_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Se durmió?",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像睡着了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像睡著了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00318",
		linknext = "0062_00320",
		line = 4012,
	},
	["0062_00320"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maldita sea. Es la típica borracha que se apaga en plena conversación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说着说着就睡着了，真是典型的醉鬼呢，还是该说像闹别扭的孩子呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"說著說著就睡著了，真是典型的醉鬼呢，還是該說像鬧彆扭的孩子呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00319",
		linknext = "0062_00321",
		line = 4022,
	},
	["0062_00321"] = {
		{"fg", mode=-1, id=9, ch="礼", lv=5, time=300},
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0597", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Vaya... Qué sorpresa. Nunca la había visto tan relajada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀……真是少见啊。我还是第一次看到礼如此毫无防备。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀……真是少見啊。我還是第一次看到禮如此毫無防備。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00320",
		linknext = "0062_00322",
		line = 4037,
	},
	["0062_00322"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Presidenta del consejo... Bueno, es el alcohol.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“学生会长……嗯，大概是受到酒精的影响吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「學生會長……嗯，大概是受到酒精的影響吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00321",
		linknext = "0062_00323",
		line = 4049,
	},
	["0062_00323"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0598", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, ella no llora así cuando está borracha.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不——即便如此，礼也不会像这样向谁哭诉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不——即便如此，禮也不會像這樣向誰哭訴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00322",
		linknext = "0062_00324",
		line = 4063,
	},
	["0062_00324"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是、这样吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是、這樣嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00323",
		linknext = "0062_00325",
		line = 4075,
	},
	["0062_00325"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0599", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Debe confiar mucho en ti... Jeje, pensar que nuestra pequeña cuota de impotencia haría que la presidenta del comité del moral pública se sentiría así. ¿No te parece que eres fascinante?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“一定是对前辈打开了心房吧……呵呵，礼竟然会变成这样……前辈真是个有意思的人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「一定是對前輩打開了心房吧……呵呵，禮竟然會變成這樣……前輩真是個有意思的人啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00324",
		linknext = "0062_00326",
		line = 4089,
	},
	["0062_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No es para tanto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么……没什么大不了的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼……沒什麼大不了的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00325",
		linknext = "0062_00327",
		line = 4100,
	},
	["0062_00327"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00101", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0600", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei carga con algunos problemas emocionales. ¿Podrías ayudarla, por favor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——礼从很久以前就一直感到寂寞，所以……请前辈帮帮她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——禮從很久以前就一直感到寂寞，所以……請前輩幫幫她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00326",
		linknext = "0062_00328",
		line = 4114,
	},
	["0062_00328"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me quedo sin palabras ante su inesperada súplica.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然被这么一说，我语塞了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然被這麼一說，我語塞了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00327",
		linknext = "0062_00329",
		line = 4124,
	},
	["0062_00329"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Te admira mucho. Creo que tienes la capacidad de hacer eso, yo no.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那样的话，学生会长应该更合适吧？礼前辈不是崇拜你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那樣的話，學生會長應該更合適吧？禮前輩不是崇拜你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00328",
		linknext = "0062_00330",
		line = 4136,
	},
	["0062_00330"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00114", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero niega con la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，学生会长却摇了摇头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，學生會長卻搖了搖頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00329",
		linknext = "0062_00331",
		line = 4148,
	},
	["0062_00331"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0601", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Creeme que no. Siento que nuestras circunstancias... son muy parecidas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我一定做不到的。因为我们都遇到了同样的处境……却选错了前进的方向。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我一定做不到的。因為我們都遇到了同樣的處境……卻選錯了前進的方向。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00330",
		linknext = "0062_00332",
		line = 4160,
	},
	["0062_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No sé a qué se refiere. Lo que sí sé es que no debería ser imprudente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不明白这句话的意思——但轻率地询问似乎不是好事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不明白這句話的意思——但輕率地詢問似乎不是好事。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00331",
		linknext = "0062_00333",
		line = 4170,
	},
	["0062_00333"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0602", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Senpai, por favor... ¿Podrías estar a su lado?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以，前辈……请你陪在礼的身边好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以，前輩……請你陪在禮的身邊好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00332",
		linknext = "0062_00334",
		line = 4184,
	},
	["0062_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa sonrisa esconde emociones que no logro comprender.",
					{"rt2"},
				},
			},
			cn = {
				{
