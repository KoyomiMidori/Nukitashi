			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Como tal no. Puedes llevarte lo que quieras. Por cierto, ¿cómo está tu cabeza?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不是不行。你按自己喜欢的方式做就好了——对了，脑袋在那之后没问题吧？”",
					{"rt2"},
				},
			},
			tw = {
