		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Obviamente, la carne es lo más importante. Necesito carne para rellenarme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然……还是肉吧。必须要重点补充点肉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然……還是肉吧。必須要重點補充點肉……」",
