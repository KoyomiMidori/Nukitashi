	},
	["0062_00071"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00105", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
