		linkback = "0062_00222",
		linknext = "0062_00224",
		line = 2794,
	},
	["0062_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que está nerviosa por nuestra conversación. La verdad, lo que más me gustaría es aclarar cualquier malentendido cuanto antes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是在意我们的对话内容，但这种行为确实会加深误会，希望她能别这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是在意我們的對話內容，但這種行為確實會加深誤會，希望她能別這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00223",
		linknext = "0062_00225",
		line = 2804,
	},
	["0062_00225"] = {
