	["0062_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso, no he comido nada desde el almuerzo de ayer. Tengo mucha hambre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仔细想想，我从昨天午饭后就什么都没吃，现在完全处于饥饿状态。",
