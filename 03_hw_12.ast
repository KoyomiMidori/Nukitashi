					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Ah, de dónde vino esa paloma...?!”",
					{"rt2"},
				},
			},
			cn = {
