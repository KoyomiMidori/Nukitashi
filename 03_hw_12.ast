					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Por cierto, Tachibana-kun. Hace tiempo que me lo pregunto y nunca he tenido la oportunidad de preguntártelo, pero ¿cuándo empezaron a salir Rei-senpai y tú?”",
					{"rt2"},
