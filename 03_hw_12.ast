	["0062_00040"] = {
		{"fg", file="asane_01f_00007", file1="asane_01f_00106", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
