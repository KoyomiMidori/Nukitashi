			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You haven't slept a wink, have you? You should head home and get to bed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“渡酱……你几乎没睡吧……还是稍微睡一下比较好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「渡醬……你幾乎沒睡吧……還是稍微睡一下比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00039",
		linknext = "0062_00041",
		line = 506,
	},
	["0062_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So she was staying up with me this whole time?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是吗，因为一直在照顾我——",
					{"rt2"},
