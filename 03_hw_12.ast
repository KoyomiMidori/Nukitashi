	["0062_00347"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0001", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "???"},
					"“Ooh, you noticed my presence. It seems it wasn't just by luck that you saved me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦", "？ ？ ？"},
					"“哦……你注意到了吗？不愧是救了我的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦", "？？？"},
					"「哦……你注意到了嗎？不愧是救了我的男人。」",
					{"rt2"},
				},
			},
		},
