					name = {"麻沙音"},
					"「啊……唔……昨天晚上，有個叫什麼風紀委員長的SS，帶著哥哥回來……唔……哥哥，最初看起來是沒事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00020",
		linknext = "0062_00022",
		line = 260,
	},
	["0062_00022"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1102", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“After that, you got more and more unsteady on your feet... you said you were gonna sleep and went back to your room... then you collapsed on your bed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是，你渐渐开始摇摇晃晃起来……说着想睡了，准备回房间的时候……就在床前倒下了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是，你漸漸開始搖搖晃晃起來……說著想睡了，準備回房間的時候……就在床前倒下了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00021",
		linknext = "0062_00023",
		line = 272,
	},
	["0062_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't say I fully remember it, but I have a vague idea of what happened when I got back here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"完全不记得——但模糊地感觉到好像有过这些事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"完全不記得——但模糊地感覺到好像有過這些事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00022",
		linknext = "0062_00024",
		line = 282,
	},
	["0062_00024"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1103", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“We got you tucked in, but we couldn't wake you up... *sniffle*... I was here bawling my eyes out, so Wata-chan said she'd stick around... hic...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我想办法让你躺到了床上，可是你一直都不起来……唔……然后我哭个不停，渡酱就说她也要陪你……诶唔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我想辦法讓你躺到了床上，可是你一直都不起來……唔……然後我哭個不停，渡醬就說她也要陪你……欸唔……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00023",
		linknext = "0062_00025",
		line = 294,
	},
	["0062_00025"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
