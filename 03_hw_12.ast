	["0062_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's usually clingy, but this is above and beyond. She must've been freaking out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天比平常更撒娇了。想必是相当担心了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天比平常更撒嬌了。想必是相當擔心了吧。",
					{"rt2"},
				},
			},
