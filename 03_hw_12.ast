				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To think that just earlier today was that ordeal with the aphrodisiac. She must be super drained, both physically and mentally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明渡酱自己昨天也吃了媚药做了那种事，身心都应该很疲惫的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明渡醬自己昨天也吃了媚藥做了那種事，身心都應該很疲憊的。",
