	["0062_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Obviously meat is the most important thing. I need meat to refill the tank.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然……还是肉吧。必须要重点补充点肉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然……還是肉吧。必須要重點補充點肉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00166",
		linknext = "0062_00168",
		line = 2082,
	},
	["0062_00168"] = {
		{"text"},
		text = {
