				},
			},
			tw = {
				{
					"也就是制定變態條例的罪魁禍首。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00348",
		linknext = "0062_00350",
		line = 4406,
	},
	["0062_00350"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La fuente de la maldad que busco destruir en esta isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"创造出让我们反对这个岛的理由，的万恶根源。",
					{"rt2"},
				},
			},
			tw = {
				{
					"創造出讓我們反對這個島的理由，的萬惡根源。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00349",
		linknext = "0062_00351",
		line = 4416,
	},
	["0062_00351"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0002", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Buenas noches. No, quizá debería decir que es un placer conocerte, Tachibana Junnosuke-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“晚上好……不，应该说初次见面吧——橘淳之介君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「晚上好……不，應該說初次見面吧——橘淳之介君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00350",
		linknext = "0062_00352",
		line = 4428,
	},
	["0062_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
