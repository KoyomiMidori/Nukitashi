	},
	["0062_00198"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00116", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
