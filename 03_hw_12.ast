		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But, right now, my feelings are more complex than that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，现在我感觉到的是————",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，現在我感覺到的是————",
					{"rt2"},
				},
			},
		},
