		{"bgm", file="bgm02", vol=100},
		{"bg", id=1, file="bg23_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0595", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ahem... I would like to make a toast. As you are all aware, Hitoura-sama was involved in a dangerous incident the other day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“好——那么，虽然很冒昧，但请允许我起个头干杯。正如大家所知，前些日子仁浦大人遭遇了一场重大危机——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好——那麼，雖然很冒昧，但請允許我起個頭乾杯。正如大家所知，前些日子仁浦大人遭遇了一場重大危機——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00154",
		linknext = "0062_00156",
		line = 1936,
	},
	["0062_00156"] = {
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00102", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0118", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Come on, Rei-chan, loosen up a little! The only things that should be that stiff at a party should be cocks!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“礼酱太僵硬了啦！在这种喜庆的场合，变硬的只有小鸡鸡就够了哦〜？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「禮醬太僵硬了啦！在這種喜慶的場合，變硬的只有小雞雞就夠了哦〜？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00155",
		linknext = "0062_00157",
		line = 1949,
	},
