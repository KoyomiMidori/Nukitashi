		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Rei-senpai? Qué pasa...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈？怎么了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩？怎麼了——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00278",
		linknext = "0062_00280",
		line = 3496,
	},
	["0062_00280"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uwah... ¡Hueles a alcohol!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哇！一身酒臭……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哇！一身酒臭……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00279",
		linknext = "0062_00281",
		line = 3508,
	},
	["0062_00281"] = {
		{"fg", file="rei_01m_00006", file1="rei_01m_00106", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0605", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Se me nota? ¿Cómo puedes decir algo así? ¡Qué malo eres...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“臭……？你刚刚说我臭吗……好过分……太过分了吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「臭……？你剛剛說我臭嗎……好過分……太過分了吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00280",
		linknext = "0062_00282",
		line = 3522,
	},
	["0062_00282"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, deja de respirarme encima... ¿Estás borracha?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是，是酒味啊……难道你喝醉了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是，是酒味啊……難道你喝醉了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00281",
		linknext = "0062_00283",
		line = 3534,
	},
	["0062_00283"] = {
		{"fg", file="rei_01m_00006", file1="rei_01m_00110", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0606", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¿Ehhh? Por supuesto que no... Soy la presidenta del comité de moral pública... No puedo emborracharme delante de todos mis subordinados...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊——？我可没有喝醉……我可是风纪委员长哦……风纪委员长是不会喝醉的哦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊——？我可沒有喝醉……我可是風紀委員長哦……風紀委員長是不會喝醉的哦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00282",
		linknext = "0062_00284",
		line = 3548,
	},
	["0062_00284"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ah, la típica línea de borracho.",
					{"rt2"},
				},
			},
			cn = {
				{
					"醉汉们都是这么说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"醉漢們都是這麼說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00283",
		linknext = "0062_00285",
		line = 3558,
	},
	["0062_00285"] = {
