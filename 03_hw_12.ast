			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She's actually a magician before anything else. Nobody expects it, so she loves to surprise people with it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“倒不如说，那才是桐香酱的本领吧？她喜欢那样让大家大吃一惊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「倒不如說，那才是桐香醬的本領吧？她喜歡那樣讓大家大吃一驚。」",
					{"rt2"},
				},
			},
