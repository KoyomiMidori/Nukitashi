	["0062_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es como cuando vi el estado de la habitación de Rei-senpai en la residencia. Supongo que en el fondo son personas normales.",
					{"rt2"},
				},
			},
