		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Ah! ¡Esta carne... está BUENÍSIMA! ¡Ñam, ñam, ñam...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……！？这肉……好好吃啊……！嚼嚼嚼……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……！？這肉……好好吃啊……！嚼嚼嚼……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00182",
		linknext = "0062_00184",
		line = 2270,
	},
	["0062_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo con ponerla en mi lengua... mmm... Nunca había experimentado algo así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只是放到舌头上就……嚼嚼……只是放到舌头上就……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只是放到舌頭上就……嚼嚼……只是放到舌頭上就……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00183",
		linknext = "0062_00185",
		line = 2281,
	},
	["0062_00185"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
					{"exfont"},
				},
			},
			en = {
				{
					{"exfont", size="f4"},
					name = {"淳之介", "Junnosuke"},
					"“¡¡Tiene sabor!!”",
					{"rt2"},
					{"exfont"},
				},
			},
			cn = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"“很有味道……！”",
					{"rt2"},
					{"exfont"},
				},
			},
			tw = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"「很有味道……！」",
					{"rt2"},
					{"exfont"},
				},
			},
		},
		linkback = "0062_00184",
		linknext = "0062_00186",
		line = 2294,
	},
	["0062_00186"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0119", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“¡Ajaja! Pues claro, tontin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊哈哈！你做说什么啊，那不是当然的吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊哈哈！你做說什麼啊，那不是當然的嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00185",
		linknext = "0062_00187",
		line = 2307,
	},
	["0062_00187"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh...? Mmm... Comandante Onabuta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嚼嚼……？嚼嚼……女部田中队长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嚼嚼……？嚼嚼……女部田中隊長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00186",
		linknext = "0062_00188",
		line = 2319,
	},
	["0062_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es tan importante, pero cada vez que veo su nombre escrito, me dan ganas de leerlo como Comandante Unaputa...",
					{"rt2"},
				},
			},
			cn = {
				{
					"话说女部田中队长这个词，怎么想都觉得很像田中队长呢……",
					{"rt2"},
				},
			},
			tw = {
				{
					"話說女部田中隊長這個詞，怎麼想都覺得很像田中隊長呢……",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00187",
		linknext = "0062_00189",
		line = 2329,
	},
	["0062_00189"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0120", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Holii, chico nuevo ♪ ¿No te cansas de ser tan seco? Tenemos la misma edad, ¿por qué no me llamas Ikuko?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗨——新人君〜♪我们是同龄，所以叫我郁子就好了。我不是一直都这么说嘛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗨——新人君〜♪我們是同齡，所以叫我郁子就好了。我不是一直都這麼說嘛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00188",
		linknext = "0062_00190",
		line = 2343,
	},
	["0062_00190"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo sé, pero eres una comandante y yo solo soy un cadete. Tengo que respetar tu autoridad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不……因为是训练生和中队长，所以我必须要坚守自己的立场。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不……因為是訓練生和中隊長，所以我必須要堅守自己的立場。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00189",
		linknext = "0062_00191",
		line = 2355,
	},
	["0062_00191"] = {
		{"text"},
		delay = {
			[6500] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00105", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0121", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Jeje, ¿no son tú y Rei-chan como dos gotas de agua? Dices que solo eres un cadete, pero fuiste fundamental en el rescate del gobernador. Además, ni siquiera sabes cómo comer en un bufé...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵，跟礼酱一个样呢。虽然说是训练生，但昨天表现得很出色吧？不过……虽然好像没有自助餐的才能……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵，跟禮醬一個樣呢。雖然說是訓練生，但昨天表現得很出色吧？不過……雖然好像沒有自助餐的才能……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00190",
		linknext = "0062_00192",
		line = 2369,
	},
	["0062_00192"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Por qué les importa tanto cómo como en un bufé? Todo va al mismo lugar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“自助餐不是随便就好吗……只要往肚子里装就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「自助餐不是隨便就好嗎……只要往肚子裡裝就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00191",
		linknext = "0062_00193",
		line = 2381,
	},
	["0062_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Además, Rei-senpai hizo todo. Yo la estaba reteniendo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且，昨天的事几乎是礼前辈的功劳。倒不如说我还拖了她的后腿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且，昨天的事幾乎是禮前輩的功勞。倒不如說我還拖了她的後腿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00192",
		linknext = "0062_00194",
		line = 2393,
	},
	["0062_00194"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00107", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00111", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, delay2=3000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0122", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Y mira nada más cómo estás. Ah, si pudieras tener una erección por ti mismo, podrías disfrutar de un bufé libre en más de un sentido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你又在谦虚了……啊——如果新人君的小鸡鸡能勃起的话，大家就可以用很色的事情来奖励它了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「你又在謙虛了……啊——如果新人君的小雞雞能勃起的話，大家就可以用很色的事情來獎勵它了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00193",
		linknext = "0062_00195",
		line = 2409,
	},
	["0062_00195"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues qué pena...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是遗憾啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是遺憾啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00194",
		linknext = "0062_00196",
		line = 2421,
	},
	["0062_00196"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00110", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0123", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oye, ¿de verdad no se te para? Si quieres lo intento. ¡Probémoslo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我说，真的勃起不了吗？郁如果认真的话，可是有能让鸡巴心情舒畅地勃起的自信呢……要不要来试一次？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我說，真的勃起不了嗎？郁如果認真的話，可是有能讓肉棒心情舒暢地勃起的自信呢……要不要來試一次？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00195",
		linknext = "0062_00197",
		line = 2435,
	},
	["0062_00197"] = {
		{"fgact", ch="郁子", id=10, act="移動", x=-400, y=0, time=500},
		{"fg", file="ran_01m_00001", file1="ran_01m_00103", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="蘭", id=8, act="移動", x=-200, y=0, time=500},
		{"se", id=0, loop=0, file="se_a218"},
		{"text"},
		delay = {
			[200] = {
				{"se", id=0, loop=0, file="se_a218", delay2=200},
			},
		},
		text = {
			vo = {
				{"vo", file="ran0165", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡Bzzt! ¡No puedes hacer eso, Onabuta-san! ¡Rei-senpai ha estado pasando mucho tiempo con él, así que si intentas quedártelo para ti, se enojará!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“吡吡——！！不行哦女部田同学！橘君是礼前辈的爱徒……如果又干奇怪的事情会被骂哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「吡吡——！！不行哦女部田同學！橘君是禮前輩的愛徒……如果又幹奇怪的事情會被罵哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00196",
		linknext = "0062_00198",
		line = 2452,
	},
	["0062_00198"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00116", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0124", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Mmm, una vez no hace daño... ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯〜〜就一次……就一次，好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯〜〜就一次……就一次，好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00197",
		linknext = "0062_00199",
		line = 2466,
	},
	["0062_00199"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0166", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡No! ¡Cuando dices eso, no terminas hasta que quedan exprimidos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“不行！你总是这么说着，然后把人家榨干！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「不行！你總是這麼說著，然後把人家榨乾！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00198",
		linknext = "0062_00200",
		line = 2478,
	},
	["0062_00200"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00112", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0125", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
