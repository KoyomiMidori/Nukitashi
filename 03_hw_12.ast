		},
		linkback = "0062_00100",
		linknext = "0062_00102",
		line = 1268,
	},
	["0062_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hay gente de todo tipo...",
					{"rt2"},
				},
			},
			cn = {
				{
					"竟然会是这么做作的角色……",
					{"rt2"},
				},
			},
			tw = {
				{
					"竟然會是這麼做作的角色……",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00101",
		linknext = "0062_00103",
		line = 1278,
	},
	["0062_00103"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="asane_02m_00007", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1109", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“También se le olvidó una palabra aquí. Escribió 'encantaría' en vez de 'me encantaría'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“话说，这句‘你能来我很开心’的地方……漏了个‘会’变成了‘我很开心’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「話說，這句『你能來我很開心』的地方……漏了個『會』變成了『我很開心』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00102",
		linknext = "0062_00104",
		line = 1293,
	},
	["0062_00104"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……的确。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……的確。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00103",
		linknext = "0062_00105",
		line = 1305,
	},
	["0062_00105"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1110", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Así es, he visto esto muchas veces. Empiezas escribiendo una cosa, luego cambias una de las palabras, pero no cambias ninguna de las que la rodean.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这是那个啊……麻沙酱懂了……是把最一开始的表现方式改成‘会很开心’之后多删了字……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這是那個啊……麻沙醬懂了……是把最一開始的表現方式改成『會很開心』之後多刪了字……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00104",
		linknext = "0062_00106",
		line = 1319,
	},
	["0062_00106"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Qué inteligente!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太做作了———！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太做作了———！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00105",
		linknext = "0062_00107",
		line = 1331,
	},
	["0062_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Así que lo cambió de algo así a “encantaría”? ¿Qué querría decir?",
					{"rt2"},
				},
			},
			cn = {
				{
					"居然特意又换成了“会很开心”？一开始到底写了什么啊？",
					{"rt2"},
				},
			},
			tw = {
				{
					"居然特意又換成了「會很開心」？一開始到底寫了什麼啊？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00106",
		linknext = "0062_00108",
		line = 1341,
	},
	["0062_00108"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No puedo creerlo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶，开什么玩笑——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡，開什麼玩笑——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00107",
		linknext = "0062_00109",
		line = 1353,
	},
	["0062_00109"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00105", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1111", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Por qué estás tan molesto? ¿Vas a ir o no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然不太懂你为什么要生气……怎么办，要去吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然不太懂你為什麼要生氣……怎麼辦，要去嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00108",
		linknext = "0062_00110",
		line = 1367,
	},
	["0062_00110"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Mmm...? Ah, a la fiesta de la SS...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……啊，也对……FS的庆功宴是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……啊，也對……FS的慶功宴是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00109",
		linknext = "0062_00111",
		line = 1379,
	},
	["0062_00111"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1259", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Por qué no? ¡Después de todo lo que ha pasado, te lo ganaste! Creo que Rei-chan también se alegraría.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“去看看吧？毕竟橘君都这么努力了，要去拿些奖励才行！而且礼酱也很高兴啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「去看看吧？畢竟橘君都這麼努力了，要去拿些獎勵才行！而且禮醬也很高興啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00110",
		linknext = "0062_00112",
		line = 1393,
	},
	["0062_00112"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues sí. Yo también me siento bien después de dormir... Sí, debería ir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，也对。睡眠也足了身体也不错……去看看吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，也對。睡眠也足了身體也不錯……去看看吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00111",
		linknext = "0062_00113",
		line = 1405,
	},
	["0062_00113"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me pregunto si quieren ascenderme a miembro hecho y derecho de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说不定……可能会被升级为FS的正式成员哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說不定……可能會被升級為FS的正式成員哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00112",
		linknext = "0062_00114",
		line = 1418,
	},
	["0062_00114"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="asane_02m_00007", file1="asane_02m_00112", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"ex", time=500, func="wait"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Por qué me miras así? Solo era un cadete, pero fui fundamental en el rescate del gobernador. Probablemente lo hagan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你那什么表情……一个小小的训练生可是救出了县知事取得了大战果哦？也不是不可能吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你那什麼表情……一個小小的訓練生可是救出了縣知事取得了大戰果哦？也不是不可能吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00113",
		linknext = "0062_00115",
		line = 1435,
	},
	["0062_00115"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si eso sucede, obtendré la beca.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果成为正式成员的话还可以得到奖学金。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果成為正式成員的話還可以得到獎學金。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00114",
		linknext = "0062_00116",
		line = 1447,
	},
	["0062_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No sería genial? Podríamos tener ingresos reales, no tendríamos que llegar a duras penas a fin de mes mientras pagamos el seguro y el préstamo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这不是非常好吗？这样就可以跟用保险和存款过日子的生活告别了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這不是非常好嗎？這樣就可以跟用保險和存款過日子的生活告別了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00115",
		linknext = "0062_00117",
		line = 1458,
	},
	["0062_00117"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
