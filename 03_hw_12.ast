		},
		linkback = "0062_00380",
		linknext = "0062_00382",
		line = 4777,
	},
	["0062_00382"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0012", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“La ley crea una sociedad que se deleita en el sexo casual. El placer y la estimulación constantes entorpecen el pensamiento de las personas. Atrae a quienes tienen sentido común mediante la presión social, y la isla se beneficia enormemente de todo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“创造出肯定无秩序性行为的环境，用快感麻痹思考，用同调压力同化有良知之人，用性爱滋润岛屿——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「創造出肯定無秩序性行為的環境，用快感麻痺思考，用同調壓力同化有良知之人，用性愛滋潤島嶼——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00381",
		linknext = "0062_00383",
		line = 4792,
	},
	["0062_00383"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0013", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Muchos están cegados por el placer y las ganancias. Si la mayoría lo acepta, nadie puede oponerse. ¿No te parece repugnante?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“大多数的人类都被利益和快乐蒙蔽了双眼。面对那样的多数派，谁也无法否定——你不觉得这是个最糟糕的条例吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「大多數的人類都被利益和快樂蒙蔽了雙眼。面對那樣的多數派，誰也無法否定——你不覺得這是個最糟糕的條例嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00382",
		linknext = "0062_00384",
		line = 4806,
	},
	["0062_00384"] = {
		{"se", id=0, loop=0, file="se_a107"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es música para mis oídos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还以为自己的耳朵里住了一只妖精。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還以為自己的耳朵裡住了一隻妖精。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00383",
		linknext = "0062_00385",
		line = 4817,
	},
	["0062_00385"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No esperaba que nuestra conversación terminara así.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生的发言，是如此地令人难以置信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生的發言，是如此地令人難以置信。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00384",
