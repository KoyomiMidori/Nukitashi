					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mm... huh? T-Tachibana-kun!? Is it really you? Tachibana-kun awake! Are you all right? Asane-chan thought you had a head injury and she was bawling her eyes out all night!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……嗯？橘、橘君！？是橘君！已经可以起来了吗麻沙音酱哭着担心你的头呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……嗯？橘、橘君！？是橘君！已經可以起來了嗎麻沙音醬哭著擔心你的頭呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00031",
		linknext = "0062_00033",
		line = 402,
	},
	["0062_00033"] = {
