				},
			},
			en = {
				{
					"Salgo de mi habitación y miro el reloj de la sala. Ya pasó la hora del almuerzo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"来到起居室一看时钟，已经过了中午了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"來到起居室一看時鐘，已經過了中午了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00058",
		linknext = "0062_00060",
		line = 759,
	},
	["0062_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estuve apagado un rato. No me extraña que me sienta mejor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我好像睡了很久。怪不得能恢复到这种状态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我好像睡了很久。怪不得能恢復到這種狀態。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00059",
		linknext = "0062_00061",
		line = 769,
	},
	["0062_00061"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No deberían estar en la escuela?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来……你们俩学校呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來……你們倆學校呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00060",
		linknext = "0062_00062",
		line = 781,
	},
	["0062_00062"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1254", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ejeje... Me tomé el día libre. No podía irme y dejarlos solos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……我请假了。因为放心不下橘君和麻沙音酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……我請假了。因為放心不下橘君和麻沙音醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00061",
		linknext = "0062_00063",
		line = 795,
	},
	["0062_00063"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00062",
		linknext = "0062_00064",
		line = 807,
	},
	["0062_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es justo. Probablemente habría hecho lo mismo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也没有办法。就算立场交换，我也会做同样的事情吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也沒有辦法。就算立場交換，我也會做同樣的事情吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00063",
		linknext = "0062_00065",
		line = 817,
	},
	["0062_00065"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Asa-chan, me vas a soltar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说，麻沙酱打算黏着哥哥到什么时候？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說，麻沙醬打算黏著哥哥到什麼時候？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00064",
		linknext = "0062_00066",
		line = 829,
	},
	["0062_00066"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="asane_02l_00007", file1="asane_02l_00122", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1106", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Cállate y acaríciame la cabeza mientras me aferro a ti y no me hagas preocuparme más así o lloraré tan fuerte que todos los vecinos empezarán a hacerse chismes sobre nosotros...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啰嗦……在我抱着你的这段时间你要一直摸摸我的头……只要让我稍微不安我就哭到让你被附近的人指指点点的程度……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「囉嗦……在我抱著你的這段時間你要一直摸摸我的頭……只要讓我稍微不安我就哭到讓你被附近的人指指點點的程度……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00065",
		linknext = "0062_00067",
		line = 844,
	},
	["0062_00067"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Qué chica tan terca.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是个没办法的孩子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是個沒辦法的孩子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00066",
		linknext = "0062_00068",
		line = 856,
	},
	["0062_00068"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sigo administrando las caricias en la cabeza prescritas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我按照她说的抚摸她的头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我按照她說的撫摸她的頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00067",
		linknext = "0062_00069",
		line = 867,
	},
	["0062_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siempre se aferra a mí, pero esto es demasiado. Debía estar muy nerviosa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天比平常更撒娇了。想必是相当担心了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天比平常更撒嬌了。想必是相當擔心了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00068",
		linknext = "0062_00070",
		line = 877,
	},
	["0062_00070"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00107", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1255", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje, te ves muy feliz, Asane-chan. Las caricias de tu hermano son las mejores.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵……麻沙音酱看起来很开心，果然还是哥哥的摸摸头最棒呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呵呵……麻沙音醬看起來很開心，果然還是哥哥的摸摸頭最棒呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00069",
		linknext = "0062_00071",
		line = 891,
	},
	["0062_00071"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00105", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece indecisa ante eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被这么说的麻沙酱，露出了复杂的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被這麼說的麻沙醬，露出了複雜的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00070",
		linknext = "0062_00072",
		line = 903,
	},
	["0062_00072"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué pasa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00071",
		linknext = "0062_00073",
		line = 915,
	},
	["0062_00073"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1107", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah... no, no pasa nada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，不……也没什么，只是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，不……也沒什麼，只是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00072",
		linknext = "0062_00074",
		line = 927,
	},
	["0062_00074"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00106", file2="asane_02l_00201", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1108", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es solo que Wata-chan ha estado presente desde hace un buen rato, pero de vez en cuando parece una hermana mayor. Nunca estoy preparada para eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“最近一直和渡酱在一起……所以偶尔会觉得……她真的就像年长的姐姐一样……有时候会让人怦然心动……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「最近一直和渡醬在一起……所以偶爾會覺得……她真的就像年長的姐姐一樣……有時候會讓人怦然心動……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00073",
		linknext = "0062_00075",
		line = 941,
	},
	["0062_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es absurdo...",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么可能——",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼可能——",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00074",
		linknext = "0062_00076",
		line = 951,
	},
	["0062_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero no puedo decirlo en voz alta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种话我说不出口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種話我說不出口。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00075",
		linknext = "0062_00077",
		line = 961,
	},
	["0062_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque no puedo negar que yo también lo he pensado algunas veces.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说实话，我有时也会——虽然真的是极其罕见，但也会这么想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說實話，我有時也會——雖然真的是極其罕見，但也會這麼想。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00076",
