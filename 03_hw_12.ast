				{"vo", file="hinami1255", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hehe, you look happy, Asane-chan. Your brother's pats are the best.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵……麻沙音酱看起来很开心，果然还是哥哥的摸摸头最棒呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
