					name = {"淳之介", "Junnosuke"},
					"“Really...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来是这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來是這樣啊……」",
					{"rt2"},
				},
			},
