			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Iba a ponerle afrodisíaco en la bebida, pero me equivoqué de botella y le puse alcohol. Jeje ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我本来想往礼酱的杯子里倒媚药，结果不小心倒成酒精了。诶嘿♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我本來想往禮醬的杯子裡倒媚藥，結果不小心倒成酒精了。欸嘿♪」",
					{"rt2"},
				},
			},
		},
