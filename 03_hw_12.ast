		linkback = "0062_00385",
		linknext = "0062_00387",
		line = 4837,
	},
	["0062_00387"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si cree que es una ley repugnante, ¿por qué la estableció”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然嘴上说是最糟糕的条例——那你为什么还要制定这样的条例？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然嘴上說是最糟糕的條例——那你為什麼還要制定這樣的條例？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00386",
		linknext = "0062_00388",
		line = 4849,
	},
	["0062_00388"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0014", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Porque soy malvado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为我是坏人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為我是壞人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00387",
		linknext = "0062_00389",
		line = 4863,
	},
	["0062_00389"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me lo dice sin tapujos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他清楚地如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他清楚地如此說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00388",
		linknext = "0062_00390",
		line = 4873,
	},
	["0062_00390"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0015", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“El comercio sexual es una herramienta para gobernar la isla, distribuir dinero a los funcionarios del gobierno continental y descubrir las debilidades de quienes la visitan. Ese es mi plan malvado para brindarle más poder a la Isla Seiran.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“使用性产业支配岛民，撒钱给本岛的大人物，掌握来到岛上的政治家的弱点——我就是靠这些行为来掌握青蓝岛实权的超级恶人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「使用性產業支配島民，撒錢給本島的大人物，掌握來到島上的政治家的弱點——我就是靠這些行為來掌握青藍島實權的超級惡人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00389",
		linknext = "0062_00391",
		line = 4885,
	},
	["0062_00391"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0016", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Je... Seguramente te sorprende oírlo del artífice de todo, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……自己这么说着自己的感觉，意外地很舒适呢，少年。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……自己這麼說著自己的感覺，意外地很舒適呢，少年。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00390",
		linknext = "0062_00392",
		line = 4899,
	},
	["0062_00392"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dice algo que lo incrimina, pero mantiene la calma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算说着对于一个县知事来说过于不妙的发言，仁浦先生还是一脸清爽。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算說著對於一個縣知事來說過於不妙的發言，仁浦先生還是一臉清爽。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00391",
		linknext = "0062_00393",
		line = 4909,
	},
	["0062_00393"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No es comprometedor decir eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这些发言……不会有问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這些發言……不會有問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00392",
		linknext = "0062_00394",
		line = 4920,
	},
	["0062_00394"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si estuviera grabando esto, podría subirlo a internet y—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果被我录了下来，流传到网络的话——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果被我錄了下來，流傳到網路的話——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00393",
		linknext = "0062_00395",
		line = 4931,
	},
	["0062_00395"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0017", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hazlo si quieres. El sistema en esta isla es tan fuerte que ni siquiera eso podría destruirlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那也没关系。我创造的地盘，可不是那么容易就会动摇的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那也沒關係。我創造的地盤，可不是那麼容易就會動搖的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00394",
		linknext = "0062_00396",
		line = 4943,
	},
	["0062_00396"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Qué confianza tan abrumadora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是绝对的自信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是絕對的自信。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00395",
		linknext = "0062_00397",
		line = 4953,
	},
	["0062_00397"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está diciendo que ni sus propias palabras podrían derribar la sociedad que él mismo construyó. Su orgullo es intimidante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是相信就算自己的真实意图被知道，创造出的东西也不会崩坏的——强到令人畏惧的自负。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是相信就算自己的真實意圖被知道，創造出的東西也不會崩壞的——強到令人畏懼的自負。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00396",
		linknext = "0062_00398",
		line = 4963,
	},
	["0062_00398"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0018", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Los habitantes de esta isla son unos imbéciles. Anhelan insaciablemente el placer y desechan su razonamiento humano. ¿Por qué no debería aplicar la ley con esos ignorantes asquerosos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这个岛的人很愚蠢。贪图快乐，忘记作为人类的理性。给这种愚民们强加最糟糕的条例，这有什么好忌讳的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這個島的人很愚蠢。貪圖快樂，忘記作為人類的理性。給這種愚民們強加最糟糕的條例，這有什麼好忌諱的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00397",
		linknext = "0062_00399",
		line = 4977,
	},
	["0062_00399"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No te estás equivocando de ideas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“顺序有点奇怪吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「順序有點奇怪吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00398",
		linknext = "0062_00400",
		line = 4988,
	},
	["0062_00400"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya no pueden pensar bien por culpa de la ley súperpervertida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是变态条例把人们的理性都夺走了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是變態條例把人們的理性都奪走了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00399",
		linknext = "0062_00401",
		line = 4999,
	},
	["0062_00401"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0019", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“¿De verdad piensas eso? Por lo que he visto, la gente no ha cambiado mucho. Si son unos tontos, así se quedarán.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你真的是这样想的吗？据我所知，这个岛上的人从以前起就没有任何改变。依然是愚蠢的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你真的是這樣想的嗎？據我所知，這個島上的人從以前起就沒有任何改變。依然是愚蠢的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00400",
		linknext = "0062_00402",
		line = 5013,
	},
	["0062_00402"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00401",
		linknext = "0062_00403",
		line = 5025,
	},
	["0062_00403"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Puedo sentirlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"嗯，我————",
					{"rt2"},
				},
			},
			tw = {
				{
					"嗯，我————",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00402",
		linknext = "0062_00404",
		line = 5035,
	},
	["0062_00404"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0020", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“La ley es ideal para mantener a raya a estos paletos irracionales y vociferantes. Las personas que tienen los hechos, la lógica y la razón de su parte deben estar por encima de ellos. ¿No te parece?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“对于没有理性只会吼叫的愚蠢家伙们，这是很般配的条例。只有拥有理性的人应该站在上位……你不这么认为吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「對於沒有理性只會吼叫的愚蠢傢伙們，這是很般配的條例。只有擁有理性的人應該站在上位……你不這麼認為嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00403",
		linknext = "0062_00405",
		line = 5047,
	},
	["0062_00405"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Puedo empatizar con lo que dice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我——对他所说的话有共鸣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我——對他所說的話有共鳴。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00404",
		linknext = "0062_00406",
		line = 5057,
	},
	["0062_00406"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde que vivía aquí, cuando me acosaban... Siempre pensé que cualquiera lo suficientemente tonto como para vivir aquí era un maldito idiota.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个岛的人很愚蠢——从过去被欺负时开始，我就一直是这样想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個島的人很愚蠢——從過去被欺負時開始，我就一直是這樣想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00405",
		linknext = "0062_00407",
		line = 5067,
	},
	["0062_00407"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa idea me ha perseguido desde ese momento.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时候亲身体验过的经历，让我一直强烈、深刻地这样认为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時候親身體驗過的經歷，讓我一直強烈、深刻地這樣認為。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00406",
		linknext = "0062_00408",
		line = 5077,
	},
	["0062_00408"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0021", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Por eso vine a verte. Sentí que tú pensabas lo mismo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“所以我才来见你。因为我在你身上也感受到了类似的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「所以我才來見你。因為我在你身上也感受到了類似的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00407",
		linknext = "0062_00409",
		line = 5091,
	},
	["0062_00409"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sabe lo que pienso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他仿佛看透了我一般说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他彷彿看透了我一般說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00408",
		linknext = "0062_00410",
		line = 5101,
	},
	["0062_00410"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No esperaba que nuestro primer encuentro me afectara así.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仿佛不像是初次见面一般，我的心被他的话语动摇了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彷彿不像是初次見面一般，我的心被他的話語動搖了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00409",
		linknext = "0062_00411",
		line = 5111,
	},
	["0062_00411"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“…………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「…………」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00410",
		linknext = "0062_00412",
		line = 5123,
	},
	["0062_00412"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero aunque coincido con su punto de vista... sus métodos no se parecen a los míos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即使想法相同——我们的做法却有着决定性的不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即使想法相同——我們的做法卻有著決定性的不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00411",
		linknext = "0062_00413",
		line = 5133,
	},
	["0062_00413"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No permitiré que me comparen con él.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这部份可不能搞混了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這部份可不能搞混了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00412",
		linknext = "0062_00414",
		line = 5143,
	},
	["0062_00414"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, aunque los isleños sean unos paletos, esta ley perjudica a las personas con sentido común. No puedo aceptarlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使岛上的人很愚蠢——但这种连有良知的人都吞入的恶劣条例，我可不能赞同。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使島上的人很愚蠢——但這種連有良知的人都吞入的惡劣條例，我可不能贊同。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00413",
		linknext = "0062_00415",
		line = 5155,
	},
	["0062_00415"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0022", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Je... Andamos muy atrevidos con esas declaraciones. No esperaba oír eso de un cadete de la SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……你可说了些大胆的话，真不像是FS训练生会说的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……你可說了些大膽的話，真不像是FS訓練生會說的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00414",
		linknext = "0062_00416",
		line = 5169,
	},
	["0062_00416"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su expresión permanece rígida, aun ante mi rechazo rotundo de su ley y su visión del mundo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使正面否定条例，仁浦先生也没有露出不快的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使正面否定條例，仁浦先生也沒有露出不快的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00415",
		linknext = "0062_00417",
		line = 5179,
	},
	["0062_00417"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0023", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Pero vamos a dejar algo claro, joven. El éxito consiste en ganar por cualquier medio necesario, sin importar lo malvado que sea, y seguir haciéndolo para proteger ese éxito. Una vez que te pasas al lado de la maldad, te quedas ahí para siempre.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是啊，少年……所谓的成功，就是做出了恶行而得胜，然后再用更多的恶去守护它。一旦开始作恶，就必须贯彻到底。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是啊，少年……所謂的成功，就是做出了惡行而得勝，然後再用更多的惡去守護它。一旦開始作惡，就必須貫徹到底。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00416",
		linknext = "0062_00418",
		line = 5193,
	},
	["0062_00418"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No creo que eso sea cierto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我——不这么认为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我——不這麼認為。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00417",
		linknext = "0062_00419",
		line = 5205,
	},
	["0062_00419"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0024", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Mmm, ¿de verdad? Entonces dime algo. ¿Puedes asegurar que nunca has cometido un acto malvado para alcanzar el éxito?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯，是吗……那么我问你——少年，你有没有曾经为了获得成功，而犯下恶行呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯，是嗎……那麼我問你——少年，你有沒有曾經為了獲得成功，而犯下惡行呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00418",
		linknext = "0062_00420",
		line = 5219,
	},
	["0062_00420"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No tengo respuesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无法回答那个问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無法回答那個問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00419",
		linknext = "0062_00421",
		line = 5230,
	},
	["0062_00421"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es más, voy a aprovecharme de la SS — de Rei-senpai — para acabar con la ley.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了摧毁变态条例，我欺骗了FS——欺骗了礼前辈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了摧毀變態條例，我欺騙了FS——欺騙了禮前輩。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00420",
		linknext = "0062_00422",
		line = 5240,
	},
	["0062_00422"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si me presionaran... diría que tengo razón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我能坚定地说出这是正义——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我能堅定地說出這是正義——",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00421",
		linknext = "0062_00423",
		line = 5250,
	},
