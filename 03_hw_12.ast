	["0062_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I think of it, I haven't had anything to eat since yesterday's lunch. I'm absolutely famished.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仔细想想，我从昨天午饭后就什么都没吃，现在完全处于饥饿状态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仔細想想，我從昨天午飯後就什麼都沒吃，現在完全處於飢餓狀態。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00164",
		linknext = "0062_00166",
		line = 2060,
	},
	["0062_00166"] = {
		{"text"},
		text = {
