	},
	["0062_00074"] = {
		{"fg", file="asane_02l_00007", file1="asane_02l_00106", file2="asane_02l_00201", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1108", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It's just that Wata-chan's been around a lot lately, but from time to time she actually seems like a big sister. I'm never ready for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“最近一直和渡酱在一起……所以偶尔会觉得……她真的就像年长的姐姐一样……有时候会让人怦然心动……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「最近一直和渡醬在一起……所以偶爾會覺得……她真的就像年長的姐姐一樣……有時候會讓人怦然心動……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00073",
		linknext = "0062_00075",
		line = 941,
	},
	["0062_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's absurd to think about.",
					{"rt2"},
				},
