			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡¡Manito!! ¡¡Manitomanitomanito!! ¡Qué bien que despertaste...! ¡¡Ahh... pensé que ibas a moriiiiir!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
