	},
	["0062_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Podría aceptarlo si solo se debiera a mi repugnancia natural hacia ellos. Como miembro del Frente Anticopulación, es lógico que nunca me pareciera bien formar parte de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果那只是厌恶感的话倒还好。身为反交尾势力的我，对FS表现出拒绝是理所当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果那隻是厭惡感的話倒還好。身為反交尾勢力的我，對FS表現出拒絕是理所當然的。",
					{"rt2"},
				},
			},
		},
