					"“Junnosuke... Cuida tu salud... No quiero que mueras... ¡waaahh!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“淳之介……不要太勉强哦……我不要你死……唔啊啊啊啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「淳之介……不要太勉強哦……我不要你死……唔啊啊啊啊……！」",
					{"rt2"},
				},
			},
		},
