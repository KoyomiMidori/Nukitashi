		linknext = "0062_00049",
		line = 593,
	},
	["0062_00049"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1250", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Wahh... Aunque tenga un poco de sueño, quiero quedarme despierta un rato más... ahora que te levantaste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呼啊……确实是有点困了……不过橘君好不容易起来了……我还想再醒着一会儿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呼啊……確實是有點睏了……不過橘君好不容易起來了……我還想再醒著一會……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00048",
		linknext = "0062_00050",
		line = 607,
	},
	["0062_00050"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
