	["0062_00380"] = {
		{"bgm", stop=1},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0011", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oh, it's quite simple. The law is disgusting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“没有怎么想。是个最糟糕的条例吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「沒有怎麼想。是個最糟糕的條例吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00379",
		linknext = "0062_00381",
		line = 4765,
	},
	["0062_00381"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00380",
		linknext = "0062_00382",
		line = 4777,
	},
	["0062_00382"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0012", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It creates a society that revels in random sex. The constant pleasure and stimulation dulls people's ability to think. It sucks in those with common sense through peer pressure, and the island profits massively from it all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“创造出肯定无秩序性行为的环境，用快感麻痹思考，用同调压力同化有良知之人，用性爱滋润岛屿——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「創造出肯定無秩序性行為的環境，用快感麻痺思考，用同調壓力同化有良知之人，用性愛滋潤島嶼——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00381",
		linknext = "0062_00383",
		line = 4792,
	},
	["0062_00383"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0013", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So many are blinded by the pleasure and the profits. If the majority accepts it, then no one can stand against it. Don't you agree it's disgusting?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“大多数的人类都被利益和快乐蒙蔽了双眼。面对那样的多数派，谁也无法否定——你不觉得这是个最糟糕的条例吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「大多數的人類都被利益和快樂蒙蔽了雙眼。面對那樣的多數派，誰也無法否定——你不覺得這是個最糟糕的條例嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00382",
		linknext = "0062_00384",
		line = 4806,
	},
	["0062_00384"] = {
		{"se", id=0, loop=0, file="se_a107"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's like music to my ears.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还以为自己的耳朵里住了一只妖精。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還以為自己的耳朵裡住了一隻妖精。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00383",
		linknext = "0062_00385",
		line = 4817,
	},
	["0062_00385"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't say this is how I expected this conversation to go.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生的发言，是如此地令人难以置信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生的發言，是如此地令人難以置信。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00384",
		linknext = "0062_00386",
		line = 4827,
	},
	["0062_00386"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My heart is pounding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心跳莫名地加速。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心跳莫名地加速。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00385",
		linknext = "0062_00387",
		line = 4837,
	},
	["0062_00387"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you think it's a disgusting law, then why did you establish it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然嘴上说是最糟糕的条例——那你为什么还要制定这样的条例？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然嘴上說是最糟糕的條例——那你為什麼還要制定這樣的條例？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00386",
		linknext = "0062_00388",
		line = 4849,
	},
	["0062_00388"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0014", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Because I'm evil.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为我是坏人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為我是壞人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00387",
		linknext = "0062_00389",
		line = 4863,
	},
	["0062_00389"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He comes right out and says it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他清楚地如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他清楚地如此說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00388",
		linknext = "0062_00390",
		line = 4873,
	},
	["0062_00390"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0015", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The sex trade is a tool to govern the island, distribute money to mainland government officials, and sniff out the weaknesses of those who visit. Such is my villainous plot to put more power in the hands of Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“使用性产业支配岛民，撒钱给本岛的大人物，掌握来到岛上的政治家的弱点——我就是靠这些行为来掌握青蓝岛实权的超级恶人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「使用性產業支配島民，撒錢給本島的大人物，掌握來到島上的政治家的弱點——我就是靠這些行為來掌握青藍島實權的超級惡人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00389",
		linknext = "0062_00391",
		line = 4885,
	},
	["0062_00391"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0016", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Heh... I'm sure you're quite surprised to hear that straight from the horse's mouth, aren't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……自己这么说着自己的感觉，意外地很舒适呢，少年。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……自己這麼說著自己的感覺，意外地很舒適呢，少年。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00390",
		linknext = "0062_00392",
		line = 4899,
	},
	["0062_00392"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He says something incredibly incriminating, but maintains his cool composure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算说着对于一个县知事来说过于不妙的发言，仁浦先生还是一脸清爽。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算說著對於一個縣知事來說過於不妙的發言，仁浦先生還是一臉清爽。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00391",
		linknext = "0062_00393",
		line = 4909,
	},
	["0062_00393"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn't that an incriminating thing to say?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这些发言……不会有问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這些發言……不會有問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00392",
		linknext = "0062_00394",
		line = 4920,
	},
	["0062_00394"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I happened to be recording this, I could throw it up online, and then—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果被我录了下来，流传到网络的话——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果被我錄了下來，流傳到網路的話——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00393",
		linknext = "0062_00395",
		line = 4931,
	},
	["0062_00395"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0017", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Please, go ahead and try. The establishment on this island is so rock-solid that not even that could bring it down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那也没关系。我创造的地盘，可不是那么容易就会动摇的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那也沒關係。我創造的地盤，可不是那麼容易就會動搖的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00394",
		linknext = "0062_00396",
		line = 4943,
	},
	["0062_00396"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What overwhelming confidence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是绝对的自信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是絕對的自信。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00395",
		linknext = "0062_00397",
		line = 4953,
	},
	["0062_00397"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's saying that even his own words couldn't bring down the society he built. His pride is almost intimidating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是相信就算自己的真实意图被知道，创造出的东西也不会崩坏的——强到令人畏惧的自负。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是相信就算自己的真實意圖被知道，創造出的東西也不會崩壞的——強到令人畏懼的自負。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00396",
		linknext = "0062_00398",
		line = 4963,
	},
	["0062_00398"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0018", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The people on this island are imbeciles. Insatiably craving pleasure, discarding all their human reasoning. So why should I hesitate in applying that disgusting law to those ignorant louts?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这个岛的人很愚蠢。贪图快乐，忘记作为人类的理性。给这种愚民们强加最糟糕的条例，这有什么好忌讳的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這個島的人很愚蠢。貪圖快樂，忘記作為人類的理性。給這種愚民們強加最糟糕的條例，這有什麼好忌諱的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00397",
		linknext = "0062_00399",
		line = 4977,
	},
	["0062_00399"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't you have it backwards?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“顺序有点奇怪吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「順序有點奇怪吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00398",
		linknext = "0062_00400",
		line = 4988,
	},
	["0062_00400"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They've lost their ability to think rationally because of the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是变态条例把人们的理性都夺走了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是變態條例把人們的理性都奪走了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00399",
		linknext = "0062_00401",
		line = 4999,
	},
	["0062_00401"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00114", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0019", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Is that really what you think? From what I've seen, there's been little change in the people since before my new law. Once a fool, always a fool.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你真的是这样想的吗？据我所知，这个岛上的人从以前起就没有任何改变。依然是愚蠢的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你真的是這樣想的嗎？據我所知，這個島上的人從以前起就沒有任何改變。依然是愚蠢的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00400",
		linknext = "0062_00402",
		line = 5013,
	},
	["0062_00402"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00401",
		linknext = "0062_00403",
		line = 5025,
	},
	["0062_00403"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can feel it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"嗯，我————",
					{"rt2"},
				},
			},
			tw = {
				{
					"嗯，我————",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00402",
		linknext = "0062_00404",
		line = 5035,
	},
	["0062_00404"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0020", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The law is nothing if not ideal for keeping these barking, irrational fools in line. People who have facts, logic and reason on their side are meant to stand above them. Do you not agree?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“对于没有理性只会吼叫的愚蠢家伙们，这是很般配的条例。只有拥有理性的人应该站在上位……你不这么认为吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「對於沒有理性只會吼叫的愚蠢傢伙們，這是很般配的條例。只有擁有理性的人應該站在上位……你不這麼認為嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00403",
		linknext = "0062_00405",
		line = 5047,
	},
	["0062_00405"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can feel myself empathizing with him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我——对他所说的话有共鸣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我——對他所說的話有共鳴。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00404",
		linknext = "0062_00406",
		line = 5057,
	},
	["0062_00406"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since I lived here before, when I used to get bullied... I always thought anyone stupid enough to live here was a fucking rube.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个岛的人很愚蠢——从过去被欺负时开始，我就一直是这样想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個島的人很愚蠢——從過去被欺負時開始，我就一直是這樣想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00405",
		linknext = "0062_00407",
		line = 5067,
	},
	["0062_00407"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That thought has followed me around endlessly and intensely from that moment on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时候亲身体验过的经历，让我一直强烈、深刻地这样认为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時候親身體驗過的經歷，讓我一直強烈、深刻地這樣認為。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00406",
		linknext = "0062_00408",
		line = 5077,
	},
	["0062_00408"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0021", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That's why I came to see you. I sensed you felt much the same way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“所以我才来见你。因为我在你身上也感受到了类似的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「所以我才來見你。因為我在你身上也感受到了類似的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00407",
		linknext = "0062_00409",
		line = 5091,
	},
	["0062_00409"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's read me like a book.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他仿佛看透了我一般说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他彷彿看透了我一般說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00408",
		linknext = "0062_00410",
		line = 5101,
	},
	["0062_00410"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never would've expected our first meeting to affect me this deeply.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仿佛不像是初次见面一般，我的心被他的话语动摇了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彷彿不像是初次見面一般，我的心被他的話語動搖了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00409",
		linknext = "0062_00411",
		line = 5111,
	},
	["0062_00411"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“…………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「…………」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00410",
		linknext = "0062_00412",
		line = 5123,
	},
	["0062_00412"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But while I concur with his point of view... his methods are diametrically opposed to mine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即使想法相同——我们的做法却有着决定性的不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即使想法相同——我們的做法卻有著決定性的不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00411",
		linknext = "0062_00413",
		line = 5133,
	},
	["0062_00413"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I won't allow myself to be equated with him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这部份可不能搞混了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這部份可不能搞混了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00412",
		linknext = "0062_00414",
		line = 5143,
	},
	["0062_00414"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, even if the islanders are all gullible fools, this is a law that adversely affects people with common sense. I can't accept that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使岛上的人很愚蠢——但这种连有良知的人都吞入的恶劣条例，我可不能赞同。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使島上的人很愚蠢——但這種連有良知的人都吞入的惡劣條例，我可不能贊同。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00413",
		linknext = "0062_00415",
		line = 5155,
	},
	["0062_00415"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0022", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Heh... That's quite a bold statement. Didn't expect to hear that from an SS trainee.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……你可说了些大胆的话，真不像是SS训练生会说的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……你可說了些大膽的話，真不像是SS訓練生會說的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00414",
		linknext = "0062_00416",
		line = 5169,
	},
	["0062_00416"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His expression remains rigid, even in the face of me rejecting his law and beliefs outright.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使正面否定条例，仁浦先生也没有露出不快的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使正面否定條例，仁浦先生也沒有露出不快的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00415",
		linknext = "0062_00417",
		line = 5179,
	},
	["0062_00417"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0023", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But let me be clear, young man. Success is to win by any means necessary, no matter how evil they may be, and to continue to do so to protect that success. Once you've gone over to the dark side, you're in it for the long haul.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是啊，少年……所谓的成功，就是做出了恶行而得胜，然后再用更多的恶去守护它。一旦开始作恶，就必须贯彻到底。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是啊，少年……所謂的成功，就是做出了惡行而得勝，然後再用更多的惡去守護它。一旦開始作惡，就必須貫徹到底。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00416",
		linknext = "0062_00418",
		line = 5193,
	},
	["0062_00418"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I don't think that's right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我——不这么认为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我——不這麼認為。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00417",
		linknext = "0062_00419",
		line = 5205,
	},
	["0062_00419"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0024", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hm, is that so. Answer me this, then. Can you say that you've never committed an act of evil in order to achieve success?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯，是吗……那么我问你——少年，你有没有曾经为了获得成功，而犯下恶行呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯，是嗎……那麼我問你——少年，你有沒有曾經為了獲得成功，而犯下惡行呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00418",
		linknext = "0062_00420",
		line = 5219,
	},
	["0062_00420"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't have an answer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无法回答那个问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無法回答那個問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00419",
		linknext = "0062_00421",
		line = 5230,
	},
	["0062_00421"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hell, I'm planning to take advantage of the SS — of Rei-senpai — just to bring that law down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了摧毁变态条例，我欺骗了SS——欺骗了礼前辈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了摧毀變態條例，我欺騙了SS——欺騙了禮前輩。",
					{"rt2"},
				},
			},
		},
