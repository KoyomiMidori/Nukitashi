		{"bg", id=1, file="bg23_3_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_012_00000"},
		{"bgm", file="bgm23", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La fiesta está en pleno apogeo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"宴会也到了高潮。",
					{"rt2"},
				},
			},
			tw = {
				{
					"宴會也到了高潮。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00258",
		linknext = "0062_00260",
		line = 3266,
	},
	["0062_00260"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con el paso del tiempo, cada vez hay menos gente comiendo, ya que otros empiezan a sacar sus propios trucos de fiesta. Varias personas también se retiran a otras habitaciones cercanas para tener sexo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有人在默默着吃东西，有的人随意表演节目，有的人开始在隔壁的做爱房里做爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有人在默默著吃東西，有的人隨意表演節目，有的人開始在隔壁的做愛房裡做愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00259",
		linknext = "0062_00261",
		line = 3276,
	},
	["0062_00261"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0053", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“¡Ey, cadetes de cursos superiores! ¡Hagan algo divertido para nosotros!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“训练生的前辈们！请干一些有趣的事情吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「訓練生的前輩們！請幹一些有趣的事情吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00260",
		linknext = "0062_00262",
		line = 3288,
	},
	["0062_00262"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La Hanamaru menor hace una petición absurda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸妹妹有点乱来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"花丸妹妹有點亂來。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00261",
		linknext = "0062_00263",
		line = 3298,
	},
	["0062_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está en las clases de nivel B, pero como es una integrante hecha y derecha de la SS, es mi superior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是B等部，但她也是FS的正式成员之一——在立场上比我们高。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是B等部，但她也是FS的正式成員之一——在立場上比我們高。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00262",
		linknext = "0062_00264",
		line = 3308,
	},
	["0062_00264"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0012", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Mmm... muy bien. Te mostraré mi truco de magia. ¡Mi polla apuntará hacia arriba, hacia el techo, sin siquiera tocarlo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“哼……交给我吧。那么……为了回应你的期待，我就表演一下不用手触摸，就把阴茎向上提的魔术吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「哼……交給我吧。那麼……為了回應你的期待，我就表演一下不用手觸摸，就把陰莖向上提的魔術吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00263",
		linknext = "0062_00265",
		line = 3320,
	},
	["0062_00265"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0009", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“¡¿Eso no es tener una erección por pensar cosas sucias?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“那不就只是想着色色的事情勃起而已吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「那不就只是想著色色的事情勃起而已嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00264",
		linknext = "0062_00266",
		line = 3332,
	},
	["0062_00266"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="obekka0007", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"おべっか"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"おべっか", "Lamebotas"},
					"“¡Entonces haré que esa polla apuntando hacia arriba desaparezca mágicamente dentro de mi coño!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"おべっか", "马屁精"},
					"“那我就表演用小穴将向上提的鸡巴变不见吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"おべっか", "馬屁精"},
					"「那我就表演用小穴將向上提的肉棒變不見吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00265",
		linknext = "0062_00267",
		line = 3344,
	},
	["0062_00267"] = {
		{"text"},
