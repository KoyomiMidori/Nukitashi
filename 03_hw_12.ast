	["0062_00347"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0001", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "???"},
					"“Ooh, notaste mi presencia. Parece que no fue pura suerte la razón por la que me salvaste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦", "？ ？ ？"},
					"“哦……你注意到了吗？不愧是救了我的男人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦", "？？？"},
					"「哦……你注意到了嗎？不愧是救了我的男人。」",
					{"rt2"},
				},
			},
		},
