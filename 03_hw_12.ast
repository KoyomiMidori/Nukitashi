	["0062_00236"] = {
		{"fg", mode=-1, id=10, ch="郁子", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como no es precisamente alguien con quien haya pasado tiempo en privado, no lo sabía.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然在FS里，也几乎没有机会看到学生会长的私人生活——这次看到了她意外的一面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然在FS裡，也幾乎沒有機會看到學生會長的私人生活——這次看到了她意外的一面。",
					{"rt2"},
				},
			},
