	["0062_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por lo que sé, eso fue consecuencia del impacto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是受到枪击的影响吗———",
					{"rt2"},
				},
