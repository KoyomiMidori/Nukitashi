		linknext = "0062_00301",
		line = 3766,
	},
	["0062_00301"] = {
		{"fg", file="rei_01m_00006", file1="rei_01m_00119", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0612", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“*Sniffle* I've been trying as hard as I can against my little brother and sister and they still beat me... ugh... And they seem so happy when they beat me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呜呜……最近，终于就算认真玩也打不过妹妹们了……呜呜……虽然他们俩赢了我，都一副开心的样子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗚嗚……最近，終於就算認真玩也打不過妹妹們了……嗚嗚……雖然他們倆贏了我，都一副開心的樣子……」",
					{"rt2"},
				},
			},
		},
