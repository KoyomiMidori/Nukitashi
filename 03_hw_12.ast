	},
	["0062_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No puedo creerlo...",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到，那位礼前辈——",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到，那位禮前輩——",
					{"rt2"},
