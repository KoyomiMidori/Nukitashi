	["0062_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, tal vez no. Acababa de despertarme, así que probablemente estaba medio dormido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，仔细想想，那时也才刚睡醒，或许只是脑袋还有些迟钝而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，仔細想想，那時也才剛睡醒，或許只是腦袋還有些遲鈍而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00175",
		linknext = "0062_00177",
		line = 2183,
	},
	["0062_00177"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hasta ahora todo va bien. Ya sabes que mi resistencia es mi única cualidad notable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到目前为止没什么变化……你应该知道吧？说到我的优点就只有身体结实而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到目前為止沒什麼變化……你應該知道吧？說到我的優點就只有身體結實而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00176",
		linknext = "0062_00178",
		line = 2195,
	},
	["0062_00178"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
