				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ahh... He estado esforzándome contra mis hermanos, pero siempre me ganan... uuuu... Y se ven muy felices cuando me ganan...”",
					{"rt2"},
				},
			},
			cn = {
