		line = 4827,
	},
	["0062_00386"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me late el corazón con fuerza.",
					{"rt2"},
				},
			},
			cn = {
