	["0062_00353"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0003", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Sería descortés como gobernador que no me supiera el nombre de mi salvador, ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这是当然的吧？如果连恩人的名字都记不住的话，就做不了县知事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這是當然的吧？如果連恩人的名字都記不住的話，就做不了縣知事了。」",
					{"rt2"},
				},
			},
		},
