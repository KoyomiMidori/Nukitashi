	["0062_00229"] = {
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=150, ease="easeinout_sine"},
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a098"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La presidenta del consejo estudiantil ha sacado un sombrero de copa de seda y de él salen volando palomas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知从哪里拿来的——和平鸽们从学生会长手中的礼帽中飞了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知從哪裡拿來的——和平鴿們從學生會長手中的禮帽中飛了出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00228",
		linknext = "0062_00230",
		line = 2875,
	},
	["0062_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es imposible que hayan tantas adentro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是绝对无法容纳在帽子里的数量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是絕對無法容納在帽子裡的數量。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00229",
		linknext = "0062_00231",
		line = 2885,
	},
	["0062_00231"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0126", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“¡Pero qué maravilla, Touka-chan! ¡No dejaste que tu odio hacia los animales te impidiera sacarlos de tu sombrero!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哇〜桐香酱好厉害！明明一直被动物讨厌，现在终于可以放出鸽子了呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哇〜桐香醬好厲害！明明一直被動物討厭，現在終於可以放出鴿子了呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00230",
		linknext = "0062_00232",
		line = 2898,
	},
	["0062_00232"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No sabía que ella también podía hacer ese tipo de trucos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“学生会长连那种魔术也会啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「學生會長連那種魔術也會啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00231",
		linknext = "0062_00233",
		line = 2910,
	},
	["0062_00233"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0127", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Es, ante todo, una maga. Nadie se lo espera, por lo que le encanta sorprender a la gente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“倒不如说，那才是桐香酱的本领吧？她喜欢那样让大家大吃一惊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「倒不如說，那才是桐香醬的本領吧？她喜歡那樣讓大家大吃一驚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00232",
		linknext = "0062_00234",
		line = 2924,
	},
	["0062_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que todavía no se ha acostumbrado a manejar las palomas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“不过好像还不太习惯鸽子”中队长又加了一句。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「不過好像還不太習慣鴿子」中隊長又加了一句。",
