				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero solo me dedica esa sonrisa inocente y no puedo preocuparme más.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，她还是天真地笑着，只为了让我不要在意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，她還是天真地笑著，只為了讓我不要在意。",
					{"rt2"},
				},
			},
