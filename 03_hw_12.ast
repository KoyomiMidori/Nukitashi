			},
		},
		text = {
			vo = {
				{"vo", file="hinami1246", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mm... ¿eh? ¡¿T-Tachibana-kun?! ¿De verdad eres tú? ¡Estás despierto! ¿Estás bien? ¡Asane-chan pensaba que tenías una lesión en la cabeza y estuvo llorando toda la noche!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……嗯？橘、橘君！？是橘君！已经可以起来了吗麻沙音酱哭着担心你的头呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……嗯？橘、橘君！？是橘君！已經可以起來了嗎麻沙音醬哭著擔心你的頭呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00031",
		linknext = "0062_00033",
		line = 402,
	},
	["0062_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está tan nerviosa que no puedo evitar sonreír.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一起床就是混乱不堪的一句话，我不禁笑了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一起床就是混亂不堪的一句話，我不禁笑了出來。",
					{"rt2"},
				},
			},
