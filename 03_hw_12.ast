	["0062_00348"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=500, mode=3, x=-100, y=0},
		{"fgact", ch="仁浦", id=10, act="移動", x=100, y=0, time=700},
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aren't you... Governor Hitoura?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是——仁浦县知事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是——仁浦縣知事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00347",
		linknext = "0062_00349",
		line = 4396,
	},
	["0062_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's the one responsible for establishing the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是制定变态条例的罪魁祸首。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是制定變態條例的罪魁禍首。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00348",
		linknext = "0062_00350",
		line = 4406,
	},
	["0062_00350"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The very source of the evil I seek to destroy upon this island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"创造出让我们反对这个岛的理由，的万恶根源。",
					{"rt2"},
				},
			},
			tw = {
				{
					"創造出讓我們反對這個島的理由，的萬惡根源。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00349",
		linknext = "0062_00351",
		line = 4416,
	},
	["0062_00351"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0002", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Good evening. No, perhaps I should say nice to meet you, Tachibana Junnosuke-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“晚上好……不，应该说初次见面吧——橘淳之介君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「晚上好……不，應該說初次見面吧——橘淳之介君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00350",
		linknext = "0062_00352",
		line = 4428,
	},
	["0062_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How do you know my name?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……为什么知道我的名字。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……為什麼知道我的名字。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00351",
		linknext = "0062_00353",
		line = 4440,
	},
	["0062_00353"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0003", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It would be uncouth as governor to not even know the name of my savior, don't you think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这是当然的吧？如果连恩人的名字都记不住的话，就做不了县知事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這是當然的吧？如果連恩人的名字都記不住的話，就做不了縣知事了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00352",
		linknext = "0062_00354",
		line = 4452,
	},
	["0062_00354"] = {
		{"bg", id=1, file="bg17_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00107", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0004", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“However, I'm glad you came outside. I wanted to see you, but going inside would cause more of an uproar than I would like.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不过，你在外面真是帮大忙了。虽然我是来见你的……可是如果进去引起骚乱就不好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不過，你在外面真是幫大忙了。雖然我是來見你的……可是如果進去引起騷亂就不好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00353",
		linknext = "0062_00355",
		line = 4467,
	},
	["0062_00355"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You came to see me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是来见我的——怎么说？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是來見我的——怎麼說？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00354",
		linknext = "0062_00356",
		line = 4478,
	},
	["0062_00356"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0005", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Is it not only natural to want to get to know the one who saved my life, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“想跟救过自己的男人说话……想知道对方的事情，这是件不可思议的事情吗，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「想跟救過自己的男人說話……想知道對方的事情，這是件不可思議的事情嗎，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00355",
		linknext = "0062_00357",
		line = 4492,
	},
	["0062_00357"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, you have a point.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……的确，也许你说得对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……的確，也許你說得對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00356",
		linknext = "0062_00358",
		line = 4503,
	},
	["0062_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This chance meeting has me off balance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"出其不意的邂逅，让我内心躁动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"出其不意的邂逅，讓我內心躁動。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00357",
		linknext = "0062_00359",
		line = 4513,
	},
	["0062_00359"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've seen him more than enough times around the island, on TV and on posters, and I've learned a bit about him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通过电视和海报看了好几遍的男人——我还以为我会有些熟悉他。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通過電視和海報看了好幾遍的男人——我還以為我會有些熟悉他。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00358",
		linknext = "0062_00360",
		line = 4523,
	},
	["0062_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In person, though, he's a whole different beast. I can't read him at all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是一这样直接见面，我根本无法读懂他的内心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是一這樣直接見面，我根本無法讀懂他的內心。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00359",
		linknext = "0062_00361",
		line = 4533,
	},
	["0062_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, wouldn't you be better off speaking with the disciplinary committee president instead? She was there too, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……如果是那样的话，比起我，跟风纪委员长聊天不是更好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……如果是那樣的話，比起我，跟風紀委員長聊天不是更好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00360",
		linknext = "0062_00362",
		line = 4544,
	},
	["0062_00362"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0006", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“There is no need. I manage both the SS and the SHO, and I know most of what goes on in both.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“没那个必要。SS和SHO都是我的组织，我知道大致的情况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「沒那個必要。SS和SHO都是我的組織，我知道大致的情況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00361",
		linknext = "0062_00363",
		line = 4556,
	},
	["0062_00363"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0007", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I looked into you a little, as well. Despite being a cadet, you were instrumental in resolving yesterday's incident. Hmm, I'm sure you've been extensively praised already.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我也多少调查了一下你的事情。明明还是个训练生，但不久前的活跃……呵，一定被大家捧上天了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我也多少調查了一下你的事情。明明還是個訓練生，但不久前的活躍……呵，一定被大家捧上天了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00362",
		linknext = "0062_00364",
		line = 4570,
	},
	["0062_00364"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was really just a coincidence that I was there at all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那只是……偶然在场而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那隻是……偶然在場而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00363",
		linknext = "0062_00365",
		line = 4582,
	},
	["0062_00365"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0008", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That may be so, but the fact still remains that you were the one to seize upon it and make the most of the situation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是偶然吗……但是，能把握住偶然，也是因为你自身有实力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是偶然嗎……但是，能把握住偶然，也是因為你自身有實力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00364",
		linknext = "0062_00366",
		line = 4598,
	},
	["0062_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His words are strangely persuasive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他的话有奇妙的说服力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他的話有奇妙的說服力。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00365",
		linknext = "0062_00367",
		line = 4608,
	},
	["0062_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Where does his charisma come from? Is it his title, his gentle demeanor, or that powerful yet quiet voice?",
					{"rt2"},
				},
			},
			cn = {
				{
					"县知事的职衔，平静的言谈举止和穿透力高的低音——是这些赋予了语言说服力的吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"縣知事的職銜，平靜的言談舉止和穿透力高的低音——是這些賦予了語言說服力的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00366",
		linknext = "0062_00368",
		line = 4618,
	},
	["0062_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't help but be suspicious, but his words do ring with truth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道是为什么——但他说的话，会让人信以为真。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道是為什麼——但他說的話，會讓人信以為真。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00367",
		linknext = "0062_00369",
		line = 4628,
	},
	["0062_00369"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0009", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Still, to think that the SS would establish a unique quota to allow a rookie such as yourself to join. She truly does some intriguing things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是，SS会设置新的位置允许你这样的少年入队……那姑娘也是干了很有趣的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是，SS會設置新的保障名額允許你這樣的少年入隊……那姑娘也是幹了很有趣的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00368",
		linknext = "0062_00370",
		line = 4642,
	},
	["0062_00370"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You even know about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你也知道这件事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你也知道這件事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00369",
		linknext = "0062_00371",
		line = 4654,
	},
	["0062_00371"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0010", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Indeed. I'm sure a young man in your position has many difficulties living on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊。你这样的少年，在这个岛生活应该很艰难吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊。你這樣的少年，在這個島生活應該很艱難吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00370",
		linknext = "0062_00372",
		line = 4668,
	},
	["0062_00372"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's no sarcasm or derision in his voice, but no compassion, either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既不是嘲讽，也不是同情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既不是嘲諷，也不是同情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00371",
		linknext = "0062_00373",
		line = 4678,
	},
	["0062_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's simply making an observation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“感想”这个词更适合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「感想」這個詞更適合。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00372",
		linknext = "0062_00374",
		line = 4688,
	},
	["0062_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is he truly the man responsible?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这真的是导致青蓝岛变成这样的罪魁祸首说的话吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這真的是導致青藍島變成這樣的罪魁禍首說的話嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00373",
		linknext = "0062_00375",
		line = 4698,
	},
	["0062_00375"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the person who imposed the insane perverted sex law on this island?",
					{"rt2"},
				},
			},
			cn = {
				{
					"就是这个人，在岛上制定了变态条例这种乱七八糟的东西吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"就是這個人，在島上制定了變態條例這種亂七八糟的東西嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00374",
		linknext = "0062_00376",
		line = 4708,
	},
	["0062_00376"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm having a hard time believing it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我根本无法相信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我根本無法相信。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00375",
		linknext = "0062_00377",
		line = 4718,
	},
	["0062_00377"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Governor, what do you think of the perverted sex law?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事——对于变态条例，你是怎么想的呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事——對於變態條例，你是怎麼想的呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00376",
		linknext = "0062_00378",
		line = 4730,
	},
	["0062_00378"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Without thinking, I ask the question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"注意到时，自己已经这样问了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"注意到時，自己已經這樣問了。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00377",
		linknext = "0062_00379",
		line = 4740,
