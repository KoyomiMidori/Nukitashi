	["0062_00340"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Leaving the party and stepping outside, I feel the pleasant evening breeze.",
					{"rt2"},
				},
			},
			cn = {
				{
					"走出宴会会场后，一股惬意的夜风扑面而来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"走出宴會會場後，一股愜意的夜風撲面而來。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00339",
		linknext = "0062_00341",
		line = 4303,
	},
	["0062_00341"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just came here to enjoy myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我来这里明明纯粹是为了享受——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我來這裡明明純粹是為了享受——」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00340",
		linknext = "0062_00342",
		line = 4315,
	},
	["0062_00342"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since I joined the SS, I haven't been able to properly relax.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要在SS里，我就怎样都无法放松心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要在SS裡，我就怎樣都無法放鬆心情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00341",
		linknext = "0062_00343",
		line = 4325,
	},
	["0062_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could deal with it if it were just due to my natural disgust towards them. As part of the Anti-Copulation Front, it stands to reason that it would never feel right for me to be part of the SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果那只是厌恶感的话倒还好。身为反交尾势力的我，对SS表现出拒绝是理所当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果那隻是厭惡感的話倒還好。身為反交尾勢力的我，對SS表現出拒絕是理所當然的。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00342",
		linknext = "0062_00344",
		line = 4335,
	},
	["0062_00344"] = {
