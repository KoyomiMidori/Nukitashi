				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Sin embargo, me alegra que hayas salido. Quería verte, pero entrar habría causado más revuelo del que me gustaría.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不过，你在外面真是帮大忙了。虽然我是来见你的……可是如果进去引起骚乱就不好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不過，你在外面真是幫大忙了。雖然我是來見你的……可是如果進去引起騷亂就不好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00353",
		linknext = "0062_00355",
		line = 4467,
	},
	["0062_00355"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Viniste a verme?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是来见我的——怎么说？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是來見我的——怎麼說？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00354",
		linknext = "0062_00356",
		line = 4478,
	},
	["0062_00356"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0005", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“¿No es natural querer conocer a la persona que me salvó la vida, joven?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“想跟救过自己的男人说话……想知道对方的事情，这是件不可思议的事情吗，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「想跟救過自己的男人說話……想知道對方的事情，這是件不可思議的事情嗎，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00355",
		linknext = "0062_00357",
		line = 4492,
	},
	["0062_00357"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……的确，也许你说得对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……的確，也許你說得對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00356",
		linknext = "0062_00358",
		line = 4503,
	},
	["0062_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Este encuentro fortuito me tiene desconcertado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"出其不意的邂逅，让我内心躁动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"出其不意的邂逅，讓我內心躁動。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00357",
		linknext = "0062_00359",
		line = 4513,
	},
	["0062_00359"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo he visto muchas veces por la isla, en la tele y en carteles, y he aprendido un poco sobre él.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通过电视和海报看了好几遍的男人——我还以为我会有些熟悉他。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通過電視和海報看了好幾遍的男人——我還以為我會有些熟悉他。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00358",
		linknext = "0062_00360",
		line = 4523,
	},
	["0062_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero en persona es completamente diferente. No puedo entenderlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是一这样直接见面，我根本无法读懂他的内心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是一這樣直接見面，我根本無法讀懂他的內心。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00359",
		linknext = "0062_00361",
		line = 4533,
	},
	["0062_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así, ¿no sería mejor que hablaras con la presidenta del comité de moral pública? Ella también estuvo ahí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……如果是那样的话，比起我，跟风纪委员长聊天不是更好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是……如果是那樣的話，比起我，跟風紀委員長聊天不是更好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00360",
		linknext = "0062_00362",
		line = 4544,
	},
	["0062_00362"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0006", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“No hace falta. Administro la SS y la OSS, y estoy al tanto de casi todo lo que ocurre en ambos lados.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“没那个必要。FS和SHO都是我的组织，我知道大致的情况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「沒那個必要。FS和SHO都是我的組織，我知道大致的情況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00361",
		linknext = "0062_00363",
		line = 4556,
	},
	["0062_00363"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0007", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“También investigué un poco sobre ti. A pesar de ser un cadete, fuiste fundamental para resolver el incidente de ayer. Mmm, seguro ya te han elogiado mucho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我也多少调查了一下你的事情。明明还是个训练生，但不久前的活跃……呵，一定被大家捧上天了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我也多少調查了一下你的事情。明明還是個訓練生，但不久前的活躍……呵，一定被大家捧上天了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00362",
		linknext = "0062_00364",
		line = 4570,
	},
	["0062_00364"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“De veras que solo fue una coincidencia.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那只是……偶然在场而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那隻是……偶然在場而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00363",
		linknext = "0062_00365",
		line = 4582,
	},
	["0062_00365"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00113", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0008", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Puede que sea así, pero el hecho es que fuiste tú quien aprovechó la oportunidad y sacó el máximo partido de la situación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是偶然吗……但是，能把握住偶然，也是因为你自身有实力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是偶然嗎……但是，能把握住偶然，也是因為你自身有實力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00364",
		linknext = "0062_00366",
		line = 4598,
	},
	["0062_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus palabras son extrañamente persuasivas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他的话有奇妙的说服力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他的話有奇妙的說服力。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00365",
		linknext = "0062_00367",
		line = 4608,
	},
	["0062_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿De dónde viene su carisma? ¿Es su título, su comportamiento amable o esa voz potente pero tranquila?",
					{"rt2"},
				},
			},
			cn = {
				{
					"县知事的职衔，平静的言谈举止和穿透力高的低音——是这些赋予了语言说服力的吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"縣知事的職銜，平靜的言談舉止和穿透力高的低音——是這些賦予了語言說服力的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00366",
		linknext = "0062_00368",
		line = 4618,
	},
	["0062_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No dejo de sospechar, pero sus palabras suenan sinceras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道是为什么——但他说的话，会让人信以为真。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道是為什麼——但他說的話，會讓人信以為真。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00367",
		linknext = "0062_00369",
		line = 4628,
	},
	["0062_00369"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0009", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Aun así, pensar que la SS establecería una cuota especial para permitir que un novato como tú se uniera... Se nota que ella hace cosas intrigantes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是，FS会设置新的位置允许你这样的少年入队……那姑娘也是干了很有趣的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是，FS會設置新的保障名額允許你這樣的少年入隊……那姑娘也是幹了很有趣的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00368",
		linknext = "0062_00370",
		line = 4642,
	},
	["0062_00370"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿Incluso sabes eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你也知道这件事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你也知道這件事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00369",
		linknext = "0062_00371",
		line = 4654,
	},
	["0062_00371"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0010", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Así es. Estoy seguro de que un joven en tu situación tiene muchas dificultades para vivir en esta isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊。你这样的少年，在这个岛生活应该很艰难吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊。你這樣的少年，在這個島生活應該很艱難吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00370",
		linknext = "0062_00372",
		line = 4668,
	},
	["0062_00372"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No hay sarcasmo ni burla en su voz, pero tampoco hay compasión.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既不是嘲讽，也不是同情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既不是嘲諷，也不是同情。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00371",
		linknext = "0062_00373",
		line = 4678,
	},
	["0062_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Solo está haciendo un comentario.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“感想”这个词更适合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「感想」這個詞更適合。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00372",
		linknext = "0062_00374",
		line = 4688,
	},
	["0062_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿De verdad es el hombre responsable de todo?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这真的是导致青蓝岛变成这样的罪魁祸首说的话吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這真的是導致青藍島變成這樣的罪魁禍首說的話嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00373",
		linknext = "0062_00375",
		line = 4698,
	},
	["0062_00375"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Esta es la persona que impuso la insana ley súperpervertida?",
					{"rt2"},
				},
			},
			cn = {
				{
					"就是这个人，在岛上制定了变态条例这种乱七八糟的东西吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"就是這個人，在島上制定了變態條例這種亂七八糟的東西嗎？",
					{"rt2"},
				},
			},
		},
