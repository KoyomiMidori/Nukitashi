	["0062_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Although I can't deny that I've thought that as well, from time to time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说实话，我有时也会——虽然真的是极其罕见，但也会这么想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說實話，我有時也會——雖然真的是極其罕見，但也會這麼想。",
					{"rt2"},
				},
			},
		},
