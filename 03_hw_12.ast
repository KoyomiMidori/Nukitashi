		{"fgact", ch="蘭", id=8, act="移動", x=-200, y=0, time=500},
		{"se", id=0, loop=0, file="se_a218"},
		{"text"},
		delay = {
			[200] = {
				{"se", id=0, loop=0, file="se_a218", delay2=200},
			},
		},
		text = {
			vo = {
				{"vo", file="ran0165", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I can't let you do that Onabuta-san! Rei-senpai's been spending a lot of time with Tachibana-kun lately, so if you try to take him for yourself she'll get angry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“吡吡——！！不行哦女部田同学！橘君是礼前辈的爱徒……如果又干奇怪的事情会被骂哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「吡吡——！！不行哦女部田同學！橘君是禮前輩的愛徒……如果又幹奇怪的事情會被罵哦！」",
					{"rt2"},
				},
