		line = 2848,
	},
	["0062_00228"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00107", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
