			},
			cn = {
				{
					"礼前辈的私生活也意外懒散，继续挖掘下去的话，可能谁都有这种正常人的一面吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩的私生活也意外懶散，繼續挖掘下去的話，可能誰都有這種正常人的一面吧。",
					{"rt2"},
				},
