			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lamento haberlas preocupado, pero ya estoy bien. Solo estaba cansado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让你担心了——不过，已经没事了，只是累到睡着了而已。”",
					{"rt2"},
