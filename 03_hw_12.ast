	["0062_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Son idiotas, pero no son malas personas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我真的打从心底觉得他们非常蠢——但他们都不是坏人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我真的打從心底覺得他們非常蠢——但他們都不是壞人。",
					{"rt2"},
