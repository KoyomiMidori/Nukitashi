			},
		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que lo pienso, Rei-senpai lleva un rato mirando hacia aquí de vez en cuando. Parece incómoda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"话说回来，刚才礼前辈就一直盯着这边看。",
					{"rt2"},
				},
			},
			tw = {
				{
					"話說回來，剛才禮前輩就一直盯著這邊看。",
