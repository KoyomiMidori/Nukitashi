		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi tableta está vibrando. La reviso y veo que tengo un mensaje.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我拿起震动的平板，收到了一条短信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我拿起震動的平板，收到了一條短信。",
