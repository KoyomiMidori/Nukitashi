	["0062_00318"] = {
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=5, time=600, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0618", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Zzz... zzz...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呼……呼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呼……呼……」",
