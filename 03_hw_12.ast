	["0062_00269"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0013", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Jodeeer... Qué técnica más increíble... ¡Nunca había visto algo así en mis datos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“唔噢噢……这、这是什么技术……这种技术，我的数据里没有哦……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「唔噢噢……這、這是什麼技術……這種技術，我的數據裡沒有哦……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00268",
		linknext = "0062_00270",
		line = 3380,
	},
	["0062_00270"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0011", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“¡¿No es esa la cuestión?! ¡Que un mago no revela sus trucos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“伯特同学根本就每次都那样说！你倒是说说看有什么数据啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「伯特同學根本就每次都那樣說！你倒是說說看有什麼數據啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00269",
		linknext = "0062_00271",
		line = 3392,
	},
	["0062_00271"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0014", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Uf, no voy a permitir que mi ciencia se doblegue ante este tipo de abuso... ¡Nekobana-kun! ¡Ayúdame ahora mismo! ¡Dame tu poder de impotencia!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“唔……我的科学可不能向这种事屈服……猫橘君！把力量借给我！赐予我阳痿的力量！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「唔……我的科學可不能向這種事屈服……貓橘君！把力量借給我！賜予我陽痿的力量！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00270",
		linknext = "0062_00272",
		line = 3404,
	},
	["0062_00272"] = {
