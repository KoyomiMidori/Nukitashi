	["0062_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta pequeña senpai terminó siendo una verdadera bendición para Asa-chan, ¿verdad?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果没有这位小前辈在场，麻沙酱会多么不安啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果沒有這位小前輩在場，麻沙醬會多麼不安啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00027",
		linknext = "0062_00029",
		line = 345,
	},
	["0062_00029"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
