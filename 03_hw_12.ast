	["0062_00340"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al salir de la fiesta y poner un pie fuera, siento la agradable brisa del anochecer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"走出宴会会场后，一股惬意的夜风扑面而来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"走出宴會會場後，一股愜意的夜風撲面而來。",
