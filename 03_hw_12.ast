	["0062_00379"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, though, his expression doesn't change.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对这样不知天高地厚的问题，仁浦先生的表情也完全没有改变。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對這樣不知天高地厚的問題，仁浦先生的表情也完全沒有改變。",
					{"rt2"},
