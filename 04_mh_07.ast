					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hmm... maybe I got it from my mom? Hehe, still, thinking about it, we've got a lot in common, haven't we?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……可能是妈妈遗传的吧？呵呵……不过这么一想，我们两个可能意外地很像呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……可能是媽媽遺傳的吧？呵呵……不過這麼一想，我們兩個可能意外地很像呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00503",
		linknext = "0084_00505",
		line = 6720,
