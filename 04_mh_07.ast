	["0084_00281"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm not trying to get out of anything, it's just how things are! Nanase, you say something, too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是要逃走，这只是按照常识——奈奈濑也说点什么啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是要逃走，這只是按照常識——奈奈瀨也說點什麼啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00280",
		linknext = "0084_00282",
		line = 3882,
	},
	["0084_00282"] = {
		{"fg", file="nanase_04m_00004", file1="nanase_04m_00106", file2="nanase_04m_00204", path=":fg/nanase_04m/", id=4, lv=5, head="nanase_04m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1976", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“W-Well, I guess I don't really mind going in with you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你、你叫我说些什么……要我和淳泡温泉，我也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你、你叫我說些什麼……要我和淳泡溫泉，我也……」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00281",
		linknext = "0084_00283",
		line = 3895,
	},
	["0084_00283"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00103", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“With me? In the hot spring!? You want to go in with me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和我泡温泉……怎么？难道你想和我一起泡吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和我泡溫泉……怎麼？難道你想和我一起泡嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00282",
		linknext = "0084_00284",
		line = 3907,
	},
	["0084_00284"] = {
		{"fg", file="nanase_04m_00004", file1="nanase_04m_00103", file2="nanase_04m_00204", path=":fg/nanase_04m/", id=4, lv=5, head="nanase_04m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
