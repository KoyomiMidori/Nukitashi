		linkback = "0084_00339",
		linknext = "0084_00341",
		line = 4648,
	},
	["0084_00341"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"By all rights, as a man and her brother, I should have done it, but that's not possible in this condition.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那本来应该是身为男人，身为哥哥的我应该做的——但这种情况下没办法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那本來應該是身為男人，身為哥哥的我應該做的——但這種情況下沒辦法。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00340",
		linknext = "0084_00342",
		line = 4658,
	},
	["0084_00342"] = {
		{"text"},
		text = {
