			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, sure! Clearly you don't give a shit about a slut like me! So you won't care if we go in together either, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……！对，反正我是婊子！你也不会对婊子有任何想法吧！？这样的话一起泡也没关系对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……！對，反正我是婊子！你也不會對婊子有任何想法吧！？這樣的話一起泡也沒關係對吧？」",
					{"rt2"},
				},
			},
		},
