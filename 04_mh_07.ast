	["0084_00027"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don't get the Seiran Islanders' way of thinking but I do understand what she's saying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这感觉青蓝岛的人也许不会懂，但有了刚刚的说明我就明白了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這感覺青藍島的人也許不會懂，但有了剛剛的說明我就明白了。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00026",
		linknext = "0084_00028",
		line = 368,
	},
	["0084_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Between seeing the students starting out with sexual, perverted events and regular, wholesome events, which would do a better job of inciting the visitors' lust?",
					{"rt2"},
				},
			},
			cn = {
				{
					"在色情竞技中表现出色情狂姿态的学生和在普通竞技中健康地运动的学生——究竟谁比较容易煽动情欲？",
					{"rt2"},
				},
			},
			tw = {
				{
					"在色情競技中表現出色情狂姿態的學生和在普通競技中健康地運動的學生——究竟誰比較容易煽動情慾？",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00027",
		linknext = "0084_00029",
		line = 378,
	},
	["0084_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The latter, without question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"用不着考虑——是后者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"用不著考慮——是後者。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00028",
		linknext = "0084_00030",
		line = 388,
	},
	["0084_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"People want to defile something pure, to get a kind of 'before and after' experience. It's how they are.",
					{"rt2"},
				},
			},
			cn = {
				{
					"越漂亮的东西越想玷污——人类有这种心理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"越漂亮的東西越想玷污——人類有這種心理。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00029",
		linknext = "0084_00031",
		line = 398,
	},
	["0084_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seeing these young students going between standard, innocent sporting events alternating with utter lechery, what would that make the spectators think?",
					{"rt2"},
				},
			},
			cn = {
				{
					"留着青春汗水的健全学生和淫乱的学生轮流看过的观众，到底会抱有什么想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"留著青春汗水的健全學生和淫亂的學生輪流看過的觀眾，到底會抱有什麼想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00030",
		linknext = "0084_00032",
		line = 408,
	},
	["0084_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Clearly they'd want to see the wholesome students engaging in debauchery.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毫无疑问，是会想看健全学生的淫乱样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"毫無疑問，是會想看健全學生的淫亂樣子。",
					{"rt2"},
				},
