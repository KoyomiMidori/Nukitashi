	["0084_00454"] = {
		{"se", id=0, loop=0, file="se_a192"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The only sound echoing through the deserted street is her bicycle. It seems louder than usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有推自行车的声音奇妙地大声响着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有推自行車的聲音奇妙地大聲響著。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00453",
		linknext = "0084_00455",
		line = 6112,
	},
	["0084_00455"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This state of affairs is absolutely intolerable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种气氛实在让人受不了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種氣氛實在讓人受不了。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00454",
		linknext = "0084_00456",
		line = 6122,
	},
	["0084_00456"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I need to strike up some kind of conversation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一定要找个话题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一定要找個話題。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00455",
		linknext = "0084_00457",
		line = 6132,
	},
	["0084_00457"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh... This isn't the usual route to your place, is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊——今天走的路和平时不同呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊——今天走的路和平時不同呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00456",
		linknext = "0084_00458",
		line = 6144,
	},
	["0084_00458"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00107", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0887", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, yeah. Since I'm on a diet, I'm taking the long way for the extra exercise. I also switched to a heavier bicycle than my beloved Tanizaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊……是的。为了减肥，我决定绕远路。想说可以稍微多运动一些……骑的自行车也换成了比谷崎先生更重的太宰。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊……是的。為了減肥，我決定繞遠路。想說可以稍微多運動一些……騎的自行車也換成了比谷崎先生更重的太宰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00457",
		linknext = "0084_00459",
		line = 6158,
	},
	["0084_00459"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ooh, that's great. Nice work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哎……好厉害啊。很努力嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哎……好厲害啊。很努力嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00458",
		linknext = "0084_00460",
		line = 6169,
	},
	["0084_00460"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Using a heavier bicycle will probably help her build muscle and make her heavier, but there's no need to point that out right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然觉得骑沉重的自行车反而会增加肌肉而让体重变重——但现在的精神状态让我说不出口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然覺得騎沉重的自行車反而會增加肌肉而讓體重變重——但現在的精神狀態讓我說不出口。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00459",
		linknext = "0084_00461",
		line = 6179,
	},
	["0084_00461"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00113", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
