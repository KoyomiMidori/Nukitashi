					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過……雖然沒有美岬那麼嚴重，不過偶爾做肌肉訓練的話確實會有感覺……比我想像地還要出汗……」",
