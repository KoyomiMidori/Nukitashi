		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've always had an intellectual curiosity about Hotori's body; like, I wanted to know what it looked like and what it felt like and other stuff like that there...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然从很早以前就认为畔的身材会引起求知欲并在不知不觉中产生了好奇心所以也不是没有想过要去了解它的实际情况——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然從很早以前就認為畔的身材會引起求知欲並在不知不覺中產生了好奇心所以也不是沒有想過要去了解它的實際情況——",
					{"rt2"},
				},
			},
		},
