				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huuh? Y-You think so?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶……是、是吗……？”",
					{"rt2"},
