				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The girls leave the hot spring behind and go somewhere else.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女孩子们从露天温泉渐渐远去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"女孩子們從露天溫泉漸漸遠去。",
