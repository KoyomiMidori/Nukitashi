		linkback = "0084_00110",
		linknext = "0084_00112",
		line = 1480,
	},
	["0084_00112"] = {
		{"fg", file="misaki_02m_00004", file1="misaki_02m_00128", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Being face-to-face with her like this makes me a bit self-conscious, and I can't get the right words out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正想与她面对面说话时，我突然过剩地意识到对方，不知不觉间变得口齿不清。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正想與她面對面說話時，我突然過剩地意識到對方，不知不覺間變得口齒不清。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00111",
		linknext = "0084_00113",
		line = 1492,
	},
	["0084_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, seeing her in a swimsuit, she's not anywhere near what I'd call fat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，就算再看一次身着泳装的畔——也完全没办法说她是个胖子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，就算再看一次身著泳裝的畔——也完全沒辦法說她是個胖子。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00112",
		linknext = "0084_00114",
		line = 1502,
	},
	["0084_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe a bit plump by Seiran Island standards, but she looks pretty normal to me. Hell, I'd say she's actually perfect.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从青蓝岛的标准来说可能有些胖，但从我的标准来看是一般，或者说是最好也不为过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從青藍島的標準來說可能有些胖，但從我的標準來看是一般，或者說是最好也不為過。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00113",
		linknext = "0084_00115",
		line = 1512,
	},
	["0084_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Any extra weight is probably muscle from riding that bicycle all the time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说她这样会比其他女孩重，那那些一定不是赘肉，而是骑自行车时练出的肌肉吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說她這樣會比其他女孩重，那那些一定不是贅肉，而是騎自行車時練出的肌肉吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00114",
		linknext = "0084_00116",
		line = 1522,
	},
	["0084_00116"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00104", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
