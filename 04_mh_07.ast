		{"bg", id=16, file="apstart6_00000", x=0, y=0, lv=5, path=":cg/apstart6/", sync=0, ev=1, time=300, alpha=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"fg", file="hinami_02f_00004", file1="hinami_02f_00109", file2="hinami_02f_00201", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1985", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, ooh! Hot springs!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦、哦哦哦……是温泉——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦、哦哦哦……是溫泉——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00260",
		linknext = "0084_00262",
		line = 3618,
	},
	["0084_00262"] = {
		{"fg", file="nanase_04f_00004", file1="nanase_04f_00109", path=":fg/nanase_04f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1975", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh right, I remember this being on the cliff route.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“想想确实有呢……在这条断崖路线上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「想想確實有呢……在這條斷崖路線上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00261",
		linknext = "0084_00263",
		line = 3631,
	},
	["0084_00263"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=4, time=300, x=0, y=0, alphadel=1, style="reset"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We call it that because it leads right to the cliff.",
					{"rt2"},
				},
			},
			cn = {
				{
					"断崖路线——正如其名，是通向断崖的路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"斷崖路線——正如其名，是通向斷崖的路。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00262",
		linknext = "0084_00264",
		line = 3643,
	},
	["0084_00264"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since it doesn't really help us get home, I forgot about it, but there's a natural open-air hot spring here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为是不能回家的线路，所以完全被排除在外，但这里有天然的露天温泉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為是不能回家的線路，所以完全被排除在外，但這裡有天然的露天溫泉。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00263",
		linknext = "0084_00265",
		line = 3653,
	},
	["0084_00265"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=18, time=600, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="misaki_01m_00004", file2="misaki_01m_00201", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00004", file1="jun_01f_00119", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't remember ever mentioning this to you. How'd you know about it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我应该没跟畔说过……你知道得真清楚啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我應該沒跟畔說過……你知道得真清楚啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00264",
		linknext = "0084_00266",
		line = 3668,
	},
	["0084_00266"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0850", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The old folks in my neighborhood have mentioned a cave with hot springs around here. Apparently they used to use them a lot, once upon a time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“之前我有听到附近的爷爷们聊到关于洞穴的温泉。据说以前经常使用……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「之前我有聽到附近的爺爺們聊到關於洞穴的溫泉。據說以前經常使用……」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00265",
		linknext = "0084_00267",
		line = 3680,
	},
	["0084_00267"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It doesn't look unused, so that makes sense.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……我就觉得有人工的感觉，原来如此。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……我就覺得有人工的感覺，原來如此。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00266",
		linknext = "0084_00268",
		line = 3692,
	},
	["0084_00268"] = {
		{"fg", file="hinami_02m_00004", file1="hinami_02m_00102", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1986", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I haven't been to a hot spring in ages. Let's get in!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好久没泡温泉了……快进去吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好久沒泡溫泉了……快進去吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00267",
		linknext = "0084_00269",
		line = 3705,
	},
	["0084_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. I'll get out of your hair and you guys can go on in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……那我就到看不见的地方，你们先进去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……那我就到看不見的地方，你們先進去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00268",
		linknext = "0084_00270",
		line = 3716,
	},
	["0084_00270"] = {
		{"fg", file="hinami_02m_00004", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1987", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You're not coming in with us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君不一起进来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君不一起進來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00269",
		linknext = "0084_00271",
		line = 3730,
	},
	["0084_00271"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00106", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I'm a guy, and you're all girls, so I'll go in by myself later.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那当然……因为我是男的，过后我一个人进。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那當然……因為我是男的，過後我一個人進。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00270",
		linknext = "0084_00272",
		line = 3742,
	},
	["0084_00272"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00109", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0851", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? No fair! In that case, I'm fat, so I'll go in by myself later, too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦，好狡猾……那我也因为是胖子，所以过后一个人进……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦，好狡猾……那我也因為是胖子，所以過後一個人進……！」",
