	["0084_00509"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since she just got out of the bath, she's unusually hot, and she's got a blush to her face that makes her look like she's in love, but she's acting perfectly calm.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许是因为洗完澡的缘故，畔的身体奇妙地发热，让人以为她坠入了爱河，但我还是故作镇定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許是因為洗完澡的緣故，畔的身體奇妙地發熱，讓人以為她墜入了愛河，但我還是故作鎮定。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00508",
		linknext = "0084_00510",
		line = 6786,
	},
	["0084_00510"] = {
