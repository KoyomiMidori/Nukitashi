	["0084_00017"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1966", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“As Wata said yesterday, the olympiad has some normal events like sprinting, relays, ball tossing, and the like.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“昨天渡酱也说过了吧？所谓的体欲节，其实也是有短跑、接力、投球之类的普通竞技。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「昨天渡醬也說過了吧？所謂的體欲節，其實也是有短跑、接力、投球之類的普通競技。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00016",
		linknext = "0084_00018",
		line = 241,
	},
	["0084_00018"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Really? On Seiran Island, that's basically unheard-of!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……？怎么可能，明明是青蓝岛……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……？怎麼可能，明明是青藍島……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00017",
		linknext = "0084_00019",
		line = 253,
	},
	["0084_00019"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1967", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's like that because, while it's an event for students, it's meant for visitors as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“当然是有理由的。虽然体欲节看起来像学生活动，但实际上也是面向游客的活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「當然是有理由的。雖然體欲節看起來像學生活動，但實際上也是面向遊客的活動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00018",
		linknext = "0084_00020",
		line = 265,
	},
	["0084_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's a tourist attraction? What the hell?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“面向游客……难道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「面向遊客……難道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00019",
		linknext = "0084_00021",
		line = 277,
	},
	["0084_00021"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00104", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0795", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The entire event leads up to a massive orgy for both students and visitors that uses the entire school grounds. It's called the 'Great Orgy Royale'.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的。有个项目是所有学生和观众使用整个场地进行大乱交。名字也叫‘性乱大合战’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的。有個項目是所有學生和觀眾使用整個場地進行大亂交。名字也叫『性亂大合戰』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00020",
		linknext = "0084_00022",
		line = 292,
	},
	["0084_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What the fuck is wrong with this island?",
					{"rt2"},
				},
			},
			cn = {
				{
					"疯了——这岛果然疯了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"瘋了——這島果然瘋了。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00021",
		linknext = "0084_00023",
		line = 302,
	},
	["0084_00023"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0796", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“The regular events are just to show off the students so the visitors can pick which ones they'd like to have sex with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“为了让客人找到想做爱的学生，才会有一般的竞技。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「為了讓客人找到想做愛的學生，才會有一般的競技。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00022",
		linknext = "0084_00024",
		line = 314,
	},
	["0084_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know it's weird for me to bring this up, but if the entire purpose is to let visitors pick who they wanna fuck, why not show them off with the sexual events?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然我说也有点那啥……但如果只是要展示的话，色情竞技不也可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然我說也有點那啥……但如果只是要展示的話，色情競技不也可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00023",
		linknext = "0084_00025",
		line = 326,
	},
	["0084_00025"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0797", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hmm... It's just speculation, but maybe the audience prefers it this way? Maybe they don't want to see them doing the sexual competitions at the start.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯……我也这么觉得……但是以倾向来说，没参加色情竞技的学生更受游客欢迎。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯……我也這麼覺得……但是以傾向來說，沒參加色情競技的學生更受遊客歡迎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00024",
		linknext = "0084_00026",
		line = 340,
	},
	["0084_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
