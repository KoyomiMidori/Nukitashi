	["0084_00012"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00120", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1305", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“He wants you to think that, but that laugh usually means he doesn't have any actual response.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“通常哥哥会得意地笑，都是为了掩饰自己什么都没想……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「通常哥哥會得意地笑，都是為了掩飾自己什麼都沒想……」",
