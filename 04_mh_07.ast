		line = 1548,
	},
	["0084_00118"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00106", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0812", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I... may be fat, I may be getting fatter, and I may be a fatty-monster right now, but I'm going to work hard on my diet! Will you help me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“现在的我……可能是个胖子，很肥，是只赘肉妖怪……但我会努力减肥的……！你能帮我吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「現在的我……可能是個胖子，很肥，是只贅肉妖怪……但我會努力減肥的……！你能幫我嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00117",
		linknext = "0084_00119",
		line = 1562,
	},
	["0084_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
