	["0084_00259"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We followed a third path, the one that didn't go to either the rear gate or to the hill behind the school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和后门路线与后山路线不同，我们就这样一边交谈一边来到第三条路线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和後門路線與後山路線不同，我們就這樣一邊交談一邊來到第三條路線。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00258",
		linknext = "0084_00260",
		line = 3584,
	},
	["0084_00260"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
