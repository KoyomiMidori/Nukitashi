	["0084_00003"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks for providing your regular confirmation. What a great senior you are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢你一直以来的确认，不愧是前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝你一直以來的確認，不愧是前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00002",
		linknext = "0084_00004",
		line = 53,
	},
	["0084_00004"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“For today's agenda, there's something I'd like to suggest: We should train up in preparation for the olympiad this weekend.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——那么，有关今天的活动内容，我想为了周末的体欲节进行训练。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——那麼，有關今天的活動內容，我想為了周末的體欲節進行訓練。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00003",
		linknext = "0084_00005",
		line = 68,
	},
	["0084_00005"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1975", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh! Oh? Huh? Why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦——！……哦？诶，为什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦——！……哦？欸，為什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00004",
		linknext = "0084_00006",
		line = 85,
	},
	["0084_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Think about it. If we enter the olympiad being weak and unathletic, we may stand out to the SS for all the wrong reasons.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你想想看，如果有人无精打采地参加体欲节的话，或许会被FS盯上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你想想看，如果有人無精打采地參加體欲節的話，或許會被FS盯上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00005",
		linknext = "0084_00007",
		line = 97,
	},
	["0084_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We need to make sure Hotori is able to infiltrate the student council room successfully. The best way the rest of us can help her is by blending in as much as we can.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们的目的是找机会溜进学生会室——为了让作战成功，为了不被怀疑，表面上就必须认真进行竞技对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們的目的是找機會溜進學生會室——為了讓作戰成功，為了不被懷疑，表面上就必須認真進行競技對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00006",
		linknext = "0084_00008",
		line = 109,
	},
	["0084_00008"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00105", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1304", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You, uh, know the olympiad events will all be sex shit, right? You really wanna be a part of that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但体欲节的项目是色情竞技吧……真的要认真参加那种竞技吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但體欲節的項目是色情競技吧……真的要認真參加那種競技嗎？」",
					{"rt2"},
				},
			},
		},
