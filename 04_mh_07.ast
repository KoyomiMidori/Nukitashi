			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They've got nothing to do with each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个和那个不一样吧……？”",
