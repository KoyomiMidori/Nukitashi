	["0084_00352"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The fuss has been moved, and now we're alone in a suddenly quiet hot spring.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才的喧哗声不知所踪——两人独处后，露天浴池突然变得静寂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才的喧嘩聲不知所踪——兩人獨處後，露天浴池突然變得靜寂。",
					{"rt2"},
				},
