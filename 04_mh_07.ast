				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Make sure you don't overdo it with your diet, okay? Go to bed early tonight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了减肥而勉强自己可是大忌。你一定很累了，今天要早点休息。”",
