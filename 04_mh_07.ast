	["0084_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Honestly, part of why I had them bring their swimsuits was so Hotori had an idea of her starting point for her diet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说实话，呼吁大家带泳衣也是为了提高畔的减肥意识。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說實話，呼籲大家帶泳衣也是為了提高畔的減肥意識。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00119",
		linknext = "0084_00121",
		line = 1584,
	},
	["0084_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As leader, I need to push her as much as she can, while providing as much support as possible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为把重要的事情推到了她身上，所以作为队长的我应该尽可能地给予帮助。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為把重要的事情推到了她身上，所以作為隊長的我應該盡可能地給予幫助。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00120",
		linknext = "0084_00122",
		line = 1594,
	},
	["0084_00122"] = {
