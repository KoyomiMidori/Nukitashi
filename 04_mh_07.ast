	},
	["0084_00110"] = {
		{"cgdel", id=2, lv=5, time=300, alphadel=1},
		{"fg", file="misaki_02m_00004", file1="misaki_02m_00125", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0810", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh!? A-A-Am I so disgusting it's gonna kill you!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“诶！？丑、丑到害死你吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸！？醜、醜到害死你嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00109",
		linknext = "0084_00111",
		line = 1468,
	},
	["0084_00111"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, no, that's not it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——绝对，不是，那个意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——絕對，不是，那個意思。」",
					{"rt2"},
