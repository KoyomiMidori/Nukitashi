		linkback = "0084_00031",
		linknext = "0084_00033",
		line = 418,
	},
	["0084_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fire up their lust like that and then they can let it all out during the Great Orgy Royale at the end.",
