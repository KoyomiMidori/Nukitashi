	["0084_00503"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I often wonder where that optimism of yours comes from.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我还在想你这种积极的态度到底是从哪里来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我還在想你這種積極的態度到底是從哪裡來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00502",
		linknext = "0084_00504",
		line = 6704,
