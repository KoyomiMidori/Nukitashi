	["0084_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I stand up, they're gonna see it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在站起来的话……会被看到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在站起來的話……會被看到。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00334",
		linknext = "0084_00336",
		line = 4582,
	},
	["0084_00336"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, on second thought, could you guys see to her? Just lay her down and she should recover soon enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……抱歉，能不能帮我把她搬出去？让她随便躺着，应该很快就能恢复……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……抱歉，能不能幫我把她搬出去？讓她隨便躺著，應該很快就能恢復……」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00335",
		linknext = "0084_00337",
		line = 4593,
	},
	["0084_00337"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1984", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"非表示", "奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Nanase"},
					"“Roger! Wata, can you support her from that side? There we go!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "奈奈濑"},
					"“了解！渡酱，你能帮我撑着那边吗？……好……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "奈奈瀨"},
					"「了解！渡醬，你能幫我撐著那邊嗎？……好……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00336",
		linknext = "0084_00338",
		line = 4605,
	},
	["0084_00338"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1318", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"非表示", "麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Asane"},
					"“I-I-I-I was literally pressed against Nanase's bare skin-in-in-in... We've basically fu... Wee-ooo-wee-ooo-wee-ooo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "麻沙音"},
					"“奈奈奈奈濑同学的肌肤如此紧贴这这这……这简直就是做……哦哦哦噢噢噢噢噢噢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "麻沙音"},
					"「奈奈奈奈瀨同學的肌膚如此緊貼這這這……這簡直就是做……哦哦哦噢噢噢噢噢噢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00337",
		linknext = "0084_00339",
		line = 4617,
	},
	["0084_00339"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1997", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"非表示", "ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"非表示", "Hinami"},
					"“It just started bleeding harder!? Huh? Why does she look so happy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "雏见"},
					"“她的病情突然恶化了哦！？咦？但是看起来好像很幸福……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"非表示", "雛見"},
					"「她的病情突然惡化了哦！？咦？但是看起來好像很幸福……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00338",
		linknext = "0084_00340",
		line = 4629,
	},
	["0084_00340"] = {
