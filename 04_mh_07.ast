			},
		},
		text = {
			vo = {
				{"vo", file="misaki0888", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I can't let everyone see this ugly, flabby body, so I have until the weekend to lose weight... siiiiiigh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“必须在周末之前瘦下来……因为不能给大家看这种丑陋的肉体……唉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「必須在周末之前瘦下來……因為不能給大家看這種醜陋的肉體……唉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00460",
		linknext = "0084_00462",
		line = 6195,
	},
	["0084_00462"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00118", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0889", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You saw it... my chubby body... hahaha... I wanna die. Maybe I should just ride this bike off the cliff into the sea...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“被看到了……被橘同学，看到了我肥胖的身体……哈哈哈……好想死……骑着太宰……跳海吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「被看到了……被橘同學，看到了我肥胖的身體……哈哈哈……好想死……騎著太宰……跳海吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00461",
		linknext = "0084_00463",
		line = 6209,
	},
	["0084_00463"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There's no need for that. This is probably presumptuous of me to say, but don't worry about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“求你了别想不开……虽然我没那个立场……但有必要那么在意吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「求你了別想不開……雖然我沒那個立場……但有必要那麼在意嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00462",
		linknext = "0084_00464",
		line = 6221,
	},
	["0084_00464"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00113", file2="misaki_02m_00204", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0890", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I can't. My ugly body is why I've always been avoiding sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“当然在意啊……我可是因为不想被人看到才一直回避做爱的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「當然在意啊……我可是因為不想被人看到才一直迴避做愛的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00463",
		linknext = "0084_00465",
		line = 6235,
	},
	["0084_00465"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So that's why.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来，畔会如此抗拒做爱是有那样的理由的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，畔會如此抗拒做愛是有那樣的理由的。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00464",
		linknext = "0084_00466",
		line = 6245,
	},
	["0084_00466"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's been going so far out of her way to avoid the sex that litters this entire island just because she doesn't want to be seen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这个到处都在做爱的岛上，只因为讨厌被看到身体，而不断逃避性爱——",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這個到處都在做愛的島上，只因為討厭被看到身體，而不斷逃避性愛——",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00465",
		linknext = "0084_00467",
		line = 6255,
	},
	["0084_00467"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That doesn't sound remotely normal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仔细想想，这不是件普通的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仔細想想，這不是件普通的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00466",
		linknext = "0084_00468",
		line = 6265,
	},
	["0084_00468"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hell, on this island it's even illegal, and I'm sure she knows that well, since she was raised here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛上，那是违反条例的犯罪行为。如果是土生土长的青蓝女孩畔，那种事应该很清楚吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島上，那是違反條例的犯罪行為。如果是土生土長的青藍女孩畔，那種事應該很清楚吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00467",
		linknext = "0084_00469",
		line = 6275,
	},
	["0084_00469"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If she's going so far out of her way even knowing that, her complex must be unbelievably intense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使这样依然不断逃避——那一定是抱有非常强烈的自卑感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使這樣依然不斷逃避——那一定是抱有非常強烈的自卑感。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00468",
		linknext = "0084_00470",
		line = 6285,
	},
	["0084_00470"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00113", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
