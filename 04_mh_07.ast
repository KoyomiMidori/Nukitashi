			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I have to harden up my body to keep up with your muscularity... wah, oops, eek!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“为了不输给肌肉发达的橘同学，我也必须要锻炼身体——哇，啊……呀！？”",
