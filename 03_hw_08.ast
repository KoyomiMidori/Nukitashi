	["0058_00084"] = {
		{"bgm", stop=1},
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=10, mode=3, x=0, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0350", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Jaaa... En serio, por eso te digo que trabajes en tus habilidades de pensamiento crítico. ¿De verdad crees que me pondría a actuar como una sargenta enojada en este ambiente?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唉……真是的……我经常说要锻炼思考能力吧？你觉得那么脏的话可以在大家享乐的地方说出来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唉……真是的……我經常說要鍛煉思考能力吧？你覺得那麼髒的話可以在大家享樂的地方說出來嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00083",
		linknext = "0058_00085",
		line = 1041,
	},
	["0058_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí... tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00084",
		linknext = "0058_00086",
		line = 1053,
	},
	["0058_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Está consciente de lo que pensamos de ella?",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来她有自己在说脏话的自觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來她有自己在說髒話的自覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00085",
		linknext = "0058_00087",
		line = 1063,
	},
	["0058_00087"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0351", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Mi trabajo como instructora es observar tu progreso. Si veo que trabajas admirablemente, te felicitaré.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“而且……我作为教官也在一一观察你们，如果有人很努力……就要好好表扬他。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「而且……我作為教官也在一一觀察你們，如果有人很努力……就要好好表揚他。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00086",
		linknext = "0058_00088",
		line = 1077,
	},
	["0058_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Increíble.",
					{"rt2"},
