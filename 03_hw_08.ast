					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿De verdad puedes negarte?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是……能拒绝的吗？”",
