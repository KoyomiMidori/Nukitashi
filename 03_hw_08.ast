	},
	["0058_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quizás incluso más que el entrenamiento físico. No me apetecía mucho el trabajo de guía, pero al parecer no se me da mal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"体能训练就不用说了，本来对导游一职也有抗拒心态，不过试一试却意外能行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"體能訓練就不用說了，本來對導遊一職也有抗拒心態，不過試一試卻意外能行。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00123",
		linknext = "0058_00125",
		line = 1544,
	},
	["0058_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tadasugawa-senpai incluso me elogió hoy, así que a este ritmo debería poder ganarme su confianza y...",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才也被糺川前辈夸奖了，按照这个状态，要得到信任也——",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才也被糺川前輩誇獎了，按照這個狀態，要得到信任也——",
					{"rt2"},
				},
