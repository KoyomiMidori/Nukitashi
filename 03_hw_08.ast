	["0058_00126"] = {
		{"bgm", stop=1},
		{"fg", file="rei_01f_00001", file1="rei_01f_00103", path=":fg/rei_01f/", id=30, ch="礼", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0356", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“¡¿Qué has dicho?! Entendido, iremos inmediatamente para interceptarlos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你说什么……！？我知道了，我马上处理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你說什麼……！？我知道了，我馬上處理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00125",
		linknext = "0058_00127",
		line = 1568,
	},
	["0058_00127"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=1, file="bg05_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me doy la vuelta y veo a Tadasugawa-senpai, con el rostro pálido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回头一看，糺川前辈的脸色变了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回頭一看，糺川前輩的臉色變了。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00126",
		linknext = "0058_00128",
		line = 1582,
	},
	["0058_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
