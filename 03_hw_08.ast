	["0058_00011"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0003", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“¡Bana-san! ¡Sé que solo somos cadetes y esas cosas, así que deberíamos esforzarnos por convertirnos en miembros oficiales!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“橘同学！虽然我们还是候补生，但是为了成为正式成员努力吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「橘同學！雖然我們還是候補生，但是為了成為正式成員努力吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00010",
		linknext = "0058_00012",
		line = 155,
	},
	["0058_00012"] = {
