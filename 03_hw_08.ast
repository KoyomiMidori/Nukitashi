	},
	["0058_00163"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hablaré con ella. ¿Tienes la sonda de exploración?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——由我来。有检查药吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——由我來。有檢查藥嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00162",
		linknext = "0058_00164",
		line = 2037,
	},
	["0058_00164"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00109", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0162", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡N-No puees hacer eso, Tachibana-kun! ¡Ya se negó y no quiere hablar con la SS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“你、你说由你来，橘君这也……太乱来了！她刚才才拒绝接受检查，而且本来很警戒FS……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「你、你說由你來，橘君這也……太亂來了！她剛才才拒絕接受檢查，而且本來很警戒FS……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00163",
		linknext = "0058_00165",
		line = 2050,
	},
	["0058_00165"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No quiere hablar con la SS. Sin embargo, puedo quitarme esto y pareceré un estudiante normal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“警戒的是FS。但是，只要我不戴",
					{"ruby", text="・・"},
					"这个",
					{"/ruby"},
					"，看起来就只是个学生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「警戒的是FS。但是，只要我不戴",
					{"ruby", text="・・"},
					"這個",
					{"/ruby"},
					"，看起來就只是個學生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00164",
		linknext = "0058_00166",
		line = 2062,
	},
	["0058_00166"] = {
