	["0058_00074"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0346", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Como no puedes participar en actividades reproductivas, es normal que tengas problemas, pero lo has estado haciendo bien. No te desanimes y sigue esforzándote.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我本来以为不能进行性产行为的你可能会遇到什么难堪的情况……但你做得很好，今后也要继续努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我本來以為不能進行性產行為的你可能會遇到什麼難堪的情況……但你做得很好，今後也要繼續努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00073",
		linknext = "0058_00075",
		line = 913,
	},
	["0058_00075"] = {
