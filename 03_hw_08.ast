				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1094", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿De verdad? ¡Bueno, es difícil, pero sé que puedes hacerlo! ¡Si alguna vez necesitas ayuda, estaré ahí para apoyarte!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊……嗯，虽然会很辛苦，但是要加油哦！有困难随时可以依靠我！我会成为橘君的力量的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊……嗯，雖然會很辛苦，但是要加油哦！有困難隨時可以依靠我！我會成為橘君的力量的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00326",
		linknext = "0058_00328",
		line = 4074,
	},
	["0058_00328"] = {
