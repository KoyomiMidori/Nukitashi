				},
			},
			cn = {
				{
					"虽然对岛来说是危机的状况，但是对我来说却是得到FS信任的绝佳机会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然對島來說是危機的狀況，但是對我來說卻是得到FS信任的絕佳機會。",
					{"rt2"},
				},
