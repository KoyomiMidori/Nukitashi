			},
		},
		text = {
			vo = {
				{"vo", file="hinami1069", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Por supuesto! ¿Mmm? ¡Te ves muy feliz! ¡¿Pasó algo bueno?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事没事……嗯？橘君，你今天的脸色比平时都好啊。有什么好事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒事沒事……嗯？橘君，你今天的臉色比平時都好啊。有什麼好事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00246",
		linknext = "0058_00248",
		line = 3064,
	},
	["0058_00248"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? Sí, ¿se me nota?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……啊，都写在脸上了吗？”",
