			ja = {
				{
					name = {"モブ男B", "ムラハメ先輩"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Portador del Demonio Sediento"},
					"“Mis más sinceras disculpas por la espera. ¿Fue usted quien solicitó mi 'Hoja del Demonio Sediente'?”",
