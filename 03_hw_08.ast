		linknext = "0058_00249",
		line = 3076,
	},
	["0058_00249"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Las cosas salieron muy bien con la SS hoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天的活动进行得特别顺利。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天的活動進行得特別順利。」",
					{"rt2"},
				},
