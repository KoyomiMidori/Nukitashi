				{"vo", file="asane1075", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es toda una loli...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哼，果然是萝莉啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哼，果然是蘿莉啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00288",
		linknext = "0058_00290",
		line = 3607,
	},
	["0058_00290"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00118", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=5, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1083", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡No estabas diciendo eso! ¡No soy una loli!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“麻沙音酱说的话不统一啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「麻沙音醬說的話不統一啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00289",
		linknext = "0058_00291",
		line = 3622,
	},
	["0058_00291"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Vamos... El simple hecho de poder comer eso te hace más 'adulta' que Tadasugawa-senpai.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“算了算了……能吃中辣的话，说明渡酱比糺川前辈还像大人了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「算了算了……能吃中辣的話，說明渡醬比糺川前輩還像大人了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00290",
		linknext = "0058_00292",
		line = 3634,
	},
	["0058_00292"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1084", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Dices eso, pero Rei-chan también tiene un lado bastante infantil.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“就算被说比礼酱还像大人……礼酱也有很多孩子气的地方啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「就算被說比禮醬還像大人……禮醬也有很多孩子氣的地方啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00291",
		linknext = "0058_00293",
		line = 3648,
	},
	["0058_00293"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... ¿En serio?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00292",
		linknext = "0058_00294",
		line = 3660,
	},
	["0058_00294"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Tiene un lado infantil?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个人有孩子气的地方吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個人有孩子氣的地方嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00293",
		linknext = "0058_00295",
		line = 3674,
	},
	["0058_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que gritar constantemente sobre pollas y coños es bastante infantil, pero también es algo habitual en esta isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"硬要说的话，就是每件事都硬要扯上鸡巴小穴等淫语显得有点幼稚————但这么说的话，青蓝岛上的人也都是这样……",
					{"rt2"},
				},
			},
			tw = {
				{
					"硬要說的話，就是每件事都硬要扯上肉棒小穴等淫語顯得有點幼稚————但這麼說的話，青藍島上的人也都是這樣……",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00294",
		linknext = "0058_00296",
		line = 3684,
	},
	["0058_00296"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1085", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah, hablando de Rei-chan, dijiste que hoy había pasado algo bueno, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对了。说到礼酱，橘君今天好像发生了什么好事对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對了。說到禮醬，橘君今天好像發生了什麼好事對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00295",
		linknext = "0058_00297",
		line = 3697,
	},
	["0058_00297"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, creo que sí... aunque no es para tanto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，说是这么说……但也不是什么大不了的事情哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，說是這麼說……但也不是什麼大不了的事情哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00296",
		linknext = "0058_00298",
		line = 3709,
	},
	["0058_00298"] = {
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00102", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1086", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Cuéntame, cuéntame!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好想听好想听。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好想聽好想聽。」",
