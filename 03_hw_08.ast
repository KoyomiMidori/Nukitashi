	["0058_00118"] = {
		{"se", id=0, loop=0, file="se_a102"},
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aquí R-1. Tenemos a un civil solicitando a la Hoja del Demonio. Se solicitan refuerzos masculinos inmediatos en mis coordenadas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这里是R-1，有客人想要‘妖屌’。取得位置信息后，要求派遣一名男性器。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這裡是R-1，有客人想要『妖屌』。取得位置資訊後，要求派遣一名男性器。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00117",
		linknext = "0058_00119",
		line = 1475,
	},
	["0058_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de enviar mi solicitud, esperamos unos segundos.",
					{"rt2"},
