					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo, hay un miembro de la SS cuya polla ha sido apodada 'Hoja del Demonio Sediento'.”",
					{"rt2"},
