	["0058_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque no tengo intención de recurrir a ninguna de las medidas extremas que sugirió la Hanamaru menor, ver lo cautelosa que es me hace sentir un poco culpable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我不是花丸妹妹，但她这么表露出戒心，就好像在说她做了什么亏心事一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我不是花丸妹妹，但她這麼表露出戒心，就好像在說她做了什麼虧心事一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00178",
		linknext = "0058_00180",
		line = 2261,
	},
	["0058_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
