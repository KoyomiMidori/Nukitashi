	["0058_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El problema de orden público probablemente ha hecho que la OSS se distribuya de forma más dispersa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO人手不足——果然是因为把人力都用在治安问题上吗？",
