				{
					name = {"礼", "Rei"},
					"“No es eso. Es solo que la gente me dice que les parezco intimidante e inalcanzable, así que pensé que esta linda correa podría contrarrestar un poco esa impresión. Esa es la única razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没那回事……只是因为其他人常说我威压感重很难接近，所以我才想说挂上这种可爱的东西是不是就可以缓和一下……除此之外，我并没有别的意图。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒那回事……只是因為其他人常說我威壓感重很難接近，所以我才想說掛上這種可愛的東西是不是就可以緩和一下……除此之外，我並沒有別的意圖。」",
					{"rt2"},
				},
			},
		},
