		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1073", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ya está listo! Jeje, que lo disfrutes ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“久等了——！呵呵，请吃吧♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「久等了——！呵呵，請吃吧♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00264",
		linknext = "0058_00266",
		line = 3291,
	},
	["0058_00266"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00110", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Trae tres platos llenos de curry a la mesa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱把装了咖喱的三个盘子放在桌上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬把裝了咖哩的三個盤子放在桌上。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00265",
		linknext = "0058_00267",
		line = 3304,
	},
	["0058_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con su sonrisa inocente, nunca imaginarías lo que tiene que aguantar con Asa-chan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那天真无邪的笑容，仿佛完全不知道自己被当成了万事屋对待。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那天真無邪的笑容，彷彿完全不知道自己被當成了萬事屋對待。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00266",
		linknext = "0058_00268",
		line = 3314,
	},
	["0058_00268"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Gracias por la comida! Mm, mm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我开动了！嚼嚼嚼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我開動了！嚼嚼嚼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00267",
		linknext = "0058_00269",
		line = 3326,
	},
	["0058_00269"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Ah, qué rico...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦哦，这个真好吃……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦哦，這個真好吃……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00268",
		linknext = "0058_00270",
		line = 3338,
	},
	["0058_00270"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00115", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1074", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿En serio? Jeje, me alegra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的吗？诶嘿嘿，太好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的嗎？欸嘿嘿，太好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00269",
		linknext = "0058_00271",
		line = 3352,
	},
	["0058_00271"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Las verduras crujientes tienen un toque casero. Las encurtidas en salsa de soya también están deliciosas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“蔬菜的口感让人觉得很有家庭料理的感觉……有腌菜这一点也很棒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「蔬菜的口感讓人覺得很有家庭料理的感覺……有醃菜這一點也很棒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00270",
		linknext = "0058_00272",
		line = 3364,
	},
	["0058_00272"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00120", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1075", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ohh, me alegra que te hayas dado cuenta! ¡Son ideales para contrarrestar el sabor fuerte del curry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦哦……能注意到那里橘君真内行呢！腌菜很棒吧？能给咖喱带来清凉感！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦哦……能注意到那裡橘君真內行呢！醃菜很棒吧？能給咖哩帶來清涼感！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00271",
		linknext = "0058_00273",
		line = 3378,
	},
	["0058_00273"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1076", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Cuando era niña no me gustaban, pero ahora me encantan. Jeje, realmente son un gusto de adultos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“小的时候有点不喜欢，不过渐渐明白它的好了……呵呵，这就是味觉也成为大人了……对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「小的時候有點不喜歡，不過漸漸明白它的好了……呵呵，這就是味覺也成為大人了……對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00272",
		linknext = "0058_00274",
		line = 3392,
	},
	["0058_00274"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00110", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1071", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Qué adorable... ¿Crees que las verduras encurtidas en salsa de soya son un sabor para adultos...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我还是第一次见到有人光是谈论腌菜就能扯到大人的味觉……好厉害啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我還是第一次見到有人光是談論醃菜就能扯到大人的味覺……好厲害啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00273",
		linknext = "0058_00275",
		line = 3406,
	},
	["0058_00275"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00115", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1077", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ejeje, nah, no es eso. Mm, mm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……不不，也没那么厉害啦——嚼嚼嚼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……不不，也沒那麼厲害啦——嚼嚼嚼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00274",
		linknext = "0058_00276",
		line = 3420,
	},
	["0058_00276"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00115", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1072", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aun así, por más 'adulto' que sea el curry, está suave. Prefiero los platos más picantes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不过，虽说已经是大人了但咖喱却还是甜的……对于麻沙酱来说刺激有些不够……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不過，雖說已經是大人了但咖哩卻還是甜的……對於麻沙醬來說刺激有些不夠……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00275",
		linknext = "0058_00277",
		line = 3434,
	},
	["0058_00277"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1078", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¿Eh? ¿Te gusta picante? Lo siento, lo hice suave por costumbre. A Rei-chan no le gusta la comida picante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶？啊，辣的比较好吗？做甜做习惯了……因为礼酱不擅长吃辣的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸？啊，辣的比較好嗎？做甜做習慣了……因為禮醬不擅長吃辣的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00276",
		linknext = "0058_00278",
		line = 3448,
	},
	["0058_00278"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Te refieres... a Tadasugawa-senpai?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼酱……是糺川前辈吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮醬……是糺川前輩嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00277",
		linknext = "0058_00279",
		line = 3460,
	},
	["0058_00279"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=10, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1079", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí. Lo preparamos muchas veces cuando ella se queda a dormir, pero siempre lo hacemos suave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯。礼酱来我家的时候经常一起做，一直都是做甜的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯。禮醬來我家的時候經常一起做，一直都是做甜的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00278",
		linknext = "0058_00280",
		line = 3475,
	},
	["0058_00280"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ehhh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“诶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00279",
		linknext = "0058_00281",
		line = 3486,
	},
	["0058_00281"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quién lo habría pensado, que Tadasugawa-senpai era así...",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个糺川前辈竟然会不喜欢吃辣的东西——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個糺川前輩竟然會不喜歡吃辣的東西——",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00280",
		linknext = "0058_00282",
		line = 3496,
	},
	["0058_00282"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No encaja con su imagen, pero me lo puedo imaginar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"意外，但说来也莫名地有信服感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"意外，但說來也莫名地有信服感。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00281",
		linknext = "0058_00283",
		line = 3506,
	},
	["0058_00283"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00110", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1073", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Definitivamente no es porque lo prefieras suave, eh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“难道不是要配合渡酱才吃甜的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「難道不是要配合渡醬才吃甜的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00282",
		linknext = "0058_00284",
		line = 3520,
	},
	["0058_00284"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00123", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1080", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ejem! ¡Por supuesto que no! ¡Como adulta, me encanta la comida picante!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哼哼！可惜了，我是大人了，所以能吃中辣哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哼哼！可惜了，我是大人了，所以能吃中辣哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00283",
		linknext = "0058_00285",
		line = 3534,
	},
	["0058_00285"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estás tan orgullosa de poder comer algo que un restaurante clasificaría como comida 'media'...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是大辣，而是在中辣止步了吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是大辣，而是在中辣止步了嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00284",
		linknext = "0058_00286",
		line = 3546,
	},
	["0058_00286"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00112", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[800] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00120", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=800, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1081", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ah... ¡Puedo comer algo más picante siempre y cuando beba mucha agua y haga pausas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……大辣的话，有水和休息时间的话就能吃哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……大辣的話，有水和休息時間的話就能吃哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00285",
		linknext = "0058_00287",
		line = 3562,
	},
	["0058_00287"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1074", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿No es más infantil comer cosas picantes solo para demostrar algo en vez de admitir que te gusta suave?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“与其勉强吃辣的，还不如一开始就说想吃甜的还比较像大人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「與其勉強吃辣的，還不如一開始就說想吃甜的還比較像大人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00286",
		linknext = "0058_00288",
		line = 3576,
	},
	["0058_00288"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1082", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Eso crees?! ¡Bueno, me gusta la comida suave!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦，是这样吗！？那……我超喜欢甜的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦，是這樣嗎！？那……我超喜歡甜的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00287",
		linknext = "0058_00289",
		line = 3593,
	},
	["0058_00289"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
