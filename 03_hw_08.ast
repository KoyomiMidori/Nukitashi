	["0058_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Guiar a los turistas forma parte de nuestra formación, y ya hemos recibido clases sobre el tema.",
					{"rt2"},
				},
			},
			cn = {
				{
					"观光导览也有训练过，事前也接受了有关导览方法的教学。",
					{"rt2"},
				},
			},
			tw = {
				{
					"觀光導覽也有訓練過，事前也接受了有關導覽方法的教學。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00012",
