	["0058_00316"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿En serio me sentí feliz porque recibí elogios de Tadasugawa-senpai, presidenta del comité de moral pública de la SS y uno de los enemigos más grande del NLNS?",
					{"rt2"},
				},
			},
			cn = {
				{
					"糺川前辈——FS风纪委员长，NLNS的敌人表扬了我，我觉得高兴吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"糺川前輩——FS風紀委員長，NLNS的敵人表揚了我，我覺得高興嗎？",
					{"rt2"},
				},
