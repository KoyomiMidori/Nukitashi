		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Resopla, ambos corren hacia la playa nudista y desaparecen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女性一边吐着粗气，一边和赶到的村正前辈消失在海滩上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"女性一邊吐著粗氣，一邊和趕到的村正前輩消失在海灘上。",
