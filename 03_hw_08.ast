	["0058_00112"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0154", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "女D"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Mujer D"},
					"“Gracias por tu ayuda. ¿Por qué no vamos juntos? Jeje... Me encantaría que follaras mi coño sin condón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "D女"},
					"“谢谢你这么贴心。如果可以的话，哥哥要一起来吗？呵呵……跟你说着说着，我的小穴就突然想做爱了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "D女"},
					"「謝謝你這麼貼心。如果可以的話，哥哥要一起來嗎？呵呵……跟你說著說著，我的小穴就突然想做愛了呢。」",
					{"rt2"},
				},
			},
		},
