		line = 176,
	},
	["0058_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si quiero ganarme la confianza de la SS, no puedo bajar la guardia ni aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了赢得FS的信赖，这部份也不能偷懒。",
