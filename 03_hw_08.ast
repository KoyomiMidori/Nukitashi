		linkback = "0058_00319",
		linknext = "0058_00321",
		line = 3991,
	},
	["0058_00321"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Estoy seguro de que el incidente de hoy me ha ayudado a ganarme su confianza, así que ya podemos alcanzar el objetivo original.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“靠着今天的事件，我应该在某种程度上取得信任了，所以差不多该准备执行当初的目的了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「靠著今天的事件，我應該在某種程度上取得信任了，所以差不多該準備執行當初的目的了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00320",
		linknext = "0058_00322",
		line = 4003,
	},
	["0058_00322"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es verdad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00321",
		linknext = "0058_00323",
		line = 4013,
	},
	["0058_00323"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Solo estoy feliz porque significa que mi infiltración ha sido un éxito.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说高兴的话——一定是因为以间谍身份潜入了FS的我，终于得到了信任。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說高興的話——一定是因為以間諜身份潛入了FS的我，終於得到了信任。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00322",
		linknext = "0058_00324",
		line = 4023,
	},
	["0058_00324"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa es la única razón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一定是这样没错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一定是這樣沒錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00323",
		linknext = "0058_00325",
		line = 4033,
	},
	["0058_00325"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A partir de mañana, voy a tomar medidas más directas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明天开始，我要稍微大胆一些。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「明天開始，我要稍微大膽一些。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00324",
		linknext = "0058_00326",
		line = 4045,
	},
	["0058_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El NLNS necesita información sobre el problema de orden público y sobre esta chica llamada Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们NLNS需要有关治安问题和‘文乃’的情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們NLNS需要有關治安問題和『文乃』的情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00325",
		linknext = "0058_00327",
		line = 4056,
	},
	["0058_00327"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bgm", file="bgm23", vol=100},
		{"text"},
		delay = {
