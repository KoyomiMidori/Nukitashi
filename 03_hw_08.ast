		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1087", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ooh, ¿guías? ¡Eso es divertido!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哎呀，导游！真了不起，真了不起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哎呀，導遊！真了不起，真了不起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00299",
		linknext = "0058_00301",
		line = 3750,
	},
	["0058_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ayudábamos a los turistas, dándoles indicaciones y enseñándoles a utilizar las aplicaciones.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到中途做的都是一般的游客导览，或者是设施和应用程序的介绍。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到中途做的都是一般的遊客導覽，或者是設施和APP的介紹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00300",
		linknext = "0058_00302",
		line = 3761,
	},
	["0058_00302"] = {
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00102", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1088", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm... Veo, veo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯……真了不起，很努力呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯……真了不起，很努力呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00301",
		linknext = "0058_00303",
		line = 3776,
	},
	["0058_00303"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sin embargo, recibimos una llamada por una mujer que estaba tratando de cometer un acto de bioterrorismo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是……从岛外来了个女人，她是来进行生化恐怖袭击的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是……從島外來了個女人，她是來進行生化恐怖襲擊的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00302",
		linknext = "0058_00304",
		line = 3788,
	},
	["0058_00304"] = {
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00109", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=5, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1089", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Bioterrorismo?! ¡Qué miedo...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶！？好可怕啊，太吓人了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸！？好可怕啊，太嚇人了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00303",
		linknext = "0058_00305",
		line = 3803,
	},
	["0058_00305"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00105", file2="asane_01f_00202", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1076", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Es esto lo que llaman escucha activa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“渡酱太擅长倾听了吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「渡醬太擅長傾聽了吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00304",
		linknext = "0058_00306",
		line = 3816,
	},
	["0058_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es verdad. Las reacciones exageradas de Wata-chan me están haciendo involucrarme mucho más en mi propia historia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"的确如此——看着渡酱夸张的反应，我不由得鼓足干劲继续说下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"的確如此——看著渡醬誇張的反應，我不由得鼓足幹勁繼續說下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00305",
		linknext = "0058_00307",
		line = 3826,
	},
	["0058_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Sin embargo, una vez que llegué al lugar, ideé un plan genial para desenmascarar su verdadera naturaleza y llevarla ante la justicia!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，我却飒爽地出现在那里暴露出女人的真面目——把她拘押起来了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，我卻颯爽地出現在那裡暴露出女人的真面目——把她拘押起來了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00306",
		linknext = "0058_00308",
		line = 3837,
	},
	["0058_00308"] = {
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00102", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-20, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1090", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Oooh! ¡Buen trabajo, Tachibana-kun! ¡Es un gran logro! Eres muy trabajador, pero hoy te superaste. Te mereces caricias en la cabeza. Ven aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“喔〜！好厉害喔橘君！是大功劳呢！你平常就很努力了，今天更特别努力呢！前辈帮你摸摸头吧！好乖好乖！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「喔〜！好厲害喔橘君！是大功勞呢！你平常就很努力了，今天更特別努力呢！前輩幫你摸摸頭吧！好乖好乖！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00307",
		linknext = "0058_00309",
		line = 3852,
	},
	["0058_00309"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=350, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a127"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De puntillas, levanta su pequeña mano y me acaricia suavemente la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她伸出小手，温柔地抚摸着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她伸出小手，溫柔地撫摸著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00308",
		linknext = "0058_00310",
		line = 3864,
	},
	["0058_00310"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus elogios sinceros me hacen sentir muy bien por dentro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"能得到这样坦率的表扬，我既高兴又感激。",
					{"rt2"},
				},
			},
			tw = {
				{
					"能得到這樣坦率的表揚，我既高興又感激。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00309",
		linknext = "0058_00311",
		line = 3874,
	},
	["0058_00311"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tadasugawa-san también me elogió. Dijo que hice un buen trabajo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“糺川前辈也夸我，说我很努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「糺川前輩也誇我，說我很努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00310",
		linknext = "0058_00312",
		line = 3886,
	},
	["0058_00312"] = {
		{"fg", file="hinami_02l_00001", file1="hinami_02l_00107", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
