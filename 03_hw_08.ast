			},
			en = {
				{
					name = {"モブ男D", "Hombre A"},
					"“Je, pues tampoco. Siempre me ha gustado ese tipo de cosas. Cuando me enteré del sonido sexplosivo de este cine, tuve que venir sí o sí.”",
					{"rt2"},
				},
			},
			cn = {
