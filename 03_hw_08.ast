		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está mirando su tableta mientras habla, así que no puedo ver bien su expresión.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她本人并没有看我，而是将视线投向手上的平板。",
