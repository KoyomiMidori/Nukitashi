			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“E-Espera, Rin. Hablar así nos hace parecer matones.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“喂，凛……不行啊，不行说那种像黑帮的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「喂，凜……不行啊，不行說那種像黑幫的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00152",
		linknext = "0058_00154",
		line = 1925,
	},
	["0058_00154"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0363", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ya tenemos suficientes problemas con el Frente Anticopulación. Lo último que necesitamos es una demanda por uso excesivo de la fuerza.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“最近本来就存在许多误认反交尾势力的问题……如果强制检查结果是冤罪的话，会成为大问题的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「最近本來就存在許多誤認反交尾勢力的問題……如果強制檢查結果是冤罪的話，會成為大問題的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00153",
		linknext = "0058_00155",
		line = 1937,
	},
	["0058_00155"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0052", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“En ese caso, podemos mandarla con unos hombres para que le proporcionen orgasmos para toda la vida y la vuelvan loca. Así no podrá demandarnos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“到那时候，只要给那个女人配10多个FS的男人，让她狂欢到一辈子无法从阿黑颜中恢复不就好了吗？这样她一定就不会再想告我们了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「到那時候，只要給那個女人配10多個FS的男人，讓她狂歡到一輩子無法從阿黑顏中恢復不就好了嗎？這樣她一定就不會再想告我們了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00154",
		linknext = "0058_00156",
		line = 1949,
	},
	["0058_00156"] = {
		{"text"},
		text = {
