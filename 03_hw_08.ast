					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Pasó algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“发生什么事了吗？”",
