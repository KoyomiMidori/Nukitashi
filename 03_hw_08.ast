		{"fg", file="ran_01m_00001", file1="ran_01m_00102", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0157", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡Bienvenidos a la isla de los sueños húmedos, la Isla Seiran! ¡Libérense y follen hasta quedar inconscientes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“欢迎来到充满梦想和做爱的青蓝岛！各位，今天请尽情地做爱吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「歡迎來到充滿夢想和做愛的青藍島！各位，今天請盡情地做愛吧！」",
					{"rt2"},
				},
			},
		},
		linknext = "0058_00002",
		line = 47,
	},
	["0058_00002"] = {
		{"fg", mode=-1, id=8, ch="蘭", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hoy estamos en la playa para realizar una actividad distinta de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一天，我们FS的课外活动来到了海边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那一天，我們FS的課外活動來到了海邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00001",
		linknext = "0058_00003",
		line = 59,
	},
	["0058_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se nos pidió que recibiéramos a los turistas aquí, ya que este lugar sirve como una especie de puerta de entrada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"活动内容是在堪称青蓝岛玄关的场所为游客进行导览。",
					{"rt2"},
				},
			},
			tw = {
				{
					"活動內容是在堪稱青藍島玄關的場所為遊客進行導覽。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00002",
		linknext = "0058_00004",
		line = 69,
	},
	["0058_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dicen que es una parte importante del trabajo de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说这也是FS的固定工作——",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說這也是FS的固定工作——",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00003",
		linknext = "0058_00005",
		line = 79,
	},
	["0058_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al parecer, esta era su actividad principal original, más que el cumplimiento de la ley.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或者说，比起战斗，这些活动才是主要的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者說，比起戰鬥，這些活動才是主要的。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00004",
		linknext = "0058_00006",
		line = 89,
	},
	["0058_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tiene sentido, teniendo en cuenta que una parte importante de la economía de la isla se basa en el turismo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛毕竟是旅游胜地，这样想起来也是理所当然。",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島畢竟是旅遊勝地，這樣想起來也是理所當然。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00005",
		linknext = "0058_00007",
		line = 99,
	},
	["0058_00007"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="shuberuto0008", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Mis datos me indican que la OSS cuenta con poco personal, por lo que la SS ha estado asumiendo más tareas rutinarias.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我的数据显示因为SHO人手不够，所以被派来的FS比平时多。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我的數據顯示因為SHO人手不夠，所以被派來的FS比平時多。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00006",
		linknext = "0058_00008",
		line = 111,
	},
	["0058_00008"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
