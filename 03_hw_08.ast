		linkback = "0058_00087",
		linknext = "0058_00089",
		line = 1087,
	},
	["0058_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Tadasugawa-senpai... me está felicitando? ¿A mí?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我……被夸奖了吗？被糺川前辈？",
					{"rt2"},
