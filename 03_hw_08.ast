		line = 1109,
	},
	["0058_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, no parece que esté avergonzada y tratando de ocultarlo. ¿Qué está haciendo aquí?",
					{"rt2"},
