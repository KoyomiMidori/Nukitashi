		{"bg", id=2, file="bg05_1l_00000", x=-405, y=-205, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0159", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Rin la encontró primero. Intentó convencerla para que se sometiera a un examen médico, pero se negó.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“凛发现的，为了辨别曾交涉过要她允许我们使用检查药……但被拒绝了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「凜發現的，為了辨別曾交涉過要她允許我們使用檢查藥……但被拒絕了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00146",
		linknext = "0058_00148",
		line = 1855,
	},
	["0058_00148"] = {
		{"text"},
		text = {
