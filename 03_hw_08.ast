	},
	["0058_00064"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gracias, perdón por obligarte a salvarme así...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，给你添麻烦了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，給你添麻煩了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00063",
		linknext = "0058_00065",
		line = 794,
	},
	["0058_00065"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0343", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Mm, no te preocupes. Es inevitable que te hagan propuestas mientras trabajas como guía.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……别在意。不过既然是导游，被邀请也是难免的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……別在意。不過既然是導遊，被邀請也是難免的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00064",
		linknext = "0058_00066",
		line = 808,
	},
	["0058_00066"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Los guías de la SS parecen ser bastante populares.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好像很有人气呢……FS的导游。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好像很有人氣呢……FS的導遊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00065",
		linknext = "0058_00067",
		line = 820,
	},
	["0058_00067"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0344", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Eso parece. Supongo que el atractivo proviene del hecho de que parecen estar prohibidos, pero no lo están.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊……乍看之下导游不属于性行为的对象——看起来像是身在安全圈里，但如果拜托就可以做爱，这样的设定似乎很受欢迎。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊……乍看之下導遊不屬於性行為的對象——看起來像是身在安全圈裡，但如果拜託就可以做愛，這樣的設定似乎很受歡迎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00066",
		linknext = "0058_00068",
		line = 834,
	},
	["0058_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya veo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00067",
		linknext = "0058_00069",
		line = 845,
	},
	["0058_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es como si no lo entendiera.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种心理也不是不能理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種心理也不是不能理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00068",
		linknext = "0058_00070",
		line = 855,
	},
	["0058_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es como cuando estás jugando un eroge y tu personaje secundario favorito resulta ser la heroína principal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"找到了原以为无法攻略的女角的攻略路径而感到喜悦——和这是同样的道理吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"找到了原以為無法攻略的女角的攻略路徑而感到喜悅——和這是同樣的道理吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00069",
		linknext = "0058_00071",
		line = 865,
	},
	["0058_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"O si tu heroína secundaria favorita tiene su propio fandisc.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也和喜欢的女配角在粉丝剪辑版中出现了攻略路径时的感觉很接近吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也和喜歡的女配角在粉絲剪輯版中出現了攻略路徑時的感覺很接近吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00070",
		linknext = "0058_00072",
		line = 875,
	},
	["0058_00072"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0345", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“La próxima vez que pase algo así, avísame por radio. Te enviaré refuerzos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘，下次如果再发生同样的事情你就直接用对讲机吧，有空的人会立刻赶过来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「橘，下次如果再發生同樣的事情你就直接用對講機吧，有空的人會立刻趕過來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00071",
		linknext = "0058_00073",
		line = 889,
	},
	["0058_00073"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
