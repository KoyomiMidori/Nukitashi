	},
	["0058_00131"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0358", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Al parecer, esta tarde, una mujer se negó a someterse al control sanitario obligatorio de la OSS. Al parecer, nadó en mariposa para llegar a la isla sin pasar por los controles de la OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“今天上午，有个没通过SHO健康检查而被拒绝乘船的女人……现在那个女人游蝶泳偷渡进来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「今天上午，有個沒通過SHO健康檢查而被拒絕乘船的女人……現在那個女人遊蝶泳偷渡進來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00130",
		linknext = "0058_00132",
		line = 1631,
	},
	["0058_00132"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Qué...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“用蝶泳……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「用蝶泳……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00131",
		linknext = "0058_00133",
		line = 1643,
	},
	["0058_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La historia es una locura, pero también me siento algo aliviado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为这不得了的事情感到惊讶的同时，内心也松了一口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為這不得了的事情感到驚訝的同時，內心也鬆了一口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00132",
		linknext = "0058_00134",
		line = 1653,
	},
	["0058_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me preocupaba que hubieran capturado a una de mis compañeras del NLNS, pero parece que era otra persona.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还以为是NLNS的谁被抓了，但似乎并不是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還以為是NLNS的誰被抓了，但似乎並不是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00133",
		linknext = "0058_00135",
		line = 1663,
	},
	["0058_00135"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0359", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Si tiene sexo con alguien, podría provocar un brote epidémico. ¡Tiene que ser detenida lo antes posible!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果让那个女人做爱，传染病将蔓延整个岛屿……必须马上找出来抓住她……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果讓那個女人做愛，傳染病將蔓延整個島嶼……必須馬上找出來抓住她……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00134",
		linknext = "0058_00136",
		line = 1677,
	},
	["0058_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En la Isla Seiran, el sexo se trata con la misma naturalidad que hablar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛，做爱是半个打招呼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島，做愛是半個打招呼。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00135",
		linknext = "0058_00137",
		line = 1687,
	},
	["0058_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por ello, es obligatorio someterse a exámenes médicos periódicos y los puntos de entrada cuentan con rigurosos controles sanitarios.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以必须要有定期的体检，还要严格进行入岛审查。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以必須要有定期的體檢，還要嚴格進行入島審查。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00136",
		linknext = "0058_00138",
		line = 1697,
	},
	["0058_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si dejan entrar a una persona con una enfermedad de transmisión sexual, la isla se vería afectada por una epidemia de la noche a la mañana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要出现一位患有性传染病的人——疾病将在眨眼之间扩散。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要出現一個患有性傳染病的人——疾病將在眨眼之間擴散。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00137",
		linknext = "0058_00139",
		line = 1707,
	},
	["0058_00139"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué hacemos? ¿Le aconsejamos a la gente que evite tener relaciones sexuales hasta que la capturen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么办？在抓到那个女人为止进行不做爱的注意劝告？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼辦？在抓到那個女人為止進行不做愛的注意勸告？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00138",
		linknext = "0058_00140",
		line = 1719,
	},
	["0058_00140"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0360", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No, eso sería un caos. El pánico podría crear una oportunidad para que los insurgentes atacaran.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不……那样会引起混乱状态。如果造成恐慌，将会给予逆贼行动的空隙——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不……那樣會引起混亂狀態。如果造成恐慌，將會給予逆賊行動的空隙——」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00139",
		linknext = "0058_00141",
		line = 1733,
	},
	["0058_00141"] = {
		{"se", id=0, loop=0, file="se_a102"},
		{"ex", time=300, func="wait"},
		{"fg", file="ran_01f_00001", file1="ran_01f_00103", path=":fg/ran_01f/", id=30, ch="蘭", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0158", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Aquí B-15. Mujer sospechosa avistada. Cabello mojado, ropa seca; parece que se acaba de cambiar. Se le ve físicamente fatigada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“这里是B-15，发现了一位可疑的女人。头发虽然完全湿了，衣服却像换了衣服一样干了……而且，可以看出全身都非常疲劳。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「這裡是B-15，發現了一個可疑的女人。頭髮雖然完全濕了，衣服卻像換了衣服一樣乾了……而且，可以看出全身都非常疲勞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00140",
		linknext = "0058_00142",
		line = 1748,
	},
	["0058_00142"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00104", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
