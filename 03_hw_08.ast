	},
	["0058_00129"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0357", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana... Sí, me informaron que ha aparecido un insurgente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“橘……嗯，就在刚才收到了逆贼的消息。”",
