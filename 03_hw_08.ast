				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque las hermanas Hanamaru se parecen físicamente y tienen voces similares, sus personalidades son completamente opuestas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸姐妹——外表和语气都很相似，但实际上完全不同。",
