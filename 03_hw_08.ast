					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Recorro la playa con la mirada y veo a un hombre rascándose la cabeza con preocupación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我环视了一下沙滩，发现有个男人在挠头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我環視了一下沙灘，發現有個男人在撓頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00014",
		linknext = "0058_00016",
		line = 198,
	},
	["0058_00016"] = {
		{"bg", id=3, file="bg05_1l_00000", x=300, y=-200, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Buenos días, soy de la SS. ¿Puedo ayudarlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你好，我是FS的人，请问怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你好，我是FS的人，請問怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00015",
		linknext = "0058_00017",
