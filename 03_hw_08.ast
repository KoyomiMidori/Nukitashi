	["0058_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Luchamos cuando rescaté a Wata-chan del edificio B, pero ella no parece recordarlo, al igual que Senba Kouki, de la OSS, y la comandante Onabuta, de la SS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前为了帮助渡酱去B栋部的时候",
					{"ruby", text="・・"},
					"大战",
					{"/ruby"},
					"了一场……但她和SHO的仙波光姬还有FS一队的女部田中队长一样，都不记得了的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前為了幫助渡醬去B棟部的時候",
					{"ruby", text="・・"},
					"大戰",
					{"/ruby"},
					"了一場……但她和SHO的仙波光姬還有FS一隊的女部田中隊長一樣，都不記得了的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00148",
		linknext = "0058_00150",
		line = 1875,
	},
	["0058_00150"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
