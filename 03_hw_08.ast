		},
		linkback = "0058_00248",
		linknext = "0058_00250",
		line = 3088,
	},
	["0058_00250"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1070", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ohhh! ¿En serio? ¡Qué bien! ¡El curry de hoy será un curry de celebración!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦〜！这样啊这样啊，那真是件好事啊！那么今天的咖喱就是庆祝咖喱了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦〜！這樣啊這樣啊，那真是件好事啊！那麼今天的咖哩就是慶祝咖哩了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00249",
		linknext = "0058_00251",
		line = 3102,
	},
	["0058_00251"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Curry?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咖喱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咖哩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00250",
		linknext = "0058_00252",
		line = 3114,
	},
	["0058_00252"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me pareció reconocer el aroma que salía de la cocina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来，厨房那边有股香味扑鼻而来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，廚房那邊有股香味撲鼻而來。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00251",
		linknext = "0058_00253",
		line = 3124,
	},
	["0058_00253"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Es curry casero?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道是你为我做的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道是你為我做的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00252",
		linknext = "0058_00254",
		line = 3135,
	},
	["0058_00254"] = {
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1071", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Sí! Asane-chan dijo que iba a estar todo el día en su habitación con la computadora, así que pensé en hacer algo bonito por ti, como tu querida senpai!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！今天麻沙音酱说要在房间里玩电脑，所以我就想说作为前辈的我一定要为努力的橘君做点什么！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！今天麻沙音醬說要在房間裡玩電腦，所以我就想說作為前輩的我一定要為努力的橘君做點什麼！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00253",
		linknext = "0058_00255",
		line = 3148,
	},
	["0058_00255"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gracias... Wata-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“渡酱……谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「渡醬……謝謝你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00254",
		linknext = "0058_00256",
		line = 3160,
	},
	["0058_00256"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00115", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1072", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Jeje, no te preocupes! Lo hice porque quería. ¡Por favor, siéntate para que te lo sirva!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵，不客气！我是想做才做的。那我马上准备，坐下来坐下来！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呵呵，不客氣！我是想做才做的。那我馬上準備，坐下來坐下來！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00255",
		linknext = "0058_00257",
		line = 3174,
	},
	["0058_00257"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"bg", id=2, file="bg19_3l_00000", x=0, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"se", id=0, loop=0, file="se_a157"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me lleva de la mano hasta la mesa y me sienta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用力拉着我的手，让我坐在椅子上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用力拉著我的手，讓我坐在椅子上。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00256",
		linknext = "0058_00258",
		line = 3188,
	},
	["0058_00258"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estaba a punto de ofrecerle mi ayuda, pero parece que no la necesita.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来想帮忙的，但看到渡酱高兴的样子，就作罢了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來想幫忙的，但看到渡醬高興的樣子，就作罷了。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00257",
		linknext = "0058_00259",
		line = 3198,
	},
	["0058_00259"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que le encanta desempeñar el papel de 'senpai útil' cuando tiene la oportunidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来这种时候能做点前辈做的事，让她很高兴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來這種時候能做點前輩做的事，讓她很高興。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00258",
		linknext = "0058_00260",
		line = 3208,
	},
	["0058_00260"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", file="asane_01m_00002", file1="asane_01m_00124", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=-200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1068", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wata-chan, tengo hambre, dame comidaaa... Y luego déjame darte otra paliza, el grindeo me ha puesto de humor...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“肚子饿了，渡酱晚饭还没好吗……？还有汇率又暴跌了当我的沙袋吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「肚子餓了，渡醬晚飯還沒好嗎……？還有匯率又暴跌了當我的沙袋吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00259",
		linknext = "0058_00261",
		line = 3224,
	},
	["0058_00261"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1069", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah... Manito. Por fin volviste...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……哥哥，回来了啊……欢迎回来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……哥哥，回來了啊……歡迎回來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00260",
		linknext = "0058_00262",
		line = 3238,
	},
	["0058_00262"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya volví, y deja de tratar a Wata-chan como si fuera tu sirvienta personal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我回来了。不能把渡酱当成万事屋哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我回來了。不能把渡醬當成萬事屋哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00261",
		linknext = "0058_00263",
		line = 3250,
	},
	["0058_00263"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1070", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, no, lo hago por ella. No sabe qué hacer cuando no le pido nada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不不不我是为渡酱着想才这样做的……那孩子比起什么都不说还是拜托点什么她才会高兴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不不不我是為渡醬著想才這樣做的……那孩子比起什麼都不說還是拜託點什麼她才會高興……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00262",
		linknext = "0058_00264",
		line = 3264,
	},
	["0058_00264"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
