		line = 1887,
	},
	["0058_00151"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0362", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sí. Aparte de las inspecciones periódicas obligatorias, el resto de exámenes médicos son voluntarios.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是的，只要不是定期检查之类的义务，要不要配合这些检查都是任意的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是的，只要不是定期檢查之類的義務，要不要配合這些檢查都是任意的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00150",
		linknext = "0058_00152",
		line = 1899,
	},
	["0058_00152"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0051", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“¿No es esta negativa una admisión de culpa? Deberíamos sujetarla y meterle la sonda en el coño, y así tendríamos pruebas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“拒绝接受检查，不就是在说自己是犯人吗？强行逮捕后再把检查药插到小穴拿到证据就可以了啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "凜"},
					"「拒絕接受檢查，不就是在說自己是犯人嗎？強行逮捕後再把檢查藥插到小穴拿到證據就可以了啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00151",
		linknext = "0058_00153",
		line = 1911,
	},
	["0058_00153"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00106", file2="ran_01m_00202", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
