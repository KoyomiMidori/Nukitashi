			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, como ella desconfía de la SS, no puedo acercarme como si nada...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，那个女人因为警戒着FS，所以想接近她——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，那個女人因為警戒著FS，所以想接近她——",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00160",
