	["0058_00174"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0365", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Su uso es sencillo. Se inserta en la vagina de la persona durante 10 segundos. Si el indicador no cambia, puede irse. Si se vuelve rojo, es una insurgente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“使用方法很简单。只要在阴道内插入10秒钟，手上凹下去的部分没有变化就没有问题。如果变成红色……那就是逆贼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「使用方法很簡單。只要在陰道內插入10秒鐘，手上凹下去的部分沒有變化就沒有問題。如果變成紅色……那就是逆賊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00173",
		linknext = "0058_00175",
		line = 2170,
	},
	["0058_00175"] = {
