	["0003_00503"] = {
		{"se", id=0, loop=0, file="se_a099"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de salir de la ducha, vuelvo a mi habitación e inmediatamente me meto en mi futón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"洗完澡后，回到房间的我立即躺在被褥上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"洗完澡後，回到房間的我立刻躺到床上。",
