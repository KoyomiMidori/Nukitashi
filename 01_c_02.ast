				},
			},
			tw = {
				{
					"因為實在是過於異空間，所以我隨便買了一個枕頭就回來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00465",
		linknext = "0003_00467",
		line = 6169,
	},
	["0003_00467"] = {
