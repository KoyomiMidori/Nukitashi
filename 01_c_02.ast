	["0003_00501"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00118", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
