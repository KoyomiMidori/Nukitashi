	["0003_00223"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="genki0002", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"元気で明るい女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"元気で明るい女子生徒", "Chica alegre y divertida"},
					"“Mmm... Bueno, ir a los Piratas del Caripié en Tierra Lasciva no está tan mal, ¡pero no hay nada mejor que hacerlo sin nada en Playa Hamehame en esta época del año!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"元気で明るい女子生徒", "开朗有精神的女学生"},
					"“嗯——变态游乐园的大屌海盗也不错，但这个季节果然还是要去啪啪啪海滩来一发嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"元気で明るい女子生徒", "開朗有精神的女學生"},
					"「嗯——變態遊樂園的大屌海盜也不錯，但這個季節果然還是要去啪啪啪海灘來一發嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00222",
		linknext = "0003_00224",
		line = 2935,
	},
	["0003_00224"] = {
		{"text"},
		text = {
