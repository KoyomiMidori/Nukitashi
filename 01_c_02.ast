					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Vecina casada"},
					"“La guardería está cerrada hoy, pero me encantaría consentirte como si fueras mi bebé, Tachibana-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "隔壁人妻"},
					"“今天奶嘴托儿所休息……所以我会好好疼爱橘君，把橘君带到梦寐以求的梦之国度奶嘴乐园哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "隔壁人妻"},
					"「今天奶嘴托兒所休息……所以我會好好疼愛橘君，把橘君帶到夢寐以求的夢之國度奶嘴樂園哦？」",
					{"rt2"},
				},
