		linkback = "0003_00203",
		linknext = "0003_00205",
		line = 2667,
	},
	["0003_00205"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0015", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Con nuestros ojos, aprendemos a percibir a quienes nos rodean. Con nuestras palabras, aprendemos a conversar con quienes nos rodean.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“只要我们抬起头，就能看到对方。只要我们交谈，就能得知对方的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「只要我們抬起頭，就能看到對方。只要我們交談，就能認識對方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00204",
		linknext = "0003_00206",
		line = 2679,
	},
	["0003_00206"] = {
		{"text"},
		text = {
			vo = {
