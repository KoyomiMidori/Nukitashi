				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aún no me he acostumbrado al entorno de escuela, así que llegar con prisas no debería ser algo terrible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过我还没有习惯学校的结构，所以也可以说还好压线到了学校——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過我還沒有習慣學校的結構，所以也可以說還好壓線到了學校——",
					{"rt2"},
				},
