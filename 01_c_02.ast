	},
	["0003_00505"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me quedo mirando al techo y recuerdo los acontecimientos de hoy como una linterna giratoria en mi mente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我盯着天花板看，今天发生的事情就像走马灯一样在眼前闪过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我盯著天花板看，今天發生的事情就像走馬燈一樣在眼前閃過。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00504",
		linknext = "0003_00506",
		line = 6727,
	},
	["0003_00506"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
