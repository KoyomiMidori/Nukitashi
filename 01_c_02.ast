	},
	["0003_00504"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi cabeza me está matando y me siento cansado hasta la médula.",
					{"rt2"},
				},
			},
			cn = {
				{
					"头很沉重。我整个人都累坏了。",
					{"rt2"},
				},
			},
