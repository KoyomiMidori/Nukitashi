	["0003_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque la Academia Minotsuki tiene su propio uniforme, a estos estudiantes se les permite llevar el uniforme de la ONS. Es muy revelador y es increíblemente popular en la isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"水乃月学园本身就推荐穿制服来学校，所以穿着这个制服并没有问题，并且高度暴露的衣服在岛内外都很受欢迎。",
					{"rt2"},
				},
			},
