			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No seas tonto, hermanito. Eso es facilísmo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥你说什么傻话……当然是小菜一碟……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥你說什麼傻話……當然是小菜一碟……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00018",
		linknext = "0003_00020",
		line = 285,
	},
	["0003_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues si te supieras las tablas de multiplicar...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“会用九九乘法就能解出来才对……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「會用九九乘法就能解出來才對……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00019",
		linknext = "0003_00021",
		line = 297,
	},
	["0003_00021"] = {
		{"fg", file="asane_02m_00006", file1="asane_02m_00103", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0060", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Puedo hacer hasta el sesenta por ciento!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“六成的九九乘法我还是会的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「六成的九九乘法我還是會的……！」",
					{"rt2"},
				},
			},
