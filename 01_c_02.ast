	},
	["0003_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Creía oír el piar de los pájaros cantores, pero hoy suenan un poco apagados.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是以为小鸟在歌唱，却是其他相似的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使以為小鳥在歌唱，卻是其他相似的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00006",
		linknext = "0003_00008",
		line = 104,
	},
	["0003_00008"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
