					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No sé lo que estás pensando, pero mira. Hay un límite de edad para la ley de esta isla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你知道吗？这个岛上有所谓的条例对象年龄。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你知道嗎？這個島上有所謂的條例對象年齡。」",
