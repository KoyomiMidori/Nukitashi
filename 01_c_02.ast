			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Y con nuestros genitales, aprendemos a comprender de todo corazón a quienes nos rodean.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“然后只要我们缠绵在一起，就可以理解对方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「然後只要我們纏綿在一起，就能理解對方。」",
					{"rt2"},
				},
