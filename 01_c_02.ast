	["0003_00466"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Era como otra dimensión. Tomé una almohada, la metí en la cesta de la compra y me largué a como diera lugar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为实在是过于异空间，所以我随便抓了一个枕头就回来了。",
