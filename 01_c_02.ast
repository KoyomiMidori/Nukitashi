		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡En realidad tengo que ayudar con la brigada de cubos intravaginales de hoy! ¡Estoy a cargo de llenar el cubo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“其、其实我这么着急，是因为我要去协助中出水桶接力！今天我扮演那个水桶……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「其、其實我這麼著急，是因為我要去協助中出水桶接力！今天我扮演那個水桶……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00428",
		linknext = "0003_00430",
		line = 5658,
	},
	["0003_00430"] = {
