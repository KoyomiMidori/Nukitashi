			tw = {
				{
					"完了，差點就聽信妹妹的話了……！",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00038",
		linknext = "0003_00040",
		line = 516,
	},
	["0003_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Sabes? Yo tampoco tengo ganas de salir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我也一样不想出去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我也一樣不想出去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00039",
		linknext = "0003_00041",
		line = 528,
	},
	["0003_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero le hice una promesa a nuestros padres.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是麻沙酱，你答应过爸爸妈妈了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是麻沙醬，你答應過爸爸媽媽了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00040",
		linknext = "0003_00042",
		line = 540,
	},
	["0003_00042"] = {
		{"fg", file="asane_02m_00006", file1="asane_02m_00109", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="asane_02m_00006", file1="asane_02m_00106", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=1500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0065", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, cierto. Les juraste que me harías llegar a un mínimo de conocimientos aritméticos de primaria... Hasta les lloraste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“——嗯，他们一边哭着……一边求我至少要学会小学等级的算术……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「——嗯，他們一邊哭著……一邊求我至少要學會小學等級的算術……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00041",
		linknext = "0003_00043",
		line = 557,
	},
	["0003_00043"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque ya no estén con nosotros, quiero cumplir su último deseo... Y no lo hago solo por ellos, sino también por ti.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然爸爸妈妈不在了，但我想实现他们最后的愿望……当然，也是为了妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然爸爸媽媽不在了，但我想實現他們最後的願望……當然，也是為了妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00042",
		linknext = "0003_00044",
		line = 569,
	},
	["0003_00044"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No nos queda nadie fuera de esta casa en quien confiar... Estamos solos contra el mundo. ¡Demos lo mejor de nosotros!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“除了这间房子外，我们已经没有依靠了。所以我们一起加油吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「除了這間房子外，我們已經沒有依靠了。所以我們一起加油吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00043",
		linknext = "0003_00045",
		line = 581,
	},
	["0003_00045"] = {
