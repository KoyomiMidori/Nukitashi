					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por favor... ¿Es que quieres volverte más tonta?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是的……再变得更傻也没关系吗？”",
