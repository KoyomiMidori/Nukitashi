					"Perder de repente a nuestros padres significaba que no teníamos a nadie que nos enseñara a vivir sin ellos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父母突然过世后，就没有人教我们怎么做了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父母突然過世後，就沒有人教我們怎麼做了。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00494",
		linknext = "0003_00496",
		line = 6580,
	},
	["0003_00496"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0135", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Olvídate de la limpieza, ¿no podemos al menos comer en algún sitio? Cocinar es horrible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“先不说清扫，我们去外面吃饭吧……？煮饭很难吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「先不說清掃，我們去外面吃飯吧……？煮飯很難吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00495",
		linknext = "0003_00497",
		line = 6594,
	},
	["0003_00497"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues créeme que me gustaría, pero ya hace falta un poco de dinero...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也想这样做，但钱不多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也想這樣做，但錢不多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00496",
		linknext = "0003_00498",
		line = 6606,
	},
	["0003_00498"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tenemos algunos ahorros, pero tenemos que ser conscientes de nuestros gastos para no quedarnos pobres.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然手头有一些钱，但很可能在不注意的时候用完。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然手頭有一些錢，但很可能在不注意的時候用完。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00497",
		linknext = "0003_00499",
		line = 6616,
	},
	["0003_00499"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No nos queda de otra que escatimar y ahorrar siempre que podemos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以可以节约的地方果然还是要节约。",
