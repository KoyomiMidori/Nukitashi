					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Mierda!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——啊。”",
					{"rt2"},
