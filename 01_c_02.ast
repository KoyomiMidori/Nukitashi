					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué están haciendo? Parece que están inspeccionando las pertenencias de todos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
