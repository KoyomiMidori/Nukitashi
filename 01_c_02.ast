		linkback = "0003_00028",
		linknext = "0003_00030",
		line = 405,
	},
	["0003_00030"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0063", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hablando en serio, corres tanto peligro como yo... Y creo que hasta más...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为……哥哥也一样危险不是吗……应该说……哥哥还更——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為……哥哥也一樣危險不是嗎……應該說……哥哥還更——」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00029",
		linknext = "0003_00031",
		line = 417,
	},
	["0003_00031"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
