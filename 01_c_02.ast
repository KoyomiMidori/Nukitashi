					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No esperaba que la SS se fijara en mí tan rápido...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
