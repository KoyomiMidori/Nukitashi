	["0003_00013"] = {
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Logré que se pusiera el uniforme y desayunara, pero está sentada en la sala, encorvada en posición fetal. Es como si realmente quisiera volver al útero...",
					{"rt2"},
				},
			},
			cn = {
				{
					"好不容易让她换了制服，还吃了饭，但她却抱着膝盖待在客厅不动了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好不容易讓她換了制服，還吃了飯，但她卻抱著膝蓋待在客廳不動了。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00012",
		linknext = "0003_00014",
		line = 207,
	},
	["0003_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Por favor, recógete el pelo y vámonos ya.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“快点，我会帮你绑个头发的，所以走吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「快點，我會幫你綁頭髮的，所以走吧？」",
					{"rt2"},
				},
