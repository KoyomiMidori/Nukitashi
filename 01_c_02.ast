			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí, tienes razón. Dejémoslo así... Después de todo, solo tú y yo estamos juntos en esto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯，说的也是……一起加油吧……毕竟只有我们兄妹两个人。”",
