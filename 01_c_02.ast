		linknext = "0003_00465",
		line = 6148,
	},
	["0003_00465"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh... ¡Devuélvanme mi infancia...!”",
					{"rt2"},
				},
			},
			cn = {
