		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Llegué tarde a la puerta, pero no la vi.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我迟迟来到学校门口时，麻沙酱已经不在了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我有點遲地來到學校門口時，麻沙醬已經不在了。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00439",
		linknext = "0003_00441",
		line = 5828,
	},
	["0003_00441"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tras unas cuantas repeticiones del tono de llamada, por fin contesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"打了几次电话后，电话通了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"打了幾次電話後，電話通了。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00440",
		linknext = "0003_00442",
		line = 5838,
	},
	["0003_00442"] = {
		{"se", id=0, loop=0, file="se_a163"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Asa-chan? ¿Dónde estás?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……麻沙酱？你现在在哪儿？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……麻沙醬？你現在在哪？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00441",
		linknext = "0003_00443",
		line = 5851,
	},
	["0003_00443"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0121", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Hermanito? Lo siento, me fui a casa sola.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，哥哥？对不起，我先回来了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，哥哥？對不起，我先回來了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00442",
		linknext = "0003_00444",
		line = 5864,
	},
	["0003_00444"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya veo. Bueno, al menos llegaste a salvo. ¿Pasó algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯嗯，能平安回家就好……但有发生什么事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯嗯，能平安回家就好……但有發生什麼事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00443",
		linknext = "0003_00445",
		line = 5875,
	},
	["0003_00445"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00114", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0122", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mi clase tiene chicos un tanto intensitos... Terminaron siguiéndome hasta la puerta, así que tuve que salir corriendo. Estoy cansada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“班上有个男孩追我追的很紧……跟我来到了校门口，所以我就逃走了……累死我了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「班上有個男孩追我追得很緊……跟我來到了校門口，所以我就逃走了……累死我了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00444",
		linknext = "0003_00446",
		line = 5888,
	},
	["0003_00446"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Puedo imaginar a mi hermana en el teléfono ahora mismo, tumbada en el sofá y derritiéndose.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是通过电话也可以想象在沙发上累瘫的妹妹的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是通過電話也可以想像在沙發上累癱的妹妹的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00445",
		linknext = "0003_00447",
		line = 5898,
	},
	["0003_00447"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, llegaste a casa, así que no te preocupes. Volveré pronto, pero primero compraré algunas cosas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你到家了就好，我很快就会回来。不过我会顺道去买些日用品。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你到家了就好，我很快就會回來。不過我會順道去買些日用品。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00446",
		linknext = "0003_00448",
		line = 5910,
	},
	["0003_00448"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0123", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Ah, perfecto! Hermanito, ¿podrías comprarme algo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，对了……！哥哥，能帮我买那个吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，對了……！哥哥，能幫我買那個嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00447",
		linknext = "0003_00449",
		line = 5923,
	},
	["0003_00449"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué quieres? Si es una tarjeta de débito prepago, olvídalo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么？点券卡是不可以的哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼？點數卡是不可以的哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00448",
		linknext = "0003_00450",
		line = 5935,
	},
	["0003_00450"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00104", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0124", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No es eso... Perdí mi almohada. Creo que se extravió cuando nos mudamos aquí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不是的……我现在没枕头了……好像是搬家的时候不见的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不是的……我現在沒枕頭了……好像是搬家的時候不見的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00449",
		linknext = "0003_00451",
		line = 5948,
	},
	["0003_00451"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Está bien. ¿Quieres cualquier almohada?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，你想要什么样的枕头？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好，你想要什麼樣的枕頭？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00450",
		linknext = "0003_00452",
		line = 5959,
	},
	["0003_00452"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0125", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí. Mientras te tenga cerca y un lugar donde apoyar la cabeza, podré dormir como yo quiera...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……能有可以枕着脑袋的地方和哥哥的话，妹妹就能一直睡下去……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……能有可以枕著腦袋的地方和哥哥的話，妹妹就能一直睡下去……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00451",
		linknext = "0003_00453",
		line = 5972,
	},
	["0003_00453"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque dudo que te despertaras aunque no tuvieras una... En fin, ya la voy a comprar. Hablamos después.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我怎么觉得就算没有你好像也起不来……好，那你等我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我怎麼覺得就算沒有你好像也起不來……好，那你等我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00452",
		linknext = "0003_00454",
		line = 5983,
	},
	["0003_00454"] = {
		{"se", id=0, loop=0, file="se_a163"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien... ¿Cómo llego al distrito comercial desde aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃，我该怎么从这里到繁华街？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃，我該怎麼從這裡到繁華街？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00453",
		linknext = "0003_00455",
		line = 5996,
	},
	["0003_00455"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Debe haber algún lugar en esta isla para comprar cosas para la cama.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个岛上会有卖寝具的地方吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個島上會有賣寢具的地方嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00454",
		linknext = "0003_00456",
		line = 6007,
	},
	["0003_00456"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora que recuerdo, oí que abrieron unos almacenes grandes en el distrito comercial.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……说起来，最近在繁华街那边好像开了一家综合商场——",
					{"rt2"},
				},
			},
			tw = {
				{
					"……說起來，最近在繁華街那邊好像開了一家百貨公司——",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00455",
		linknext = "0003_00457",
		line = 6017,
	},
	["0003_00457"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bien, creo que iré allá primero.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，先去那里看看吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，先去那裡看看吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00456",
		linknext = "0003_00458",
		line = 6028,
	},
