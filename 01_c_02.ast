					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahh, mi hermana respira como si estuviera destinada a traer equilibrio a la fuerza.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊，妹妹的呼吸就像个能给原力带来平衡的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊，妹妹的呼吸就像個能給原力帶來平衡的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00114",
		linknext = "0003_00116",
		line = 1529,
	},
	["0003_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al menos llegamos a tiempo a la escuela.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论如何，还好没有迟到，平安到达了学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論如何，還好沒有遲到，平安到達了學校。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00115",
