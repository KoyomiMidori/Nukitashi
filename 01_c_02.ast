					{"rt2"},
				},
			},
			en = {
				{
					"Como era de esperar, los estudiantes son propensos a buscar diversión en la playa nudista o el parque de atracciones después de clases.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但最厉害的果然还是放学之后，学生们都纷纷跟去玩似的前往裸体海滩和游乐园。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但最厲害的果然還是放學之後，學生們都紛紛跟去玩似的前往裸體海灘和遊樂園。",
					{"rt2"},
				},
			},
		},
