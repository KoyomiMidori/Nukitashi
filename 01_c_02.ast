		linkback = "0003_00036",
		linknext = "0003_00038",
		line = 496,
	},
	["0003_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El retrato de mi difunta madre me mira fijamente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲的遗照看着这边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親的遺照看著這邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00037",
		linknext = "0003_00039",
		line = 506,
	},
	["0003_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mierda, por poco volví a caer en las tácticas manipuladora de mi hermana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"完了，差点就听信妹妹的话了……！",
