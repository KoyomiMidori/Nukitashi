		linkback = "0003_00013",
		linknext = "0003_00015",
		line = 218,
	},
	["0003_00015"] = {
		{"fg", file="asane_01m_00006", file1="asane_01m_00115", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0057", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No voy a ir... No voy a ir de ninguna manera. Me voy a quedar en mi casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不去……妹妹不能去上学……要在家……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不去……妹妹不能去上學……要在家……」",
					{"rt2"},
				},
