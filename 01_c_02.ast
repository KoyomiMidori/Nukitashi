					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Creo firmemente en una cosa... El sexo puede llevarte a comprender mejor a tus semejantes, y también a las mujeres.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“只要做爱，就能更好地了解对方……我是这么想的。”",
