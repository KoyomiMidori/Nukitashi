	["0003_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despertarse por la mañana en una isla tropical no tiene nada de raro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是南部岛屿，果然早晨也没有什么不一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是南部島嶼，果然早晨也沒有什麼不一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00001",
		linknext = "0003_00003",
		line = 50,
	},
	["0003_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque por alguna razón la luz del sol que entra desde afuera no parece tan brillante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是从外面射进来的光线有点刺眼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是從外面射進來的光線有點刺眼。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00002",
		linknext = "0003_00004",
		line = 60,
	},
	["0003_00004"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No está pasando nada raro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有变化没有变化。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「都沒變。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00003",
		linknext = "0003_00005",
		line = 72,
	},
	["0003_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El olor del océano en el aire me hace cosquillas en la nariz.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使空气混杂着大海的气味，让鼻孔有一种奇妙的搔痒感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使空氣混雜著大海的氣味，讓鼻孔有一種奇妙的搔癢感。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00004",
		linknext = "0003_00006",
		line = 82,
	},
	["0003_00006"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
