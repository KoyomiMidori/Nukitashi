		linkback = "0003_00020",
		linknext = "0003_00022",
		line = 311,
	},
	["0003_00022"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero de ahí en adelante nada, mmm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是只能算到六吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是只能算到六嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00021",
		linknext = "0003_00023",
		line = 323,
	},
	["0003_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No creía que nuestra familia tuviera tantos problemas genéticos, pero mi hermana vive a partir de sus impulsos como un animal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为亲人，我觉得妹妹并没有那么傻，但卻只靠着野兽般的感觉在生活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為親人，我覺得妹妹並沒有那麼傻，但卻只靠著野獸般的感覺在生活。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00022",
		linknext = "0003_00024",
		line = 333,
	},
	["0003_00024"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0061", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡¿Qué, quieres llevarme a un lugar tan peligroso solo para que me violen mientras tú te masturbas?! ¡Das asco! ¡¿No te da vergüenza como hermano mayor, virgen de mierda?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“要把妹妹带到那样一个危险的地方看着被凌辱的妹妹撸管什么的作为哥哥也太不要脸了吧不羞耻吗你这个垃圾处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「要把妹妹帶到那樣一個危險的地方看著被凌辱的妹妹手淫什麼的作為哥哥也太不要臉了吧不羞恥嗎你這個垃圾處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00023",
		linknext = "0003_00025",
		line = 346,
	},
	["0003_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pues al menos el rápido chorro de diarrea verbal que sale de su boca funciona sin problemas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过骂起人来却毫不留情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過罵起人來卻毫不留情。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00024",
		linknext = "0003_00026",
		line = 356,
	},
	["0003_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque, a decir verdad... eso me dolió.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，被她这么一说……我也有点心痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，被她這麼一說……我也有點心痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00025",
		linknext = "0003_00027",
		line = 366,
	},
	["0003_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si vas a insultarme así, iré yo solo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你都说的那么过分了，那哥哥我一个人去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你都說的那麼過分了，那哥哥我一個人去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00026",
		linknext = "0003_00028",
		line = 378,
	},
	["0003_00028"] = {
		{"fg", file="asane_01m_00006", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0062", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Aaah! ¡Nooo, no te vayas! ¡Por favor quédate conmigooo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊……不要〜！妹妹要和哥哥一起宅在家里〜〜！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊……不要〜！妹妹要和哥哥一起宅在家裡〜〜！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00027",
		linknext = "0003_00029",
		line = 393,
	},
	["0003_00029"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
