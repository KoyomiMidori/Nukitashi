	["0003_00474"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00113", file4="asane_02m_00401", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0130", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Genial! ¡Así no tengo que hablar cuando no quiero! ¡Hyaa, qué cómodo...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好厉害……！有这个的话，累的时候就不用说话了……哇，超方便的……！”",
