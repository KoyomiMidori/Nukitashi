					name = {"モブ女B", "隔壁人妻"},
					"“这样吗……可惜。那等你有劲的时候再来吧。让我的人妻技术把你变成奶嘴乐园的勃起老鼠哦！哈哈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "隔壁人妻"},
					"「這樣嗎……可惜。那等你有勁的時候再來吧。讓我的人妻技術把你變成奶嘴樂園的勃奇老鼠！哈哈。」",
					{"rt2"},
				},
