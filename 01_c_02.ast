					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, perdón... La verdad es anoche me la pasé follando, así que estoy muy agotado... No creo que se me pueda parar hoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃……对不起昨晚我一夜干了七次所以已经没有力气了……感觉今天已经硬不起来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃……對不起昨晚我通宵做愛所以現在很累……感覺今天已經硬不起來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00066",
		linknext = "0003_00068",
		line = 911,
	},
	["0003_00068"] = {
