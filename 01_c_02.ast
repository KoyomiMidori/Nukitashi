		linkback = "0003_00030",
		linknext = "0003_00032",
		line = 429,
	},
	["0003_00032"] = {
		{"fg", file="asane_01m_00006", file1="asane_01m_00104", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0064", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Qué dices, hermanito? Seamos hikikomoris juntos. Podemos ver transmisiones en directo de gente perdiendo su dinero en la bolsa y usar su dolor como sustento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呐，哥哥……和我一起在家吧……？一起看因为FX大亏而哭成傻子的人们的直播来得到心灵上的满足吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「吶，哥哥……和我一起在家吧……？一起看因為FX大虧而哭成傻子的人們的直播來得到心靈上的滿足吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00031",
		linknext = "0003_00033",
		line = 443,
	},
	["0003_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eres un demonio que se deleita con la desgracia de la humanidad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“居然把人类的苦难当主食，你是恶魔吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「居然把人類的苦難當主食，你是惡魔嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00032",
		linknext = "0003_00034",
		line = 454,
	},
	["0003_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A pesar de todo, entiendo por qué no quiere salir de casa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是……不想出门一事倒可以理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是……不想出門一事倒可以理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00033",
		linknext = "0003_00035",
		line = 464,
	},
	["0003_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not like I want to go to such a dangerous place either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是我，也不想去那么危险的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是我，也不想去那麼危險的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00034",
		linknext = "0003_00036",
		line = 474,
	},
	["0003_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tal vez Asa-chan tenga razón. Nos quedaremos en casa hoy—",
					{"rt2"},
				},
			},
			cn = {
				{
					"……正如麻沙酱所说，今天还是先待在家里吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"……正如麻沙醬所說，今天還是先待在家裡吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00035",
		linknext = "0003_00037",
		line = 484,
	},
	["0003_00037"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
