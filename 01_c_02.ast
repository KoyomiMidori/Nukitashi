		linkback = "0003_00119",
		linknext = "0003_00121",
		line = 1588,
	},
	["0003_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las chicas de la primera fila han tomado el mando e inspeccionan las mochilas de los alumnos mientras escriben en sus libretas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在队伍前，受过良好训练的少女们正在检查学生们包里的东西，然后在检查板上记录着什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在隊伍前，受過良好訓練的少女們正在檢查學生們包裡的東西，然後在檢查板上記錄著什麼。",
					{"rt2"},
				},
			},
		},
