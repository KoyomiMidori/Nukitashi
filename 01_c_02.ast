		linkback = "0003_00123",
		linknext = "0003_00125",
		line = 1641,
	},
	["0003_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La ONS, la organización encargada de la isla, ofrece becas especiales a los estudiantes para que acudan a la escuela.",
					{"rt2"},
				},
			},
			cn = {
				{
					"管理青蓝岛的SHO为在岛上学校就读的学生，提供了特别的奖学金。",
					{"rt2"},
				},
			},
			tw = {
				{
					"管理青藍島的SHO為在島上學校就讀的學生，提供了特別的獎學金。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00124",
		linknext = "0003_00126",
		line = 1651,
	},
	["0003_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al tratarse de un subsidio, no es necesario devolver el dinero, y supone un incentivo adicional para establecer residencia en la isla. De hecho, muchos de los que obtienen la beca hacen precisamente eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是一项不用归还的奖学金，据说许多学生为了这个而搬到青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是一項不用歸還的獎學金，據說許多學生為了這個而搬到青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00125",
		linknext = "0003_00127",
		line = 1661,
	},
	["0003_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero a cambio, están obligados a realizar trabajo voluntario para la ONS. Es algo así como una especie de programa de aprendizaje.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但作为回报必须帮SHO工作，就好像新闻奖学生一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但作為回報必須幫SHO工作，就好像新聞獎學生一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00126",
		linknext = "0003_00128",
		line = 1671,
	},
	["0003_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los estudiantes que reciben la beca de la ONS tienen su propio uniforme especial.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后SHO奖学生将收到SHO的特殊制服。",
