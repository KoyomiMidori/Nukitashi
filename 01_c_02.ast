		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En fin, lo que importa es que vayamos y volvamos de la escuela sin que nadie nos vea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之，上下学的时候不要被别人看见应该是最好的办法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之，上下學的時候不要被別人看見應該是最好的辦法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00074",
		linknext = "0003_00076",
		line = 1007,
	},
	["0003_00076"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00110", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0073", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Esto requiere algo de acción de espionaje táctico. Por si algo, puedes dejármelo a mí... He jugado suficientes juegos de sigilo en mis ratos libres para aplicar algo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那我们隐蔽行动吧，包在妹妹我身上……最近可是通宵在玩隐蔽游戏呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那我們隱蔽行動吧，包在妹妹身上……最近可是玩了很多潛行遊戲呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00075",
		linknext = "0003_00077",
		line = 1021,
	},
	["0003_00077"] = {
