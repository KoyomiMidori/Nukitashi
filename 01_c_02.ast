					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Deja de ser tan malcriada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太任性了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太任性了。」",
					{"rt2"},
