	["0003_00314"] = {
		{"bgm", file="bgm11", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0042", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“Estoy buscando al estudiante de transferencia, sé que estuvo por aquí. ¿Lo has visto, Nanase? Me imagino que si está por aquí deberías poder olfatearlo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“我以为转学生男孩来到了这里，奈奈濑有看到他吗？如果是奈奈濑的话，用小穴就能感觉到有没有在附近对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「我以為轉學生男孩來到了這裡，奈奈瀨有看到他嗎？如果是奈奈瀨的話，用小穴就能感覺到有沒有在附近對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00313",
		linknext = "0003_00315",
		line = 4071,
	},
	["0003_00315"] = {
		{"bg", id=1, file="bg15_1_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="nozokiana_00000", x=0, y=0, path=":cg/nozokiana/", ev=1, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0001", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"？？？", "???"},
					"“¿Estudiante de transferencia? ¿Cómo así? He estado aquí desde hace rato y no vi a nadie.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"？？？", "？ ？ ？"},
					"“转校生？那是什么？我在这待了很长时间，但没有看到哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"？？？"},
					"「轉學生？那是什麼？我在這待了很長時間，但沒有看到哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00314",
		linknext = "0003_00316",
		line = 4086,
	},
