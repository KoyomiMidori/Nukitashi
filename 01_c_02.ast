					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, bienvenido a casa, hermanito... Uh, ¿qué te pasa? Estás muy pálido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥欢迎回来……怎么了？感觉好累的样子……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥歡迎回來……怎麼了？感覺好累的樣子……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00457",
		linknext = "0003_00459",
		line = 6078,
	},
	["0003_00459"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00125", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hola... Tranquila, no es nada...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我回来了……不，没什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我回來了……不，沒什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00458",
		linknext = "0003_00460",
		line = 6090,
	},
	["0003_00460"] = {
		{"se", id=0, loop=0, file="se_a183"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Suelto las bolsas de las compras y caigo al suelo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我卸下东西，瘫在地上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我放下東西，癱在地上。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00459",
		linknext = "0003_00461",
		line = 6101,
	},
	["0003_00461"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los almacenes a los que fui... no eran normales, sino muy, muy cachondos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到我去的百货商店不是普通的百货商店，而是“色情百货商店”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到我去的百貨公司不是普通的百貨公司，而是「色情百貨公司」。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00460",
		linknext = "0003_00462",
		line = 6111,
	},
	["0003_00462"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Quién iba a pensar que la mercancía no sería más que juguetes sexuales y otros artículos eróticos...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"完全没想到到处都是与普通产品混合在一起具有色情效果的产品……",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡的普通商品都和具有色情效果的產品混在一起……",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00461",
		linknext = "0003_00463",
		line = 6121,
	},
	["0003_00463"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Vi algo que parecían libros infantiles ilustrados y me picó la curiosidad, pero los títulos eran "La Oruga Terriblemente Cachonda" y "Servicio Nocturno"! ¿¡Qué demonios!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么嘛，以为是漫画书，结果一看是‘小穴和鸡巴’、‘做了100万次的猫’什么的——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼嘛，原以為是童話故事，結果卻是『小穴和肉棒』、『做了100萬次的貓』之類的——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00462",
		linknext = "0003_00464",
		line = 6133,
	},
	["0003_00464"] = {
		{"bg", id=1, file="bg19_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
