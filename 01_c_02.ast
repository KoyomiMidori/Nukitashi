	["0003_00321"] = {
		{"bg", id=1, file="bg15_1_1_00000", x=0, y=0, path=":bg/", sync=0, time=500, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, style="blur", blurx=11, blury=11, time=500, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="移動", x=0, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0044", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“Y yo que pensaba que iba a tener un pequeño sorbito de frutita fresca para mí solita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“我以为我能偷偷享受处男的第一次呢——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「我以為我能偷偷享受處男的第一次呢——」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00320",
		linknext = "0003_00322",
		line = 4202,
	},
	["0003_00322"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=100},
		{"bg", id=1, file="bg15_1_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0002", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“¿Qué...? Qué curioso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那是什么，好好玩哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那是什麼，好像很好玩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00321",
		linknext = "0003_00323",
		line = 4219,
	},
	["0003_00323"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0045", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante A"},
					"“¿No te interesa, Nanase? Tengo entendido que estás muy cerca de alcanzar la cifra de 500 vírgenes, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“奈奈濑不感兴趣吗？你不是正在挑战处男500人斩吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「奈奈瀨不感興趣嗎？你不是正在挑戰處男500人斬嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00322",
		linknext = "0003_00324",
		line = 4231,
	},
	["0003_00324"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00117", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0003", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ahora mismo creo que estoy en 489. Además, si mantengo mi ritmo, llegaré el mes que viene, así que no tengo prisa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“现在是第489位处男吧。如果是这样的节奏，下个月就能实现，所以我不怎么着急。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「現在應該處男489人斬了吧。如果照這個步調，下個月就能實現，所以我不怎麼著急。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00323",
		linknext = "0003_00325",
		line = 4245,
	},
