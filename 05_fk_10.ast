					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Honestly, I haven't really come up with any ideas. But I can't leave it at that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老实说，我现在还没有想到要怎么做。但总不能一直这样下去。”",
