	["0110_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After the truck got totaled and we'd managed to get some distance into the mountains...",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我们抛下被发现的卡车，在山中告一段落的时候。",
