					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I suppose... Oh, but that was so underhanded, Tokie! I wanted a little taste of him too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是啊……啊，不过太狡猾了吧桐香酱！我也想着最后一定要尝尝看的说〜！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是啊……啊，不過太狡猾了吧桐香醬！我也想著最後一定要嚐嚐看的說〜！」",
					{"rt2"},
