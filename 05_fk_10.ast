		linkback = "0110_00162",
		linknext = "0110_00164",
		line = 2239,
	},
	["0110_00164"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0180", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Insurance. My memory and eyesight in the night are both exceptional. I haven't forgotten the young man who saved me that night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是个保险啊。我啊，记忆力很好，晚上也看得很清楚。那个时候，我记得",
					{"ruby", text="・・"},
					"最先",
					{"/ruby"},
					"救助我的少年是谁。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是個保險啊。我啊，記憶力很好，晚上也看得很清楚。那個時候，我記得",
					{"ruby", text="・・"},
					"最先",
					{"/ruby"},
					"救助我的少年是誰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00163",
		linknext = "0110_00165",
		line = 2251,
	},
	["0110_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So that's why he went to the trouble? Looks like my hunch was right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以为了以防万一才下手，然后刚好猜中了是吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以為了以防萬一才下手，然後剛好猜中了是嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00164",
		linknext = "0110_00166",
		line = 2261,
	},
	["0110_00166"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0181", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But I certainly did not expect Fumino to be there as well. That was most regrettable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但是——我没想到居然连‘文乃’也在。真叫人难过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但是——我沒想到居然連『文乃』也在。真叫人難過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00165",
		linknext = "0110_00167",
		line = 2276,
	},
	["0110_00167"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just so you know, I have no idea where she is now, so don't bother asking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话先说在前头，那个孩子现在不在我这边，所以你别浪费精力了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話先說在前頭，那個孩子現在不在我這邊，所以你別浪費精力了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00166",
		linknext = "0110_00168",
		line = 2288,
	},
	["0110_00168"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0182", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Yeah, I figured as much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯，好像是那样呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯，好像是那樣呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00167",
		linknext = "0110_00169",
		line = 2302,
	},
	["0110_00169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm still searching for her. I feel like I'd be able to protect her once I find her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“目前正在调查。发现后我会保护好她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「目前正在調查。發現後我會保護好她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00168",
		linknext = "0110_00170",
		line = 2314,
	},
	["0110_00170"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0183", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hmm, that's reassuring. Please do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哼，那还真是可靠。请你务必那样做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哼，那還真是可靠。請你務必那樣做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00169",
		linknext = "0110_00171",
		line = 2329,
	},
	["0110_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He just brushes off my desperate comment with an adult's composure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我逞强说的一句话，被仁浦先生以成熟的态度一句话带过了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我逞強說的一句話，被仁浦先生以成熟的態度一句話帶過了。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00170",
		linknext = "0110_00172",
		line = 2339,
	},
	["0110_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I continue my desperate line of thinking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我挣扎地继续说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我掙扎地繼續說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00171",
		linknext = "0110_00173",
		line = 2349,
	},
	["0110_00173"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Governor Hitoura. What's your connection to that girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“仁浦县知事。那个孩子，对你而言是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「仁浦縣知事。那個孩子，對你而言是——」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00172",
		linknext = "0110_00174",
		line = 2361,
	},
	["0110_00174"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0184", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It's exactly what you think. Fumino is my daughter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯，你说的没错。文乃是我的女儿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯，你說的沒錯。文乃是我的女兒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00173",
		linknext = "0110_00175",
		line = 2373,
	},
	["0110_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He comes right out and admits it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生爽快地承认了。",
					{"rt2"},
				},
