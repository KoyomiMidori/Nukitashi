		{"bg", id=1, file="bg05_2_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0178", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Fear not. I don't have any security detail following me. You don't need to worry about being attacked from behind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“放心吧，我身旁没有保镖，所以你不用担心背后会被袭击。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「放心吧，我身旁沒有保鏢，所以你不用擔心背後會被襲擊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00153",
		linknext = "0110_00155",
		line = 2139,
	},
	["0110_00155"] = {
