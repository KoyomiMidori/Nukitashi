				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And then, she quietly turned around, facing the darkness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，她又再次悄无声息地转过身去，凝视着黑暗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，她又再次悄無聲息地轉過身去，凝視著黑暗。",
