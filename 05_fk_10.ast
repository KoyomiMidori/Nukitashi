	},
	["0110_00349"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fg", file="fumino_02m_00007", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0572", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Please forget everything that happened. I will pray for your continued success in battle from the shadows.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“之前的事情，请您千万要忘记……今后我也会默默祈求您们的好运。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「之前的事情，請您千萬要忘記……今後我也會默默祈求您們的好運。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00348",
		linknext = "0110_00350",
		line = 4525,
	},
	["0110_00350"] = {
		{"se", id=0, loop=0, file="se_a036", vol=40},
		{"text"},
		text = {
