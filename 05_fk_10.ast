	["0110_00119"] = {
		{"se", id=0, loop=0, file="se_a021"},
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1609", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So about the multi-story enemy locator system, I pretty much have it coded up, but I haven't done any debugging yet, so I dunno if it'll error out or anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……关于那个多楼层索敌系统，已经成型了……但因为还没开始除错，所以不知道会出现什么样的系统错误。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……關於那個多樓層索敵系統，已經成型了……但因為還沒開始除錯，所以不知道會出現什麼樣的系統錯誤。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00118",
		linknext = "0110_00120",
		line = 1675,
	},
	["0110_00120"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see... Would've come in handy at the Mutable Membrane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……‘一时的皮膜’的时候确实也曾需要它。”",
