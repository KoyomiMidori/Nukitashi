		linkback = "0110_00064",
		linknext = "0110_00066",
		line = 983,
	},
	["0110_00066"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1995", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um, Tachibana... how come you didn't notice at all until now? You spent so much time together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个，橘同学……为什么到目前为止都没有察觉呢……？毕竟在一起那么长时间……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個，橘同學……為什麼到目前為止都沒有察覺呢……？畢竟在一起那麼長時間……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00065",
		linknext = "0110_00067",
		line = 997,
	},
	["0110_00067"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, no, I had a sense of deja vu, but I didn't put two and two together at all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，虽然有既视感，但完全没有共通点啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，雖然有既視感，但完全沒有共通點啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00066",
		linknext = "0110_00068",
		line = 1009,
	},
	["0110_00068"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00114", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2131", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I think we can all agree you were being way too dense, though. Right, Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过，这次橘君确实太迟钝了对吧……奈奈濑酱……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過，這次橘君確實太遲鈍了對吧……奈奈瀨醬……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00067",
		linknext = "0110_00069",
		line = 1024,
	},
	["0110_00069"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2141", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hmm, yeah, dense enough for light to bend around him. But, well... that's nothing new for Jun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯——确实太迟钝了……不过算了，毕竟是淳，这也不是什么奇怪的事情……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯——確實太遲鈍了……不過算了，畢竟是淳，這也不是什麼奇怪的事情……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00068",
		linknext = "0110_00070",
		line = 1038,
	},
	["0110_00070"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“H-Hey... What's that supposed to mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什、什么……？你是什么意思？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什、什麼……？你是什麼意思？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00069",
		linknext = "0110_00071",
		line = 1050,
	},
	["0110_00071"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00120", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Really, why didn't I notice?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……真的，为什么我没注意到呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……真的，為什麼我沒注意到呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00070",
		linknext = "0110_00072",
		line = 1063,
	},
	["0110_00072"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=200},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=200},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=200},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was a very high possibility that a girl whose true identity I didn't know, and was trying to crush the illegal sex industry, was Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟是个打算摧毁地下风俗的不明身份的少女，的确有充分的可能性是文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟是個打算摧毀地下風俗的不明身份的少女，的確有充分的可能性是文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00071",
		linknext = "0110_00073",
		line = 1079,
	},
	["0110_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I saw that boy in the showers, I was sure he reminded me exactly of the impression she gave.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后在淋浴室里见到的少年，也和她完全是一模一样的氛围。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後在淋浴室裡見到的少年，也和她完全是一模一樣的氛圍。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00072",
		linknext = "0110_00074",
		line = 1089,
	},
	["0110_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was clear why I always had a sense of deja vu regarding her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对她，我总是有某种既视感，这可假不了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對她，我總是有某種既視感，這可假不了。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00073",
		linknext = "0110_00075",
		line = 1099,
	},
	["0110_00075"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I didn't associate the two.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，这些并没有办法联系在一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，這些並沒有辦法聯繫在一起。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00074",
		linknext = "0110_00076",
		line = 1110,
	},
	["0110_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It somehow feels linked to a much older memory.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我反而觉得与更旧的记忆有所关联——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我反而覺得與更舊的記憶有所關聯——",
					{"rt2"},
				},
			},
