		},
		linkback = "0110_00175",
		linknext = "0110_00177",
		line = 2393,
	},
	["0110_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's a lot like Reizeiin that way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一点，他和学生会长冷泉院桐香很像。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一點，他和學生會長冷泉院桐香很像。",
