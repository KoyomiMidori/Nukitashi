		{"text"},
		text = {
			vo = {
				{"vo", file="touka0735", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You're resigning?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……你说辞职吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……你說辭職嗎？」",
					{"rt2"},
				},
			},
		},
		linknext = "0110_00002",
		line = 45,
	},
	["0110_00002"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00001",
		linknext = "0110_00003",
		line = 58,
	},
	["0110_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After school the following day, when I was called to the student council office, I dropped that on them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第二天放学后。被叫到学生会室后，我我把那个交给了她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第二天放學後。被叫到學生會室後，我我把那個交給了她。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00002",
		linknext = "0110_00004",
		line = 68,
	},
	["0110_00004"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0736", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The SS was planning to give you a commendation for your significant contributions towards solving the illegal sex industry problem.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“FS本来打算表扬你为了解决地下风俗问题所做出的巨大贡献……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「FS本來打算表揚你為了解決地下風俗問題所做出的巨大貢獻……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00003",
		linknext = "0110_00005",
		line = 80,
	},
	["0110_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, but I will be declining it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，我要辞职。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，我要辭職。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00004",
		linknext = "0110_00006",
		line = 92,
	},
	["0110_00006"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00109", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0620", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Are you sure, Darling? You get a week's SS pay as your reward; that's enough to buy a small car, you know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这、这样好吗亲爱的？　FS的奖赏是一星期的带薪休假权利，还有可以买一辆小车的钱哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這、這樣好嗎親愛的？　FS的獎賞是一星期的帶薪休假權利，還有可以買一輛小車的錢哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00005",
		linknext = "0110_00007",
		line = 105,
	},
	["0110_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've achieved my objective. I have no interest in money.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“目的已经实现了，我对钱不感兴趣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「目的已經實現了，我對錢不感興趣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00006",
		linknext = "0110_00008",
		line = 117,
	},
	["0110_00008"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00110", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1120", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“As a precedence, they were talking of awarding you with the Straddled Fuck Award as well. You don't even want that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“还有破例跳段，直接赐予立松叶啪啪四十八章……难道连这个都不需要吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「還有破例跳段，直接賜予立松葉啪啪四十八章……難道連這個都不需要嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00007",
		linknext = "0110_00009",
		line = 130,
	},
	["0110_00009"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
