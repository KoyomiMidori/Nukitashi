	["0110_00128"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just need to go buy something I forgot about. I'll be in the shopping district.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我有东西忘记买了，去一下商店街。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我有東西忘記買了，去一下商店街。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00127",
		linknext = "0110_00129",
		line = 1794,
	},
	["0110_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll run back as quick as I can. Lock the door, and don't open it for anyone but me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“买完会马上赶回来，你要把门窗锁好。”",
