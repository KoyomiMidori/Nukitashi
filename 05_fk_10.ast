	},
	["0110_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This man... is impossible to read.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个男人——我看不懂。",
					{"rt2"},
				},
