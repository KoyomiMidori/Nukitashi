					"「啊——走掉了……呿——好不容易成為了好朋友，真遺憾啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00032",
		linknext = "0110_00034",
		line = 516,
	},
	["0110_00034"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00115", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1123", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hmph. We have no need for spineless cowards who abandon us halfway in the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哼……我们FS不需要中途逃跑的胆小鬼和没有毅力的家伙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哼……我們FS不需要中途逃跑的膽小鬼和沒有毅力的傢伙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00033",
		linknext = "0110_00035",
		line = 530,
	},
	["0110_00035"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00107", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="郁子", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0622", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Aw, you say that but you look so sad! I bet you're gonna miss him. Like, you were kinda sticking to him like peanut butter and all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊——礼酱说这话的时候，脸上露出了悲伤的表情呢〜！很寂寞对吧，毕竟最近一直和亲爱的在一起呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊——禮醬說這話的時候，臉上露出了悲傷的表情呢〜！很寂寞對吧，畢竟最近一直和親愛的在一起呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00034",
		linknext = "0110_00036",
		line = 545,
	},
	["0110_00036"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00109", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1124", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What!? No! I just regret that if only he'd trained a bit more he would have made a much better soldier!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呃、才没有……！我只是觉得可惜，他再多训练一下，或许能成为一名合格的士兵……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呃、才沒有……！我只是覺得可惜，他再多訓練一下，或許能成為一名合格的士兵……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00035",
		linknext = "0110_00037",
		line = 560,
	},
	["0110_00037"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0742", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now, now, you two. He decided this himself. Let's respect his decision.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“算了算了，你们两个。那是他自己决定的，我们就尊重他吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「算了算了，你們兩個。那是他自己決定的，我們就尊重他吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00036",
		linknext = "0110_00038",
		line = 574,
	},
	["0110_00038"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00102", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
