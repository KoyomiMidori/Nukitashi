	["0110_00251"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So how exactly would you use it to come up with more idiotic bullshit like the perverted sex law?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你打算怎么用它去创造名为”变态法“的可笑法律？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你打算怎麼用它去創造名為」變態法「的可笑法律？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00250",
		linknext = "0110_00252",
		line = 3268,
	},
	["0110_00252"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0209", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“There are more ways than one. If anything, what you have is ideal. You could use the power of sex to gradually expand the scope of your authority.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“方法有很多。比如用性的力量一点一点扩张势力之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「方法有很多。比如用性的力量一點一點擴張勢力之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00251",
		linknext = "0110_00253",
		line = 3282,
	},
	["0110_00253"] = {
		{"text"},
		text = {
