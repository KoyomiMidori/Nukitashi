			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, the organization you founded taught me how to always feel everything around me like a radar.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……因为你培养的组织里的人告诉我，在作战行动中，全身要像雷达一样。”",
