		line = 1957,
	},
	["0110_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And I'm still not strong enough to guarantee that I can resoundingly beat just anyone bare-handed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且我还没有强到空手就能把人揍到体无完肤的程度。",
