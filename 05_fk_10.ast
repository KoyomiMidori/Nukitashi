			},
		},
		text = {
			vo = {
				{"vo", file="asane1612", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bro? What's wrong? Does your tummy hurt? Want to me to rub it? Don't worry, we're almost home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……哥哥？怎么了？肚子疼了？我帮你揉一揉吧。放心，快要到家了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……哥哥？怎麼了？肚子痛了？我幫你揉一揉吧。放心，快要到家了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00125",
		linknext = "0110_00127",
		line = 1770,
	},
	["0110_00127"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
