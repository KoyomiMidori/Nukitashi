					"“We can cover for that on the hardware end, but that'd be down to you. Think it's doable?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那方面是硬件问题……主要还是要看哥哥……能行吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那方面是硬體問題……主要還是要看哥哥……能行嗎？」",
