		linknext = "0110_00081",
		line = 1169,
	},
	["0110_00081"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His expression remains the expressionless iron mask he always carries.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人面不改色，他总是一脸僵硬地先问这个问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人面不改色，他總是一臉僵硬地先問這個問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00080",
		linknext = "0110_00082",
		line = 1180,
	},
	["0110_00082"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0118", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“I've heard that there was a lot of commotion on your end. This old codger hears things, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“我知道发生了很大的动静。毕竟老人这种生物信息很灵通的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「我知道發生了很大的動靜。畢竟老人這種生物消息很靈通的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00081",
		linknext = "0110_00083",
		line = 1193,
	},
	["0110_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase looks imploringly at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑窥探着我的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨窺探著我的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00082",
		linknext = "0110_00084",
		line = 1203,
	},
	["0110_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her expression says she'd like me to deal with this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我用眼神示意她，要她把这个场子交给我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我用眼神示意她，要她把這個場子交給我。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00083",
		linknext = "0110_00085",
		line = 1213,
	},
	["0110_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“To cut a long story short, we located Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——简单来说，我们发现了‘文乃’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——簡單來說，我們發現了『文乃』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00084",
		linknext = "0110_00086",
		line = 1225,
	},
	["0110_00086"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But it was purely coincidental. We were in the midst of a battle, and just happened to discover she had been bound and taken hostage.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，我们也只是偶然发现，她在战斗中被抓住了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，我們也只是偶然發現，她在戰鬥中被抓住了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00085",
		linknext = "0110_00087",
		line = 1237,
	},
	["0110_00087"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“After the battle, she disappeared. We are no less in the dark than before now. We do not know where she could have gone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“战斗结束后，她消失了。除此之外的一切都不明。有关细节的部份，也仍然是不明的情况。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「戰鬥結束後，她消失了。除此之外的一切都不明。有關細節的部份，也仍然是不明的情況。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00086",
		linknext = "0110_00088",
		line = 1249,
	},
	["0110_00088"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0119", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“So you were able to ascertain the circumstances surrounding Fumino, then?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——你是说，你无法掌握‘文乃’的详细信息吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——你是說，你無法掌握『文乃』的詳細資訊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00087",
		linknext = "0110_00089",
		line = 1262,
	},
	["0110_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, more or less.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，完全没有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，完全沒有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00088",
		linknext = "0110_00090",
		line = 1274,
	},
	["0110_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear Hotori and Wata hold their breaths.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我听到了畔和渡酱的屏息声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我聽到了畔和渡醬的屏息聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00089",
		linknext = "0110_00091",
		line = 1284,
	},
	["0110_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I stare at the man across the display.",
					{"rt2"},
				},
			},
			cn = {
				{
					"隔着画面，我和老人对视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隔著畫面，我和老人對視。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00090",
		linknext = "0110_00092",
		line = 1294,
	},
	["0110_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A silence which lasts just a few seconds, but feels interminable, then follows.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有几秒，但却感觉沉默持续了半个世纪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有幾秒，但卻感覺沉默持續了半個世紀。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00091",
		linknext = "0110_00093",
		line = 1304,
	},
	["0110_00093"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0120", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“She is within your reach. You must find her, and secure her. That is your job. I expect results.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——碰到影子了，那么一定要找到，然后收入掌心。这是你们的工作，我期待你们的成果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——碰到影子了，那麼一定要找到，然後收入掌心。這是你們的工作，我期待你們的成果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00092",
		linknext = "0110_00094",
		line = 1317,
	},
	["0110_00094"] = {
		{"bgm", stop=1},
		{"se", id=0, loop=0, file="se_a136"},
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=500, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=500, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He then ends the transmission.",
					{"rt2"},
				},
			},
			cn = {
				{
					"扔下这句话后，通讯就结束了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"扔下這句話後，通訊就結束了。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00093",
		linknext = "0110_00095",
		line = 1333,
	},
	["0110_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, he didn't bring up cutting off our funding again, so I guess that could've been a lot worse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——赞助没有被中断，结果还不差。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——贊助沒有被中斷，結果還不差。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00094",
		linknext = "0110_00096",
		line = 1343,
	},
	["0110_00096"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2142", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yo, Jun. Why didn't you come clean with him about it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……喂淳，你为什么没说真话？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……喂淳，你為什麼沒說真話？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00095",
		linknext = "0110_00097",
		line = 1358,
	},
	["0110_00097"] = {
		{"fg", file="asane_02f_00001", file1="asane_02f_00103", path=":fg/asane_02f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1608", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, Bro. He probably knew who Fumino really was. This could have been your chance to extract more info out of him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是啊哥哥，‘文乃’的身份不是大致猜想到了吗……现在的话，说不定可以从那个老人那里引出一些情报——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是啊哥哥，『文乃』的身份不是大致猜想到了嗎……現在的話，說不定可以從那個老人那裡引出一些情報——」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00096",
		linknext = "0110_00098",
		line = 1371,
	},
	["0110_00098"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It turns out that Fumino is really Senator Hitoura's daughter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——文乃的真实身份，是仁浦先生的女儿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——文乃的真實身份，是仁浦先生的女兒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00097",
		linknext = "0110_00099",
		line = 1383,
	},
	["0110_00099"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00109", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2132", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? I-Is that really true, Tachibana!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……那、那是真的吗橘君……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……那、那是真的嗎橘君……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00098",
		linknext = "0110_00100",
		line = 1402,
	},
	["0110_00100"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's just an assumption. But I'm quite sure about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然有部份是我的推测——但我认为没有错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然有部份是我的推測——但我認為沒有錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00099",
		linknext = "0110_00101",
		line = 1414,
	},
	["0110_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Senator Hitoura had sent an edict to search for her early on, and there's also the fact that she's pivotal to crushing the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生的搜索命令很早就发布了，再加上她是可以摧毁变态条例的存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生的搜索命令很早就發布了，再加上她是可以摧毀變態條例的存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00100",
		linknext = "0110_00102",
		line = 1424,
	},
	["0110_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So based on how he reacted to seeing her, I can only come to that conclusion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有看他的反应——这样想是最自然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有看他的反應——這樣想是最自然的。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00101",
		linknext = "0110_00103",
		line = 1434,
	},
	["0110_00103"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1996", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I-I hadn't heard that Governor Hitoura had a child, but if I recall correctly, isn't he unmarried?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“虽、虽然没听说过仁浦县知事有孩子……但我记得他好像是未婚……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「雖、雖然沒聽說過仁浦縣知事有孩子……但我記得他好像是未婚……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00102",
		linknext = "0110_00104",
		line = 1449,
	},
	["0110_00104"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“He's a handsome bloke who's promoted like an idol around here. Of course it wouldn't be public knowledge, given it's enough to damage his political prospects.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那家伙是光靠容貌和偶像人气也很抢手的男人。如果可能会影响选举，那他当然会保持沉默。而且——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那傢伙是光靠容貌和偶像人氣也很搶手的男人。如果可能會影響選舉，那他當然會保持沉默。而且——」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00103",
		linknext = "0110_00105",
		line = 1461,
	},
	["0110_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Plus, it could be the case that that information could bring down the law, and that's why it isn't public knowledge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——大家都不知道的事情，才可能会是能够破坏变态条例的要素。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——大家都不知道的事情，才可能會是能夠破壞變態條例的要素。",
					{"rt2"},
				},
