	["0110_00158"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I mean, you managed to play at being difficult with technology, yet you put a tracker app on me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你之前假装对机器不在行，给我偷装了GPS软件呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你之前假裝對機器不在行，給我偷裝了GPS軟體呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00157",
		linknext = "0110_00159",
		line = 2181,
	},
	["0110_00159"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0179", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Mhm. But that was a failure on my part. I didn't plan for you to turn your device off. Maybe I'll take a note from you and put a bug on it next time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯，但那次失败了，我没有预想到你会把电源关了。下次换成小型发信器吧，学你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯，但那次失敗了，我沒有預想到你會把電源關了。下次換成小型訊號發射器吧，學你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00158",
		linknext = "0110_00160",
		line = 2196,
	},
	["0110_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My mouth is dry.",
