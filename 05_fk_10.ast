	},
	["0110_00178"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0185", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hmm... the beach is even crowded at this time of day. Residents and tourists alike are engaging in procreational actions. Splendid.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯……就算是这个时间段，海滩上也有很多人。居民、游客，大家都在进行性产行为。真不错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯……就算是這個時間段，海灘上也有很多人。居民、遊客，大家都在進行性產行為。真不錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00177",
		linknext = "0110_00179",
		line = 2417,
	},
	["0110_00179"] = {
		{"fg", mode=-1, id=10, ch="仁浦", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He has charisma, and strong leadership.",
					{"rt2"},
				},
			},
			cn = {
				{
					"领袖力、领导力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"領袖力、領導力。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00178",
		linknext = "0110_00180",
		line = 2429,
	},
	["0110_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The one thing that's different is a sense of tolerance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果要说哪里不同——应该是器量的大小吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果要說哪裡不同——應該是器量的大小吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00179",
		linknext = "0110_00181",
		line = 2439,
	},
	["0110_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He oozes it, whilst the student council president is lacking any.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种感觉，之前在学生会长身上并没有感受到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種感覺，之前在學生會長身上並沒有感受到。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00180",
		linknext = "0110_00182",
		line = 2449,
	},
	["0110_00182"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0186", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Young man. How do you feel about this island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“少年。关于这个岛你有什么感觉？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「少年。關於這個島你有什麼感覺？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00181",
		linknext = "0110_00183",
		line = 2463,
	},
	["0110_00183"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I... I hate it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我——很讨厌。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我——很討厭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00182",
		linknext = "0110_00184",
		line = 2475,
	},
	["0110_00184"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All those non-virgins indulging in sex, how the mob mentality forces people into it, and the perverted sex law... I hate all of them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“沉迷于性爱的非处女们，对此赞同以同调压力强迫他人的群众，还有变态条例——我全都讨厌。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沉迷於性愛的非處女們，對此贊同以同調壓力強迫他人的群眾，還有變態條例——我全都討厭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00183",
		linknext = "0110_00185",
		line = 2487,
	},
	["0110_00185"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0187", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You and me both.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯，我也有同感。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯，我也有同感。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00184",
		linknext = "0110_00186",
		line = 2501,
	},
	["0110_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What did he say...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……你说什么？",
					{"rt2"},
				},
			},
			tw = {
				{
					"……你說什麼？",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00185",
		linknext = "0110_00187",
		line = 2511,
	},
	["0110_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He came up with the law, and it helped him rise to the top... Did I really just hear him say that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"变态条例的发起人，并且借此有了现在的地位的男人，他在说什么——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"變態條例的發起人，並且藉此有了現在的地位的男人，他在說什麼——？",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00186",
		linknext = "0110_00188",
		line = 2521,
	},
	["0110_00188"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0188", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But as much as I despise it, it is a necessity. The island would never have prospered without it, right, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不过虽然讨厌，但这也是必要的东西。如果不是这样，这个岛就不会繁荣。你说是吧，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不過雖然討厭，但這也是必要的東西。如果不是這樣，這個島就不會繁榮。你說是吧，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00187",
		linknext = "0110_00189",
		line = 2535,
	},
	["0110_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well... that's probably true...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……的确，或许是这样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……的確，或許是這樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00188",
		linknext = "0110_00190",
		line = 2547,
	},
	["0110_00190"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0189", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I was born on this island. I have always hated it here. Or more precisely, I have hated those who live here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我也是在这个岛出生的，而且一直很讨厌这里。应该说是讨厌住在这里的人们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我也是在這個島出生的，而且一直很討厭這裡。應該說是討厭住在這裡的人們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00189",
		linknext = "0110_00191",
		line = 2561,
	},
	["0110_00191"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why is that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00190",
		linknext = "0110_00192",
		line = 2573,
	},
	["0110_00192"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0190", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“All the islanders did was complain without taking action. Didn't even bother promoting their own tourist attractions, and let them become derelict.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“岛上的人只会抱怨，什么都不干。不充分利用旅游资源，只是让其一味腐朽。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「島上的人只會抱怨，什麼都不幹。不充分利用旅遊資源，只是讓其一味腐朽。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00191",
		linknext = "0110_00193",
		line = 2587,
	},
	["0110_00193"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0191", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So I put forth the perverted sex law, and what did they say? That it was impossible. Pointless. They were happy to complain, but never had any better idea to come up with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“推广变态条例的时候也一样。只是说不可能没有意义什么的，抱怨但也想不出替代方案。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「推廣變態條例的時候也一樣。只是說不可能沒有意義什麼的，抱怨但也想不出替代方案。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00192",
		linknext = "0110_00194",
		line = 2599,
	},
	["0110_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Christ... He's actually making sense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那也——可以理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那也——可以理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00193",
		linknext = "0110_00195",
		line = 2609,
	},
	["0110_00195"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0192", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“And now look at them. They worship the law. They are happy to indulge in the pleasure and wealth it has brought them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“现在变成怎么样了？所有人都崇拜变态条例，沉迷于金钱上的宽裕和瞬间的快感。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「現在變成怎麼樣了？所有人都崇拜變態條例，沉迷於金錢上的寬裕和瞬間的快感。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00194",
		linknext = "0110_00196",
		line = 2621,
	},
	["0110_00196"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0193", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So being able to put those rubes in line to allow me to live some measure of a peaceful life? That is no bruise on my conscience.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“所以说，圈养那些人，让他们能在某种程度上安稳地生活，对此我一点都不会感到不安。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「所以說，圈養那些人，讓他們能在某種程度上安穩地生活，對此我一點都不會感到不安。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00195",
		linknext = "0110_00197",
		line = 2635,
	},
	["0110_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This must be what empathy is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……这些，我也有同感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……這些，我也有同感。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00196",
		linknext = "0110_00198",
		line = 2645,
	},
	["0110_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's what I feel from him right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从这个男人身上感受到的，就是这一点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從這個男人身上感受到的，就是這一點。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00197",
		linknext = "0110_00199",
		line = 2655,
	},
	["0110_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I understand his words. I share his sentiment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我能理解他在说什么。也可以共享情感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我能理解他在說什麼。也可以共享情感。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00198",
		linknext = "0110_00200",
		line = 2665,
	},
	["0110_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can even comprehend his feelings.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心情也能理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心情也能理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00199",
		linknext = "0110_00201",
		line = 2675,
	},
	["0110_00201"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0194", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So if someone with common sense, that is, someone who understands what this place is really about, hates it that much... they may as well make the most of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那么，只有拥有良知的人——能够正确理解状况的人，才值得去哀悼他们，并加以利用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那麼，只有擁有良知的人——能夠正確理解狀況的人，才值得去哀悼他們，並加以利用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00200",
		linknext = "0110_00202",
		line = 2687,
	},
	["0110_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's probably why I find his words get to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以这个男人的发言——才会让我有这么深的共鸣吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以這個男人的發言——才會讓我有這麼深的共鳴吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00201",
		linknext = "0110_00203",
		line = 2697,
	},
	["0110_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He knows that too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦先生很清楚这些事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦先生很清楚這些事。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00202",
		linknext = "0110_00204",
		line = 2707,
	},
	["0110_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps he's able to easily change the content of what he says and his manner of speaking according to the person.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说不定，他还能根据对象不同而改变内容或语调。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說不定，他還能根據對象不同而改變內容或語調。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00203",
		linknext = "0110_00205",
		line = 2717,
	},
	["0110_00205"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0195", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Don't you think so, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——你不这么认为吗，少年？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——你不這麼認為嗎，少年？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00204",
		linknext = "0110_00206",
		line = 2732,
	},
	["0110_00206"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I've always hated non-virgins.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我也讨厌非处女。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我也討厭非處女。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00205",
		linknext = "0110_00207",
		line = 2744,
	},
	["0110_00207"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So if anyone else knows the feeling of being somewhere where they're essentially a fish out of water, I guess they probably wouldn't care less about an island like this either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……所以，如果是在和我无关的地方，这种岛的事情或许怎么样都无所谓。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……所以，如果是在和我無關的地方，這種島的事情或許怎麼樣都無所謂。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00206",
		linknext = "0110_00208",
		line = 2756,
	},
	["0110_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我认为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我認為。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00207",
		linknext = "0110_00209",
		line = 2766,
	},
	["0110_00209"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And yet, this island has lost its way. It's gone mad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“尽管如此……这个岛还是太疯狂了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「儘管如此……這個島還是太瘋狂了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00208",
		linknext = "0110_00210",
		line = 2778,
	},
	["0110_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can feel it clearly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的，我清楚地感觉到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的，我清楚地感覺到了。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00209",
		linknext = "0110_00211",
		line = 2788,
	},
	["0110_00211"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I still have my dignity to hold onto. So I'm going to crush the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“正因为如此——我要凭着自己的矜持，毁掉变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「正因為如此——我要憑著自己的矜持，毀掉變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00210",
		linknext = "0110_00212",
		line = 2800,
	},
	["0110_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I say it clearly to the instigator of the law itself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我对造成这一切的始作俑者如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我對造成這一切的始作俑者如此說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00211",
		linknext = "0110_00213",
		line = 2810,
	},
	["0110_00213"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Your law is paving the road to hell with good intentions and tainted money. It must be abolished.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“变态条例是个会让好人变成坏人的条例，所以有必要摧毁它。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「變態條例是個會讓好人變成壞人的條例，所以有必要摧毀它。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00212",
		linknext = "0110_00214",
		line = 2822,
	},
	["0110_00214"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0196", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So are you saying the islanders are fundamentally good people, and they must be saved?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哦，你是说岛上本来有好人，这样的人应该被拯救是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哦，你是說島上本來有好人，這樣的人應該被拯救是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00213",
		linknext = "0110_00215",
		line = 2834,
	},
	["0110_00215"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The people I despise are the non-virgins who wallow in their own hedonism.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我憎恨的是沉溺于快感的非处女。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我憎恨的是沉溺於快感的非處女。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00214",
		linknext = "0110_00216",
		line = 2846,
	},
	["0110_00216"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If the law is creating more of them, I want to crush that law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“增加这种非处女的条例，我想破坏掉——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「增加這種非處女的條例，我想破壞掉——」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00215",
		linknext = "0110_00217",
		line = 2858,
	},
	["0110_00217"] = {
		{"bgm", stop=1},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0197", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Is it really non-virgins that you hate?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你",
					{"ruby", text="・・・・・・・・"},
					"真的讨厌非处女吗",
					{"/ruby"},
					"？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你",
					{"ruby", text="・・・・・・・・"},
					"真的討厭非處女嗎",
					{"/ruby"},
					"？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00216",
		linknext = "0110_00218",
		line = 2873,
	},
	["0110_00218"] = {
		{"se", id=0, loop=1, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My heart is beating away unpleasantly fast.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的心不情愿地敲响警钟。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的心不情願地敲響警鐘。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00217",
		linknext = "0110_00219",
		line = 2884,
	},
	["0110_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't quite discern what he's really getting at with that question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我没能马上理解这句话的意思。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沒能馬上理解這句話的意思。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00218",
		linknext = "0110_00220",
		line = 2894,
	},
	["0110_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But all the same.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——身体的深处被人触碰了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——身體的深處被人觸碰了。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00219",
		linknext = "0110_00221",
		line = 2904,
	},
	["0110_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My hand instinctively goes for my pocket.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我条件反射般的这么觉得。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我條件反射般的這麼覺得。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00220",
		linknext = "0110_00222",
		line = 2914,
	},
	["0110_00222"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why don't you just arrest me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——你为什么不抓我？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——你為什麼不抓我？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00221",
		linknext = "0110_00223",
		line = 2927,
	},
	["0110_00223"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0198", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I need your help.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为我需要力量。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為我需要力量。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00222",
		linknext = "0110_00224",
		line = 2941,
	},
	["0110_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He answers without hesitation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他立即回答道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他立即回答道。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00223",
		linknext = "0110_00225",
		line = 2951,
	},
	["0110_00225"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00101", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0199", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“This is a country of imbeciles. It drives all its greatest talents and labors abroad, then turns around and values unproductive things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这个国家太愚蠢了。人才和技术流失到海外，没有像样的生产力却满足于现状。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這個國家太愚蠢了。人才和技術流失到海外，沒有像樣的生產力卻滿足於現狀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00224",
		linknext = "0110_00226",
		line = 2966,
	},
	["0110_00226"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0200", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Politicians do nothing but provide a facade of normalcy. And the people just accept their word as fact, basking in their own mediocrity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“政治家们只说些好听话，把那些话当真的民众则开心地沉浸在维持现状这锅温水中。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「政治家們只說些好聽話，把那些話當真的民眾則開心地沉浸在維持現狀這鍋溫水中。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00225",
		linknext = "0110_00227",
		line = 2978,
	},
	["0110_00227"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0201", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Nobody raises an eyebrow at the fact that the country is slowly killing itself. Ha! Absolutely pathetic.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“全是些享受慢性自杀的人们。唉，这是多么愚蠢的事情啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「全是些享受慢性自殺的人們。唉，這是多麼愚蠢的事情啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00226",
		linknext = "0110_00228",
		line = 2990,
	},
	["0110_00228"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0202", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“So what do you think we ought to do to solve that, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……为了解决这些，你觉得该怎么办，少年？”",
