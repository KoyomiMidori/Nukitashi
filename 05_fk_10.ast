				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Phew... Isn't it nice how you can walk around freely at this time of night?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呼……在这个时间像这样自由地外出感觉好舒服啊。你不这么认为吗？”",
