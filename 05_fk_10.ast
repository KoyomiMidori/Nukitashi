	["0110_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Use the familiar concept of sex to establish a new nation, based on the exploitation of sex for profit...",
					{"rt2"},
				},
			},
			cn = {
				{
					"用性爱这种古老的新产业，作为国政。",
					{"rt2"},
				},
			},
			tw = {
				{
					"用性愛這種古老的新產業，作為國政。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00238",
		linknext = "0110_00240",
		line = 3132,
	},
	["0110_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
