	["0110_00017"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I put the handgun she gave me on the desk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我把风纪委员长给我的手枪放在桌上。",
					{"rt2"},
				},
			},
			tw = {
