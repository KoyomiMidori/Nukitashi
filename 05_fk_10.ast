	["0110_00049"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2139", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun? How'd it go with the SS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳——FS那边怎么样呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳——FS那邊怎麼樣呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00048",
		linknext = "0110_00050",
		line = 803,
	},
	["0110_00050"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I got out unscathed. Plus, it doesn't seem like Senator Hitoura told them about me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“平安脱离了——而且，仁浦先生好像没有通报我的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「平安脫離了——而且，仁浦先生好像沒有通報我的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00049",
		linknext = "0110_00051",
		line = 815,
	},
	["0110_00051"] = {
		{"se", id=0, loop=0, file="se_a176", vol=70},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I put the combat TAE I had in my pocket in case of emergency on the table.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我将口袋里万一需要战斗时要用的T-A-E拿出来放在桌上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我將口袋裡萬一需要戰鬥時要用的T-A-E拿出來放在桌上。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00050",
		linknext = "0110_00052",
		line = 826,
	},
	["0110_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since I didn't need to use it, you could call it good fortune.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有使用到这些该说是幸运吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有使用到這些該說是幸運嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00051",
		linknext = "0110_00053",
		line = 836,
	},
	["0110_00053"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seriously, though. You guys saved my ass last night. Who knows what would've happened if you didn't show up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不过昨天真是得救了。你们没有来的话，都不知道现在会怎么样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不過昨天真是得救了。你們沒有來的話，都不知道現在會怎麼樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00052",
		linknext = "0110_00054",
		line = 848,
	},
	["0110_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Soon after Hitoura arrived, Nanase and the others did too. She set off a stun grenade on the way in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后，奈奈濑和闪光弹一起出现在了建筑物内。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那之後，奈奈瀨和閃光彈一起出現在了建築物內。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00053",
		linknext = "0110_00055",
		line = 858,
	},
	["0110_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We managed to escape in the confusion, and the enemy was subdued by the OSS strike force. Not an easy task.",
					{"rt2"},
				},
			},
			cn = {
				{
					"混乱中我们虽然逃走了，但是敌人是SHO的强袭部队，所以事情没那么简单。",
					{"rt2"},
				},
			},
			tw = {
				{
					"混亂中我們雖然逃走了，但是敵人是SHO的強襲部隊，所以事情沒那麼簡單。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00054",
		linknext = "0110_00056",
		line = 868,
	},
	["0110_00056"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, I never thought that Hotori would be able to drive a truck.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是没想到畔居然会驾驶卡车。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是沒想到畔居然會駕駛卡車。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00055",
		linknext = "0110_00057",
		line = 882,
	},
	["0110_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She drove it right into the building, worsening the confusion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时畔开着卡车撞了进来，让敌人的混乱更加恶化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時畔開著卡車撞了進來，讓敵人的混亂更加惡化。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00056",
		linknext = "0110_00058",
		line = 892,
	},
	["0110_00058"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But somehow, Wata managed to use her chair to mow down the enemies like a row of dominoes. Well played, indeed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"再加上渡酱的钢管椅子，让敌人如多米诺般纷纷倒下。",
					{"rt2"},
				},
			},
			tw = {
				{
					"再加上渡醬的鋼管椅，讓敵人如多米諾般紛紛倒下。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00057",
		linknext = "0110_00059",
		line = 904,
	},
	["0110_00059"] = {
		{"text"},
		text = {
