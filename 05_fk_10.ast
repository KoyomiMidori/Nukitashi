		linkback = "0110_00230",
		linknext = "0110_00232",
		line = 3040,
	},
	["0110_00232"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0204", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Drive the churls out, and come up with a new way to oil the engine of capitalism. I've been doing it with sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“为了排斥愚蠢的人，使国家复兴，推进新的产业。我，要靠性来实现——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「為了排斥愚蠢的人，使國家復興，推進新的產業。我，要靠性來實現——」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00231",
		linknext = "0110_00233",
		line = 3052,
	},
	["0110_00233"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0205", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I will make a nation of my own, where the perverted sex law is enshrined.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——用以我国所有人为对象的‘变态法’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——用以我國所有人為對象的『變態法』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00232",
		linknext = "0110_00234",
		line = 3064,
	},
	["0110_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
