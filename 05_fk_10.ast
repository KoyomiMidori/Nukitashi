		linkback = "0110_00240",
		linknext = "0110_00242",
		line = 3156,
	},
	["0110_00242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
