	},
	["0110_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to keep myself from saying the wrong thing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要避免不谨慎的发言比较好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要避免不謹慎的發言比較好。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00160",
		linknext = "0110_00162",
		line = 2216,
	},
	["0110_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But he's too overbearing for me to stay quiet. It's a serious catch-22.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但保持沉默又会被他的气势压制，又疼又痒——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但保持沉默又會被他的氣勢壓制，又痛又癢——",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00161",
		linknext = "0110_00163",
		line = 2226,
	},
	["0110_00163"] = {
		{"se", id=0, loop=0, file="se_a033"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why did you call out to me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——那个时候，为什么要找我说话？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——那個時候，為什麼要找我說話？」",
