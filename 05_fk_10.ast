	},
	["0110_00121"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"bg", id=1, file="bg09_2_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1610", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, that's definitely a rookie mistake. But without cameras, the IFF system won't work, so even if GPS is functional, I won't be able to discern what the enemy's equipped with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯，那里确实凸显了当初的设想失误……不过，没有摄像头在的话，IFF就没办法用，就算有GPS，也不知道对方的装备是什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯，那裡確實凸顯了當初的設想失誤……不過，沒有攝影機在的話，IFF就沒辦法用，就算有GPS，也不知道對方的裝備是什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00120",
		linknext = "0110_00122",
		line = 1704,
	},
	["0110_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“On the other hand, even if we can't do anything about the cameras, if the individuals aren't on Cumblr, we can assume them to be enemies.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反过来说，只要能解决摄像头问题，即使是没有下载‘淫sta’的对象，也能靠IFF先下手为强是吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「反過來說，只要能解決攝影機問題，即使是沒有下載『淫sta』的對象，也能靠IFF先下手為強是嗎——」",
					{"rt2"},
				},
