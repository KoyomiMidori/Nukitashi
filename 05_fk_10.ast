	["0110_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The monitor right near the table we're all standing at flickers to life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们站着的桌子附近的显示器闪烁着。",
