		{"fgact", ch="礼", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The disciplinary committee president and the first squad commander look at each other in bewilderment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风纪委员长和一队队长以无法理解的表情面面相觑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風紀委員長和一隊隊長以無法理解的表情面面相覷。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00010",
		linknext = "0110_00012",
		line = 180,
	},
	["0110_00012"] = {
		{"fg", file="touka_01m_00001", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0737", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You were only ever a provisional member, in order to crush the illegal sex industry. Now that you don't have an objective, there's no point in staying. Is that right, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你本来就是为了破坏地下风俗而临时加入的。所以只要失去了目的，就没有意义继续待下去了……对吧，前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你本來就是為了破壞地下風俗而臨時加入的。所以只要失去了目的，就沒有意義繼續待下去了……對吧，前輩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00011",
		linknext = "0110_00013",
		line = 194,
	},
	["0110_00013"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You trained my feeble physical ability in such a short timeframe. I'm also grateful for the information you gave me. Thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……在这么短的时间内锻炼了这么脆弱的我，而且还告诉了我很多信息，真的非常感谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……在這麼短的時間內鍛煉了這麼脆弱的我，而且還告訴了我很多資訊，真的非常感謝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00012",
		linknext = "0110_00014",
		line = 206,
	},
	["0110_00014"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I bow my head again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我再次低下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我再次低下了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00013",
		linknext = "0110_00015",
		line = 217,
	},
	["0110_00015"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00113", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch="礼", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00111", path=":fg/ikuko_01m/", id=10, lv=5, head="ikuko_01m", ch="郁子", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They see my firm resolve and say no more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是觉得我的意志很坚定，两人没有再说什么了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是覺得我的意志很堅定，兩人沒有再說什麼了。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00014",
		linknext = "0110_00016",
		line = 231,
	},
	["0110_00016"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm returning this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么——我把这个还给你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼——我把這個還給你。」",
