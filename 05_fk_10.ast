	},
	["0110_00235"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You plan to liven up the whole country with sex!? That's insane! You can't do that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“用性爱来振兴国家……！？真是愚蠢！那种事怎么可能做到——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「用性愛來振興國家……！？真是愚蠢！那種事怎麼可能做到——」",
					{"rt2"},
				},
			},
