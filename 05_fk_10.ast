					"“We've come to retrieve you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们是来接你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們是來接你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00316",
		linknext = "0110_00318",
		line = 4147,
	},
	["0110_00318"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So please, join our organization and fight alongside us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“加入我们的组织，一起战斗吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「加入我們的組織，一起戰鬥吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00317",
		linknext = "0110_00319",
		line = 4159,
	},
	["0110_00319"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Our objective is already in sight now that we've found you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果说你是文乃，那就更——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果說你是文乃，那就更——」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00318",
		linknext = "0110_00320",
		line = 4171,
	},
	["0110_00320"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she just shook her head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是她摇头了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是她搖頭了。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00319",
		linknext = "0110_00321",
		line = 4181,
	},
	["0110_00321"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0562", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm terribly sorry... for deceiving you all this time... Please allow me to bow in apology.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“一直以来，我都在故意欺骗您……真是对不起……我下跪，向您道歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「一直以來，我都在故意欺騙您……真是對不起……我下跪，向您道歉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00320",
		linknext = "0110_00322",
		line = 4196,
	},
	["0110_00322"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don't care about that! Right now, I just want you in our team!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事根本无所谓！我只是想邀请您加入队伍——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種事根本無所謂！我只是想邀請您加入隊伍——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00321",
		linknext = "0110_00323",
		line = 4208,
	},
	["0110_00323"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00113", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, delay2=3500, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="fumino0563", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Being invited to your organization is terribly appealing... however, nonetheless... I cannot do that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“老实说，橘大人的组织确实吸引了我的心……但是——我不能这么做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「老實說，橘大人的組織確實吸引了我的心……但是——我不能這麼做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00322",
		linknext = "0110_00324",
		line = 4224,
	},
	["0110_00324"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A flat-out refusal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吹子用明确的语气拒绝了我的提案。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吹子用明確的語氣拒絕了我的提案。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00323",
		linknext = "0110_00325",
		line = 4234,
	},
	["0110_00325"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes radiated her ever-powerful will.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的瞳孔中，渗透着平时那股强烈意志。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的瞳孔中，滲透著平時那股強烈意志。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00324",
		linknext = "0110_00326",
		line = 4247,
	},
	["0110_00326"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00325",
		linknext = "0110_00327",
		line = 4259,
	},
	["0110_00327"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0564", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I can't bring chaos to the organization you so painstakingly created.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我不能把您拼尽全力建立起来的组织搞得一团糟……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我不能把您拼盡全力建立起來的組織搞得一團糟……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00326",
		linknext = "0110_00328",
		line = 4271,
	},
	["0110_00328"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0565", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I am aware of who it is that is pursuing me. I'm in a position where I must hide myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我……我知道自己正在被人追赶，我知道自己处于必须要躲藏的立场……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我……我知道自己正在被人追趕，我知道自己處於必須要躲藏的立場……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00327",
		linknext = "0110_00329",
		line = 4285,
	},
	["0110_00329"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0566", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“That's why I cannot join your organization.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“正因为如此——我才不能加入您们的组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「正因為如此——我才不能加入您們的組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00328",
		linknext = "0110_00330",
		line = 4297,
	},
	["0110_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She knew everything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她似乎明白这一切。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她似乎明白這一切。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00329",
		linknext = "0110_00331",
		line = 4307,
	},
	["0110_00331"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So she was aware of her own usefulness, as the key to abolishing the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她知道作为毁灭变态条例的关键，自己到底有多少利用价值。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她知道作為毀滅變態條例的關鍵，自己到底有多少利用價值。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00330",
		linknext = "0110_00332",
		line = 4317,
	},
	["0110_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And aware of her status as a stumbling block to the OSS, and every other party currently pursuing her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她对于SHO或其他组织来说是最大的麻烦，所以被各式各样的人追捕着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她對於SHO或其他組織來說是最大的麻煩，所以被各式各樣的人追捕著。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00331",
		linknext = "0110_00333",
		line = 4327,
	},
	["0110_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If she were to join us, that would almost certainly put us in greater danger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的人一旦进入组织，危险当然会更大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的人一旦進入組織，危險當然會更大。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00332",
		linknext = "0110_00334",
		line = 4337,
	},
	["0110_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We started our organization to get all our members home safely. That kind of danger could well prove lethal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这对于以逃回家为主的团队来说，将成为致命因素。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這對於以逃回家為主的團隊來說，將成為致命因素。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00333",
		linknext = "0110_00335",
		line = 4347,
	},
	["0110_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And so I understood... that she could not join us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为如此——才不能和我们在一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為如此——才不能和我們在一起。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00334",
		linknext = "0110_00336",
		line = 4357,
	},
	["0110_00336"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0567", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I'm truly sorry with respect to my father. Allow me to express my apology once more for presenting yourself, and everyone else, such a huge burden.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“关于父亲的事情，真的非常抱歉……橘大人，以及给大家添了很大的麻烦……再次向您道歉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「關於父親的事情，真的非常抱歉……橘大人，以及給大家添了很大的麻煩……再次向您道歉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00335",
		linknext = "0110_00337",
		line = 4369,
	},
	["0110_00337"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You knew about Governor Hitoura?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你知道仁浦县知事的事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你知道仁浦縣知事的事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00336",
		linknext = "0110_00338",
		line = 4381,
	},
	["0110_00338"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0568", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I wasn't certain... but I was vaguely aware... that might be the case.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我并没有确信……不过，我有隐约感觉到，可能是这样的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我並沒有確信……不過，我有隱約感覺到，可能是這樣的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00337",
		linknext = "0110_00339",
		line = 4395,
	},
	["0110_00339"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0569", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“That is why I must bear the burden of responsibility, for my father's wrongdoings.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以——我必须对父亲犯下的错误负责。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以——我必須對父親犯下的錯誤負責。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00338",
		linknext = "0110_00340",
		line = 4409,
	},
	["0110_00340"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her demeanor was unwavering.",
					{"rt2"},
				},
			},
			cn = {
				{
					"静谧和坚强挂在那过于端正的容貌上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"靜謐和堅強掛在那過於端正的容貌上。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00339",
		linknext = "0110_00341",
		line = 4419,
	},
	["0110_00341"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her red eyes seemed almost transcendental, standing out amongst her emotionless visage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的红色瞳孔给人一种超然的感觉，即使表情还是毫无感情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的紅色瞳孔給人一種超然的感覺，即使表情還是毫無感情。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00340",
		linknext = "0110_00342",
		line = 4429,
	},
	["0110_00342"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00111", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0570", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“When it comes to the law... I will do what I can.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“关于那个条例……我会想办法解决……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「關於那個條例……我會想辦法解決……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00341",
		linknext = "0110_00343",
		line = 4443,
	},
	["0110_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looked so very noble, anyone would almost feel the need to kowtow before her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"令人不由得想屈膝侍奉，她那高贵的姿态——",
					{"rt2"},
				},
			},
			tw = {
				{
					"令人不由得想屈膝侍奉，她那高貴的姿態——",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00342",
		linknext = "0110_00344",
		line = 4453,
	},
	["0110_00344"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0571", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“That is the duty... of Kotoyose Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这就是——琴寄文乃的责任所在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這就是——琴寄文乃的責任所在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00343",
		linknext = "0110_00345",
		line = 4467,
	},
	["0110_00345"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Did she inherit that ability to control everything from her father?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那部份，是来自能够掌握一切的父亲的遗传吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那部份，是來自能夠掌握一切的父親的遺傳嗎——",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00344",
		linknext = "0110_00346",
		line = 4477,
	},
	["0110_00346"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're going to do what you can?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“想办法什么的，你……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「想辦法什麼的，你……」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00345",
		linknext = "0110_00347",
		line = 4489,
	},
	["0110_00347"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't tell me you're just going to go back to fighting alone, like before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道你今后还是打算一个人战斗吗——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道你今後還是打算一個人戰鬥嗎——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00346",
		linknext = "0110_00348",
		line = 4500,
	},
	["0110_00348"] = {
		{"text"},
		text = {
