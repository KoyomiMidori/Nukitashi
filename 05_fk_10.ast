	["0110_00241"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00104", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="仁浦", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0206", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Once we are the remaining few individuals with common sense, this nation shall be ours.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“——这个国家，将成为在那个状况下也没有失去良知的一部分人的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「——這個國家，將成為在那個狀況下也沒有失去良知的一部分人的東西。」",
					{"rt2"},
				},
			},
