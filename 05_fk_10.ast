		linkback = "0110_00243",
		linknext = "0110_00245",
		line = 3186,
	},
	["0110_00245"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00112", path=":fg/hitoura_01m/", id=10, lv=5, head="hitoura_01m", ch="仁浦", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0207", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I need much more strength to pull such a thing off. So I want to make use of you... and what you have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因此，我需要更强而有力的力量。所以——请让我利用你的那个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因此，我需要更強而有力的力量。所以——請讓我利用你的那個。」",
					{"rt2"},
				},
			},
