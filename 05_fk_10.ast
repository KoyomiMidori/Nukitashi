				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Good grief... Anyway, Miss Touka. I shall deliver his letter of resignation to the OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真是的……那么桐香大人，橘的退伍申请由我向SHO申报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
