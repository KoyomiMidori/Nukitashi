				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She just nodded.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她面无表情地微微点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她面無表情地微微點了點頭。",
					{"rt2"},
