	},
	["0110_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her dignified appearance, her wise-beyond-her-years demeanor, and her timid voice belying all of those.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那凛然的站姿，那与年龄不符、过于整齐的容貌，还有那与外表不合的纤细声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那凜然的站姿，那與年齡不符、過於整齊的容貌，還有那與外表不合的纖細聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00361",
		linknext = "0110_00363",
		line = 4704,
	},
	["0110_00363"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to experience all of those with her walking beside me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想要一边感受着这一切，一边走在她身边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想要一邊感受著這一切，一邊走在她身邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00362",
		linknext = "0110_00364",
		line = 4714,
	},
	["0110_00364"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That untouchable princess, always fighting on her own, through sheer force of will...",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论何时，她都以一副公主的姿态高傲地战斗着，同时内心蕴藏着坚强的意志。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論何時，她都以一副公主的姿態高傲地戰鬥著，同時內心蘊藏著堅強的意志。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00363",
		linknext = "0110_00365",
		line = 4724,
	},
	["0110_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's even inherited that unusual ability from her father to incite people around her to agree to do something, even when they object to it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她有着继承自父亲的血脉，那是能煽动周围的人的神秘魅力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她有著繼承自父親的血脈，那是能煽動周圍的人的神秘魅力。",
					{"rt2"},
				},
			},
		},
