			cn = {
				{
					"我一边听着NLNS成员们的声音，一边抬头看着天花板。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊聽著NLNS成員們的聲音，一邊抬頭看著天花板。",
					{"rt2"},
				},
			},
