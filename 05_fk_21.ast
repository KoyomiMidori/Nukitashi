					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“I'm Pussy Galore, giving the people what they want. A 53-year-old tofu seller is in hospital with serious injuries after being assaulted last night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"“我是接受你一切的茅津野播音员。昨晚，53岁的豆腐店老板遭到袭击，受到了重伤。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "主播茅津野"},
					"「我是接受你一切的主播茅津野。昨晚，53歲的豆腐店老闆遭到襲擊，受到了重傷。」",
					{"rt2"},
				},
