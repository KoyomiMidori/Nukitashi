			cn = {
				{
					"带着满不在意的笑容，她说了和那个女孩同样的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"帶著滿不在意的笑容，她說了和那個女孩同樣的話。",
					{"rt2"},
				},
