	["0121_00141"] = {
		{"se", id=0, loop=0, file="se_a042"},
		{"fg", mode=-1, id=6, ch="麻沙音", lv=5, time=400},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=2, file="bg12_1l_00000", x=-300, y=0, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=10000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We all gather in front of the monitor where we often had communication from the old man.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家都聚集到经常收到老人通讯的显示器前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家都聚集到經常收到老人通訊的顯示器前。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00140",
		linknext = "0121_00142",
		line = 1880,
	},
	["0121_00142"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a nightly news program from the mainland, and not from the local SBS station.",
					{"rt2"},
				},
			},
			cn = {
				{
					"屏幕里放送的不是SHK，而是本岛的新闻节目。",
					{"rt2"},
				},
			},
			tw = {
				{
					"螢幕裡放送的不是SHK，而是本島的新聞節目。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00141",
		linknext = "0121_00143",
		line = 1891,
	},
	["0121_00143"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0085", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“Now for our top story: controversy has recently erupted over an island known as a paradise of perversion, Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“——现在成为问题的是被统称为变态天堂的青蓝岛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「——現在成為問題的是被統稱為變態天堂的青藍島。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00142",
		linknext = "0121_00144",
		line = 1904,
	},
	["0121_00144"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0086", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“Tourism advertisements proclaim that men and women of suitable age can engage freely in sexual activity, and it has sustained popularity as such a tourist destination.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“这里以达到条例对象年龄的男女可以自由进行性行为为宣传，吸引了很多游客，成为了话题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「這裡以達到條例對象年齡的男女可以自由進行性行為為宣傳，吸引了很多遊客，成為了話題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00143",
		linknext = "0121_00145",
		line = 1916,
	},
	["0121_00145"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0087", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“However, certain sections of government and mass media figures believe it to be dangerous, owing to past issues over money donations and rumored links with organized crime.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“但是从以前开始，捐款问题和与暴力组织之间的联系就被传得沸沸扬扬，所以被部分政治家和大众媒体认为很危险。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「但是從以前開始，捐款問題和與暴力組織之間的聯繫就被傳得沸沸揚揚，所以被部分政治家和大眾媒體認為很危險。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00144",
		linknext = "0121_00146",
		line = 1928,
	},
	["0121_00146"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0088", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナウンサーA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Newslady A"},
					"“Now, the island is once again in the spotlight, as revelations of very strong links to organized crime were exposed earlier this week. We now take you live to a press conference about this issue.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "主播A"},
					"“还有不久前的大举揭发暴力团体行动也与青蓝岛有很大的牵连，因此成为了热门话题。今日再次发现了大问题。接下来为你播放记者会的直播。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "主播A"},
					"「還有不久前的大舉揭發暴力團體行動也與青藍島有很大的牽連，因此成為了熱門話題。今日再次發現了大問題。接下來為你播放記者會的直播。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00145",
		linknext = "0121_00147",
		line = 1940,
	},
	["0121_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They promptly switch from the news studio to a large meeting room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"画面从收录室，转到了巨大的记者会现场。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畫面從收錄室，轉到了巨大的記者會現場。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00146",
		linknext = "0121_00148",
		line = 1950,
	},
	["0121_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There are two men standing before a podium, the eyes of numerous reporters on them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在大群记者面前，隔着桌子，站着两个男人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在大群記者面前，隔著桌子，站著兩個男人。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00147",
		linknext = "0121_00149",
		line = 1960,
	},
	["0121_00149"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0157", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Seiran Island has never been anything but an illusion, willed into being by Senator Toshiaki Hitoura!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——原本，青蓝岛就是仁浦俊明先生制造出来的幻想！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——原本，青藍島就是仁浦俊明先生製造出來的幻想！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00148",
		linknext = "0121_00150",
		line = 1972,
	},
	["0121_00150"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0158", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“They force their will onto everyone, rob the public of their right to freedom of speech, and slur those who will not engage in copulation as unpatriotic— the exact same kind of manipulative tactics seen during the war!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“使用同调压力，夺取居民的发言自由，声称没有性行为就不是国民，进行了和战争时代完全一样的印象操纵！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「使用同調壓力，奪取居民的發言自由，聲稱沒有性行為就不是國民，進行了和戰爭時代完全一樣的印像操縱！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00149",
		linknext = "0121_00151",
		line = 1984,
	},
	["0121_00151"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0159", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“This island is no different from a dictatorship, where people are not free, and their rights are willfully infringed!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“这与夺取人们的自由，侵害人们的权利是相同的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「這與奪取人們的自由，侵害人們的權利是相同的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00150",
		linknext = "0121_00152",
		line = 1996,
	},
	["0121_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Politicians on the mainland have always condemned Seiran Island in vast numbers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"政治家对青蓝岛以往被批判的许多意见进行议论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"政治家對青藍島以往被批判的許多意見進行議論。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00151",
		linknext = "0121_00153",
		line = 2006,
	},
	["0121_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So why are they having a press conference like this now?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么会在这个时候召开这样的记者会——",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼會在這個時候召開這樣的記者會——",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00152",
		linknext = "0121_00154",
		line = 2016,
	},
	["0121_00154"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0160", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“To believe that Senator Hitoura has no connection with the issue of prostitution, still fresh in everyone's minds now, is a huge mistake!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“虽然关于记忆犹新的卖春问题，仁浦先生声称与自己无关，但这也是个天大的错误！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「雖然關於記憶猶新的賣春問題，仁浦先生聲稱與自己無關，但這也是個天大的錯誤！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00153",
		linknext = "0121_00155",
		line = 2028,
	},
	["0121_00155"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0161", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Seiran Island is a breeding ground for prostitution, a hotbed for criminal activity which robs children of their freedom!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“青蓝岛是卖淫的据点，是剥夺孩子自由的温床！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「青藍島是賣淫的據點，是剝奪孩子自由的溫床！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00154",
		linknext = "0121_00156",
		line = 2040,
	},
	["0121_00156"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0162", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“And today, we have one very brave young girl here who serves as proof of this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“今天——作为牢不可破的证据，现场来了一位有勇气的少女！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「今天——作為牢不可破的證據，現場來了一位有勇氣的少女！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00155",
		linknext = "0121_00157",
		line = 2052,
	},
	["0121_00157"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0163", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“She is perhaps one of the greatest victims of the evil realm known as Seiran Island!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“她才是青蓝岛这个伏魔殿的最大受害者！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「她才是青藍島這個伏魔殿的最大受害者！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00156",
		linknext = "0121_00158",
		line = 2064,
	},
	["0121_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Camera flashes go off like lightning.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在如暴风雨般袭来的闪光灯中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在如暴風雨般襲來的閃光燈中。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00157",
		linknext = "0121_00159",
		line = 2074,
	},
	["0121_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The girl he mentioned slowly steps forward.",
