				},
			},
			cn = {
				{
					"一位少女，慢慢地走了过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一個少女，慢慢地走了過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00158",
		linknext = "0121_00160",
		line = 2084,
	},
	["0121_00160"] = {
