	["0121_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't remember if I was charmed by her eyes, or taken by some other emotion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不记得自己是被那双眼睛吸引了，还是有别的情感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不記得自己是被那雙眼睛吸引了，還是有別的情感。",
