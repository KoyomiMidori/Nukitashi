		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1755", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Don't go forgetting your actual sister, dammit! You'd better keep me in the back of your head and come into my room once every hour to check on me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“别把亲妹妹忘了啊〜……！好好记着每个小时来一次我房间看我啊〜……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「別把親妹妹忘了啊〜……！好好記著每個小時來一次我房間看我啊〜……！」",
					{"rt2"},
				},
			},
		},
