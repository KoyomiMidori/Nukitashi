	["0121_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That simple, inquisitive look was proof that she had just acknowledged me for who I was.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她歪着头，肯定了现在的我。",
