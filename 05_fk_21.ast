	["0121_00037"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0008", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "???"},
					"“It's just one of your characteristics.”",
					{"rt2"},
