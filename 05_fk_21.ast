					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑知道要从晚上才开始，所以先帮我做好了吗——",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨知道要從晚上才開始，所以先幫我做好了嗎——",
					{"rt2"},
				},
			},
		},
