		linkback = "0121_00115",
		linknext = "0121_00117",
		line = 1524,
	},
	["0121_00117"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2286", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Here, got my battle report for you. Took a while, but I managed to piece together how the enemy's parties were divvied up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“给你，战斗报告书。虽然花了一些时间，但我还是总结了一下分割敌人型编队的问题点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「給你，戰鬥報告書。雖然花了一些時間，但我還是總結了一下分割敵人型編隊的問題點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00116",
		linknext = "0121_00118",
		line = 1539,
	},
	["0121_00118"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00104", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2287", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“This time we were effective indoors by knowing where the enemy was coming from, but once we're outside in open spaces, we need to be conscious of more than just their direction of movement.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“因为这次是室内战，敌人来的方向是故定的所以很有效，但如果是在野外的宽广场所，就必须要注意前进方向以外的敌人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為這次是室內戰，敵人來的方向是故定的所以很有效，但如果是在野外的寬廣場所，就必須要注意前進方向以外的敵人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00117",
		linknext = "0121_00119",
		line = 1554,
	},
	["0121_00119"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2288", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“If Wata and I attack as flankers and you attack from the other side, that leaves the support members at the rear exposed and potentially in danger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我和渡酱作为边锋进行攻击，如果你去夹攻，会让后面的支援队员孤立无援，危险程度上升的可能性很高。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我和渡醬作為邊鋒進行攻擊，如果你去夾攻，會讓後面的支援隊員孤立無援，危險程度上升的可能性很高。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00118",
		linknext = "0121_00120",
		line = 1566,
	},
	["0121_00120"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2289", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Plus, if one of us in the advance guard gets injured, there's the issue of there being no route of escape. We also have to worry about stamina and taking rests.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“而且如果前卫的我们受伤，没有撤退的途径也是个问题，体力和休息也有问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「而且如果前衛的我們受傷，沒有撤退的途徑也是個問題，體力和休息也有問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00119",
		linknext = "0121_00121",
		line = 1578,
	},
	["0121_00121"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[7500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=7500, time=300, mode=3, x=0, y=0},
				{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=7500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2290", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“As you've said previously, we need to have a place we can return to, and yet still be aware of the support members that we have to protect... Jun, are you listening?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“果然就像你之前说的那样，我们要创造出可以回去的场所，而且还要把保护支援队员的人员配置在中间……淳，你在听吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「果然就像你之前說的那樣，我們要創造出可以回去的場所，而且還要把保護支援隊員的人員配置在中間……淳，你在聽嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00120",
		linknext = "0121_00122",
		line = 1595,
	},
	["0121_00122"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00121",
		linknext = "0121_00123",
		line = 1607,
	},
	["0121_00123"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1769", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Dammit, Bro, start listening. If this keeps up, we're gonna keep fighting indefinitely for no good reason, like a bunch of rebels without a cause.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喂哥哥好好听着啊……这样下去如同恶势力般的战斗风格是改变不了的——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喂哥哥好好聽著啊……這樣下去如同惡勢力般的戰鬥風格是改變不了的——」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00122",
		linknext = "0121_00124",
		line = 1621,
	},
	["0121_00124"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2291", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, it's fine, Asa. I went to the trouble of making it this time, but I don't really need to anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“算了麻沙酱……虽然做了，但这已经是没有必要的东西了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「算了麻沙醬……雖然做了，但這已經是沒有必要的東西了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00123",
		linknext = "0121_00125",
		line = 1636,
	},
	["0121_00125"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=3, act="移動", x=-600, y=0, time=1400},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00110", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=500, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=5, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2091", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yes... We received notification that Fumino was delivered safely to Sakimori earlier, too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是的……防人老人也已传来成功保护好文乃酱的消息了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是的……防人老人也已傳來成功保護好文乃醬的消息了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00124",
		linknext = "0121_00126",
		line = 1653,
	},
	["0121_00126"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00112", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2214", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I hope she's doing okay... I wonder if she'll write to us soon?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“她现在还好吗……？是不是该来信了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「她現在還好嗎……？是不是該來信了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00125",
		linknext = "0121_00127",
		line = 1667,
	},
	["0121_00127"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00116", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1770", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Who gives a shit if that fuckin' minx writes us or not!? I bet her rich-ass sugar daddy's pampering her like a goddamn princess right now anyway!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不用啦那种家伙的信不来也好……！反正肯定会被有钱的老爷爷细心呵护的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不用啦那種傢伙的信不來也好……！反正肯定會被有錢的老爺爺細心呵護的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00126",
		linknext = "0121_00128",
		line = 1682,
	},
	["0121_00128"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00117", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2292", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We haven't received any further word about the abolition of the perverted sex law either, so we're kinda in the dark about things right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“关于破坏变态条例这件事，因为没有后续信息，所以也不知道怎么样了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「關於破壞變態條例這件事，因為沒有後續報導，所以也不知道怎麼樣了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00127",
		linknext = "0121_00129",
		line = 1696,
	},
	["0121_00129"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2215", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Don't worry about it! I'm sure he's working real hard on it as we speak! Like, huffing and puffing away!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没问题啦〜！现在那个爷爷正在努力呢！哼，哼，哼～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒問題啦〜！現在那個爺爺正在努力呢！哼，哼，哼～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00128",
		linknext = "0121_00130",
		line = 1711,
	},
	["0121_00130"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2092", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“They say a watched cock never hardens, after all! We'll just wait and see what happens.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“毕竟有句话叫欲速则不高潮……！我们慢慢等吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「畢竟有句話叫欲速則不高潮……！我們慢慢等吧。」",
