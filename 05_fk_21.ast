	["0121_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种事，根本疯了——",
					{"rt2"},
				},
