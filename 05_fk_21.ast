		linkback = "0121_00161",
		linknext = "0121_00163",
		line = 2123,
	},
	["0121_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her face is emotionless. Her hair is drooping in complete neglect.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使披头散发，露出真正的面无表情，",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使披頭散發，露出真正的面無表情，",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00162",
		linknext = "0121_00164",
		line = 2133,
	},
	["0121_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But that is, without a doubt, Kotoyose Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那也是不折不扣的琴寄文乃本人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那也是不折不扣的琴寄文乃本人。",
					{"rt2"},
