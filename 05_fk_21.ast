	["0121_00075"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"fg", file="asane_01m_00008", file1="asane_01m_00111", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1754", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Broooo! Why the hell didn't ya wake me!? I barely got any time to spare now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥〜……为什么不叫醒我啊〜……！起来发现完全没有时间了啊〜……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥〜……為什麼不叫醒我啊〜……！起來發現完全沒有時間了啊〜……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00074",
		linknext = "0121_00076",
		line = 891,
	},
	["0121_00076"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
