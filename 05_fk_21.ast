		line = 354,
	},
	["0121_00031"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0006", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "???"},
					"“Is it really that big? Let me take a look for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "？ ？ ？"},
					"“……有那么大吗？来来来，给阿姨看看吧？”",
