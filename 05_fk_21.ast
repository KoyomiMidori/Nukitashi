		linkback = "0121_00037",
		linknext = "0121_00039",
		line = 440,
	},
	["0121_00039"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0009", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "???"},
					"“Human beings all have their differences. There's no need to complain about everyone being different, but more importantly, it's no reason to beat yourself up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "？ ？ ？"},
					"“人类啊，每个人都是不一样的。这种差异没必要被任何人抱怨，最重要的是不能把它当成讨厌自己的理由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "？？？"},
					"「人類啊，每個人都是不一樣的。這種差異沒必要被任何人抱怨，最重要的是不能把它當成討厭自己的理由。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00038",
		linknext = "0121_00040",
		line = 452,
	},
	["0121_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I asked her why.",
					{"rt2"},
				},
