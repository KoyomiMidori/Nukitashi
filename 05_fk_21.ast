	["0121_00038"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She said the same thing the other girl had said to me, with an unaffected smile.",
					{"rt2"},
				},
