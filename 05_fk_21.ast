			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yaaaawn... Damn, I'm tired. Nothing like watching TV and vibing on the sofa to take the edge off... Hee hee.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呼啊啊啊啊〜……真是困啊……一边看电视一边在沙发上躺着也很幸福……呵呵……”",
					{"rt2"},
				},
