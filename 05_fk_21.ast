				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“More importantly, how's the SS Big Three been doing, Wata?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“比起那个渡酱，FS三巨头的情况，现在怎么样了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「比起那個渡醬，FS三巨頭的情況，現在怎麼樣了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00103",
		linknext = "0121_00105",
		line = 1339,
	},
	["0121_00105"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=4, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2212", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“They seemed well! Apparently they need a nice, long vacation due to all those bullets they took. So their underlings are going to be working in their place to make up for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“看起来还不错哦！如果中了很多枪好像就必须休长假，所以是FS的后辈们在加油呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「看起來還不錯哦！如果中了很多槍好像就必須休長假，所以是FS的後輩們在加油呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00104",
		linknext = "0121_00106",
		line = 1354,
	},
	["0121_00106"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", path=":fg/misaki_01m/", id=5, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=200, y=0},
		{"fgact", ch="美岬", id=5, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2089", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That rep from the other class, Hanamaru? I think that's her name. She seemed pretty hyped up, so that's probably why.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“隔壁班的委员长……花丸同学？她努力的理由原来是这样啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「隔壁班的委員長……花丸同學？她努力的理由原來是這樣啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00105",
		linknext = "0121_00107",
		line = 1369,
	},
	["0121_00107"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-200, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2213", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I feel real bad, though... Rei got pretty banged up, and I heard the hospital got a lot of new admissions too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是我好心疼啊……礼酱也受伤了，其他人也是，说是有好多人都去住院了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是我好心疼啊……禮醬也受傷了，其他人也是，說是有好多人都去住院了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00106",
		linknext = "0121_00108",
		line = 1384,
	},
	["0121_00108"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2282", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, you know. That couldn't be avoided. We were taking them on to save Fumino, so don't beat yourself up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好了好了，这也没有办法……毕竟是为了帮助文乃，不是渡酱的错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好了好了，這也沒有辦法……畢竟是為了幫助文乃，不是渡醬的錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00107",
		linknext = "0121_00109",
		line = 1399,
	},
	["0121_00109"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2090", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, and I've heard that Onabuta's doing all right too. Apparently, she may or may not be coincidentally under investigation owing to her ridiculous sexual appetite.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊，听说女部田同学没事。反倒是她的性欲太强可能是病，结果不知道有没有去检查……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊，聽說女部田同學沒事。反倒是她的性慾太強可能是病，結果不知道有沒有去檢查……」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00108",
		linknext = "0121_00110",
		line = 1411,
	},
	["0121_00110"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00115", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=3, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2283", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I'm most worried about the student council prez myself. She's still coming to school acting like nothing's happened.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这么说来，总觉得若无其事上着学的学生会长逐渐可怕起来了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這麼說來，總覺得若無其事上著學的學生會長逐漸可怕起來了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00109",
		linknext = "0121_00111",
		line = 1426,
	},
	["0121_00111"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=6, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1767", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sh-She's in my class! And I'm already terrified that she definitely saw my face in battle but hasn't said a word about ow-ow-ow!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“她、她跟我同班哦……！？明明已经完完全全暴露了，但却什么都没跟我说，真的好可怕～～～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「她、她跟我同班哦……！？明明已經完完全全暴露了，但卻什麼都沒跟我說，真的好可怕～～～」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00110",
		linknext = "0121_00112",
		line = 1441,
	},
	["0121_00112"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1768", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Anyway. Rumor has it, the OSS bigwigs summoned her to meetings in an effort to figure out who was responsible for this. She's been absent from time to time, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……不过，她好像还是被SHO高层叫了过去，听说要被追究这次的责任。她有时也会请假，没来上学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……不過，她好像還是被SHO高層叫了過去，聽說要被追究這次的責任。她有時也會請假，沒來上學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00111",
		linknext = "0121_00113",
		line = 1456,
	},
	["0121_00113"] = {
		{"se", id=0, loop=0, file="se_a117"},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00120", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00107", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=5500, time=300, mode=3, x=-600, y=0},
				{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=5500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase2284", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I highly doubt that even she'd be able to play it business as usual in these circumstances... All right, Jun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“即使是学生会长，也没法正常营业是吗……好，淳！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「即使是學生會長，也沒法正常營業是嗎……好，淳！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00112",
		linknext = "0121_00114",
		line = 1474,
	},
	["0121_00114"] = {
