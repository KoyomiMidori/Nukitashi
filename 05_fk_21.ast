		line = 324,
	},
	["0121_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A few days after we met, I told her about how I was bullied at school, and that I ended up hurting a certain girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在相遇的几天后，我告诉了她我在学校被欺负，伤害了某位女孩的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在相遇的幾天後，我告訴了她我在學校被欺負，傷害了某位女孩的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00027",
		linknext = "0121_00029",
		line = 334,
	},
	["0121_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She never once called it “being bullied.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"她完全没有说过“你被欺凌了”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她完全沒有說過「你被欺凌了」。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00028",
		linknext = "0121_00030",
		line = 344,
	},
	["0121_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Surely she was treading carefully, so as not to injure my youthful pride.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概是连我幼小的自尊，她都顾虑到了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概是連我幼小的自尊，她都顧慮到了吧。",
					{"rt2"},
				},
