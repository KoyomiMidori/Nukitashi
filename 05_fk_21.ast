			},
			ja = {
				{
					name = {"文歌", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "???"},
					"“Hey, what are you doing here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "？ ？ ？"},
					"“……呐，你在那里干什么？”",
