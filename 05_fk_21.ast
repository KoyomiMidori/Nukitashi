				},
			},
			tw = {
				{
					name = {"文歌", "？？？"},
					"「……吶，你在那裡幹什麼？」",
					{"rt2"},
				},
			},
		},
		linknext = "0121_00002",
		line = 23,
	},
	["0121_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those words marked the start of a memory I'd chosen to forget until now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一直逃避不去直视的回忆，从那句话开始。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一直逃避不去直視的回憶，從那句話開始。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00001",
		linknext = "0121_00003",
		line = 33,
	},
	["0121_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This was after I'd hurt my only friend. That girl had left the island by now, and I was all alone again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是我伤害了唯一的朋友，那个女孩子离开了岛，我又变回孤身一人的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是我傷害了唯一的朋友，那個女孩子離開了島，我又變回孤身一人的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00002",
		linknext = "0121_00004",
		line = 43,
	},
	["0121_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was just sitting at the site of our secret hideout.",
					{"rt2"},
				},
			},
