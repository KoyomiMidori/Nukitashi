			cn = {
				{
					"我问她为什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我問她為什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00039",
		linknext = "0121_00041",
		line = 462,
	},
	["0121_00041"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0010", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"文歌", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文歌", "???"},
					"“Well, you've effectively pushed away the people that have acknowledged you for what you are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文歌", "？ ？ ？"},
					"“因为会变成你自己否定了肯定你的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文歌", "？？？"},
					"「因為會變成你自己否定了肯定你的人。」",
					{"rt2"},
				},
