	["0121_00162"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=1000, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="jun_01f_00001", file2="jun_01f_00202", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
