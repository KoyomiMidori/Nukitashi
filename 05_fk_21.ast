				},
			},
			tw = {
				{
					name = {"文歌", "？？？"},
					"「……有那麼大嗎？來來來，給阿姨看看吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00030",
		linknext = "0121_00032",
		line = 366,
	},
	["0121_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hesitant though I was, I took my pants down and showed her my equipment.",
