			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well, not like I can blame you. You haven't been waking me lately. Fumino was doing that instead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不过也没有办法……毕竟你最近都没有来叫我起来……都是文乃代替的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不過也沒有辦法……畢竟你最近都沒有來叫我起來……都是文乃代替的。」",
