				{
					"我虽然犹豫，但还是脱下了衣服，给女人看了我的鸡巴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我雖然猶豫，但還是脫下了衣服，給女人看了我的肉棒。",
					{"rt2"},
				},
