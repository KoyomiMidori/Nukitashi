	["0121_00102"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00114", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2088", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But I wonder how long we'll be able to stay in this base? I never thought about it before, but aren't the costs for electricity and utilities coming out of Sakimori's pockets?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过这个基地能使用到什么时候呢……？我从来没想过，但电费什么的都是防人老人支付的吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過這個基地能使用到什麼時候呢……？我從來沒想過，但電費甚麼的都是防人老人支付的吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00101",
		linknext = "0121_00103",
		line = 1302,
	},
	["0121_00103"] = {
