		},
		linkback = "0121_00164",
		linknext = "0121_00166",
		line = 2157,
	},
	["0121_00166"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00112", file2="asane_01m_00202", path=":fg/asane_01m/", id=6, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1774", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wh... What? What is this? What the fuck's going on!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶，什么，这是什么，怎、怎么回事……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸，什麼，這是什麼，怎、怎麼回事……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00165",
		linknext = "0121_00167",
		line = 2171,
	},
	["0121_00167"] = {
		{"fg", mode=-1, id=6, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=3, ch="奈々瀬", lv=5, time=300},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg12_1l_00000", x=300, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0164", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“This girl, Kotoyose Fumino, will not be found in any family registry! Anyone doing a simple search will see! And why? Because she was born on Seiran Island, and locked away in isolation from a young age!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“这个叫琴寄文乃的少女没有户籍！一查就知道了！为什么？因为她出生在青蓝岛，从小就被幽禁着！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「這個叫琴寄文乃的少女沒有戶籍！一查就知道了！為什麼？因為她出生在青藍島，從小就被幽禁著！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00166",
		linknext = "0121_00168",
		line = 2190,
	},
	["0121_00168"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0165", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“But most importantly... this girl is Senator Hitoura's daughter!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“而且最重要的是，这个少女——是仁浦先生的女儿！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「而且最重要的是，這個少女——是仁浦先生的女兒！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00167",
		linknext = "0121_00169",
		line = 2202,
	},
	["0121_00169"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0166", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“His biological daughter, confined to this island, born of a woman he had a fling with! She stands before you now! This in itself is unacceptable!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“是他让偶遇的女人生下的，一直藏在岛上的亲生女儿！这就是他的真面目！这就已经是个大问题了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「是他讓偶遇的女人生下的，一直藏在島上的親生女兒！這就是他的真面目！這就已經是個大問題了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00168",
		linknext = "0121_00170",
		line = 2214,
	},
	["0121_00170"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0167", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“The island advertises sex there as being safe, but is that really the case? Are children not born there? How exactly are they dealt with?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“然后虽然岛上的广告说做爱是安全的，但真的是那样吗！？不会有孩子出生吗！？那是怎么处理的呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「然後雖然島上的廣告說做愛是安全的，但真的是那樣嗎！？不會有孩子出生嗎！？那是怎麼處理的呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00169",
		linknext = "0121_00171",
		line = 2226,
	},
	["0121_00171"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0168", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Is Seiran Island not just accumulating young boys and girls this way for the sake of prostitution, and calling it a tourist attraction?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“青蓝岛不就是像这样，假借旅游资源之名来吸引卖淫的少男少女入住的吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「青藍島不就是像這樣，假借旅遊資源之名來吸引賣淫的少男少女入住的嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00170",
		linknext = "0121_00172",
		line = 2238,
	},
	["0121_00172"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0169", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“And furthermore, is the money they make from this not distributed through the country back to organized crime organizations, and then fed back in order to further develop the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“然后赚来的钱都落入了全国的暴力团组织上，最后再次变成继续养肥青蓝岛的资金不是吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「然後賺來的錢都落入了全國的暴力團組織上，最後再次變成繼續養肥青藍島的資金不是嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00171",
		linknext = "0121_00173",
		line = 2250,
	},
	["0121_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That comment draws the biggest flurry of flashes yet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这句话，让今天最闪亮的闪光灯打了上去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這句話，讓今天最閃亮的閃光燈打了上去。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00172",
		linknext = "0121_00174",
		line = 2260,
	},
	["0121_00174"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00122", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=5, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="美岬", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki2093", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No... way... How is this even possible?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这、这种……事情……这种论调，是不可能的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這、這種……事情……這種論調，是不可能的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00173",
		linknext = "0121_00175",
		line = 2276,
	},
	["0121_00175"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00113", path=":fg/hinami_01m/", id=4, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="ヒナミ", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2216", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Th-This is all wrong! I thought we sent Fumino to her grandfather so she could be happy! Didn't we, Tachibana!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“好、好奇怪啊……！？文乃酱去了老爷爷那里，应该会变幸福的不是吗……！？对吧，橘君……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「好、好奇怪啊……！？文乃醬去了老爺爺那裡，應該會變幸福的不是嗎……！？對吧，橘君……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00174",
		linknext = "0121_00176",
		line = 2290,
	},
	["0121_00176"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
