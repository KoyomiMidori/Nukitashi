	["0121_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe I was just betting on having an adult tell me that it wasn't that big after all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时，说不定我是在期待大人对我说“并没有很大”。",
