					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sorry... I forgot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，对不起……我忘记了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，對不起……我忘記了……」",
					{"rt2"},
				},
