	},
	["0121_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So this is what it feels like to be lost for words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我说不出话来，原来是这样啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我說不出話來，原來是這樣啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00179",
		linknext = "0121_00181",
		line = 2349,
	},
	["0121_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I stare at the monitor in utter disbelief.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我呆呆地凝视着显示器的另一侧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我呆呆地凝視著顯示器的另一側。",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00180",
		linknext = "0121_00182",
		line = 2359,
	},
	["0121_00182"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg12_1l_00000", x=300, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0170", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Should this be allowed? Can we permit such an island to exist?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人"},
					"“能允许这样的事吗！能允许这样的岛吗——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人"},
					"「能允許這樣的事嗎！能允許這樣的島嗎——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00181",
		linknext = "0121_00183",
		line = 2374,
	},
	["0121_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Captions appear on the screen to punctuate the speech.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与写着政治家的字幕同时出现的老人——",
					{"rt2"},
				},
			},
			tw = {
				{
					"與寫著政治家的字幕同時出現的老人——",
					{"rt2"},
				},
			},
		},
		linkback = "0121_00182",
		linknext = "0121_00184",
		line = 2384,
	},
	["0121_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And Sakimori — the man giving the speech — is thanked for his effort by a relentless barrage of camera flashes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"防人老人在暴风雨般的闪光灯中如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"防人老人在暴風雨般的閃光燈中如此說道。",
					{"rt2"},
				},
			},
		},
