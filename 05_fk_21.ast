	["0121_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, I'm concerned about what will become of the perverted sex law too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然也很在意变态条例究竟会有怎样的变化。",
