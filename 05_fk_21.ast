			},
		},
		linkback = "0121_00163",
		linknext = "0121_00165",
		line = 2143,
	},
	["0121_00165"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00109", path=":fg/nanase_01m/", id=3, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="奈々瀬", id=3, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
