			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Even at this hour, you're up working hard and trying to come up with a plan... Thank you. It makes me happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这么晚了，你为了我们努力考虑了这么多……谢谢，我很高兴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這麼晚了，你為了我們努力考慮了這麼多……謝謝，我很高興。」",
					{"rt2"},
				},
			},
		},
