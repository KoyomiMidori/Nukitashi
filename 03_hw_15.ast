		},
		linkback = "0065_00212",
		linknext = "0065_00214",
		line = 2687,
	},
	["0065_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata puffs out her cheeks and pouts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱鼓起脸颊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬鼓起臉頰。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00213",
		linknext = "0065_00215",
		line = 2697,
	},
	["0065_00215"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's starting to get depressed again, so we should probably stop.",
					{"rt2"},
				},
			},
			cn = {
				{
					"做得太过分她又要沮丧了，就先这样吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"做得太過分她又要沮喪了，就先這樣吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00214",
		linknext = "0065_00216",
		line = 2712,
	},
	["0065_00216"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00101", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, you're part of the team now. You don't need to be so formal, just address us normally.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃——你已经是我们的同伴了。不要拘谨地喊‘大人’，普通地喊我们好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃——你已經是我們的同伴了。不要拘謹地喊『大人』，普通地喊我們好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00215",
		linknext = "0065_00217",
		line = 2725,
	},
	["0065_00217"] = {
		{"bgm", file="bgm10", vol=100},
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00106", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0224", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But... I owe you my life...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是……我要对大家的帮助表示感谢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是……我要對大家的幫助表示感謝……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00216",
		linknext = "0065_00218",
		line = 2740,
	},
	["0065_00218"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then think of it as respecting our preference. I know I'd definitely prefer if we could be more casual with each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，能不能更平常地叫我们呢？我不想让同伴之间过于拘谨。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，能不能更平常地叫我們呢？我不想讓同伴之間過於拘謹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00217",
		linknext = "0065_00219",
		line = 2752,
	},
	["0065_00219"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00110", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0225", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Very well. If that is what you wish... then I will strive to respect that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我明白了。如果您希望的话……我就这么做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我明白了。如果您希望的話……我就這麼做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00218",
		linknext = "0065_00220",
		line = 2766,
	},
	["0065_00220"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, please.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，拜托了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，拜託了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00219",
		linknext = "0065_00221",
		line = 2778,
	},
	["0065_00221"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00101", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0226", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Okay, so once more... It's a pleasure to make your acquaintances, Tachibana, Hinami, Asane, Nanase, and... Corpulent...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“好。那么……请多关照。橘同学、雏见同学、麻沙音同学、奈奈濑同学、胖猪同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「好。那麼……請多關照。橘同學、雛見同學、麻沙音同學、奈奈瀨同學、胖豬同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00220",
		linknext = "0065_00222",
		line = 2792,
	},
	["0065_00222"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00101", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="misaki_01m_00001", file2="misaki_01m_00202", file3="misaki_01m_00303", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0423", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Looks like I'm the butt of the joke now, huh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嗯，我已经完全成为一个梗了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗯，我已經完全成為一個梗了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00221",
		linknext = "0065_00223",
		line = 2807,
	},
	["0065_00223"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00111", file2="fumino_02m_00202", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0227", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“H-Have I made yet another blunder...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我、我又说错了什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我、我又說錯了什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00222",
		linknext = "0065_00224",
		line = 2821,
	},
	["0065_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the second time she's done this, but she looks even more flustered than before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与刚才说同句话时相比，文乃显得有些慌张。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與剛才說同句話時相比，文乃顯得有些慌張。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00223",
		linknext = "0065_00225",
		line = 2831,
	},
	["0065_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe this is her way of opening up to us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许虽然只有一点点，但她对我们敞开了心胸吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許雖然只有一點點，但她對我們敞開了心胸吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00224",
		linknext = "0065_00226",
		line = 2841,
	},
	["0065_00226"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That makes me happy to see.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是的——这样就可以了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是的——這樣就可以了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00225",
		linknext = "0065_00227",
		line = 2855,
	},
	["0065_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For so long, we searched for Fumino, for the sole purpose of bringing down the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"的确，我们为了使条例失效一直在寻找文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"的確，我們為了使條例失效一直在尋找文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00226",
		linknext = "0065_00228",
		line = 2865,
	},
	["0065_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I successfully infiltrated our bitter enemy, the SS, to that end. I was able to get their trust, before finally betraying them to their face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，还不惜潜入仇敌FS，并以最糟糕的形式背叛了从中得到的信任。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，還不惜潛入仇敵FS，並以最糟糕的形式背叛了從中得到的信任。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00227",
		linknext = "0065_00229",
		line = 2875,
	},
	["0065_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because of that, we were able to secure Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最后，终于找到了文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最後，終於找到了文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00228",
		linknext = "0065_00230",
		line = 2885,
	},
	["0065_00230"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00101", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now, I know she's not just some tool.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即便如此——我也知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即便如此——我也知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00229",
		linknext = "0065_00231",
		line = 2896,
	},
	["0065_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She shouldn't be used to bring down the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她绝对不是用来使条例崩坏的装置或工具。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她絕對不是用來使條例崩壞的裝置或工具。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00230",
		linknext = "0065_00232",
		line = 2906,
	},
	["0065_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I were to just use her to accomplish my goal, then that would put me in the same league as Senator Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果为了大义而加害别人——那和仁浦先生的做法有什么两样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果為了大義而加害別人——那和仁浦先生的做法有什麼兩樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00231",
