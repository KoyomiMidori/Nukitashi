				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Well done. It looks like you have successfully completed your task.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——辛苦了。看来你顺利完成了任务。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——辛苦了。看來你順利完成了任務。」",
					{"rt2"},
				},
			},
