			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Don't kick me off the islaaaaaand!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不要把我出货啊啊啊啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不要把我出貨啊啊啊啊——！」",
					{"rt2"},
				},
			},
