		linkback = "0065_00288",
		linknext = "0065_00290",
		line = 3660,
	},
	["0065_00290"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suggested it because she was desperate for a way she could help, and even though it was just an offhand comment, she did it every day without complaint.",
					{"rt2"},
				},
			},
			cn = {
				{
					"起先只是个随便的请求，渡酱明明没有这个义务——但她却没有露出任何不悦的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"起先只是個隨便的請求，渡醬明明沒有這個義務——但她卻沒有露出任何不悅的表情。",
					{"rt2"},
