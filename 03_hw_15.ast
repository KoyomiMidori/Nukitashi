				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, even if we've got one more person, we still only have six relatively untrained members.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是——即使同伴增加了，也只是从5人变成了6人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是——即使同伴增加了，也只是從5人變成了6人。",
					{"rt2"},
				},
			},
