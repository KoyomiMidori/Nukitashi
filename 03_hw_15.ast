		{"text"},
		delay = {
			[6000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00104", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=6000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
