					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tranquilo... has hecho un buen trabajo, Tachibana-kun... Buenas noches... Que tengas dulces sueños...”",
					{"rt2"},
				},
			},
			cn = {
