					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Pardon?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯……？”",
					{"rt2"},
				},
			},
			tw = {
