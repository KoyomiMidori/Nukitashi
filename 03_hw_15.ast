		linkback = "0065_00012",
		linknext = "0065_00014",
		line = 156,
	},
	["0065_00014"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00110", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1885", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Con razón no te encontrábamos, si te hacías pasar por un chico en la escuela.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过，女扮男装上学……难怪怎么找女生都找不到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過，女扮男裝上學……難怪怎麼找女生都找不到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00013",
		linknext = "0065_00015",
		line = 169,
	},
	["0065_00015"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00110", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0201", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Sí. También falsifiqué mi nombre. Si les hice perder tiempo valioso, me gustaría disculparme de todo corazón. Por favor, perdónenme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……因为名字也是假的……浪费了大家宝贵的时间，请恕我再次请求各位的饶恕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……因為名字也是假的……浪費了大家寶貴的時間，請恕我再次請求各位的饒恕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00014",
		linknext = "0065_00016",
		line = 183,
	},
	["0065_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"... Qué educada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……太僵硬了。",
					{"rt2"},
