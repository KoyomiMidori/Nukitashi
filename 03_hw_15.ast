				{"vo", file="fumino0215", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Sí. Responderé todo lo que pueda.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯……只要是我能回答的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗯……只要是我能回答的事。」",
