	["0065_00204"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00118", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1323", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Ahora soy una extraña que viste en la calle?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“变得像中国地区的人了——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「變得像中國地區的人了——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00203",
		linknext = "0065_00205",
		line = 2563,
	},
	["0065_00205"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0222", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Eso fue lo que sugirió, ¿no? ¿Lo hice mal?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我是按照橘大人说的做的，有哪里说错了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我是按照橘大人說的做的，有哪裡說錯了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00204",
		linknext = "0065_00206",
		line = 2575,
	},
	["0065_00206"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00114", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1324", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Espera! ¡¿Lo llamas por su apellido pero a mí solo me dices san?! ¡Se supone que soy tu senpai!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“话说橘君后面明明加了大人，为什么我就是同学啊！？我可是前辈哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「話說橘君後面明明加了大人，為什麼我就是同學啊！？我可是前輩哦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00205",
		linknext = "0065_00207",
		line = 2589,
	},
	["0065_00207"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00105", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1125", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Está haciendo lo que le pediste...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那不是你自己说的吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那不是你自己說的嗎……」",
					{"rt2"},
				},
			},
