		line = 1222,
	},
	["0065_00091"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Ahora que lo pienso, hace no mucho parecía unos 12 años menor a mi edad actual!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，我之前还被别人以为比实际年龄小了12岁呢～……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，我之前還被別人以為比實際年齡小了12歲呢～……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00090",
		linknext = "0065_00092",
		line = 1234,
	},
	["0065_00092"] = {
