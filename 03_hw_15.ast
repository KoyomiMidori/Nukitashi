	["0065_00358"] = {
		{"se", id=0, loop=0, file="se_a127"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me abraza con su pequeño cuerpo y me acaricia suavemente la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用娇小的身体抱紧我，用温柔的手抚摸我的头。",
