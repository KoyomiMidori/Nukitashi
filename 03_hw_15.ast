		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who are we talking about again? Hotori?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那应该不会……又不是畔。”",
