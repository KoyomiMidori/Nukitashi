		linkback = "0065_00049",
		linknext = "0065_00051",
		line = 651,
	},
	["0065_00051"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1302", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Now, let me show you around the base a bit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对了，首先得把这个基地的事情告诉文乃！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對了，首先得把這個基地的事情告訴文乃！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00050",
		linknext = "0065_00052",
		line = 665,
	},
	["0065_00052"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata shows no hesitation whatsoever in engaging the anxious Fumino, and proactively gets close to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使面对紧张的文乃，渡酱也毫不畏惧，积极地缩短距离。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使面對緊張的文乃，渡醬也毫不畏懼，積極地縮短距離。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00051",
		linknext = "0065_00053",
		line = 681,
	},
	["0065_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata seems totally fine, despite all that happened just the previous day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然昨天还发生了那样的事，但——这样看着的话，渡酱和平时没什么区别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然昨天還發生了那樣的事，但——這樣看著的話，渡醬和平時沒什麼區別。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00052",
		linknext = "0065_00054",
		line = 691,
	},
	["0065_00054"] = {
		{"bg", id=2, file="bg12_1l_00000", x=200, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[7300] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00114", file2="hinami_02m_00203", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=7300, time=300, mode=3, x=400, y=0},
