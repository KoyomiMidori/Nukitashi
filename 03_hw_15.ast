	},
	["0065_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los ojos de Fumino me miran fijamente, sin pestañear.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃并没有认真对待，而是用那双大眼睛直直看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃並沒有認真對待，而是用那雙大眼睛直直看著我。",
					{"rt2"},
				},
