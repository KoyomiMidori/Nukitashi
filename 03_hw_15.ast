					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, seriously!? If that's true, then if Wata only looks nine years younger, that means she looks more mature for her age than most people!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哇真的假的？那看起来只比实际年龄小9岁的渡酱该不会很成熟吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哇真的假的？那看起來只比實際年齡小9歲的渡醬該不會很成熟吧！？」",
					{"rt2"},
				},
			},
