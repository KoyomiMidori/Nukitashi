			},
		},
		text = {
			vo = {
				{"vo", file="misaki0418", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡¿Qu...?! ¡T-Tachibana-san...! ¡¿Aun con todo es una despistada...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“什……！？橘、橘同学……！她居然还有天然呆属性……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「什……！？橘、橘同學……！她居然還有天然呆屬性……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00036",
		linknext = "0065_00038",
		line = 478,
	},
	["0065_00038"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Solo cálmate...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你跟我报告也没用……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你跟我報告也沒用……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00037",
		linknext = "0065_00039",
		line = 490,
	},
	["0065_00039"] = {
		{"bgm", stop=1},
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun después de todo eso, la mirada de Fumino sigue siendo impasible e imposible de entender. Parece que no se dio cuenta de que dijo algo grosero.",
					{"rt2"},
				},
			},
			cn = {
				{
					"依然读不出文乃的表情，但她好像是真的不知道自己哪里不礼貌了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"依然讀不出文乃的表情，但她好像是真的不知道自己哪裡不禮貌了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00038",
		linknext = "0065_00040",
		line = 507,
	},
	["0065_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En ese caso, supongo que es un poco despistada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，这里面可能含有天然呆的成分。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，這裡面可能含有天然呆的成分。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00039",
		linknext = "0065_00041",
		line = 517,
	},
	["0065_00041"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00104", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"bgm", file="bgm07", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1120", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Espera, no eres la única que tiene cuentas que saldar con ella. Oye, señorita vestida de chico, como sea que te llames. ¿Fuumin?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“还有我这里……喂喂喜欢扮男装的小姑娘啊……叫什么名字来着……？文米？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「還有我這裡……喂喂喜歡扮男裝的小姑娘啊……叫什麼名字來著……？文米？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00040",
		linknext = "0065_00042",
		line = 532,
	},
	["0065_00042"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0204", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“... Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我是文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我是文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00041",
		linknext = "0065_00043",
		line = 544,
	},
	["0065_00043"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1121", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Je, Fumino-chan. Te informo que yo soy la hermana menor aquí. Si quieres que te consientan por ser la hermana menor, primero tendrás que pasar por encima de mí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶，文乃酱啊……我话说在前面这里的低龄位置已经被我占走了……如果你以为自己年龄最小就能得到大家的疼爱就大错特错了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸，文乃醬啊……我話說在前面這裡的低齡位置已經被我佔走了……如果你以為自己年齡最小就能得到大家的疼愛就大錯特錯了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00042",
		linknext = "0065_00044",
		line = 558,
	},
	["0065_00044"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00110", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1122", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pero si realmente lo quieres, solo acércate a mí. Te voy a consentir como nunca.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“而且……如果想被好好‘疼爱’一下的话我会好好‘疼爱’你的哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「而且……如果想被好好『疼愛』一下的話我會好好『疼愛』你的哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00043",
		linknext = "0065_00045",
		line = 572,
	},
	["0065_00045"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00103", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=500, mode=3, x=800, y=0},
		{"fg", file="asane_02m_00001", file1="asane_02m_00124", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="移動", x=-200, y=0, time=700},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-400, y=0, time=500},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1299", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Oye, no te pongas a amenazar a la chica nueva!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“喂，不能威胁新来的孩子哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「喂，不能威脅新來的孩子哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00044",
		linknext = "0065_00046",
		line = 590,
	},
	["0065_00046"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1300", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Lo siento, Fumino-chan. Asane-chan quiere mucho a su hermano mayor y le preocupa un poco que otra niña ocupe su lugar como hermana menor. Lo entiendes, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对不起文乃酱。因为麻沙音酱最喜欢哥哥了……所以有小孩在的话她会担心哥哥被抢走。体谅她吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對不起文乃醬。因為麻沙音醬最喜歡哥哥了……所以有小孩在的話她會擔心哥哥被搶走。體諒她吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00045",
		linknext = "0065_00047",
		line = 604,
	},
	["0065_00047"] = {
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asiente con la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃果然还是点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃果然還是點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00046",
		linknext = "0065_00048",
		line = 615,
	},
	["0065_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus ojos e un color inusual miran fijamente a Wata-chan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"凝视着渡酱的那双眼睛——真是不可思议的颜色啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"凝視著渡醬的那雙眼睛——真是不可思議的顏色啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00047",
		linknext = "0065_00049",
		line = 625,
	},
	["0065_00049"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1301", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Seguro que da un poco de miedo estar rodeada de personas mayores, pero no tienes por qué preocuparte! ¡Aquí todo el mundo es muy amable!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“突然被前辈们包围很紧张吧……但是放心好了！大家都是好孩子哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「突然被前輩們包圍很緊張吧……但是放心好了！大家都是好孩子哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00048",
		linknext = "0065_00050",
		line = 639,
	},
	["0065_00050"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0205", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Está bien...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……嗯……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……嗯……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00049",
		linknext = "0065_00051",
		line = 651,
	},
	["0065_00051"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1302", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ahora, déjame mostrarte un poco la base!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对了，首先得把这个基地的事情告诉文乃！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「對了，首先得把這個基地的事情告訴文乃！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00050",
		linknext = "0065_00052",
		line = 665,
	},
	["0065_00052"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan se siente segura ante a la inquieta Fumino y se muestra dispuesta a acercarse a ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使面对紧张的文乃，渡酱也毫不畏惧，积极地缩短距离。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使面對緊張的文乃，渡醬也毫不畏懼，積極地縮短距離。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00051",
		linknext = "0065_00053",
		line = 681,
	},
	["0065_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan parece estar bien, a pesar de todo lo que pasó el día anterior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然昨天还发生了那样的事，但——这样看着的话，渡酱和平时没什么区别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然昨天還發生了那樣的事，但——這樣看著的話，渡醬和平時沒什麼區別。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00052",
		linknext = "0065_00054",
		line = 691,
	},
	["0065_00054"] = {
		{"bg", id=2, file="bg12_1l_00000", x=200, y=0, lv=5, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
