					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. As per your request, we have located and secured Kotoyose Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是——按照你的命令，成功确保了琴寄文乃的安全。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
