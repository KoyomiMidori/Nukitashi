	},
	["0065_00350"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00102", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1352", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hehe... I get it. You've been thinking so hard, you went and exhausted yourself... When that happens, the best thing to do is rest. Come on, you can sleep beside me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵……我明白。一直动脑子会很累吧……这种时候，就让它休息吧。好了，过来，我会陪着你睡觉的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呵呵……我明白。一直動腦子會很累吧……這種時候，就讓它休息吧。好了，過來，我會陪著你睡覺的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00349",
		linknext = "0065_00351",
		line = 4420,
	},
	["0065_00351"] = {
		{"text"},
		text = {
