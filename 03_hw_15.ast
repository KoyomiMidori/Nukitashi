		linkback = "0065_00125",
		linknext = "0065_00127",
		line = 1656,
	},
	["0065_00127"] = {
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir. May I ask one thing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老爷爷，我想问你一个问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「老爺爺，我想問你一個問題。」",
