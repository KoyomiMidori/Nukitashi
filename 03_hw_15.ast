				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé que lo que pasó después de rescatar a Fumino nos pesa mucho a los dos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从昨天帮助文乃的那一刻起，我们应该一直都在心中有所牵挂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從昨天幫助文乃的那一刻起，我們應該一直都在心中有所牽掛。",
