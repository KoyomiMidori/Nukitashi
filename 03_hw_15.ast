					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Ja, jaja, jajaja... Lo siento. Es una broma, ¿verdad...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“哈，哈哈，啊哈哈哈……非常抱歉。我不太擅长做这种事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「哈，哈哈，啊哈哈哈……非常抱歉。我不太擅長做這種事……」",
					{"rt2"},
