	["0065_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata has an expression that I can read easily.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果渡酱的情感，我可以从她的表情读取。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果渡醬的情感，我可以從她的表情讀取。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00160",
		linknext = "0065_00162",
		line = 2046,
	},
	["0065_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know all too well that, despite her naive appearance and tendencies, she can be surprisingly good at picking up on people's feelings.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看似天真的她，其实意外地对情感的细微变动极其敏锐，这我知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看似天真的她，其實意外地對情感的細微變動極其敏銳，這我知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00161",
		linknext = "0065_00163",
		line = 2056,
	},
	["0065_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if I can't comprehend Fumino's feelings, maybe she can.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算我办不到，但如果是渡酱的话，或许可以读懂文乃的内心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算我辦不到，但如果是渡醬的話，或許可以讀懂文乃的內心。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00162",
		linknext = "0065_00164",
		line = 2066,
	},
	["0065_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's looking at Fumino with great concern in her eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果这样的渡酱，对文乃投射出如此担心的视线——那么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果這樣的渡醬，對文乃投射出如此擔心的視線——那麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00163",
		linknext = "0065_00165",
		line = 2076,
	},
	["0065_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I probably shouldn't just hand her over so casually.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然，不应该简简单单地交出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然，不應該簡簡單單地交出去。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00164",
		linknext = "0065_00166",
		line = 2086,
	},
	["0065_00166"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"ex", time=200, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sir, regarding the handover, there's something I'd like to confirm, just to be sure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老爷爷——关于文乃的引渡，请一定要做好万全的准备。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「老爺爺——關於文乃的引渡，請一定要做好萬全的準備。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00165",
		linknext = "0065_00167",
		line = 2103,
	},
	["0065_00167"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0077", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“What is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00166",
		linknext = "0065_00168",
		line = 2116,
	},
	["0065_00168"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure you know that to enter or leave the island, you'll need to pass through the sea gate, which is kept under close surveillance by the OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你应该知道，岛的出入，必须通过SHO严格管理的海上大门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你應該知道，島的出入，必須通過SHO嚴格管理的海上大門。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00167",
		linknext = "0065_00169",
		line = 2128,
	},
	["0065_00169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Given the SS knows that Fumino has been taken, smuggling her off the island will be a Herculean task.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“光这样就已经很困难了——再加上，FS还知道文乃被夺走了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「光這樣就已經很困難了——再加上，FS還知道文乃被奪走了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00168",
		linknext = "0065_00170",
		line = 2140,
	},
	["0065_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hell, even the Yakuza have taken root on the island and are hunting for her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“连盘踞在岛上的黑社会也盯上了文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「連盤踞在島上的黑社會也盯上了文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00169",
		linknext = "0065_00171",
		line = 2151,
	},
	["0065_00171"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Any carelessness during the transfer could cause her to slip through our fingers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果在引渡文乃的时候疏忽大意，可能会再次失去文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果在引渡文乃的時候疏忽大意，可能會再次失去文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00170",
		linknext = "0065_00172",
		line = 2163,
	},
	["0065_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I want absolute assurance of her safety, so we know all our effort hasn't been to waste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了不让我们的辛苦化为泡影，请确实确保她的安全。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了不讓我們的辛苦化為泡影，請確實確保她的安全。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00171",
		linknext = "0065_00173",
		line = 2174,
	},
	["0065_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Otherwise, I'm afraid I can't hand her over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不这样的话，就不能把文乃交给你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不這樣的話，就不能把文乃交給你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00172",
		linknext = "0065_00174",
		line = 2185,
	},
	["0065_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I say the whole thing in one breath to avoid any objections.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了不让他反驳，我一口气说出了所有的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了不讓他反駁，我一口氣說出了所有的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00173",
		linknext = "0065_00175",
		line = 2195,
	},
	["0065_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This likely won't do anything more than buy us time, but that's not important.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种讨价还价，就算顺利也只能拖延时间——但现在就算只有这样也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種討價還價，就算順利也只能拖延時間——但現在就算只有這樣也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00174",
		linknext = "0065_00176",
		line = 2205,
	},
	["0065_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He doesn't respond at first, but it doesn't even look like he's thinking over his response. He's just staring me down in silence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人没有开口，也看不出在思考的样子——只是，一直沉默着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人沒有開口，也看不出在思考的樣子——只是，一直沉默著。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00175",
		linknext = "0065_00177",
		line = 2215,
	},
	["0065_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My heart quietly beats faster.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心脏默默地高声鼓动着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心臟默默地高聲鼓動著。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00176",
		linknext = "0065_00178",
		line = 2225,
	},
	["0065_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can take this much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过——这种事没什么大不了的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過——這種事沒什麼大不了的。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00177",
		linknext = "0065_00179",
		line = 2235,
	},
	["0065_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hell, after dealing with the drill sergeant from Hell who could easily beat the shit out of me, some old dude who can only yell at me from a screen is nothing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只能隔着画面对话的老人什么的，跟真的会举起拳头挥过来的魔鬼教官相比，根本一点都不可怕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只能隔著畫面對話的老人甚麼的，跟真的會舉起拳頭揮過來的魔鬼教官相比，根本一點都不可怕。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00178",
		linknext = "0065_00180",
		line = 2245,
	},
	["0065_00180"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0078", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Naturally. I've waited too long for this to allow anything to happen to her during the transfer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——这是当然。这对我来说也是最大的夙愿。我一定会做好万全的准备去迎接她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——這是當然。這對我來說也是最大的夙願。我一定會做好萬全的準備去迎接她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00179",
		linknext = "0065_00181",
		line = 2258,
	},
	["0065_00181"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0079", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“I will contact you once more when preparations for a safe transfer are complete. Hold on fast to Fumino until then. Am I clear?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“准备好了之后，我会立刻跟你们联络。在那之前，把文乃牢牢保护好——记住了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「準備好了之後，我會立刻跟你們聯絡。在那之前，把文乃牢牢保護好——記住了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00180",
		linknext = "0065_00182",
		line = 2271,
	},
	["0065_00182"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Without waiting for a response, he cuts off the transmission.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通讯被单方面地切断了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通訊被單方面切斷了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00181",
		linknext = "0065_00183",
		line = 2282,
	},
	["0065_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Gradually, the tension in the air eases.",
					{"rt2"},
				},
			},
			cn = {
				{
					"紧张的空气逐渐变得松弛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"緊張的空氣逐漸變得鬆弛。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00182",
		linknext = "0065_00184",
		line = 2292,
	},
	["0065_00184"] = {
		{"bgm", file="bgm01", vol=100},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1888", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ayo, Jun... Are you really going to just hand her over when he says to?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂淳，如果他真的做好了万全的准备……你真的打算把文乃交给他吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂淳，如果他真的做好了萬全的準備……你真的打算把文乃交給他嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00183",
		linknext = "0065_00185",
		line = 2306,
	},
	["0065_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase, one of the original members of the NLNS, seems to know me well. She reads me like a book.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到今天为止一直一起在寻找文乃的奈奈濑，似乎一眼就看穿了我的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到今天為止一直一起在尋找文乃的奈奈瀨，似乎一眼就看穿了我的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00184",
		linknext = "0065_00186",
		line = 2316,
	},
	["0065_00186"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hell no. Hopefully by then I'll have come up with a plan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——在那之前，我打算想点别的办法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——在那之前，我打算想點別的辦法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00185",
		linknext = "0065_00187",
		line = 2328,
	},
	["0065_00187"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00109", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0218", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Tachibana... Why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“橘大人……为什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「橘大人……為什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00186",
		linknext = "0065_00188",
		line = 2341,
	},
	["0065_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino's pupils dilate in surprise.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃的瞳孔微微收缩着，似乎很惊讶的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃的瞳孔微微收縮著，似乎很驚訝的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00187",
		linknext = "0065_00189",
		line = 2351,
	},
	["0065_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Looks like she was feeling something deep down, after all. This is the first time she's shown any emotion since we got her here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她内心深处果然还是有自己的想法吧——那是她第一次流露出情感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她內心深處果然還是有自己的想法吧——那是她第一次流露出情感。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00188",
		linknext = "0065_00190",
		line = 2361,
	},
	["0065_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So she does have other expressions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她也有那种表情啊。",
					{"rt2"},
				},
