		linknext = "0065_00080",
		line = 1051,
	},
	["0065_00080"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1311", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Asane-chan está en primer año y los demás están segundo! ¡Soy la senpai de todos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君们是2年级生，麻沙音酱是1年级生，所以我最大！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君們是2年級生，麻沙音醬是1年級生，所以我最大！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00079",
		linknext = "0065_00081",
		line = 1065,
	},
	["0065_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino no cambia su expresión, pero comienza a parpadear rápidamente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃——没有改变表情，只是眨着眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃——沒有改變表情，只是眨著眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00080",
		linknext = "0065_00082",
		line = 1075,
	},
	["0065_00082"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00109", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0212", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Ah... por favor, perdónenme. Se esforzaron por hacer una broma, pero no pude reírme...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“哈……真是失敬了，难得您开了个玩笑，可我却没有笑出来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「哈……真是失敬了，難得您開了個玩笑，可我卻沒有笑出來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00081",
		linknext = "0065_00083",
		line = 1089,
	},
	["0065_00083"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00113", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1312", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡N-No es una broma! ¡Voy a graduarme después de este año!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不、不是玩笑啊！？我真的是高年级学生啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不、不是玩笑啊！？我真的是高年級學生啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00082",
		linknext = "0065_00084",
		line = 1103,
	},
	["0065_00084"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00123", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		delay = {
