	},
	["0065_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How I get there from where we are now?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，现在需要知道的是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，現在需要知道的是——",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00108",
		linknext = "0065_00110",
		line = 1447,
	},
	["0065_00110"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00101", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino... There's something I want to ask you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃……我有件事想问你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃……我有件事想問你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00109",
		linknext = "0065_00111",
		line = 1460,
	},
	["0065_00111"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00101", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0215", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes. I'll answer anything that I can.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯……只要是我能回答的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗯……只要是我能回答的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00110",
		linknext = "0065_00112",
		line = 1474,
	},
	["0065_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well then, I'll just cut to the chase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，我就开门见山地问了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，我就開門見山地問了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00111",
		linknext = "0065_00113",
		line = 1486,
	},
	["0065_00113"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is Governor Toshiaki Hitoura your father?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事——仁浦俊明，是你的父亲吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事——仁浦俊明，是你的父親嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00112",
		linknext = "0065_00114",
		line = 1498,
	},
	["0065_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like that, the mood in the base suddenly tenses up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基地的空气紧张起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"基地的空氣緊張起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00113",
		linknext = "0065_00115",
		line = 1508,
	},
	["0065_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino's big eyes stare back at me, unblinking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃并没有认真对待，而是用那双大眼睛直直看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃並沒有認真對待，而是用那雙大眼睛直直看著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00114",
		linknext = "0065_00116",
		line = 1518,
	},
	["0065_00116"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00104", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0216", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have no way of knowing for sure... but I believe he may be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我不确定……但我想应该没错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我不確定……但我想應該沒錯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00115",
		linknext = "0065_00117",
		line = 1532,
	},
	["0065_00117"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00104", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1124", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Huh? Fumino is the governor's daughter...? Bro, what the fuck?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶……？文乃是县知事的……哥哥，这是怎么回事……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸……？文乃是縣知事的……哥哥，這是怎麼回事……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00116",
		linknext = "0065_00118",
		line = 1547,
	},
	["0065_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是——」",
					{"rt2"},
