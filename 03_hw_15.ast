	["0065_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The five usual suspects are gathered in the base, with one extra.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的基地里，除了往常的5个人之外——又多了一个少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的基地裡，除了往常的5個人之外——又多了一個少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00001",
		linknext = "0065_00003",
		line = 29,
	},
	["0065_00003"] = {
		{"bgm", file="bgm10", vol=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00104", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0200", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I would like to take this opportunity to sincerely thank you for rescuing one as worthless as me. I will truly never be able to fully repay your kindness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那么再一次……大家，这次为了在下尽心尽力，真是非常感谢。感激之情无以言表……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那麼再一次……大家，這次為了在下盡心盡力，真是非常感謝。感激之情無以言表……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00002",
		linknext = "0065_00004",
		line = 44,
	},
	["0065_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The white-haired girl, Fumino, bows her head deeply.",
					{"rt2"},
				},
			},
			cn = {
				{
					"淡色头发的少女——文乃深深地低下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"淡色頭髮的少女——文乃深深地低下了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00003",
		linknext = "0065_00005",
		line = 54,
	},
	["0065_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently she's been dressing as a boy to avoid attention until now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"依她的说法，她似乎都是这样女扮男装避开视线的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"依她的說法，她似乎都是這樣女扮男裝避開視線的。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00004",
		linknext = "0065_00006",
		line = 64,
	},
	["0065_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haven't I told you? We're all your comrades here. You don't need to be so formal around us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我说过了吧？这里的人都是你的同伴。不必这么毕恭毕敬。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我說過了吧？這裡的人都是你的同伴。不必這麼畢恭畢敬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00005",
		linknext = "0065_00007",
		line = 76,
	},
	["0065_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nonetheless, her expression remains unchanged.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这么说了——但文乃的表情依然很僵硬。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這麼說了——但文乃的表情依然很僵硬。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00006",
		linknext = "0065_00008",
		line = 86,
	},
	["0065_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's not that surprising, considering she was suddenly smuggled into some weird secret base underneath the school and surrounded by people older than her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然被带到这种地方，被5名年长的人包围，她会这样也是可以理解的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然被帶到這種地方，被5名年長的人包圍，她會這樣也是可以理解的。",
					{"rt2"},
				},
			},
		},
