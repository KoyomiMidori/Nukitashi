		{"fg", file="hinami_02l_00003", file1="hinami_02l_00102", file2="hinami_02l_00201", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1354", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jaja, no te preocupes. Puedes contarme lo que quieras. Si hay algo que quieras decir, puedes decírmelo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊哈哈，你不用在意那种事啊……如果你有什么想说的，不管是什么都可以对我说哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊哈哈，你不用在意那種事啊……如果你有什麼想說的，不管是什麼都可以對我說哦？」",
					{"rt2"},
				},
