	["0065_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como líder del NLNS, es mi deber alcanzar nuestro objetivo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"NLNS是一个团队，而我是这个团队的领导者，所以只要考虑达成目标所需的事情就可以了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"NLNS是一個團隊，而我是這個團隊的領導者，所以只要考慮達成目標所需的事情就可以了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00107",
		linknext = "0065_00109",
		line = 1437,
	},
	["0065_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Cómo llego allí desde este punto...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，现在需要知道的是——",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，現在需要知道的是——",
					{"rt2"},
				},
