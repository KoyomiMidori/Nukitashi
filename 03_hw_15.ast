	["0065_00251"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're talking about Fumino, but the conversation feels forced, and there's a bit of a pink elephant in the room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"两人一边说着文乃的事，一边感到有些语塞，甚至有些脸色苍白。",
					{"rt2"},
				},
			},
			tw = {
				{
					"兩人一邊說著文乃的事，一邊感到有些語塞，甚至有些臉色蒼白。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00250",
		linknext = "0065_00252",
		line = 3171,
	},
	["0065_00252"] = {
