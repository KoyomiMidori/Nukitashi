				{
					"连续几天来我家，加上以前也住过一次，所以似乎把要换洗的衣服放在了我家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連續幾天來我家，加上以前也住過一次，所以似乎把要換洗的衣服放在了我家。",
					{"rt2"},
				},
			},
		},
