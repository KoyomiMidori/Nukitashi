		linknext = "0065_00205",
		line = 2563,
	},
	["0065_00205"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0222", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“That was what Tachibana suggested, right? Did I do something wrong?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我是按照橘大人说的做的，有哪里说错了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我是按照橘大人說的做的，有哪裡說錯了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00204",
		linknext = "0065_00206",
		line = 2575,
	},
	["0065_00206"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00114", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1324", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hey, hold on a sec! You call him by his full surname, but I'm just 'Miss' or 'Wata'!? I'm supposed to be your senior!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“话说橘君后面明明加了大人，为什么我就是同学啊！？我可是前辈哦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「話說橘君後面明明加了大人，為什麼我就是同學啊！？我可是前輩哦！？」",
					{"rt2"},
				},
			},
		},
