		linkback = "0065_00286",
		linknext = "0065_00288",
		line = 3640,
	},
	["0065_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's been a while since then, but I still feel grateful to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过去的事情，即使是现在也觉得感激不尽。",
