		line = 3738,
	},
	["0065_00294"] = {
		{"se", id=0, loop=0, file="se_a150"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's past two in the morning, almost three.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过了凌晨两点，已经快到三点了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過了凌晨兩點，已經快到三點了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00293",
		linknext = "0065_00295",
		line = 3749,
	},
	["0065_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was typing down any ideas I could come up with for the future and combat strategies, but nothing stuck.",
					{"rt2"},
				},
			},
			cn = {
				{
					"电脑屏幕上随意地写着今后的展望和作战内容——但没有半个能派上用场。",
					{"rt2"},
				},
			},
			tw = {
				{
					"電腦螢幕上隨意地寫著今後的展望和作戰內容——但沒有半個能派上用場。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00294",
		linknext = "0065_00296",
		line = 3759,
	},
	["0065_00296"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sigh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00295",
		linknext = "0065_00297",
		line = 3771,
	},
	["0065_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I take off my glasses, rub my eyes, and take a deep breath.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我摘下眼镜，擦了擦眼角，叹了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我摘下眼鏡，擦了擦眼角，嘆了口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00296",
		linknext = "0065_00298",
		line = 3781,
	},
	["0065_00298"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I heard that the best strategists in the past usually studied history, so I looked back on our previous fights and operations for reference, but it was just a waste of time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听说聪明人要向历史学习，所以我也试着调查了一下历史上的战术，看看有没有可以参考的东西——但是毫无意义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽說聰明人要向歷史學習，所以我也試著調查了一下歷史上的戰術，看看有沒有可以參考的東西——但是毫無意義。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00297",
		linknext = "0065_00299",
		line = 3791,
	},
	["0065_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn't learn anything useful, and at some point I got distracted and just ended up looking at cute anthropomorphized warships.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有什么可应用的，而且本来是在调查过去的战术，最后却发现自己在看被拟人化的可爱军舰图像。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有什麼可應用的，而且本來是在調查過去的戰術，最後卻發現自己在看被擬人化的可愛軍艦圖像。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00298",
		linknext = "0065_00300",
		line = 3801,
	},
	["0065_00300"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't focus.",
					{"rt2"},
				},
			},
			cn = {
				{
					"集中力不足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"集中力不足。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00299",
		linknext = "0065_00301",
		line = 3811,
	},
	["0065_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This isn't exactly my forte anyway; Nanase's usually our strategist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也是有原因的——本来，想作战方案是奈奈濑的工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也是有原因的——本來，想作戰方案是奈奈瀨的工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00300",
		linknext = "0065_00302",
		line = 3821,
	},
	["0065_00302"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But, considering the circumstances, it would be unreasonable to rely on her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，如果要拜托她解决现在的状况，太勉强她了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，如果要拜託她解決現在的狀況，太勉強她了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00301",
		linknext = "0065_00303",
		line = 3831,
	},
	["0065_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're up against the SS, the OSS, and the Yakuza. They all want Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SS、OSS、黑社会——所有人都看准了文乃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SS、OSS、黑社會——所有人都看準了文乃。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00302",
		linknext = "0065_00304",
		line = 3841,
	},
	["0065_00304"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not only that, but even though she's our only hope for dismantling the perverted sex law, I agreed to hand her over to the old man.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也决定不把作为废除条例关键的文乃交给那位老人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也決定不把作為廢除條例關鍵的文乃交給那位老人。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00303",
		linknext = "0065_00305",
		line = 3851,
	},
	["0065_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Logically, I don't think it's the wrong decision, and I don't think I was coerced into it, but something about it isn't sitting right with me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不认为这个选择是错的，也完全没有改变的意思——但是，情况有点太严峻了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不認為這個選擇是錯的，也完全沒有改變的意思——但是，情況有點太嚴峻了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00304",
		linknext = "0065_00306",
		line = 3861,
	},
	["0065_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I play my cards wrong and we make an enemy out of our sponsor, then everything we've got will fall apart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果继续这样毫无进展，最后连出资的老人也可能成为敌人，到时就连逃跑的机会都没有了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果繼續這樣毫無進展，最後連出資的老人也可能成為敵人，到時就連逃跑的機會都沒有了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00305",
		linknext = "0065_00307",
		line = 3871,
	},
	["0065_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino first opened up to us when we told her we wouldn't hand her over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃——在我们说不会把她交给老人的时候，才打开了心扉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃——在我們說不會把她交給老人的時候，才打開了心扉。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00306",
		linknext = "0065_00308",
		line = 3881,
	},
	["0065_00308"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That made her trust us, and I can't let myself betray someone's trust again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不能辜负你的信任。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不能辜負你的信任。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00307",
		linknext = "0065_00309",
		line = 3891,
	},
	["0065_00309"] = {
		{"text"},
		text = {
