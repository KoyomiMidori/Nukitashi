	},
	["0065_00281"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Most children would probably still be awake right now, but it's probably way past her bedtime.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这时间现代的小孩都还醒着，但看这个样子，渡酱的睡觉时间早就过了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這時間現代的小孩都還醒著，但看這個樣子，渡醬的睡覺時間早就過了吧。",
					{"rt2"},
