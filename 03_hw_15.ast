			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun... at least try to say something believable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳……这也太勉强了吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳……這也太勉強了吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00091",
		linknext = "0065_00093",
		line = 1247,
	},
	["0065_00093"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shut up and come here for a sec. You, too, Fumino... whisper whisper...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别说了安静迎合我……还有文乃也是……（窸窸窣窣）……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別說了安靜迎合我……還有文乃也是……（窸窸窣窣）……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00092",
		linknext = "0065_00094",
		line = 1259,
	},
	["0065_00094"] = {
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00101", file2="fumino_02m_00202", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
