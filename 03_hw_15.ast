		linkback = "0065_00015",
		linknext = "0065_00017",
		line = 193,
	},
	["0065_00017"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tener a alguien tan sincera y directa en nuestro grupo nos volvería más respetables, creo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"认真到让人觉得和我们在一起真的好吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"認真到讓人覺得和我們在一起真的好嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00016",
		linknext = "0065_00018",
		line = 203,
	},
	["0065_00018"] = {
