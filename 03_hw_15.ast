		line = 1646,
	},
	["0065_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I've never seen the old man in this good a mood before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看到文乃的身影，老人显得格外开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看到文乃的身影，老人顯得格外開心。",
