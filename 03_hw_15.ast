		linkback = "0065_00206",
		linknext = "0065_00208",
		line = 2602,
	},
	["0065_00208"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00116", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
