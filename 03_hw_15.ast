			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Have I made some kind of careless blunder?”",
					{"rt2"},
				},
			},
			cn = {
