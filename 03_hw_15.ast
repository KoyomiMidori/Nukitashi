	["0065_00119"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a190"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My explanation is cut off by a sudden familiar sound. It's been a while since I least heard it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想说的时候——久违地听到了那个声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想說的時候——久違地聽到了那個聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00118",
		linknext = "0065_00120",
		line = 1570,
	},
	["0065_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And to think I was just about to call him to let him know that we've secured Fumino. What uncanny timing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为已经发送了确保文乃安全的消息，现在正是绝佳的时机。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為已經發送了確保文乃安全的消息，現在正是絕佳的時機。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00119",
		linknext = "0065_00121",
		line = 1580,
	},
	["0065_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I assumed he already knew. Since he was the one who gave us the order to find her, it made sense that he'd be tracking our progress.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是下达确保文乃安全命令的当事人，一定会知道的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是下達確保文乃安全命令的當事人，一定會知道的。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00120",
		linknext = "0065_00122",
		line = 1590,
	},
	["0065_00122"] = {
