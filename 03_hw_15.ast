			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I-I... I'm so small... I got mistaken for a hobbit...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我、我……还因为太矮了，被人怀疑……是小矮人呢……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我、我……還因為太矮了，被人懷疑……是小矮人呢……？」",
					{"rt2"},
				},
			},
		},
