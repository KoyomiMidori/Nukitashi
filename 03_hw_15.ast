					name = {"ヒナミ", "Hinami"},
					"“¡Sí! ¡No suena bien!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“对，有两个敬称很奇怪！”",
					{"rt2"},
