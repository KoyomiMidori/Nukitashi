					"「老爺爺，我想問你一個問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00126",
		linknext = "0065_00128",
		line = 1670,
	},
	["0065_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Antes de que Fumino pueda hablar, interrumpo su risa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"掩盖住他的笑声——在文乃想说什么之前抢先插嘴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"掩蓋住他的笑聲——在文乃想說什麼之前搶先插嘴。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00127",
		linknext = "0065_00129",
		line = 1680,
	},
	["0065_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Sabías que... es la hija del gobernador?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你知道她是县知事的女儿吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你知道她是縣知事的女兒嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00128",
		linknext = "0065_00130",
		line = 1691,
	},
	["0065_00130"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0071", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“¿Dónde oíste eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——从哪里听说的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——從哪裡聽說的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00129",
		linknext = "0065_00131",
		line = 1704,
	},
	["0065_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voz se vuelve gélida, provocándome un escalofrío que me recorre la espalda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然——那冰冷的声音让人脊背发颤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然——那冰冷的聲音讓人脊背發顫。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00130",
		linknext = "0065_00132",
		line = 1714,
	},
	["0065_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, su respuesta me confirma que mis sospechas eran acertadas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是这个回答——几乎可以确认文乃是仁浦先生的女儿了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是這個回答——幾乎可以確認文乃是仁浦先生的女兒了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00131",
		linknext = "0065_00133",
		line = 1724,
	},
	["0065_00133"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me infiltré en la SS y descubrí la información mientras investigaba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在潜入FS内部的调查中，偶然知道的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在潛入FS內部的調查中，偶然知道的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00132",
		linknext = "0065_00134",
		line = 1736,
	},
	["0065_00134"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si se me permite preguntar... ¿Por qué nos ocultaste esa información?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“容我问一句，为什么不告诉我们这些情报呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「容我問一句，為什麼不告訴我們這些情報呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00133",
		linknext = "0065_00135",
		line = 1748,
	},
	["0065_00135"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0072", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Déjame preguntarte algo a cambio. ¿Qué motivo tendría para contártelo? ¿Qué ganaría con eso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“那我反过来问你们——为什么要告诉你们那样的事？这样做对我有什么好处？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「那我反過來問你們——為什麼要告訴你們那樣的事？這樣做對我有什麼好處？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00134",
		linknext = "0065_00136",
		line = 1761,
	},
	["0065_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tiene razón.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这句话很有道理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這句話很有道理。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00135",
		linknext = "0065_00137",
		line = 1771,
	},
	["0065_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La posición de Fumino como hija del gobernador no era importante a la hora de completar nuestra misión.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃是仁浦女儿的情报并不是完成任务所必须的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃是仁浦女兒的情報並不是完成任務所必須的。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00136",
		linknext = "0065_00138",
		line = 1781,
	},
	["0065_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dado que la revelación de que tiene una hija ilegítima podría propagarse como la pólvora al filtrarse, tiene sentido que solo lo sepan las personas que necesitan saberlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说到底，仁浦先生有私生子的情报本身就像炸弹一样。不是随随便便能说出去的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說到底，仁浦先生有私生子的情報本身就像炸彈一樣。不是隨隨便便能說出去的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00137",
		linknext = "0065_00139",
		line = 1791,
	},
	["0065_00139"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0073", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Rescataron a Fumino, tal y como lo pedí. Cumpliré mi parte del trato y haré que se elimine la ley súperpervertida. ¿No era ese nuestro acuerdo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“你们按照我的要求确保了文乃。我实现你们要给岛的条例画上句号的愿望。这不就是一切吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「你們按照我的要求確保了文乃。我實現你們要給島的條例畫上句號的願望。這不就是一切嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00138",
		linknext = "0065_00140",
		line = 1804,
	},
	["0065_00140"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, así es.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的——你说得没错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的——你說得沒錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00139",
		linknext = "0065_00141",
		line = 1816,
	},
	["0065_00141"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0074", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Entonces no hace falta que busquen información que pueda llevarlos a su destrucción.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“既然这样，又何必知道多余的事呢？这会引火上身的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「既然這樣，又何必知道多餘的事呢？這會引火上身的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00140",
		linknext = "0065_00142",
		line = 1829,
	},
	["0065_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo expresó como una advertencia, incluso como una amenaza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这听起来就像警告——甚至可以视为在威胁我们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這聽起來就像警告——甚至可以視為在威脅我們。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00141",
		linknext = "0065_00143",
		line = 1839,
	},
	["0065_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dejen de investigar a Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他要我们别再挖掘文乃的事了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他要我們別再挖掘文乃的事了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00142",
		linknext = "0065_00144",
		line = 1849,
	},
	["0065_00144"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0075", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“La existencia de Fumino es fundamental para la destrucción de la ley. Enviaré un emisario para que se lleve a Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——要想终止条例，文乃的存在是必须的。过几天我将派人过去，把文乃接走。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——要想終止條例，文乃的存在是必須的。過幾天我將派人過去，把文乃接走。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00143",
		linknext = "0065_00145",
		line = 1862,
	},
	["0065_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Se la van a llevar...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说要接走文乃——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說要接走文乃——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00144",
		linknext = "0065_00146",
		line = 1874,
	},
	["0065_00146"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0076", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Por supuesto. Ese era el plan. ¿Creen que gastaría tanto dinero por capricho?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“当然，我原先就是这个打算。我并不是平白无故花掉这么多的私人财产来搜索文乃的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「當然，我原先就是這個打算。我並不是平白無故花掉這麼多的私人財產來搜索文乃的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00145",
		linknext = "0065_00147",
		line = 1887,
	},
	["0065_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parecía más o menos alegre cuando se enteró de que Fumino estaba a salvo, pero su tono es helado, y hasta aterrador.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然确认到文乃的安全被确保时语气明朗，但他现在的语气非常冰冷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然確認到文乃的安全被確保時語氣明朗，但他現在的語氣非常冰冷。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00146",
		linknext = "0065_00148",
		line = 1897,
	},
	["0065_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tengo que pensarlo bien. Ahora que sé que es la hija del senador Hitoura, ¿puedo confiar en este misterioso anciano?",
					{"rt2"},
				},
			},
			cn = {
				{
					"想一想——知道文乃是仁浦先生的女儿的现在，是否还应该相信这个老人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想一想——知道文乃是仁浦先生的女兒的現在，是否還應該相信這個老人。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00147",
		linknext = "0065_00149",
		line = 1907,
	},
	["0065_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tal vez solo estoy siendo desagradecido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我知道抱有疑问并不合理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我知道抱有疑問並不合理。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00148",
		linknext = "0065_00150",
		line = 1917,
	},
	["0065_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No puedo negar que su patrocinio fue la razón por la que hemos podido llegar tan lejos, proteger nuestra castidad y rescatar a Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们收到大量的出资是毋庸置疑的事实。而且大家能保住节操到今天，还能确保文乃的安全，都是因为有了这个基地和设备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們收到大量的出資是毋庸置疑的事實。而且大家能保住節操到今天，還能確保文乃的安全，都是因為有了這個基地和設備。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00149",
		linknext = "0065_00151",
		line = 1927,
	},
	["0065_00151"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00110", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es la hija ilegítima del padre de la ley súperpervertida.",
					{"rt2"},
				},
			},
			cn = {
				{
					"变态条例的发起人，仁浦先生的私生女——",
					{"rt2"},
				},
			},
			tw = {
				{
					"變態條例的發起人，仁浦先生的私生女——",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00150",
		linknext = "0065_00152",
		line = 1938,
	},
	["0065_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si esa información se hiciera pública, podría socavar la confianza de la gente en el gobernador, lo que probablemente acabaría con la ley.",
					{"rt2"},
				},
			},
			cn = {
				{
					"由合适的人来操纵这个情报的话，的确可以让仁浦先生失去信用，摧毁条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"由合適的人來操縱這個情報的話，的確可以讓仁浦先生失去信用，摧毀條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00151",
		linknext = "0065_00153",
		line = 1948,
	},
	["0065_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero ¿qué le pasará a Fumino?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，到那时候，文乃会怎么样呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，到那時候，文乃會怎麼樣呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00152",
		linknext = "0065_00154",
		line = 1958,
	},
	["0065_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Qué va a hacer este viejo con ella?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个老人为了摧毁条例，将怎样对待文乃呢——",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個老人為了摧毀條例，將怎樣對待文乃呢——",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00153",
		linknext = "0065_00155",
		line = 1968,
	},
	["0065_00155"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0217", path=":vo/", ch="fumino"},
