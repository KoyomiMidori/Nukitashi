		},
		linkback = "0065_00309",
		linknext = "0065_00311",
		line = 3911,
	},
	["0065_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque siguiera en la SS, al menos tendría una manera de enfrentarme a la yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果，我现在也还在FS的话，就可以作为FS和黑社会厮杀了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果，我現在也還在FS的話，就可以作為FS和黑社會廝殺了——",
					{"rt2"},
				},
			},
