		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_032_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Finalmente, sacó su tarjeta de estudiante y logró convencer a Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之后，渡酱把学生证拿给文乃看，文乃才终于认同了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之後，渡醬把學生證拿給文乃看，文乃才終於認同了。",
					{"rt2"},
				},
