				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-30, time=400, ease="easeinout_sine", delay2=9300},
			},
			[11000] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=11000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1303", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mira, hay un montón de cosas en ese estante de ahí. Por mucho que lo intentes... ¡Nnngh! ¡Nnnnghh! No podrás alcanzarlas tú sola.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“然后啊……这里，在高处也有很多东西对吧？即使想拿也……嗯——嗯——！这样……够不着吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「然後啊……這裡，在高處也有很多東西對吧？即使想拿也……嗯——嗯——！這樣……搆不著吧？」",
					{"rt2"},
				},
			},
		},
