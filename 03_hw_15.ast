	["0065_00088"] = {
		{"bgm", file="bgm25", vol=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00116", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1314", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahh... Waaah... está bien, sé que soy una enana... y que pensaste que me refería al tercer año del nivel C... Te equivocaste en mi edad por nueve años... ¡¿Estos últimos nueve años de crecimiento fueron en vano?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔、呜呜……好啦，反正我是个矮子……被以为是C等部的3年级生……被认为小了9岁……这9年对于我来说什么嘛……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔、嗚嗚……好啦，反正我是個矮子……被以為是C等部的3年級生……被認為小了9歲……這9年對於我來說什麼嘛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00087",
		linknext = "0065_00089",
		line = 1202,
	},
	["0065_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como era de esperarse, se deprimió.",
					{"rt2"},
				},
			},
			cn = {
				{
					"照惯例，渡酱沮丧了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"照慣例，渡醬沮喪了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00088",
		linknext = "0065_00090",
		line = 1212,
	},
	["0065_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Afortunadamente, tengo una solución para este tipo de situaciones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种时候——果然还是只能靠平时的那个吧。",
