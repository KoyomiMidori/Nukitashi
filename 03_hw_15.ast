	["0065_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ha venido mucho a esta casa, y además se quedó a dormir una vez, así que tiene ropa para cambiarse aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"连续几天来我家，加上以前也住过一次，所以似乎把要换洗的衣服放在了我家。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連續幾天來我家，加上以前也住過一次，所以似乎把要換洗的衣服放在了我家。",
