					name = {"ヒナミ", "Hinami"},
					"“But I'm not Missh Sheenior!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不是哇叫酱学大人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不是哇叫醬學大人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00211",
		linknext = "0065_00213",
		line = 2671,
	},
	["0065_00213"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00118", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00118", path=":fg/misaki_01f/", id=30, ch="美岬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0422", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We're getting further and further away, now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你说错了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你說錯了……」",
					{"rt2"},
				},
