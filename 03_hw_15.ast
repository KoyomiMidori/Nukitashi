	["0065_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't bring myself to hurt someone again for my own selfish goals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了自己的目的而做出伤害他人的行为——我不想再做第二次了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了自己的目的而做出傷害他人的行為——我不想再做第二次了。",
