			en = {
				{
					"Se lo sugerí porque ella estaba desesperada por encontrar una forma de ayudar, y aunque solo fue un comentario sin importancia, lo hizo todos los días sin quejarse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"起先只是个随便的请求，渡酱明明没有这个义务——但她却没有露出任何不悦的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"起先只是個隨便的請求，渡醬明明沒有這個義務——但她卻沒有露出任何不悅的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00289",
		linknext = "0065_00291",
		line = 3670,
	},
	["0065_00291"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
