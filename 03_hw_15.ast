			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Okay...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……嗯……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……嗯……？」",
					{"rt2"},
				},
