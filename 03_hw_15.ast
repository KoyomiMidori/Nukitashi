	["0065_00345"] = {
		{"fg", file="hinami_01m_00003", file1="hinami_01m_00129", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1350", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sí, lo sé... Todo va a estar bien, Tachibana-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，我知道……没关系的，橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，我知道……沒關係的，橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00344",
		linknext = "0065_00346",
		line = 4357,
	},
	["0065_00346"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00129", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan está tranquila. Simplemente toma con delicadeza los puños temblorosos entre sus manos suaves y diminutas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使如此，渡酱也没有退缩，她用柔软的手轻轻握紧了颤抖的拳头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使如此，渡醬也沒有退縮，她用柔軟的手輕輕握緊了顫抖的拳頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00345",
		linknext = "0065_00347",
		line = 4370,
	},
	["0065_00347"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00129", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1351", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Incluso a estas horas, estás esforzándote y tratando de idear un plan... Gracias. Eso me alegra muchísimo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这么晚了，你为了我们努力考虑了这么多……谢谢，我很高兴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這麼晚了，你為了我們努力考慮了這麼多……謝謝，我很高興。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00346",
		linknext = "0065_00348",
		line = 4384,
	},
	["0065_00348"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00106", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是，我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是，我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00347",
		linknext = "0065_00349",
		line = 4396,
	},
	["0065_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Intento decir algo, pero no me salen las palabras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想说些什么——但是，却说不下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想說些什麼——但是，卻說不下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00348",
		linknext = "0065_00350",
		line = 4406,
	},
	["0065_00350"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00102", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1352", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Jeje... Lo entiendo. Has estado pensando tanto que estás cansadito... Cuando eso pasa, lo mejor es descansar. Vamos, puedes dormir a mi lado...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵……我明白。一直动脑子会很累吧……这种时候，就让它休息吧。好了，过来，我会陪着你睡觉的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呵呵……我明白。一直動腦子會很累吧……這種時候，就讓它休息吧。好了，過來，我會陪著你睡覺的……」",
