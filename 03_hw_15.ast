	["0065_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me recuerda a mi mamá. Solía hacerme esto cuando era un niño y no podía dormir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我记得还小的时候——每当我睡不着觉，妈妈就会这样安抚我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我記得還小的時候——每當我睡不著覺，媽媽就會這樣安撫我。",
