		},
		linkback = "0065_00271",
		linknext = "0065_00273",
		line = 3465,
	},
	["0065_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me quedaré despierto un rato más. Tengo que pensar en lo que haremos ahora. ¿Te molesta si dejo las luces encendidas un rato?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想再醒一会儿。因为还要考虑今后的事……灯开着没关系吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想再醒一下。因為還要考慮今後的事……燈開著沒關係嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00272",
		linknext = "0065_00274",
		line = 3476,
	},
	["0065_00274"] = {
