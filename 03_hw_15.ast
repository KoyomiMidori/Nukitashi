			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Estuvimos hablando con Fumino durante mucho tiempo, ¿no? El tiempo se nos pasó volando... wahhh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为和文乃酱聊天聊到了这么晚……比平时感觉时间过得更快啊……呼啊啊啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為和文乃醬聊天聊到了這麼晚……比平時感覺時間過得更快啊……呼啊啊啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00257",
		linknext = "0065_00259",
		line = 3258,
	},
	["0065_00259"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gracias. Aunque ya no tengo que ir al entrenamiento de la SS, sigues acompañando a Asa-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起……明明已经没有FS的训练了，还是让你为了麻沙酱过来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起……明明已經沒有FS的訓練了，還是讓你為了麻沙醬過來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00258",
		linknext = "0065_00260",
		line = 3270,
	},
	["0065_00260"] = {
