			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Vale... Tengo que esforzarme más como su senpai para que pueda tener una vida más tranquila y cómoda.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是吗……为了让文乃酱过得更自在，我要作为前辈加倍努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是嗎……為了讓文乃醬過得更自在，我要作為前輩加倍努力。」",
