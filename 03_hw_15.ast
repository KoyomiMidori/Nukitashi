				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Algo que ambos quisiéramos olvidar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"理由很明显。",
					{"rt2"},
