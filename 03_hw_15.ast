		linknext = "0065_00285",
		line = 3608,
	},
	["0065_00285"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The day we infiltrated the OSS headquarters to save Senator Hitoura, and I got shot in the head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了救仁浦先生潜入SHO的本部，被击中头部的那一天——",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了救仁浦先生潛入SHO的本部，被擊中頭部的那一天——",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00284",
		linknext = "0065_00286",
		line = 3618,
	},
	["0065_00286"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She watched over me all night long.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渡酱一直到早上都寸步不离地看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渡醬一直到早上都寸步不離地看著我。",
