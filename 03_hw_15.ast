	["0065_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hell, even if I were still part of the SS, it would at least give me a way to deal with the Yakuza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果，我现在也还在FS的话，就可以作为FS和黑社会厮杀了——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果，我現在也還在FS的話，就可以作為FS和黑社會廝殺了——",
