	},
	["0065_00342"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“L-Lo siento, Wata-chan... Estaba bromeando...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对、对不起，渡酱……这只是开玩笑的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對、對不起，渡醬……這只是開玩笑的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00341",
		linknext = "0065_00343",
		line = 4323,
	},
	["0065_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
