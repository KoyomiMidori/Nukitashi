	},
	["0065_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wata-chan tiene una expresión que puedo ver con facilidad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果渡酱的情感，我可以从她的表情读取。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果渡醬的情感，我可以從她的表情讀取。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00160",
		linknext = "0065_00162",
		line = 2046,
	},
	["0065_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sé muy bien que, a pesar de su apariencia e inclinaciones ingenuas, se le da muy bien captar los sentimientos de las personas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看似天真的她，其实意外地对情感的细微变动极其敏锐，这我知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看似天真的她，其實意外地對情感的細微變動極其敏銳，這我知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00161",
		linknext = "0065_00163",
		line = 2056,
	},
	["0065_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque no pueda entender los sentimientos de Fumino, quizá ella sí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算我办不到，但如果是渡酱的话，或许可以读懂文乃的内心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算我辦不到，但如果是渡醬的話，或許可以讀懂文乃的內心。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00162",
		linknext = "0065_00164",
		line = 2066,
	},
	["0065_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está mirando a Fumino con mucha preocupación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果这样的渡酱，对文乃投射出如此担心的视线——那么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果這樣的渡醬，對文乃投射出如此擔心的視線——那麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00163",
		linknext = "0065_00165",
		line = 2076,
	},
	["0065_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Probablemente no debería entregarla tan fácilmente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然，不应该简简单单地交出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然，不應該簡簡單單地交出去。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00164",
		linknext = "0065_00166",
		line = 2086,
	},
	["0065_00166"] = {
		{"cgact", file="cgact", act="汎用アクション", alpha=0, id=2, time=300, x=0, y=0, alphadel=1, style="reset", lv=5},
		{"fg", mode=-1, id=5, ch="ヒナミ", lv=5, time=300},
		{"ex", time=200, func="wait"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En cuanto a la entrega, hay algo que me gustaría confirmar, solo para estar seguro.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老爷爷——关于文乃的引渡，请一定要做好万全的准备。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「老爺爺——關於文乃的引渡，請一定要做好萬全的準備。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00165",
		linknext = "0065_00167",
		line = 2103,
	},
	["0065_00167"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0077", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“¿Qué cosa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00166",
		linknext = "0065_00168",
		line = 2116,
	},
	["0065_00168"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seguramente sabes que para entrar o salir de la isla hay que pasar por la entrada cerca al mar, la cual está vigilada de cerca por la OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你应该知道，岛的出入，必须通过SHO严格管理的海上大门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你應該知道，島的出入，必須通過SHO嚴格管理的海上大門。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00167",
		linknext = "0065_00169",
		line = 2128,
	},
	["0065_00169"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Como la SS sabe que tenemos a Fumino, sacarla clandestinamente de la isla será casi imposible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“光这样就已经很困难了——再加上，FS还知道文乃被夺走了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「光這樣就已經很困難了——再加上，FS還知道文乃被奪走了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00168",
		linknext = "0065_00170",
		line = 2140,
	},
	["0065_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es más, hasta la yakuza se ha establecido en la isla y la está buscando.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“连盘踞在岛上的黑社会也盯上了文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「連盤踞在島上的黑社會也盯上了文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00169",
		linknext = "0065_00171",
		line = 2151,
	},
	["0065_00171"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cualquier descuido al recogerla podría ser nuestro fin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果在引渡文乃的时候疏忽大意，可能会再次失去文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果在引渡文乃的時候疏忽大意，可能會再次失去文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00170",
		linknext = "0065_00172",
		line = 2163,
	},
	["0065_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Quiero tener la certeza absoluta de que está a salvo, y que nuestros esfuerzos no sean en vano.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了不让我们的辛苦化为泡影，请确实确保她的安全。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了不讓我們的辛苦化為泡影，請確實確保她的安全。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00171",
		linknext = "0065_00173",
		line = 2174,
	},
	["0065_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si no, me temo que no la entregaremos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——不这样的话，就不能把文乃交给你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——不這樣的話，就不能把文乃交給你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00172",
		linknext = "0065_00174",
		line = 2185,
	},
	["0065_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo digo todo para evitar cualquier objeción.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了不让他反驳，我一口气说出了所有的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了不讓他反駁，我一口氣說出了所有的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00173",
		linknext = "0065_00175",
		line = 2195,
	},
	["0065_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esto solo nos permitirá ganar tiempo, pero eso no importa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种讨价还价，就算顺利也只能拖延时间——但现在就算只有这样也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種討價還價，就算順利也只能拖延時間——但現在就算只有這樣也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00174",
		linknext = "0065_00176",
		line = 2205,
	},
	["0065_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al principio no responde, pero ni siquiera parece que esté pensando en su respuesta. Solo me mira fijamente en silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人没有开口，也看不出在思考的样子——只是，一直沉默着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人沒有開口，也看不出在思考的樣子——只是，一直沉默著。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00175",
		linknext = "0065_00177",
		line = 2215,
	},
	["0065_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi corazón late más rápido sin hacer ruido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心脏默默地高声鼓动着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心臟默默地高聲鼓動著。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00176",
		linknext = "0065_00178",
		line = 2225,
	},
	["0065_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No puedo aguantarlo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过——这种事没什么大不了的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過——這種事沒什麼大不了的。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00177",
		linknext = "0065_00179",
		line = 2235,
	},
	["0065_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Después de lidiar con esa instructora, que podría darme una paliza fácilmente, un viejo que solo puede gritarme desde una pantalla no es nada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只能隔着画面对话的老人什么的，跟真的会举起拳头挥过来的魔鬼教官相比，根本一点都不可怕。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只能隔著畫面對話的老人甚麼的，跟真的會舉起拳頭揮過來的魔鬼教官相比，根本一點都不可怕。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00178",
		linknext = "0065_00180",
		line = 2245,
	},
	["0065_00180"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0078", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Por supuesto. He esperado demasiado tiempo como para permitir que le pase algo durante el traslado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“——这是当然。这对我来说也是最大的夙愿。我一定会做好万全的准备去迎接她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「——這是當然。這對我來說也是最大的夙願。我一定會做好萬全的準備去迎接她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00179",
		linknext = "0065_00181",
		line = 2258,
	},
	["0065_00181"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0079", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Me pondré en contacto con ustedes cuando estén listos los preparativos para un traslado seguro. Hasta entonces, cuiden bien a Fumino. ¿Queda claro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“准备好了之后，我会立刻跟你们联络。在那之前，把文乃牢牢保护好——记住了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「準備好了之後，我會立刻跟你們聯絡。在那之前，把文乃牢牢保護好——記住了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00180",
		linknext = "0065_00182",
		line = 2271,
	},
	["0065_00182"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin esperar respuesta, corta la transmisión.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通讯被单方面地切断了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通訊被單方面切斷了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00181",
		linknext = "0065_00183",
		line = 2282,
	},
	["0065_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Poco a poco, la tensión en el ambiente se va disipando.",
					{"rt2"},
				},
			},
			cn = {
				{
					"紧张的空气逐渐变得松弛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"緊張的空氣逐漸變得鬆弛。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00182",
		linknext = "0065_00184",
		line = 2292,
	},
	["0065_00184"] = {
		{"bgm", file="bgm01", vol=100},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00106", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1888", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“A ver, Jun... ¿En serio vas a entregarla cuando te lo pida?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“喂淳，如果他真的做好了万全的准备……你真的打算把文乃交给他吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「喂淳，如果他真的做好了萬全的準備……你真的打算把文乃交給他嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00183",
		linknext = "0065_00185",
		line = 2306,
	},
	["0065_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase, una de las integrantes originales del NLNS, parece conocerme bien. Me lee como un libro abierto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到今天为止一直一起在寻找文乃的奈奈濑，似乎一眼就看穿了我的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到今天為止一直一起在尋找文乃的奈奈瀨，似乎一眼就看穿了我的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00184",
		linknext = "0065_00186",
		line = 2316,
	},
	["0065_00186"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ni hablar. Ya se me ocurrirá algo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不——在那之前，我打算想点别的办法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不——在那之前，我打算想點別的辦法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00185",
		linknext = "0065_00187",
		line = 2328,
	},
	["0065_00187"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00109", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0218", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Tachibana... ¿Por qué?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“橘大人……为什么……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「橘大人……為什麼……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00186",
		linknext = "0065_00188",
		line = 2341,
	},
	["0065_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Las pupilas de Fumino se dilatan por la sorpresa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃的瞳孔微微收缩着，似乎很惊讶的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃的瞳孔微微收縮著，似乎很驚訝的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00187",
		linknext = "0065_00189",
		line = 2351,
	},
	["0065_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que sentía algo en lo más profundo de su ser. Es la primera vez que muestra alguna emoción desde que la trajimos aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她内心深处果然还是有自己的想法吧——那是她第一次流露出情感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她內心深處果然還是有自己的想法吧——那是她第一次流露出情感。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00188",
		linknext = "0065_00190",
		line = 2361,
	},
	["0065_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que sí tiene más expresiones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她也有那种表情啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她也有那種表情啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00189",
		linknext = "0065_00191",
		line = 2371,
	},
	["0065_00191"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No es mi razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有为什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒有為什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00190",
		linknext = "0065_00192",
		line = 2383,
	},
	["0065_00192"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=300},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es solo... la mirada que tenía nuestra senpai en ese momento.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只因为我们的前辈……露出了那样的表情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只因為我們的前輩……露出了那樣的表情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00191",
		linknext = "0065_00193",
		line = 2398,
	},
	["0065_00193"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino se vuelve para mirarla y le devuelve la mirada con una gran sonrisa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在文乃的视线下——渡酱微笑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在文乃的視線下——渡醬微笑著。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00192",
		linknext = "0065_00194",
		line = 2410,
	},
	["0065_00194"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1318", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ejeje... ¿No te dije que todos eran muy amables? ¿No te parece genial, Fumino-chan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……不是说了大家都是好孩子吗？太好了呢，文乃酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……不是說了大家都是好孩子嗎？太好了呢，文乃醬！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00193",
		linknext = "0065_00195",
		line = 2422,
	},
	["0065_00195"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0219", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Sí... Gracias, Wata-chan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……谢谢您，渡酱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……謝謝您，渡醬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00194",
		linknext = "0065_00196",
		line = 2436,
	},
	["0065_00196"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[1200] = {
				{"fg", file="hinami_01m_00001", file3="hinami_01m_00301", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1200, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1319", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Tranquila, tranquila! Ah, pero, eh... ¿podrías tratarme más como tu senpai!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不用谢不用谢！啊，不过啊……如果可以的话，我有点希望你能加上前辈或者同学呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不用謝不用謝！啊，不過啊……如果可以的話，我有點希望你能加上前輩或者同學呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00195",
		linknext = "0065_00197",
		line = 2452,
	},
	["0065_00197"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0220", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“¿Wata-chan... san...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“渡酱、同学……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「渡醬、同學……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00196",
		linknext = "0065_00198",
		line = 2464,
	},
	["0065_00198"] = {
		{"fg", file="hinami_01m_00001", file3="hinami_01m_00303", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1320", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿Cómo?! Um, mira, Fumino-chan... Wata-chan es solo un apodo que me pusieron, es una abreviatura de mi apellido, Watarai...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“加在那里吗！？呃，我说文乃酱……所谓的渡酱本来就是外号，是渡会的渡加上酱而已……嗯……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「加在那裡嗎！？呃，我說文乃醬……所謂的渡醬本來就是外號，是渡會的渡加上醬而已……嗯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00197",
		linknext = "0065_00199",
		line = 2481,
	},
	["0065_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿No es un poco raro ponerle el honorífico a un apodo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有两个敬称不是很奇怪吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有兩個敬稱不是很奇怪嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00198",
		linknext = "0065_00200",
		line = 2493,
	},
	["0065_00200"] = {
