ast = {
	["0065_00001"] = {
		{"savetitle", text="褪せる思いは淡色に", ja="褪せる思いは淡色に", en="Desvaneciéndose en gris", cn="褪色思念化薄色", tw="褪色思念化薄色"},
		{"eval", exp="g.03_hw_15=1"},
		{"fg", mode=-1, id=30},
		{"cgdel", id=1, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=1000, rule="eff_033_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al día siguiente, después de clases.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第二天放学后。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第二天放學後。",
					{"rt2"},
				},
			},
		},
		linknext = "0065_00002",
		line = 19,
	},
	["0065_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los cinco sospechosos habituales están reunidos en la base, pero ahora hay alguien más.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的基地里，除了往常的5个人之外——又多了一个少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的基地裡，除了往常的5個人之外——又多了一個少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00001",
		linknext = "0065_00003",
		line = 29,
	},
	["0065_00003"] = {
		{"bgm", file="bgm10", vol=100},
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="fumino_02m_00002", file1="fumino_02m_00104", file4="fumino_02m_00401", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0200", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Me gustaría agradecerles por rescatar a alguien tan insignificante como yo. Nunca podré retribuirles por completo su amabilidad.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那么再一次……大家，这次为了在下尽心尽力，真是非常感谢。感激之情无以言表……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那麼再一次……大家，這次為了在下盡心盡力，真是非常感謝。感激之情無以言表……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00002",
		linknext = "0065_00004",
		line = 44,
	},
	["0065_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La chica de cabello blanco, Fumino, nos hace una reverencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"淡色头发的少女——文乃深深地低下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"淡色頭髮的少女——文乃深深地低下了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00003",
		linknext = "0065_00005",
		line = 54,
	},
	["0065_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por lo visto, se estaba vistiendo como un chico para no llamar la atención.",
					{"rt2"},
				},
			},
			cn = {
				{
					"依她的说法，她似乎都是这样女扮男装避开视线的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"依她的說法，她似乎都是這樣女扮男裝避開視線的。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00004",
		linknext = "0065_00006",
		line = 64,
	},
	["0065_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya te lo dijimos, ¿no? Aquí todos somos tus compañeros. No tienes que ser tan formal con nosotros.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我说过了吧？这里的人都是你的同伴。不必这么毕恭毕敬。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我說過了吧？這裡的人都是你的同伴。不必這麼畢恭畢敬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00005",
		linknext = "0065_00007",
		line = 76,
	},
	["0065_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, su expresión no cambia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这么说了——但文乃的表情依然很僵硬。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這麼說了——但文乃的表情依然很僵硬。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00006",
		linknext = "0065_00008",
		line = 86,
	},
	["0065_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No es tan sorprendente, teniendo en cuenta que la llevaron a escondidas a una extraña base secreta debajo de la escuela y que está rodeada de personas mayores que ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然被带到这种地方，被5名年长的人包围，她会这样也是可以理解的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然被帶到這種地方，被5名年長的人包圍，她會這樣也是可以理解的。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00007",
		linknext = "0065_00009",
		line = 96,
	},
	["0065_00009"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1297", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Ah, ya me acordé! ¿Nos vimos una vez en la playa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……我想起来了！文乃酱，以前我们在海边见过面吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……我想起來了！文乃醬，以前我們在海邊見過面吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00008",
		linknext = "0065_00010",
		line = 109,
	},
	["0065_00010"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", delay2=1000},
			},
		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino mira a Wata-chan con sus grandes ojos y asiente con la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃用大大的眼睛看着渡酱——微微点了点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃用大大的眼睛看著渡醬——微微點了點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00009",
		linknext = "0065_00011",
		line = 122,
	},
	["0065_00011"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1298", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡Sabía que te había visto antes! ¡Ejeje, gracias!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“果然！诶嘿嘿，那时谢谢你了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「果然！欸嘿嘿，那時謝謝你了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00010",
		linknext = "0065_00012",
		line = 136,
	},
	["0065_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun cuando le mostramos agradecimiento genuino e inocente, Fumino se mantiene quieta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"面对天真无邪的感谢之词，文乃的表情依旧不变。",
					{"rt2"},
				},
			},
			tw = {
				{
					"面對天真無邪的感謝之詞，文乃的表情依舊不變。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00011",
		linknext = "0065_00013",
		line = 146,
	},
	["0065_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Va a ser difícil convencerla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来她很难对付。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來她很難對付。",
					{"rt2"},
				},
