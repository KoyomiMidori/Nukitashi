		linkback = "0065_00285",
		linknext = "0065_00287",
		line = 3628,
	},
	["0065_00287"] = {
		{"fg", file="jun_01f_00002", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So she normally goes to sleep this early...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明明平时，睡得这么早……”",
