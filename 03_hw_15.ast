		linknext = "0065_00015",
		line = 169,
	},
	["0065_00015"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00110", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0201", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes. I falsified my name as well. If I inadvertently caused you to waste your precious time, I would like to express my sincerest regret. Please forgive me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……因为名字也是假的……浪费了大家宝贵的时间，请恕我再次请求各位的饶恕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……因為名字也是假的……浪費了大家寶貴的時間，請恕我再次請求各位的饒恕……」",
					{"rt2"},
				},
			},
		},
