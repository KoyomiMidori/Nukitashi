					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know what happened immediately after we rescued Fumino is weighing heavily on both our minds.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从昨天帮助文乃的那一刻起，我们应该一直都在心中有所牵挂。",
					{"rt2"},
				},
			},
			tw = {
				{
