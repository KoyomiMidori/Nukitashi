		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sight of her gentle smile makes me start to tear up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我直直地看着那温和的微笑，眼眶不由自主地红了起来。",
					{"rt2"},
				},
			},
