			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That's fine... You're working so hard, aren't you... There, there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，没事……橘君真了不起，是个很努力的人呢……好乖好乖……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯，沒事……橘君真了不起，是個很努力的人呢……好乖好乖……」",
					{"rt2"},
				},
