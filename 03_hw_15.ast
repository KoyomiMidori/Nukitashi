		{"fg", file="hinami_01m_00001", file1="hinami_01m_00110", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, mode=3, x=0, y=0},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm04", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1328", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I wonder what Fumino's up to right now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“文乃酱现在在干什么呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「文乃醬現在在幹什麼呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00235",
		linknext = "0065_00237",
		line = 2997,
	},
	["0065_00237"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wonder... I hope she's enjoying a good rest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在干什么呢……要是她能好好休息就好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在幹什麼呢……要是她能好好休息就好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00236",
		linknext = "0065_00238",
		line = 3009,
	},
	["0065_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When we split up to go home, we decided it would be best for Fumino to stay in the base.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之后经过一番交谈后，决定让文乃暂时住在基地里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之後經過一番交談後，決定讓文乃暫時住在基地裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00237",
		linknext = "0065_00239",
		line = 3019,
	},
	["0065_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's got everything someone would need, and even though they're just temporary provisions, there's even food. She'll be able to sleep and eat, at least.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基地里一应俱全，也有吃的。不缺食宿。",
					{"rt2"},
				},
			},
			tw = {
				{
					"基地裡一應俱全，也有吃的。不缺食宿。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00238",
		linknext = "0065_00240",
		line = 3029,
	},
	["0065_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"More importantly, though, she'll be safe there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最重要的是安全。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最重要的是安全。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00239",
		linknext = "0065_00241",
		line = 3039,
	},
	["0065_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm sure the SS and the Yakuza are still hunting for her, but they'll never find her at the base.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS和黑社会们或许还在寻找文乃，但那里的话就不用担心了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS和黑社會們或許還在尋找文乃，但那裡的話就不用擔心了。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00240",
		linknext = "0065_00242",
		line = 3049,
	},
	["0065_00242"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, it's a hell of a lot better than where she was before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，比她以前住的地方要好多了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，比她以前住的地方要好多了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00241",
		linknext = "0065_00243",
		line = 3061,
	},
	["0065_00243"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When we asked, Fumino told us that she'd been hiding in a deserted shrine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一问之下才知道，文乃好像一直躲在无人的神社里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一問之下才知道，文乃好像一直躲在無人的神社裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00242",
		linknext = "0065_00244",
		line = 3071,
	},
	["0065_00244"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wonder how she stayed safe in a place like that, but it's probably the last place anyone would look for someone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我感叹在那种地方居然还能平安无事——但从某种意义上讲，也许正是因为在那种地方，所以才平安无事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我感嘆在那種地方居然還能平安無事——但從某種意義上講，也許正是因為在那種地方，所以才平安無事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00243",
		linknext = "0065_00245",
		line = 3081,
	},
	["0065_00245"] = {
		{"bg", id=1, file="bg19_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, lv=5, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00110", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1329", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I wonder if she's using my favorite cushion like I told her? I wish she'd rely on me a bit more, but she's so restrained...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“她会用我喜欢的靠垫吗？文乃酱好像很客气，希望她能多依赖前辈啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「她會用我喜歡的靠墊嗎？文乃醬好像很客氣，希望她能多依賴前輩啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00244",
		linknext = "0065_00246",
		line = 3096,
	},
	["0065_00246"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Maybe she's way more animated when there's no one looking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一个人的时候可能意外地情绪高涨哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一個人的時候可能意外地情緒高漲哦。」",
