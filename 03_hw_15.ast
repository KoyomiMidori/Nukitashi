					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Okay... I need to work harder as her senior for her to be able to live a more relaxed and comfortable life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是吗……为了让文乃酱过得更自在，我要作为前辈加倍努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是嗎……為了讓文乃醬過得更自在，我要作為前輩加倍努力。」",
					{"rt2"},
