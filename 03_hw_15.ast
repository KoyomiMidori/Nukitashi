	["0065_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No importa qué planes tontos se me ocurran, no importa a qué conclusiones idiotas llegue, ella está ahí para apoyarme. Se preocupa por mí, me cuida y me acepta tal y como soy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论我做了多少任性的事，说了多少不中听的话，都不会退缩也不会责备我——她担心我，关心我，温柔地接受我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論我做了多少任性的事，說了多少不中聽的話，都不會退縮也不會責備我——她擔心我，關心我，溫柔地接受我。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00352",
		linknext = "0065_00354",
		line = 4451,
	},
	["0065_00354"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Qué tan grande es su corazón?",
