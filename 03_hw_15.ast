					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿En serio?! ¡Si Wata-chan solo parece nueve años más joven, eso significa que parece más madura para su edad que la mayoría de las personas!”",
					{"rt2"},
