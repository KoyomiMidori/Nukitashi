		linkback = "0065_00191",
		linknext = "0065_00193",
		line = 2398,
	},
	["0065_00193"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino turns to look at her, and she returns the gaze with a broad grin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在文乃的视线下——渡酱微笑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在文乃的視線下——渡醬微笑著。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00192",
		linknext = "0065_00194",
		line = 2410,
	},
	["0065_00194"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1318", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ehehe... Didn't I tell you they're all nice? Isn't that great, Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶嘿嘿……不是说了大家都是好孩子吗？太好了呢，文乃酱！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿……不是說了大家都是好孩子嗎？太好了呢，文乃醬！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00193",
		linknext = "0065_00195",
		line = 2422,
	},
	["0065_00195"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0219", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes... Thank you, Wata.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是的……谢谢您，渡酱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是的……謝謝您，渡醬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00194",
		linknext = "0065_00196",
		line = 2436,
	},
	["0065_00196"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00102", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[1200] = {
				{"fg", file="hinami_01m_00001", file3="hinami_01m_00301", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, delay2=1200, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1319", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“No worries, no worries! Ah, but, uh... could you maybe address me more like your senior?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不用谢不用谢！啊，不过啊……如果可以的话，我有点希望你能加上前辈或者同学呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不用謝不用謝！啊，不過啊……如果可以的話，我有點希望你能加上前輩或者同學呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00195",
		linknext = "0065_00197",
		line = 2452,
	},
	["0065_00197"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0220", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Miss Wata...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“渡酱、同学……？”",
					{"rt2"},
