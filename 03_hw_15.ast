		{"fg", file="hinami_02m_00001", file1="hinami_02m_00116", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1314", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Sob... Waaah... it's okay, I know I'm such a shrimp... that you thought I meant third year in C-level... You got my age wrong by nine years... Have these last nine years of growing been worthless!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔、呜呜……好啦，反正我是个矮子……被以为是C等部的3年级生……被认为小了9岁……这9年对于我来说什么嘛……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔、嗚嗚……好啦，反正我是個矮子……被以為是C等部的3年級生……被認為小了9歲……這9年對於我來說什麼嘛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00087",
		linknext = "0065_00089",
		line = 1202,
	},
	["0065_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unsurprisingly, she's depressed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"照惯例，渡酱沮丧了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"照慣例，渡醬沮喪了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00088",
		linknext = "0065_00090",
		line = 1212,
	},
	["0065_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fortunately, I've got an ace up my sleeve for just this kind of situation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种时候——果然还是只能靠平时的那个吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種時候——果然還是只能靠平時的那個吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00089",
		linknext = "0065_00091",
		line = 1222,
	},
	["0065_00091"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come to think of it, not that long ago I looked about 12 years younger than my real age!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，我之前还被别人以为比实际年龄小了12岁呢～……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，我之前還被別人以為比實際年齡小了12歲呢～……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00090",
		linknext = "0065_00092",
		line = 1234,
	},
	["0065_00092"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00105", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
