	["0065_00316"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sorry. Did I wake you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊，对不起。把你吵醒了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊，對不起。把你吵醒了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00315",
		linknext = "0065_00317",
		line = 3984,
	},
	["0065_00317"] = {
		{"fg", file="hinami_02m_00003", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1343", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah... nah, it's fine... What's up? You look... kinda happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……不，没事……怎么了？总觉得……一副很高兴的样子呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……不，沒事……怎麼了？總覺得……一副很高興的樣子呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00316",
		linknext = "0065_00318",
		line = 3998,
	},
	["0065_00318"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yep. I just came up with a new strategy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。我刚刚想到新的作战方案。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。我剛剛想到新的作戰方案。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00317",
		linknext = "0065_00319",
		line = 4010,
	},
	["0065_00319"] = {
		{"fg", file="hinami_02m_00003", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[4800] = {
				{"fg", file="hinami_02m_00003", file1="hinami_02m_00127", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=4800, time=300, mode=3, x=0, y=0},
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=-12.5, time=500, ease="easeinout_sine", delay2=4800},
			},
			[6500] = {
				{"fg", file="hinami_02m_00003", file1="hinami_02m_00119", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=6500, time=300, mode=3, x=0, y=0},
			},
			[8000] = {
				{"fg", file="hinami_02m_00003", file1="hinami_02m_00107", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1344", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Really? Amazing! Great work... nngh! Phew... So, what is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的……？橘，果然好厉害啊……嗯——！呼……什么作战啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的……？橘，果然好厲害啊……嗯——！呼……什麼作戰啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00318",
		linknext = "0065_00320",
		line = 4031,
	},
	["0065_00320"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The first step is me rejoining the SS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的——首先，我要回到FS。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的——首先，我要回到FS。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00319",
		linknext = "0065_00321",
		line = 4043,
	},
	["0065_00321"] = {
		{"fg", file="hinami_01m_00003", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1345", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? Can you do that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……？那种事能做到吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……？那種事能做到嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00320",
		linknext = "0065_00322",
		line = 4057,
	},
	["0065_00322"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. I think I contributed a lot to the SS when I was a cadet, if I do say so myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。自己讲虽然有点奇怪……但我作为一个训练生，对FS做出了很大贡献。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。自己講雖然有點奇怪……但我作為一個訓練生，對FS做出了很大貢獻。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00321",
		linknext = "0065_00323",
		line = 4069,
	},
	["0065_00323"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I captured the woman trying to bring her illness into the island, and I extricated the prefectural governor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“抓住了打算把疾病带入岛屿的女人，还把那个仁浦県知事救了出来——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「抓住了打算把疾病帶入島嶼的女人，還把那個仁浦県知事救了出來——」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00322",
		linknext = "0065_00324",
		line = 4080,
	},
	["0065_00324"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hell, I think I was more decorated as a cadet than most of the official members.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不认为这样就已经是正式成员以上的成果了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你不認為這樣就已經是正式成員以上的成果了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00323",
		linknext = "0065_00325",
		line = 4092,
	},
	["0065_00325"] = {
		{"fg", file="hinami_02m_00003", file1="hinami_02m_00117", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1346", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Y-Yeah... I guess?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯、嗯……是啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯、嗯……是啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00324",
		linknext = "0065_00326",
		line = 4106,
	},
	["0065_00326"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Above all that, though, I was the one who finally secured Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不仅如此，我还找到了FS一直寻找的文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不僅如此，我還找到了FS一直尋找的文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00325",
		linknext = "0065_00327",
		line = 4118,
	},
	["0065_00327"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'd say that makes me officer standard, wouldn't you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这么说来，说是队长级别的活跃也不为过吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這麼說來，說是隊長級別的活躍也不為過吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00326",
		linknext = "0065_00328",
		line = 4130,
	},
	["0065_00328"] = {
		{"fg", file="hinami_01m_00003", file1="hinami_01m_00117", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1347", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? T-Tachibana...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“诶……橘、橘君……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸……橘、橘君……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00327",
		linknext = "0065_00329",
		line = 4144,
	},
	["0065_00329"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Considering all I've done, I think I'd be able to have a real say in the SS if I rejoined.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个成果的话，如果回到FS也能拥有自己的发言权吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個成果的話，如果回到FS也能擁有自己的發言權吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00328",
		linknext = "0065_00330",
		line = 4156,
	},
	["0065_00330"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hell, I don't think they can afford to turn me down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对于FS来说，应该舍不得放下取得这么多成就的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對於FS來說，應該捨不得放下取得這麼多成就的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00329",
		linknext = "0065_00331",
		line = 4168,
	},
	["0065_00331"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then I could get them to make dealing with the illegal sex trade their top priority. That would let us solve the public order problem and deal with the Yakuza in one fell swoop.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以，首先要做的就是破坏地下风俗……这样一来，我们既能解决治安问题，又能打垮我们的死对头——黑社会。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以，首先要做的就是破壞地下風俗……這樣一來，我們既能解決治安問題，又能打垮我們的死對頭——黑社會。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00330",
		linknext = "0065_00332",
		line = 4180,
	},
	["0065_00332"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pretty good, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么样，这个作战？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼樣，這個作戰？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00331",
		linknext = "0065_00333",
		line = 4192,
	},
	["0065_00333"] = {
		{"bgm", stop=1},
		{"fg", file="hinami_02m_00003", file1="hinami_02m_00122", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1348", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, uh... yeah... it's great. If it works, then we'd be able to protect all those little kids... which would be great... But, uh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊……嗯……那个……我觉得很厉害哦？如果一切顺利的话，小孩们的受害人数也会减少……我觉得很厉害……但是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊……嗯……那個……我覺得很厲害哦？如果一切順利的話，小孩們的受害人數也會減少……我覺得很厲害……但是……」",
					{"rt2"},
