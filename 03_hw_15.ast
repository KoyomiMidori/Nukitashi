	["0065_00022"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00118", path=":fg/misaki_01m/", id=3, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y... Hotori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有……畔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有……畔。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00021",
		linknext = "0065_00023",
		line = 267,
	},
	["0065_00023"] = {
		{"fg", mode=-1, id=3, ch="美岬", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin querer, formamos un grupo de inadaptados y marginados.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不是刻意的，但整体上是支充满谜团的队伍。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不是刻意的，但整體上是支充滿謎團的隊伍。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00022",
		linknext = "0065_00024",
		line = 279,
	},
	["0065_00024"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00110", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Quiero que Fumino se sienta cómoda, pero la realidad es que la trajimos a la fuerza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但既然硬是把文乃带过来了，还是希望她能放松紧张感——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但既然硬是把文乃帶過來了，還是希望她能放鬆緊張感——",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00023",
		linknext = "0065_00025",
		line = 290,
	},
	["0065_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sabiendo todo eso, ¿puedo esperar que alguna vez se sienta cómoda con nosotros?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她真的会向我们敞开心扉吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她真的會向我們敞開心扉嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00024",
		linknext = "0065_00026",
		line = 300,
	},
	["0065_00026"] = {
		{"bgm", file="bgm24", vol=100},
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00110", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00117", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0413", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Wawawa, ¿q-qué hacemos, Tachibana-san...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哈哇哇……怎、怎么办呢，橘同学……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哈哇哇……怎、怎麼辦呢，橘同學……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00025",
		linknext = "0065_00027",
		line = 316,
	},
	["0065_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Podrías calmarte un poco.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算你问我……不用那么露骨地着急吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算你問我……不用那麼露骨地著急吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00026",
		linknext = "0065_00028",
		line = 328,
	},
	["0065_00028"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00115", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00125", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=7000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0414", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡Pero es que mírala! Es joven, muy linda, muy educada... ¡¡¡Y se ha estado haciendo pasar por un chico!!! ¡¿Cómo voy a competir con alguien así?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“因为！她年纪小、明显很可爱、超级拘谨……而且还女扮男装！？特色太显眼了吧！我明明一点都还没变得显眼！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「因為！她年紀小、明顯很可愛、超級拘謹……而且還女扮男裝！？特色太顯眼了吧！我明明一點都還沒變得顯眼！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00027",
		linknext = "0065_00029",
		line = 344,
	},
	["0065_00029"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nadie dijo eso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你还在说这事啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你還在說這事啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00028",
		linknext = "0065_00030",
		line = 356,
	},
	["0065_00030"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00110", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=0, y=200},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-200, time=700},
		{"fgact", ch="美岬", id=6, act="移動", x=200, y=0, time=500},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1118", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ay, manito. Como somos más personas, tendremos que despedir a alguien o construir soportes adicionales.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊——对了哥哥，既然队友多了一名，那就必须剔除一名才行……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊——對了哥哥，既然隊友多了一名，那就必須剔除一名才行……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00029",
		linknext = "0065_00031",
		line = 372,
	},
	["0065_00031"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00111", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"fgact", ch="美岬", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1800] = {
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00124", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=1800, time=300, mode=3, x=600, y=0},
			},
			[8000] = {
				{"fg", file="misaki_02m_00001", file1="misaki_02m_00125", file2="misaki_02m_00202", path=":fg/misaki_02m/", id=6, lv=5, head="misaki_02m", ch="美岬", mw="mw", sync=0, delay2=8000, time=300, mode=3, x=600, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0415", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡¿De eso se trata! ¡Por favor, no me saquen de aquí! ¡No dejen que Fumino-chan me consuma! ¡Se supone que yo soy la gordita!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“有那样的系统！？请不要扔掉我！我会被吃掉的……会被文乃酱吃掉！明明是个贪吃的角色！却被吃掉了——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「有那樣的系統！？請不要扔掉我！我會被吃掉的……會被文乃醬吃掉！明明是個貪吃的角色！卻被吃掉了——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00030",
		linknext = "0065_00032",
		line = 391,
	},
	["0065_00032"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00120", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1119", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No nos conocemos desde hace mucho tiempo, pero sé que ha sido como una eternidad. Eres el eslabón más débil, señorita gordita... Adiós...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然相处时间很短但也不怎么开心哦……拜拜，超级肥猪……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然相處時間很短但也不怎麼開心哦……拜拜，超級肥豬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00031",
		linknext = "0065_00033",
		line = 405,
	},
	["0065_00033"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00125", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0416", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“¡No me saquen de la islaaaa...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不要把我出货啊啊啊啊——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不要把我出貨啊啊啊啊——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00032",
		linknext = "0065_00034",
		line = 419,
	},
	["0065_00034"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0202", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Si mi presencia le resulta tan molesta... Lo siento mucho, señorita gordita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“都怪我给您添了很大的麻烦……非常抱歉，超级肥猪大人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「都怪我給您添了很大的麻煩……非常抱歉，超級肥豬大人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00033",
		linknext = "0065_00035",
		line = 433,
	},
	["0065_00035"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00121", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=5, head="misaki_01m", ch="美岬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0417", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Puedes decir cosas ofensivas con tanta pulcritud...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“虽然用词很敬畏，但说的话超级失礼诶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「雖然用詞很敬畏，但說的話超級失禮欸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00034",
		linknext = "0065_00036",
		line = 447,
	},
	["0065_00036"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00111", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0203", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“¿Cometí algún error por descuido?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我说错了什么吗……？”",
					{"rt2"},
