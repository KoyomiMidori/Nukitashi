	["0065_00349"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I try to say something, but the words get caught in my throat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想说些什么——但是，却说不下去。",
