		linkback = "0065_00078",
		linknext = "0065_00080",
		line = 1051,
	},
	["0065_00080"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00123", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1311", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Asane is a first year, and the others are all second years! I'm everybody's senior here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君们是2年级生，麻沙音酱是1年级生，所以我最大！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君們是2年級生，麻沙音醬是1年級生，所以我最大！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00079",
		linknext = "0065_00081",
		line = 1065,
	},
	["0065_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino doesn't change her expression, but she starts blinking rapidly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃——没有改变表情，只是眨着眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃——沒有改變表情，只是眨著眼睛。",
