		linknext = "0065_00272",
		line = 3452,
	},
	["0065_00272"] = {
		{"fg", file="hinami_01m_00003", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1338", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tachibana...? You can't sleep?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“橘君……？橘君，你不睡觉吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「橘君……？橘君，你不睡覺嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00271",
		linknext = "0065_00273",
		line = 3465,
	},
	["0065_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'll stay up a bit longer. I need to figure out where we go from here. Is it okay if I leave the lights on for a bit?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想再醒一会儿。因为还要考虑今后的事……灯开着没关系吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想再醒一下。因為還要考慮今後的事……燈開著沒關係嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00272",
		linknext = "0065_00274",
		line = 3476,
	},
	["0065_00274"] = {
		{"fg", file="hinami_01m_00003", file1="hinami_01m_00107", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=1, mode=3, x=0, y=0},
		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
