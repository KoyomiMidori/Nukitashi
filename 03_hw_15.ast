				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Tranquilo... Estás esforzándote mucho, ¿verdad? Todo va a estar bien...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯，没事……橘君真了不起，是个很努力的人呢……好乖好乖……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
