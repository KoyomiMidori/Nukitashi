		line = 1474,
	},
	["0065_00112"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, empezaré por lo importante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，我就开门见山地问了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，我就開門見山地問了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00111",
		linknext = "0065_00113",
		line = 1486,
	},
	["0065_00113"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿El gobernador Hitoura Toshiaki es tu padre?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“县知事——仁浦俊明，是你的父亲吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「縣知事——仁浦俊明，是你的父親嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00112",
		linknext = "0065_00114",
		line = 1498,
	},
	["0065_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"De repente, el ambiente en la base se vuelve tenso.",
