		linkback = "0065_00154",
		linknext = "0065_00156",
		line = 1980,
	},
	["0065_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino sigue sin mostrar emoción alguna.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃还是没有改变表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃還是沒有改變表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00155",
		linknext = "0065_00157",
		line = 1990,
	},
	["0065_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque se trata de su destino, ella escucha en silencio. Es como si simplemente aceptara lo que le suceda.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是当事人，但却仿佛认定了那是自己的命运一样默默地听着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是當事人，但卻彷彿認定了那是自己的命運一樣默默地聽著。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00156",
		linknext = "0065_00158",
		line = 2000,
	},
	["0065_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No puedo entenderla ni a ella ni al anciano. No tengo idea de cómo se sienten en el fondo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人和文乃——两人心里到底在想什么，我不知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人和文乃——兩人心裡到底在想什麼，我不知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00157",
		linknext = "0065_00159",
		line = 2010,
	},
	["0065_00159"] = {
		{"text"},
		text = {
