				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estamos en desventaja.",
					{"rt2"},
				},
			},
			cn = {
				{
					"战斗力非常不足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"戰鬥力非常不足。",
					{"rt2"},
				},
