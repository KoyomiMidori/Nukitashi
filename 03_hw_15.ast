			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“¿Disculpa...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯……？”",
					{"rt2"},
