		linkback = "0065_00287",
		linknext = "0065_00289",
		line = 3650,
	},
	["0065_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Plus, the whole time I was in the SS, she was coming here to take care of Asa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且我在FS的时候，渡酱一直都在照顾麻沙酱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且我在FS的時候，渡醬一直都在照顧麻沙醬。",
