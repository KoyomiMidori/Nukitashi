	},
	["0065_00073"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0210", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“¿En serio? Eres bastante grande para estar en tercer año...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“是吗……以3年级生来看，应该算是比较高大的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「是嗎……以3年級生來看，應該算是比較高大的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00072",
		linknext = "0065_00074",
		line = 971,
	},
	["0065_00074"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00109", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=0, y=0},
			},
			[6000] = {
				{"fgact", ch="ヒナミ", id=5, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine", delay2=6000},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami1310", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“¡¿En serio?! Nadie me había dicho eso antes... Eres una chica muy simpática, ¿verdad? Tranquila, tranquila... Jejeje, ni siquiera hace falta que te agaches para que te acaricie la cabeza ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“真的！？第一次被这么说呢……文乃酱真是个好孩子啊……好乖好乖……诶嘿嘿，不用让她蹲下也能摸到♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「真的！？第一次被這麼說呢……文乃醬真是個好孩子啊……好乖好乖……欸嘿嘿，不用讓她蹲下也能摸到♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00073",
		linknext = "0065_00075",
		line = 988,
	},
	["0065_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está tan feliz que no me atrevo a decirle que ha cometido un error fatal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然渡酱心情很好，但是——我感觉到了致命性的误解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然渡醬心情很好，但是——我感覺到了致命性的誤解。",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00074",
		linknext = "0065_00076",
		line = 998,
	},
	["0065_00076"] = {
		{"fg", mode=-1, id=6, ch="美岬", lv=5, time=300},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1886", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jaa... La reacción de Wata-chan ante un simple malentendido es tan linda...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哈……没有意识到误解还那么开心的渡酱好可爱啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哈……沒有意識到誤解還那麼開心的渡醬好可愛啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00075",
		linknext = "0065_00077",
		line = 1013,
	},
	["0065_00077"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Si hubieras mantenido la boca cerrada, esto no habría pasado...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果你放弃吐槽的话，会一发不可收拾吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果你放棄吐槽的話，會一發不可收拾吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00076",
		linknext = "0065_00078",
		line = 1025,
	},
	["0065_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, Fumino... Sé que no lo especificó, pero Wata-chan es una estudiante de nivel A, como nosotros. Cuando dice tercer año, se refiere al tercer año del nivel A.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个，文乃——我跟你说，渡酱和我们一样是A等部。她是A等部的3年级生哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個，文乃——我跟你說，渡醬和我們一樣是A等部。她是A等部的3年級生哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00077",
		linknext = "0065_00079",
		line = 1037,
	},
	["0065_00079"] = {
		{"fg", file="fumino_01m_00002", file1="fumino_01m_00114", file4="fumino_01m_00401", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-600, y=0},
		{"text"},
