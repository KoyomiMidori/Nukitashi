					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I also need raw materials if I'm going to develop new ones.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
