	["0114_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She shows no hint of displeasure, looking in fact somewhat pleased as she whisks off to the kitchen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃并没有露出厌恶的表情，反而有些开心地跑向厨房。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃並沒有露出厭惡的表情，反而有些開心地跑向廚房。",
