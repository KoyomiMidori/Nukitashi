		linkback = "0114_00360",
		linknext = "0114_00362",
		line = 5176,
	},
	["0114_00362"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're fucking insane!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我有什么好……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我有什麼好……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00361",
		linknext = "0114_00363",
		line = 5188,
	},
	["0114_00363"] = {
		{"fg", file="touka_01l_00002", file1="touka_01l_00102", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0759", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“To take such an interest in anything, to have a person captivate me so... This has never happened to me before. I'm sure I'll enjoy myself while it lasts... Teehee.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“让我这么感兴趣——对其他人这么在意，应该是有生以来第一次……所以，一定会很开心吧……哧哧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「讓我這麼感興趣——對其他人這麼在意，應該是有生以來第一次……所以，一定會很開心吧……哧哧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00362",
		linknext = "0114_00364",
		line = 5202,
	},
	["0114_00364"] = {
		{"fgact", ch="桐香", id=8, act="振動下", loop=2, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She laughs in my face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她在我面前窃笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她在我面前竊笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00363",
		linknext = "0114_00365",
		line = 5213,
	},
	["0114_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Like an innocent maiden.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像一个不知道险恶的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像一個不知道險惡的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00364",
		linknext = "0114_00366",
		line = 5223,
	},
	["0114_00366"] = {
		{"bg", id=1, file="bg09_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="touka_01m_00002", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Almost with pity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且——还很同情地看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且——還很同情地看著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00365",
		linknext = "0114_00367",
		line = 5238,
	},
	["0114_00367"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0760", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It truly does pain me so, how everyone misunderstands precisely why I am so interested in you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——我如此在意的你，被大家误会，这让我非常痛苦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——我如此在意的你，被大家誤會，這讓我非常痛苦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00366",
		linknext = "0114_00368",
		line = 5250,
	},
	["0114_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her frown can't help but make me feel sympathy for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她皱起眉头，似乎打从心底觉得我很可怜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她皺起眉頭，似乎打從心底覺得我很可憐。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00367",
		linknext = "0114_00369",
		line = 5260,
	},
	["0114_00369"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00121", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misunderstand?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说误会——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說誤會——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00368",
		linknext = "0114_00370",
		line = 5272,
	},
	["0114_00370"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0761", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You have far greater value than anyone realizes. You are someone those around you should be acknowledging, nay, revering.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你本来是可以得到更多评价的人。你是应该得到周围人认可和称赞的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你本來是可以得到更多評價的人。你是應該得到周圍人認可和稱讚的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00369",
		linknext = "0114_00371",
		line = 5284,
	},
	["0114_00371"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0762", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But no one is aware of that just yet. Why? Because there has never been an opportunity for them to understand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是，周围的人还没有理解这一点——因为他们没有得到机会。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是，周圍的人還沒有理解這一點——因為他們沒有得到機會。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00370",
		linknext = "0114_00372",
		line = 5296,
	},
	["0114_00372"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She continues her explanation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她继续说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她繼續說。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00371",
		linknext = "0114_00373",
		line = 5306,
	},
	["0114_00373"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0763", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Why not make the islanders understand you? Your power, your greatness, the true you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“让岛上的人们了解你吧？你的力量，你的伟大，真实的你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「讓島上的人們了解你吧？你的力量，你的偉大，真實的你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00372",
		linknext = "0114_00374",
		line = 5320,
	},
	["0114_00374"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you talking about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在说什——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你在說什——」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00373",
		linknext = "0114_00375",
		line = 5332,
	},
	["0114_00375"] = {
		{"bgm", stop=1},
		{"fg", file="touka_01m_00002", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
