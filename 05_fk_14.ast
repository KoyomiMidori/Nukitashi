		line = 1716,
	},
	["0114_00118"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like I said, ever since yesterday... Fumino's been way too nice to me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从昨天开始……文乃真的太宠我了啊，渡酱前辈……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從昨天開始……文乃真的太寵我了啊，渡醬前輩……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00117",
		linknext = "0114_00119",
		line = 1728,
	},
	["0114_00119"] = {
		{"fg", file="hinami_02f_00002", file1="hinami_02f_00112", file2="hinami_02f_00202", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2147", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, really? Well, you must be happy then, I guess?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，是那样啊……？好高兴啊，那真是太好了……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，是那樣啊……？好高興啊，那真是太好了……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00118",
		linknext = "0114_00120",
		line = 1741,
	},
	["0114_00120"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, but still! She's so much of a kindred spirit that it's driving me nuts, so I had to phone you up... Are you listening!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，那个已经……！完全肯定到我都不禁要打电话给你了……请听我说！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，那個已經……！完全肯定到我都不禁要打電話給你了……請聽我說！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00119",
		linknext = "0114_00121",
		line = 1753,
	},
	["0114_00121"] = {
		{"fg", file="hinami_02f_00002", file1="hinami_02f_00106", file2="hinami_02f_00202", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2148", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yes, of course, I'm listening. I'm your senior, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……会听会听……因为我是前辈啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……會聽會聽……因為我是前輩啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00120",
		linknext = "0114_00122",
		line = 1766,
	},
	["0114_00122"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, first of all, she's just so... so teeny!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先，那个孩子……总觉得是个小不点！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先，那個孩子……總覺得是個小不點！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00121",
		linknext = "0114_00123",
		line = 1778,
	},
	["0114_00123"] = {
		{"fg", file="hinami_01f_00002", file1="hinami_01f_00112", file2="hinami_01f_00202", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2149", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Uh, teeny? You mean, like, small?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“小、小不点……很小的意思吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「小、小不點……很小的意思嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00122",
		linknext = "0114_00124",
		line = 1791,
	},
	["0114_00124"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah! Like if I touched her the wrong way, she'd shatter into a million pieces! She's just too loli and adorable!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的——！让我觉得一不小心就会碰碎的那种，萝莉可爱……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的——！讓我覺得一不小心就會碰碎的那種，蘿莉可愛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00123",
		linknext = "0114_00125",
		line = 1803,
	},
	["0114_00125"] = {
		{"fg", file="hinami_02f_00002", file1="hinami_02f_00111", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2150", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“L-Loli and adorable... Is that a fact. I feel like I get called that a lot too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“萝、萝莉可爱……原来是这样啊……我好像也经常被这样说哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「蘿、蘿莉可愛……原來是這樣啊……我好像也經常被這樣說哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00124",
		linknext = "0114_00126",
		line = 1816,
	},
	["0114_00126"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
