		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1672", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What the fuck, she makes a great punching bag... I bet she'd make great noises when I hit her. Urge to continuously tease her and incite my sadistic urges, rising!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……！？这个正好合适的沙袋是怎么回事……！？敲了之后就会发出好听的叫声，不知不觉间就会激起想要作弄人的嗜虐心——！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……！？這個正好合適的沙袋是怎麼回事……！？敲了之後就會發出好聽的叫聲，不知不覺間就會激起想要作弄人的嗜虐心——！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00089",
		linknext = "0114_00091",
		line = 1303,
	},
	["0114_00091"] = {
