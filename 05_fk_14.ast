	["0114_00062"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=400, y=0, time=800},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1664", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Anyway, Fumino, get me some lunch, will ya? It's hot so I'm not really hungry but I still need some energy to yell at foreigners on voice chat. And don't give me rice porridge.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那比那个，文乃，麻沙酱想吃午饭了。虽然太热没有食欲但是吃了可以有力气和老外语音互骂不输的那种，除了稀饭。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那比那個，文乃，麻沙醬想吃午飯了。雖然太熱沒有食慾但是吃了可以有力氣和老外語音互罵不輸的那種，除了稀飯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00061",
		linknext = "0114_00063",
		line = 909,
	},
	["0114_00063"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“With that kind of attitude, I bet you could be an op-ed writer for a major newspaper.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是报社的社长吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是報社的社長嗎。」",
					{"rt2"},
				},
			},
		},
