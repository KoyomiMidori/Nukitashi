				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Excuse me. Good morning, Junnosuke. I came to ask about today's plans...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……打扰了。早安，淳之介同学。我来询问今天的安排……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……打擾了。早安，淳之介同學。我來詢問今天的安排……」",
					{"rt2"},
				},
			},
		},
