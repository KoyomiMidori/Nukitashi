		{"bg", id=1, file="bg09_3l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="touka_01l_00002", file1="touka_01l_00113", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0758", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You, that is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“——只有你一个人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「——只有你一個人。」",
