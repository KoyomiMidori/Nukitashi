			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Wait, I'm not that small! Not small... Am I really not that small?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不，虽然不小……！？虽然不小……是、是吗……？”",
