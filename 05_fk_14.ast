		linkback = "0114_00357",
		linknext = "0114_00359",
		line = 5144,
	},
	["0114_00359"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The instant I begin to draw my next breath...",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像穿过了我呼吸的间隙一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像穿過了我呼吸的間隙一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00358",
		linknext = "0114_00360",
		line = 5154,
	},
	["0114_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She slips forward to embrace me...",
					{"rt2"},
