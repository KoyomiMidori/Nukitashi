		},
		linkback = "0114_00221",
		linknext = "0114_00223",
		line = 3265,
	},
	["0114_00223"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sometimes I experience feelings of carnal desires coming on. But I'd be unable to obtain my lofty goals if I were to give in to them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在这种情况下，有时也会产生一些情欲。但是，拥有这种情绪将阻碍我们达到目标。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在這種情況下，有時也會產生一些情慾。但是，擁有這種情緒將阻礙我們達到目標。」",
					{"rt2"},
				},
