				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She shudders slightly and then bows her head deeply.",
					{"rt2"},
				},
			},
			cn = {
				{
					"身子颤抖了一下后，她深深鞠了一躬。",
					{"rt2"},
