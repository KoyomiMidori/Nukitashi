		linkback = "0114_00132",
		linknext = "0114_00134",
		line = 1917,
	},
	["0114_00134"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, anyway, I just wanted to tell you that. Enjoy your day off and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，我就是想把这件事告诉你才打了电话。那祝你假期愉快。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，我就是想把這件事告訴你才打了電話。那祝你假期愉快。」",
					{"rt2"},
				},
