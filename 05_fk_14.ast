				{"vo", file="fumino0736", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“How long? I believe from seven o'clock?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“什么时候，诶……大概7点左右吧……？”",
