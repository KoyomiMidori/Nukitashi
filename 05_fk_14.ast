					"“All right, we better get going. Asa, go and get changed for our little date.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好，那我们也该走了。麻沙酱快去换衣服吧，我们约会去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好，那我們也該走了。麻沙醬快去換衣服吧，我們約會去了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00166",
		linknext = "0114_00168",
		line = 2453,
	},
	["0114_00168"] = {
		{"se", id=0, loop=0, file="se_a144"},
		{"fg", file="asane_01m_00007", file1="asane_01m_00102", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=3, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		delay = {
