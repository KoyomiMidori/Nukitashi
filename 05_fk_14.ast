	["0114_00106"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=1, size=5, time=150, ease="easeinout_sine"},
		{"fg", file="asane_02m_00007", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whoa, you heard that!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦哦哦，你在听我说话吗……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦哦哦，你在聽我說話嗎……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00105",
		linknext = "0114_00107",
		line = 1533,
	},
	["0114_00107"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0751", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Your strong sense of dignity, your ability to act to protect your convictions, your stout heart that is willing to spare no effort for your objectives, and your unwavering will in the face of overwhelming authority!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“您那强烈的自尊，能够坚守信念的行动力，为了目的不惜一切努力的内心，面对强大权力也绝对不会动摇的决心……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「您那強烈的自尊，能夠堅守信念的行動力，為了目的不惜一切努力的內心，面對強大權力也絕對不會動搖的決心……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00106",
		linknext = "0114_00108",
		line = 1547,
	},
	["0114_00108"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00121", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0752", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have heartfelt respect for that immense strength of will!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那样强大的精神力……让文乃发自内心感到尊敬……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那樣強大的精神力……讓文乃發自內心感到尊敬……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00107",
		linknext = "0114_00109",
		line = 1561,
	},
