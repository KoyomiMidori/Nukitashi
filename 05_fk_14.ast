	["0114_00133"] = {
		{"fg", file="hinami_01f_00002", file1="hinami_01f_00103", path=":fg/hinami_01f/", id=30, ch="ヒナミ", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami2154", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
