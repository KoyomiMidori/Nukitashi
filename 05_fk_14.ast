		},
		linkback = "0114_00347",
		linknext = "0114_00349",
		line = 5006,
	},
	["0114_00349"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=6, size=5, time=100, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Stop running my ass ragged! What the fuck are you doing here!? What the fuck does the SS head honcho want with me!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别糊弄我——！那为什么和我接触了！FS的最高领袖到底是为了什么来找我的——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別糊弄我——！那為什麼和我接觸了！FS的最高領袖到底是為了什麼來找我的——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00348",
		linknext = "0114_00350",
		line = 5020,
	},
	["0114_00350"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0754", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I've already told you that I have come to see you as an individual. I simply wanted to see your face... you see?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我刚才也说了，今天我是作为个人与前辈见面的哦。只想看看你的脸哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我剛才也說了，今天我是作為個人與前輩見面的哦。只想看看你的臉哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00349",
		linknext = "0114_00351",
		line = 5034,
	},
	["0114_00351"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her frighteningly beautiful face smiles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的笑容，美丽得令人感到寒意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的笑容，美麗得令人感到寒意。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00350",
		linknext = "0114_00352",
		line = 5047,
	},
	["0114_00352"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0755", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In fact, neither the SS nor the OSS interest me in the slightest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“应该说——我其实对FS和SHO都不感兴趣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「應該說——我其實對FS和SHO都不感興趣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00351",
		linknext = "0114_00353",
		line = 5059,
	},
	["0114_00353"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00126", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00352",
		linknext = "0114_00354",
		line = 5071,
	},
	["0114_00354"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0756", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Naturally, I do care for Rei, Ikuko, and all my little underlings. But that has nothing to do with how the SS and OSS keep the lights on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“当然礼和郁子，还有部下们都很可爱……但我对于作为组织的FS和SHO的工作完全不感兴趣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「當然禮和郁子，還有部下們都很可愛……但我對於作為組織的FS和SHO的工作完全不感興趣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00353",
		linknext = "0114_00355",
		line = 5085,
	},
	["0114_00355"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then why the hell would you want to come here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，你为什么成了学生会长——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，你為什麼成了學生會長——」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00354",
		linknext = "0114_00356",
		line = 5097,
	},
	["0114_00356"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0757", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Call it a whim of mine. After all, I am fascinated by something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“只不过是顺其自然。是的，对我来说，最在意的事情——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「只不過是順其自然。是的，對我來說，最在意的事情——」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00355",
		linknext = "0114_00357",
		line = 5111,
	},
	["0114_00357"] = {
