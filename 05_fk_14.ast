			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“She's scaring you too! Heh! Anyway, I still haven't taken out my damn frustration! Fumino, c'mere and be my punching bag!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥不也在害怕吗……哼！不管怎样我的焦躁都不会平息下来的！文乃，当我的沙袋吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥不也在害怕嗎……哼！不管怎樣我的焦躁都不會平息下來的！文乃，當我的沙袋吧……！」",
					{"rt2"},
				},
			},
		},
