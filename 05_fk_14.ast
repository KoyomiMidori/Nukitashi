		{"text"},
		delay = {
			[2500] = {
				{"fg", file="asane_01m_00007", file1="asane_01m_00116", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=2500, time=300, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine", delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1676", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“This from 'just kinda worked out that way'? Tsk, and I thought Nanase and I were the only ones to understand your appeal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“顺其自然能到这个地步……？……切，我还以为能理解哥哥的魅力的只有我和奈奈濑同学呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「順其自然能到這個地步……？……呿，我還以為能理解哥哥的魅力的只有我和奈奈瀨同學呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00101",
		linknext = "0114_00103",
		line = 1477,
	},
	["0114_00103"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sure you do, but it's not like that slut understands.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱就不说了，婊子怎么能理解我的魅力呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬就不說了，婊子怎麼能理解我的魅力呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00102",
		linknext = "0114_00104",
		line = 1489,
	},
	["0114_00104"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My intense pride as a proud virgin and my overwhelming charisma has left a lasting impression on her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是我高傲的处男自尊心，还有洋溢的领袖魅力吸引了文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是我高傲的處男自尊心，還有洋溢的領袖魅力吸引了文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00103",
		linknext = "0114_00105",
		line = 1501,
	},
	["0114_00105"] = {
		{"se", id=0, loop=0, file="se_a093"},
