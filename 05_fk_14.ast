					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay, Fumino, I'm leaving you to watch the place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那么文乃，家里的事就拜托你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那麼文乃，家裡的事就拜託你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00169",
		linknext = "0114_00171",
		line = 2495,
	},
