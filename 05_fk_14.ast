				{
					name = {"文乃", "Fumino"},
					"“Since this is your first meal of the day, I opted for something simple. Some cold soup.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“虽然是午饭时间，但第一道是简单的菜……竹荚鱼凉汤……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「雖然是午飯時間，但第一道是簡單的菜……竹莢魚涼湯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00070",
		linknext = "0114_00072",
		line = 1035,
	},
	["0114_00072"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00112", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1667", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You managed to get me something that's easy to gulp down when you're not hungry, is cool, and even highly nutritious!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没有食欲的时候也容易吃，凉快，而且营养丰富的食物出现了……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒有食慾的時候也容易吃，涼快，而且營養豐富的食物出現了……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00071",
		linknext = "0114_00073",
		line = 1050,
	},
	["0114_00073"] = {
		{"se", id=0, loop=0, file="se_a176", vol=60},
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's boiled barley and rice, and unbelievably delicious!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且还是麦饭，好吃得难以置信……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且還是麥飯，好吃得難以置信……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00072",
		linknext = "0114_00074",
		line = 1063,
	},
	["0114_00074"] = {
		{"fg", file="asane_01m_00007", file2="asane_01m_00202", file3="asane_01m_00301", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1668", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Now what? How am I supposed to take out my PMS frustration if I have no excuse to pointlessly tease her!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么办，这样的话就没办法毫无理由地通过欺负文乃消除生理期前的烦躁啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼辦，這樣的話就沒辦法毫無理由地通過欺負文乃消除生理期前的煩躁啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00073",
		linknext = "0114_00075",
		line = 1078,
	},
	["0114_00075"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Knowing I share a last name with you really pains me sometimes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“像你这样的家伙有损我家名誉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「像你這樣的傢伙有損我家名譽。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00074",
		linknext = "0114_00076",
		line = 1090,
	},
	["0114_00076"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But when did you manage to prepare this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……不过，这些东西是什么时候准备的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……不過，這些東西是什麼時候準備的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00075",
		linknext = "0114_00077",
		line = 1102,
	},
	["0114_00077"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0743", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Last night... during dinner, I happened to notice that your sister had a poor appetite.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“从昨天晚上开始……晚饭时，我看妹妹大人食欲不佳……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「從昨天晚上開始……晚飯時，我看妹妹大人食慾不佳……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00076",
		linknext = "0114_00078",
		line = 1116,
	},
	["0114_00078"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00108", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[1000] = {
				{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=150, ease="easeinout_sine", delay2=1000},
				{"se", id=0, loop=0, file="se_a093", delay2=1000},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You noticed that and I didn't!? Dammit... I hate this shit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看穿了连我都没注意到的妹妹的状态不佳……！？唔，那还真有点不甘心——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看穿了連我都沒注意到的妹妹的狀態不佳……！？唔，那還真有點不甘心——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00077",
		linknext = "0114_00079",
		line = 1130,
	},
	["0114_00079"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00112", file2="fumino_01m_00202", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0744", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I-I'm terribly sorry?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“很、很抱歉……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「很、很抱歉……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00078",
		linknext = "0114_00080",
		line = 1145,
	},
	["0114_00080"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00109", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[8500] = {
				{"fg", file="asane_02m_00007", file1="asane_02m_00101", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=8500, time=300, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine", delay2=8500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1669", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Heh, that's nothing to apologize over! I mean, drinking chilled soup with the A/C going's gonna make you feel like shit anyway! Maybe think of... huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哼，别以为那样我就会认同你！再说了喝了凉汤之后再吹空调的话肯定会着凉更难受的啊！这部份你也要考虑……咦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哼，別以為那樣我就會認同你！再說了喝了涼湯之後再吹空調的話肯定會著涼更難受的啊！這部份你也要考慮……咦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00079",
		linknext = "0114_00081",
		line = 1163,
	},
	["0114_00081"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The A/C isn't even on... But it feels weirdly cool in here...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“明明没开空调……却很凉爽……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「明明沒開空調……卻很涼爽……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00080",
		linknext = "0114_00082",
		line = 1175,
	},
	["0114_00082"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0745", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Forgive my insolence, but I was finally able to ascertain the location of all the windows last night, so I ventilated the house.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“恕我僭越……我昨晚才终于明白了所有窗户的位置……所以进行了通风……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「恕我僭越……我昨晚才終於明白了所有窗戶的位置……所以進行了通風……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00081",
		linknext = "0114_00083",
		line = 1189,
	},
	["0114_00083"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're right, it feels a lot less stuffy in here... How'd you pull it off, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的，觉得浑浊的空气变清新了，但……光那样就会这么凉爽吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的，覺得渾濁的空氣變清新了，但……光那樣就會這麼涼爽嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00082",
		linknext = "0114_00084",
		line = 1201,
	},
	["0114_00084"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0746", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I adjusted the position of the fans with the open windows, and arranged for water to be sprayed in the flow of air.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“还配合风的流动洒了水，调整打开的窗户和电风扇的位置之后……是的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「還配合風的流動灑了水，調整打開的窗戶和電風扇的位置之後……是的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00083",
		linknext = "0114_00085",
		line = 1213,
	},
	["0114_00085"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00106", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1670", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Huh? Yo, Bro, this girl's kinda scaring me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呃，这个孩子怎么回事，能干到这种程度不觉得有点可怕吗哥哥？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「呃，這個孩子怎麼回事，能幹到這種程度不覺得有點可怕嗎哥哥？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00084",
		linknext = "0114_00086",
		line = 1228,
	},
	["0114_00086"] = {
		{"fg", file="fumino_02m_00001", file3="fumino_02m_00302", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0747", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“A sniper needs to be able to read the breeze.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“狙击手，是能读懂风的生物……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「狙擊手，是能讀懂風的生物……」",
					{"rt2"},
				},
