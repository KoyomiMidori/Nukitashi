			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Use your enormous junk to do so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“使用那个巨大的鸡巴吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「使用那個巨大的肉棒吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00374",
		linknext = "0114_00376",
		line = 5348,
	},
	["0114_00376"] = {
		{"se", id=1, loop=1, file="se_a107"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A chill runs down my spine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一阵寒意扑面而来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一陣寒意撲面而來。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00375",
		linknext = "0114_00377",
		line = 5359,
	},
	["0114_00377"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is it from what she said? Or her ominous grin?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是因为她说的话吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是因為她說的話嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00376",
		linknext = "0114_00378",
		line = 5369,
	},
	["0114_00378"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't say for sure.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还是因为那张凉爽的笑容？",
					{"rt2"},
				},
			},
			tw = {
				{
					"還是因為那張涼爽的笑容？",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00377",
