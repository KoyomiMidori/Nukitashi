		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
					{"exfont"},
				},
			},
			en = {
				{
					{"exfont", size="f4"},
					name = {"淳之介", "Junnosuke"},
					"“Fumino's too good at her job and I'm gonna lose my fuckin' mind!!”",
					{"rt2"},
					{"exfont"},
				},
			},
			cn = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"“——文乃太能干了我快不行了！！”",
					{"rt2"},
					{"exfont"},
				},
			},
			tw = {
				{
					{"exfont", size="f4"},
					name = {"淳之介"},
					"「——文乃太能幹了我快不行了！！」",
					{"rt2"},
					{"exfont"},
				},
			},
		},
		linkback = "0114_00286",
		linknext = "0114_00288",
		line = 4241,
	},
	["0114_00288"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="nanase_01f_00007", file1="nanase_01f_00115", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2197", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……啥？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……啥？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00287",
		linknext = "0114_00289",
		line = 4255,
	},
	["0114_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase's voice comes back with a similar reaction once more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一样是类似的反应，奈奈濑懵着回应我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一樣是類似的反應，奈奈瀨懵著回應我。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00288",
		linknext = "0114_00290",
		line = 4265,
	},
	["0114_00290"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm telling you! Fumino is too damn reliable! It's driving me nuts!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我说！文乃！太能干了！我好难啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我說！文乃！太能幹了！我好困擾啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00289",
		linknext = "0114_00291",
		line = 4277,
	},
	["0114_00291"] = {
		{"fg", file="nanase_02f_00007", file1="nanase_02f_00119", file2="nanase_02f_00202", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2198", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uh... Isn't that a good thing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啥……不，那不是很好吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啥……不，那不是很好嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00290",
		linknext = "0114_00292",
		line = 4290,
	},
	["0114_00292"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course it is!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那很好啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那很好啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00291",
		linknext = "0114_00293",
		line = 4302,
	},
	["0114_00293"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She takes care of all my daily needs, she's quiet, and whenever I think I might want something, she's already coming out with it spontaneously!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“身边的事都帮我做了，还安静，就连我无意识地想要某种东西时也能帮我做到！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「身邊的事都幫我做了，還安靜，就連我無意識地想要某種東西時也能幫我做到！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00292",
		linknext = "0114_00294",
		line = 4314,
	},
	["0114_00294"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Plus, she's so cute! A simple word of thanks and she's pleased without showing any expression! She praises me no matter what I say too!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且还很可爱啊！一道谢就会面无表情地高兴！我说什么都会夸奖我！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且還很可愛啊！一道謝就會面無表情地高興！我說什麼都會誇獎我！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00293",
		linknext = "0114_00295",
		line = 4326,
	},
	["0114_00295"] = {
		{"fg", file="nanase_01f_00007", file1="nanase_01f_00103", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2199", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sorry, but I am not seeing the issue here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我不觉得有什么不行的要素啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我不覺得有什麼不行的要素啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00294",
		linknext = "0114_00296",
		line = 4339,
	},
	["0114_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If she keeps pampering me like this, I'm gonna turn into a goddamn useless sloth!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“再这样宠我，我就要不行了啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「再這樣寵我，我就要不行了啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00295",
		linknext = "0114_00297",
		line = 4350,
	},
	["0114_00297"] = {
		{"fg", file="nanase_01f_00007", file1="nanase_01f_00110", file2="nanase_01f_00202", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2200", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh... So basically, you've been through so much shit in life that you're completely unaccustomed to somebody waiting on you hand and foot?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“哦……的确你好像到目前为止一直都在相当严苛的环境里……没有在家对谁撒娇的经验呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「哦……的確你好像到目前為止一直都在相當嚴苛的環境裡……沒有在家對誰撒嬌的經驗呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00296",
		linknext = "0114_00298",
		line = 4363,
	},
	["0114_00298"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00126", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You hit the nail on the head! I wonder if I'm gonna just end up being constantly needy now! And it scares the shit outta me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊！所以我害怕自己会在不知不觉间没完没了地对她撒娇啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊！所以我害怕自己會在不知不覺間沒完沒了地對她撒嬌啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00297",
		linknext = "0114_00299",
		line = 4375,
	},
	["0114_00299"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00124", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Dammit... If this keeps up, by the time Fumino leaves, I'm gonna be a sad, useless sack of a man!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔，再这样下去，如果文乃不在的话，我就会变成什么都做不了的男人——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔，再這樣下去，如果文乃不在的話，我就會變成什麼都做不了的男人——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00298",
		linknext = "0114_00300",
		line = 4387,
	},
	["0114_00300"] = {
		{"fg", file="nanase_02f_00007", file1="nanase_02f_00110", file2="nanase_02f_00202", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2201", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, you have Asa, don't you? Plus you're a grown-ass young adult. I think you'll be fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不还有麻沙酱在吗？而且你也是个大人了，我觉得应该没事吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不還有麻沙醬在嗎？而且你也是個大人了，我覺得應該沒事吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00299",
		linknext = "0114_00301",
		line = 4400,
	},
	["0114_00301"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_01f_00007", file1="nanase_01f_00110", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2202", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It's on you to make sure you don't end up like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“既然这样，那你就努力不要让自己变成那样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「既然這樣，那你就努力不要讓自己變成那樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00300",
		linknext = "0114_00302",
		line = 4414,
	},
	["0114_00302"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么意思……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼意思……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00301",
		linknext = "0114_00303",
		line = 4426,
	},
	["0114_00303"] = {
		{"bgm", file="bgm03", vol=100},
		{"fg", file="nanase_01f_00007", file1="nanase_01f_00102", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2203", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You're worried that Fumino's gonna get sick of you, and then it'll all be over, right? Then how about you make sure Fumino won't abandon you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳是在想要是文乃嫌弃你就完了对吧？那从今以后，为了不被文乃抛弃，试着努力看看怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳是在想要是文乃嫌棄你就完了對吧？那從今以後，為了不被文乃拋棄，試著努力看看怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00302",
		linknext = "0114_00304",
		line = 4440,
	},
	["0114_00304"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That's not a bad idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这——是个很好的想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這——是個很好的想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00303",
		linknext = "0114_00305",
		line = 4452,
	},
	["0114_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She's absolutely right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实如此。",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實如此。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00304",
		linknext = "0114_00306",
		line = 4462,
	},
	["0114_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She completely trusts me, and is utterly devoted to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个孩子很信任我，对我尽心尽力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個孩子很信任我，對我盡心盡力。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00305",
		linknext = "0114_00307",
		line = 4472,
	},
	["0114_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So worrying over putting in the effort to live up to her expectations won't do me any good.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么我——也要不停回应她的期待，不断努力下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼我——也要不停回應她的期待，不斷努力下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00306",
		linknext = "0114_00308",
		line = 4482,
	},
	["0114_00308"] = {
		{"fg", file="nanase_01f_00007", file1="nanase_01f_00120", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2204", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“For a start, don't be that guy who phones his teammates about this kinda shit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“首先，因为这种事就给队友打电话的男人是不行的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「首先，因為這種事就給隊友打電話的男人是不行的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00307",
		linknext = "0114_00309",
		line = 4495,
	},
	["0114_00309"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00120", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, sorry... Guess I got in the way of your day off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔……对不起了……难得的休息日却联系你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔……對不起了……難得的休息日卻聯繫你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00308",
		linknext = "0114_00310",
		line = 4507,
	},
	["0114_00310"] = {
		{"fg", file="nanase_01f_00007", file1="nanase_01f_00102", path=":fg/nanase_01f/", id=30, ch="奈々瀬", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase2205", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, I don't mind. I was on standby just in case anything happened anyway. I sure as hell didn't expect something like this, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那倒是没关系，我毕竟也为了以防万一而在待机……只是没想到是这样的内容而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那倒是沒關係，我畢竟也為了以防萬一而在待機……只是沒想到是這樣的內容而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00309",
		linknext = "0114_00311",
		line = 4520,
	},
	["0114_00311"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00125", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry about that... Well, see you at school.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真惭愧……那么，学校见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真慚愧……那麼，學校見。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00310",
		linknext = "0114_00312",
		line = 4532,
	},
	["0114_00312"] = {
