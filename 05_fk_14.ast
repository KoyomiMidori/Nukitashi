	["0114_00345"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must have some demand to ask of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——她应该对我有什么要求。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——她應該對我有什麼要求。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00344",
		linknext = "0114_00346",
		line = 4971,
	},
	["0114_00346"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That's all I can assume.",
