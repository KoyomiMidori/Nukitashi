	["0114_00347"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0753", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I'm not here to threaten you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，我不打算威胁你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，我不打算威脅你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00346",
		linknext = "0114_00348",
		line = 4996,
	},
	["0114_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says, having read my mind again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长又像读了我的心一样说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長又像讀了我的心一樣說道。",
					{"rt2"},
