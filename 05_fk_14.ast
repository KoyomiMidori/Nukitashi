		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="asane_01m_00007", file1="asane_01m_00104", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=1000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1678", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, there you are. What's up? You rushed right into your room looking all flustered. Needed some 'alone time', I'm guessing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，回来了……怎么了哥哥，突然一脸恶心地回房间……来例假吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，回來了……怎麼了哥哥，突然一臉噁心地回房間……生理期來了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00135",
		linknext = "0114_00137",
		line = 1993,
	},
	["0114_00137"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00110", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it's nothing. I just got a little emotional.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，没什么……只是情绪有点高涨——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，沒什麼……只是情緒有點高漲——」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00136",
		linknext = "0114_00138",
		line = 2005,
	},
	["0114_00138"] = {
		{"fg", file="asane_01m_00007", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="asane_01m_00007", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=2000, time=300, mode=3, x=400, y=0},
			},
			[6700] = {
				{"fg", file="asane_01m_00007", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=6700, time=300, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=6700},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1679", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hmmm... Well, whatevs. I feel hungrier now that I've eaten something. Yo, Fumino, gimme something sweet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哼，那就好……感觉吃了饭就有食欲了……文乃，我想吃甜的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哼，那就好……感覺吃了飯就有食慾了……文乃，我想吃甜的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00137",
		linknext = "0114_00139",
		line = 2025,
	},
	["0114_00139"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00110", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=-400, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0753", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“As you wish. I shall prepare some anmitsu and matcha. Please enjoy it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“知道了……那么，请把豆沙和抹茶一起品尝吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「知道了……那麼，請把豆沙和抹茶一起品嚐吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00138",
		linknext = "0114_00140",
		line = 2040,
	},
	["0114_00140"] = {
		{"se", id=0, loop=0, file="se_a002"},
		{"fgact", ch="文乃", id=7, act="移動", x=-200, y=0, time=600},
		{"fg", mode=-1, id=7, ch="文乃", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She adroitly whisks off towards the kitchen and begins preparing the sweets.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃以不难看的小跑前往厨房，开始准备起甜点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃以不難看的小跑前往廚房，開始準備起甜點。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00139",
		linknext = "0114_00141",
		line = 2054,
	},
	["0114_00141"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="asane_01m_00007", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="asane_01m_00007", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, delay2=4000, time=300, mode=3, x=400, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1680", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You said she was like an upper-class girl, or some kind of princess... but it's more like we have a servant in the house now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“原本听说有个大小姐还公主要来……结果家里却多了个佣人呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「原本聽說有個大小姐還公主要來……結果家裡卻多了個傭人呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00140",
		linknext = "0114_00142",
		line = 2071,
	},
	["0114_00142"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, she's not your personal slave, so knock it off. She's under our roof now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不能把同居人当做佣人哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不能把同居人當做傭人哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00141",
		linknext = "0114_00143",
		line = 2083,
	},
	["0114_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though to me, I can only really see her as a servant as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是现在的她，在我看来也只是个佣人或随从。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是現在的她，在我看來也只是個傭人或隨從。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00142",
		linknext = "0114_00144",
		line = 2093,
	},
	["0114_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But still...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，总的说来——",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，總的說來——",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00143",
		linknext = "0114_00145",
		line = 2103,
	},
	["0114_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks much more lively like this than an austere girl of upper-class upbringing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与深闺大小姐这种孤高的她相比，现在的文乃更有活力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與深閨大小姐這種孤高的她相比，現在的文乃更有活力。",
					{"rt2"},
				},
			},
		},
