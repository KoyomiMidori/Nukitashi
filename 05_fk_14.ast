			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Huh? Good morning, Junnosuke. Today is a most pleasant day once more.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“哈……早、早安，淳之介同学……今天、天气也很好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「哈……早、早安，淳之介同學……今天、天氣也很好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00039",
