		linkback = "0114_00042",
		linknext = "0114_00044",
		line = 605,
	},
	["0114_00044"] = {
		{"fg", file="jun_01f_00002", file2="jun_01f_00202", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it's my fault for not waking up. How long have you been there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，不如说是没起床的我不对……从什么时候开始等的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，不如說是沒起床的我不對……從什麼時候開始等的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00043",
		linknext = "0114_00045",
		line = 617,
	},
	["0114_00045"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00111", file2="fumino_02m_00202", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="文乃", id=7, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
