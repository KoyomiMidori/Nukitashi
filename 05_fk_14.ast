	["0114_00324"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The student council president — Reizeiin Touka — stands there with an imposing smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生会长——冷泉院桐香露出无敌的笑容站在那里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生會長——冷泉院桐香露出無敵的笑容站在那裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00323",
		linknext = "0114_00325",
		line = 4712,
	},
	["0114_00325"] = {
		{"cgdel", id=2, lv=5, time=700, alphadel=1},
		{"fg", mode=-1, id=8, ch="桐香", lv=5, time=700},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg09_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00121", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why are you here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么你在这里——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼你在這裡——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00324",
		linknext = "0114_00326",
		line = 4732,
	},
	["0114_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why'd she come to my house?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么，这家伙会到我家来——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼，這傢伙會到我家來——？",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00325",
		linknext = "0114_00327",
		line = 4742,
	},
	["0114_00327"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0747", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“My capabilities are not like other people. I can discern quite a few details about someone simply by touching them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我有个与他人不同，而且有点奇怪的特长，那就是——只要和对方接触，就能大概知道对方的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我有個與他人不同，而且有點奇怪的特長，那就是——只要和對方接觸，就能大概知道對方的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00326",
		linknext = "0114_00328",
		line = 4756,
	},
	["0114_00328"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Discern...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说知道……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說知道……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00327",
		linknext = "0114_00329",
		line = 4768,
	},
	["0114_00329"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00113", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0748", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It requires the intertwining of mucous membranes to be effective. Especially to discern when someone is lying.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“只要粘膜接触，就能知道大概的事情——特别是，如果那是谎言的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「只要黏膜接觸，就能知道大概的事情——特別是，如果那是謊言的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00328",
		linknext = "0114_00330",
		line = 4782,
	},
	["0114_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Intertwining of mucous membranes...",
					{"rt2"},
				},
			},
			cn = {
				{
					"粘膜接触。",
					{"rt2"},
				},
			},
			tw = {
				{
					"黏膜接觸。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00329",
		linknext = "0114_00331",
		line = 4792,
	},
	["0114_00331"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that why you kissed me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道，那个时候的吻是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道，那個時候的吻是——」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00330",
		linknext = "0114_00332",
		line = 4804,
	},
	["0114_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SS have sniffed us out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——FS找过来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——FS找過來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00331",
		linknext = "0114_00333",
		line = 4814,
	},
	["0114_00333"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"se", id=1, loop=0, file="se_a036"},
		{"cgact", file="cgact", id=1, act="振動下", loop=1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So there has to be a squad somewhere, lying in wait—",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么某处一定有队员隐藏着——",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼某處一定有隊員隱藏著——",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00332",
		linknext = "0114_00334",
		line = 4827,
	},
	["0114_00334"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0749", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Worry not. I have come here alone. Neither Rei nor Ikuko are with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……请放心，这里只有我一个人。礼和郁子都没有来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……請放心，這裡只有我一個人。禮和郁子都沒有來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00333",
		linknext = "0114_00335",
		line = 4841,
	},
	["0114_00335"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She smiles. Almost as if she just read my mind?",
					{"rt2"},
				},
			},
			cn = {
				{
					"仿佛看透了我的思维，她微笑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彷彿看透了我的思維，她微笑著。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00334",
		linknext = "0114_00336",
		line = 4852,
	},
	["0114_00336"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And you expect me to believe you? You're the big cheese of the SS. A bigwig wouldn't be walking the streets by themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说的话能信吗。你们FS，怎么可能会让最高领袖一个人过来——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說的話能信嗎。你們FS，怎麼可能會讓最高領袖一個人過來——」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00335",
		linknext = "0114_00337",
		line = 4864,
	},
	["0114_00337"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00102", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0750", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You are right. But I am here strictly as an individual. As Reizeiin Touka, and nothing more.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的。所以我今天是作为个人过来的，只是作为冷泉院桐香这个身份。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的。所以我今天是作為個人過來的，只是作為冷泉院桐香這個身份。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00336",
		linknext = "0114_00338",
		line = 4878,
	},
	["0114_00338"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00337",
		linknext = "0114_00339",
		line = 4890,
	},
	["0114_00339"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00110", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="桐香", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0751", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If you want proof, I haven't told the SS about your deception. All of that is a secret, quite literally sealed with a kiss.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“作为证据，你对FS进行的谎报，也都守在我的手里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「作為證據，你對FS進行的謊報，也都守在我的手裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00338",
		linknext = "0114_00340",
		line = 4905,
	},
	["0114_00340"] = {
		{"fg", file="touka_01m_00002", file1="touka_01m_00111", path=":fg/touka_01m/", id=8, lv=5, head="touka_01m", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="touka0752", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And of course... when it comes to how Fumino has concealed her identity, I have not told the OSS a thing about that either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“当然——我也没有把",
					{"ruby", text="・・・・"},
					"那个姿态",
					{"/ruby"},
					"的文乃同学的情报交给SHO哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「當然——我也沒有把",
					{"ruby", text="・・・・"},
					"那個姿態",
					{"/ruby"},
					"的文乃同學的情報交給SHO哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00339",
		linknext = "0114_00341",
		line = 4919,
	},
	["0114_00341"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the SS had found me out, we wouldn't be able to make it to school comfortably anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO只要知道了——我应该就没办法像往常一样正常去学校了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO只要知道了——我應該就沒辦法像往常一樣正常去學校了。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00340",
		linknext = "0114_00342",
		line = 4929,
	},
	["0114_00342"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And if the OSS had found Fumino out, she wouldn't be able to just lay low out here. Especially not if they found out about her crossdressing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO知道文乃的存在，但同时她还能过得好好的——那是因为女扮男装的文乃没有被识破。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO知道文乃的存在，但同時她還能過得好好的——那是因為女扮男裝的文乃沒有被識破。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00341",
		linknext = "0114_00343",
		line = 4939,
	},
	["0114_00343"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So she must be telling the truth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，她真的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，她真的——",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00342",
		linknext = "0114_00344",
		line = 4949,
	},
	["0114_00344"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What do you want?”",
					{"rt2"},
