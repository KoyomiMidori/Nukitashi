				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Hmm... there must be more... There's a ladder behind the drawers that leads to an attic. I'll clean here too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“呜……",
					{"ruby", text="・・"},
					"还有",
					{"/ruby"},
					"……在哪呢……柜子的后面，有个连接到阁楼的梯子……这里也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗚……",
					{"ruby", text="・・"},
					"還有",
					{"/ruby"},
					"……在哪呢……櫃子的後面，有個連接到閣樓的梯子……這裡也……」",
					{"rt2"},
				},
			},
