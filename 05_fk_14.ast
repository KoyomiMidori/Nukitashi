				{"fg", file="asane_02m_00007", file1="asane_02m_00121", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, delay2=4500, time=300, mode=3, x=400, y=0},
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine", delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="asane1681", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A date with Bro, a date with Bro, and no one to get between us! Why not call Nanase while we're at it!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“和哥哥约会～和哥哥约会～没有妨碍只有两个人〜……！对了，把奈奈濑同学也叫来吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「和哥哥約會～和哥哥約會～沒有妨礙只有兩個人〜……！對了，把奈奈瀨同學也叫來吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00167",
		linknext = "0114_00169",
		line = 2471,
	},
	["0114_00169"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00114", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I'm sure she wants some time off too, so no.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也想让奈奈濑休息一下，所以不行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也想讓奈奈瀨休息一下，所以不行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00168",
		linknext = "0114_00170",
		line = 2483,
	},
	["0114_00170"] = {
