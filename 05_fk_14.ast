		text = {
			vo = {
				{"vo", file="fumino0763", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Ah, to think that I'd leave the master's belongings on the floor. What an oversight. I have to let him scold me afterwards. Oh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“啊，居然把主人的东西弄掉了……真是、太失态了……等一下，要让他教训我才行……咦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「啊，居然把主人的東西弄掉了……真是、太失態了……等一下，要讓他教訓我才行……咦……？」",
					{"rt2"},
				},
			},
		},
