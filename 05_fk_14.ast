	["0114_00066"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="asane_01m_00007", file1="asane_01m_00120", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1665", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don't have much of an appetite but I'm hungry AF so if you don't get me something in the next three minutes I'm gonna roast your ass for no reason.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我没有食欲但肚子瘪瘪的所以3分钟之内不拿过来的话我会毫无理由地霸凌你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我沒有食慾但肚子癟癟的所以3分鐘之內不拿過來的話我會毫無理由地霸凌你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00065",
		linknext = "0114_00067",
		line = 966,
	},
	["0114_00067"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually, forget newspapers. Try looking up 'cognitive dissonance' in the dictionary.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么可以说出那种就算写在词典里的‘矛盾’项目上也说得通的要求呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼可以說出那種就算寫在詞典裡的『矛盾』項目上也說得通的要求呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00066",
		linknext = "0114_00068",
		line = 978,
	},
	["0114_00068"] = {
