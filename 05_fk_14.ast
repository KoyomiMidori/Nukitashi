	},
	["0114_00146"] = {
		{"se", id=0, loop=0, file="se_a176", vol=40},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00119", path=":fg/fumino_01m/", id=7, lv=5, head="fumino_01m", ch="文乃", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="文乃", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
