			},
			tw = {
				{
					"學生會長輕易地鑽進了我的懷裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00359",
		linknext = "0114_00361",
		line = 5164,
	},
	["0114_00361"] = {
		{"fg", file="touka_01l_00002", file1="touka_01l_00110", path=":fg/touka_01l/", id=8, lv=5, head="touka_01l", ch="桐香", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And makes that baffling comment as she does so.",
					{"rt2"},
				},
			},
			cn = {
				{
					"伴随着意图不明的言辞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"伴隨著意圖不明的言辭。",
