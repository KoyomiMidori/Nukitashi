					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I-I'm terribly sorry. I unintentionally nodded off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“对、对不起……不小心就……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「對、對不起……不小心就……」",
					{"rt2"},
				},
