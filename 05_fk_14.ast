	},
	["0114_00042"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00123", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, never mind that... Were you sleeping?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，虽然没关系……你睡着了吗……？”",
