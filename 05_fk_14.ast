				{"vo", file="fumino0754", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Junnosuke... what's on the agenda for today?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“淳之介同学……您今天有什么安排吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「淳之介同學……您今天有什麼安排嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00145",
		linknext = "0114_00147",
		line = 2128,
	},
	["0114_00147"] = {
		{"fg", file="asane_02m_00007", file1="asane_02m_00113", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[900] = {
				{"fgact", ch="麻沙音", id=3, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine", delay2=900},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm? Let's see, I was thinking of going to buy what's needed for our TAEs with Asa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯？对了，我想和麻沙酱一起去买T-A-E需要的东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯？對了，我想和麻沙醬一起去買T-A-E需要的東西。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00146",
		linknext = "0114_00148",
		line = 2144,
	},
	["0114_00148"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[900] = {
