			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“In that case, may I stay at home and do the cleaning?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那么……我可以帮忙打扫一下家里吗？”",
