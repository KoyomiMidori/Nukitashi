		line = 324,
	},
	["0069_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The old man is likely close to being ready to receive Fumino, and the illegal sex industry is still targeting children.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人现在应该已经做好了接手文乃的准备，而地下风俗现在也打着小孩子的主意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人現在應該已經做好了接手文乃的準備，而地下風俗現在也打著小孩子的主意。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00021",
		linknext = "0069_00023",
		line = 334,
	},
	["0069_00023"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think it's about high time we kicked our sting operation into gear.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——所以，我想马上展开诱饵调查。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——所以，我想馬上展開誘餌調查。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00022",
		linknext = "0069_00024",
		line = 346,
	},
	["0069_00024"] = {
		{"bg", id=1, file="bg12_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
