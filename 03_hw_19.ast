	["0069_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There didn't seem to have any problem immediately after sex, but it seems she suffered the effects somewhat later. She can't walk properly this morning.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作爱之后虽然没有立刻发生什么问题，但之后负担就出现了——早上雏见几乎不能走路。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作愛之後雖然沒有立刻發生什麼問題，但之後負擔就出現了——早上雛見幾乎不能走路。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00012",
		linknext = "0069_00014",
		line = 198,
	},
	["0069_00014"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wanted to throw her a line, but if I say anything now it'll only worsen things.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然很想帮她，但这种情况如果再插嘴的话，大概只会让灾害扩大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然很想幫她，但這種情況如果再插嘴的話，大概只會讓災害擴大。",
					{"rt2"},
