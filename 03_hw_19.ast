		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hide in the shadows and keep my eye on Hinami, ready for battle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我躲在阴影里，以临战状态看着雏见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我躲在陰影裡，以臨戰狀態看著雛見。",
