		{"fgact", ch="ヒナミ", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1551", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah! Let's do this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦——！加油——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦——！加油——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00023",
		linknext = "0069_00025",
		line = 361,
	},
	["0069_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami seems to have gotten over this morning's bout of the jibblies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见不停发抖的脚似乎已经恢复了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見不停發抖的腳似乎已經恢復了。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00024",
		linknext = "0069_00026",
		line = 371,
	},
	["0069_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now, let's go over the details of our strategy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那么再次确认作战内容。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那麼再次確認作戰內容。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00025",
		linknext = "0069_00027",
		line = 383,
	},
	["0069_00027"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hinami acts as a decoy to lure out those illegal sex industry thugs, and then we swoop in and interrogate them... Them's the basics.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“雏见来当诱饵引出地下风俗的关系者，然后从他那里打听出地下风俗的情报——简单地说就是这样的作战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雛見來當誘餌引出地下風俗的關係者，然後從他那裡打聽出地下風俗的情報——簡單地說就是這樣的作戰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00026",
		linknext = "0069_00028",
		line = 395,
	},
	["0069_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It sounds easy enough, but anything's going to have an additional risk factor with the yakuza involved.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然用说的很容易，但要跟黑社会打交道就相当危险了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然用說的很容易，但要跟黑社會打交道就相當危險了。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00027",
		linknext = "0069_00029",
		line = 405,
	},
	["0069_00029"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The rest of our team will be assigned to bodyguard duties in case of an urgent need to escape.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了避免万一，全员都前去护卫。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了避免萬一，全員都前去護衛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00028",
		linknext = "0069_00030",
		line = 417,
	},
	["0069_00030"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0252", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Does that mean I can help too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那么，我也……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那麼，我也……」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00029",
		linknext = "0069_00031",
		line = 430,
	},
	["0069_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks up at me in appeal, but I shake my head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对着像是恳求似的抬头看着我的文乃，我摇了摇头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對著像是懇求似的抬頭看著我的文乃，我搖了搖頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00030",
		linknext = "0069_00032",
		line = 440,
	},
	["0069_00032"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry. We have to allocate all our resources to protecting Hinami.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起……我们有必要把所有的资源用在雏见的护卫上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起……我們有必要把所有的資源用在雛見的護衛上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00031",
		linknext = "0069_00033",
		line = 452,
	},
	["0069_00033"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If some organization were to catch wind of your existence, we wouldn't be able to respond.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“万一文乃的存在被某个组织发现了，我们会应对不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「萬一文乃的存在被某個組織發現了，我們會應對不了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00032",
		linknext = "0069_00034",
		line = 464,
	},
	["0069_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's a cowardly way to put it, but I'm unable to hide how I really feel.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我觉得这是个卑鄙的说法，但这也是我毫不隐藏的真心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我覺得這是個卑鄙的說法，但這也是我毫不隱藏的真心。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00033",
		linknext = "0069_00035",
		line = 474,
	},
	["0069_00035"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00113", path=":fg/fumino_02m/", id=7, lv=5, head="fumino_02m", ch="文乃", mw="mw", sync=0, time=300, mode=3, x=600, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0253", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Very well. Even if I cannot assist you, I would like to wish all of you the best of luck.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“……我明白了。虽然不能帮上大家，但我会为在场的各位祈祷的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「……我明白了。雖然不能幫上大家，但我會為在場的各位祈禱的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00034",
		linknext = "0069_00036",
		line = 488,
	},
	["0069_00036"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, thanks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
