	["0069_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I take a closer look from my vantage point, and see some two-bit thug wringing the neck of the woman he's having sex with.",
					{"rt2"},
