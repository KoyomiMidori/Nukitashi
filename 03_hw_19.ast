	["0069_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We gather in the base after school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后，今天也在基地集合。",
					{"rt2"},
				},
