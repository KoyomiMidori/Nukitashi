		linkback = "0069_00038",
		linknext = "0069_00040",
		line = 541,
	},
	["0069_00040"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don't you feel like Hinami's suddenly become much more mature lately? I'm worried as to whether they'll perceive her as a loli.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最近雏见突然变得很成熟对吧？不知道那群人会不会当她是萝莉——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最近雛見突然變得很成熟對吧？不知道那群人會不會當她是蘿莉——」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00039",
		linknext = "0069_00041",
		line = 553,
	},
	["0069_00041"] = {
