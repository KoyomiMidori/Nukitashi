		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1545", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“J-Jun, is there something I can help with? Can't I help?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“淳君，我也帮点什么吧……？有什么能帮你的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「淳君，我也幫點什麼吧……？有什麼能幫你的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00001",
		linknext = "0069_00003",
		line = 41,
	},
	["0069_00003"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, no... you're still not... fully recovered, are you? I'll take care of things this morning. You rest up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不、不用……你还没那个……完全恢复吧？今天早上我来准备就好……你休息一下吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不、不用……你還沒那個……完全恢復吧？今天早上我來準備就好……你休息一下吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00002",
		linknext = "0069_00004",
		line = 53,
	},
	["0069_00004"] = {
