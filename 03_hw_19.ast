					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我、我就说没有！昨天晚上很想和淳君做些色色的事情最后还真的做了但我并没有两腿发软哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我、我就說沒有！昨天晚上很想和淳君做些色色的事情最後還真的做了但我並沒有兩腿發軟哦！」",
					{"rt2"},
				},
