				},
			},
		},
		linkback = "0069_00047",
		linknext = "0069_00049",
		line = 708,
	},
	["0069_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hold the SS-style handgun in both hands— the one that Rei gave me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"双手上的装备是FS式手枪——那天礼前辈送给我的手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雙手上的裝備是FS式手槍——那天禮前輩送給我的手槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00048",
		linknext = "0069_00050",
		line = 718,
	},
	["0069_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can't give it back, and I can't exactly get rid of it either, so unfortunately, I'm stuck with it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不能归还，但也不能扔掉——所以我恋恋不舍地留在自己身边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不能歸還，但也不能扔掉——所以我戀戀不捨地留在自己身邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00049",
		linknext = "0069_00051",
		line = 728,
	},
	["0069_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just clutching it in my hands makes me feel nervous.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一握，至今还是会觉得心痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一握，至今還是會覺得心痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00050",
		linknext = "0069_00052",
		line = 738,
	},
	["0069_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But it'll be indispensable when it comes to protecting Hinami... You bet your ass I'll pull that trigger if I have to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是为了保护雏见，它是必不可少的——如果有必要的话，我会毫不犹豫地扣下扳机。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是為了保護雛見，它是必不可少的——如果有必要的話，我會毫不猶豫地扣下扳機。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00051",
		linknext = "0069_00053",
		line = 748,
	},
