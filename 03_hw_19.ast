	["0069_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I was in a bad place, and about to lose my mind, I was able to get back on my feet with Hinami's support.",
					{"rt2"},
				},
			},
			cn = {
				{
					"内心不稳定，快要崩溃的时候——是雏见支持了我，让我可以重新振作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"內心不穩定，快要崩潰的時候——是雛見支持了我，讓我可以重新振作。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00136",
