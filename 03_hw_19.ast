	},
	["0069_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He told me that not long after coming to the island, he was given some of the so-called “magic water”, and told he could make use of it to fuck kids.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们说，来岛没多久就听人说“只要用这个，就可以跟小孩做爱”，然后得到了“魔法水”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們說，來島沒多久就聽人說「只要用這個，就可以跟小孩做愛」，然後得到了「魔法水」。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00103",
		linknext = "0069_00105",
		line = 1496,
	},
	["0069_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And when I asked who gave it to him, he said it was from an OSS member.",
					{"rt2"},
				},
			},
			cn = {
				{
					"问他们是跟谁拿的——结果他们说是从SHO的人那里拿到的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"問他們是跟誰拿的——結果他們說是從SHO的人那裡拿到的。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00104",
		linknext = "0069_00106",
		line = 1506,
	},
	["0069_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The OSS are the last possible people I can imagine saying that railing lolis is okay, but he seemed to be telling the truth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不觉得SHO会允许游客跟萝莉做爱，但他们看起来也不像在说谎。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不覺得SHO會允許遊客跟蘿莉做愛，但他們看起來也不像在說謊。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00105",
		linknext = "0069_00107",
		line = 1516,
	},
	["0069_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thinking back, when we recaptured Fumino, some of the OSS were under yakuza orders, so this is probably a continuation of that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想起来，在夺回文乃的那一天——SHO的一部分成为了黑社会的手下，也许这也是那之后的延续。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回想起來，在奪回文乃的那一天——SHO的一部分成為了黑社會的手下，也許這也是那之後的延續。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00106",
		linknext = "0069_00108",
		line = 1526,
	},
	["0069_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At any rate, that's all the information we obtained for today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之，这次得到的情报只有这些。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之，這次得到的情報只有這些。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00107",
		linknext = "0069_00109",
		line = 1536,
	},
	["0069_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still... it's undeniable that someone is leading the spread of activity that's turning children into victims of sexual abuse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然只有这些——但确实有人在带头引发小孩子受害的事件。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然只有這些——但確實有人在帶頭引發小孩子受害的事件。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00108",
		linknext = "0069_00110",
		line = 1546,
	},
	["0069_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It makes me sick to my stomach.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真是令人恶心的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真是令人噁心的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00109",
		linknext = "0069_00111",
		line = 1556,
	},
	["0069_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As stupid and illogical the perverted sex law is, it does at least have a specific provision which excludes sexually immature children.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然变态条例确实是很不合常理的条例，但在照顾性方面还不成熟的孩子这部份还算是很通情达理的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然變態條例確實是很不合常理的條例，但在照顧性方面還不成熟的孩子這部份還算是很通情達理的。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00110",
		linknext = "0069_00112",
		line = 1566,
	},
	["0069_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But now even that is in peril...",
					{"rt2"},
				},
			},
			cn = {
				{
					"连这方面都受到威胁的话——",
					{"rt2"},
				},
			},
			tw = {
				{
					"連這方面都受到威脅的話——",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00111",
		linknext = "0069_00113",
		line = 1576,
	},
	["0069_00113"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=-600, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1161", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bro. I looked into the company which produced that water. Their record's clean as can be. Just your average manufacturing company with nationwide operations, nothing special.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥……我查了一下那水的制造公司……是无辜的。那是一家在全国范围内做正常销售的制造商。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥……我查了一下那水的製造公司……是無辜的。那是一家在全國範圍內做正常銷售的製造商。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00112",
		linknext = "0069_00114",
		line = 1590,
	},
	["0069_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎——」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00113",
		linknext = "0069_00115",
		line = 1601,
	},
	["0069_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, I suspected as much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，我也隐约觉得应该是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，我也隱約覺得應該是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00114",
		linknext = "0069_00116",
		line = 1611,
	},
	["0069_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I did confiscate the bottle containing the “magic water” in order to look into it, but it turns out it's no different from a typical water bottle you'd see on store shelves.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我看了看从他们那里没收的“魔法水”的塑料瓶——那个包装很眼熟。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我看了看從他們那裡沒收的「魔法水」的塑膠瓶——那個包裝很眼熟。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00115",
		linknext = "0069_00117",
		line = 1621,
	},
	["0069_00117"] = {
		{"bg", id=1, file="bg19_3_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00106", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1557", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Say, Jun, do you think this water's...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“淳君，难道这水是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「淳君，難道這水是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00116",
		linknext = "0069_00118",
		line = 1635,
	},
	["0069_00118"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The same stuff you drank before? Yeah, it seems likely enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——应该和雏见喝到的水是一样的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯——應該和雛見喝到的水是一樣的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00117",
		linknext = "0069_00119",
		line = 1647,
	},
	["0069_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It's basically the same aphrodisiac that the SS put in the water coolers. Different ballpark, same sport.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跟FS装在给水器里的是同一种媚药，是之后被人为添加进去的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跟FS裝在給水器裡的是同一種媚藥，是之後被人為添加進去的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00118",
		linknext = "0069_00120",
		line = 1659,
	},
	["0069_00120"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		delay = {
			[700] = {
				{"se", id=0, loop=0, file="se_a177", delay2=700},
			},
		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I pour some out into a glass and have a closer look.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我试着把塑料瓶里的水倒到杯子里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我試著把塑膠瓶裡的水倒到杯子裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00119",
		linknext = "0069_00121",
		line = 1671,
	},
	["0069_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's clean, transparent and odorless. No matter how you look at it, it just seems to be plain old bottled water.",
					{"rt2"},
				},
			},
			cn = {
				{
					"外观晶莹剔透，没有任何气味——是没有任何奇特之处的矿泉水。",
					{"rt2"},
				},
			},
			tw = {
				{
					"外觀晶瑩剔透，沒有任何氣味——是沒有任何奇特之處的礦泉水。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00120",
		linknext = "0069_00122",
		line = 1681,
	},
	["0069_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since it doesn't show any signs of having had the drug mixed into it, that would make it consistent with the stuff the SS had.",
					{"rt2"},
				},
			},
			cn = {
				{
					"掺入水中也不产生变化这点，和FS使用的媚药相同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"摻入水中也不產生變化這點，和FS使用的媚藥相同。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00121",
		linknext = "0069_00123",
		line = 1691,
	},
	["0069_00123"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00106", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch="ヒナミ", mw="mw", sync=0, time=300, mode=3, x=400, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1558", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Though, it doesn't necessarily mean that the SS are responsible for mixing that stuff into this water themselves, huh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是FS的人往水里放了色色的药……应该不会有这种事吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是FS的人往水裡放了色色的藥……應該不會有這種事吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00122",
		linknext = "0069_00124",
		line = 1706,
	},
	["0069_00124"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Anyone could do it if they got ahold of the stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊……只要有媚药，谁都可以办到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊……只要有媚藥，誰都可以辦到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00123",
		linknext = "0069_00125",
		line = 1718,
	},
	["0069_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, by that extension... where's the drug coming from?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么，药的来源就是问题了吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼，藥的來源就是問題了吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00124",
		linknext = "0069_00126",
		line = 1730,
	},
	["0069_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"During the entrance examination, the student council prez had referred to it as a “specimen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"入队考试时，学生会长说那媚药是“试用品”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"入隊考試時，學生會長說那媚藥是「試用品」。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00125",
		linknext = "0069_00127",
		line = 1740,
	},
	["0069_00127"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess we'd need to ask the SS firsthand if we're gonna find out where the hell they got it from.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是从哪里进货的……有必要直接问FS。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是從哪裡進貨的……有必要直接問FS。」",
					{"rt2"},
