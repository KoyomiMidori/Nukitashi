	["0069_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I used my mad CQC skills to put the screws on the guy about to assault Hinami, and he sang for me like fuckin' Pavarotti.",
					{"rt2"},
				},
			},
			cn = {
				{
					"——准备攻击雏见的男人们，在遭到SQC的间接拷问之后立即道出了经过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"——準備攻擊雛見的男人們，在遭到SQC的間接拷問之後立即道出了經過。",
					{"rt2"},
				},
			},
