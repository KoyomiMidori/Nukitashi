					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yawn... I'm awake at a reasonable hour again... Maybe I'll become healthy, wealthy and/or wise now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呼哇……又在健康的时间里起床了……这样下去会变成正经人的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「呼哇……又在健康的時間裡起床了……這樣下去會變成正經人的……」",
					{"rt2"},
				},
			},
		},
		linknext = "0069_00002",
		line = 24,
