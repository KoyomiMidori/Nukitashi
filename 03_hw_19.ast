				{
					name = {"麻沙音"},
					"“呼啊啊……调查也结束了，我去挑衅一下外国人好了……晚饭做好叫我……今晚的麻沙酱对黑毛和牛感到饥渴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「呼啊啊……調查也結束了，我去挑釁一下外國人好了……晚飯做好叫我……今晚的麻沙醬對黑毛和牛感到飢渴……」",
					{"rt2"},
				},
			},
		},
