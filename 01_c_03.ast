					name = {"淳之介", "Junnosuke"},
					"“Qué alivio que hubiera funcionado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“多亏了你，逃过了一劫——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「多虧了你，逃過了一劫——」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00175",
		linknext = "0004_00177",
		line = 2285,
	},
	["0004_00177"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00102", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0178", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A la próxima, ¿podemos volver a hacerlo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“今后如果又碰上危机的话，也可以用这招回避吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「今後如果又碰上危機的話，也可以用這招迴避吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00176",
		linknext = "0004_00178",
		line = 2299,
	},
	["0004_00178"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0179", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aún me quedan dos semanas hasta que la píldora obligatoria de la isla haga efecto, así que por ahora puedo rechazar a cualquiera que me lo pida...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“根据岛上的规定，我最少有2周是安全的，就算有人找我我也可以拒绝……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「根據島上的規定，我最少有2周是安全的，就算有人邀請我，我也可以拒絕……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00177",
		linknext = "0004_00179",
		line = 2311,
	},
	["0004_00179"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0180", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Además, mientras piensen que tú y yo estamos follando, estaremos bien. Tendremos dos semanas siempre y cuando permanezcamos juntos. ¿Qué te parece?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“然后只要让大家觉得哥哥在跟我啪啪啪的话就没问题了，所以只要我们能见面，最起码2周内是安全的吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「然後只要讓大家覺得哥哥有跟我啪啪啪就沒問題了，所以只要我們能見面，最起碼2週內是安全的吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00178",
		linknext = "0004_00180",
		line = 2323,
	},
	["0004_00180"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00116", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
