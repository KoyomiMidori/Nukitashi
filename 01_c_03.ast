					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——哈、哈啊、麻沙音，你的胸部摸上去太棒了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——哈、哈啊、麻沙音，你的胸部摸起來超棒的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00159",
		linknext = "0004_00161",
		line = 2074,
	},
	["0004_00161"] = {
		{"fg", file="asane_02l_00001", file1="asane_02l_00121", file2="asane_02l_00202", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0173", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aah. Jun-kun, por favor, no seas tan brusco. Si sigues haciendo eso, mi coño va a canturrear lo mucho que desea tu polla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊、淳君，不能那么用力、呀、你这样我的小穴会寂寞的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊、淳君，不能那麼用力、呀、你這樣我的小穴會寂寞的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00160",
		linknext = "0004_00162",
		line = 2087,
	},
	["0004_00162"] = {
		{"text"},
		text = {
