				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00407",
		linknext = "0004_00409",
		line = 5107,
	},
	["0004_00409"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Siento que me desmayo. Probablemente porque no he dormido bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"头脑很模糊，可能是因为睡眠不足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"頭腦很不清楚，可能是因為睡眠不足。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00408",
		linknext = "0004_00410",
		line = 5117,
	},
	["0004_00410"] = {
		{"se", id=0, loop=0, file="se_a003"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, time=100, alphadel=1, evmaskoff=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_043_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, por más que cierre los ojos, no puedo dormir.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，即使我试着闭着眼睛睡觉，也无法入睡。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，即使我試著閉著眼睛睡覺，也無法入睡。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00409",
		linknext = "0004_00411",
		line = 5135,
	},
	["0004_00411"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0020", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "女子生徒B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Estudiante B"},
					"“Conseguí un trabajo a tiempo parcial en el karaoke del distrito comercial.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "女学生B"},
					"“我最近开始打工了。在繁华街的卡拉OK店。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "女學生B"},
					"「我最近開始打工了。在繁華街的卡拉OK店。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00410",
		linknext = "0004_00412",
		line = 5147,
	},
	["0004_00412"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0009", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "女子生徒C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Estudiante C"},
					"“Ah, ¿es en el que te devuelven el dinero si cantas sin correrte mientras te hacen una paja?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "女学生C"},
					"“啊——就是那个一边撸管一边要是能把歌唱完就返还现金的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "女學生C"},
					"「啊——就是那個一邊手淫一邊要是能把歌唱完就返還現金的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00411",
		linknext = "0004_00413",
		line = 5159,
	},
	["0004_00413"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0021", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "女子生徒B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Estudiante B"},
					"“Sí, ese. Pero a veces me dejo llevar tanto que hago que se corran al instante.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "女学生B"},
					"“对对，但我总是会认真起来，让他们马上就射了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "女學生B"},
					"「對對，但我總是會認真起來，讓他們馬上就射了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00412",
		linknext = "0004_00414",
		line = 5171,
	},
	["0004_00414"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0010", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "女子生徒C"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Estudiante C"},
					"“Aun así, te deben llegar corredores lentos y gente que aguanta, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "女学生C"},
					"“但偶尔会有一些超级迟泄或耐久力强的人来吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "女學生C"},
					"「但偶爾會有一些超級遲洩或耐久力強的人來吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00413",
		linknext = "0004_00415",
		line = 5183,
	},
	["0004_00415"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0022", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "女子生徒D"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Estudiante D"},
					"“Bueno, con ellos no puedo evitar hacerles una mamada e igual se corren... ",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "女学生D"},
					"“那种人我都会帮他们含，所以还是会射……",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "女學生D"},
					"「那種人我都會幫他們含，所以還是會射……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00414",
		linknext = "0004_00416",
		line = 5195,
	},
	["0004_00416"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00121", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Me duele la cabeza.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……头好痛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……頭好痛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00415",
		linknext = "0004_00417",
		line = 5207,
	},
	["0004_00417"] = {
		{"se", id="0遠ざかる", loop=0, file="se_a003"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los gemidos de las chicas resuenan en mi cerebro desprovisto de sueño.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女人的娇喘在睡眠不足的大脑内回响着——",
					{"rt2"},
				},
			},
			tw = {
				{
					"女人的嬌喘在睡眠不足的大腦內迴響著——",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00416",
		linknext = "0004_00418",
		line = 5218,
	},
	["0004_00418"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por fin oigo alejarse a la pareja que folla fuera del armario.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在清扫用具柜附近做爱的两人终于走远了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在清掃用具櫃附近做愛的兩人終於走遠了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00417",
		linknext = "0004_00419",
		line = 5228,
	},
	["0004_00419"] = {
		{"se", id=0, loop=0, file="se_a087"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=18, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="bg15_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Salgo y me estiro.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我从里面出来，伸了个懒腰。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我從裡面出來，伸了個懶腰。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00418",
		linknext = "0004_00420",
		line = 5246,
	},
	["0004_00420"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh, por fin... tengo que ir al baño...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呼……厕所厕所……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呼……廁所廁所……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00419",
		linknext = "0004_00421",
		line = 5258,
	},
	["0004_00421"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He estado aguantando como por una hora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我耐心等了一个小时。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我耐心等了一個小時。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00420",
		linknext = "0004_00422",
		line = 5268,
	},
	["0004_00422"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Resulta que esos dos estaban apoyados en la puerta del armario del conserje, así que no podía salir mientras estuvieran cerca.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到他们居然搭在我在的柜子上做爱，所以没能逃脱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到他們居然按在我在的清掃用具櫃上做愛，所以沒辦法逃脫。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00421",
		linknext = "0004_00423",
		line = 5278,
	},
	["0004_00423"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"cgdel", id=2, time=100, alphadel=1, lv=5},
		{"cgdel", id=3, time=100, alphadel=1, lv=5},
		{"cgdel", id=4, time=100, alphadel=1, lv=5},
		{"cgdel", id=5, time=100, alphadel=1, lv=5},
		{"cgdel", id=6, time=100, alphadel=1, lv=5},
		{"cgdel", id=7, time=100, alphadel=1, lv=5},
		{"cgdel", id=8, time=100, alphadel=1, lv=5},
		{"cgdel", id=9, time=100, alphadel=1, lv=5},
		{"cgdel", id=10, time=100, alphadel=1, lv=5},
		{"cgdel", id=11, time=100, alphadel=1, lv=5},
		{"bg", id=1, file="blackback_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_009_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ya por fin llego al baño y hago mis cosas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"终于到了厕所，解决问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"終於到廁所解決內急了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00422",
		linknext = "0004_00424",
		line = 5313,
	},
	["0004_00424"] = {
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg15_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Parece que algunos todavía se quedan follando hasta la noche.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他们都留下来做爱呢——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他們都留下來做愛呢——」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00423",
		linknext = "0004_00425",
		line = 5330,
	},
	["0004_00425"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asomo la cabeza desde el baño y reviso mis alrededores.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我环视着周围，把头从男厕里探出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我環視著周圍，把頭從男廁裡探出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00424",
		linknext = "0004_00426",
		line = 5340,
	},
	["0004_00426"] = {
		{"se", id=0, loop=0, file="se_a003"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Como esta zona es donde están los salones especiales, no hay mucho movimiento de gente, por lo que parece que no vienen muchos estudiantes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"显然，这里是学生们不怎么接近的地方——因为周围都是特殊教室——所以人不怎么来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"顯然，這裡是學生們不怎麼接近的地方——因為周圍都是特殊教室——所以人不怎麼來。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00425",
		linknext = "0004_00427",
		line = 5351,
	},
	["0004_00427"] = {
		{"se", id=1, loop=1, file="se_d012", vol=40},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero sigo oyendo muchos gemidos en los salones normales.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，在这里也可以听得到从普通教室传来的呻吟声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，在這裡也可以聽得到從普通教室傳來的呻吟聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00426",
		linknext = "0004_00428",
		line = 5362,
	},
	["0004_00428"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que aún hay bastantes estudiantes haciendo de las suyas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"似乎还有很多学生在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"似乎還有很多學生在。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00427",
		linknext = "0004_00429",
		line = 5372,
	},
	["0004_00429"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus actos de procreación proactiva.",
					{"rt2"},
				},
			},
			cn = {
