					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Estoo... ¡Ah, cierto! Pronto estaré en la... ¿segunda mitad? ¡De la brigada del cubo intravaginal, creo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃——啊，对了对了！等一下有中出水桶接力？的后半场呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃——啊，對了對了！等一下有中出水桶接力？的後半場呢！」",
