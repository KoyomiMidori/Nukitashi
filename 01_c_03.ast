				{"vo", file="asane0195", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Espera, manito... Hay una cosa con aspecto de camión parada por allí. ¿Por qué no pedimos un aventón?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，哥哥……那辆像卡车一样的车，好像会停诶……会不会载我们……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，哥哥……那輛像卡車一樣的車，好像會停欸……會不會載我們……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00238",
		linknext = "0004_00240",
		line = 3052,
	},
	["0004_00240"] = {
