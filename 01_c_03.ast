	["0004_00607"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al menos tengo el día libre mañana, pero saber que lo voy a malgastar limpiando la casa me molesta un poco.",
