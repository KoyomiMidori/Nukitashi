					"“Está bien... Se me olvidó que cocinabas hoy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊……说起来，今天是麻沙酱做饭……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊……說起來，今天是麻沙醬做飯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00579",
		linknext = "0004_00581",
		line = 7163,
	},
	["0004_00581"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nos sentamos en la sala y empezamos a comer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我坐在客厅的椅子上，把桌上的食物放入嘴中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我坐在客廳的椅子上，把桌上的食物放入嘴中。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00580",
		linknext = "0004_00582",
		line = 7173,
	},
	["0004_00582"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí... Es justo como la comida que yo hago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊……味道和自己做的一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
