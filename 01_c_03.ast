	["0004_00218"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00118", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0190", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Entonces... ¿quizás hay otras personas que aún no han sido contaminadas por ese gusano del cerebro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那……可能会有一些人没有被那种价值观污染吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那……可能會有一些人沒有被那種價值觀污染吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00217",
		linknext = "0004_00219",
		line = 2778,
	},
	["0004_00219"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00218",
		linknext = "0004_00220",
		line = 2790,
	},
	["0004_00220"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0191", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“O sea, no todos están de acuerdo con la cultura dominante. \n¿No crees que hay otras personas con diferentes creencias en esta isla?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为不可能每个人都处于主流。所以，岛上可能会有一些有自己价值观的人在……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為不可能每個人都處於主流。所以，島上可能會有一些有自己價值觀的人在……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00219",
		linknext = "0004_00221",
		line = 2802,
	},
	["0004_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eso... es posible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那——很有可能。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那——很有可能。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00220",
		linknext = "0004_00222",
		line = 2812,
	},
	["0004_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque no creo que haya tantos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然那种人可能不多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然那種人可能不多。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00221",
		linknext = "0004_00223",
		line = 2822,
	},
	["0004_00223"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aun así... pensar eso me da un rayo de esperanza en medio de la fatalidad y la tristeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一这么想，我突然觉得黑暗中出现了一道曙光。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一這麼想，我突然覺得黑暗中出現了一道曙光。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00222",
		linknext = "0004_00224",
		line = 2832,
	},
