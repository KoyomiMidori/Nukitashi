		linkback = "0004_00207",
		linknext = "0004_00209",
		line = 2666,
	},
	["0004_00209"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0189", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Esto es como un crisol de humanidad, pero... ¿por qué a los \nisleños no les parece raro tener sexo con cualquiera...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“明明很多人来到这里，遇到很多人……为什么岛上的人不认为与任何人都能发生性关系是奇怪的事情……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「明明很多人來到這裡，遇到很多人……為什麼島上的人不認為與任何人都能發生性行為是奇怪的事情……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00208",
		linknext = "0004_00210",
		line = 2678,
	},
	["0004_00210"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Quizás por presión?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该是因为同调压力吧……或许。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該是因為同調壓力吧……或許。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00209",
		linknext = "0004_00211",
		line = 2690,
	},
	["0004_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Se podría decir que la opinión más popular se convierte en un pararrayos para el pensamiento colectivo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"占多数的意见会成为大家的共识。",
					{"rt2"},
				},
			},
			tw = {
				{
					"佔多數的意見會成為大家的共識。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00210",
		linknext = "0004_00212",
		line = 2700,
	},
	["0004_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cualquier tendencia social extraña que consiga hipernormalizarse facilita el lavado cerebral de las masas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果存在着一种理所当然的“趋势”，人类便很容易被洗脑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果存在著一種理所當然的「趨勢」，人類便很容易被洗腦。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00211",
		linknext = "0004_00213",
		line = 2710,
	},
	["0004_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si ese tipo de idea se implanta en alguien desde pequeño, puede asentarle esa creencia con bastante fuerza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果从小就被灌输的话，那么价值观就会被完全固定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果從小就被灌輸的話，那麼價值觀就會被完全固定。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00212",
		linknext = "0004_00214",
		line = 2720,
	},
	["0004_00214"] = {
		{"text"},
		text = {
