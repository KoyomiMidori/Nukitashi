				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y no es tarea fácil que alguien cambie sus creencias si está lo suficientemente comprometido con ellas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被植入的意识没有那么容易改变。",
