	["0004_00033"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mira, ya he hecho esto por ti, así que tú puedes hacer el resto, ¿no? ¿Puedes prepararte el desayuno?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我都帮你做到这样了，接下来你可以办到吧？我可以去做早饭了吗？”",
