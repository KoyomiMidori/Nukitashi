	["0004_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Le pediría que encontrara habilidades y aficiones más normales, y que no se obsesionara constantemente con tonterías sin valor, pero yo no tengo derecho a decir algo así.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我经常自己想着不要学那些没用的事情，应该多一些一般的特技和兴趣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我經常自己想著不要學那些沒用的事情，應該多一些一般的特技和興趣。",
					{"rt2"},
				},
			},
