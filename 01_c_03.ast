		linkback = "0004_00432",
		linknext = "0004_00434",
		line = 5427,
	},
	["0004_00434"] = {
		{"se", id=0, loop=0, file="se_a031"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me doy la vuelta y veo a mi profesora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回头一看，班主任站在那里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回頭一看，班導站在那裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00433",
		linknext = "0004_00435",
		line = 5438,
	},
	["0004_00435"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su atuendo es tan revelador como siempre, cuesta creer que sea profesora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她还是穿着让人不相信是老师的极度暴露胸口的衣服。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她還是穿著讓人不相信是老師的極度暴露胸口的衣服。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00434",
		linknext = "0004_00436",
		line = 5448,
	},
	["0004_00436"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0013", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“¿Qué estás haciendo por aquí? Ah, ¿te estabas follando a alguien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“你在这里干嘛？啊，难道是刚和谁啪啪啪完吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「你在這裡幹什麼？啊，難道是剛和誰啪啪啪完嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00435",
		linknext = "0004_00437",
		line = 5460,
	},
	["0004_00437"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Umm, sí... era eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃……是的，差不多是那样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃……是的，差不多是那樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00436",
		linknext = "0004_00438",
		line = 5472,
	},
	["0004_00438"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0014", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Mmm, ya veo. Tachibana-kun, ¿estás libre ahora mismo? Hay algo que quiero hablar contigo al ser tu profesora.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“嗯，这样啊——呐橘君，现在有时间吗？作为班主任，我有些话想问你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「嗯，這樣啊——我說橘君，現在有空嗎？作為班導，我有些話想問你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00437",
		linknext = "0004_00439",
		line = 5484,
	},
	["0004_00439"] = {
		{"se", id=0, loop=0, file="se_a084"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Abre la puerta de un salón cercano sin esperar mi respuesta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也没等我回复，老师就拉开了附近空教室的门。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也沒等我回答，老師就拉開了附近空教室的門。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00438",
		linknext = "0004_00440",
		line = 5495,
	},
	["0004_00440"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me hace señas para que entre, y lo hago.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用眼神示意要我进去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用眼神示意要我進去。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00439",
