				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero... considerando que a mi hermana no le gustan los chicos, tal vez haya sido desconsiderado de mi parte.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是……对性倾向不是男生的妹妹而言，确实做了不好的事情。",
