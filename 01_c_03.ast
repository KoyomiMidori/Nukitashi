					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ahh, discúlpame por haberte usado así. Esos tipos me sacan de quicio. Solo necesitaba que me ayudaras a alejarme de ellos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊……抱歉利用了你。因为他们有点烦，所以我就躲到了这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊……抱歉利用了你。因為他們有點煩，所以我就躲到了這裡。」",
					{"rt2"},
				},
			},
		},
