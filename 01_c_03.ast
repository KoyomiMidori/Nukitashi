		linkback = "0004_00372",
		linknext = "0004_00374",
		line = 4647,
	},
	["0004_00374"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00111", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0027", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“O sea, el sexo pervertido en la escuela no es malo, pero no es suficiente para mí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“学校的变态做爱也不是不好啦……只是到了我这个等级，会有点不满足的感觉？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「學校的變態做愛也不是不好啦……只是到了我這個等級，會有點不滿足的感覺？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00373",
		linknext = "0004_00375",
		line = 4661,
	},
	["0004_00375"] = {
		{"text"},
		delay = {
			[6000] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00119", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, delay2=6000, time=600, mode=3, x=0, y=0},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0028", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Supongo que es como un juego de niños para mí, así que decidí saltarme la clase para tener algo más serio... Espera, ¿qué pasa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“该说像过家家的做爱吗？所以我才想翘课来点激烈的做爱……你怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「該說像扮家家酒的做愛嗎？所以我才想翹課來點激烈的做愛……你怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00374",
		linknext = "0004_00376",
		line = 4675,
	},
	["0004_00376"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
