	["0004_00184"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Más bien me gustaría saber por qué a TI se te da tan bien soltar esas obscenidades!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反而麻沙酱，你怎么能那么容易就说出色情台词……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該說麻沙醬，你怎麼能那麼容易就說出色情臺詞……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00183",
		linknext = "0004_00185",
		line = 2389,
	},
	["0004_00185"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0183", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Vamos, es lo normal en las películas porno y los eroges. \nAcéptalo, tu vocabulario sexual apesta, manito.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“AV和色情游戏不就都这种感觉吗……反而哥哥的色情词汇量也太少了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「AV和色情遊戲不都那種感覺嗎……反倒是哥哥的色情詞彙量也太少了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00184",
		linknext = "0004_00186",
		line = 2403,
	},
	["0004_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que tiene razón. No soy tan versado como ella en el lenguaje obsceno...",
					{"rt2"},
				},
			},
			cn = {
				{
					"的确，在词汇量上我或许输给了妹妹……",
					{"rt2"},
				},
			},
			tw = {
				{
					"的確，在詞彙量上我或許輸給了妹妹……",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00185",
		linknext = "0004_00187",
		line = 2413,
	},
	["0004_00187"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pero ¿funcionaría si la gente descubriera que somos hermanos? ¿Aquí está bien que lo hagan parientes cercanos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，如果麻沙酱是我妹妹的事情暴露了，就不能用了吧……？可以乱伦吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，如果麻沙醬是我妹妹的事情暴露了，就不能用了吧……？可以亂倫嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00186",
		linknext = "0004_00188",
		line = 2425,
	},
	["0004_00188"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0184", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Creo que la ley no lo prohíbe. Ya he oído el rumor de que lo hacemos en casa...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好像没有被禁止，而且听说有人在家里做……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好像沒有被禁止，而且聽說有人在家裡做……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00187",
		linknext = "0004_00189",
		line = 2439,
	},
	["0004_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ya veo... Por cierto, ¿esa guardia no dijo que estaba feliz de ver a la familia experimentando la alegría del sexo pervertido o algo así?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊……话说之前，刚刚那个人说过‘一家人啪啪啪真让人感动’什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊……話說之前，剛剛那個人說過『真佩服家人能一起做愛』什麼的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00188",
		linknext = "0004_00190",
		line = 2451,
	},
	["0004_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aunque si solo es entre hermanos, ¿no crees que comenzarán a sospechar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，要是一直只跟兄妹的话会被怀疑吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，要是一直只跟兄妹的話會被懷疑吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00189",
		linknext = "0004_00191",
		line = 2462,
	},
	["0004_00191"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0185", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Lo dudo. Dejando a un lado la escuela, la gente de por aquí probablemente no se dará cuenta de que somos hermanos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不会吧……？除了学校，附近似乎没有人记得我们是兄妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不會吧……？除了學校，附近似乎沒有人記得我們是兄妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00190",
		linknext = "0004_00192",
		line = 2476,
	},
	["0004_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Es curioso que lo menciones, acabo de recordar que no nos hemos encontrado con ninguna cara conocida por aquí...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这么一说，好像真的没见到熟悉的人啊——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你這麼一說，好像真的沒見到熟面孔啊——」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00191",
		linknext = "0004_00193",
		line = 2487,
	},
	["0004_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La casa en la que vivimos era de nuestros abuelos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在住的房子是祖父母的老房子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在住的房子是祖父母的老房子。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00192",
		linknext = "0004_00194",
		line = 2497,
	},
	["0004_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuando la isla se estaba urbanizando y el terreno se estaba dividiendo, nos mudamos a esta casa aislada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时岛屿开发，因为要区域整修，我们才搬到现在的房子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時島嶼開發，因為要區域重劃，我們才搬到現在的房子。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00193",
		linknext = "0004_00195",
		line = 2507,
	},
	["0004_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Básicamente vivimos en el mismo sitio en el que solíamos vivir, pero...",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以住的地方和当时一样，但……",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以住的地方和當時一樣，但……",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00194",
		linknext = "0004_00196",
		line = 2517,
	},
	["0004_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nadie aquí parece recordarnos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们附近的居民似乎都不记得我们了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們附近的居民似乎都不記得我們了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00195",
		linknext = "0004_00197",
		line = 2527,
	},
	["0004_00197"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Has visto alguna cara en la escuela que se te haga conocida?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有见到过以前在同一个学校的人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有見到過以前在同一間學校的人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00196",
		linknext = "0004_00198",
		line = 2539,
	},
	["0004_00198"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00104", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0186", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Vi a unos cuantos, pero... no parecían reconocerme.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“有见过一两个……但对方似乎没发觉我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「有見過一兩個……但對方似乎沒認出我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00197",
		linknext = "0004_00199",
		line = 2553,
	},
	["0004_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tampoco es que haya pasado tanto tiempo... ¿Por qué será?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然我们也不是待了很久……但为什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然我們也不是待了很久……但為什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00198",
		linknext = "0004_00200",
		line = 2565,
	},
	["0004_00200"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0187", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“La gente de aquí probablemente ha cambiado mucho. Con todo el turismo, definitivamente están haciendo muchas más conexiones con las personas. Supongo que simplemente no nos recuerdan..”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“也许是因为人口正在快速交替。有很多游客，也和很多人见了面，所以不记得了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「也許是因為人口正在快速交替。有很多遊客，也和很多人見了面，所以不記得了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00199",
		linknext = "0004_00201",
		line = 2579,
	},
	["0004_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es posible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这的确有可能。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這的確有可能。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00200",
		linknext = "0004_00202",
		line = 2589,
	},
	["0004_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En esta isla puedes conocer a muchas personas distintas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这个岛上，我们总是会见到人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這個島上，我們總是會碰到人。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00201",
		linknext = "0004_00203",
		line = 2599,
	},
	["0004_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los turistas vienen aquí y se acuestan con personas que apenas conocen y que viven en la isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上不认识人，前来做爱的游客等等——",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上不認識人，前來做愛的遊客等等——",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00202",
		linknext = "0004_00204",
		line = 2609,
	},
	["0004_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si se me permite el chiste, el sexo pervertido hace que la gente se venga junta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和任何人都做爱。",
					{"rt2"},
				},
