		linkback = "0004_00610",
		linknext = "0004_00612",
		line = 7543,
	},
	["0004_00612"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El servicio de limpieza parece consistir en que alguien acuda a tu casa un día previamente programado y realice las tareas domésticas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"家务代理服务好像是在特定日期来访并帮忙做家务的服务。",
					{"rt2"},
				},
			},
			tw = {
				{
					"家事代理服務好像是在特定日期來訪並幫忙做家事的服務。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00611",
		linknext = "0004_00613",
		line = 7553,
	},
	["0004_00613"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pueden limpiar, lavar y cocinar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"似乎能够处理清洁、洗涤和烹饪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"似乎能夠處理清潔、洗滌和烹飪。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00612",
		linknext = "0004_00614",
		line = 7563,
	},
	["0004_00614"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00102", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0214", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Incluso pueden prepararnos la comida... Parece más barato que comer afuera, ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“而且，还能帮我们做一些料理冰起来……从这个价格来看的话，比在外面吃要好吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「而且還能幫我們做一些料理冰起來……從這個價格來看的話，比在外面吃要好吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00613",
		linknext = "0004_00615",
		line = 7577,
	},
	["0004_00615"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tienes razón... Es más barato de lo que esperaba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的……比我想象的要便宜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的欸……比我想的還要便宜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00614",
		linknext = "0004_00616",
		line = 7589,
	},
	["0004_00616"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0215", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Qué te parece? Ah, pero no me gusta que otras personas \nestén en mi habitación, así que probablemente deberíamos dejarles hacer la zona principal, el baño y el inodoro...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么样？啊，麻沙酱不希望别人进入自己的房间，所以打扫只要客厅和浴室和厕所……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼樣？啊，麻沙醬不希望別人進入自己的房間，所以打掃只要客廳和浴室和廁所……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00615",
		linknext = "0004_00617",
		line = 7603,
	},
	["0004_00617"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A mí tampoco me gusta la idea de que un extraño se meta en mi habitación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也是不太想让别人进入我的房间的类型。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也是不太想讓別人進入我的房間的類型。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00616",
		linknext = "0004_00618",
		line = 7613,
	},
	["0004_00618"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero si pudieran ocuparse de todas las zonas comunes de la casa, nos vendría muy bien.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但如果能帮我们清扫共用空间的话，那是最好的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但如果能幫我們清掃共用空間的話，那是最好的。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00617",
		linknext = "0004_00619",
		line = 7623,
	},
	["0004_00619"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Además... Me encantaría poder relajarme y descansar por una vez de todas esas molestas tareas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且现在……我只想摆脱麻烦好好休息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且現在……我只想擺脫麻煩好好休息。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00618",
		linknext = "0004_00620",
		line = 7633,
	},
	["0004_00620"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, me agrada la idea... ¿Podrías llamarlos después?”",
					{"rt2"},
				},
			},
			cn = {
