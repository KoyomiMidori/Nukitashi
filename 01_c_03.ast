	},
	["0004_00487"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0027", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Pues no te preocupes. Sé que puedes hacerlo... Si sigues preocupado, me encantaría hacerte una pequeña prueba sorpresa ",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“但是没关系，橘君一定办得到——如果你觉得不安，老师可以帮你测试看看……",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「但是沒關係，橘君一定辦得到——如果你覺得不安，老師可以幫你測試看看……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00486",
		linknext = "0004_00488",
		line = 6034,
	},
	["0004_00488"] = {
