					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Supongo que sí, pero... no puedo hacer eso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也许你是对的……但我不行……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也許你是對的……但我不行……」",
					{"rt2"},
				},
			},
