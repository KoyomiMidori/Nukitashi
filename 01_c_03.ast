		{"ex", time=2000, func="wait"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-200, y=0, time=700},
		{"bgm", file="bgm11", vol=100},
		{"se", id=0, loop=0, file="se_a021"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahora mismo, hay tres cosas de las que debemos cuidarnos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……基本上我们需要注意三件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……基本上我們需要注意三件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00116",
		linknext = "0004_00118",
		line = 1541,
	},
	["0004_00118"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0167", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Primero... la gente de aquí, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“首先是……镇上的人对吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「首先是……鎮上的人對吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00117",
		linknext = "0004_00119",
		line = 1553,
	},
	["0004_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Exacto. Todos están infectados con el gusano del cerebro que les hace creer que hacer actos proactivos de procreación es algo bueno y justo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，是那些积极做性产活动的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，是那些積極做性產活動的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00118",
		linknext = "0004_00120",
		line = 1564,
	},
	["0004_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Se follarán a todo lo que se mueva, y no les avergüenza admitirlo. Son una gran amenaza para nosotros.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“每个人都有高超技术，喜欢变态做爱，对我们来说风险很高。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「每個人都有高超技術，喜歡變態做愛，對我們來說風險很高。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00119",
		linknext = "0004_00121",
		line = 1575,
	},
	["0004_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Lo segundo... serían los turistas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“接下来是……游览岛屿的游客。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「接下來是……遊覽島嶼的觀光客。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00120",
		linknext = "0004_00122",
		line = 1586,
	},
	["0004_00122"] = {
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0168", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí, solo vinieron a la isla a follar...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“期待在这个岛上发生性行为的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「期待在這個島上發生性行為的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00121",
		linknext = "0004_00123",
		line = 1601,
	},
	["0004_00123"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seguramente también están bastante excitados. Además, no están dispersos por todas partes durante el día como los de \naquí, por lo que son peligrosos en otro sentido.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他们似乎有很强的性欲。这很危险，因为他们不像镇上的人会在日常生活中发泄。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他們似乎有很強的性慾。這很危險，因為他們不像鎮上的人會在日常生活中發洩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00122",
		linknext = "0004_00124",
		line = 1613,
	},
	["0004_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aun así, no son tan listos en la calle como los lugareños, así que debería ser más fácil huir de ellos si los confundimos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但他们没有相关的知识，所以逃跑或者欺骗都不成问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但他們沒有相關的知識，所以逃跑或者欺騙都不成問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00123",
		linknext = "0004_00125",
		line = 1624,
	},
	["0004_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y por último, pero no por ello menos importante, la mayor amenaza para nosotros ahora mismo es—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最后。对我们来说，最危险的存在是——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最後。對我們來說，最危險的存在是——」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00124",
		linknext = "0004_00126",
		line = 1636,
	},
	["0004_00126"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00109", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan se detiene.",
					{"rt2"},
				},
			},
			cn = {
				{
					"此时，麻沙音突然停下了脚步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"此時，麻沙音突然停下了腳步。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00125",
		linknext = "0004_00127",
		line = 1650,
	},
	["0004_00127"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=100},
		{"bg", id=1, file="bg09_1l_00000", x=0, y=0, path=":bg/", sync=0, ax=1280, ay=730, bx=-480, by=-280},
		{"extrans", sync=0, time=150},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Agarra mi uniforme y se oculta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她拉着我的衣服，迅速躲到了阴影处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她拉著我的衣服，迅速躲到了陰影處。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00126",
		linknext = "0004_00128",
		line = 1667,
	},
	["0004_00128"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00104", path=":fg/asane_01f/", id=30, ch="麻沙音", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0169", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Manito! ¡Es un guardia de la OSS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥……！那边有一个SHO的警卫……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥……！那邊有一個SHO的警衛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00127",
		linknext = "0004_00129",
		line = 1680,
	},
	["0004_00129"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡¿Qué?! ¿Cambian de estación según el día...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么……！难道他们的位置每天都会改变吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼……！難道他們的位置每天都會改變嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00128",
		linknext = "0004_00130",
		line = 1692,
	},
	["0004_00130"] = {
		{"fg", file="asane_01ll_00001", file1="asane_01ll_00101", path=":fg/asane_01ll/", id=3, lv=5, head="asane_01ll", ch="麻沙音", mw="mw", sync=0, time=600, mode=3, x=0, y=600},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-200, time=700},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ambos asomamos la cabeza por detrás del poste eléctrico.",
					{"rt2"},
				},
			},
			cn = {
				{
					"兄妹两人从电线杆后面一上一下地探出头脑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"兄妹兩人從電線桿後面一上一下地探出頭腦。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00129",
		linknext = "0004_00131",
		line = 1704,
	},
	["0004_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, como decía, la amenaza más grande para nosotros son las guardias de la OSS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——最危险的存在是SHO警卫。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——最危險的存在是SHO警衛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00130",
		linknext = "0004_00132",
		line = 1715,
	},
	["0004_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La OSS no tiene sus funciones establecidas por un comité como tal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"名为SHO的一般社团法人似乎有各种委员会负责每项任务。",
					{"rt2"},
				},
			},
			tw = {
				{
					"名為SHO的一般社團法人似乎有各種委員會負責每項任務。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00131",
		linknext = "0004_00133",
		line = 1725,
	},
	["0004_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sus guardias están apostados por toda la ciudad para mantener el 'orden público'.",
					{"rt2"},
				},
			},
			cn = {
				{
					"站在镇上的SHO警卫属于“治安管理委员会”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"站在鎮上的SHO警衛屬於「治安管理委員會」。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00132",
		linknext = "0004_00134",
		line = 1735,
	},
	["0004_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al parecer, esta 'división de orden público' está dividida en distintas unidades.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其中似乎还分成“治安维持部”等多个部门",
					{"rt2"},
				},
			},
			tw = {
				{
					"其中似乎還分成「治安維持部」等多個部門。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00133",
		linknext = "0004_00135",
		line = 1745,
	},
	["0004_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esas señoras se conocen la isla como la palma de su mano. No será fácil evitarlas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她们熟悉这个岛屿，很难轻易逃离她们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她們熟悉這個島嶼，很難輕易逃離她們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00134",
		linknext = "0004_00136",
		line = 1756,
	},
	["0004_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y además, están entrenadas para el combate con el fin de mantener el orden público...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且还具有维持治安的战斗能力……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且還具有維持治安的戰鬥能力……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00135",
