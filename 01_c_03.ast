	["0004_00584"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Uno pensaría que al menos sería capaz de asimilar mis sentimientos con algo de comida decente. Pues no.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然说吃饭似乎具有治愈疲劳的效果，但这顿饭看起来是发挥不了作用了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然說吃飯似乎具有治愈疲勞的效果，但這頓飯看起來是發揮不了作用了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00583",
		linknext = "0004_00585",
		line = 7208,
	},
	["0004_00585"] = {
		{"text"},
		text = {
