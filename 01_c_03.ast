	["0004_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voz se interrumpe y desaparece entre los sonidos del océano.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱用几乎要消失在海浪声中的声音小声嘀咕道。",
					{"rt2"},
				},
			},
			tw = {
