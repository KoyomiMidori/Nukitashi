					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Debes ser sensible. Tienes el coño empapado. Puedo oír cómo suena.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么这么敏感啊你，都这么湿了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼這麼敏感啊你，都這麼濕了。」",
