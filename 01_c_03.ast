	},
	["0004_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Estamos muy cortos de tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我发现时，已经没多少时间了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我注意到時，已經沒多少時間了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00226",
		linknext = "0004_00228",
		line = 2913,
	},
	["0004_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Bueno, perdí muchísimo tiempo tratando de despertar a mi \nestúpida hermana esta mañana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟我今天花了很多时间来叫醒这个笨蛋妹妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟我今天花了很多時間來叫醒這個笨蛋妹妹。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00227",
		linknext = "0004_00229",
		line = 2923,
	},
	["0004_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y cada vez que nos veía un guardia de la OSS, teníamos que volver a ejecutar el “Plan de Evasión de Tortolitos Calenturientos”.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且今天每看到SHO警卫就会采取“脱单狗你侬我侬回避作战”逃脱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且今天每看到SHO警衛就會採取「脫單狗你儂我儂迴避作戰」逃脫。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00228",
		linknext = "0004_00230",
		line = 2933,
	},
	["0004_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Así que hemos vuelto al distrito de negocios.",
					{"rt2"},
				},
			},
			cn = {
				{
					"多亏这样，我们又来到了繁华街。",
					{"rt2"},
				},
			},
			tw = {
				{
					"多虧這樣，我們又來到了繁華街。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00229",
		linknext = "0004_00231",
		line = 2943,
	},
	["0004_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aún es temprano, por lo que no hay turistas y las tiendas no \nestán abiertas, así que al menos no hay peligro...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说早上没有观光客，店铺也没开，所以没什么危险——",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說早上沒有觀光客，店鋪也沒開，所以沒什麼危險——",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00230",
		linknext = "0004_00232",
		line = 2953,
	},
	["0004_00232"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Vamos a llegar tarde!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样下去会迟到哦……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣下去會遲到哦……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00231",
		linknext = "0004_00233",
		line = 2965,
	},
	["0004_00233"] = {
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=4, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0193", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Solo... dame un descanso, manito. ¿A quién le importa una mierda haber llegado tarde una vez? ¡No te vi quejándote de que tu sentido de la orientación te hacía llegar tarde a tu antigua escuela a cada rato!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“放……放弃吧……哥哥……迟到就迟到……反正我们在上一所学校也因为是路痴而迟到了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「放……放棄吧……哥哥……遲到就遲到……反正我們在上一所學校也因為是路痴而遲到了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00232",
		linknext = "0004_00234",
		line = 2978,
	},
	["0004_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Aquí no puedo hacer eso! ¡La SS me tiene en la mira!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不行，我们已经被SS盯上了——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不行，我們已經被SS盯上了——」",
					{"rt2"},
				},
			},
