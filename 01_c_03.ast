			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nunca pensé que haría eso con mi hermano... Si lo hubiera hecho con otro, me mataba.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没想到居然会和哥哥在这种地方做……如果不是哥哥就惨了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒想到居然會和哥哥在這種地方做……如果不是哥哥就慘了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00169",
