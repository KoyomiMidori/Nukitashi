	["0004_00431"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En todo caso, todavía tengo que quedarme por aquí hasta que mi hermana termine con sus cosas...",
					{"rt2"},
