	["0004_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Si encuentra algún crimen en que no tengamos sexo pervertido a primera hora de la mañana, probablemente ofrecerá sus servicios.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果被发现没有从早上开始进行性行为，她可能会自己来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果被發現沒有從早上開始進行性行為，她可能會自己來。",
