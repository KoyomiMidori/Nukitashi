					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「讓老師用這個大到快要沒辦法當老師的巨乳，像個媽媽一樣好好疼愛你的肉棒吧",
					{"gaiji", text="①"},
