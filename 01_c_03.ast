	},
	["0004_00608"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="asane_02m_00003", file1="asane_02m_00112", file4="asane_02m_00401", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0212", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¡Ah cierto! ¡Manito, manito! ¿Por qué no llamamos a un servicio de limpieza para que venga mañana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，说到那个，哥哥哥哥……！从明天开始叫家务代理服务怎么样……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，說到那個，哥哥哥哥……！從明天開始叫家事代理服務怎麼樣……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00607",
		linknext = "0004_00609",
		line = 7507,
	},
	["0004_00609"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00125", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Podrías bajar esa almohada...? Servicio de limpieza, ¿eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你也该把那个枕头放下了……家务代理服务？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你也該把那個枕頭放下了……家事代理服務？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00608",
		linknext = "0004_00610",
		line = 7519,
	},
	["0004_00610"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
