	},
	["0004_00621"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00102", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0216", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Vale. Los llamaré ahorita.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
