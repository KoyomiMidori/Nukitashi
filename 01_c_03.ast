		line = 5505,
	},
	["0004_00441"] = {
		{"se", id=0, loop=0, file="se_a085"},
		{"fg", mode=-1, id=30, ch="淳之介", lv=5},
		{"bg", id=1, file="bg14_2_00000", x=0, y=0, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0015", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“¿Cómo la estás pasando en la isla? ¿Ya te acostumbraste?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“……那么，这个岛上的生活怎么样？习惯了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「……那麼，這個島上的生活怎麼樣？習慣了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00440",
		linknext = "0004_00442",
		line = 5524,
	},
	["0004_00442"] = {
		{"fg", file="jun_01f_00001", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí... bueno, más o menos. Igual solía vivir aquí.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯——很习惯了。毕竟我以前有住过这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯——很習慣了。畢竟我以前有住過這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00441",
		linknext = "0004_00443",
		line = 5536,
	},
	["0004_00443"] = {
		{"bgm", file="bgm03", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Pfft... ¡Vamos, no estés tan nervioso! No vine a darte un \nsermón. Solo es una pequeña charla normal, ¿vale?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“噗……不要那么有戒心！我不是要对你说教啦。放轻松跟我聊天就可以了哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「噗……不要那麼有戒心！我不是要對你說教啦。放輕鬆跟我聊天就可以了哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00442",
		linknext = "0004_00444",
		line = 5549,
	},
	["0004_00444"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Le divierte mi desconfianza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着僵硬的我，老师开心地笑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著僵硬的我，老師開心地笑了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00443",
		linknext = "0004_00445",
		line = 5559,
	},
	["0004_00445"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su sonrisa me relaja un poco.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看到老师的笑容，我感到自己的身体有些放松了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看到老師的笑容，我感到自己的身體有些放鬆了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00444",
		linknext = "0004_00446",
		line = 5569,
	},
	["0004_00446"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0017", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“... Pero me imagino que te ha costado acostumbrarte a tu nueva vida aquí. Tus padres fallecieron hace poco...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“不过新生活很辛苦吧？毕竟……突然一下子失去了父亲和母亲……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「不過新生活很辛苦吧？畢竟……突然一下子失去了父親和母親……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00445",
		linknext = "0004_00447",
		line = 5581,
	},
	["0004_00447"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“... Sí, así es.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——嗯，是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——嗯，是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00446",
		linknext = "0004_00448",
		line = 5593,
	},
	["0004_00448"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nuestros padres murieron hace dos meses.",
					{"rt2"},
				},
			},
			cn = {
				{
					"两个月前，我和麻沙酱失去了父母。",
					{"rt2"},
				},
			},
			tw = {
				{
					"兩個月前，我和麻沙醬失去了父母。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00447",
		linknext = "0004_00449",
		line = 5603,
	},
	["0004_00449"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fue un accidente de tráfico. No hubo nada sospechoso o \nextraño en cómo sucedió.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是一起交通事故。并没有被卷入什么阴谋或者事件之中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是一起交通事故。並沒有被捲入什麼陰謀或者事件之中。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00448",
		linknext = "0004_00450",
		line = 5613,
	},
	["0004_00450"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Básicamente, chocamos contra un camión. Los dos iban en los asientos delanteros y murieron ahí, pero mi hermana y yo sobrevivimos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"卡车撞了过来，坐在驾驶座和副驾驶座上的父母死了，只有我和妹妹得救了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"卡車撞了過來，坐在駕駛座和副駕駛座上的父母死了，只有我和妹妹得救了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00449",
		linknext = "0004_00451",
		line = 5623,
	},
	["0004_00451"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No recuerdo bien qué pasó después.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后的事情，我不怎么记得了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那之後的事情，我不怎麼記得了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00450",
		linknext = "0004_00452",
		line = 5633,
	},
	["0004_00452"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero sé que no teníamos otros parientes ni nadie cercano en quien confiar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们没有亲戚，也没有可以依靠的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們沒有親戚，也沒有可以依靠的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00451",
		linknext = "0004_00453",
		line = 5643,
	},
	["0004_00453"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sin embargo, éramos demasiado grandes para vivir en un orfanato.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我们的年龄太大，无法进入孤儿设施。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我們的年齡太大，無法進入收容機構。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00452",
		linknext = "0004_00454",
		line = 5653,
	},
	["0004_00454"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0018", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Tus abuelos vivían aquí, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“祖父的房子在这里对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「祖父的房子在這裡對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00453",
		linknext = "0004_00455",
		line = 5665,
	},
	["0004_00455"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sí, por parte de mi padre. Vivían en la isla antes del gran proyecto de reurbanización. Así que nos dejaron su casa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的，父亲的父母在发展前的青蓝岛住过……所以家还在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的，父親的父母在發展前的青藍島住過……所以家還在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00454",
		linknext = "0004_00456",
		line = 5677,
	},
	["0004_00456"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No tenemos que preocuparnos de pagar el alquiler viviendo en esa casa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果生活在这里，就可以不用担心租金之类的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果生活在這裡，就可以不用擔心房租之類的。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00455",
		linknext = "0004_00457",
		line = 5687,
	},
	["0004_00457"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sinceramente, nuestros padres no nos dejaron suficiente dinero para vivir como estudiantes y pagar el alquiler.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老实说，父母留下的遗产并不够我们一边支付房租还一边上学。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老實說，父母留下的遺產並不夠我們一邊支付房租還一邊上學。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00456",
		linknext = "0004_00458",
		line = 5697,
	},
	["0004_00458"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No nos quedó de otra que venir aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以——我们不得不来这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以——我們不得不來這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00457",
		linknext = "0004_00459",
		line = 5707,
	},
	["0004_00459"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0019", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Ya veo... No me imagino lo terrible que debe ser para alguien de tu edad estar en esa situación.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“嗯……这个年龄就被限制了生活方式，是件很艰辛的事情呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「嗯……這個年齡就被限制了生活方式，是件很艱辛的事呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00458",
		linknext = "0004_00460",
		line = 5719,
	},
	["0004_00460"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Su voz está cargada de empatía.",
					{"rt2"},
				},
			},
			cn = {
				{
					"班主任很友善地与我交谈着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"班導很友善地與我交談著。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00459",
		linknext = "0004_00461",
		line = 5729,
	},
	["0004_00461"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0020", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Pero si te preocupa el dinero... ¿por qué no solicitaste una beca de la SS, Tachibana-kun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“但如果是钱的问题……橘君，你为什么不申请SS奖学金呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「但如果是錢的問題……橘君，你為什麼不申請SS獎學金呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00460",
		linknext = "0004_00462",
		line = 5741,
	},
	["0004_00462"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0021", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Ya eres residente en la Isla Seiran, ¿por qué no aceptas la beca de la OSS? Solo puedes conseguirla aquí, y no hay intereses en el reembolso.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“既然住在青蓝岛，去申请个SHO1级奖学金怎么样？不需要还利息哦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「既然住在青藍島，去申請個SHO第一類獎學金怎麼樣？不需要還利息哦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00461",
		linknext = "0004_00463",
		line = 5753,
	},
	["0004_00463"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0022", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Además, con tus notas, no debería serte difícil conseguir la beca de la OSS. Ni siquiera necesitas pagarla. Incluso Hanamaru se las arregló para conseguirla.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“如果是橘君的成绩，也可以申请到SHO特别奖学金吧。这个连返还义务都没有，花丸同学也有申请呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「如果是橘君的成績，也可以申請到SHO特別獎學金吧。這個連返還義務都沒有，花丸同學也有申請呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00462",
		linknext = "0004_00464",
		line = 5765,
	},
	["0004_00464"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Esto, pues...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃，那是因为——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃，那是因為——」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00463",
		linknext = "0004_00465",
		line = 5777,
	},
	["0004_00465"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unirme a la SS me impondría ciertas 'obligaciones'.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果进入SS，就会产生义务。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果進入SS，就會產生義務。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00464",
		linknext = "0004_00466",
		line = 5787,
	},
	["0004_00466"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es decir, ayudar a la OSS y actuar en su nombre.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是SHO的工作辅助和执行——",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是SHO的工作輔助和執行——",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00465",
		linknext = "0004_00467",
		line = 5797,
	},
	["0004_00467"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En pocas palabras, me pondría en una posición en la que estaría recomendando sexo pervertido.",
					{"rt2"},
				},
			},
			cn = {
				{
					"换句话说，就是要成为站在鼓励性行为的立场上的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"換句話說，就是要成為站在鼓勵性行為的立場上的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00466",
		linknext = "0004_00468",
		line = 5807,
	},
	["0004_00468"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Definitivamente no puedo hacer eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就只有这点——我绝对办不到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就只有這點——我絕對辦不到。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00467",
		linknext = "0004_00469",
		line = 5817,
	},
	["0004_00469"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0023", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Vale, ya veo... Si te unieras a la SS, tendrías que hacer un trabajo que no sientes que podrías hacer. Debe ser aterrador... Sí, lo entiendo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“嗯，也对……如果进入了SS，就要去完成不知道能不能完成的任务。很可怕对吧……嗯，我可以理解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「嗯，也對……如果進入了SS，就要去完成不知道能不能完成的任務。很可怕對吧……嗯，我可以理解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00468",
		linknext = "0004_00470",
		line = 5829,
	},
	["0004_00470"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asiente con la cabeza.",
					{"rt2"},
				},
			},
			cn = {
				{
					"班主任认真地点点头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"班導認真地點點頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00469",
		linknext = "0004_00471",
		line = 5839,
	},
	["0004_00471"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Malinterpretó mis razones, pero al menos lo entiende.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说老师没有理解到我真正的意思——但她还是理解我的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說老師沒有理解到我真正的意思——但她還是理解我的。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00470",
		linknext = "0004_00472",
		line = 5849,
	},
	["0004_00472"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Al fin y al cabo, es una profesora.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不愧是老师。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不愧是老師。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00471",
		linknext = "0004_00473",
		line = 5859,
	},
	["0004_00473"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso en esta isla depravada de perversión, los adultos son adultos, y los profesores tienen el mismo papel que en cualquier otra parte. Parece que tenía una noción equivocada por su vestimenta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是在变态岛上，大人就是大人，老师就是老师。看来我是因为她的服装而有了先入为主的观念。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是在變態島上，大人就是大人，老師就是老師。看來我是因為她的服裝而有了先入為主的觀念。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00472",
		linknext = "0004_00474",
		line = 5869,
	},
	["0004_00474"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me siento mejor luego de hablar con ella. Es fácil desahogarme con ella.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟她聊天果然很轻松，述说烦恼也很容易——",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟她聊天果然很輕鬆，述說煩惱也很容易——",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00473",
		linknext = "0004_00475",
		line = 5879,
	},
	["0004_00475"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0024", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“En todo caso, Tachibana-kun... ¿no crees que podrías adquirir un poco más de confianza?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“但是橘君……如果说你有了自信呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「但是橘君……如果說你有了自信呢？」",
