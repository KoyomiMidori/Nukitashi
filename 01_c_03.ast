	["0004_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El “Plan de Evasión de Tortolitos Calenturientos”.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我称为“脱单狗你侬我侬回避作战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					"我稱為「脫單狗你儂我儂迴避作戰。」",
					{"rt2"},
				},
