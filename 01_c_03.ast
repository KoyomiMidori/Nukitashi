		line = 2999,
	},
	["0004_00236"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Ahora qué...? ¡Ah, espera, es una parada de autobuses! ¡¿Nos metemos?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“该怎么办——有一个公交车站！有公交车！要坐吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「該怎麼辦——啊，有個巴士站！有巴士！要坐嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00235",
		linknext = "0004_00237",
		line = 3011,
	},
	["0004_00237"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00106", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
