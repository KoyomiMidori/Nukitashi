			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Mira, alguien dejó este folleto hoy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你看，今天收到了这样的传单……”",
					{"rt2"},
