	["0004_00432"] = {
		{"bgm", stop=1},
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0012", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“¿Oh, Tachibana-kun?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“……哎呀，橘君？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「……哎呀，橘君？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00431",
		linknext = "0004_00433",
		line = 5417,
	},
	["0004_00433"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Escucho una voz a mis espaldas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"背后有人叫我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"背後有人叫我。",
					{"rt2"},
				},
