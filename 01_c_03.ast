					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊，沙也加老師……呃，我現在在找一個可以開始最終中出水桶接力賽的地方，你們在忙嗎？」",
					{"rt2"},
