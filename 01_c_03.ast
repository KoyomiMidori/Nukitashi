	["0004_00480"] = {
		{"bgm", file="bgm19", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0025", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Tal vez te asusta guiar a otros en los caminos del sexo a través de la SS. Debes estar preocupado por no ser hábil en el sexo pervertido, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“你是害怕成为SS之后要站在指导别人做爱的立场对吧……？不知道自己是不是能好好贯彻变态做爱很不安对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「你是害怕成為SS之後要站在指導別人做愛的立場對吧……？不知道自己是不是能好好貫徹變態做愛所以很不安對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00479",
		linknext = "0004_00481",
		line = 5948,
	},
	["0004_00481"] = {
		{"se", id=0, loop=0, file="se_a144"},
