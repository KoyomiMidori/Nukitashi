		line = 2619,
	},
	["0004_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso los residentes locales solo permanecen en una zona durante un corto periodo de tiempo debido al desarrollo de la zona, por lo que hay mucha rotación.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是居民，有些人也是为了开发而只留一段时间，所以交替很频繁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是居民，有些人也是為了開發而只留一段時間，所以交替很頻繁。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00204",
		linknext = "0004_00206",
		line = 2629,
	},
	["0004_00206"] = {
