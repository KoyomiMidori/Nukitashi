		line = 608,
	},
	["0004_00044"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0151", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bueno, primero codifiqué una aplicación cliente que descargaba automáticamente viddeos porno a partir de una palabra clave determinada, luego les cambiaba el nombre y les aplicaba etiquetas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我先做了个客户端程式来自动下载有特定辞的色情动画进行重新命名并加上标籤。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我先做了個客戶端程式來自動下載有特定關鍵字的色情動畫進行重新命名並加上標籤。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00043",
		linknext = "0004_00045",
		line = 622,
	},
	["0004_00045"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00103", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
