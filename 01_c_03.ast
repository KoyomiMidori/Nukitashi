	["0004_00137"] = {
		{"bg", id=1, file="bg09_1l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="asane_01ll_00001", file1="asane_01ll_00104", path=":fg/asane_01ll/", id=3, lv=5, head="asane_01ll", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0170", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí, esa tiene una ametralladora atada al cuello.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……真的，脖子上挂着机关枪呢，那个人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……真的，脖子上掛著機關槍呢，那個人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00136",
		linknext = "0004_00138",
		line = 1782,
	},
	["0004_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh? Ah, tienes razón.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦？……还真的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦？……還真的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00137",
		linknext = "0004_00139",
		line = 1794,
	},
	["0004_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El arma que lleva es de antidisturbios y está cargada con balas de goma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"拿着的枪里装的应该是特殊的橡皮弹，用于镇压暴徒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"拿著的槍裡裝的應該是特殊的橡皮彈，用於鎮壓暴徒。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00138",
		linknext = "0004_00140",
		line = 1804,
	},
	["0004_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Puede que no sea un armamento letal, pero parece un poco extremo para ella llevar armas de fuego.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使没有杀伤能力，装备这样令人害怕的东西也太疯狂了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使沒有殺傷能力，裝備這樣令人害怕的東西也太瘋狂了。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00139",
		linknext = "0004_00141",
		line = 1814,
	},
	["0004_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero supongo que lo que pasa por sentido común en esta isla es cualquier cosa menos eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不——在这样一个岛上谈论常识才奇怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不——在這種島上談論常識才奇怪。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00140",
		linknext = "0004_00142",
		line = 1824,
	},
	["0004_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Dicho eso, solo vemos a las guardias llevando pistolas...",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，即使是经常看到的警卫，也至多只有一把手枪……",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是即使是經常看到的警衛，也頂多只有一把手槍……",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00141",
		linknext = "0004_00143",
		line = 1834,
	},
	["0004_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Será que es de otra división?",
					{"rt2"},
				},
			},
			cn = {
				{
					"每个人都不一样吗……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"每個人都不一樣嗎……？",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00142",
		linknext = "0004_00144",
		line = 1844,
	},
	["0004_00144"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“En todo caso, sería difícil inventarle excusas con las capacidades de lucha que tiene y su conocimiento de la ley.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无论如何，除了战斗力之外，她们也熟悉规则，我们很难找借口蒙混过关。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無論如何，除了戰鬥力之外，她們也熟悉規則，我們很難找藉口蒙混過關。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00143",
		linknext = "0004_00145",
		line = 1856,
	},
	["0004_00145"] = {
