		linkback = "0004_00481",
		linknext = "0004_00483",
		line = 5971,
	},
	["0004_00483"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0026", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“La gente de esta isla es bastante fogosa a la hora de follar, así que te preocupa saber si podrás enfrentarte a semejante \nreto, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“是在担心这个岛上的人都在变态做爱方面充满活力，害怕自己不能跟上那种挑战精神对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「是在擔心這個島上的人都在變態做愛方面充滿活力，害怕自己不能跟上那種挑戰精神對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00482",
		linknext = "0004_00484",
		line = 5983,
	},
	["0004_00484"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
