				{"vo", file="asane0152", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Luego desarrollé un programa para instalar mods +18 antibragas para un juego 3D dirigido a un público general.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“然后开发了在家机3DCG游戏上能导入脱内裤功能的色情MOD的工具。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「然後開發了在家機3DCG遊戲上能導入脫內褲功能的色情MOD的工具。」",
					{"rt2"},
				},
			},
		},
