	["0004_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa guardia con la que nos topamos... También la vimos el otro día. Es la que salía en el anuncio que vimos en el barco.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚刚那个人，是昨天也见到过的SHO警卫吗……那个出现在宣传短片里的——",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛剛那個人，是昨天也見到過的SHO警衛嗎……那個出現在宣傳短片裡的——",
