		{"bg", id=1, file="bg14_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0025", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Tachibana-kun no parece acostumbrarse a la clase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“……橘君似乎没怎么融入班级呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「……橘君似乎沒怎麼融入班級呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00389",
		linknext = "0004_00391",
		line = 4870,
	},
	["0004_00391"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuando volvía a clase luego de ir al baño, oí a Hanamaru hablando con otras personas de mi clase.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我打算从厕所回到教室时，花丸委员长对班上的同学们这么说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我打算從廁所回到教室時，花丸委員長對班上的同學們這麼說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00390",
		linknext = "0004_00392",
		line = 4880,
	},
	["0004_00392"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmoba0007", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男A", "人の良さそうな男子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男A", "Estudiante completamente genial"},
					"“Sí, no parece quedarse y participar realmente en el sexo pervertido...”",
