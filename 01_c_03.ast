					name = {"蘭", "Ran"},
					"“Estaba pensando que podríamos celebrar una fiesta combinada de iluminación de pollas y bien'venida'. ¿Qué opinan?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“所以，我打算在班上举行鸡鸡启发讲座兼新人欢淫会，大家觉得怎么样？”",
					{"rt2"},
				},
			},
