		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Una cosa es no querer madrugar, y otra es lo que haces. En serio que a veces me das muchísimos problemas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是的，起不来也要有个限度。总让我帮你那么多。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是的，起不來也要有個限度。總讓我幫你那麼多。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00040",
		linknext = "0004_00042",
		line = 581,
	},
	["0004_00042"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0150", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Lo siento... Anoche estuve despierta hasta tarde. No terminé de dormirme hasta altas horas de la madrugada.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对不起……昨天熬夜太晚了……今天早上才睡的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對不起……昨天熬夜太晚了……今天早上才睡的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00041",
