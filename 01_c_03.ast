		line = 2217,
	},
	["0004_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fue una idea improvisada que se me ocurrió de repente.",
