			en = {
				{
					name = {"モブ女A", "Mujer A"},
					"“Y bien... ¿qué te parece? ¿No te prenden esos sonidos sofocantes mientras te acaricio el brazo con mi escote?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "A女"},
					"“嗯……怎么样……亲？您的手臂在我的乳沟里滑来滑去被爱抚着呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "A女"},
					"「嗯……怎麼樣……客人？您的手臂在我的乳溝裡滑來滑去被愛撫著呢……」",
					{"rt2"},
				},
			},
		},
