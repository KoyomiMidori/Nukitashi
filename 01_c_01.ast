		line = 1158,
	},
	["0002_00088"] = {
		{"bg", id=1, file="bg09_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0022", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Es una lástima que te niegues a reconocer las capacidades innatas de orientación de tu propia hermanita pero igual esa es la ruta más corta así que cállate y escúchame maldito virgen.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“当然啊，哥哥居然鄙视妹妹的导航能力真是让我惊讶从那边走会更近啊知不知道知道了就闭嘴听我说就好你这个垃圾处男。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「當然啊，哥哥居然鄙視妹妹的導航能力真是讓我驚訝從那邊走會更近啊知不知道知道了就閉嘴聽我說就好你這個垃圾處男。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00087",
		linknext = "0002_00089",
		line = 1173,
	},
	["0002_00089"] = {
