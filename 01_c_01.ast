					"不知是不是轉學生不是很少見，班導也習慣了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00135",
		linknext = "0002_00137",
		line = 1809,
	},
	["0002_00137"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0001", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Bien, Tachibana-kun, te sentarás ahí. Hay un conjunto de libros en tu escritorio. Ya vamos a empezar con la clase de hoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“那橘君就坐那个座位，课桌上有你的教科书。好了，那就开始上课了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「那橘君就坐那個座位，課桌上有你的教科書。好了，那就開始上課了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00136",
		linknext = "0002_00138",
		line = 1821,
	},
	["0002_00138"] = {
		{"se", id=0, loop=0, file="se_a144"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La primera hora comienza en silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"严肃的第一节课开始了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"嚴肅的第一節課開始了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00137",
		linknext = "0002_00139",
		line = 1832,
	},
	["0002_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece decepcionantemente tranquila y seria.",
					{"rt2"},
				},
			},
			cn = {
				{
					"课堂上的安静程度消除了我的紧张感，大家看起来都很认真的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"課堂上的安靜程度消除了我的緊張感，大家看起來都很認真的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00138",
		linknext = "0002_00140",
		line = 1842,
	},
	["0002_00140"] = {
		{"se", id=0, loop=0, file="se_a142"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La profesora sigue el libro y los alumnos toman notas en silencio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老师也不疾不徐地随着教科书讲课，学生们都默默地记笔记。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老師也不疾不徐地隨著教科書講課，學生們都默默地記筆記。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00139",
		linknext = "0002_00141",
		line = 1853,
	},
	["0002_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Son todos aquí superdiligentes...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……大家都这么认真学习的吗？",
					{"rt2"},
				},
