			tw = {
				{
					"……大家都這麼認真學習的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00140",
		linknext = "0002_00142",
		line = 1863,
	},
	["0002_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Parece que se toman las cosas mucho más en serio que en mi escuela en Tokio.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与东京的学校相比，这里的教课非常认真。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與東京的學校相比，這裡的教課非常認真。",
