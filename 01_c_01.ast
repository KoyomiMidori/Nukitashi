		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0002", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Con esto termina la clase de hoy. ¡Chicos, asegúrese de recibir o dar una buena cogida y sin interrupciones al volver a sus casas!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“那么，班会就到这里了。大家回去的时候不要去其他地方，要好好做了爱回去哦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「那麼，班會就到這裡了。大家回去的時候不要去其他地方，要好好做了愛回去哦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00281",
		linknext = "0002_00283",
		line = 3644,
	},
	["0002_00283"] = {
