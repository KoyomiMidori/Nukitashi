					"我抓住在我旁邊喘息的妹妹的後頸。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00420",
		linknext = "0002_00422",
		line = 5419,
	},
	["0002_00422"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0015", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒D"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Estudiante D"},
					"“Bueno... ¿por qué no nos turnamos y nos lo follamos entre todas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生D"},
					"“那不然……我们一个个排队来吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生D"},
					"「那不然……我們一個個排隊來吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00421",
		linknext = "0002_00423",
		line = 5431,
	},
	["0002_00423"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0006", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "女子生徒E"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Estudiante E"},
					"“¿Eh? ¿Otra vez? Mi coño tendrá problemas para respirar si tiene que esperar su turno... ¿Por qué Dios no dotó a los hombres con seis pollas?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "女学生E"},
					"“诶〜又排？再等我的小穴就要呼吸困难了啦……为什么神不让男孩子长出6根鸡巴呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "女學生E"},
					"「欸〜又排？再等我的小穴就要呼吸困難了啦……為什麼神不讓男孩子長出6根肉棒呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00422",
		linknext = "0002_00424",
		line = 5443,
	},
	["0002_00424"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0001", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "女子生徒F"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Estudiante F"},
					"“Ni siquiera Dios es perfecto. Decidámoslo con piedra, papel o tijera.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "女学生F"},
					"“这说明神不是完美的啊。那，我们猜拳决定顺序吧——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "女學生F"},
					"「這說明神不是完美的啊。那，我們猜拳決定順序吧——」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00423",
		linknext = "0002_00425",
		line = 5455,
	},
	["0002_00425"] = {
		{"text"},
		text = {
