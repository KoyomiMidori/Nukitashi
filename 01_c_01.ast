				{"vo", file="ran0017", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Todo va a estar bien, Tachibana-kun. No tienes que preocuparte. Después de todo, siempre se dice que "nada disminuye la ansiedad más rápido que follar", ¿no crees?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“没事的，橘君。不用担心。‘操比撸开心’不是有这种说法嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「沒事的，橘君。不用擔心。『操比擼開心』不是有這種說法嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00329",
		linknext = "0002_00331",
		line = 4225,
	},
	["0002_00331"] = {
