					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Ah, Tachibana-kun. Hay unos documentos que necesito que llenes. ¿Puedes venir a la sala de profesores?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“啊，橘君。有想要让你填的资料。能来职员办公室一下吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「啊，橘君。有想要讓你填的資料。能來職員辦公室一下嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00288",
		linknext = "0002_00290",
		line = 3728,
	},
	["0002_00290"] = {
