		line = 1146,
	},
	["0002_00087"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Veamos... ¿el camino a la escuela se cruza con este?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让我看看……去学院的路，是这条吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
