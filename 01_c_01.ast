	["0002_00327"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00107", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0015", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“De hecho, esta isla es muy segura.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“实际上，这个岛非常安全。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「實際上，這個島非常安全。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00326",
		linknext = "0002_00328",
		line = 4189,
	},
	["0002_00328"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¡En el continente se cometen delitos prácticamente todos los días, pero la tasa de criminalidad en nuestra isla es casi inexistente! ¡El sexo pervertido realmente salvará al mundo...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“虽然本岛上每天都有人犯罪，但我们岛的犯罪率几乎是0%！变态做爱果然能拯救世界呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「雖然本島上每天都有人犯罪，但我們島的犯罪率幾乎是0%！變態做愛果然能拯救世界呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00327",
		linknext = "0002_00329",
		line = 4201,
	},
	["0002_00329"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supongo que tiene razón con esas estadísticas... Pero esa última parte como que no...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然从数据上来说是这样……但是真的吗……",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然從數據上來說是這樣……但是真的嗎……",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00328",
		linknext = "0002_00330",
		line = 4211,
	},
	["0002_00330"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
