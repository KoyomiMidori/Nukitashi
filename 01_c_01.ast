			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ahh, el arrecife de coral sobresale por encima del nivel del mar en esta orilla...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哇，这个海岸的珊瑚礁是从海面暴露出来形成的吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哇，這個海岸的珊瑚礁是從海面暴露出來形成的嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00096",
		linknext = "0002_00098",
		line = 1291,
	},
	["0002_00098"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0024", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Una barrera de coral, ¿eh? Bueno, a esta isla la llaman la Bora Bora de Japón...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“堡礁……吧？它似乎在日本被称为波拉波拉岛什么的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「堡礁……吧？它似乎在日本被稱為波拉波拉島什麼的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00097",
		linknext = "0002_00099",
		line = 1305,
	},
	["0002_00099"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La bahía está bordeada de cabañas turísticas situadas sobre el agua, y el hermoso mar azul está rodeado por una barrera de coral.",
					{"rt2"},
				},
			},
			cn = {
				{
					"游客的水上小屋漂浮着的内海，堡礁内的大海有着美丽的浅蓝色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"遊客的水上小屋漂浮著的內海，堡礁內的大海有著美麗的淺藍色。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00098",
		linknext = "0002_00100",
		line = 1317,
	},
	["0002_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Suelen decirle algo así como el Mar Seductor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像在表示美丽大海这个词一般的景色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像在表示美麗大海這個詞一般的景色。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00099",
		linknext = "0002_00101",
		line = 1327,
	},
	["0002_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Luce transparente como el cristal, probablemente debido al arrecife de coral que crece en las aguas poco profundas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为珊瑚礁生长变成浅海，所以看起来十分透明。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為珊瑚礁生長變成淺海，所以看起來十分透明。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00100",
		linknext = "0002_00102",
		line = 1337,
	},
	["0002_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El contraste entre el azul claro de las aguas poco profundas y el azul intenso del perímetro que delimita la isla definitivamente contribuyó a darle el adecuado nombre de Isla Seiran (azul índigo).",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是为什么这座浅蓝色和深蓝色的边界非常明显的美丽岛屿会被称为「青蓝岛」的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是為什麼這座淺藍色和深藍色的邊界非常明顯的美麗島嶼會被稱為「青藍島」的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00101",
		linknext = "0002_00103",
		line = 1347,
	},
	["0002_00103"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y pensar que viví aquí hace mucho tiempo, eh... Me siento un poco raro al volver a descubrir todo lo que hay en este folleto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……过去住过的岛屿刊载在宣传册上，真是太奇妙了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……過去住過的島嶼刊載在宣傳冊上，真是太奇妙了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00102",
		linknext = "0002_00104",
		line = 1359,
	},
	["0002_00104"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="asane_01l_00001", file1="asane_01l_00101", path=":fg/asane_01l/", id=3, lv=5, head="asane_01l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=200},
		{"fgact", ch="麻沙音", id=3, act="移動", x=0, y=-200, time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan mira por encima de mi hombro para ver el folleto.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我这么自言自语着，麻沙音突然看着宣传册。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我這麼自言自語著，麻沙音突然看著宣傳冊。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00103",
		linknext = "0002_00105",
		line = 1372,
	},
	["0002_00105"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0025", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Sí... Mmm, parece que la población es de unas 15.000 personas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这样啊……哼〜现在这里大约有15，000名居民……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這樣啊……哼〜現在這里大約有15，000名居民……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00104",
		linknext = "0002_00106",
		line = 1384,
	},
	["0002_00106"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Había tantas personas cuando vivíamos aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“以前也是这样吗，麻沙酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「以前也是這樣嗎，麻沙醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00105",
		linknext = "0002_00107",
		line = 1396,
	},
	["0002_00107"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00104", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0026", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, ha ido creciendo poco a poco a lo largo de los años. Teniendo en cuenta la actualidad candente de la isla, tampoco es nada raro...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不，似乎渐渐变多了……不愧是现在最火热的岛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不，似乎漸漸變多了……不愧是現在最火熱的島……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00106",
		linknext = "0002_00108",
		line = 1411,
	},
	["0002_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Desde hace tiempo, en Japón se viene hablando bastante del descenso de la población.",
					{"rt2"},
				},
			},
			cn = {
				{
					"日本从很久以前，就在叹息农村地区的人口减少。",
					{"rt2"},
				},
			},
			tw = {
				{
					"日本從很久以前，就在嘆息農村地區的人口減少。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00107",
		linknext = "0002_00109",
		line = 1421,
	},
	["0002_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso ahora, las cosas no han cambiado mucho. La gente se desplaza cada vez más de los centros urbanos a los suburbios y la situación está alcanzando un estado crítico.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是现在也没有改变，甜甜圈现象相当危险。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是現在也沒有改變，甜甜圈現象相當危險。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00108",
		linknext = "0002_00110",
		line = 1431,
	},
	["0002_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero la Isla Seiran ha demostrado ser una excepción. Su población no ha disminuido, sino que no ha dejado de aumentar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而在这之中，这个青蓝岛的人口与过去相比并没有减少，反而有逐渐增加的趋势。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而在這之中，這個青藍島的人口與過去相比並沒有減少，反而有逐漸增加的趨勢。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00109",
		linknext = "0002_00111",
		line = 1441,
	},
	["0002_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y claro, hay un buen motivo para eso.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，这是有原因的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，這是有原因的。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00110",
		linknext = "0002_00112",
		line = 1451,
	},
	["0002_00112"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, podemos tomar un atajo si tomamos la curva de aquí y seguimos derecho...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，从这里转过去直走有条近道——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，從這裡轉過去直走有條近道——」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00111",
