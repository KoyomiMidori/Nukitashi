		line = 1956,
	},
	["0002_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahora estamos en un centro de aprendizaje. Es completamente normal y no es como la playa nudista.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不愧是教学楼，与裸体海滩的气氛不同也是理所当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不愧是校舍，與裸體海灘的氣氛不同也是理所當然的。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00149",
		linknext = "0002_00151",
		line = 1966,
	},
	["0002_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mi hermanita también debería recibir una buena educación aquí.",
					{"rt2"},
