					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦，妹妹……！你来的刚好……没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦，妹妹……！你來的剛好……沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00379",
		linknext = "0002_00381",
		line = 4902,
	},
	["0002_00381"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00112", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
