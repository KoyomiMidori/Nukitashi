		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Qué calor hace hoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦……好热啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦……好熱啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00079",
		linknext = "0002_00081",
		line = 1077,
	},
	["0002_00081"] = {
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Me tapo los ojos con la mano y miro al sol, el cual ya está bastante elevado en el cielo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我用手搭成伞，看着高照的太阳自语道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我用手搭成傘，看著高照的太陽自語道。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00080",
		linknext = "0002_00082",
		line = 1088,
	},
	["0002_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apenas estamos a principios de mayo, pero el sol ya calienta lo suficiente como para quemarme los brazos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是五月的早晨，仍然可以感受到烧烤着手臂的阳光。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是五月的早晨，仍然可以感受到燒烤著手臂的陽光。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00081",
		linknext = "0002_00083",
		line = 1098,
	},
	["0002_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tan solo hace unos días, estábamos en Tokio y nos habíamos vestido para el frío.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不久前还在的东京，这个季节还有点冷呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不久前還在的東京，這個季節還有點冷呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00082",
		linknext = "0002_00084",
		line = 1108,
	},
	["0002_00084"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00117", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Típico, es una isla tropical...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不愧是南方岛屿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不愧是南方島嶼……」",
					{"rt2"},
				},
