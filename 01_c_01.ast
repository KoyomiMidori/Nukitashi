		},
		linkback = "0002_00083",
		linknext = "0002_00085",
		line = 1120,
	},
	["0002_00085"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=500, mode=3, x=250, y=0},
		{"fgact", ch="麻沙音", id=3, act="移動", x=-250, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0021", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Parece que hará aún más calor cuando llegue agosto... Seguramente habrá un montón de tifones... Qué fastidio...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“8月好像会更热哦……然后台风也很多……真是讨厌呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「8月好像會更熱哦……然後颱風也很多……真是討厭呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00084",
		linknext = "0002_00086",
		line = 1134,
	},
	["0002_00086"] = {
		{"se", id=0, loop=0, file="se_a021"},
		{"se", id=1, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa-chan saca de su bolso un folleto que le dieron en el barco y lo mira.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妹妹从包里拿出了她从船上拿到的小册子阅览着。",
