					{"rt2"},
				},
			},
			tw = {
				{
					"島上有各種設施和公共機構。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00455",
		linknext = "0002_00457",
		line = 5841,
	},
	["0002_00457"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Está la playa nudista que vimos antes, el parque de atracciones Tierra Lasciva, la guardería Baby Me Creche y un montón de manantiales termales variados.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚刚的裸体海滩、变态游乐园、奶嘴幼儿园、混浴温泉这些。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛剛的裸體海灘、變態遊樂園、奶嘴幼兒園、混浴溫泉這些。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00456",
		linknext = "0002_00458",
		line = 5851,
	},
	["0002_00458"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0044", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“El santuario sintoísta dedicado a los niños también parece recibir cada vez menos visitantes. He oído que incluso le han cambiado el nombre...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“还有可以早生贵子的神社，如今来了非常多的参拜客……据说连名字都变了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「還有可以早生貴子的神社，如今來了非常多的參拜客……據說連名字都變了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00457",
		linknext = "0002_00459",
		line = 5865,
	},
	["0002_00459"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Cómo se llama ahora?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“变成什么名字了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「變成什麼名字了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00458",
		linknext = "0002_00460",
		line = 5877,
	},
	["0002_00460"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0045", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
