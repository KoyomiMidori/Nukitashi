					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pues más o menos... Hah, haah... ¡Corrí una maratón de diez metros...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……总……算……哈……我冲刺了10米呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……總……算……哈……我衝刺了10米呢……」",
					{"rt2"},
