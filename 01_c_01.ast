		linkback = "0002_00385",
		linknext = "0002_00387",
		line = 4978,
	},
	["0002_00387"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00103", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0033", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Casi siempre se rinden y se ponen a follar a los tres días...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“大多数的人才三天就做爱了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「大多數的人才三天就做愛了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00386",
		linknext = "0002_00388",
		line = 4992,
	},
	["0002_00388"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00105", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
