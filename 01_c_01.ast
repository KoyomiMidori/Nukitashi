		line = 5901,
	},
	["0002_00462"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00104", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
