		linknext = "0002_00395",
		line = 5082,
	},
	["0002_00395"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bueno, solo estamos hablando de estar en la escuela. Nadie va a saber si soy novato o no una vez que estemos afuera. Vamos al patio...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但这是在学校中的事情。只要出去，就没人知道我是不是处男了，所以快点出去——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但這是在學校中的事情。只要出去，就沒人知道我是不是處男了，所以快點出去——」",
					{"rt2"},
				},
			},
		},
