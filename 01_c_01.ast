	["0002_00033"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Da la cara de mala gana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"随着沙沙的声音，妹妹一脸想睡觉地出现了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"隨著沙沙的聲音，妹妹一臉想睡覺地出現了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00032",
		linknext = "0002_00034",
		line = 472,
	},
	["0002_00034"] = {
		{"bg", id=1, file="bg19_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="asane_02m_00001", file1="asane_02m_00106", file2="asane_02m_00202", path=":fg/asane_02m/", id=3, lv=5, head="asane_02m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0008", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hermanito... ¿en serio tenemos que ir a la escuela?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥〜真的要去学校吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥〜真的要去學校嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00033",
		linknext = "0002_00035",
		line = 487,
	},
	["0002_00035"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00106", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Qué es esa pregunta? Somos estudiantes así que no hay de otra.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是的……没办法啊，我们是学生嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是的……沒辦法啊，我們是學生嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00034",
		linknext = "0002_00036",
		line = 499,
	},
	["0002_00036"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00105", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0009", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ehhh... Oye, ¿y si mejor no? Yo no veo ninguna razón para ir...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“诶——呐呐，别去了……妹妹完全看不出去学校哪里好……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸——吶吶，別去了……妹妹完全看不出去學校哪裡好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00035",
		linknext = "0002_00037",
		line = 513,
	},
	["0002_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Deja de pensar tanto en por qué tenemos que ir. Tenemos que ir y ya.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别深思上学的理由。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別深思上學的理由。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00036",
		linknext = "0002_00038",
		line = 524,
	},
	["0002_00038"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00106", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0010", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿Por qué tenemos que ir a la escuela...? ¿Qué es estudiar...? ¿Qué es la humanidad? ¿Qué es la muerte...? Puede que lo que todos estamos viendo sean solo sombras en una cueva...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“为什么我要去上学……什么是学习……人类是什么啊……什么是死亡……我们一开始所看到的是洞穴的阴影……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「為什麼我要去上學……什麼是學習……人類是什麼啊……什麼是死亡……我們一開始所看到的是洞穴的陰影……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00037",
		linknext = "0002_00039",
		line = 538,
	},
	["0002_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
