	},
	["0002_00421"] = {
		{"se", id=0, loop=0, file="se_a132"},
		{"fg", file="asane_01ll_00001", file1="asane_01ll_00112", file2="asane_01ll_00204", path=":fg/asane_01ll/", id=3, lv=5, head="asane_01ll", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=-7.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Agarro a mi hermana, que jadea como un perro, por el cuello.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我抓住在我旁边喘息的妹妹的后颈。",
