	["0002_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cierro la puerta y respiro hondo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我关上门，大口地喘气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我關上門，大口地喘氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00218",
		linknext = "0002_00220",
		line = 2878,
	},
	["0002_00220"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡Lo sabía...! ¡Incluso la escuela es así...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然，这个学校里也……这样了吗……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然，這個學校裡也……這樣了嗎……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00219",
		linknext = "0002_00221",
		line = 2890,
	},
	["0002_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Cuando la población de aquí disminuía, también aumentó el desempleo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为过疏化的雇用减少。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為過疏化的僱用減少。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00220",
		linknext = "0002_00222",
		line = 2900,
	},
	["0002_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Poco después, la población se redujo bastante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和随之而来的人口减少。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和隨之而來的人口減少。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00221",
		linknext = "0002_00223",
		line = 2910,
	},
	["0002_00223"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los organismos públicos y las instalaciones recreativas no consiguieron atraer a la gente, y con pocas atracciones turísticas, nada funcionaba en la Isla Seiran.",
					{"rt2"},
				},
			},
			cn = {
				{
					"公共机关和旅游设施的招揽也没有成功，也没有观光资源，干什么都没发成功的青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"公共機關和旅遊設施的招攬也沒有成功，也沒有觀光資源，幹什麼都無法成功的青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00222",
		linknext = "0002_00224",
		line = 2920,
	},
	["0002_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hace unas décadas se encontró en una cueva una especie de avión de combate con el mismo nombre de la isla, pero no pudieron mantener el interés durante mucho tiempo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然在几十年前从洞穴中发现了一架和岛一样名字的战斗机（？）而成为了话题，但也只是一瞬间的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然在幾十年前從洞穴中發現了一架和島一樣名字的戰鬥機（？）而成為了話題，但也只是一瞬間的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00223",
		linknext = "0002_00225",
		line = 2930,
	},
	["0002_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero luego vino alguien y dijo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但话说回来，到底是谁啊？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但話說回來，到底是誰啊？",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00224",
		linknext = "0002_00226",
		line = 2940,
	},
	["0002_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"“¡Oigan, estimulemos la economía de la isla follando!”",
					{"rt2"},
				},
			},
			cn = {
				{
					"说出“用色情复兴岛”这种话的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說出「用色情復興島」這種話的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00225",
		linknext = "0002_00227",
		line = 2950,
	},
	["0002_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Acto seguido, un adulto de renombre también le dio luz verde.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，到底是谁啊？",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，到底是誰啊？",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00226",
		linknext = "0002_00228",
		line = 2960,
	},
	["0002_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sí, un adulto literalmente pensó que la idea del tipo era buena.",
					{"rt2"},
				},
			},
			cn = {
				{
					"同意这件事的大人们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"同意這件事的大人們。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00227",
		linknext = "0002_00229",
		line = 2970,
	},
	["0002_00229"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“El tipo dijo 'En la Isla Seiran, el sexo pervertido debería estar permitido por la ley'...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个条例，准许了在青蓝岛上进行变态做爱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『這個條例，准許了在青藍島上進行變態做愛』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00228",
		linknext = "0002_00230",
		line = 2982,
	},
	["0002_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Con aquellas aparentemente improvisadas palabras, se creó esa ley.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个条例，由这句极具冲击力的阐述开始。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個條例，由這句極具衝擊力的闡述開始。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00229",
		linknext = "0002_00231",
		line = 2992,
	},
	["0002_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Una ley especial para revitalizar la isla... comúnmente conocida como 'la ley pervertida'.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复兴乡镇特别条例……俗称“变态条例”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"復興鄉鎮特別條例……俗稱「變態條例」。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00230",
		linknext = "0002_00232",
		line = 3002,
	},
	["0002_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La prohibición del sexo en lugares públicos se levantó a modo de una medida recomendable para revitalizar la isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是为了复兴乡镇而全面解禁在这个岛上的性爱，以及鼓励其行为的条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是為了復興鄉鎮而全面解禁在這個島上的性愛，以及鼓勵其行為的條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00231",
		linknext = "0002_00233",
		line = 3012,
	},
	["0002_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esta ley se aplicaba a toda la isla, y la escuela a la que asisto ahora, la academia Minotsuki, también entra dentro de ese ámbito.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且这个条例在岛屿全域被适用，我从今天开始上的『水乃月学园』也是一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且這個條例在島嶼全域被適用，我從今天開始上的『水乃月學園』也是一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00232",
