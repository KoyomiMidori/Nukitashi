			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ahhh... Tetas enormes por todas partes... Increíble... ¡Hwaaah...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯哈……都是爆乳婊呢……好厉害……哇，哇……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯哈……都是爆乳婊呢……好厲害……哇，哇……！」",
