					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「啊啊，如果是那裡的話，嗯哼！啊啊，好激烈啊！在一樓電梯的，附近嗯啊，啊啊啊，小穴裡花丸了……！」",
