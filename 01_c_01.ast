			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Ngh... Hwaah, tu polla de glande enorme está dentro de mííí.. Lo siento, Tachibana-kun, tendrás que hablarme mientras me la mete.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“嗯……哈啊啊啊，花丸大鸡巴进来了啊啊啊啊啊……对不起橘君，一边做爱一边跟你聊天。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「嗯……哈啊啊啊，花丸大肉棒進來了啊啊啊啊啊……對不起橘君，一邊做愛一邊跟你聊天。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00202",
		linknext = "0002_00204",
		line = 2655,
	},
	["0002_00204"] = {
