	},
	["0002_00478"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0023", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Mujer A"},
					"“¿No crees que te sentirías genial si se lo hiciera a tu polla? Ahora mismo, mi bomboncito está empapado, así que como extra, te dejaré usarlo incluso sin el lubricante ♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "A女"},
					"“如果这是鸡巴的话，不觉得会很舒服吗……？就算不用润滑液，我现在也可以用不断涌出蜜汁的密壶来服务您呢〜♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "A女"},
					"「如果這是肉棒的話，不覺得會很舒服嗎……？就算不用潤滑液，我現在也可以用不斷湧出蜜汁的密壺來服務您呢〜♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00477",
		linknext = "0002_00479",
		line = 6112,
	},
	["0002_00479"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00112", file2="asane_01m_00204", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="浮遊横", loop=5, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
