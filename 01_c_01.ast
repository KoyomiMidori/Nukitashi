					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No seas tonta. Por lo menos entiendo un mapa... Bien, veamos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在说什么傻话啊，我当然看得懂地图啊……往这边走。”",
