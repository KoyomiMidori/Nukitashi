		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"El comienzo de un nuevo día es, por lo general, un acontecimiento agradable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一天开始的心情，大多数都是愉快的。",
