		linkback = "0002_00478",
		linknext = "0002_00480",
		line = 6128,
	},
	["0002_00480"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡No voy a comprar nada! ¡Vámonos!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不买！走！”",
					{"rt2"},
				},
			},
			tw = {
