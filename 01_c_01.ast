					"「……打擾了，我是橘。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00302",
		linknext = "0002_00304",
		line = 3896,
	},
	["0002_00304"] = {
		{"se", id=0, loop=0, file="se_a005"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nuestra profesora sale corriendo al pasillo, trayendo consigo los documentos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚刚叫我的班主任，拿着资料来到了走廊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛剛叫我的班導，拿著資料來到了走廊。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00303",
		linknext = "0002_00305",
		line = 3907,
	},
	["0002_00305"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0004", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Lo siento, te iba a entregar esto esta mañana, pero el día de hoy estuvo muy ajetreado. Toma.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“对不起，本来想早上交给你的，但是今天很忙。这是资料。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「對不起，本來想早上交給你的，但是今天很忙。這是資料。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00304",
		linknext = "0002_00306",
		line = 3920,
	},
	["0002_00306"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0005", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Por cierto, siempre le explicamos esta isla a todos los estudiantes de transferencia, pero... jeje, creo que ya entiendes, ¿no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“还有，虽然有规定要和转学生说明一下有关岛的事……呵呵，但你大概也懂了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「還有，雖然有規定要和轉學生說明一下有關島的事……呵呵，但你大概也懂了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00305",
		linknext = "0002_00307",
		line = 3932,
	},
	["0002_00307"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ah, sí, claro...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，当然……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，當然……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00306",
		linknext = "0002_00308",
		line = 3944,
	},
	["0002_00308"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Lo entiendo a la perfección.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……甚至感到厌恶——这句话被我吞了下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……甚至感到厭惡——這句話被我吞了下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00307",
		linknext = "0002_00309",
		line = 3954,
	},
	["0002_00309"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0006", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Cierto. Tachibana-kun, tú vivías en esta isla, ¿verdad? No me extraña.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“这样啊，橘君毕竟在这个岛有住过。知道也是当然吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「這樣啊，橘君畢竟在這個島有住過。知道也是當然吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00308",
		linknext = "0002_00310",
		line = 3966,
	},
	["0002_00310"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00111", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, eso fue hace mucho tiempo... Ahora hay más instalaciones públicas y el ambiente ha cambiado mucho.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，那是很久以前的事情了……有了公共设施之后，这里的气氛变了好多呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，那是很久以前的事情了……有了公共設施之後，這裡的氣氛變了好多呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00309",
		linknext = "0002_00311",
		line = 3978,
	},
	["0002_00311"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="minase0007", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Minase"},
					"“Ah, ¿así que eso fue cuando aún estabas en una edad inmadura? Bueno, ¿dejo que la representante de la clase se encargue a partir de ahora?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“这样啊，那那时还是未性人的年龄吧？这部分能拜託委员长吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「這樣啊，那那時還是未性人的年齡吧？這部分能拜託委員長嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00310",
		linknext = "0002_00312",
		line = 3990,
	},
	["0002_00312"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=500, mode=3, x=200, y=0},
		{"fgact", ch="蘭", id=8, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0008", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Por supuesto. Al fin y al cabo, esto es responsabilidad del SS, o mejor dicho, de la representante de la clase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“明白了。这也是ss——不，班级委员长的工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「明白了。這也是SS——不，班級委員長的工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00311",
		linknext = "0002_00313",
		line = 4004,
	},
	["0002_00313"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hanamaru, la representante de la clase, aparece por detrás de la profesora mientras se ajusta las gafas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"摆正了眼镜，代替走到里面的老师，花丸委员长出现了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"擺正了眼鏡，代替走到裡面的老師，花丸委員長出現了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00312",
		linknext = "0002_00314",
		line = 4014,
	},
	["0002_00314"] = {
		{"bg", id=1, file="bg15_1_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="ran_01m_00001", file1="ran_01m_00104", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0009", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Bien, Tachibana-kun, tal vez ande repitiendo lo que ya sabes, pero aquí en la Academia Minotsuki, los actos de procreación sexual están sumamente alentados por el código de conducta de la escuela.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“那么橘君。虽然有些事情你已经知道了……在这个水乃月学园，校规鼓励我们进行性产行为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「那麼橘君。雖然有些事情你已經知道了……在這個水乃月學園，校規鼓勵我們進行性產行為。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00313",
		linknext = "0002_00315",
		line = 4029,
	},
	["0002_00315"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0010", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Tener relaciones sexuales con los isleños y los turistas en el camino de ida y vuelta a la escuela es una actividad admirable. Ve y procrea proactivamente.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“上下学途中的性爱，还有跟岛上的人或者观光客做爱都值得嘉奖。请积极进行性产行为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「上下學途中的性愛，還有跟島上的人或者觀光客做愛都值得嘉獎。請積極進行性產行為。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00314",
		linknext = "0002_00316",
		line = 4041,
	},
	["0002_00316"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0011", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“¿Tienes alguna duda?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“目前为止你有什么问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「目前為止你有什麼問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00315",
		linknext = "0002_00317",
		line = 4055,
	},
	["0002_00317"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pues...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呃——」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00316",
		linknext = "0002_00318",
		line = 4067,
	},
	["0002_00318"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ni siquiera sé si debería preguntar esto, pero bueno...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然不知道能不能问这种事情……",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然不知道能不能問這種事情……",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00317",
		linknext = "0002_00319",
		line = 4077,
	},
	["0002_00319"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿De verdad está bien tener relaciones sexuales con todo el mundo?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……真的和谁都没关系吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……真的和誰都沒關係嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00318",
		linknext = "0002_00320",
		line = 4089,
	},
	["0002_00320"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00118", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“O sea... ¿y si lo estoy haciendo con la pareja de alguien?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比如……那个，恋人被人睡了这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比如……那個，戀人被人睡了這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00319",
		linknext = "0002_00321",
		line = 4101,
	},
	["0002_00321"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="蘭", id=8, act="振動下", loop=2, size=12.5, time=125, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0012", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Jeje. Tachibana-kun, creo que estás haciendo un embarazo de una corrida.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“呵呵。橘君，那就和‘对孕妇外射’差不多啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「呵呵。橘君，那就和『對孕婦外射』差不多啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00320",
		linknext = "0002_00322",
		line = 4116,
	},
	["0002_00322"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00119", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Eh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00321",
		linknext = "0002_00323",
		line = 4128,
	},
	["0002_00323"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0013", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Ah, perdón... Es un dicho local que tenemos aquí. Significa preocuparse demasiado por algo. O sea, algo trivial.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“啊，失礼了……这是我们这边的说法。是指不用担心的事情，也可以说是杞人忧天。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「啊，失禮了……這是我們這邊的說法。是指不用擔心的事情，也可以說是杞人憂天。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00322",
		linknext = "0002_00324",
		line = 4140,
	},
	["0002_00324"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sea un dicho local o no, me pareció exagerado...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种事能当成是一种说法吗……",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種事能當成是一種說法嗎……",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00323",
		linknext = "0002_00325",
		line = 4150,
	},
	["0002_00325"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="蘭", id=8, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0014", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Por favor, piénsalo bien. Alguien podría tener toda la capacidad de complacer al amante de otra persona. ¿No es algo maravilloso?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“从常识角度好好想想。别人能把自己的恋人搞得非常爽啊？这不是很好的事情吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「從常識角度好好想想。別人能把自己的戀人搞得非常爽哦？這不是很好的事情嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00324",
		linknext = "0002_00326",
		line = 4165,
	},
	["0002_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Esa lógica es un tanto perversa...",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么想都有问题……吧？",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼想都有問題……吧？",
					{"rt2"},
				},
