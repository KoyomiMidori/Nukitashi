		line = 1910,
	},
	["0002_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Un estudiante de aspecto taciturno que está a mi lado responde con voz apagada.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一个坐在我旁边的沉默男孩默默地跟我说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一個坐在我旁邊的沉默男孩默默地跟我說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00145",
		linknext = "0002_00147",
		line = 1920,
	},
	["0002_00147"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="otona0000", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"大人っぽい女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"大人っぽい女子生徒", "Estudiante de actitud madura"},
					"“No le prestes atención, siempre es así. Las lecturas de literatura clásica son ese enorme compendio y esas impresiones. No deberían darte problemas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"大人っぽい女子生徒", "成熟的女学生"},
					"“……他总是那号表情，不需要太在意。古文课程主要使用那本大手册和印刷的课件，你一定没问题的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"大人っぽい女子生徒", "成熟的女學生"},
					"「……他總是那號表情，不需要太在意。古文課程主要使用那本大手冊和印刷物，你一定沒問題的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00146",
		linknext = "0002_00148",
		line = 1932,
	},
	["0002_00148"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="otona0001", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"大人っぽい女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"大人っぽい女子生徒", "Estudiante de actitud madura"},
					"“Jeje... Un gusto conocerte, Tachibana-kun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"大人っぽい女子生徒", "成熟的女学生"},
					"“呵呵……从今以后请多关照哦，橘君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"大人っぽい女子生徒", "成熟的女學生"},
					"「呵呵……從今以後請多關照哦，橘君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00147",
		linknext = "0002_00149",
		line = 1944,
	},
	["0002_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00107", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
