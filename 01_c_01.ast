					name = {"モブ女A", "Estudiante C"},
					"“¡Pues escúchame y pruébame! ¡Quedarás sorprendida! ¡Por algo quedé en el sexto lugar de mi clase en el Gran Premio local de Apertura!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生C"},
					"“那你来听听啊！被小镇里排名第6位的我的小穴声震撼吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生C"},
					"「那你來聽聽啊！被小鎮裡排名第6的我的小穴聲震撼吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00415",
		linknext = "0002_00417",
		line = 5358,
	},
	["0002_00417"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"¿Soy solo yo... o están llegando más personas...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么感觉……逐渐地，人越来越多了呢……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼感覺……逐漸地人越來越多了呢……？",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00416",
		linknext = "0002_00418",
		line = 5368,
	},
	["0002_00418"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En un abrir y cerrar de ojos, estamos rodeados de putas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"发觉的时候，我们已经被婊子们包围了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"發覺的時候，我們已經被婊子們包圍了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00417",
		linknext = "0002_00419",
		line = 5378,
	},
	["0002_00419"] = {
		{"fg", file="asane_02l_00001", file1="asane_02l_00112", file2="asane_02l_00204", path=":fg/asane_02l/", id=3, lv=5, head="asane_02l", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="麻沙音", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
