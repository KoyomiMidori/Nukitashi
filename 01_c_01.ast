				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Es hasta impresionante lo poco atlética y débil que es mi hermanita.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不会运动的妹妹没体力到令人绝望的程度。",
