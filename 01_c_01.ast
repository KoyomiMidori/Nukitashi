		{"text"},
		text = {
			vo = {
				{"vo", file="ran0005", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Tranquilo, es que yo, ¡uhh!, soy la representante de ahh, la clase... ¿Hay algo que te moleste?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“不，我，嗯哼……！毕竟是班级……啊！委员长……有什么困扰的……事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「不，我，嗯哼……！畢竟是委員長……啊！有什麼困擾的……事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00204",
		linknext = "0002_00206",
		line = 2681,
	},
	["0002_00206"] = {
