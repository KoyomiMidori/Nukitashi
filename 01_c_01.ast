		linknext = "0002_00389",
		line = 5004,
	},
	["0002_00389"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0034", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Bueno, al menos tenemos la píldora... Bueh, en todo caso, probablemente la tenemos mejor que los chicos... Esta isla está prácticamente infestada de locas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“毕竟有避孕药……所以相比男孩子受到的诱惑还算好……这个岛，据说有很多肉食女……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「畢竟有避孕藥……所以相比男孩子受到的誘惑還算好……這個島，據說有很多肉食女……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00388",
		linknext = "0002_00390",
		line = 5018,
	},
	["0002_00390"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0035", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Parece que todos los chicos nuevos aquí son muy populares. Es un mercado muy competitivo para ellas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以，第一次的男孩子都很抢手……据说是争夺赛呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以第一次的男孩子都很搶手……據說是爭奪戰呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00389",
