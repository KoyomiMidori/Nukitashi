	["0002_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incluso estar en una habitación desconocida a la que me acabo de mudar no debería suponer una gran diferencia.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是刚刚搬入还不习惯的房子，也没有太大的区别。",
