	["0002_00463"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00115", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Debiste estar aguantando ese chiste desde hace rato, ¿verdad?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要记这种没用的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要記這種沒用的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00462",
		linknext = "0002_00464",
		line = 5927,
	},
	["0002_00464"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque la isla sea atractiva por permitir el sexo en cualquier lugar, hacer eso en el santuario sintoísta es una locura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然能够在任何地方发生性行为是岛上的魅力，但怎么连神社都这样呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然能夠在任何地方發生性行為是島上的魅力，但怎麼連神社都這樣呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00463",
		linknext = "0002_00465",
		line = 5937,
	},
	["0002_00465"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero es un hecho que ha revitalizado la isla.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，岛屿因此蓬勃发展却也是事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，島嶼因此蓬勃發展卻也是事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00464",
		linknext = "0002_00466",
		line = 5947,
	},
	["0002_00466"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normalmente sería imposible que hasta las tiendas de recuerdos afuera de la ciudad prosperaran así.",
					{"rt2"},
				},
			},
			cn = {
				{
					"活动结束后纪念品商店还这么热闹，其他地方应该办不到吧——",
					{"rt2"},
				},
			},
			tw = {
				{
					"活動結束後紀念品商店還這麼熱鬧，其他地方應該辦不到吧——",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00465",
		linknext = "0002_00467",
		line = 5957,
	},
