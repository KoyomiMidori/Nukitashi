			en = {
				{
					name = {"蘭", "Ran"},
					"“En fin, eso es todo lo que tenía que explicar. Puedes entregarle tus documentos a la profesora. Tengo trabajo que hacer, así que si me disculpas...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“那么我的说明就到这了，资料我会帮你交给老师的。接下来我还有工作，先失陪了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「那麼我的說明就到這了，資料我會幫你交給老師的。接下來我還有工作，先失陪了。」",
