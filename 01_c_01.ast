		linkback = "0002_00418",
		linknext = "0002_00420",
		line = 5393,
	},
	["0002_00420"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¡No te excites ahora!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“笨蛋……！你在兴奋什么啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「笨蛋……！你在興奮什麼啊……！」",
