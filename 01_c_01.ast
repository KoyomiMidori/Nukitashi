		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Doblo la esquina, y mis palabras mueren en mi garganta.",
					{"rt2"},
				},
			},
			cn = {
				{
					"走过拐角，我顿时语塞。",
