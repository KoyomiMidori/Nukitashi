		{"fg", file="ran_01m_00001", file1="ran_01m_00101", path=":fg/ran_01m/", id=8, lv=5, head="ran_01m", ch="蘭", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
