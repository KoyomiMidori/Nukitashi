					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“¿No es peligroso? ¿Y si no vuelves sano a casa...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这，很糟糕吧……？可能会回不了家吧……？”",
