				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Supongo que no hace falta mucho tiempo para que los gusanos del cerebro se cuelen...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大家被影响得好快啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大家被影響得好快啊。」",
					{"rt2"},
				},
