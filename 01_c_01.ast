	["0002_00116"] = {
		{"bgm", file="bgm08", vol=100},
		{"bg", id=2, file="bg05_1_1l_00000", x=300, y=-100, lv=5, path=":bg/", sync=0, time=500, ax=1280, ay=730, bx=-480, by=-280},
		{"cgact", file="cgact", id=2, act="移動", x=-605, y=-5, time=20000, lv=5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aunque aún no son vacaciones de verano, la isla más grande de la playa está abarrotada de gente.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管还没暑假，岛上最大的海滩也有很多人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管還沒暑假，島上最大的海灘也有很多人。",
					{"rt2"},
				},
