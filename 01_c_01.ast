		linkback = "0002_00381",
		linknext = "0002_00383",
		line = 4927,
	},
	["0002_00383"] = {
		{"se", id=0, loop=0, file="se_a015"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿A las chicas también les dan fuerte aquí?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……难道，对女孩子也邀约的很厉害吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……難道對女孩子也邀約得很厲害嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00382",
		linknext = "0002_00384",
		line = 4940,
	},
	["0002_00384"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00104", file2="asane_01m_00202", path=":fg/asane_01m/", id=3, lv=5, head="asane_01m", ch="麻沙音", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0031", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pues... no creo que tanto como a los chicos... pero fue intenso...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然不像男孩子那么严重……但也很厉害……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然不像男孩子那麼嚴重……但也很厲害……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00383",
		linknext = "0002_00385",
		line = 4954,
	},
	["0002_00385"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0032", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Resulta que todas las chicas toman la píldora a largo plazo... Se supone que no deben hacer nada durante dos semanas hasta que haga efecto, pero...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是，女孩子因为要吃长期避孕药……所以在效果出现的2周内是基本禁止的……可是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是，女孩子因為要吃長期避孕藥……所以在效果出現的2週內是基本禁止的……可是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00384",
		linknext = "0002_00386",
		line = 4966,
	},
	["0002_00386"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00113", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
