	["0002_00153"] = {
		{"bgm", file="bgm05", vol=100},
		{"se", id=1, loop=0, file="se_d020"},
		{"text"},
		text = {
			vo = {
				{"vo", file="genki0000", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"元気で明るい女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"元気で明るい女子生徒", "Chica alegre y divertida"},
					"“¡Oye, oye, Tachibana-kun! ¡¿Qué te pareció que te transfirieran acá?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"元気で明るい女子生徒", "开朗有精神的女学生"},
					"“呐呐，橘君！转校到这里感觉怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"元気で明るい女子生徒", "開朗有精神的女學生"},
					"「吶吶，橘君！轉校到這裡感覺怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00152",
		linknext = "0002_00154",
		line = 2032,
	},
	["0002_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"En un parpadeo, mi escritorio se encuentra rodeado.",
					{"rt2"},
				},
			},
			cn = {
				{
					"下一刻，我的桌子被大家包围了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"下一刻，我的桌子被大家包圍了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00153",
		linknext = "0002_00155",
		line = 2042,
	},
	["0002_00155"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmoba0000", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男A", "人の良さそうな男子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男A", "Estudiante completamente genial"},
					"“Sí, ¿has tenido problemas? ¡Te ayudaremos con lo que necesites!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男A", "好像人很好的男学生"},
					"“哦，你没有什么困扰吧？如果我们能帮到你的话尽管说！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男A", "好像人很好的男學生"},
					"「哦，你沒有什麼困擾吧？如果我們能幫到你的話儘管說！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00154",
		linknext = "0002_00156",
		line = 2054,
	},
	["0002_00156"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0000", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "体育会系な男子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Estudiante fanático de la gimnasia"},
					"“Ajaja, chicos, ya. ¿No ven que Tachibana está incómodo? Denle un tiempo para que se acostumbre a su nueva escuela.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "运动会系男学生"},
					"“哈哈哈，喂喂大家，橘很困扰呢。别着急，慢慢适应就好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "運動會系男學生"},
					"「哈哈哈，喂喂大家，橘很困擾呢。別著急，慢慢適應就好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00155",
		linknext = "0002_00157",
		line = 2066,
	},
	["0002_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mis compañeros se acercan a mi mesa, uno tras otro, y de forma constante.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这样，我的同学们纷纷来到我的桌前。",
					{"rt2"},
