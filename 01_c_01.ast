		line = 6140,
	},
	["0002_00481"] = {
		{"fg", mode=-1, id=3, ch="麻沙音", lv=5, time=300},
		{"se", id=0, loop=0, file="se_a022"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Santo cielo, aquí todo tiene que ver con sexo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真是的，不管从什么方面都能和性联系在一起——",
					{"rt2"},
				},
			},
			tw = {
				{
					"真是的，不管從什麼方面都能和性聯繫在一起——",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00480",
		linknext = "0002_00482",
		line = 6153,
	},
	["0002_00482"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Por lo visto, cuando introdujeron por primera vez esta ley de "todo el sexo está bien", se dieron graves problemas de salud y se alteró el orden público.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时，“健康问题”和“安全问题”也似乎曾成为执行此条例的阻碍。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時，「健康問題」和「治安問題」也似乎曾經成為執行此條例的阻礙。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00481",
		linknext = "0002_00483",
		line = 6163,
	},
	["0002_00483"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Era de esperarse.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是理所当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是理所當然的。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00482",
		linknext = "0002_00484",
		line = 6173,
	},
	["0002_00484"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"La propagación de cualquier enfermedad infecciosa sería un gran problema, y si a eso le añadimos las ETS derivadas del coito, es un desastre de salud pública muy grave e inevitable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是疾病传播那就出大事了，而且不难想象性活动会成为一个暴力问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是疾病傳開來那就出大事了，而且不難想像性行為會成為一個暴力問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00483",
		linknext = "0002_00485",
		line = 6183,
	},
	["0002_00485"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Para ello, se encomendó el mantenimiento del orden en la isla a la corporación de servicio público, la Organización Nacional de Seiran—comúnmente conocida como ONS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此，青蓝岛将这些工作委任给了青蓝岛保险组织……通称“SHO”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此，青藍島將這些工作委任給了青藍島保險組織……通稱「SHO」。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00484",
		linknext = "0002_00486",
		line = 6193,
	},
	["0002_00486"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Para entrar en la isla hay que pasar un control sanitario. Tuvimos que pasar unos exámenes muy estrictos para que nos dejaran entrar.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果没有通过SHO的审查，将无法进入岛屿，我们在入岛时也接受了严格的检查。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果沒有通過SHO的審查，將無法進入島嶼，我們在入島時也接受了嚴格的檢查。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00485",
		linknext = "0002_00487",
		line = 6203,
	},
	["0002_00487"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nos dijeron que, incluso para los residentes permanentes de la isla, los exámenes mensuales son obligatorios.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛民还被告知每月都要定期进行一次体检。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島民還被告知每月都要定期進行一次體檢。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00486",
		linknext = "0002_00488",
		line = 6213,
	},
	["0002_00488"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Además, la mayoría de los medicamentos se suministran gratuitamente a modo de servicio público de salud. Esto no ha cambiado desde que yo vivía aquí.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了维持岛民的身体状况，据说大多数药物都是免费提供给居民的。这和我很久以前在这里生活时一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了維持島民的身體狀況，據說大多數藥物都是免費提供給居民的。這和我很久以前在這裡生活時一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00487",
		linknext = "0002_00489",
		line = 6224,
	},
	["0002_00489"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pero hay una gran diferencia entre entonces y ahora: la ONS moderna también tiene la misión de preservar el "orden público".",
					{"rt2"},
				},
			},
			cn = {
				{
					"最大的不同，应该是“治安维持”的方式。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最大的不同，應該是「治安維持」的方式。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00488",
		linknext = "0002_00490",
		line = 6234,
	},
	["0002_00490"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=1, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0008", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SHOガードマンA"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Guardia de la ONS A"},
					"“Aquí el sector A1. La situación está bajo control. Seguimos observando, cambio...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SHO警卫A"},
					"“这里是Ａ1区域，没有异常。继续戒备……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛A"},
					"「這裡是Ａ1區域，沒有異常。繼續戒備……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00489",
		linknext = "0002_00491",
		line = 6248,
	},
	["0002_00491"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los guardias de seguridad de la ONS están apostados por toda la isla, vigilando a todo el mundo.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO会将警卫安置在岛上以维持治安，让其时刻监视各地。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO會將警衛安置在島上以維持治安，讓其時刻監視各地。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00490",
		linknext = "0002_00492",
		line = 6258,
	},
	["0002_00492"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A donde sea que vayas te los encuentras.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每走几步都可以发现他们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每走幾步都可以發現他們。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00491",
		linknext = "0002_00493",
		line = 6268,
	},
	["0002_00493"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0024", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女A", "SHOガードマンB"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Guardia de la ONS B"},
					"“¿Quieres entrar a Tierra Lasciva? Vale, si sigues directamente por esta carretera, encontrarás un autobús que te dejará allá.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO警卫B"},
					"“是去变态游乐园吗？好的，只要往这条路直走，就会有一个直达的公交车站。我带你去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "SHO警衛B"},
					"「是去變態遊樂園嗎？好的，只要往這條路直走，就會有一個直達巴士的巴士站。我帶你去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00492",
		linknext = "0002_00494",
		line = 6280,
	},
	["0002_00494"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0009", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SHOガードマンC"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Guardia de la ONS C"},
					"“¿Dónde están tus padres, pequeñín? Ya veo, ¿te separaste de ellos? Jeje, no te preocupes. Acompáñame y los esperamos juntos, ¿vale?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SHO警卫C"},
					"“你的爸爸和妈妈呢？都在別的地方……呵呵，别担心。和姐姐在那边等一下吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SHO警衛C"},
					"「你的爸爸和媽媽呢？都在別的地方……呵呵，別擔心。和姐姐在那邊等一下吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00493",
		linknext = "0002_00495",
		line = 6292,
	},
	["0002_00495"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Los guardias de la ONS son bastante amables; se les puede ver ofreciendo indicaciones a la gente e incluso cuidando a niños perdidos.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO的警卫非常亲切，除了维持治安，他们还提供导览和托儿服务。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO的警衛非常親切，除了維持治安，他們還提供導覽和托兒服務。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00494",
		linknext = "0002_00496",
		line = 6302,
	},
	["0002_00496"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0002", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女C", "SHOガードマンD"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Guardia de la ONS D"},
					"“Te acabas de mudar a esta isla, ¿verdad? Si es así... permíteme ser tu primera compañera ",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "SHO警卫D"},
					"“你第一次来这个岛吗？嗯……我来当你第一次的对象吧……",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "SHO警衛D"},
					"「你第一次來這個島嗎？嗯……我來當你第一次的對象吧……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
