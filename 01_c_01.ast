					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“¿Pero...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是……？」",
					{"rt2"},
