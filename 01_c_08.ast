	["0009_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Direct combat, long-range support, transport, communications, supply, and so on... They're practically an army with the way they're structured.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直接战斗、远程支援、运输支援、电子战支援、补给……就像军队般的职务分配。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直接戰鬥、遠程支援、運輸支援、電子戰支援、補給……就像軍隊般的職務分配。",
					{"rt2"},
				},
			},
