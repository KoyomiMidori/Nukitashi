	},
	["0009_00311"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'll never accept it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我绝对不会允许。",
					{"rt2"},
				},
