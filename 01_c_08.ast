		},
		linkback = "0009_00192",
		linknext = "0009_00194",
		line = 2414,
	},
	["0009_00194"] = {
		{"se", id=0, loop=0, file="se_a075"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We're close to the front gate from here, but from the ground level, this is a blind spot.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这里虽然离学校正面很近，但它从操场上看刚好是一个盲点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這裡雖然離學校正面很近，但它從操場上看剛好是一個盲點。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00193",
		linknext = "0009_00195",
		line = 2425,
	},
	["0009_00195"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They can't see us from outside.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以无法从外面发现。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以無法從外面發現。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00194",
		linknext = "0009_00196",
		line = 2435,
	},
	["0009_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Never thought there'd be something like this here...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我完全没想到这种地方有这样一个盲点——",
					{"rt2"},
				},
			},
			tw = {
				{
					"我完全沒想到這種地方有這樣一個盲點——",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00195",
		linknext = "0009_00197",
		line = 2445,
	},
	["0009_00197"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“B-But can you walk along here!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但、但是这有办法走吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但、但是這有辦法走嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00196",
		linknext = "0009_00198",
		line = 2457,
	},
	["0009_00198"] = {
		{"bg", id=1, file="bg17_2l_00000", x=0, y=0, path=":bg/", sync=0, time=300, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0289", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You'll be fine, I always went through here to get away from the perverted sex classes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没事，我想逃离性爱课时经常走这里——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒事，我想逃離性愛課時經常走這裡——」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00197",
		linknext = "0009_00199",
		line = 2472,
	},
	["0009_00199"] = {
		{"fgact", ch="奈々瀬", id=4, act="移動", x=-200, y=0, time=600},
		{"fg", mode=-1, id=4, ch="奈々瀬", lv=5, time=400},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She leads the way, nimbly walking along the scaffolding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她轻快地走在高高的脚手架上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她輕快地走在高高的鷹架上。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00198",
		linknext = "0009_00200",
		line = 2485,
	},
	["0009_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I'm astonished... I never expected this from her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到……奈奈濑居然会那样干。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到……奈奈瀨居然會那樣做。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00199",
		linknext = "0009_00201",
		line = 2495,
	},
	["0009_00201"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0034", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ女B", "SS二番隊隊長"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "SS 2nd Squad Commander"},
					"“Why's there scaffolding here...!? This is B-1! The non-procreators are armed! Requesting immediate permission from the commander to use firearms!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "SS第二中队队长"},
					"“这里居然有脚手架……！？这里是B-1！非性产者持有武器！立即向大队长申请枪支使用许可！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "SS第二中隊隊長"},
					"「這裡居然有鷹架……！？這裡是B-1！非性產者持有武器！立即向大隊長申請槍支使用許可！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00200",
		linknext = "0009_00202",
		line = 2507,
	},
	["0009_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I see, so they need permission from the disciplinary committee president to use them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来如此，没有风纪委员长的许可就不能使用啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來如此，沒有風紀委員長的許可就不能使用啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00201",
		linknext = "0009_00203",
		line = 2517,
	},
	["0009_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though I certainly don't have the time to be dwelling on that now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，我现在完全没有时间去想这些问题——",
					{"rt2"},
				},
			},
			tw = {
				{
					"不對，我現在完全沒有時間去想這些問題——",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00202",
		linknext = "0009_00204",
		line = 2527,
	},
	["0009_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You gonna tell me what we're supposed to do next!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但，之后怎么办……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但，之後怎麼辦……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00203",
		linknext = "0009_00205",
		line = 2538,
	},
	["0009_00205"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0290", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Most of the SS are at Lewd Land for the event, so there aren't many left. There's one at each entrance, and two on each floor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“今天SS的人都去了游乐园的活动，所以人比较少。出入口分别有1个人，每层有2个人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「今天SS的人都去了遊樂園的活動，所以人比較少。出入口分別有1個人，每層有2個人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00204",
		linknext = "0009_00206",
		line = 2551,
	},
	["0009_00206"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0290b", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So there's none stationed outside the school building!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“也就是说教学楼外面一个人也没有……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「也就是說校舍外面一個人也沒有……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00205",
		linknext = "0009_00207",
		line = 2563,
	},
	["0009_00207"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see, so if we safely get down from here, we can escape through the front gate... Man, you've really done your homework.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，那只要安全下去之后逃到后门就——你怎么这么熟悉啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，那只要安全下去之後逃到後門就——你怎麼這麼熟悉啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00206",
		linknext = "0009_00208",
		line = 2575,
	},
	["0009_00208"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00110", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0291", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I haven't been running from them these last few years just for show.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我这几年可不是逃假的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我這幾年可不是白逃的。」",
					{"rt2"},
				},
			},
