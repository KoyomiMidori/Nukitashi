		line = 3878,
	},
	["0009_00312"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Endorsement of perverted sex is something I will never, ever accept.",
					{"rt2"},
				},
			},
			cn = {
				{
					"鼓励变态做爱什么的——绝对不能允许。",
					{"rt2"},
				},
			},
			tw = {
				{
					"鼓勵變態做愛什麼的——絕對不能允許。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00311",
		linknext = "0009_00313",
		line = 3888,
	},
	["0009_00313"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0004", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Hahaha... Such youthful pride and naive arrogance. But I admire your spirited nature.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“哈哈哈……年轻的傲慢，无知的不逊，但——很棒的觉悟。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「哈哈哈……年輕的傲慢，無知的不遜，但——很棒的覺悟。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00312",
		linknext = "0009_00314",
		line = 3900,
	},
	["0009_00314"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
