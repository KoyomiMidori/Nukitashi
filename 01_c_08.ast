					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Huh... A dead end? There's just a stone wall here... There's no way forward. Commander, are you quite sure it was this way?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“咦——死路一条……？这……一堵岩墙……没法往前走了……中队长，真的是这边吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「咦——死路一條……？這……一堵岩牆……沒辦法往前走了……中隊長，真的是這邊嗎……？」",
					{"rt2"},
				},
			},
