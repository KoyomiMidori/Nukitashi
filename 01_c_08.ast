		{"fgact", ch="奈々瀬", id=4, act="移動", x=100, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0288", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sigh... Back when they were constructing the accessibility features, they forgot to take down the scaffolding here. I've been using it to get out to the left side of the building from here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“唉……只有这里，还留着在无障碍工程期间制作的踏脚处……继续前进的话可以在教学楼的左侧下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「唉……只有這裡，還留著在無障礙工程期間製作的踏腳處……繼續前進的話可以在校舍的左側下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00191",
		linknext = "0009_00193",
		line = 2402,
	},
	["0009_00193"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說什麼？」",
					{"rt2"},
				},
