		line = 3912,
	},
	["0009_00315"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The man's voice laughs in amusement from the speaker.",
					{"rt2"},
				},
			},
			cn = {
				{
					"音响的男人似乎觉得很有趣，愉快地笑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"音響的男人似乎覺得很有趣，愉快地笑著。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00314",
		linknext = "0009_00316",
		line = 3922,
	},
	["0009_00316"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0005", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Experience repeated hardships, overcome numerous difficulties, and finally attain the fulfillment of your goals through your trials and tribulations...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“尝过多重辛酸，克服无数苦难，在辛苦艰难的尽头，成就圆满夙愿——正因如此！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「嚐過多重辛酸，克服無數苦難，在辛苦艱難的盡頭，成就圓滿夙願——正因如此！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00315",
		linknext = "0009_00317",
		line = 3934,
	},
	["0009_00317"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0006", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You, warrior who would come before my eyes. Can you bring such a path to fruition? If so, you have earned the right to pass through this door.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“你能完成吗？既然战士出现在了",
					{"ruby", text="・・"},
					"这里",
					{"/ruby"},
					"——你有权打开这扇门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「你能完成嗎？既然戰士出現在了",
					{"ruby", text="・・"},
					"這裡",
					{"/ruby"},
					"——你有權打開這扇門。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00316",
		linknext = "0009_00318",
		line = 3946,
	},
	["0009_00318"] = {
