		{"fgact", ch="奈々瀬", id=4, act="移動", x=200, y=0, time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0284", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun, there's one SS member normally posted over there at this time!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳！这个时间段的话，那边应该还有一位SS在待命！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳！這個時間段的話，那邊應該還有一個SS在待命！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00172",
		linknext = "0009_00174",
		line = 2154,
	},
	["0009_00174"] = {
