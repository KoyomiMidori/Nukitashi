			cn = {
				{
					name = {"淳之介"},
					"“这里是哪里……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這裡是哪裡……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00339",
		linknext = "0009_00341",
		line = 4266,
	},
	["0009_00341"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0008", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You are underground, directly beneath where your school stands.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“是你们学校的地下室。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「是你們學校的地下室。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00340",
		linknext = "0009_00342",
		line = 4279,
	},
	["0009_00342"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0304", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Underground? I didn't get the memo that our school had a place like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“地下室？我从没听说我们学校有这样的地方——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「地下室？我從沒聽說過我們學校有這樣的地方——」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00341",
		linknext = "0009_00343",
		line = 4294,
	},
	["0009_00343"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0009", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You are not meant to know. This place was not constructed as part of your school. It was used as a laboratory by the former Imperial Army long ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“不可能知道吧。这里虽然是地下室，但不是学校建造的。这里是旧帝国军很久以前用作试验场的设施。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「不可能知道吧。這裡雖然是地下室，但不是學校建造的。這裡是舊帝國軍很久以前用作試驗場的設施。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00342",
		linknext = "0009_00344",
		line = 4307,
	},
	["0009_00344"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0010", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Now, of course, that is no longer the case. So I refurbished it with the latest technology. When Minotsuki Academy was constructing their accessibility features, I was able to connect this place to the school.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“当然，现在已经与当时不一样了。是我将所有东西改装为最新的设备——在水乃月学园无障碍化的时候，连接到了这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「當然，現在已經與當時不一樣了。是我將所有東西改裝為最新的設備——在水乃月學園無障礙化的時候，連接到了這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00343",
		linknext = "0009_00345",
		line = 4320,
	},
	["0009_00345"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0305", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You connected it... Does that mean we can get here directly from the school!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“连接到了这里……也就是说能从学校直接过来吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「連接到了這裡……也就是說能從學校直接過來嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00344",
		linknext = "0009_00346",
		line = 4332,
	},
	["0009_00346"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0011", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Correct. Otherwise... warriors could not establish a base here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“没错。否则它就无法成为战士的基地。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「沒錯。否則它就無法成為戰士的基地。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00345",
		linknext = "0009_00347",
		line = 4345,
	},
	["0009_00347"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Warriors...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“战士……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「戰士……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00346",
		linknext = "0009_00348",
		line = 4356,
	},
	["0009_00348"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0012", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Yes. I envisioned people would wish to revolt against Seiran island and the SHO, so I established this facility with that in mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“是的……这里是我为了反抗青蓝岛以及SHO的人的到来而准备的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「是的……這裡是我為了反抗青藍島以及SHO的人的到來而準備的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00347",
		linknext = "0009_00349",
		line = 4369,
	},
	["0009_00349"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0013", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“This is a base of operations for warriors with the will to erase the calamity created on this island, and to protect its citizens.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“为了纠正这个岛屿产出的谬论，立志于救民济世的战士——的作战基地。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「為了糾正這個島嶼產出的謬論，立志於救民濟世的戰士——的作戰基地。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00348",
		linknext = "0009_00350",
		line = 4382,
	},
	["0009_00350"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With all the facilities here, it's possible to amass weaponry and devise battle strategies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要有了这些设备，就能张罗武器，也能制定作战计画。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要有了這些設備，就能張羅武器，也能制定作戰計畫。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00349",
		linknext = "0009_00351",
		line = 4392,
	},
	["0009_00351"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's no longer impossible to fight them head on with this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是这样的话，想从正面战斗也不是不可能的事情——",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是這樣的話，想從正面戰鬥也不是不可能的事情——",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00350",
		linknext = "0009_00352",
		line = 4403,
	},
	["0009_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you mean you've invited us here to this base of operations?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——邀请我们到这个作战基地来的意思是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「——邀請我們到這個作戰基地來的意思是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00351",
		linknext = "0009_00353",
		line = 4415,
	},
	["0009_00353"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0014", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Indeed. It is my wish that you use this facility to overthrow the SHO.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“没错。我希望你们使用这里的设备，打倒SHO。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「沒錯。我希望你們使用這裡的設備，打倒SHO。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00352",
		linknext = "0009_00354",
		line = 4428,
	},
	["0009_00354"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00123", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0306", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“O-Overthrow them!? Like, actually take down the SHO!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“打、打倒……！叫我们打倒SHO……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「打、打倒……！叫我們打倒SHO……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00353",
		linknext = "0009_00355",
		line = 4442,
	},
	["0009_00355"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0015", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Of course, I shall provide you with the ample amount of funding needed to do so. Everything possible you may need, I assure you I am able to procure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“当然，为此我会资助资金。我保证会提供万全的资源。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「當然，為此我會資助資金。我保證會提供萬全的資源。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00354",
		linknext = "0009_00356",
		line = 4455,
	},
	["0009_00356"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In other words, you'll be acting as our patron?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说——你会成为赞助人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說——你會成為贊助人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00355",
		linknext = "0009_00357",
		line = 4467,
	},
	["0009_00357"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0307", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No way! That organization's just too big to—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这太疯狂了，那样的大组织——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這太瘋狂了，那樣的大組織——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00356",
		linknext = "0009_00358",
		line = 4481,
	},
	["0009_00358"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00109", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fgact", ch="奈々瀬", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I silence Nanase and signal to him to continue.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我制止了喊叫的奈奈濑，用眼神示意他继续。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我制止了喊叫的奈奈瀨，用眼神示意他繼續。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00357",
		linknext = "0009_00359",
		line = 4495,
	},
	["0009_00359"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0016", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Yes. I ask of you only one thing in return.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“对了——为了这一切，我这边只有一个条件。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「對了——為了這一切，我這邊只有一個條件。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00358",
		linknext = "0009_00360",
		line = 4508,
	},
	["0009_00360"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0017", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“A girl named Kotoyose Fumino... I ask of you to find this girl before any other organization does, and to shelter her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“请比任何组织都快找到名为‘琴寄文乃’的少女，并保护她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「請比任何組織都快找到名為『琴寄文乃』的少女，並保護她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00359",
		linknext = "0009_00361",
		line = 4521,
	},
	["0009_00361"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Shelter? What do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“保护……怎么回事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「保護……怎麼回事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00360",
		linknext = "0009_00362",
		line = 4533,
	},
	["0009_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why do we have to shelter her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们为什么要保护那个孩子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們為什麼要保護那個孩子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00361",
		linknext = "0009_00363",
		line = 4544,
	},
	["0009_00363"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00103", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0308", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, actually... what's the reason for doing this? Who on earth is this girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“应该说……那个，什么意思？那个孩子究竟是什么人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「應該說……那個，什麼意思？那個孩子究竟是什麼人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00362",
		linknext = "0009_00364",
		line = 4558,
	},
	["0009_00364"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0018", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“This girl holds the power to fundamentally bring down the perverted sex law on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“这个女孩——身上拥有能从根本颠覆这个岛上的变态条例的可能性。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「這個女孩——身上擁有能從根本顛覆這個島上的變態條例的可能性。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00363",
		linknext = "0009_00365",
		line = 4571,
	},
	["0009_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fundamentally bring it down?",
					{"rt2"},
				},
			},
			cn = {
				{
					"从根本颠覆这个岛上的变态条例？",
					{"rt2"},
				},
			},
			tw = {
				{
					"從根本顛覆這個島上的變態條例？",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00364",
		linknext = "0009_00366",
		line = 4581,
	},
	["0009_00366"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There's someone out there who can do that?",
					{"rt2"},
				},
			},
			cn = {
				{
					"有这样的存在吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"有這樣的存在嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00365",
		linknext = "0009_00367",
		line = 4591,
	},
	["0009_00367"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Someone who can just shut down the perverted sex law...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"摧毁变态条例的，关键存在——？",
					{"rt2"},
				},
			},
			tw = {
				{
					"摧毀變態條例的，關鍵存在——？",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00366",
		linknext = "0009_00368",
		line = 4602,
	},
	["0009_00368"] = {
		{"bgm", stop=1},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0019", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“This base shall become the bridgehead which shall bring down that law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“这个基地将成为瓦解变态条例的桥头堡。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「這個基地將成為瓦解變態條例的橋頭堡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00367",
		linknext = "0009_00369",
		line = 4616,
	},
	["0009_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is this old guy for real?",
					{"rt2"},
				},
			},
			cn = {
				{
					"老人这么说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老人如此說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00368",
		linknext = "0009_00370",
		line = 4626,
	},
	["0009_00370"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0020", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You, young one who came running to this place. Is that not what you wish for?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“你不这么希望吗？逃到这里的男孩啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「你不這麼希望嗎？逃到這裡的男孩啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00369",
		linknext = "0009_00371",
		line = 4639,
	},
	["0009_00371"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He's right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……嗯，说得对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……嗯，說得對。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00370",
		linknext = "0009_00372",
		line = 4650,
	},
	["0009_00372"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0021", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Is that not what you truly desire? Not to merely run from the enemy, but to be gifted the means to fight back against them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“你难道不是这么希望的吗？希望得到的不是逃跑，而是战斗的手段。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「你難道不是這麼希望的嗎？希望得到的不是逃跑，而是戰鬥的手段。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00371",
		linknext = "0009_00373",
		line = 4663,
	},
	["0009_00373"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It's what I've always longed for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我已经渴望了很长时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我已經渴望了很長時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00372",
		linknext = "0009_00374",
		line = 4674,
	},
	["0009_00374"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0022", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“You can flee from the SHO all you like. But that makes you naught but a slave barking at your captors.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“逃离SHO的人啊。只能吠叫的奴隶啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「逃離SHO的人啊。只能吠叫的奴隸啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00373",
		linknext = "0009_00375",
		line = 4687,
	},
	["0009_00375"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A means to oppose this insane island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渴望能对抗这个疯狂岛屿的手段。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渴望能對抗這個瘋狂島嶼的手段。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00374",
		linknext = "0009_00376",
		line = 4698,
	},
	["0009_00376"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0023", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Do you not despise this law, which disregards and tramples on the rights of minorities?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“你不是仇恨抛弃少数人，践踏他们内心的这个条例吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「你不是仇恨拋棄少數人，踐踏他們內心的這個條例嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00375",
		linknext = "0009_00377",
		line = 4711,
	},
	["0009_00377"] = {
		{"se", id=0, loop=0, file="se_a105"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Facilities to fight the SS and SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渴望能与SHO和SS战斗的设备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渴望能與SHO和SS戰鬥的設備。",
