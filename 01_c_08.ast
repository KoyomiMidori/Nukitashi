			},
			en = {
				{
					"A voice ringing out, almost like it's coming from a speaker.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如同透过音响发出的电子音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如同透過音響發出的電子音。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00298",
		linknext = "0009_00300",
		line = 3741,
	},
	["0009_00300"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0300", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Wh-What was that!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“什、什么，刚刚的……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「什、什麼，剛剛的……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00299",
		linknext = "0009_00301",
		line = 3753,
	},
	["0009_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The origin of the voice is most likely on the other side of the stone wall in front of us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"似乎是从正面的岩石中发出的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"似乎是從正面的岩石中發出的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00300",
		linknext = "0009_00302",
		line = 3763,
	},
	["0009_00302"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0001", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Answer this question. Do you support the SHO?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“我在此发问——你是赞同SHO之人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「我在此發問——你是讚同SHO之人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00301",
		linknext = "0009_00303",
		line = 3775,
	},
	["0009_00303"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00103", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=5, head="nanase_01m", ch="奈々瀬", mw="mw", sync=0, time=300, mode=3, x=0, y=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00103", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么——？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼——？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00302",
		linknext = "0009_00304",
		line = 3789,
	},
	["0009_00304"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0002", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“Answer. Do you support the SHO, and the laws of this island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“在此发问……你是赞同SHO、赞同岛上条例之人吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「在此發問……你是讚同SHO、贊同島上條例之人嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00303",
		linknext = "0009_00305",
		line = 3801,
	},
	["0009_00305"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00112", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I did, I wouldn't be trying to escape from them by running all the way down here!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果是那种人的话——我就不会逃到这种地方了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果是那種人的話——我就不會逃到這種地方了！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00304",
		linknext = "0009_00306",
		line = 3813,
	},
	["0009_00306"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I unconsciously grow angry and shout at the voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不禁发怒，朝着突然传出的声音怒吼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不禁發怒，朝著突然傳出的聲音怒吼。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00305",
		linknext = "0009_00307",
		line = 3823,
	},
	["0009_00307"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0003", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "???"},
					"“In that case, I have one more question. Do you oppose the perverted sex law of this island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "？ ？ ？"},
					"“那我继续发问……你是仇恨这个岛、仇恨变态条例之人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "？？？"},
					"「那我繼續發問……你是仇恨這個島、仇恨變態條例之人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00306",
		linknext = "0009_00308",
		line = 3835,
	},
	["0009_00308"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You're damn right I do! You think I'd support such an idiotic law!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然了！这种乱来的条例——！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然了！這種亂來的條例——！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00307",
		linknext = "0009_00309",
		line = 3846,
	},
	["0009_00309"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00126", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even if the whole country accepts it, I never will!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算国家允许，我也绝对不会允许的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算國家允許，我也絕對不會允許的！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00308",
		linknext = "0009_00310",
		line = 3858,
	},
	["0009_00310"] = {
		{"text"},
		text = {
