					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啥……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啥……？」",
					{"rt2"},
