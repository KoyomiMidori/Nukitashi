					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh God, no...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“混乱……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「混亂……」",
					{"rt2"},
				},
