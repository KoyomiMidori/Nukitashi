		{"se", id=1, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00128", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mr. Kenzou! Is Fumino all right!?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……健藏先生！文乃没事吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……健藏先生！文乃沒事吧……！？」",
					{"rt2"},
				},
			},
		},
		linknext = "0129_00002",
		line = 45,
	},
	["0129_00002"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="kenzo0070", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"健蔵"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"健蔵", "Kenzou"},
					"“Yeah, the doc next door had a look at her today, but she still ain't fully conscious yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"健蔵", "健藏"},
					"“哦哦，刚才让对面的看过了……意识暂时还有些混乱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"健蔵", "健藏"},
					"「哦哦，剛才讓對面的看過了……意識暫時還有些混亂。」",
					{"rt2"},
				},
			},
		},
		linkback = "0129_00001",
		linknext = "0129_00003",
		line = 57,
	},
	["0129_00003"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00109", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
